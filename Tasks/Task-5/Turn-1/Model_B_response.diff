+from typing import Any, Optional
+from .interfaces import (
+    IFilterStrategy, 
+    IFilterProvider, 
+    IFilterableDataSource,
+    FilterCriteria,
+    FilterChangeEmitter,
+)
+
+
+class FilterManager(IFilterProvider, IFilterableDataSource):
+    """Central manager for coordinating filters on race data."""
+    
+    def __init__(self, emitter: FilterChangeEmitter = None):
+        self._strategies: dict[str, IFilterStrategy] = {}
+        self._active_filters: dict[str, FilterCriteria] = {}
+        self._items: list[dict] = []
+        self._emitter = emitter or FilterChangeEmitter()
+        self._cached_filter_values: dict[str, list[str]] = {}
+    
+    @property
+    def emitter(self) -> FilterChangeEmitter:
+        return self._emitter
+    
+    def register_strategy(self, strategy: IFilterStrategy) -> None:
+        """Register a filter strategy."""
+        self._strategies[strategy.get_filter_key()] = strategy
+    
+    def unregister_strategy(self, filter_key: str) -> None:
+        """Unregister a filter strategy."""
+        if filter_key in self._strategies:
+            del self._strategies[filter_key]
+            self.clear_filter(filter_key)
+    
+    def set_data(self, items: list[dict]) -> None:
+        """Set the data to be filtered."""
+        self._items = items
+        self._refresh_cached_filter_values()
+    
+    def _refresh_cached_filter_values(self) -> None:
+        """Refresh cached filter values for all registered strategies."""
+        for key, strategy in self._strategies.items():
+            self._cached_filter_values[key] = strategy.extract_filterable_values(self._items)
+    
+    def get_available_filters(self) -> list[str]:
+        """Get list of registered filter keys."""
+        return list(self._strategies.keys())
+    
+    def get_filter_options(self, filter_key: str) -> list[str]:
+        """Get available filter options for a specific filter."""
+        return self._cached_filter_values.get(filter_key, [])
+    
+    def refresh_filters(self, data_source: list[dict]) -> None:
+        """Refresh available filters based on current data."""
+        self.set_data(data_source)
+    
+    def get_all_items(self) -> list[dict]:
+        """Get all unfiltered items."""
+        return self._items
+    
+    def apply_filter(self, strategy: IFilterStrategy, criteria: FilterCriteria) -> list[dict]:
+        """Apply a filter and return filtered items."""
+        self._active_filters[strategy.get_filter_key()] = criteria
+        self._emitter.filter_changed.emit(strategy.get_filter_key(), criteria.value)
+        return self._get_filtered_items()
+    
+    def set_filter(self, filter_key: str, value: Any, display_name: str = "") -> list[dict]:
+        """Set a filter by key and value."""
+        if filter_key not in self._strategies:
+            return self._items
+        
+        strategy = self._strategies[filter_key]
+        criteria = FilterCriteria(
+            field_name=filter_key,
+            value=value,
+            display_name=display_name or str(value)
+        )
+        return self.apply_filter(strategy, criteria)
+    
+    def clear_filter(self, filter_key: str) -> list[dict]:
+        """Clear a specific filter and return items."""
+        if filter_key in self._active_filters:
+            del self._active_filters[filter_key]
+            self._emitter.filter_cleared.emit(filter_key)
+        return self._get_filtered_items()
+    
+    def clear_all_filters(self) -> list[dict]:
+        """Clear all filters and return unfiltered items."""
+        self._active_filters.clear()
+        self._emitter.filters_reset.emit()
+        return self._items
+    
+    def _get_filtered_items(self) -> list[dict]:
+        """Apply all active filters and return results."""
+        if not self._active_filters:
+            return self._items
+        
+        result = self._items
+        
+        for filter_key, criteria in self._active_filters.items():
+            strategy = self._strategies.get(filter_key)
+            if strategy:
+                result = [item for item in result if strategy.matches(item, criteria)]
+        
+        return result
+    
+    def get_active_filter(self, filter_key: str) -> Optional[FilterCriteria]:
+        """Get the active filter criteria for a key."""
+        return self._active_filters.get(filter_key)
+    
+    def is_filter_active(self, filter_key: str) -> bool:
+        """Check if a filter is currently active."""
+        return filter_key in self._active_filters
+
+
+class FilterManagerFactory:
+    """Factory for creating pre-configured FilterManager instances."""
+    
+    @staticmethod
+    def create_race_filter_manager() -> FilterManager:
+        """Create a FilterManager configured for race filtering."""
+        from .race_name_filter import RaceNameFilterStrategy
+        
+        manager = FilterManager()
+        manager.register_strategy(RaceNameFilterStrategy())
+        return manager
+    
+    @staticmethod
+    def create_with_strategies(*strategies: IFilterStrategy) -> FilterManager:
+        """Create a FilterManager with custom strategies."""
+        manager = FilterManager()
+        for strategy in strategies:
+            manager.register_strategy(strategy)
+        return manager
