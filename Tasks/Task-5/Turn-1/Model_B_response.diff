+from PySide6.QtWidgets import (
+    QWidget, QHBoxLayout, QVBoxLayout, QLabel, QComboBox, QPushButton
+)
+from PySide6.QtCore import Signal, Qt
+from typing import Optional
+
+from .interfaces import FilterChangeEmitter
+from .filter_manager import FilterManager
+
+
+class FilterComboBoxWidget(QWidget):
+    """A combo box widget for filter selection."""
+    
+    selection_changed = Signal(str)  # Emits selected value
+    cleared = Signal()
+    
+    def __init__(
+        self, 
+        label_text: str,
+        placeholder: str = "All",
+        parent: QWidget = None
+    ):
+        super().__init__(parent)
+        self._placeholder = placeholder
+        self._setup_ui(label_text)
+    
+    def _setup_ui(self, label_text: str) -> None:
+        layout = QHBoxLayout(self)
+        layout.setContentsMargins(0, 0, 0, 0)
+        
+        self._label = QLabel(label_text)
+        self._combo = QComboBox()
+        self._combo.setMinimumWidth(200)
+        self._combo.addItem(self._placeholder)
+        self._combo.currentTextChanged.connect(self._on_selection_changed)
+        
+        self._clear_btn = QPushButton("✕")
+        self._clear_btn.setFixedSize(24, 24)
+        self._clear_btn.setCursor(Qt.PointingHandCursor)
+        self._clear_btn.setToolTip("Clear filter")
+        self._clear_btn.clicked.connect(self._on_clear_clicked)
+        self._clear_btn.hide()
+        
+        layout.addWidget(self._label)
+        layout.addWidget(self._combo)
+        layout.addWidget(self._clear_btn)
+        layout.addStretch()
+    
+    def set_options(self, options: list[str]) -> None:
+        """Set the available filter options."""
+        current = self._combo.currentText()
+        self._combo.blockSignals(True)
+        self._combo.clear()
+        self._combo.addItem(self._placeholder)
+        for opt in options:
+            self._combo.addItem(opt)
+        
+        idx = self._combo.findText(current)
+        if idx >= 0:
+            self._combo.setCurrentIndex(idx)
+        else:
+            self._combo.setCurrentIndex(0)
+        
+        self._combo.blockSignals(False)
+    
+    def get_selected_value(self) -> Optional[str]:
+        """Get the currently selected filter value, or None if placeholder."""
+        text = self._combo.currentText()
+        return None if text == self._placeholder else text
+    
+    def set_selected_value(self, value: str) -> None:
+        """Set the selected value programmatically."""
+        idx = self._combo.findText(value)
+        if idx >= 0:
+            self._combo.setCurrentIndex(idx)
+    
+    def clear_selection(self) -> None:
+        """Reset to placeholder."""
+        self._combo.setCurrentIndex(0)
+        self._clear_btn.hide()
+    
+    def _on_selection_changed(self, text: str) -> None:
+        if text == self._placeholder:
+            self._clear_btn.hide()
+            self.cleared.emit()
+        else:
+            self._clear_btn.show()
+            self.selection_changed.emit(text)
+    
+    def _on_clear_clicked(self) -> None:
+        self.clear_selection()
+
+
+class RaceNameFilterWidget(FilterComboBoxWidget):
+    """Specialized filter widget for Grand Prix name filtering."""
+    
+    FILTER_KEY = "race_name"
+    
+    def __init__(self, parent: QWidget = None):
+        super().__init__(
+            label_text="Filter by GP:",
+            placeholder="All Grand Prix",
+            parent=parent
+        )
+    
+    def bind_to_manager(self, manager: FilterManager) -> None:
+        """Bind this widget to a FilterManager."""
+        self._manager = manager
+        
+        options = manager.get_filter_options(self.FILTER_KEY)
+        self.set_options(options)
+        
+        self.selection_changed.connect(self._on_filter_selected)
+        self.cleared.connect(self._on_filter_cleared)
+        
+        manager.emitter.filters_reset.connect(self.clear_selection)
+    
+    def _on_filter_selected(self, value: str) -> None:
+        if hasattr(self, '_manager'):
+            self._manager.set_filter(self.FILTER_KEY, value, value)
+    
+    def _on_filter_cleared(self) -> None:
+        if hasattr(self, '_manager'):
+            self._manager.clear_filter(self.FILTER_KEY)
+    
+    def refresh_options(self, manager: FilterManager) -> None:
+        """Refresh the available options from the manager."""
+        options = manager.get_filter_options(self.FILTER_KEY)
+        self.set_options(options)
+
+
+class FilterPanelWidget(QWidget):
+    """Container widget for multiple filters."""
+    
+    filters_changed = Signal()
+    
+    def __init__(self, parent: QWidget = None):
+        super().__init__(parent)
+        self._filter_widgets: dict[str, FilterComboBoxWidget] = {}
+        self._setup_ui()
+    
+    def _setup_ui(self) -> None:
+        self._layout = QHBoxLayout(self)
+        self._layout.setContentsMargins(0, 5, 0, 5)
+    
+    def add_filter_widget(self, key: str, widget: FilterComboBoxWidget) -> None:
+        """Add a filter widget to the panel."""
+        self._filter_widgets[key] = widget
+        self._layout.addWidget(widget)
+        
+        widget.selection_changed.connect(lambda: self.filters_changed.emit())
+        widget.cleared.connect(lambda: self.filters_changed.emit())
+    
+    def get_filter_widget(self, key: str) -> Optional[FilterComboBoxWidget]:
+        """Get a filter widget by key."""
+        return self._filter_widgets.get(key)
+    
+    def clear_all(self) -> None:
+        """Clear all filter widgets."""
+        for widget in self._filter_widgets.values():
+            widget.clear_selection()
