+import re
+from typing import Any
+from .interfaces import IFilterStrategy, FilterCriteria
+
+
+class RaceNameNormalizer:
+    """Handles normalization of Grand Prix names for consistent matching."""
+    
+    COMMON_SUFFIXES = [
+        "Grand Prix",
+        "GP",
+    ]
+    
+    COMMON_PREFIXES = [
+        "Formula 1",
+        "F1",
+    ]
+    
+    NAME_MAPPINGS = {
+        "emilia romagna": "emilia-romagna",
+        "emilia-romagna": "emilia-romagna",
+        "las vegas": "las-vegas",
+        "saudi arabian": "saudi-arabia",
+        "saudi arabia": "saudi-arabia",
+        "abu dhabi": "abu-dhabi",
+        "united states": "usa",
+        "us": "usa",
+        "american": "usa",
+        "great britain": "british",
+        "british": "british",
+        "gb": "british",
+        "uk": "british",
+    }
+    
+    @classmethod
+    def normalize(cls, name: str) -> str:
+        if not name:
+            return ""
+        
+        normalized = name.lower().strip()
+        
+        for prefix in cls.COMMON_PREFIXES:
+            if normalized.startswith(prefix.lower()):
+                normalized = normalized[len(prefix):].strip()
+        
+        for suffix in cls.COMMON_SUFFIXES:
+            if normalized.endswith(suffix.lower()):
+                normalized = normalized[:-len(suffix)].strip()
+        
+        for key, value in cls.NAME_MAPPINGS.items():
+            if key in normalized:
+                normalized = normalized.replace(key, value)
+        
+        normalized = re.sub(r'\s+', '-', normalized)
+        normalized = re.sub(r'[^a-z0-9-]', '', normalized)
+        normalized = re.sub(r'-+', '-', normalized)
+        normalized = normalized.strip('-')
+        
+        return normalized
+    
+    @classmethod
+    def extract_core_name(cls, event_name: str) -> str:
+        """Extract the core GP name from a full event name."""
+        normalized = cls.normalize(event_name)
+        return normalized if normalized else event_name
+
+
+class RaceNameFilterStrategy(IFilterStrategy):
+    """Filter strategy for filtering events by race/Grand Prix name."""
+    
+    FILTER_KEY = "race_name"
+    
+    def __init__(self, normalizer: RaceNameNormalizer = None):
+        self._normalizer = normalizer or RaceNameNormalizer()
+    
+    def matches(self, item: dict, criteria: FilterCriteria) -> bool:
+        if not criteria.value:
+            return True
+        
+        event_name = item.get("event_name", "")
+        normalized_event = self._normalizer.normalize(event_name)
+        normalized_criteria = self._normalizer.normalize(str(criteria.value))
+        
+        return normalized_criteria in normalized_event or normalized_event in normalized_criteria
+    
+    def get_filter_key(self) -> str:
+        return self.FILTER_KEY
+    
+    def extract_filterable_values(self, items: list[dict]) -> list[str]:
+        seen_normalized = {}
+        
+        for item in items:
+            event_name = item.get("event_name", "")
+            if not event_name:
+                continue
+            
+            normalized = self._normalizer.extract_core_name(event_name)
+            
+            if normalized not in seen_normalized:
+                seen_normalized[normalized] = event_name
+        
+        display_names = list(seen_normalized.values())
+        display_names.sort()
+        
+        return display_names
+    
+    def get_canonical_name(self, event_name: str) -> str:
+        """Get the canonical/normalized form of a GP name."""
+        return self._normalizer.extract_core_name(event_name)
