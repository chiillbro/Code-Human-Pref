+from abc import ABC, abstractmethod
+from typing import Any, Callable, Generic, TypeVar, Protocol
+from dataclasses import dataclass
+from PySide6.QtCore import Signal, QObject
+
+T = TypeVar('T')
+
+
+@dataclass
+class FilterCriteria:
+    field_name: str
+    value: Any
+    display_name: str = ""
+
+
+class IFilterStrategy(ABC):
+    """Interface for filter strategies that determine how filtering logic is applied."""
+    
+    @abstractmethod
+    def matches(self, item: dict, criteria: FilterCriteria) -> bool:
+        """Check if an item matches the filter criteria."""
+        pass
+    
+    @abstractmethod
+    def get_filter_key(self) -> str:
+        """Return the unique key for this filter strategy."""
+        pass
+    
+    @abstractmethod
+    def extract_filterable_values(self, items: list[dict]) -> list[str]:
+        """Extract unique filterable values from a list of items."""
+        pass
+
+
+class IFilterProvider(ABC):
+    """Interface for components that provide filter options."""
+    
+    @abstractmethod
+    def get_available_filters(self) -> list[str]:
+        """Get list of available filter values."""
+        pass
+    
+    @abstractmethod
+    def refresh_filters(self, data_source: list[dict]) -> None:
+        """Refresh available filters based on current data."""
+        pass
+
+
+class IFilterableDataSource(ABC):
+    """Interface for data sources that can be filtered."""
+    
+    @abstractmethod
+    def get_all_items(self) -> list[dict]:
+        """Get all unfiltered items."""
+        pass
+    
+    @abstractmethod
+    def apply_filter(self, strategy: IFilterStrategy, criteria: FilterCriteria) -> list[dict]:
+        """Apply a filter and return filtered items."""
+        pass
+    
+    @abstractmethod
+    def clear_filter(self, filter_key: str) -> list[dict]:
+        """Clear a specific filter and return items."""
+        pass
+
+
+class IFilterObserver(ABC):
+    """Interface for observers that react to filter changes."""
+    
+    @abstractmethod
+    def on_filter_changed(self, filter_key: str, new_value: Any) -> None:
+        """Called when a filter value changes."""
+        pass
+    
+    @abstractmethod
+    def on_filter_cleared(self, filter_key: str) -> None:
+        """Called when a filter is cleared."""
+        pass
+
+
+class FilterChangeEmitter(QObject):
+    """Qt signal emitter for filter changes."""
+    filter_changed = Signal(str, object)  # filter_key, new_value
+    filter_cleared = Signal(str)  # filter_key
+    filters_reset = Signal()
