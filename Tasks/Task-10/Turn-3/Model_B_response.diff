+            self._screen_outer_b = [self._world_to_screen_b(x, y) for x, y in self._track_b['world_outer']]
+        
+        self._leaderboard_a.x = half_width - leaderboard_width - 20
+        self._leaderboard_b.x = width - leaderboard_width - 20
+    
+    def _update_single_layout(self, width: int, height: int) -> None:
+        margin = 100
+        leaderboard_width = 240
+        
+        if self._track_a:
+            self._scale_a, self._tx_a, self._ty_a = self._compute_scaling(
+                self._track_a, left=margin, right=width - leaderboard_width - margin, bottom=80, top=height - 80
+            )
+            self._screen_inner_a = [self._world_to_screen_a(x, y) for x, y in self._track_a['world_inner']]
+            self._screen_outer_a = [self._world_to_screen_a(x, y) for x, y in self._track_a['world_outer']]
+        
+        self._leaderboard_a.x = width - leaderboard_width - 20
+    
+    def _compute_scaling(self, track: Dict[str, Any], left: float, right: float, bottom: float, top: float) -> Tuple[float, float, float]:
+        if not track:
+            return 1.0, 0.0, 0.0
+        
+        padding = 0.05
+        world_cx = (track['x_min'] + track['x_max']) / 2
+        world_cy = (track['y_min'] + track['y_max']) / 2
+        
+        cos_rot = track.get('cos_rot', 1.0)
+        sin_rot = track.get('sin_rot', 0.0)
+        
+        def rotate(x, y):
+            tx, ty = x - world_cx, y - world_cy
+            return tx * cos_rot - ty * sin_rot + world_cx, tx * sin_rot + ty * cos_rot + world_cy
+        
+        rotated_xs, rotated_ys = [], []
+        for x, y in track['world_inner'] + track['world_outer']:
+            rx, ry = rotate(x, y)
+            rotated_xs.append(rx)
+            rotated_ys.append(ry)
+        
+        if not rotated_xs or not rotated_ys:
+            return 1.0, 0.0, 0.0
+        
+        world_w = max(1.0, max(rotated_xs) - min(rotated_xs))
+        world_h = max(1.0, max(rotated_ys) - min(rotated_ys))
+        
+        usable_w = (right - left) * (1 - 2 * padding)
+        usable_h = (top - bottom) * (1 - 2 * padding)
+        
+        scale = min(usable_w / world_w, usable_h / world_h)
+        screen_cx = (left + right) / 2
+        screen_cy = (bottom + top) / 2
+        
+        return scale, screen_cx - scale * world_cx, screen_cy - scale * world_cy
+    
+    def _world_to_screen_a(self, x: float, y: float) -> Tuple[float, float]:
+        return self._world_to_screen(x, y, self._track_a, self._scale_a, self._tx_a, self._ty_a)
+    
+    def _world_to_screen_b(self, x: float, y: float) -> Tuple[float, float]:
+        return self._world_to_screen(x, y, self._track_b, self._scale_b, self._tx_b, self._ty_b)
+    
+    def _world_to_screen(self, x: float, y: float, track: Optional[Dict], scale: float, tx: float, ty: float) -> Tuple[float, float]:
+        if track is None:
+            return x * scale + tx, y * scale + ty
+        
+        world_cx = (track['x_min'] + track['x_max']) / 2
+        world_cy = (track['y_min'] + track['y_max']) / 2
+        cos_rot = track.get('cos_rot', 1.0)
+        sin_rot = track.get('sin_rot', 0.0)
+        
+        if sin_rot != 0.0:
+            dx, dy = x - world_cx, y - world_cy
+            x, y = dx * cos_rot - dy * sin_rot + world_cx, dx * sin_rot + dy * cos_rot + world_cy
+        
+        return x * scale + tx, y * scale + ty
+    
+    def _update_ui_positions(self, width: int, height: int) -> None:
+        self._progress_bar.on_resize(self)
+        self._race_controls.center_x = width // 2
+        self._race_controls.on_resize(self)
+        
+        if self._view_mode == ViewMode.SPLIT:
+            half_width = width // 2
+            self._lap_text_a.x, self._time_text_a.x, self._race_label_a.x = 20, 20, 20
+            self._lap_text_b.x, self._time_text_b.x, self._race_label_b.x = half_width + 20, half_width + 20, half_width + 20
+        else:
+            self._lap_text_a.x, self._time_text_a.x, self._race_label_a.x = 20, 20, 20
+        
+        self._lap_text_a.y = self._lap_text_b.y = height - 40
+        self._time_text_a.y = self._time_text_b.y = height - 65
+        self._race_label_a.y = self._race_label_b.y = height - 20
+        self._mode_text.x = self._sync_text.x = width // 2
+        self._mode_text.y, self._sync_text.y = height - 20, height - 40
+    
+    def on_resize(self, width: int, height: int) -> None:
+        super().on_resize(width, height)
+        self._update_layout(width, height)
+    
+    def on_draw(self) -> None:
+        self.clear()
+        
+        if self._bg_texture:
+            arcade.draw_lrbt_rectangle_textured(left=0, right=self.width, bottom=0, top=self.height, texture=self._bg_texture)
+        
+        if self._view_mode == ViewMode.SPLIT:
+            self._draw_split_view()
+        elif self._view_mode == ViewMode.OVERLAY:
+            self._draw_overlay_view()
+        elif self._view_mode == ViewMode.DIFFERENCE:
+            self._draw_difference_view()
+        
+        self._draw_common_ui()
+    
+    def _draw_split_view(self) -> None:
+        arcade.draw_line(self.width // 2, 0, self.width // 2, self.height, arcade.color.DARK_GRAY, 2)
+        
+        self._draw_track(self._screen_inner_a, self._screen_outer_a, self._get_track_color_a())
+        self._draw_track(self._screen_inner_b, self._screen_outer_b, self._get_track_color_b())
+        
+        frame_a = self._get_current_frame_a()
+        frame_b = self._get_current_frame_b()
+        
+        if frame_a:
+            self._draw_cars(frame_a, self._data.driver_colors_a, 'a')
+        if frame_b:
+            self._draw_cars(frame_b, self._data.driver_colors_b, 'b')
+        
+        if self._visible_hud:
+            if frame_a:
+                self._leaderboard_a.set_entries(self._build_leaderboard_entries(frame_a, self._data.driver_colors_a))
+            self._leaderboard_a.draw(self)
+            
+            if frame_b:
+                self._leaderboard_b.set_entries(self._build_leaderboard_entries(frame_b, self._data.driver_colors_b))
+                self._leaderboard_b.x = self.width - 220
+            self._leaderboard_b.draw(self)
+            
+            info_a, info_b = self._data.info_a, self._data.info_b
+            self._race_label_a.text = f"A: {info_a.event_name} {info_a.year}" if info_a else "Race A"
+            self._race_label_a.draw()
+            self._race_label_b.text = f"B: {info_b.event_name} {info_b.year}" if info_b else "Race B"
+            self._race_label_b.draw()
+            
+            self._draw_race_info(frame_a, self._lap_text_a, self._time_text_a, 'a')
+            self._draw_race_info(frame_b, self._lap_text_b, self._time_text_b, 'b')
+    
+    def _draw_overlay_view(self) -> None:
+        self._draw_track(self._screen_inner_a, self._screen_outer_a, self._get_track_color_a())
+        
+        frame_a, frame_b = self._get_current_frame_a(), self._get_current_frame_b()
+        
+        if frame_b:
+            self._draw_ghost_cars(frame_b, self._data.driver_colors_b)
+        if frame_a:
+            self._draw_cars(frame_a, self._data.driver_colors_a, 'a')
+        
+        if self._visible_hud and frame_a:
+            self._leaderboard_a.set_entries(self._build_leaderboard_entries(frame_a, self._data.driver_colors_a))
+            self._leaderboard_a.draw(self)
+        
+        if self._visible_hud:
+            info_a, info_b = self._data.info_a, self._data.info_b
+            label = f"{info_a.event_name} {info_a.year}" if info_a else "Race A"
+            label += f" vs {info_b.event_name} {info_b.year} (ghost)" if info_b else " vs Race B"
+            self._race_label_a.text = label
+            self._race_label_a.draw()
+            self._draw_race_info(frame_a, self._lap_text_a, self._time_text_a, 'a')
+    
+    def _draw_difference_view(self) -> None:
+        self._draw_track(self._screen_inner_a, self._screen_outer_a, (100, 100, 100))
+        
+        frame_a, frame_b = self._get_current_frame_a(), self._get_current_frame_b()
+        
+        if frame_a and frame_b:
+            deltas = compute_position_deltas(frame_a, frame_b, self._data.driver_colors_a, self._data.driver_colors_b)
+            self._draw_delta_cars(frame_a, deltas)
+            if self._visible_hud:
+                self._draw_delta_legend()
+        elif frame_a:
+            self._draw_cars(frame_a, self._data.driver_colors_a, 'a')
+        
+        if self._visible_hud and frame_a and frame_b:
+            self._draw_delta_leaderboard(frame_a, frame_b)
+        
+        if self._visible_hud:
+            info_a, info_b = self._data.info_a, self._data.info_b
+            label = f"Position Delta: {info_a.event_name} {info_a.year}" if info_a else "Race A"
+            label += f" vs {info_b.event_name} {info_b.year}" if info_b else " vs Race B"
+            self._race_label_a.text = label
+            self._race_label_a.draw()
+    
+    def _draw_track(self, inner_points: List[Tuple[float, float]], outer_points: List[Tuple[float, float]], color: Tuple[int, int, int]) -> None:
+        if len(inner_points) > 1:
+            arcade.draw_line_strip(inner_points, color, 3)
+        if len(outer_points) > 1:
+            arcade.draw_line_strip(outer_points, color, 3)
+    
+    def _draw_cars(self, frame: Dict[str, Any], driver_colors: Dict[str, Tuple[int, int, int]], track: str) -> None:
+        for code, pos in frame.get('drivers', {}).items():
+            sx, sy = self._world_to_screen_a(pos['x'], pos['y']) if track == 'a' else self._world_to_screen_b(pos['x'], pos['y'])
+            color = driver_colors.get(code, arcade.color.WHITE)
+            arcade.draw_circle_filled(sx, sy, 6, color)
+            if self._show_driver_labels:
+                arcade.draw_text(code, sx + 8, sy, color, 10, anchor_y="center", bold=True)
+    
+    def _draw_ghost_cars(self, frame: Dict[str, Any], driver_colors: Dict[str, Tuple[int, int, int]]) -> None:
+        for code, pos in frame.get('drivers', {}).items():
+            sx, sy = self._world_to_screen_a(pos['x'], pos['y'])
+            base_color = driver_colors.get(code, arcade.color.WHITE)
+            arcade.draw_circle_filled(sx, sy, 5, (*base_color[:3], 100))
+            arcade.draw_circle_outline(sx, sy, 6, base_color, 2)
+    
+    def _draw_delta_cars(self, frame_a: Dict[str, Any], deltas: Dict[str, Dict[str, Any]]) -> None:
+        for code, pos in frame_a.get('drivers', {}).items():
+            sx, sy = self._world_to_screen_a(pos['x'], pos['y'])
+            delta_info = deltas.get(code, {})
+            color = delta_info.get('color', (128, 128, 128))
+            arcade.draw_circle_filled(sx, sy, 6, color)
+            
+            delta = delta_info.get('delta')
+            if delta is not None and delta != 0:
+                arcade.draw_text(f"+{delta}" if delta > 0 else str(delta), sx + 8, sy + 4, color, 9, anchor_y="center", bold=True)
+            if self._show_driver_labels:
+                arcade.draw_text(code, sx + 8, sy - 8, arcade.color.WHITE, 10, anchor_y="center")
+    
+    def _draw_delta_legend(self) -> None:
+        arcade.draw_text("Position Delta:", 20, 150, arcade.color.WHITE, 12, bold=True)
+        for i, (color, label) in enumerate([((0, 180, 0), "Improved"), ((128, 128, 128), "Same"), ((180, 0, 0), "Worse")]):
+            y = 130 - i * 18
+            arcade.draw_circle_filled(28, y, 5, color)
+            arcade.draw_text(label, 40, y, arcade.color.LIGHT_GRAY, 11, anchor_y="center")
+    
+    def _draw_delta_leaderboard(self, frame_a: Dict[str, Any], frame_b: Dict[str, Any]) -> None:
+        deltas = compute_position_deltas(frame_a, frame_b, self._data.driver_colors_a, self._data.driver_colors_b)
+        entries = [(code, deltas.get(code, {}).get('color_a', arcade.color.WHITE), pos, pos.get('dist', 0.0))
+                   for code, pos in frame_a.get('drivers', {}).items()]
+        entries.sort(key=lambda x: x[3], reverse=True)
+        self._leaderboard_a.set_entries(entries)
+        self._leaderboard_a.draw(self)
+    
+    def _build_leaderboard_entries(self, frame: Dict[str, Any], driver_colors: Dict[str, Tuple[int, int, int]]) -> List[Tuple]:
+        entries = [(code, driver_colors.get(code, arcade.color.WHITE), pos, pos.get('dist', 0.0))
+                   for code, pos in frame.get('drivers', {}).items()]
+        entries.sort(key=lambda x: x[3], reverse=True)
+        return entries
+    
+    def _draw_race_info(self, frame: Optional[Dict], lap_text: arcade.Text, time_text: arcade.Text, race: str) -> None:
+        if not frame:
+            return
+        
+        leader_lap = max((d.get('lap', 1) for d in frame.get('drivers', {}).values()), default=1)
+        total_laps = self._data.get_total_laps(race)
+        lap_text.text = f"Lap: {leader_lap}" + (f"/{total_laps}" if total_laps > 0 else "")
+        lap_text.draw()
+        
+        t = frame.get('t', 0.0)
+        time_text.text = f"Time: {int(t // 3600):02}:{int((t % 3600) // 60):02}:{int(t % 60):02}"
+        time_text.draw()
+    
+    def _draw_common_ui(self) -> None:
+        if not self._visible_hud:
+            return
+        
+        view_names = {ViewMode.SPLIT: "Split View", ViewMode.OVERLAY: "Overlay View", ViewMode.DIFFERENCE: "Difference View"}
+        sync_names = {SyncMode.LAP_BASED: "Sync: Lap", SyncMode.TIME_BASED: "Sync: Time", SyncMode.DISTANCE_BASED: "Sync: Distance"}
+        
+        self._mode_text.text = view_names.get(self._view_mode, "")
+        self._mode_text.draw()
+        self._sync_text.text = sync_names.get(self._sync_controller.sync_mode, "")
+        self._sync_text.draw()
+        
+        arcade.draw_text(f"Speed: {self._playback_speed}x", self.width - 100, self.height - 20, arcade.color.WHITE, 12, anchor_y="top")
+        if self._paused:
+            arcade.draw_text("PAUSED", self.width - 100, self.height - 40, arcade.color.YELLOW, 12, anchor_y="top", bold=True)
+        
+        self._progress_bar.draw(self)
+        self._race_controls.draw(self)
+        self._controls_popup.draw(self)
+    
+    def _get_current_frame_a(self) -> Optional[Dict]:
+        idx = self._sync_controller.frame_index_a
+        return self._data.frames_a[idx] if 0 <= idx < len(self._data.frames_a) else None
+    
+    def _get_current_frame_b(self) -> Optional[Dict]:
+        idx = self._sync_controller.frame_index_b
+        return self._data.frames_b[idx] if 0 <= idx < len(self._data.frames_b) else None
+    
+    def _get_track_color_a(self) -> Tuple[int, int, int]:
+        return self._get_track_color_from_status(self._get_current_frame_a(), self._data.track_statuses_a)
+    
+    def _get_track_color_b(self) -> Tuple[int, int, int]:
+        return self._get_track_color_from_status(self._get_current_frame_b(), self._data.track_statuses_b)
+    
+    def _get_track_color_from_status(self, frame: Optional[Dict], track_statuses: List[Dict]) -> Tuple[int, int, int]:
+        if not frame:
+            return (150, 150, 150)
+        
+        current_time = frame.get('t', 0.0)
+        for status in track_statuses:
+            start, end = status.get('start_time', 0.0), status.get('end_time')
+            if start <= current_time and (end is None or current_time < end):
+                code = status.get('status', '')
+                if code == "2": return (220, 180, 0)
+                if code == "4": return (180, 100, 30)
+                if code == "5": return (200, 30, 30)
+                if code in ("6", "7"): return (200, 130, 50)
+        return (150, 150, 150)
+    
+    def on_update(self, delta_time: float) -> None:
+        self._race_controls.on_update(delta_time)
+        
+        seek_speed = 3.0 * max(1.0, self._playback_speed)
+        if self._is_rewinding:
+            self._sync_controller.advance(-delta_time * FPS * seek_speed)
+            self._race_controls.flash_button('rewind')
+        elif self._is_forwarding:
+            self._sync_controller.advance(delta_time * FPS * seek_speed)
+            self._race_controls.flash_button('forward')
+        
+        if not self._paused:
+            self._sync_controller.advance(delta_time * FPS * self._playback_speed)
+        
+        self._progress_bar._current_frame = self._sync_controller.frame_index_a
+    
+    def on_key_press(self, symbol: int, modifiers: int) -> None:
+        if symbol == arcade.key.ESCAPE:
+            arcade.close_window()
+        elif symbol == arcade.key.SPACE:
+            self._paused = not self._paused
+            self._race_controls.flash_button('play_pause')
+        elif symbol == arcade.key.RIGHT:
+            self._was_paused_before_hold, self._is_forwarding, self._paused = self._paused, True, True
+        elif symbol == arcade.key.LEFT:
+            self._was_paused_before_hold, self._is_rewinding, self._paused = self._paused, True, True
+        elif symbol == arcade.key.UP:
+            self._increase_speed()
+            self._race_controls.flash_button('speed_increase')
+        elif symbol == arcade.key.DOWN:
+            self._decrease_speed()
+            self._race_controls.flash_button('speed_decrease')
+        elif symbol == arcade.key.KEY_1: self._playback_speed = 0.5
+        elif symbol == arcade.key.KEY_2: self._playback_speed = 1.0
+        elif symbol == arcade.key.KEY_3: self._playback_speed = 2.0
+        elif symbol == arcade.key.KEY_4: self._playback_speed = 4.0
+        elif symbol == arcade.key.R:
+            self._sync_controller.seek(0)
+            self._playback_speed = 1.0
+            self._race_controls.flash_button('rewind')
+        elif symbol == arcade.key.V:
+            modes = list(ViewMode)
+            self._view_mode = modes[(modes.index(self._view_mode) + 1) % len(modes)]
+            self._update_layout(self.width, self.height)
+        elif symbol == arcade.key.S:
+            modes = list(SyncMode)
+            self._sync_controller.sync_mode = modes[(modes.index(self._sync_controller.sync_mode) + 1) % len(modes)]
+        elif symbol == arcade.key.L:
+            self._show_driver_labels = not self._show_driver_labels
+        elif symbol == arcade.key.D:
+            self._toggle_drs_zones = not self._toggle_drs_zones
+        elif symbol == arcade.key.H:
+            if self._controls_popup.visible:
+                self._controls_popup.hide()
+            else:
+                self._controls_popup.show_over(20.0, 20.0 + self._controls_popup.height)
+    
+    def on_key_release(self, symbol: int, modifiers: int) -> None:
+        if symbol == arcade.key.RIGHT:
+            self._is_forwarding, self._paused = False, self._was_paused_before_hold
+        elif symbol == arcade.key.LEFT:
+            self._is_rewinding, self._paused = False, self._was_paused_before_hold
+    
+    def on_mouse_press(self, x: float, y: float, button: int, modifiers: int) -> None:
+        if self._is_forwarding or self._is_rewinding:
+            self._is_forwarding = self._is_rewinding = False
+            self._paused = self._was_paused_before_hold
+            return
+        
+        if self._controls_popup.on_mouse_press(self, x, y, button, modifiers): return
+        if self._race_controls.on_mouse_press(self, x, y, button, modifiers): return
+        if self._progress_bar.on_mouse_press(self, x, y, button, modifiers):
+            self._sync_controller.seek(float(self._progress_bar._x_to_frame(x)))
+            return
+        self._leaderboard_a.on_mouse_press(self, x, y, button, modifiers)
+    
+    def on_mouse_motion(self, x: float, y: float, dx: float, dy: float) -> None:
+        self._progress_bar.on_mouse_motion(self, x, y, dx, dy)
+        self._race_controls.on_mouse_motion(self, x, y, dx, dy)
+    
+    def on_mouse_release(self, x: float, y: float, button: int, modifiers: int) -> None:
+        if self._is_forwarding or self._is_rewinding:
+            self._is_forwarding = self._is_rewinding = False
+            self._paused = self._was_paused_before_hold
+    
+    def _increase_speed(self) -> None:
+        if self._playback_speed < PLAYBACK_SPEEDS[-1]:
+            for spd in PLAYBACK_SPEEDS:
+                if spd > self._playback_speed:
+                    self._playback_speed = spd
+                    break
+    
+    def _decrease_speed(self) -> None:
+        if self._playback_speed > PLAYBACK_SPEEDS[0]:
+            for spd in reversed(PLAYBACK_SPEEDS):
+                if spd < self._playback_speed:
+                    self._playback_speed = spd
+                    break
+    
+    # Properties for compatibility
+    @property
+    def paused(self) -> bool: return self._paused
+    @paused.setter
+    def paused(self, v: bool): self._paused = v
+    @property
+    def playback_speed(self) -> float: return self._playback_speed
+    @playback_speed.setter
+    def playback_speed(self, v: float): self._playback_speed = self._validate_playback_speed(v)
+    @property
+    def frame_index(self) -> float: return self._sync_controller.frame_index_a_float
+    @frame_index.setter
+    def frame_index(self, v: float): self._sync_controller.seek(v)
+    @property
+    def n_frames(self) -> int: return len(self._data.frames_a)
+    @property
+    def is_rewinding(self) -> bool: return self._is_rewinding
+    @is_rewinding.setter
+    def is_rewinding(self, v: bool): self._is_rewinding = v
+    @property
+    def is_forwarding(self) -> bool: return self._is_forwarding
+    @is_forwarding.setter
+    def is_forwarding(self, v: bool): self._is_forwarding = v
+    @property
+    def was_paused_before_hold(self) -> bool: return self._was_paused_before_hold
+    @was_paused_before_hold.setter
+    def was_paused_before_hold(self, v: bool): self._was_paused_before_hold = v
+
+
+def run_comparison_replay(comparison_data: RaceComparisonData, playback_speed: float = 1.0) -> None:
+    if comparison_data is None or not comparison_data.is_loaded:
+        print("Error: Comparison data is not loaded")
+        return
+    
