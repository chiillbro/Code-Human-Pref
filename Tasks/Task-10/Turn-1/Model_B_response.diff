+    def _update_leaderboard(self, leaderboard: ComparisonLeaderboardComponent, frame: dict, race: RaceData):
+        """Update leaderboard entries from frame data."""
+        drivers_data = frame.get("drivers", {})
+        
+        entries = []
+        for code, pos in drivers_data.items():
+            color = race.driver_colors.get(code, arcade.color.WHITE)
+            progress_m = pos.get("dist", 0)
+            entries.append((code, color, pos, progress_m))
+            
+        entries.sort(key=lambda x: x[3], reverse=True)
+        leaderboard.set_entries(entries)
+        
+    def on_update(self, delta_time: float):
+        """Update playback state."""
+        self.controls_comp.on_update(delta_time)
+        
+        seek_speed = 3.0 * max(1.0, self.playback_speed)
+        
+        if self.is_rewinding:
+            self.frame_index = max(0.0, self.frame_index - delta_time * FPS * seek_speed)
+            self.controls_comp.flash_button('rewind')
+        elif self.is_forwarding:
+            max_frame = self.race_a.n_frames - 1
+            self.frame_index = min(max_frame, self.frame_index + delta_time * FPS * seek_speed)
+            self.controls_comp.flash_button('forward')
+            
+        if self.paused:
+            return
+            
+        self.frame_index += delta_time * FPS * self.playback_speed
+        
+        if self.frame_index >= self.race_a.n_frames:
+            self.frame_index = float(self.race_a.n_frames - 1)
+            
+    def on_key_press(self, symbol: int, modifiers: int):
+        """Handle keyboard input."""
+        if symbol == arcade.key.ESCAPE:
+            arcade.close_window()
+            return
+            
+        if symbol == arcade.key.SPACE:
+            self.paused = not self.paused
+            self.controls_comp.flash_button('play_pause')
+            
+        elif symbol == arcade.key.RIGHT:
+            self.was_paused_before_hold = self.paused
+            self.is_forwarding = True
+            self.paused = True
+            
+        elif symbol == arcade.key.LEFT:
+            self.was_paused_before_hold = self.paused
+            self.is_rewinding = True
+            self.paused = True
+            
+        elif symbol == arcade.key.UP:
+            self._increase_speed()
+            self.controls_comp.flash_button('speed_increase')
+            
+        elif symbol == arcade.key.DOWN:
+            self._decrease_speed()
+            self.controls_comp.flash_button('speed_decrease')
+            
+        elif symbol == arcade.key.V:
+            # Cycle view mode
+            modes = list(ViewMode)
+            idx = modes.index(self.view_mode)
+            self.view_mode = modes[(idx + 1) % len(modes)]
+            self._update_layout()
+            
+        elif symbol == arcade.key.S:
+            # Cycle sync mode
+            modes = list(SyncMode)
+            idx = modes.index(self.sync_mode)
+            self.sync_mode = modes[(idx + 1) % len(modes)]
+            self.sync_strategy = get_sync_strategy(self.sync_mode)
+            
+        elif symbol == arcade.key.R:
+            self.frame_index = 0.0
+            self.playback_speed = 1.0
+            self.controls_comp.flash_button('rewind')
+            
+        elif symbol == arcade.key.H:
+            if self.controls_popup.visible:
+                self.controls_popup.hide()
+            else:
+                self.controls_popup.show_over(20, 280)
+                
+        elif symbol == arcade.key.KEY_1:
+            self.playback_speed = 0.5
+        elif symbol == arcade.key.KEY_2:
+            self.playback_speed = 1.0
+        elif symbol == arcade.key.KEY_3:
+            self.playback_speed = 2.0
+        elif symbol == arcade.key.KEY_4:
+            self.playback_speed = 4.0
+            
+    def on_key_release(self, symbol: int, modifiers: int):
+        """Handle key release."""
+        if symbol == arcade.key.RIGHT:
+            self.is_forwarding = False
+            self.paused = self.was_paused_before_hold
+        elif symbol == arcade.key.LEFT:
+            self.is_rewinding = False
+            self.paused = self.was_paused_before_hold
+            
+    def _increase_speed(self):
+        """Increase playback speed."""
+        idx = PLAYBACK_SPEEDS.index(self.playback_speed) if self.playback_speed in PLAYBACK_SPEEDS else 3
+        if idx < len(PLAYBACK_SPEEDS) - 1:
+            self.playback_speed = PLAYBACK_SPEEDS[idx + 1]
+            
+    def _decrease_speed(self):
+        """Decrease playback speed."""
+        idx = PLAYBACK_SPEEDS.index(self.playback_speed) if self.playback_speed in PLAYBACK_SPEEDS else 3
+        if idx > 0:
+            self.playback_speed = PLAYBACK_SPEEDS[idx - 1]
+            
+    def on_mouse_press(self, x: float, y: float, button: int, modifiers: int):
+        """Handle mouse click."""
+        if self.controls_popup.on_mouse_press(self, x, y, button, modifiers):
+            return
+        if self.controls_comp.on_mouse_press(self, x, y, button, modifiers):
+            return
+        if self.progress_bar.on_mouse_press(self, x, y, button, modifiers):
+            return
+            
+    def on_mouse_release(self, x: float, y: float, button: int, modifiers: int):
+        """Handle mouse release."""
+        if self.is_forwarding or self.is_rewinding:
+            self.is_forwarding = False
+            self.is_rewinding = False
+            self.paused = self.was_paused_before_hold
+            
+    def on_mouse_motion(self, x: float, y: float, dx: float, dy: float):
+        """Handle mouse motion."""
+        self.progress_bar.on_mouse_motion(self, x, y, dx, dy)
+        self.controls_comp.on_mouse_motion(self, x, y, dx, dy)
+
+
+def run_comparison(race_a: RaceData, race_b: RaceData, title: str = "F1 Race Comparison"):
+    """Launch the comparison window."""
+    window = RaceComparisonWindow(race_a, race_b, title)
+    arcade.run()
