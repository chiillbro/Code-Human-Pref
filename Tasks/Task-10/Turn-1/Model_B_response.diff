+"""
+Race Comparison Window - Main visualization for comparing two F1 races.
+
+Supports three view modes:
+- Split: Side-by-side tracks with independent leaderboards
+- Overlay: Single track with ghost cars from second race
+- Difference: Position delta color coding
+
+And three sync modes:
+- Lap-based: Align by lap number
+- Time-based: Align by elapsed race time  
+- Distance-based: Align by track position percentage
+"""
+
+import os
+import arcade
+import numpy as np
