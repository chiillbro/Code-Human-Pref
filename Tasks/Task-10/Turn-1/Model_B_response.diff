+        leaderboard_y = window.height - 40
+        
+        # Draw race label header
+        if self.race_label:
+            arcade.Text(
+                self.race_label, self.x, leaderboard_y + 25,
+                arcade.color.LIGHT_GRAY, 14, bold=True,
+                anchor_x="left", anchor_y="top"
+            ).draw()
+            
+        # Draw standard leaderboard header
+        arcade.Text(
+            "Leaderboard", self.x, leaderboard_y,
+            arcade.color.WHITE, 18, bold=True,
+            anchor_x="left", anchor_y="top"
+        ).draw()
+        
+        self.rects = []
+        
+        # Sort entries
+        if any(e[2].get("lap", 0) > 1 for e in self.entries):
+            new_entries = sorted(
+                self.entries,
+                key=lambda e: (-e[2].get("lap", 0), -e[2].get("dist", 0))
+            )
+        else:
+            new_entries = self.entries
+            
+        for i, (code, color, pos, progress_m) in enumerate(new_entries):
+            current_pos = i + 1
+            top_y = leaderboard_y - 28 - ((current_pos - 1) * self.row_height)
+            
+            text_color = color
+            text = f"{current_pos}. {code}"
+            
+            # Add position delta indicator in difference mode
+            delta = self.position_deltas.get(code, 0)
+            if delta != 0:
+                if delta > 0:
+                    delta_text = f" ▲{delta}"
+                    delta_color = arcade.color.GREEN
+                else:
+                    delta_text = f" ▼{abs(delta)}"
+                    delta_color = arcade.color.RED
+                    
+                arcade.Text(
+                    text, self.x, top_y, text_color, 14,
+                    anchor_x="left", anchor_y="top"
+                ).draw()
+                arcade.Text(
+                    delta_text, self.x + 70, top_y, delta_color, 12,
+                    anchor_x="left", anchor_y="top"
+                ).draw()
+            else:
+                arcade.Text(
+                    text, self.x, top_y, text_color, 14,
+                    anchor_x="left", anchor_y="top"
+                ).draw()
