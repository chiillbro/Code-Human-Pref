+            info_b, self.width - 10, 100,
+            arcade.color.WHITE, 14,
+            anchor_x="right", anchor_y="center"
+        ).draw()
+        
+        # Leaderboards
+        self._update_leaderboard(self.leaderboard_a, frame_a, self.race_a)
+        self._update_leaderboard(self.leaderboard_b, frame_b, self.race_b)
+        
+        if self.view_mode == ViewMode.SPLIT:
+            self.leaderboard_a.draw(self)
+            self.leaderboard_b.x = self.width - 210
+            self.leaderboard_b.draw(self)
+        else:
+            # In overlay/difference, show both leaderboards on sides
+            self.leaderboard_a.draw(self)
+            self.leaderboard_b.x = self.width - 210
+            self.leaderboard_b.draw(self)
