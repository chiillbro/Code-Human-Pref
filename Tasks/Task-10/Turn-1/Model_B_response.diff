+"""
+Synchronization modes for race comparison.
+
+Provides different strategies for syncing two races:
+- Lap-based: Align by lap number
+- Time-based: Align by elapsed race time
+- Distance-based: Align by track position percentage
+"""
+
+from abc import ABC, abstractmethod
+from enum import Enum, auto
+from typing import Tuple, Optional
+import numpy as np
+
+
+class SyncMode(Enum):
+    """Available synchronization modes for race comparison."""
+    LAP = auto()
+    TIME = auto()
+    DISTANCE = auto()
+
+
+class BaseSyncStrategy(ABC):
+    """Base class for synchronization strategies."""
+    
+    @abstractmethod
+    def get_frame_indices(
+        self,
+        primary_frame_idx: int,
+        primary_frames: list,
+        secondary_frames: list,
+        primary_total_laps: int,
+        secondary_total_laps: int
+    ) -> Tuple[int, int]:
+        """
+        Get synchronized frame indices for both races.
+        
+        Args:
+            primary_frame_idx: Current frame index in primary race
+            primary_frames: Frame data for primary race
+            secondary_frames: Frame data for secondary race
+            primary_total_laps: Total laps in primary race
+            secondary_total_laps: Total laps in secondary race
+            
+        Returns:
+            Tuple of (primary_frame_idx, secondary_frame_idx)
+        """
+        pass
+
+
+class LapBasedSync(BaseSyncStrategy):
+    """
+    Synchronize races by lap number.
+    
+    Maps the current lap percentage in race A to the equivalent
+    lap percentage in race B. Useful for comparing how drivers
+    performed at similar race stages.
+    """
+    
+    def get_frame_indices(
+        self,
+        primary_frame_idx: int,
+        primary_frames: list,
+        secondary_frames: list,
+        primary_total_laps: int,
+        secondary_total_laps: int
+    ) -> Tuple[int, int]:
+        if not primary_frames or not secondary_frames:
+            return 0, 0
+            
+        primary_frame_idx = min(primary_frame_idx, len(primary_frames) - 1)
+        primary_frame = primary_frames[primary_frame_idx]
+        
+        # Get current lap in primary race
+        current_lap = primary_frame.get("lap", 1)
+        
+        # Calculate lap progress (0.0 to 1.0 within current lap)
+        primary_t = primary_frame.get("t", 0)
+        lap_progress = self._estimate_lap_progress(
+            primary_frame_idx, primary_frames, current_lap
+        )
+        
+        # Map to equivalent position in secondary race
+        # Scale lap to secondary race's lap count
+        scaled_lap = (current_lap / max(1, primary_total_laps)) * secondary_total_laps
+        target_lap = int(scaled_lap)
+        target_lap_progress = scaled_lap - target_lap
+        
+        # Find frame in secondary race at equivalent lap position
+        secondary_idx = self._find_frame_at_lap_position(
+            secondary_frames, target_lap, target_lap_progress
+        )
+        
+        return primary_frame_idx, secondary_idx
+    
+    def _estimate_lap_progress(
+        self, frame_idx: int, frames: list, current_lap: int
+    ) -> float:
+        """Estimate progress within current lap (0.0 to 1.0)."""
+        if frame_idx <= 0:
+            return 0.0
+            
+        # Find lap start and end frames
+        lap_start_idx = 0
+        lap_end_idx = len(frames) - 1
+        
+        for i in range(frame_idx, -1, -1):
+            if frames[i].get("lap", 1) < current_lap:
+                lap_start_idx = i + 1
+                break
+                
+        for i in range(frame_idx, len(frames)):
+            if frames[i].get("lap", 1) > current_lap:
+                lap_end_idx = i - 1
+                break
+                
+        lap_duration = lap_end_idx - lap_start_idx
+        if lap_duration <= 0:
+            return 0.0
+            
+        return (frame_idx - lap_start_idx) / lap_duration
+    
+    def _find_frame_at_lap_position(
+        self, frames: list, target_lap: int, lap_progress: float
+    ) -> int:
+        """Find frame index at specified lap and progress."""
+        if not frames:
+            return 0
+            
+        target_lap = max(1, target_lap)
+        
+        # Find lap boundaries
+        lap_start_idx = 0
+        lap_end_idx = len(frames) - 1
+        
+        for i, frame in enumerate(frames):
+            frame_lap = frame.get("lap", 1)
+            if frame_lap == target_lap and lap_start_idx == 0:
+                lap_start_idx = i
+            elif frame_lap > target_lap:
+                lap_end_idx = i - 1
+                break
+                
+        lap_duration = lap_end_idx - lap_start_idx
+        if lap_duration <= 0:
+            return lap_start_idx
+            
+        target_idx = lap_start_idx + int(lap_duration * lap_progress)
+        return min(max(0, target_idx), len(frames) - 1)
+
+
+class TimeBasedSync(BaseSyncStrategy):
+    """
+    Synchronize races by elapsed race time.
+    
+    Both races play at real-time alignment. Frame at t=60s in race A
+    corresponds to frame at t=60s in race B.
+    """
+    
+    def get_frame_indices(
+        self,
+        primary_frame_idx: int,
+        primary_frames: list,
+        secondary_frames: list,
+        primary_total_laps: int,
+        secondary_total_laps: int
+    ) -> Tuple[int, int]:
+        if not primary_frames or not secondary_frames:
+            return 0, 0
+            
+        primary_frame_idx = min(primary_frame_idx, len(primary_frames) - 1)
+        primary_t = primary_frames[primary_frame_idx].get("t", 0)
+        
+        # Binary search for closest time in secondary frames
+        secondary_idx = self._find_frame_at_time(secondary_frames, primary_t)
+        
+        return primary_frame_idx, secondary_idx
+    
+    def _find_frame_at_time(self, frames: list, target_time: float) -> int:
+        """Binary search for frame closest to target time."""
+        if not frames:
+            return 0
+            
+        left, right = 0, len(frames) - 1
+        
+        while left < right:
+            mid = (left + right) // 2
+            mid_time = frames[mid].get("t", 0)
+            
+            if mid_time < target_time:
+                left = mid + 1
+            else:
+                right = mid
+                
+        # Return closest frame
+        if left > 0:
+            prev_diff = abs(frames[left - 1].get("t", 0) - target_time)
+            curr_diff = abs(frames[left].get("t", 0) - target_time)
+            if prev_diff < curr_diff:
+                return left - 1
+                
+        return left
+
+
+class DistanceBasedSync(BaseSyncStrategy):
+    """
+    Synchronize races by track position percentage.
+    
+    Aligns races based on leader's distance around the track.
+    Useful for comparing specific track sections regardless of pace.
+    """
+    
+    def get_frame_indices(
+        self,
+        primary_frame_idx: int,
+        primary_frames: list,
+        secondary_frames: list,
+        primary_total_laps: int,
+        secondary_total_laps: int
+    ) -> Tuple[int, int]:
+        if not primary_frames or not secondary_frames:
+            return 0, 0
+            
+        primary_frame_idx = min(primary_frame_idx, len(primary_frames) - 1)
+        
+        # Calculate total race progress as percentage (lap + position within lap)
+        primary_progress = self._get_race_progress(
+            primary_frames[primary_frame_idx], primary_total_laps
+        )
+        
+        # Find equivalent progress in secondary race
+        secondary_idx = self._find_frame_at_progress(
+            secondary_frames, primary_progress, secondary_total_laps
+        )
+        
+        return primary_frame_idx, secondary_idx
+    
+    def _get_race_progress(self, frame: dict, total_laps: int) -> float:
+        """Calculate total race progress as fraction (0.0 to 1.0)."""
+        lap = frame.get("lap", 1)
+        
+        # Get leader's relative distance within lap (0-1)
+        drivers = frame.get("drivers", {})
+        if not drivers:
+            return (lap - 1) / max(1, total_laps)
+            
+        # Find leader's position
+        leader_rel_dist = 0.0
+        for code, pos in drivers.items():
+            rel_dist = pos.get("rel_dist", 0)
+            if rel_dist > leader_rel_dist:
+                leader_rel_dist = rel_dist
+                
+        # Total progress: completed laps + current lap progress
+        completed_laps_progress = (lap - 1) / max(1, total_laps)
+        current_lap_progress = leader_rel_dist / max(1, total_laps)
+        
+        return completed_laps_progress + current_lap_progress
+    
+    def _find_frame_at_progress(
+        self, frames: list, target_progress: float, total_laps: int
+    ) -> int:
+        """Find frame at specified race progress."""
+        if not frames:
+            return 0
+            
+        best_idx = 0
+        best_diff = float('inf')
+        
+        # Sample frames for efficiency (check every 10th frame)
+        sample_step = max(1, len(frames) // 100)
+        
+        for i in range(0, len(frames), sample_step):
+            progress = self._get_race_progress(frames[i], total_laps)
+            diff = abs(progress - target_progress)
+            
+            if diff < best_diff:
+                best_diff = diff
+                best_idx = i
+                
+        # Refine search around best candidate
+        start = max(0, best_idx - sample_step)
+        end = min(len(frames), best_idx + sample_step)
+        
+        for i in range(start, end):
+            progress = self._get_race_progress(frames[i], total_laps)
+            diff = abs(progress - target_progress)
+            
+            if diff < best_diff:
+                best_diff = diff
+                best_idx = i
+                
+        return best_idx
+
+
+def get_sync_strategy(mode: SyncMode) -> BaseSyncStrategy:
+    """Factory function to get sync strategy by mode."""
+    strategies = {
+        SyncMode.LAP: LapBasedSync(),
+        SyncMode.TIME: TimeBasedSync(),
+        SyncMode.DISTANCE: DistanceBasedSync(),
+    }
+    return strategies.get(mode, TimeBasedSync())
