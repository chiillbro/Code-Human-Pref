+class TrackRenderer:
+    """Handles rendering of a single track with its cars."""
+    
+    def __init__(self, race_data: RaceData):
+        self.race_data = race_data
+        
+        # Compute track geometry
+        geom = compute_track_geometry(race_data.example_lap)
+        self.plot_x_ref = geom['plot_x_ref']
+        self.plot_y_ref = geom['plot_y_ref']
+        self.x_inner = geom['x_inner']
+        self.y_inner = geom['y_inner']
+        self.x_outer = geom['x_outer']
+        self.y_outer = geom['y_outer']
+        self.x_min, self.x_max, self.y_min, self.y_max = geom['bounds']
+        
+        # Pre-interpolate track points
+        self.world_inner_points = interpolate_track_points(self.x_inner, self.y_inner)
+        self.world_outer_points = interpolate_track_points(self.x_outer, self.y_outer)
+        
+        # Screen coordinates (updated on resize)
+        self.screen_inner_points = []
+        self.screen_outer_points = []
+        
+        # Transform parameters
+        self.scale = 1.0
+        self.tx = 0
+        self.ty = 0
+        
+        # Rotation
+        self.rotation = race_data.circuit_rotation
+        self._rot_rad = float(np.deg2rad(self.rotation)) if self.rotation else 0.0
+        self._cos_rot = float(np.cos(self._rot_rad))
+        self._sin_rot = float(np.sin(self._rot_rad))
+        
+    def update_viewport(self, left: float, right: float, bottom: float, top: float, padding: float = 0.05):
+        """Update rendering transform for given viewport."""
+        width = max(1.0, right - left)
+        height = max(1.0, top - bottom)
+        
+        # World center
+        world_cx = (self.x_min + self.x_max) / 2
+        world_cy = (self.y_min + self.y_max) / 2
+        
+        # Compute rotated bounds
+        def rotate_point(x, y):
+            tx = x - world_cx
+            ty = y - world_cy
+            rx = tx * self._cos_rot - ty * self._sin_rot
+            ry = tx * self._sin_rot + ty * self._cos_rot
+            return rx + world_cx, ry + world_cy
+            
+        rotated_xs = []
+        rotated_ys = []
+        for x, y in self.world_inner_points + self.world_outer_points:
+            rx, ry = rotate_point(x, y)
+            rotated_xs.append(rx)
+            rotated_ys.append(ry)
+            
+        world_x_min = min(rotated_xs) if rotated_xs else self.x_min
+        world_x_max = max(rotated_xs) if rotated_xs else self.x_max
+        world_y_min = min(rotated_ys) if rotated_ys else self.y_min
+        world_y_max = max(rotated_ys) if rotated_ys else self.y_max
+        
+        world_w = max(1.0, world_x_max - world_x_min)
+        world_h = max(1.0, world_y_max - world_y_min)
+        
+        usable_w = width * (1 - 2 * padding)
+        usable_h = height * (1 - 2 * padding)
+        
+        scale_x = usable_w / world_w
+        scale_y = usable_h / world_h
+        self.scale = min(scale_x, scale_y)
+        
+        screen_cx = left + width / 2
+        screen_cy = bottom + height / 2
+        
+        self.tx = screen_cx - self.scale * world_cx
+        self.ty = screen_cy - self.scale * world_cy
+        
+        # Update screen points
+        self.screen_inner_points = [self.world_to_screen(x, y) for x, y in self.world_inner_points]
+        self.screen_outer_points = [self.world_to_screen(x, y) for x, y in self.world_outer_points]
+        
+    def world_to_screen(self, x: float, y: float) -> Tuple[float, float]:
+        """Transform world coordinates to screen coordinates."""
+        world_cx = (self.x_min + self.x_max) / 2
+        world_cy = (self.y_min + self.y_max) / 2
+        
+        if self._rot_rad:
+            tx = x - world_cx
+            ty = y - world_cy
+            rx = tx * self._cos_rot - ty * self._sin_rot
+            ry = tx * self._sin_rot + ty * self._cos_rot
+            x, y = rx + world_cx, ry + world_cy
+            
+        return self.scale * x + self.tx, self.scale * y + self.ty
+        
+    def draw_track(self, color: Tuple[int, int, int] = (150, 150, 150), line_width: int = 4):
+        """Draw track boundaries."""
+        if len(self.screen_inner_points) > 1:
+            arcade.draw_line_strip(self.screen_inner_points, color, line_width)
+        if len(self.screen_outer_points) > 1:
+            arcade.draw_line_strip(self.screen_outer_points, color, line_width)
+            
+    def draw_cars(
+        self, 
+        frame: dict, 
+        driver_colors: Dict[str, tuple],
+        ghost: bool = False,
+        alpha: int = 255
+    ):
+        """Draw cars at their positions from frame data."""
+        drivers_data = frame.get("drivers", {})
+        
+        for code, pos in drivers_data.items():
+            x, y = pos.get("x", 0), pos.get("y", 0)
+            sx, sy = self.world_to_screen(x, y)
+            
+            color = driver_colors.get(code, arcade.color.WHITE)
+            if ghost:
+                # Semi-transparent for ghost cars
+                color = (*color[:3], alpha)
+                arcade.draw_circle_filled(sx, sy, 5, color)
+                # Draw outline for visibility
+                arcade.draw_circle_outline(sx, sy, 6, arcade.color.WHITE, 1)
+            else:
+                arcade.draw_circle_filled(sx, sy, 6, color)
+
