+"""
+Dual Race Picker Dialog for race comparison.
+
+Provides a Qt dialog for selecting two races to compare.
+"""
+
+from PySide6.QtWidgets import (
+    QDialog, QVBoxLayout, QHBoxLayout, QLabel, QComboBox,
+    QPushButton, QGroupBox, QMessageBox, QProgressDialog, QApplication
+)
+from PySide6.QtCore import Qt, QThread, Signal
+from src.f1_data import get_race_weekends_by_year, load_session, enable_cache
+
+
+class FetchScheduleWorker(QThread):
+    """Worker thread to fetch race schedule."""
+    result = Signal(object)
+    error = Signal(str)
+    
+    def __init__(self, year, parent=None):
+        super().__init__(parent)
+        self.year = year
+        
+    def run(self):
+        try:
+            enable_cache()
+            events = get_race_weekends_by_year(self.year)
+            self.result.emit(events)
+        except Exception as e:
+            self.error.emit(str(e))
+
+
+class RaceComparisonDialog(QDialog):
+    """
+    Dialog for selecting two races to compare.
+    
+    Allows user to pick:
+    - Race A: Year and Round
+    - Race B: Year and Round
+    """
+    
+    def __init__(self, parent=None):
+        super().__init__(parent)
+        self.setWindowTitle("Compare Races")
+        self.setMinimumSize(600, 400)
+        
+        # Store selected races
+        self.race_a_selection = None
+        self.race_b_selection = None
+        
+        # Cache for schedules
+        self._schedule_cache = {}
+        self._workers = []
+        
+        self._setup_ui()
+        
+    def _setup_ui(self):
+        """Build the dialog UI."""
+        layout = QVBoxLayout(self)
+        
+        # Header
+        header = QLabel("Select two races to compare")
+        header.setStyleSheet("font-size: 16px; font-weight: bold; margin-bottom: 10px;")
+        layout.addWidget(header)
+        
+        # Race selection panels side by side
+        races_layout = QHBoxLayout()
+        
+        # Race A panel
+        self.race_a_group = self._create_race_panel("Race A (Primary)")
+        races_layout.addWidget(self.race_a_group)
+        
+        # Race B panel
+        self.race_b_group = self._create_race_panel("Race B (Comparison)")
+        races_layout.addWidget(self.race_b_group)
+        
+        layout.addLayout(races_layout)
+        
+        # Buttons
+        button_layout = QHBoxLayout()
+        button_layout.addStretch()
+        
+        self.compare_btn = QPushButton("Compare")
+        self.compare_btn.setEnabled(False)
+        self.compare_btn.clicked.connect(self.accept)
+        self.compare_btn.setStyleSheet("padding: 8px 24px; font-weight: bold;")
+        
+        cancel_btn = QPushButton("Cancel")
+        cancel_btn.clicked.connect(self.reject)
+        cancel_btn.setStyleSheet("padding: 8px 24px;")
+        
+        button_layout.addWidget(cancel_btn)
+        button_layout.addWidget(self.compare_btn)
+        
+        layout.addLayout(button_layout)
+        
+        # Load initial schedules
+        current_year = 2025
+        self._load_schedule('a', current_year)
+        self._load_schedule('b', current_year)
+        
+    def _create_race_panel(self, title: str) -> QGroupBox:
+        """Create a race selection panel."""
+        group = QGroupBox(title)
+        layout = QVBoxLayout(group)
+        
+        # Determine panel ID from title
+        panel_id = 'a' if 'A' in title else 'b'
+        
+        # Year selection
+        year_layout = QHBoxLayout()
+        year_label = QLabel("Year:")
+        year_combo = QComboBox()
+        year_combo.setObjectName(f"year_{panel_id}")
+        
+        current_year = 2025
+        for year in range(current_year, 2009, -1):
+            year_combo.addItem(str(year))
+        year_combo.setCurrentText(str(current_year))
+        year_combo.currentTextChanged.connect(
+            lambda y, pid=panel_id: self._on_year_changed(pid, int(y))
+        )
+        
+        year_layout.addWidget(year_label)
+        year_layout.addWidget(year_combo, 1)
+        layout.addLayout(year_layout)
+        
+        # Round selection
+        round_layout = QHBoxLayout()
+        round_label = QLabel("Round:")
+        round_combo = QComboBox()
+        round_combo.setObjectName(f"round_{panel_id}")
+        round_combo.currentIndexChanged.connect(
+            lambda idx, pid=panel_id: self._on_round_changed(pid)
+        )
+        
+        round_layout.addWidget(round_label)
+        round_layout.addWidget(round_combo, 1)
+        layout.addLayout(round_layout)
+        
+        # Info label
+        info_label = QLabel("")
+        info_label.setObjectName(f"info_{panel_id}")
+        info_label.setStyleSheet("color: gray; font-size: 11px;")
+        layout.addWidget(info_label)
+        
+        layout.addStretch()
+        
+        return group
+        
+    def _get_widget(self, panel_id: str, name: str):
+        """Get widget by panel ID and name."""
+        from PySide6.QtWidgets import QComboBox, QLabel
+        group = self.race_a_group if panel_id == 'a' else self.race_b_group
+        widget_type = QLabel if name == 'info' else QComboBox
+        return group.findChild(widget_type, f"{name}_{panel_id}")
+        
+    def _on_year_changed(self, panel_id: str, year: int):
+        """Handle year selection change."""
+        self._load_schedule(panel_id, year)
+        
+    def _load_schedule(self, panel_id: str, year: int):
+        """Load race schedule for specified year."""
+        # Check cache
+        if year in self._schedule_cache:
+            self._populate_rounds(panel_id, self._schedule_cache[year])
+            return
+            
+        round_combo = self._get_widget(panel_id, 'round')
+        if round_combo:
+            round_combo.clear()
+            round_combo.addItem("Loading...")
+            round_combo.setEnabled(False)
+            
+        worker = FetchScheduleWorker(year)
+        worker.result.connect(
+            lambda events, pid=panel_id, y=year: self._on_schedule_loaded(pid, y, events)
+        )
+        worker.error.connect(
+            lambda msg, pid=panel_id: self._on_schedule_error(pid, msg)
+        )
+        self._workers.append(worker)
+        worker.start()
+        
+    def _on_schedule_loaded(self, panel_id: str, year: int, events: list):
+        """Handle schedule load completion."""
+        self._schedule_cache[year] = events
+        self._populate_rounds(panel_id, events)
+        
+    def _on_schedule_error(self, panel_id: str, message: str):
+        """Handle schedule load error."""
+        round_combo = self._get_widget(panel_id, 'round')
+        if round_combo:
+            round_combo.clear()
+            round_combo.addItem("Error loading")
+            round_combo.setEnabled(False)
+            
+    def _populate_rounds(self, panel_id: str, events: list):
+        """Populate round combo with events."""
+        round_combo = self._get_widget(panel_id, 'round')
+        if not round_combo:
+            return
+            
+        round_combo.clear()
+        round_combo.setEnabled(True)
+        
+        for event in events:
+            round_num = event.get('round_number', 0)
+            name = event.get('event_name', 'Unknown')
+            round_combo.addItem(f"R{round_num}: {name}", event)
+            
+        self._on_round_changed(panel_id)
+        
+    def _on_round_changed(self, panel_id: str):
+        """Handle round selection change."""
+        round_combo = self._get_widget(panel_id, 'round')
+        info_label = self._get_widget(panel_id, 'info')
+        
+        if not round_combo:
+            return
+            
+        event = round_combo.currentData()
+        
+        if event and info_label:
+            country = event.get('country', '')
