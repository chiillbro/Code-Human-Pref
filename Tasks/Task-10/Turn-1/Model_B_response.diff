+    LeaderboardComponent, WeatherComponent, RaceControlsComponent,
+    ControlsPopupComponent, RaceProgressBarComponent
+)
+from src.comparison.comparison_controls import ComparisonControlsPopup
+
+
+SCREEN_WIDTH = 1600
