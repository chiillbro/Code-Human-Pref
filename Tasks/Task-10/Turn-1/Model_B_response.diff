+        
+        # Text objects for HUD
+        self.mode_text = arcade.Text("", 0, 0, arcade.color.WHITE, 14)
+        self.info_text_a = arcade.Text("", 0, 0, arcade.color.WHITE, 16)
+        self.info_text_b = arcade.Text("", 0, 0, arcade.color.WHITE, 16)
+        
+    def _update_layout(self):
+        """Update component layouts based on window size and view mode."""
+        if self.view_mode == ViewMode.SPLIT:
+            # Split view: two tracks side by side
+            mid_x = self.width // 2
+            track_bottom = 120
+            track_top = self.height - 60
+            
+            # Left track (Race A)
+            self.renderer_a.update_viewport(
+                left=220, right=mid_x - 10,
+                bottom=track_bottom, top=track_top
+            )
+            # Right track (Race B)
+            self.renderer_b.update_viewport(
+                left=mid_x + 10, right=self.width - 220,
+                bottom=track_bottom, top=track_top
+            )
+            
+            # Leaderboards
+            self.leaderboard_a.x = 10
+            self.leaderboard_b.x = self.width - 210
+            
+        else:
+            # Overlay/Difference: single track centered
+            self.renderer_a.update_viewport(
+                left=220, right=self.width - 220,
+                bottom=120, top=self.height - 60
+            )
+            self.leaderboard_a.x = 10
+            self.leaderboard_b.x = self.width - 210
+            
+        # Update controls position
+        self.controls_comp.center_x = self.width // 2
+        self.controls_comp.on_resize(self)
+        
+        self.progress_bar.on_resize(self)
+        
+    def on_resize(self, width: int, height: int):
+        """Handle window resize."""
+        super().on_resize(width, height)
+        self._update_layout()
+        
+    def _get_synchronized_frames(self) -> Tuple[int, int]:
+        """Get frame indices for both races based on sync mode."""
+        primary_idx = int(self.frame_index)
+        
+        idx_a, idx_b = self.sync_strategy.get_frame_indices(
+            primary_idx,
+            self.race_a.frames,
+            self.race_b.frames,
+            self.race_a.total_laps,
+            self.race_b.total_laps
+        )
+        
+        return idx_a, idx_b
+        
+    def on_draw(self):
+        """Render the comparison view."""
+        self.clear()
+        
+        # Background
+        if self.bg_texture:
+            arcade.draw_lrbt_rectangle_textured(
+                left=0, right=self.width,
+                bottom=0, top=self.height,
+                texture=self.bg_texture
+            )
+            
+        # Get synchronized frame indices
+        idx_a, idx_b = self._get_synchronized_frames()
+        idx_a = min(idx_a, self.race_a.n_frames - 1)
+        idx_b = min(idx_b, self.race_b.n_frames - 1)
+        
+        frame_a = self.race_a.frames[idx_a] if self.race_a.frames else {}
+        frame_b = self.race_b.frames[idx_b] if self.race_b.frames else {}
+        
+        if self.view_mode == ViewMode.SPLIT:
+            self._draw_split_view(frame_a, frame_b)
+        elif self.view_mode == ViewMode.OVERLAY:
+            self._draw_overlay_view(frame_a, frame_b)
+        else:  # DIFFERENCE
+            self._draw_difference_view(frame_a, frame_b, idx_a, idx_b)
+            
+        # Draw common UI
+        self._draw_ui(frame_a, frame_b, idx_a, idx_b)
+        
+    def _draw_split_view(self, frame_a: dict, frame_b: dict):
+        """Draw side-by-side tracks."""
+        # Draw divider
+        mid_x = self.width // 2
+        arcade.draw_line(mid_x, 100, mid_x, self.height - 40, arcade.color.GRAY, 2)
+        
+        # Track A
+        self.renderer_a.draw_track()
+        self.renderer_a.draw_cars(frame_a, self.race_a.driver_colors)
+        
+        # Track B
+        self.renderer_b.draw_track()
+        self.renderer_b.draw_cars(frame_b, self.race_b.driver_colors)
+        
+        # Race labels
+        arcade.Text(
+            f"{self.race_a.event_name} {self.race_a.year}",
+            mid_x // 2, self.height - 30,
+            arcade.color.WHITE, 16, bold=True,
+            anchor_x="center", anchor_y="center"
+        ).draw()
+        
+        arcade.Text(
+            f"{self.race_b.event_name} {self.race_b.year}",
+            mid_x + mid_x // 2, self.height - 30,
+            arcade.color.WHITE, 16, bold=True,
+            anchor_x="center", anchor_y="center"
+        ).draw()
+        
+    def _draw_overlay_view(self, frame_a: dict, frame_b: dict):
+        """Draw single track with ghost cars from race B."""
+        # Draw primary track
+        self.renderer_a.draw_track()
+        
+        # Draw Race B cars as ghosts (semi-transparent)
+        # Need to project race B positions onto race A track
+        self._draw_ghost_cars(frame_b)
+        
+        # Draw Race A cars normally
+        self.renderer_a.draw_cars(frame_a, self.race_a.driver_colors)
+        
+        # Legend
+        arcade.Text(
+            f"● {self.race_a.event_name} {self.race_a.year}",
+            self.width // 2 - 150, self.height - 30,
+            arcade.color.WHITE, 14,
+            anchor_x="left", anchor_y="center"
+        ).draw()
+        arcade.Text(
+            f"○ {self.race_b.event_name} {self.race_b.year} (ghost)",
+            self.width // 2 + 20, self.height - 30,
+            arcade.color.LIGHT_GRAY, 14,
+            anchor_x="left", anchor_y="center"
+        ).draw()
+        
+    def _draw_ghost_cars(self, frame_b: dict):
+        """Draw ghost cars from race B on race A's track."""
+        drivers_b = frame_b.get("drivers", {})
+        
+        for code, pos in drivers_b.items():
+            # Use relative distance to position on track A
+            rel_dist = pos.get("rel_dist", 0)
+            
+            # Find position on race A track at same relative distance
+            ref_idx = int(rel_dist * (len(self.renderer_a.plot_x_ref) - 1))
+            ref_idx = max(0, min(ref_idx, len(self.renderer_a.plot_x_ref) - 1))
+            
+            x = float(self.renderer_a.plot_x_ref.iloc[ref_idx])
+            y = float(self.renderer_a.plot_y_ref.iloc[ref_idx])
+            
+            sx, sy = self.renderer_a.world_to_screen(x, y)
+            
+            color = self.race_b.driver_colors.get(code, arcade.color.WHITE)
+            # Draw as hollow circle
+            arcade.draw_circle_outline(sx, sy, 6, color, 2)
+            # Small label
+            arcade.draw_text(code, sx + 8, sy, (*color, 180), 9)
+            
+    def _draw_difference_view(self, frame_a: dict, frame_b: dict, idx_a: int, idx_b: int):
+        """Draw with position delta color coding."""
+        # Calculate position deltas
+        deltas = self.comparison.get_position_deltas(idx_a, idx_b)
+        
+        # Draw track
+        self.renderer_a.draw_track()
+        
+        # Draw cars with color indicating position change
+        drivers_a = frame_a.get("drivers", {})
+        
+        for code, pos in drivers_a.items():
+            x, y = pos.get("x", 0), pos.get("y", 0)
+            sx, sy = self.renderer_a.world_to_screen(x, y)
+            
+            delta = deltas.get(code, 0)
+            
+            if delta > 0:
+                # Gained positions - green
+                color = arcade.color.GREEN
+            elif delta < 0:
+                # Lost positions - red
+                color = arcade.color.RED
+            else:
+                # Same position - original color
+                color = self.race_a.driver_colors.get(code, arcade.color.WHITE)
+                
+            arcade.draw_circle_filled(sx, sy, 6, color)
+            
+            # Show delta text next to car
+            if delta != 0:
+                delta_str = f"+{delta}" if delta > 0 else str(delta)
+                arcade.draw_text(delta_str, sx + 8, sy, color, 10, bold=True)
+                
+        # Update leaderboards with deltas
+        self.leaderboard_a.set_position_deltas(deltas)
+        inverted_deltas = {k: -v for k, v in deltas.items()}
+        self.leaderboard_b.set_position_deltas(inverted_deltas)
+        
+        # Legend
+        arcade.Text(
+            "Position Delta: ",
+            self.width // 2 - 120, self.height - 30,
+            arcade.color.WHITE, 14,
+            anchor_x="left", anchor_y="center"
+        ).draw()
+        arcade.draw_circle_filled(self.width // 2, self.height - 30, 6, arcade.color.GREEN)
+        arcade.Text(
+            " Gained  ",
+            self.width // 2 + 10, self.height - 30,
+            arcade.color.GREEN, 12,
+            anchor_x="left", anchor_y="center"
+        ).draw()
+        arcade.draw_circle_filled(self.width // 2 + 80, self.height - 30, 6, arcade.color.RED)
+        arcade.Text(
+            " Lost",
+            self.width // 2 + 90, self.height - 30,
+            arcade.color.RED, 12,
+            anchor_x="left", anchor_y="center"
+        ).draw()
+        
+    def _draw_ui(self, frame_a: dict, frame_b: dict, idx_a: int, idx_b: int):
+        """Draw common UI elements."""
