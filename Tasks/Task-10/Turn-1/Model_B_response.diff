+class RaceComparisonWindow(arcade.Window):
+    """
+    Main window for comparing two F1 races side-by-side.
+    """
+    
+    def __init__(
+        self,
+        race_a: RaceData,
+        race_b: RaceData,
+        title: str = "F1 Race Comparison"
+    ):
+        super().__init__(SCREEN_WIDTH, SCREEN_HEIGHT, title, resizable=True)
+        self.maximize()
+        
+        # Store race data
+        self.race_a = race_a
+        self.race_b = race_b
+        self.comparison = ComparisonData(race_a, race_b)
+        
+        # Track renderers
+        self.renderer_a = TrackRenderer(race_a)
+        self.renderer_b = TrackRenderer(race_b)
+        
+        # Playback state
+        self.frame_index = 0.0
+        self.paused = False
+        self.playback_speed = 1.0
+        
+        # View and sync modes
+        self.view_mode = ViewMode.SPLIT
+        self.sync_mode = SyncMode.TIME
+        self.sync_strategy = get_sync_strategy(self.sync_mode)
+        
+        # Secondary frame (computed from sync strategy)
+        self.frame_index_b = 0
+        
+        # Seeking state
+        self.is_rewinding = False
+        self.is_forwarding = False
+        self.was_paused_before_hold = False
+        
+        # UI Components
+        self._setup_ui()
+        
+        # Load background
+        bg_path = os.path.join("resources", "background.png")
+        self.bg_texture = arcade.load_texture(bg_path) if os.path.exists(bg_path) else None
+        
+        arcade.set_background_color(arcade.color.BLACK)
+        
+        # Initial layout
+        self._update_layout()
+        
+    def _setup_ui(self):
+        """Initialize UI components."""
+        # Leaderboards for each race
+        self.leaderboard_a = ComparisonLeaderboardComponent(
+            x=20, width=200,
+            race_label=f"{self.race_a.event_name} {self.race_a.year}"
+        )
+        self.leaderboard_b = ComparisonLeaderboardComponent(
+            x=20, width=200,
+            race_label=f"{self.race_b.event_name} {self.race_b.year}"
+        )
+        
+        # Playback controls
+        self.controls_comp = RaceControlsComponent(
+            center_x=self.width // 2,
+            center_y=80,
+            visible=True
+        )
