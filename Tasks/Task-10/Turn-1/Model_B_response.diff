+        # Help popup (comparison-specific)
+        self.controls_popup = ComparisonControlsPopup()
+        self.controls_popup.set_size(400, 340)
+        
+        # Progress bar
+        self.progress_bar = RaceProgressBarComponent(
+            left_margin=240,
+            right_margin=240,
