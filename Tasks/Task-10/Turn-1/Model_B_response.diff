+"""
+Data loading utilities for race comparison.
+
+Handles loading and preparing race data for comparison views.
+"""
+
+from dataclasses import dataclass
+from typing import Optional, Dict, List, Any
+import numpy as np
+
+
+@dataclass
+class RaceData:
+    """Container for all data needed to display a single race."""
+    frames: List[dict]
+    track_statuses: List[dict]
+    example_lap: Any  # pandas DataFrame with X, Y columns
+    drivers: List[str]
+    driver_colors: Dict[str, tuple]
+    total_laps: int
+    circuit_rotation: float
+    session_info: Dict[str, Any]
+    
+    @property
+    def n_frames(self) -> int:
+        return len(self.frames) if self.frames else 0
+    
+    @property
+    def event_name(self) -> str:
+        return self.session_info.get('event_name', 'Unknown')
+    
+    @property
+    def year(self) -> int:
+        return self.session_info.get('year', 0)
+
+
+@dataclass
+class ComparisonData:
+    """Container for comparison between two races."""
+    race_a: RaceData
+    race_b: RaceData
+    
+    def get_position_deltas(
+        self, frame_a_idx: int, frame_b_idx: int
+    ) -> Dict[str, int]:
+        """
+        Calculate position changes for drivers between two races.
+        
+        Returns dict mapping driver code to position delta (positive = gained positions).
+        """
+        if frame_a_idx >= len(self.race_a.frames) or frame_b_idx >= len(self.race_b.frames):
+            return {}
+            
+        frame_a = self.race_a.frames[frame_a_idx]
+        frame_b = self.race_b.frames[frame_b_idx]
+        
+        drivers_a = frame_a.get("drivers", {})
+        drivers_b = frame_b.get("drivers", {})
+        
+        # Get positions from each race
+        positions_a = {
+            code: data.get("position", 99) 
+            for code, data in drivers_a.items()
+        }
+        positions_b = {
+            code: data.get("position", 99)
+            for code, data in drivers_b.items()
+        }
+        
+        # Calculate deltas for common drivers
+        deltas = {}
+        for code in set(positions_a.keys()) | set(positions_b.keys()):
+            pos_a = positions_a.get(code, 99)
+            pos_b = positions_b.get(code, 99)
+            # Positive delta means driver is higher in race A than race B
+            deltas[code] = pos_b - pos_a
+            
+        return deltas
+
+
+def compute_track_geometry(example_lap, track_width: float = 200) -> dict:
+    """
+    Compute track geometry from example lap telemetry.
+    
+    Returns dict with:
+        - plot_x_ref, plot_y_ref: Reference line coordinates
+        - x_inner, y_inner: Inner track boundary
+        - x_outer, y_outer: Outer track boundary
+        - bounds: (x_min, x_max, y_min, y_max)
+    """
+    plot_x_ref = example_lap["X"]
+    plot_y_ref = example_lap["Y"]
+    
+    # Compute tangent vectors
+    dx = np.gradient(plot_x_ref)
+    dy = np.gradient(plot_y_ref)
+    
+    norm = np.sqrt(dx**2 + dy**2)
+    norm[norm == 0] = 1.0
+    dx /= norm
+    dy /= norm
+    
+    # Normal vectors
+    nx = -dy
+    ny = dx
+    
+    # Track boundaries
+    x_outer = plot_x_ref + nx * (track_width / 2)
+    y_outer = plot_y_ref + ny * (track_width / 2)
+    x_inner = plot_x_ref - nx * (track_width / 2)
+    y_inner = plot_y_ref - ny * (track_width / 2)
+    
+    # World bounds
+    x_min = min(plot_x_ref.min(), x_inner.min(), x_outer.min())
+    x_max = max(plot_x_ref.max(), x_inner.max(), x_outer.max())
+    y_min = min(plot_y_ref.min(), y_inner.min(), y_outer.min())
+    y_max = max(plot_y_ref.max(), y_inner.max(), y_outer.max())
+    
+    return {
+        'plot_x_ref': plot_x_ref,
+        'plot_y_ref': plot_y_ref,
+        'x_inner': x_inner,
+        'y_inner': y_inner,
+        'x_outer': x_outer,
+        'y_outer': y_outer,
+        'bounds': (x_min, x_max, y_min, y_max)
+    }
+
+
+def interpolate_track_points(xs, ys, n_points: int = 2000) -> list:
+    """Interpolate track coordinates for smooth rendering."""
+    t_old = np.linspace(0, 1, len(xs))
+    t_new = np.linspace(0, 1, n_points)
+    xs_i = np.interp(t_new, t_old, xs)
+    ys_i = np.interp(t_new, t_old, ys)
+    return list(zip(xs_i, ys_i))
