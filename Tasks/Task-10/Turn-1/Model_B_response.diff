+"""
+View modes for race comparison visualization.
+
+Provides different ways to display two races simultaneously:
+- Split: Side-by-side tracks with independent leaderboards
+- Overlay: Single track with ghost cars from second race
+- Difference: Position delta color coding
+"""
+
+from enum import Enum, auto
+
+
+class ViewMode(Enum):
+    """Available view modes for race comparison."""
+    SPLIT = auto()      # Side-by-side tracks
+    OVERLAY = auto()    # Ghost cars on single track
+    DIFFERENCE = auto() # Position delta visualization
