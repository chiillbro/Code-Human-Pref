+    def _compute_scaling(self, track: Dict[str, Any], left: float, right: float, bottom: float, top: float) -> Tuple[float, float, float]:
+        if not track:
+            return 1.0, 0.0, 0.0
+        
+        padding = 0.05
+        world_cx = (track['x_min'] + track['x_max']) / 2
+        world_cy = (track['y_min'] + track['y_max']) / 2
+        cos_rot = track.get('cos_rot', 1.0)
+        sin_rot = track.get('sin_rot', 0.0)
+        
+        def rotate(x, y):
+            tx = x - world_cx
+            ty = y - world_cy
+            rx = tx * cos_rot - ty * sin_rot
+            ry = tx * sin_rot + ty * cos_rot
+            return rx + world_cx, ry + world_cy
+        
+        rotated_xs, rotated_ys = [], []
+        for x, y in track['world_inner'] + track['world_outer']:
+            rx, ry = rotate(x, y)
+            rotated_xs.append(rx)
+            rotated_ys.append(ry)
+        
+        if not rotated_xs or not rotated_ys:
+            return 1.0, 0.0, 0.0
+        
+        world_x_min, world_x_max = min(rotated_xs), max(rotated_xs)
+        world_y_min, world_y_max = min(rotated_ys), max(rotated_ys)
+        world_w = max(1.0, world_x_max - world_x_min)
+        world_h = max(1.0, world_y_max - world_y_min)
+        
+        usable_w = (right - left) * (1 - 2 * padding)
+        usable_h = (top - bottom) * (1 - 2 * padding)
+        scale = min(usable_w / world_w, usable_h / world_h)
+        
+        screen_cx = (left + right) / 2
+        screen_cy = (bottom + top) / 2
+        tx = screen_cx - scale * world_cx
+        ty = screen_cy - scale * world_cy
+        
+        return scale, tx, ty
+    
+    def _world_to_screen_a(self, x: float, y: float) -> Tuple[float, float]:
+        return self._world_to_screen(x, y, self._track_a, self._scale_a, self._tx_a, self._ty_a)
+    
+    def _world_to_screen_b(self, x: float, y: float) -> Tuple[float, float]:
+        return self._world_to_screen(x, y, self._track_b, self._scale_b, self._tx_b, self._ty_b)
+    
+    def _world_to_screen(self, x: float, y: float, track: Optional[Dict], scale: float, tx: float, ty: float) -> Tuple[float, float]:
+        if track is None:
+            return x * scale + tx, y * scale + ty
+        
+        world_cx = (track['x_min'] + track['x_max']) / 2
+        world_cy = (track['y_min'] + track['y_max']) / 2
+        cos_rot = track.get('cos_rot', 1.0)
+        sin_rot = track.get('sin_rot', 0.0)
+        
+        if sin_rot != 0.0:
+            dx = x - world_cx
+            dy = y - world_cy
+            rx = dx * cos_rot - dy * sin_rot
+            ry = dx * sin_rot + dy * cos_rot
+            x, y = rx + world_cx, ry + world_cy
+        
+        return x * scale + tx, y * scale + ty
