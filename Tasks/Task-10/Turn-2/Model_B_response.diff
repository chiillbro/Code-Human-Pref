+    def _build_sync_mappings(self, data: RaceComparisonData) -> None:
+        """Build synchronization mappings between the two races."""
+        frames_a = data.frames_a
+        frames_b = data.frames_b
+        
+        if not frames_a or not frames_b:
+            return
+        
+        # Lap-based sync: map lap numbers to frame indices
+        data.lap_sync_map = self._build_lap_sync_map(frames_a, frames_b)
+        
+        # Time-based sync: direct frame mapping by time
+        data.time_sync_map = self._build_time_sync_map(frames_a, frames_b)
+        
+        # Distance-based sync: map by track position percentage
+        data.distance_sync_map = self._build_distance_sync_map(frames_a, frames_b)
+    
+    def _build_lap_sync_map(
+        self,
+        frames_a: List[Dict],
+        frames_b: List[Dict]
+    ) -> Dict[int, Tuple[int, int]]:
+        """
+        Build lap-based synchronization map.
+        
+        Returns dict: lap_number -> (frame_index_a, frame_index_b)
+        where frame indices are the start of each lap.
+        """
+        lap_map = {}
+        
+        # Find lap start frames for race A
+        lap_starts_a = {}
+        prev_lap = 0
+        for i, frame in enumerate(frames_a):
+            lap = frame.get('lap', 1)
+            if lap != prev_lap and lap not in lap_starts_a:
+                lap_starts_a[lap] = i
+            prev_lap = lap
+        
+        # Find lap start frames for race B
+        lap_starts_b = {}
+        prev_lap = 0
+        for i, frame in enumerate(frames_b):
+            lap = frame.get('lap', 1)
+            if lap != prev_lap and lap not in lap_starts_b:
+                lap_starts_b[lap] = i
+            prev_lap = lap
+        
+        # Build combined map
+        all_laps = set(lap_starts_a.keys()) | set(lap_starts_b.keys())
+        for lap in sorted(all_laps):
+            frame_a = lap_starts_a.get(lap, 0)
+            frame_b = lap_starts_b.get(lap, 0)
+            lap_map[lap] = (frame_a, frame_b)
+        
+        return lap_map
+    
+    def _build_time_sync_map(
+        self,
+        frames_a: List[Dict],
+        frames_b: List[Dict]
+    ) -> List[Tuple[float, int, int]]:
+        """
+        Build time-based synchronization map.
+        
+        Returns list of (time, frame_index_a, frame_index_b) tuples.
+        """
+        time_map = []
+        
+        # Get time ranges
+        times_a = [f.get('t', 0.0) for f in frames_a]
+        times_b = [f.get('t', 0.0) for f in frames_b]
+        
+        if not times_a or not times_b:
+            return time_map
+        
+        max_time = max(max(times_a), max(times_b))
+        
+        # Sample at regular intervals (every second)
+        sample_interval = 1.0
+        current_time = 0.0
+        idx_a = 0
+        idx_b = 0
+        
+        while current_time <= max_time:
+            # Find closest frame in race A
+            while idx_a < len(times_a) - 1 and times_a[idx_a + 1] <= current_time:
+                idx_a += 1
+            
+            # Find closest frame in race B
+            while idx_b < len(times_b) - 1 and times_b[idx_b + 1] <= current_time:
+                idx_b += 1
+            
+            time_map.append((current_time, idx_a, idx_b))
+            current_time += sample_interval
+        
+        return time_map
+    
+    def _build_distance_sync_map(
+        self,
+        frames_a: List[Dict],
+        frames_b: List[Dict]
+    ) -> List[Tuple[float, int, int]]:
+        """
+        Build distance-based synchronization map using track position percentage.
+        
+        Returns list of (percentage, frame_index_a, frame_index_b) tuples.
+        """
+        distance_map = []
+        
+        # Sample at 1% intervals
+        for pct in range(0, 101):
+            pct_float = pct / 100.0
+            
+            # Find frame where leader's rel_dist is closest to target percentage
+            frame_a = self._find_frame_by_rel_dist(frames_a, pct_float)
+            frame_b = self._find_frame_by_rel_dist(frames_b, pct_float)
+            
+            distance_map.append((pct_float, frame_a, frame_b))
+        
+        return distance_map
+    
+    def _find_frame_by_rel_dist(
+        self,
+        frames: List[Dict],
+        target_pct: float
+    ) -> int:
+        """Find frame index where leader is closest to target track percentage."""
+        if not frames:
+            return 0
+        
+        best_idx = 0
+        best_diff = float('inf')
+        
+        for i, frame in enumerate(frames):
+            drivers = frame.get('drivers', {})
+            if not drivers:
+                continue
+            
+            # Find leader's rel_dist
+            leader_dist = 0.0
+            for driver_data in drivers.values():
+                rel_dist = driver_data.get('rel_dist', 0.0)
+                if rel_dist > leader_dist:
+                    leader_dist = rel_dist
+            
+            diff = abs(leader_dist - target_pct)
+            if diff < best_diff:
+                best_diff = diff
+                best_idx = i
+        
+        return best_idx
+
+
+class SyncController:
+    """
+    Controls synchronization between two races during playback.
+    
+    Manages frame indices for both races based on the current sync mode.
+    """
+    
+    def __init__(self, comparison_data: RaceComparisonData):
+        self._data = comparison_data
+        self._sync_mode = SyncMode.LAP_BASED
+        self._primary_frame_idx = 0.0  # Frame index for primary race (A)
+        self._secondary_frame_idx = 0.0  # Frame index for secondary race (B)
+    
+    @property
+    def sync_mode(self) -> SyncMode:
+        return self._sync_mode
+    
+    @sync_mode.setter
+    def sync_mode(self, mode: SyncMode) -> None:
+        if not isinstance(mode, SyncMode):
+            raise ValueError(f"Invalid sync mode: {mode}")
+        self._sync_mode = mode
+        # Recalculate secondary frame based on new mode
+        self._update_secondary_frame()
+    
+    @property
+    def frame_index_a(self) -> int:
+        """Current frame index for race A."""
+        return max(0, min(int(self._primary_frame_idx), len(self._data.frames_a) - 1))
+    
+    @property
+    def frame_index_b(self) -> int:
+        """Current frame index for race B."""
+        return max(0, min(int(self._secondary_frame_idx), len(self._data.frames_b) - 1))
+    
+    @property
+    def frame_index_a_float(self) -> float:
+        """Fractional frame index for race A (for smooth playback)."""
+        return self._primary_frame_idx
+    
+    @frame_index_a_float.setter
+    def frame_index_a_float(self, value: float) -> None:
+        max_frame = max(0, len(self._data.frames_a) - 1)
+        self._primary_frame_idx = max(0.0, min(float(value), float(max_frame)))
+        self._update_secondary_frame()
+    
+    def advance(self, delta_frames: float) -> None:
+        """Advance playback by delta_frames."""
+        max_frame = max(0, len(self._data.frames_a) - 1)
+        self._primary_frame_idx = max(0.0, min(
+            self._primary_frame_idx + delta_frames,
+            float(max_frame)
+        ))
+        self._update_secondary_frame()
+    
+    def seek(self, frame_idx: float) -> None:
+        """Seek to specific frame index in primary race."""
+        self.frame_index_a_float = frame_idx
+    
+    def _update_secondary_frame(self) -> None:
+        """Update secondary frame index based on sync mode."""
+        if not self._data.frames_a or not self._data.frames_b:
+            return
+        
+        if self._sync_mode == SyncMode.LAP_BASED:
+            self._sync_by_lap()
+        elif self._sync_mode == SyncMode.TIME_BASED:
+            self._sync_by_time()
+        elif self._sync_mode == SyncMode.DISTANCE_BASED:
+            self._sync_by_distance()
+    
+    def _sync_by_lap(self) -> None:
+        """Synchronize by lap number."""
+        frame_a = self.frame_index_a
+        if frame_a >= len(self._data.frames_a):
+            return
+        
+        current_lap = self._data.frames_a[frame_a].get('lap', 1)
+        
+        # Find corresponding lap start in race B
+        lap_map = self._data.lap_sync_map
+        if current_lap in lap_map:
+            lap_start_a, lap_start_b = lap_map[current_lap]
+            
+            # Calculate offset within current lap
+            offset = frame_a - lap_start_a
+            
+            # Apply same offset to race B
+            self._secondary_frame_idx = float(lap_start_b + offset)
+        else:
+            # Fallback: use time-based sync
+            self._sync_by_time()
+    
+    def _sync_by_time(self) -> None:
+        """Synchronize by race elapsed time."""
+        frame_a = self.frame_index_a
+        if frame_a >= len(self._data.frames_a):
+            return
+        
+        current_time = self._data.frames_a[frame_a].get('t', 0.0)
+        
+        # Find frame in race B with closest time
+        frames_b = self._data.frames_b
+        best_idx = 0
+        best_diff = float('inf')
+        
+        for i, frame in enumerate(frames_b):
+            diff = abs(frame.get('t', 0.0) - current_time)
+            if diff < best_diff:
+                best_diff = diff
+                best_idx = i
+            elif diff > best_diff:
+                break  # Times are monotonic, stop searching
+        
+        self._secondary_frame_idx = float(best_idx)
+    
+    def _sync_by_distance(self) -> None:
+        """Synchronize by track position percentage."""
+        frame_a = self.frame_index_a
+        if frame_a >= len(self._data.frames_a):
+            return
+        
+        # Get leader's rel_dist in race A
+        drivers_a = self._data.frames_a[frame_a].get('drivers', {})
+        leader_dist_a = 0.0
+        for driver_data in drivers_a.values():
+            rel_dist = driver_data.get('rel_dist', 0.0)
+            if rel_dist > leader_dist_a:
+                leader_dist_a = rel_dist
+        
+        # Find frame in race B with similar leader rel_dist
+        frames_b = self._data.frames_b
+        best_idx = 0
+        best_diff = float('inf')
+        
+        for i, frame in enumerate(frames_b):
+            drivers_b = frame.get('drivers', {})
+            leader_dist_b = 0.0
+            for driver_data in drivers_b.values():
+                rel_dist = driver_data.get('rel_dist', 0.0)
+                if rel_dist > leader_dist_b:
+                    leader_dist_b = rel_dist
+            
+            diff = abs(leader_dist_b - leader_dist_a)
+            if diff < best_diff:
+                best_diff = diff
+                best_idx = i
+        
+        self._secondary_frame_idx = float(best_idx)
+
+
+def compute_position_deltas(
+    frame_a: Dict[str, Any],
+    frame_b: Dict[str, Any],
+    driver_colors_a: Dict[str, Tuple[int, int, int]],
+    driver_colors_b: Dict[str, Tuple[int, int, int]],
+) -> Dict[str, Dict[str, Any]]:
+    """
+    Compute position deltas between two frames for difference view.
+    
+    Returns dict of driver_code -> {
+        'position_a': position in race A (or None),
+        'position_b': position in race B (or None),
+        'delta': position difference (positive = worse in B),
+        'color': computed delta color (green=improved, red=worse),
+    }
+    """
+    deltas = {}
+    
+    drivers_a = frame_a.get('drivers', {})
+    drivers_b = frame_b.get('drivers', {})
+    
+    # Build position maps
+    positions_a = {}
+    for code, data in drivers_a.items():
+        positions_a[code] = data.get('position', 0)
+    
+    positions_b = {}
+    for code, data in drivers_b.items():
+        positions_b[code] = data.get('position', 0)
+    
+    # Find all drivers
+    all_drivers = set(positions_a.keys()) | set(positions_b.keys())
+    
+    for code in all_drivers:
+        pos_a = positions_a.get(code)
+        pos_b = positions_b.get(code)
+        
+        if pos_a is not None and pos_b is not None:
+            delta = pos_b - pos_a  # Positive = worse in B
+            # Color: green if improved (negative delta), red if worse
+            if delta < 0:
+                intensity = min(255, 100 + abs(delta) * 30)
+                color = (0, intensity, 0)
+            elif delta > 0:
+                intensity = min(255, 100 + delta * 30)
+                color = (intensity, 0, 0)
+            else:
+                color = (128, 128, 128)  # Gray for no change
+        else:
+            delta = None
+            color = (100, 100, 100)  # Dim for missing
+        
+        deltas[code] = {
+            'position_a': pos_a,
+            'position_b': pos_b,
+            'delta': delta,
+            'color': color,
+            'color_a': driver_colors_a.get(code, (128, 128, 128)),
+            'color_b': driver_colors_b.get(code, (128, 128, 128)),
+        }
+    
+    return deltas
