+class F1RaceComparisonWindow(arcade.Window):
+    """
+    Window for comparing two F1 races.
+    
+    Supports three view modes:
+    - SPLIT: Side-by-side tracks with separate leaderboards
+    - OVERLAY: Single track with ghost cars from race B
+    - DIFFERENCE: Single track color-coded by position deltas
+    
+    And three sync modes:
+    - LAP_BASED: Align by lap number
+    - TIME_BASED: Align by race elapsed time
+    - DISTANCE_BASED: Align by track position percentage
+    """
+    
+    def __init__(
+        self,
+        comparison_data: RaceComparisonData,
+        playback_speed: float = 1.0,
+        visible_hud: bool = True,
+    ):
+        super().__init__(SCREEN_WIDTH, SCREEN_HEIGHT, SCREEN_TITLE, resizable=True)
+        self.maximize()
+        
+        if comparison_data is None or not comparison_data.is_loaded:
+            raise ValueError("Comparison data is not loaded or is None")
+        
+        self._data = comparison_data
+        self._sync_controller = SyncController(comparison_data)
+        
+        # State
+        self._view_mode = ViewMode.SPLIT
+        self._playback_speed = self._validate_playback_speed(playback_speed)
+        self._paused = False
+        self._visible_hud = visible_hud
+        self._show_driver_labels = False
+        self._toggle_drs_zones = True
+        
+        # Seeking state
+        self._is_rewinding = False
+        self._is_forwarding = False
+        self._was_paused_before_hold = False
+        
+        # Track geometries
+        self._track_a = self._init_track_geometry(
+            comparison_data.example_lap_a,
+            comparison_data.race_a.get('circuit_rotation', 0.0)
+        )
+        self._track_b = self._init_track_geometry(
+            comparison_data.example_lap_b,
+            comparison_data.race_b.get('circuit_rotation', 0.0)
+        )
+        
+        # Screen coordinates
+        self._screen_inner_a: List[Tuple[float, float]] = []
+        self._screen_outer_a: List[Tuple[float, float]] = []
+        self._screen_inner_b: List[Tuple[float, float]] = []
+        self._screen_outer_b: List[Tuple[float, float]] = []
+        
+        # Scaling parameters
+        self._scale_a = 1.0
+        self._tx_a = 0.0
+        self._ty_a = 0.0
+        self._scale_b = 1.0
+        self._tx_b = 0.0
+        self._ty_b = 0.0
+        
+        # UI components
+        self._init_ui_components()
+        
+        # Background
+        bg_path = os.path.join("resources", "background.png")
+        self._bg_texture = arcade.load_texture(bg_path) if os.path.exists(bg_path) else None
+        
+        arcade.set_background_color(arcade.color.BLACK)
+        
+        # Text objects
+        self._init_text_objects()
+        
+        # Layout
+        self._update_layout(self.width, self.height)
+    
+    def _validate_playback_speed(self, speed: float) -> float:
+        if speed in PLAYBACK_SPEEDS:
+            return speed
+        return min(PLAYBACK_SPEEDS, key=lambda x: abs(x - speed))
+    
+    def _init_track_geometry(self, example_lap, circuit_rotation: float) -> Optional[Dict[str, Any]]:
+        if example_lap is None:
+            return None
+        
+        try:
+            result = build_track_from_example_lap(example_lap)
+            if result is None or len(result) < 10:
+                return None
+            
+            (plot_x_ref, plot_y_ref, x_inner, y_inner, x_outer, y_outer,
+             x_min, x_max, y_min, y_max, drs_zones) = result
+            
+            rot_rad = float(np.deg2rad(circuit_rotation)) if circuit_rotation else 0.0
+            cos_rot = float(np.cos(rot_rad))
+            sin_rot = float(np.sin(rot_rad))
+            
+            world_inner = self._interpolate_points(x_inner, y_inner)
+            world_outer = self._interpolate_points(x_outer, y_outer)
+            
+            return {
+                'plot_x_ref': plot_x_ref,
+                'plot_y_ref': plot_y_ref,
+                'x_inner': x_inner,
+                'y_inner': y_inner,
+                'x_outer': x_outer,
+                'y_outer': y_outer,
+                'x_min': x_min,
+                'x_max': x_max,
+                'y_min': y_min,
+                'y_max': y_max,
+                'drs_zones': drs_zones,
+                'rot_rad': rot_rad,
+                'cos_rot': cos_rot,
+                'sin_rot': sin_rot,
+                'world_inner': world_inner,
+                'world_outer': world_outer,
+            }
+        except Exception as e:
+            print(f"Error initializing track geometry: {e}")
+            return None
