+class ComparisonControlsPopup(BaseComponent):
+    """Controls popup specialized for comparison view."""
+    
+    def __init__(self, width: int = 420, height: int = 380):
+        self.width = width
+        self.height = height
+        self.visible = False
+        self.cx: Optional[float] = None
+        self.cy: Optional[float] = None
+        self._header_text = arcade.Text("", 0, 0, arcade.color.BLACK, 16, anchor_x="left", anchor_y="center")
+        self._body_text = arcade.Text("", 0, 0, arcade.color.LIGHT_GRAY, 13, anchor_x="left", anchor_y="center")
+    
+    def show_over(self, left: float, top: float):
+        self.cx = float(left + self.width / 2)
+        self.cy = float(top - self.height / 2)
+        self.visible = True
+    
+    def hide(self):
+        self.visible = False
+        self.cx = None
+        self.cy = None
+    
+    def draw(self, window):
+        if not self.visible:
+            return
+        
+        cx = self.cx if self.cx is not None else window.width / 2
+        cy = self.cy if self.cy is not None else window.height / 2
+        
+        rect = arcade.XYWH(cx, cy, self.width, self.height)
+        arcade.draw_rect_filled(rect, (0, 0, 0, 255))
+        arcade.draw_rect_outline(rect, arcade.color.GRAY, 2)
+        
+        header_height = 28
+        header_cy = cy + self.height / 2 - header_height / 2
+        arcade.draw_rect_filled(arcade.XYWH(cx, header_cy, self.width, header_height), arcade.color.GRAY)
+        
+        self._header_text.text = "Comparison Controls"
+        self._header_text.bold = True
+        self._header_text.color = arcade.color.BLACK
+        self._header_text.x = cx - self.width / 2 + 12
+        self._header_text.y = header_cy
+        self._header_text.draw()
+        
+        lines = [
+            " ",
+            "[SPACE]   Pause/Resume",
+            "← / →     Seek backward/forward",
+            "↑ / ↓     Speed +/-",
+            "[1-4]     Set speed: 0.5x / 1x / 2x / 4x",
+            "[R]       Restart",
+            " ",
+            "[V]       Cycle View Mode (Split/Overlay/Difference)",
+            "[S]       Cycle Sync Mode (Lap/Time/Distance)",
+            " ",
+            "[L]       Toggle Driver Labels",
+            "[D]       Toggle DRS Zones",
+            "[H]       Toggle Help Popup",
+            "[ESC]     Exit",
+        ]
+        
+        line_spacing = 21
+        y = header_cy - 20
+        for line in lines:
+            self._body_text.text = line
+            self._body_text.bold = False
+            self._body_text.color = arcade.color.LIGHT_GRAY
+            self._body_text.x = cx - self.width / 2 + 16
+            self._body_text.y = y
+            self._body_text.draw()
+            y -= line_spacing
+    
+    def on_mouse_press(self, window, x: float, y: float, button: int, modifiers: int) -> bool:
+        if not self.visible:
+            return False
+        
+        cx = self.cx if self.cx is not None else window.width / 2
+        cy = self.cy if self.cy is not None else window.height / 2
+        left = cx - self.width / 2
+        right = cx + self.width / 2
+        bottom = cy - self.height / 2
+        top = cy + self.height / 2
+        
+        if left <= x <= right and bottom <= y <= top:
+            return True
+        
+        self.hide()
+        return True
