+    def _get_track_color_from_status(self, frame: Optional[Dict], track_statuses: List[Dict]) -> Tuple[int, int, int]:
+        if not frame:
+            return (150, 150, 150)
+        current_time = frame.get('t', 0.0)
+        for status in track_statuses:
+            start, end = status.get('start_time', 0.0), status.get('end_time')
+            if start <= current_time and (end is None or current_time < end):
+                code = status.get('status', '')
+                if code == "2": return (220, 180, 0)
+                elif code == "4": return (180, 100, 30)
+                elif code == "5": return (200, 30, 30)
+                elif code in ("6", "7"): return (200, 130, 50)
+        return (150, 150, 150)
