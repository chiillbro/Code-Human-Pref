+    def on_update(self, delta_time: float) -> None:
+        self._race_controls.on_update(delta_time)
+        
+        seek_speed = 3.0 * max(1.0, self._playback_speed)
+        if self._is_rewinding:
+            self._sync_controller.advance(-delta_time * FPS * seek_speed)
+            self._race_controls.flash_button('rewind')
+        elif self._is_forwarding:
+            self._sync_controller.advance(delta_time * FPS * seek_speed)
+            self._race_controls.flash_button('forward')
+        
+        if not self._paused:
+            self._sync_controller.advance(delta_time * FPS * self._playback_speed)
+        
+        self._progress_bar._current_frame = self._sync_controller.frame_index_a
+    
+    def on_key_press(self, symbol: int, modifiers: int) -> None:
+        if symbol == arcade.key.ESCAPE:
+            arcade.close_window()
+        elif symbol == arcade.key.SPACE:
+            self._paused = not self._paused
+            self._race_controls.flash_button('play_pause')
+        elif symbol == arcade.key.RIGHT:
+            self._was_paused_before_hold = self._paused
+            self._is_forwarding = True
+            self._paused = True
+        elif symbol == arcade.key.LEFT:
+            self._was_paused_before_hold = self._paused
+            self._is_rewinding = True
+            self._paused = True
+        elif symbol == arcade.key.UP:
+            self._increase_speed()
+            self._race_controls.flash_button('speed_increase')
+        elif symbol == arcade.key.DOWN:
+            self._decrease_speed()
+            self._race_controls.flash_button('speed_decrease')
+        elif symbol == arcade.key.KEY_1:
+            self._playback_speed = 0.5
+        elif symbol == arcade.key.KEY_2:
+            self._playback_speed = 1.0
+        elif symbol == arcade.key.KEY_3:
+            self._playback_speed = 2.0
+        elif symbol == arcade.key.KEY_4:
+            self._playback_speed = 4.0
+        elif symbol == arcade.key.R:
+            self._sync_controller.seek(0)
+            self._playback_speed = 1.0
+            self._race_controls.flash_button('rewind')
+        elif symbol == arcade.key.V:
+            modes = list(ViewMode)
+            self._view_mode = modes[(modes.index(self._view_mode) + 1) % len(modes)]
+            self._update_layout(self.width, self.height)
+        elif symbol == arcade.key.S:
+            modes = list(SyncMode)
+            self._sync_controller.sync_mode = modes[(modes.index(self._sync_controller.sync_mode) + 1) % len(modes)]
+        elif symbol == arcade.key.L:
+            self._show_driver_labels = not self._show_driver_labels
+        elif symbol == arcade.key.D:
+            self._toggle_drs_zones = not self._toggle_drs_zones
+        elif symbol == arcade.key.H:
+            if self._controls_popup.visible:
+                self._controls_popup.hide()
+            else:
+                self._controls_popup.show_over(20.0, float(20 + self._controls_popup.height))
+    
+    def on_key_release(self, symbol: int, modifiers: int) -> None:
+        if symbol == arcade.key.RIGHT:
+            self._is_forwarding = False
+            self._paused = self._was_paused_before_hold
+        elif symbol == arcade.key.LEFT:
+            self._is_rewinding = False
+            self._paused = self._was_paused_before_hold
+    
+    def on_mouse_press(self, x: float, y: float, button: int, modifiers: int) -> None:
+        if self._is_forwarding or self._is_rewinding:
+            self._is_forwarding = self._is_rewinding = False
+            self._paused = self._was_paused_before_hold
+            return
+        if self._controls_popup.on_mouse_press(self, x, y, button, modifiers):
+            return
+        if self._race_controls.on_mouse_press(self, x, y, button, modifiers):
+            return
+        if self._progress_bar.on_mouse_press(self, x, y, button, modifiers):
+            target_frame = self._progress_bar._x_to_frame(x)
+            self._sync_controller.seek(float(target_frame))
+            return
+        if self._leaderboard_a.on_mouse_press(self, x, y, button, modifiers):
+            return
+    
+    def on_mouse_motion(self, x: float, y: float, dx: float, dy: float) -> None:
+        self._progress_bar.on_mouse_motion(self, x, y, dx, dy)
+        self._race_controls.on_mouse_motion(self, x, y, dx, dy)
+    
+    def on_mouse_release(self, x: float, y: float, button: int, modifiers: int) -> None:
+        if self._is_forwarding or self._is_rewinding:
+            self._is_forwarding = self._is_rewinding = False
+            self._paused = self._was_paused_before_hold
+    
+    def _increase_speed(self) -> None:
+        if self._playback_speed < PLAYBACK_SPEEDS[-1]:
+            for spd in PLAYBACK_SPEEDS:
+                if spd > self._playback_speed:
+                    self._playback_speed = spd
+                    break
+    
+    def _decrease_speed(self) -> None:
+        if self._playback_speed > PLAYBACK_SPEEDS[0]:
+            for spd in reversed(PLAYBACK_SPEEDS):
+                if spd < self._playback_speed:
+                    self._playback_speed = spd
+                    break
+    
+    # Properties for UI component compatibility
+    @property
+    def paused(self) -> bool: return self._paused
+    @paused.setter
+    def paused(self, value: bool) -> None: self._paused = value
+    @property
+    def playback_speed(self) -> float: return self._playback_speed
+    @playback_speed.setter
+    def playback_speed(self, value: float) -> None: self._playback_speed = self._validate_playback_speed(value)
+    @property
+    def frame_index(self) -> float: return self._sync_controller.frame_index_a_float
+    @frame_index.setter
+    def frame_index(self, value: float) -> None: self._sync_controller.seek(value)
+    @property
+    def n_frames(self) -> int: return len(self._data.frames_a)
+    @property
+    def is_rewinding(self) -> bool: return self._is_rewinding
+    @is_rewinding.setter
+    def is_rewinding(self, value: bool) -> None: self._is_rewinding = value
+    @property
+    def is_forwarding(self) -> bool: return self._is_forwarding
+    @is_forwarding.setter
+    def is_forwarding(self, value: bool) -> None: self._is_forwarding = value
+    @property
+    def was_paused_before_hold(self) -> bool: return self._was_paused_before_hold
+    @was_paused_before_hold.setter
+    def was_paused_before_hold(self, value: bool) -> None: self._was_paused_before_hold = value
+
+
+def run_comparison_replay(comparison_data: RaceComparisonData, playback_speed: float = 1.0) -> None:
+    """Run the race comparison replay window."""
+    if comparison_data is None or not comparison_data.is_loaded:
+        print("Error: Comparison data is not loaded")
+        return
+    window = F1RaceComparisonWindow(comparison_data=comparison_data, playback_speed=playback_speed, visible_hud=True)
+    arcade.run()
