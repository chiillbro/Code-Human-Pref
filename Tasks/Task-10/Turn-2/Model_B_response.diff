+"""
+Dual Race Picker Dialog for Race Comparison.
+
+Provides a GUI dialog to select two races for comparison.
+"""
+
+from PySide6.QtWidgets import (
+    QDialog, QVBoxLayout, QHBoxLayout, QLabel,
+    QPushButton, QMessageBox, QProgressDialog, QSplitter
+)
+from PySide6.QtCore import Qt, QThread, Signal
+from PySide6.QtGui import QFont
+from typing import Optional, Dict, Tuple
+import sys
+import os
+import subprocess
+
+from src.gui.race_picker import RacePickerWidget
+
+
+class RaceComparisonDialog(QDialog):
+    """
+    Dialog for selecting two races to compare.
+    
+    Uses RacePickerWidget for both race selections.
+    """
+    
+    def __init__(self, parent=None):
+        super().__init__(parent)
+        self._race_a: Optional[Dict] = None
+        self._race_b: Optional[Dict] = None
+        
+        self.setWindowTitle("Compare Races")
+        self.setMinimumSize(900, 600)
+        self._setup_ui()
+    
+    def _setup_ui(self):
+        layout = QVBoxLayout(self)
+        
+        # Header
+        header = QLabel("Select Two Races to Compare")
+        header_font = QFont()
+        header_font.setPointSize(16)
+        header_font.setBold(True)
+        header.setFont(header_font)
+        header.setAlignment(Qt.AlignCenter)
+        layout.addWidget(header)
+        
+        # Instructions
+        instructions = QLabel(
+            "Compare races from the same circuit across different years "
+            "(e.g., Monza 2023 vs 2024) or different circuits (Monaco vs Singapore)."
+        )
+        instructions.setWordWrap(True)
+        instructions.setAlignment(Qt.AlignCenter)
+        instructions.setStyleSheet("color: gray;")
+        layout.addWidget(instructions)
+        
+        # Splitter with two race pickers
+        splitter = QSplitter(Qt.Horizontal)
+        
+        self._picker_a = RacePickerWidget("Race A (Primary)", show_session_selector=True)
+        splitter.addWidget(self._picker_a)
+        
+        self._picker_b = RacePickerWidget("Race B (Comparison)", show_session_selector=True)
+        splitter.addWidget(self._picker_b)
+        
+        layout.addWidget(splitter)
+        
+        # Button row
+        button_layout = QHBoxLayout()
+        button_layout.addStretch()
+        
+        self._compare_btn = QPushButton("Compare Races")
+        self._compare_btn.setMinimumSize(150, 40)
+        self._compare_btn.clicked.connect(self._on_compare_clicked)
+        button_layout.addWidget(self._compare_btn)
+        
+        cancel_btn = QPushButton("Cancel")
+        cancel_btn.setMinimumSize(100, 40)
+        cancel_btn.clicked.connect(self.reject)
+        button_layout.addWidget(cancel_btn)
+        
+        button_layout.addStretch()
+        layout.addLayout(button_layout)
+    
+    def _on_compare_clicked(self):
+        """Handle compare button click with validation."""
+        # Validate Race A selection
+        if not self._picker_a.is_valid():
+            QMessageBox.warning(
+                self,
+                "Invalid Selection",
+                "Please select Race A (primary race)."
+            )
+            return
+        
+        # Validate Race B selection
+        if not self._picker_b.is_valid():
+            QMessageBox.warning(
+                self,
+                "Invalid Selection",
+                "Please select Race B (comparison race)."
+            )
+            return
+        
+        self._race_a = self._picker_a.get_selection()
+        self._race_b = self._picker_b.get_selection()
+        
+        # Validate that races are different
+        if (self._race_a and self._race_b and
+            self._race_a['year'] == self._race_b['year'] and
+            self._race_a['round'] == self._race_b['round'] and
+            self._race_a['session_type'] == self._race_b['session_type']):
+            QMessageBox.warning(
+                self,
+                "Invalid Selection",
+                "Race A and Race B cannot be the same race and session.\n"
+                "Please select different races or sessions to compare."
+            )
+            return
+        
+        self.accept()
+    
+    def get_selections(self) -> Tuple[Optional[Dict], Optional[Dict]]:
+        """Get the selected races."""
+        return self._race_a, self._race_b
+
+
+class LoadComparisonWorker(QThread):
+    """Worker thread for loading comparison data."""
+    result = Signal(object)
+    error = Signal(str)
+    progress = Signal(str)
+    
+    def __init__(
+        self,
+        year_a: int,
+        round_a: int,
+        year_b: int,
+        round_b: int,
+        session_a: str = 'R',
+        session_b: str = 'R',
+        parent=None
+    ):
+        super().__init__(parent)
+        self.year_a = year_a
+        self.round_a = round_a
+        self.year_b = year_b
+        self.round_b = round_b
+        self.session_a = session_a
+        self.session_b = session_b
+    
+    def run(self):
+        try:
+            from src.comparison.comparison_data import ComparisonDataLoader
+            
+            self.progress.emit("Loading comparison data...")
+            
+            loader = ComparisonDataLoader()
+            data = loader.load_races(
+                year_a=self.year_a,
+                round_a=self.round_a,
+                year_b=self.year_b,
+                round_b=self.round_b,
+                session_type_a=self.session_a,
+                session_type_b=self.session_b,
+            )
+            
+            if data is None:
+                errors = loader.load_errors
+                error_msg = "\n".join(errors) if errors else "Unknown error"
+                self.error.emit(f"Failed to load comparison data:\n{error_msg}")
+                return
+            
+            self.result.emit(data)
+            
+        except Exception as e:
+            self.error.emit(f"Error loading comparison data: {e}")
+
+
+def show_comparison_dialog(parent=None) -> Optional[Tuple[Dict, Dict]]:
+    """
+    Show the race comparison dialog and return selected races.
+    
+    Returns (race_a, race_b) tuple if user selected races, None if cancelled.
+    """
+    dialog = RaceComparisonDialog(parent)
+    if dialog.exec() == QDialog.Accepted:
+        return dialog.get_selections()
+    return None
+
+
+def load_and_run_comparison(parent, race_a: Dict, race_b: Dict) -> None:
+    """
+    Load comparison data and launch the comparison window.
+    
+    Shows a loading dialog while data is being fetched.
+    """
+    if not race_a or not race_b:
+        QMessageBox.warning(
+            parent,
+            "Invalid Selection",
+            "Both races must be selected."
+        )
+        return
+    
+    # Show loading dialog
+    progress = QProgressDialog("Loading race data...", None, 0, 0, parent)
+    progress.setWindowTitle("Loading Comparison")
+    progress.setWindowModality(Qt.ApplicationModal)
+    progress.setCancelButton(None)
+    progress.setMinimumDuration(0)
+    progress.show()
+    
+    def on_loaded(data):
+        progress.close()
+        
+        if data is None or not data.is_loaded:
+            QMessageBox.critical(
+                parent,
+                "Load Error",
+                "Failed to load comparison data."
+            )
+            return
+        
+        # Launch comparison window in subprocess
+        _launch_comparison_subprocess(race_a, race_b)
+    
+    def on_error(msg):
+        progress.close()
+        QMessageBox.critical(parent, "Load Error", msg)
+    
+    def on_progress(msg):
+        progress.setLabelText(msg)
+    
+    worker = LoadComparisonWorker(
+        year_a=race_a['year'],
+        round_a=race_a['round'],
+        year_b=race_b['year'],
+        round_b=race_b['round'],
+        session_a=race_a.get('session_type', 'R'),
+        session_b=race_b.get('session_type', 'R'),
+    )
+    worker.result.connect(on_loaded)
+    worker.error.connect(on_error)
+    worker.progress.connect(on_progress)
+    
+    # Keep reference to prevent garbage collection
+    parent._comparison_worker = worker
+    worker.start()
+
+
+def _launch_comparison_subprocess(race_a: Dict, race_b: Dict) -> None:
+    """Launch comparison in a subprocess."""
+    main_path = os.path.normpath(
+        os.path.join(os.path.dirname(__file__), '..', '..', 'main.py')
+    )
+    
+    cmd = [
+        sys.executable, main_path,
+        "--compare",
+        "--year", str(race_a['year']),
+        "--round", str(race_a['round']),
+        "--year-b", str(race_b['year']),
+        "--round-b", str(race_b['round']),
+    ]
+    
+    session_a = race_a.get('session_type', 'R')
+    session_b = race_b.get('session_type', 'R')
+    
+    if session_a == 'S':
+        cmd.append("--sprint")
+    if session_b == 'S':
+        cmd.append("--sprint-b")
+    
+    try:
+        subprocess.Popen(cmd)
+    except Exception as e:
+        print(f"Error launching comparison: {e}")
