 class ImportMap(DefaultDict[Any, Any]):
     """A mapping of module name to the set of names to be imported."""
 
     def __init__(self) -> None:
         super().__init__(set)
 
     def merge(self, other: "ImportMap") -> None:
         for module, names in other.items():
             self[module].update(names)
 
+    def get_conflicting_names(self) -> Dict[str, List[str]]:
+        """Find names that are imported from multiple modules.
+
+        Returns a dict mapping each conflicting name to the list of modules
+        that export it.
+        """
+        name_to_modules: Dict[str, List[str]] = {}
+        for module, names in self.items():
+            for name in names:
+                if name not in name_to_modules:
+                    name_to_modules[name] = []
+                name_to_modules[name].append(module)
+        return {name: modules for name, modules in name_to_modules.items() if len(modules) > 1}
+
+    def generate_alias_map(self) -> Dict[Tuple[str, str], str]:
+        """Generate aliases for conflicting names.
+
+        Returns a dict mapping (module, name) tuples to their alias.
+        For non-conflicting names, no entry is added (they don't need aliases).
+        Ensures all generated aliases are unique by adding numerical suffixes if needed.
+        """
+        conflicts = self.get_conflicting_names()
+        alias_map: Dict[Tuple[str, str], str] = {}
+        used_aliases: Set[str] = set()
+
+        for name, modules in conflicts.items():
+            for module in sorted(modules):
+                base_alias = _generate_base_alias_for_import(module, name)
+                alias = _make_unique_alias(base_alias, used_aliases)
+                used_aliases.add(alias)
+                alias_map[(module, name)] = alias
+
+        return alias_map
+
+
+def _generate_base_alias_for_import(module: str, name: str) -> str:
+    """Generate a base alias for an import to avoid conflicts.
+
+    For example:
+        xml.dom.minidom.Element -> MinidomElement
+        xml.etree.ElementTree.Element -> ElementTreeElement
+        module.a.Parent.Child -> AParentChild (nested classes)
+    """
+    parts = module.split(".")
+    if len(parts) >= 2:
+        qualifier = pascal_case(parts[-1])
+    else:
+        qualifier = pascal_case(module)
+    clean_name = name.replace(".", "")
+    return f"{qualifier}{clean_name}"
+
+
+def _make_unique_alias(base_alias: str, used_aliases: Set[str]) -> str:
+    """Ensure alias is unique by adding numerical suffix if needed."""
+    if base_alias not in used_aliases:
+        return base_alias
+    counter = 2
+    while f"{base_alias}{counter}" in used_aliases:
+        counter += 1
+    return f"{base_alias}{counter}"
+
 
