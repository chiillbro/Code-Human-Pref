+++ b/src/commands/ui.py
@@ -0,0 +1,59 @@
+from .base import Command, CommandContext
+
+
+class UICommand(Command):
+    """Base class for UI-related commands."""
+    pass
+
+
+class ToggleDrsZonesCommand(UICommand):
+    """Toggle DRS zones visibility on track."""
+    
+    def execute(self, context: CommandContext) -> None:
+        current = context.get_window_attr('toggle_drs_zones', True)
+        context.set_window_attr('toggle_drs_zones', not current)
+
+
+class ToggleDriverLabelsCommand(UICommand):
+    """Toggle driver labels visibility on track."""
+    
+    def execute(self, context: CommandContext) -> None:
+        current = context.get_window_attr('show_driver_labels', False)
+        context.set_window_attr('show_driver_labels', not current)
+
+
+class ToggleHelpPopupCommand(UICommand):
+    """Toggle help/controls popup visibility."""
+    
+    def execute(self, context: CommandContext) -> None:
+        popup = context.get_window_attr('controls_popup_comp')
+        if not popup:
+            return
+        
+        margin_x = 20
+        margin_y = 20
+        left_pos = float(margin_x)
+        top_pos = float(margin_y + popup.height)
+        
+        if popup.visible:
+            popup.hide()
+        else:
+            popup.show_over(left_pos, top_pos)
+
+
+class ToggleProgressBarCommand(UICommand):
+    """Toggle progress bar visibility."""
+    
+    def execute(self, context: CommandContext) -> None:
+        progress_bar = context.get_window_attr('progress_bar_comp')
+        if progress_bar:
+            progress_bar.toggle_visibility()
+
+
+class ToggleSessionInfoCommand(UICommand):
+    """Toggle session info banner visibility."""
+    
+    def execute(self, context: CommandContext) -> None:
+        session_info = context.get_window_attr('session_info_comp')
+        if session_info:
+            session_info.toggle_visibility()
