+from abc import ABC, abstractmethod
+from dataclasses import dataclass
+from enum import Enum, auto
+from typing import Callable, Dict, List, Optional, Tuple
+
+import arcade
+
+from .base import Command, CommandContext, CommandRegistry
+from .playback import (
+    PlayPauseCommand,
+    StartRewindCommand,
+    StopRewindCommand,
+    StartForwardCommand,
+    StopForwardCommand,
+    IncreaseSpeedCommand,
+    DecreaseSpeedCommand,
+    SetSpeedCommand,
+    RestartCommand,
+    StopSeekingCommand,
+)
+from .ui import (
+    ToggleDrsZonesCommand,
+    ToggleDriverLabelsCommand,
+    ToggleHelpPopupCommand,
+    ToggleProgressBarCommand,
+    ToggleSessionInfoCommand,
+)
+
+
+class InputEventType(Enum):
+    KEY_PRESS = auto()
+    KEY_RELEASE = auto()
+    MOUSE_PRESS = auto()
+    MOUSE_RELEASE = auto()
+
+
+@dataclass
+class InputBinding:
+    """Represents a binding between an input and a command."""
+    command: Command
+    event_type: InputEventType
+
+
+class InputMapper(ABC):
+    """Interface for mapping inputs to commands."""
+    
+    @abstractmethod
+    def get_command(self, event_type: InputEventType, key_or_button: int) -> Optional[Command]:
+        pass
+
+
+class KeyboardInputMapper(InputMapper):
+    """Maps keyboard inputs to commands."""
+    
+    def __init__(self):
+        self._key_press_bindings: Dict[int, Command] = {}
+        self._key_release_bindings: Dict[int, Command] = {}
+        self._setup_default_bindings()
+    
+    def _setup_default_bindings(self) -> None:
+        self._key_press_bindings = {
+            arcade.key.SPACE: PlayPauseCommand(),
+            arcade.key.RIGHT: StartForwardCommand(),
+            arcade.key.LEFT: StartRewindCommand(),
+            arcade.key.UP: IncreaseSpeedCommand(),
+            arcade.key.DOWN: DecreaseSpeedCommand(),
+            arcade.key.KEY_1: SetSpeedCommand(0.5),
+            arcade.key.KEY_2: SetSpeedCommand(1.0),
+            arcade.key.KEY_3: SetSpeedCommand(2.0),
+            arcade.key.KEY_4: SetSpeedCommand(4.0),
+            arcade.key.R: RestartCommand(),
+            arcade.key.D: ToggleDrsZonesCommand(),
+            arcade.key.L: ToggleDriverLabelsCommand(),
+            arcade.key.H: ToggleHelpPopupCommand(),
+            arcade.key.B: ToggleProgressBarCommand(),
+            arcade.key.I: ToggleSessionInfoCommand(),
+        }
+        
+        self._key_release_bindings = {
+            arcade.key.RIGHT: StopForwardCommand(),
+            arcade.key.LEFT: StopRewindCommand(),
+        }
+    
+    def get_command(self, event_type: InputEventType, key: int) -> Optional[Command]:
+        if event_type == InputEventType.KEY_PRESS:
+            return self._key_press_bindings.get(key)
+        elif event_type == InputEventType.KEY_RELEASE:
+            return self._key_release_bindings.get(key)
+        return None
+    
+    def bind_key_press(self, key: int, command: Command) -> None:
+        self._key_press_bindings[key] = command
+    
+    def bind_key_release(self, key: int, command: Command) -> None:
+        self._key_release_bindings[key] = command
+
+
+class InputHandlerStrategy(ABC):
+    """Strategy interface for handling different input scenarios."""
+    
+    @abstractmethod
+    def handle(self, context: CommandContext, event_type: InputEventType, **kwargs) -> bool:
+        """Handle input and return True if handled."""
+        pass
+
+
+class KeyboardInputStrategy(InputHandlerStrategy):
+    """Strategy for handling keyboard input."""
+    
+    def __init__(self, mapper: KeyboardInputMapper):
+        self._mapper = mapper
+    
+    def handle(self, context: CommandContext, event_type: InputEventType, **kwargs) -> bool:
+        key = kwargs.get('key')
+        if key is None:
+            return False
+        
+        command = self._mapper.get_command(event_type, key)
+        if command:
+            command.execute(context)
+            return True
+        return False
+
+
+class InputHandler:
+    """Main input handler that coordinates input processing."""
+    
+    def __init__(self):
+        self._keyboard_mapper = KeyboardInputMapper()
+        self._keyboard_strategy = KeyboardInputStrategy(self._keyboard_mapper)
+        self._stop_seeking_command = StopSeekingCommand()
+    
+    @property
+    def keyboard_mapper(self) -> KeyboardInputMapper:
+        return self._keyboard_mapper
+    
+    def handle_key_press(self, window, symbol: int, modifiers: int) -> bool:
+        """Handle key press event. Returns True if handled."""
+        if symbol == arcade.key.ESCAPE:
+            arcade.close_window()
+            return True
+        
+        context = CommandContext(window=window)
+        return self._keyboard_strategy.handle(
+            context, 
+            InputEventType.KEY_PRESS, 
+            key=symbol, 
+            modifiers=modifiers
+        )
+    
+    def handle_key_release(self, window, symbol: int, modifiers: int) -> bool:
+        """Handle key release event. Returns True if handled."""
+        context = CommandContext(window=window)
+        return self._keyboard_strategy.handle(
+            context, 
+            InputEventType.KEY_RELEASE, 
+            key=symbol, 
+            modifiers=modifiers
+        )
+    
+    def handle_mouse_release_seeking(self, window, x: float, y: float, button: int, modifiers: int) -> bool:
+        """Handle mouse release to stop seeking. Returns True if seeking was active."""
+        context = CommandContext(window=window)
+        is_seeking = (
+            context.get_window_attr('is_forwarding', False) or 
+            context.get_window_attr('is_rewinding', False)
+        )
+        
+        if is_seeking:
+            self._stop_seeking_command.execute(context)
+            return True
+        return False
+
+
+class RaceControlsCommandAdapter:
+    """Adapter that provides commands for the RaceControlsComponent mouse interactions."""
+    
+    def __init__(self):
+        self._play_pause = PlayPauseCommand()
+        self._start_rewind = StartRewindCommand()
+        self._start_forward = StartForwardCommand()
+        self._increase_speed = IncreaseSpeedCommand()
+        self._decrease_speed = DecreaseSpeedCommand()
+    
+    def execute_play_pause(self, window) -> None:
+        context = CommandContext(window=window)
+        self._play_pause.execute(context)
+    
+    def execute_start_rewind(self, window) -> None:
+        context = CommandContext(window=window)
+        self._start_rewind.execute(context)
+    
+    def execute_start_forward(self, window) -> None:
+        context = CommandContext(window=window)
+        self._start_forward.execute(context)
+    
+    def execute_increase_speed(self, window) -> None:
+        context = CommandContext(window=window)
+        self._increase_speed.execute(context)
+    
+    def execute_decrease_speed(self, window) -> None:
+        context = CommandContext(window=window)
+        self._decrease_speed.execute(context)
