@@ -0,0 +1,177 @@
+import sys
+import os
+
+sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
+
+class MockArcade:
+    class key:
+        ESCAPE = 65307
+        SPACE = 32
+        RIGHT = 65363
+        LEFT = 65361
+        UP = 65362
+        DOWN = 65364
+        KEY_1 = 49
+        KEY_2 = 50
+        KEY_3 = 51
+        KEY_4 = 52
+        R = 114
+        D = 100
+        L = 108
+        H = 104
+        B = 98
+        I = 105
+    
+    @staticmethod
+    def close_window():
+        pass
+
+sys.modules['arcade'] = MockArcade()
+
+from src.commands import (
+    Command,
+    CommandContext,
+    PlayPauseCommand,
+    StartRewindCommand,
+    StopRewindCommand,
+    StartForwardCommand,
+    StopForwardCommand,
+    IncreaseSpeedCommand,
+    DecreaseSpeedCommand,
+    SetSpeedCommand,
+    RestartCommand,
+    ToggleDrsZonesCommand,
+    InputHandler,
+    RaceControlsCommandAdapter,
+)
+
+
+class MockWindow:
+    def __init__(self):
+        self.paused = False
+        self.is_rewinding = False
+        self.is_forwarding = False
+        self.was_paused_before_hold = False
+        self.playback_speed = 1.0
+        self.frame_index = 100.0
+        self.toggle_drs_zones = True
+        self.show_driver_labels = False
+        self.race_controls_comp = MockRaceControls()
+        self.degradation_integrator = None
+    
+    def _broadcast_telemetry_state(self):
+        pass
+
+
+class MockRaceControls:
+    def __init__(self):
+        self.flashed_buttons = []
+    
+    def flash_button(self, name):
+        self.flashed_buttons.append(name)
+
+
+def test_play_pause_command():
+    window = MockWindow()
+    context = CommandContext(window=window)
+    command = PlayPauseCommand()
+    
+    assert window.paused == False
+    command.execute(context)
+    assert window.paused == True
+    command.execute(context)
+    assert window.paused == False
+
+
+def test_rewind_commands():
+    window = MockWindow()
+    context = CommandContext(window=window)
+    
+    start = StartRewindCommand()
+    stop = StopRewindCommand()
+    
+    start.execute(context)
+    assert window.is_rewinding == True
+    assert window.paused == True
+    
+    stop.execute(context)
+    assert window.is_rewinding == False
+
+
+def test_speed_commands():
+    window = MockWindow()
+    context = CommandContext(window=window)
+    
+    increase = IncreaseSpeedCommand()
+    decrease = DecreaseSpeedCommand()
+    
+    increase.execute(context)
+    assert window.playback_speed == 2.0
+    
+    increase.execute(context)
+    assert window.playback_speed == 4.0
+    
+    decrease.execute(context)
+    assert window.playback_speed == 2.0
+
+
+def test_set_speed_command():
+    window = MockWindow()
+    context = CommandContext(window=window)
+    
+    command = SetSpeedCommand(4.0)
+    command.execute(context)
+    assert window.playback_speed == 4.0
+
+
+def test_restart_command():
+    window = MockWindow()
+    context = CommandContext(window=window)
+    
+    command = RestartCommand()
+    command.execute(context)
+    
+    assert window.frame_index == 0.0
+    assert window.playback_speed == 1.0
+
+
+def test_toggle_drs_zones():
+    window = MockWindow()
+    context = CommandContext(window=window)
+    
+    command = ToggleDrsZonesCommand()
+    
+    assert window.toggle_drs_zones == True
+    command.execute(context)
+    assert window.toggle_drs_zones == False
+
+
+def test_input_handler():
+    handler = InputHandler()
+    window = MockWindow()
+    
+    handler.handle_key_press(window, MockArcade.key.SPACE, 0)
+    assert window.paused == True
+
+
+def test_command_adapter():
+    adapter = RaceControlsCommandAdapter()
+    window = MockWindow()
+    
+    adapter.execute_play_pause(window)
+    assert window.paused == True
+    
+    adapter.execute_start_rewind(window)
+    assert window.is_rewinding == True
+
+
+if __name__ == "__main__":
+    test_play_pause_command()
+    test_rewind_commands()
+    test_speed_commands()
+    test_set_speed_command()
+    test_restart_command()
+    test_toggle_drs_zones()
+    test_input_handler()
+    test_command_adapter()
+    print("All tests passed!")
