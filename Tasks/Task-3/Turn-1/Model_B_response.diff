@@ -0,0 +1,95 @@
+from abc import ABC, abstractmethod
+from dataclasses import dataclass
+from typing import Any, Callable, Dict, List, Optional, Type
+
+
+@dataclass
+class CommandContext:
+    """Context object passed to commands containing the window and any additional state."""
+    window: Any
+    
+    def get_window_attr(self, attr: str, default: Any = None) -> Any:
+        return getattr(self.window, attr, default)
+    
+    def set_window_attr(self, attr: str, value: Any) -> None:
+        setattr(self.window, attr, value)
+    
+    def has_window_attr(self, attr: str) -> bool:
+        return hasattr(self.window, attr)
+
+
+class Command(ABC):
+    """Base command interface for all playback and UI commands."""
+    
+    @abstractmethod
+    def execute(self, context: CommandContext) -> None:
+        """Execute the command."""
+        pass
+
+
+class CommandFactory(ABC):
+    """Factory interface for creating command instances."""
+    
+    @abstractmethod
+    def create_command(self, command_type: str, **kwargs) -> Optional[Command]:
+        """Create a command instance by type."""
+        pass
+
+
+class CommandRegistry:
+    """Registry for mapping command identifiers to command classes."""
+    
+    def __init__(self):
+        self._commands: Dict[str, Type[Command]] = {}
+        self._factories: Dict[str, CommandFactory] = {}
+    
+    def register(self, command_id: str, command_class: Type[Command]) -> None:
+        """Register a command class with an identifier."""
+        self._commands[command_id] = command_class
+    
+    def register_factory(self, factory_id: str, factory: CommandFactory) -> None:
+        """Register a command factory."""
+        self._factories[factory_id] = factory
+    
+    def get_command(self, command_id: str, **kwargs) -> Optional[Command]:
+        """Get a command instance by identifier."""
+        if command_id in self._commands:
+            return self._commands[command_id](**kwargs)
+        
+        for factory in self._factories.values():
+            command = factory.create_command(command_id, **kwargs)
+            if command:
+                return command
+        
+        return None
+    
+    def execute(self, command_id: str, context: CommandContext, **kwargs) -> bool:
+        """Execute a command by identifier. Returns True if command was found and executed."""
+        command = self.get_command(command_id, **kwargs)
+        if command:
+            command.execute(context)
+            return True
+        return False
+
+
+class CompositeCommand(Command):
+    """A command that executes multiple commands in sequence."""
+    
+    def __init__(self, commands: List[Command]):
+        self._commands = commands
+    
+    def execute(self, context: CommandContext) -> None:
+        for command in self._commands:
+            command.execute(context)
+
+
+class ConditionalCommand(Command):
+    """A command that executes only if a condition is met."""
+    
+    def __init__(self, command: Command, condition: Callable[[CommandContext], bool]):
+        self._command = command
+        self._condition = condition
+    
+    def execute(self, context: CommandContext) -> None:
+        if self._condition(context):
+            self._command.execute(context)
