+        rotated_points = []
+        for x, y in self.world_inner_points:
+            rotated_points.append(_rotate_about_center(x, y))
+        for x, y in self.world_outer_points:
+            rotated_points.append(_rotate_about_center(x, y))
+
+        xs = [p[0] for p in rotated_points]
+        ys = [p[1] for p in rotated_points]
