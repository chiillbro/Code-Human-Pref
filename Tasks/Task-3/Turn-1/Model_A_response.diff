+        usable_h = screen_h * (1 - 2 * padding)
+
+        # Calculate scale to fit whichever dimension is the limiting factor
+        scale_x = usable_w / world_w
+        scale_y = usable_h / world_h
+        self.world_scale = min(scale_x, scale_y)
