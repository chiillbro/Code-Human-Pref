+                # Get normal vector in world space
+                nx = self._ref_nx[idx]
+
+                ny = self._ref_ny[idx]
+                
+                # Rotate normal to screen space
+                if self._rot_rad:
+                    snx = nx * self._cos_rot - ny * self._sin_rot
