+        world_x_max = max(xs) if xs else self.x_max
+        world_y_min = min(ys) if ys else self.y_min
+        world_y_max = max(ys) if ys else self.y_max
+
+        world_w = max(1.0, world_x_max - world_x_min)
+        world_h = max(1.0, world_y_max - world_y_min)
