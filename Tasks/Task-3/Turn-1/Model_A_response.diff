@@ -0,0 +1,237 @@
+"""
+Input handler for race replay windows.
+
+This module provides a unified input handling system that maps keyboard
+and mouse events to commands. It eliminates the duplication between
+on_key_press/on_key_release handlers and UI component click handlers.
+"""
+from typing import TYPE_CHECKING, Dict, Optional, Callable
+import arcade
+
+from src.commands import (
+    Command,
+    CommandInvoker,
+    TogglePauseCommand,
+    StartForwardSeekCommand,
+    StopForwardSeekCommand,
+    StartRewindSeekCommand,
+    StopRewindSeekCommand,
+    StopAllSeekingCommand,
+    IncreaseSpeedCommand,
+    DecreaseSpeedCommand,
+    SetSpeedCommand,
+    RestartCommand,
+    ToggleDRSZonesCommand,
+    ToggleDriverLabelsCommand,
+    ToggleHelpPopupCommand,
+    ToggleProgressBarCommand,
+    ToggleSessionInfoCommand,
+    CloseWindowCommand,
+    ToggleComparisonTelemetryCommand,
+    QualifyingRestartCommand,
+    QualifyingIncreaseSpeedCommand,
+    QualifyingDecreaseSpeedCommand,
+    QualifyingSetSpeedCommand,
+)
+
+if TYPE_CHECKING:
+    from arcade import Window
+
+
+class InputHandler:
+    """
+    Handles keyboard and mouse input for race replay windows.
+    
+    This class maintains the mapping between input events and commands,
+    providing a clean separation between input detection and action execution.
+    """
+    
+    def __init__(self, window: "Window"):
+        self.window = window
+        self.invoker = CommandInvoker(window)
+        self._key_press_commands: Dict[int, Command] = {}
+        self._key_release_commands: Dict[int, Command] = {}
+    
+    def register_key_press(self, key: int, command: Command) -> None:
+        """Register a command to be executed when a key is pressed."""
+        self._key_press_commands[key] = command
+    
+    def register_key_release(self, key: int, command: Command) -> None:
+        """Register a command to be executed when a key is released."""
+        self._key_release_commands[key] = command
+    
+    def handle_key_press(self, symbol: int, modifiers: int) -> bool:
+        """
+        Handle a key press event.
+        
+        Returns True if the key was handled, False otherwise.
+        """
+        if symbol in self._key_press_commands:
+            self.invoker.execute(self._key_press_commands[symbol])
+            return True
+        return False
+    
+    def handle_key_release(self, symbol: int, modifiers: int) -> bool:
+        """
+        Handle a key release event.
+        
+        Returns True if the key was handled, False otherwise.
+        """
+        if symbol in self._key_release_commands:
+            self.invoker.execute(self._key_release_commands[symbol])
+            return True
+        return False
+    
+    def execute_command(self, command: Command) -> None:
+        """Execute a command directly (used by UI components)."""
+        self.invoker.execute(command)
+
+
+class RaceReplayInputHandler(InputHandler):
+    """
+    Input handler specifically configured for race replay mode.
+    
+    This sets up all the default key bindings for race replay playback:
+    - SPACE: Toggle pause
+    - Arrow keys: Speed control and seeking
+    - Number keys: Preset speeds
+    - Letter keys: Toggle various UI elements
+    - ESC: Close window
+    """
+    
+    def __init__(self, window: "Window"):
+        super().__init__(window)
+        self._setup_default_bindings()
+    
+    def _setup_default_bindings(self) -> None:
+        """Configure the default key bindings for race replay."""
+        # ESC always closes
+        self.register_key_press(arcade.key.ESCAPE, CloseWindowCommand())
+        
+        # Playback controls
+        self.register_key_press(arcade.key.SPACE, TogglePauseCommand())
+        self.register_key_press(arcade.key.RIGHT, StartForwardSeekCommand())
+        self.register_key_press(arcade.key.LEFT, StartRewindSeekCommand())
+        self.register_key_release(arcade.key.RIGHT, StopForwardSeekCommand())
+        self.register_key_release(arcade.key.LEFT, StopRewindSeekCommand())
+        
+        # Speed controls
+        self.register_key_press(arcade.key.UP, IncreaseSpeedCommand())
+        self.register_key_press(arcade.key.DOWN, DecreaseSpeedCommand())
+        
+        # Preset speeds
+        self.register_key_press(arcade.key.KEY_1, SetSpeedCommand(0.5))
+        self.register_key_press(arcade.key.KEY_2, SetSpeedCommand(1.0))
+        self.register_key_press(arcade.key.KEY_3, SetSpeedCommand(2.0))
+        self.register_key_press(arcade.key.KEY_4, SetSpeedCommand(4.0))
+        
+        # Restart
+        self.register_key_press(arcade.key.R, RestartCommand())
+        
+        # UI toggles
+        self.register_key_press(arcade.key.D, ToggleDRSZonesCommand())
+        self.register_key_press(arcade.key.L, ToggleDriverLabelsCommand())
+        self.register_key_press(arcade.key.H, ToggleHelpPopupCommand())
+        self.register_key_press(arcade.key.B, ToggleProgressBarCommand())
+        self.register_key_press(arcade.key.I, ToggleSessionInfoCommand())
+
+
+class QualifyingReplayInputHandler(InputHandler):
+    """
+    Input handler specifically configured for qualifying replay mode.
+    
+    Similar to race replay but with qualifying-specific behavior:
+    - Different speed control logic (doubles/halves instead of preset steps)
+    - Comparison telemetry toggle
+    - Respects lap completion state
+    """
+    
+    def __init__(self, window: "Window"):
+        super().__init__(window)
+        self._setup_default_bindings()
+    
+    def _setup_default_bindings(self) -> None:
+        """Configure the default key bindings for qualifying replay."""
+        # ESC always closes
+        self.register_key_press(arcade.key.ESCAPE, CloseWindowCommand())
+        
+        # Always-available commands (even when lap is complete)
+        self.register_key_press(arcade.key.R, QualifyingRestartCommand())
+        self.register_key_press(arcade.key.C, ToggleComparisonTelemetryCommand())
+        self.register_key_press(arcade.key.D, ToggleDRSZonesCommand())
+        self.register_key_press(arcade.key.H, ToggleHelpPopupCommand())
+    
+    def handle_key_press(self, symbol: int, modifiers: int) -> bool:
+        """
+        Handle a key press event with qualifying-specific logic.
+        
+        Some commands are blocked when the lap is complete.
+        """
+        # Always handle ESC, R, C, D, H
+        always_allowed = {
+            arcade.key.ESCAPE,
+            arcade.key.R,
+            arcade.key.C,
+            arcade.key.D,
+            arcade.key.H,
+        }
+        
+        if symbol in always_allowed:
+            return super().handle_key_press(symbol, modifiers)
+        
+        # Block other controls when lap is complete
+        if self._is_lap_complete():
+            return False
+        
+        # Handle playback controls (not registered, handled inline for clarity)
+        return self._handle_playback_key_press(symbol)
+    
+    def handle_key_release(self, symbol: int, modifiers: int) -> bool:
+        """Handle a key release event."""
+        if symbol == arcade.key.RIGHT:
+            self.invoker.execute(StopForwardSeekCommand())
+            return True
+        elif symbol == arcade.key.LEFT:
+            self.invoker.execute(StopRewindSeekCommand())
+            return True
+        return False
+    
+    def _handle_playback_key_press(self, symbol: int) -> bool:
+        """Handle playback-related key presses."""
+        if symbol == arcade.key.SPACE:
+            self.invoker.execute(TogglePauseCommand())
+            return True
+        elif symbol == arcade.key.RIGHT:
+            self.invoker.execute(StartForwardSeekCommand())
+            return True
+        elif symbol == arcade.key.LEFT:
+            self.invoker.execute(StartRewindSeekCommand())
+            return True
+        elif symbol == arcade.key.UP:
+            self.invoker.execute(QualifyingIncreaseSpeedCommand())
+            return True
+        elif symbol == arcade.key.DOWN:
+            self.invoker.execute(QualifyingDecreaseSpeedCommand())
+            return True
+        elif symbol == arcade.key.KEY_1:
+            self.invoker.execute(QualifyingSetSpeedCommand(0.5))
+            return True
+        elif symbol == arcade.key.KEY_2:
+            self.invoker.execute(QualifyingSetSpeedCommand(1.0))
+            return True
+        elif symbol == arcade.key.KEY_3:
+            self.invoker.execute(QualifyingSetSpeedCommand(2.0))
+            return True
+        elif symbol == arcade.key.KEY_4:
+            self.invoker.execute(QualifyingSetSpeedCommand(4.0))
+            return True
+        return False
+    
+    def _is_lap_complete(self) -> bool:
+        """Check if the current lap has finished playing."""
+        window = self.window
+        return (
+            getattr(window, "chart_active", False) and
+            getattr(window, "n_frames", 0) > 0 and
+            getattr(window, "frame_index", 0) >= window.n_frames - 1
+        )
