+                else:
+                    snx, sny = nx, ny
+                
+                offset_dist = 45 if i % 2 == 0 else 75
+                
+                lx = sx + snx * offset_dist
+                ly = sy + sny * offset_dist
+                
+                arcade.draw_line(sx, sy, lx, ly, color, 1)
+                
+                anchor_x = "left" if snx >= 0 else "right"
+                text_padding = 3 if snx >= 0 else -3
