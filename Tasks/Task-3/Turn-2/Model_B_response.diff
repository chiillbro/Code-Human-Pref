+from typing import Any
+from .base import Command
+
+
+class ToggleDrsZonesCommand(Command):
+    """Toggle DRS zones visibility on track."""
+    
+    def execute(self, window: Any) -> None:
+        window.toggle_drs_zones = not getattr(window, 'toggle_drs_zones', True)
+
+
+class ToggleDriverLabelsCommand(Command):
+    """Toggle driver labels visibility on track."""
+    
+    def execute(self, window: Any) -> None:
+        window.show_driver_labels = not getattr(window, 'show_driver_labels', False)
+
+
+class ToggleHelpPopupCommand(Command):
+    """Toggle help/controls popup visibility."""
+    
+    def execute(self, window: Any) -> None:
+        popup = getattr(window, 'controls_popup_comp', None)
+        if not popup:
+            return
+        
+        margin_x = 20
+        margin_y = 20
+        left_pos = float(margin_x)
+        top_pos = float(margin_y + popup.height)
+        
+        if popup.visible:
+            popup.hide()
+        else:
+            popup.show_over(left_pos, top_pos)
+
+
+class ToggleProgressBarCommand(Command):
+    """Toggle progress bar visibility."""
+    
+    def execute(self, window: Any) -> None:
+        progress_bar = getattr(window, 'progress_bar_comp', None)
+        if progress_bar:
+            progress_bar.toggle_visibility()
+
+
+class ToggleSessionInfoCommand(Command):
+    """Toggle session info banner visibility."""
+    
+    def execute(self, window: Any) -> None:
+        session_info = getattr(window, 'session_info_comp', None)
+        if session_info:
+            session_info.toggle_visibility()
