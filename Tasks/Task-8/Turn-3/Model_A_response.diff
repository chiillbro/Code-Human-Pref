+class TestReplaceTypedDictWithStubs:
+    """Test the ReplaceTypedDictWithStubs TypeRewriter."""
+
+    def test_direct_typed_dict(self):
+        """Direct TypedDict should be replaced with forward ref."""
+        td = TypedDict(DUMMY_TYPED_DICT_NAME, {'a': int, 'b': str})
+        rewriter = ReplaceTypedDictWithStubs('foo')
+        result = rewriter.rewrite(td)
+
+        assert result == make_forward_ref('FooTypedDict')
+        assert len(rewriter.class_stubs) == 1
+        assert rewriter.class_stubs[0].name == 'FooTypedDict(TypedDict)'
+
+    def test_typed_dict_in_list(self):
+        """TypedDict nested in List should be replaced."""
+        td = TypedDict(DUMMY_TYPED_DICT_NAME, {'a': int})
+        rewriter = ReplaceTypedDictWithStubs('items')
+        result = rewriter.rewrite(List[td])
+
+        assert result == List[make_forward_ref('ItemsTypedDict')]
+        assert len(rewriter.class_stubs) == 1
