+class ReplaceTypedDictWithStubs(TypeRewriter):
+    """TypeRewriter that replaces anonymous TypedDicts with forward references.
+
+    This rewriter walks through types (including nested generics) and replaces
+    any anonymous TypedDicts (generated by MonkeyType tracing) with forward
+    references to generated class stubs.
+    """
+
+    def __init__(self, name_prefix: str) -> None:
+        """Initialize the rewriter.
+
+        Args:
+            name_prefix: Prefix for generating TypedDict class names.
+        """
+        self.name_prefix = name_prefix
+        self.class_stubs: List['ClassStub'] = []
+        self._counter = 0
+        self._used_base_name = False
+
+    def _get_next_name(self) -> str:
+        """Generate the next unique TypedDict class name.
+
+        The first TypedDict uses the base name_prefix directly.
+        Subsequent TypedDicts get numbered suffixes.
+        """
+        if not self._used_base_name:
+            self._used_base_name = True
+            return self.name_prefix
+        self._counter += 1
+        return f"{self.name_prefix}_{self._counter}"
+
+    def _rewrite_container(self, cls: Any, container: Any) -> Any:
+        """Override to handle containers from any module, not just typing."""
+        args = getattr(container, '__args__', None)
+        if args is None:
+            return container
+        elif args == ((),):  # special case of empty tuple `Tuple[()]`
+            return container
+
+        new_args = tuple(self.rewrite(elem) for elem in args)
+        if new_args == args:
+            return container
+
+        # Use copy_with if available (Python 3.7+)
+        copy_with = getattr(container, 'copy_with', None)
+        if copy_with is not None:
+            return copy_with(new_args)
+
+        # Fallback: use cls if provided, otherwise use origin
+        if cls is not None:
+            if len(new_args) == 1:
+                return cls[new_args[0]]
+            return cls[new_args]
+
+        origin = getattr(container, '__origin__', None)
+        if origin is not None:
+            if len(new_args) == 1:
+                return origin[new_args[0]]
+            return origin[new_args]
+        return container
+
+    def rewrite_TypedDict(self, typ: Any) -> Any:
+        """Handle TypedDicts - replace anonymous ones with forward references."""
+        if is_anonymous_typed_dict(typ):
+            class_name = get_typed_dict_class_name(self._get_next_name())
+            self.class_stubs.extend(ClassStub.stubs_from_typed_dict(typ, class_name))
+            return make_forward_ref(class_name)
+        # Non-anonymous TypedDicts pass through but still rewrite their fields
+        return super().rewrite_TypedDict(typ)
+
+
