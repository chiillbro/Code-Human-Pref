+def _extract_nested_typed_dicts(
+    typ: type,
+    name_prefix: str,
+    class_stubs: List['ClassStub'],
+) -> type:
+    """Extract anonymous TypedDicts nested within generic types and replace with forward refs.
+
+    This function recursively processes a type and extracts any anonymous TypedDicts
+    found within generic containers (List, Dict, Set, Tuple, Union, etc.).
+    Each extracted TypedDict is converted to a ClassStub and replaced with a forward reference.
+
+    Args:
+        typ: The type to process
+        name_prefix: Prefix to use for generating class names from nested TypedDicts
+        class_stubs: List to append extracted ClassStub instances to
+
+    Returns:
+        The processed type with anonymous TypedDicts replaced by forward references
+    """
+    if is_anonymous_typed_dict(typ):
+        _class_name = get_typed_dict_class_name(name_prefix)
+        class_stubs.extend(ClassStub.stubs_from_typed_dict(typ, _class_name))
+        return make_forward_ref(_class_name)
+
+    if is_generic(typ):
+        args = getattr(typ, '__args__', None)
+        if args:
+            new_args = []
+            for i, arg in enumerate(args):
+                # Generate a unique name for each nested TypedDict
+                nested_prefix = f"{name_prefix}_{i}"
+                new_arg = _extract_nested_typed_dicts(arg, nested_prefix, class_stubs)
+                new_args.append(new_arg)
+            if new_args != list(args):
+                # Reconstruct the generic with the new arguments
+                # Use copy_with if available (Python 3.9+), otherwise use __class_getitem__
+                if hasattr(typ, 'copy_with'):
+                    return typ.copy_with(tuple(new_args))
+                else:
+                    # For older Python or different generic types, reconstruct manually
+                    # We use __class_getitem__ on the type's class to preserve typing.List vs list
+                    origin = getattr(typ, '__origin__', None)
+                    if origin is not None:
+                        # Get the typing module's generic alias (e.g., typing.List instead of list)
+                        # by using the generic alias's __class_getitem__ if available
+                        if hasattr(typ, '__class__') and hasattr(typ.__class__, '__getitem__'):
+                            # Reconstruct by getting the base generic and subscripting it
+                            # We check if it's a Union first since it's special
+                            if is_union(typ):
+                                return Union[tuple(new_args)]
+                            # For _GenericAlias, we can use __getitem__ on the origin
+                            # but we need to get the proper typing.X form
+                            import typing
+                            _name = getattr(typ, '_name', None)
+                            if _name and hasattr(typing, _name):
+                                base_generic = getattr(typing, _name)
+                                return base_generic[tuple(new_args)]
+                        return origin[tuple(new_args)]
+    return typ
+
