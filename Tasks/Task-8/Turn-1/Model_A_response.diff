+def _is_subscriptable_generic(typ: Any) -> bool:
+    """Check if typ is a subscriptable generic type (e.g., List, Dict from typing module).
+
+    This handles both parameterized generics (List[int]) and unparameterized
+    generic aliases (List, Dict) which are _SpecialGenericAlias in Python 3.9+.
+    """
+    return hasattr(typ, '__getitem__') and hasattr(typ, '__origin__')
+
