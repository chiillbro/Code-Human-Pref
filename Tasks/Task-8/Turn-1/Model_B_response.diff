+def _reconstruct_generic(typ: Any, new_args: Tuple) -> Any:
+    """Reconstruct a generic type with new type arguments.
+
+    Uses copy_with if available (Python 3.7+) to properly preserve
+    typing module generics like List, Dict, etc.
+    """
+    copy_with = getattr(typ, 'copy_with', None)
+    if copy_with is not None:
+        return copy_with(new_args)
+
+    # Fallback for older Python versions or non-standard generics
+    origin = getattr(typ, '__origin__', None)
+    if origin is None:
+        return typ
+    if len(new_args) == 1:
+        return origin[new_args[0]]
+    return origin[new_args]
+
+
+def extract_and_replace_typeddicts(
+    typ: Any,
+    name_prefix: str,
+    typed_dict_class_stubs: List['ClassStub'],
+    counter: Optional[List[int]] = None,
+) -> Any:
+    """Recursively extract TypedDicts from a type and replace them with forward references.
+
+    This handles TypedDicts nested within generic containers like List[TypedDict],
+    Dict[str, TypedDict], etc.
+
+    Args:
+        typ: The type to process
+        name_prefix: Prefix for generating TypedDict class names
+        typed_dict_class_stubs: List to append generated ClassStub instances to
+        counter: Mutable counter for generating unique names for nested TypedDicts
+
+    Returns:
+        The type with all anonymous TypedDicts replaced with forward references
+    """
+    if counter is None:
+        counter = [0]
+
+    if is_anonymous_typed_dict(typ):
+        class_name = get_typed_dict_class_name(name_prefix)
+        typed_dict_class_stubs.extend(ClassStub.stubs_from_typed_dict(typ, class_name))
+        return make_forward_ref(class_name)
+
+    if is_generic(typ) and not is_any(typ):
+        args = getattr(typ, '__args__', None)
+        if args:
+            new_args = []
+            for i, arg in enumerate(args):
+                if is_anonymous_typed_dict(arg):
+                    counter[0] += 1
+                    nested_name = f"{name_prefix}_{counter[0]}"
+                    new_arg = extract_and_replace_typeddicts(
+                        arg, nested_name, typed_dict_class_stubs, counter
+                    )
+                elif is_generic(arg) and not is_any(arg):
+                    new_arg = extract_and_replace_typeddicts(
+                        arg, name_prefix, typed_dict_class_stubs, counter
+                    )
+                else:
+                    new_arg = arg
+                new_args.append(new_arg)
+
+            if new_args != list(args):
+                return _reconstruct_generic(typ, tuple(new_args))
+
+    return typ
