+class ReplaceTypedDictWithForwardRef(TypeRewriter):
+    """Replace anonymous TypedDicts with forward references and collect class stubs.
+
+    This rewriter walks through types (including nested generics) and replaces
+    any anonymous TypedDicts with forward references while accumulating the
+    ClassStub definitions needed to define those TypedDicts.
+    """
+
+    def __init__(self, name_prefix: str, class_stubs: List) -> None:
+        """Initialize the rewriter.
+
+        Args:
+            name_prefix: Prefix for generating TypedDict class names
+            class_stubs: List to append generated ClassStub instances to
+        """
+        self.name_prefix = name_prefix
+        self.class_stubs = class_stubs
+        self._counter = 0
+
+    def _get_next_name(self) -> str:
+        """Generate a unique name for a nested TypedDict."""
+        self._counter += 1
+        return f"{self.name_prefix}_{self._counter}"
+
+    def _reconstruct_generic(self, typ, new_args):
+        """Reconstruct a generic type with new type arguments."""
+        copy_with = getattr(typ, 'copy_with', None)
+        if copy_with is not None:
+            return copy_with(new_args)
+        # Fallback for older Python versions
+        origin = getattr(typ, '__origin__', None)
+        if origin is None:
+            return typ
+        if len(new_args) == 1:
+            return origin[new_args[0]]
+        return origin[new_args]
+
+    def _rewrite_container(self, cls, container):
+        """Override to use _reconstruct_generic for proper typing module support."""
+        args = getattr(container, '__args__', None)
+        if args is None:
+            return container
+        elif args == ((),):  # special case of empty tuple `Tuple[()]`
+            return container
+        new_args = tuple(self.rewrite(elem) for elem in args)
+        if new_args == args:
+            return container
+        return self._reconstruct_generic(container, new_args)
+
+    def rewrite_DUMMY_NAME(self, typ):
+        """Handle anonymous TypedDicts (those with DUMMY_TYPED_DICT_NAME as their name)."""
+        # Import here to avoid circular dependency
+        from monkeytype.stubs import ClassStub, get_typed_dict_class_name
+
+        class_name = get_typed_dict_class_name(self.name_prefix)
+        self.class_stubs.extend(ClassStub.stubs_from_typed_dict(typ, class_name))
+        return make_forward_ref(class_name)
+
+    def generic_rewrite(self, typ):
+        """Handle TypedDicts that are nested inside other anonymous TypedDicts."""
+        if is_anonymous_typed_dict(typ):
+            # Import here to avoid circular dependency
+            from monkeytype.stubs import ClassStub, get_typed_dict_class_name
+
+            nested_name = self._get_next_name()
+            class_name = get_typed_dict_class_name(nested_name)
+            self.class_stubs.extend(ClassStub.stubs_from_typed_dict(typ, class_name))
+            return make_forward_ref(class_name)
+        return typ
+
