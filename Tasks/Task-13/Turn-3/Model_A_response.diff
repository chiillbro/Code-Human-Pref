+class TestGetWdcStandings:
+    @patch('fastf1.ergast.Ergast')
+    def test_successful_ergast_fetch(self, mock_ergast_class):
+        mock_session = Mock()
+        mock_session.event.get.side_effect = lambda k, default=None: {
+            'EventDate': Mock(year=2024),
+            'RoundNumber': 5
+        }.get(k, default)
+
+        mock_df = pd.DataFrame({
+            'driverCode': ['VER', 'NOR', 'LEC'],
+            'position': [1, 2, 3]
+        })
+        mock_standings = Mock()
+        mock_standings.content = [mock_df]
+        
+        mock_ergast_instance = Mock()
+        mock_ergast_instance.get_driver_standings.return_value = mock_standings
+        mock_ergast_class.return_value = mock_ergast_instance
+
+        result = _get_wdc_standings(mock_session)
+        
+        assert result == {'VER': 1, 'NOR': 2, 'LEC': 3}
+
+    def test_missing_year_returns_empty(self):
+        mock_session = Mock()
+        mock_session.event.get.side_effect = lambda k, default=None: {
+            'EventDate': None,
+            'RoundNumber': 5
+        }.get(k, default)
+
+        result = _get_wdc_standings(mock_session)
+        assert result == {}
+
+    def test_missing_round_returns_empty(self):
+        mock_session = Mock()
+        mock_session.event.get.side_effect = lambda k, default=None: {
+            'EventDate': Mock(year=2024),
+            'RoundNumber': None
+        }.get(k, default)
+
+        result = _get_wdc_standings(mock_session)
+        assert result == {}
+
