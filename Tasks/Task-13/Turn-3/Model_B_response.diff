+class TestGetWdcStandings:
+    @pytest.fixture
+    def mock_session(self):
+        session = Mock()
+        session.event = {
+            'EventDate': pd.Timestamp('2024-03-10'),
+            'RoundNumber': 3
+        }
+        return session
+        
+    def test_missing_year_returns_empty(self):
+        session = Mock()
+        session.event = {'EventDate': None, 'RoundNumber': 3}
+        
+        result = _get_wdc_standings(session)
+        assert result == {}
+        
+    def test_missing_round_returns_empty(self):
+        session = Mock()
+        session.event = {'EventDate': pd.Timestamp('2024-03-10'), 'RoundNumber': None}
+        
+        result = _get_wdc_standings(session)
+        assert result == {}
+        
+    def test_fastf1_ergast_success(self, mock_session):
+        # Mock the Ergast class inside fastf1.ergast
+        mock_ergast_instance = Mock()
+        standings_df = pd.DataFrame({
+            'driverCode': ['VER', 'PER', 'LEC'],
+            'position': [1, 2, 3]
+        })
+        mock_standings = Mock()
+        mock_standings.content = [standings_df]
+        mock_ergast_instance.get_driver_standings.return_value = mock_standings
+        
+        mock_ergast_class = Mock(return_value=mock_ergast_instance)
+        
+        with patch.dict('sys.modules', {'fastf1.ergast': Mock(Ergast=mock_ergast_class)}):
+            result = _get_wdc_standings(mock_session)
+        
+        assert result == {'VER': 1, 'PER': 2, 'LEC': 3}
+        
+    @patch('requests.get')
+    def test_fallback_to_ergast_api(self, mock_requests, mock_session):
+        # Make fastf1.ergast import fail
+        with patch.dict('sys.modules', {'fastf1.ergast': None}):
+            # Mock successful requests fallback
+            mock_response = Mock()
+            mock_response.status_code = 200
+            mock_response.json.return_value = {
+                'MRData': {
+                    'StandingsTable': {
+                        'StandingsLists': [{
+                            'DriverStandings': [
+                                {'position': '1', 'Driver': {'code': 'VER'}},
+                                {'position': '2', 'Driver': {'code': 'PER'}},
+                            ]
+                        }]
+                    }
+                }
+            }
+            mock_requests.return_value = mock_response
+            
+            result = _get_wdc_standings(mock_session)
+        
+        assert result == {'VER': 1, 'PER': 2}
+        
+    @patch('requests.get')
+    def test_both_methods_fail_returns_empty(self, mock_requests, mock_session):
+        mock_requests.side_effect = Exception("requests failed")
+        
+        with patch.dict('sys.modules', {'fastf1.ergast': None}):
+            result = _get_wdc_standings(mock_session)
+        
+        assert result == {}
+
