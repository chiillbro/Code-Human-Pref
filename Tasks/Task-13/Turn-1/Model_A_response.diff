+import pytest
+from src.lib.tyres import get_tyre_compound_int, get_tyre_compound_str
+
+
+class TestGetTyreCompoundInt:
+    @pytest.mark.parametrize("compound_str,expected", [
+        ("SOFT", 0),
+        ("MEDIUM", 1),
+        ("HARD", 2),
+        ("INTERMEDIATE", 3),
+        ("WET", 4),
+    ])
+    def test_standard_compounds(self, compound_str, expected):
+        assert get_tyre_compound_int(compound_str) == expected
+
+    @pytest.mark.parametrize("compound_str,expected", [
+        ("soft", 0),
+        ("Soft", 0),
+        ("SoFt", 0),
+        ("medium", 1),
+        ("MEDIUM", 1),
+        ("hard", 2),
+        ("intermediate", 3),
+        ("wet", 4),
+    ])
+    def test_case_insensitivity(self, compound_str, expected):
+        assert get_tyre_compound_int(compound_str) == expected
+
+    @pytest.mark.parametrize("invalid_input", [
+        "SUPERSOFT",
+        "HYPERSOFT",
+        "ULTRASOFT",
+        "unknown",
+        "",
+        "S",
+        "M",
+        "H",
+        "I",
+        "W",
+        "12345",
+        "soft ",
+        " soft",
+    ])
+    def test_invalid_compounds_return_minus_one(self, invalid_input):
+        assert get_tyre_compound_int(invalid_input) == -1
+
+    def test_none_input_raises_attribute_error(self):
+        with pytest.raises(AttributeError):
+            get_tyre_compound_int(None)
+
+    def test_numeric_input_raises_attribute_error(self):
+        with pytest.raises(AttributeError):
+            get_tyre_compound_int(123)
+
+
+class TestGetTyreCompoundStr:
+    @pytest.mark.parametrize("compound_int,expected", [
+        (0, "SOFT"),
+        (1, "MEDIUM"),
+        (2, "HARD"),
+        (3, "INTERMEDIATE"),
+        (4, "WET"),
+    ])
+    def test_standard_compound_ints(self, compound_int, expected):
+        assert get_tyre_compound_str(compound_int) == expected
+
+    @pytest.mark.parametrize("invalid_int", [
+        -1,
+        5,
+        100,
+        -100,
+        999,
+    ])
+    def test_invalid_ints_return_unknown(self, invalid_int):
+        assert get_tyre_compound_str(invalid_int) == "UNKNOWN"
+
+    @pytest.mark.parametrize("float_input,expected", [
+        (0.0, "SOFT"),
+        (1.0, "MEDIUM"),
+        (2.0, "HARD"),
+        (3.0, "INTERMEDIATE"),
+        (4.0, "WET"),
+    ])
+    def test_float_inputs_match_ints(self, float_input, expected):
+        assert get_tyre_compound_str(float_input) == expected
+
+    @pytest.mark.parametrize("non_matching_float", [
+        0.5,
+        1.5,
+        2.5,
+        3.5,
+        4.5,
+    ])
+    def test_non_integer_floats_return_unknown(self, non_matching_float):
+        assert get_tyre_compound_str(non_matching_float) == "UNKNOWN"
+
+    def test_none_returns_unknown(self):
+        assert get_tyre_compound_str(None) == "UNKNOWN"
+
+    def test_string_returns_unknown(self):
+        assert get_tyre_compound_str("SOFT") == "UNKNOWN"
+
+    def test_negative_zero(self):
+        assert get_tyre_compound_str(-0) == "SOFT"
diff --git a/tests/test_ui_components.py b/tests/test_ui_components.py
