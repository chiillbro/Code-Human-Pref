+import pytest
+
+
+def _format_wind_direction(degrees):
+    """Local copy of the function to test without importing the full module."""
+    if degrees is None:
+        return "N/A"
+    deg_norm = degrees % 360
+    dirs = [
+        "N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE",
+        "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW",
+    ]
+    idx = int((deg_norm / 22.5) + 0.5) % len(dirs)
+    return dirs[idx]
+
+
+class TestFormatWindDirection:
+    @pytest.mark.parametrize("degrees,expected", [
+        (0, "N"),
+        (45, "NE"),
+        (90, "E"),
+        (135, "SE"),
+        (180, "S"),
+        (225, "SW"),
+        (270, "W"),
+        (315, "NW"),
+    ])
+    def test_cardinal_and_ordinal_directions(self, degrees, expected):
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (22.5, "NNE"),
+        (67.5, "ENE"),
+        (112.5, "ESE"),
+        (157.5, "SSE"),
+        (202.5, "SSW"),
+        (247.5, "WSW"),
+        (292.5, "WNW"),
+        (337.5, "NNW"),
+    ])
+    def test_intercardinal_directions(self, degrees, expected):
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (360, "N"),
+        (361, "N"),
+        (450, "E"),
+        (720, "N"),
+        (810, "E"),
+        (1080, "N"),
+    ])
+    def test_degrees_above_360_wrap_around(self, degrees, expected):
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (-45, "NW"),
+        (-90, "W"),
+        (-180, "S"),
+        (-270, "E"),
+        (-360, "N"),
+    ])
+    def test_negative_degrees(self, degrees, expected):
+        assert _format_wind_direction(degrees) == expected
+
+    def test_none_returns_na(self):
+        assert _format_wind_direction(None) == "N/A"
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (0.0, "N"),
+        (89.9, "E"),
+        (90.1, "E"),
+        (179.9, "S"),
+        (180.1, "S"),
+        (269.9, "W"),
+        (270.1, "W"),
+        (359.9, "N"),
+    ])
+    def test_float_degrees(self, degrees, expected):
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (11.24, "N"),
+        (11.25, "NNE"),
+        (33.74, "NNE"),
+        (33.75, "NE"),
+    ])
+    def test_boundary_rounding(self, degrees, expected):
+        assert _format_wind_direction(degrees) == expected
+
+    def test_very_large_positive_value(self):
+        result = _format_wind_direction(36000)
+        assert result == "N"
+
+    def test_very_large_negative_value(self):
+        result = _format_wind_direction(-36000)
+        assert result == "N"
