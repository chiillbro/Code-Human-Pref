+            self._text.anchor_x = "right"
+            self._text.draw()
+            
+    def _build_stats_list(self, data: dict) -> List[Tuple[str, str]]:
+        """Build the stats list for display."""
+        stats = []
+        
+        # Race time or gap
+        pos = data.get('final_pos', 0)
+        if pos == 1:
+            race_time = data.get('race_time', '')
+            if race_time:
+                stats.append(("Time:", race_time))
+        else:
+            gap = data.get('gap', '')
