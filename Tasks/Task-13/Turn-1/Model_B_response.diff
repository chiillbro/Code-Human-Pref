+class PodiumOverlayComponent(BaseComponent):
+    """
+    Displays end-of-race podium overlay with top 3 finishers.
+    Features staggered reveal animation (P3 -> P2 -> P1) and driver stats cards.
+    """
+    
+    PODIUM_COLORS = {
+        1: (255, 215, 0),      # Gold
+        2: (192, 192, 192),    # Silver
+        3: (205, 127, 50),     # Bronze
+    }
+    
+    POINTS_SYSTEM = {
+        1: 25, 2: 18, 3: 15, 4: 12, 5: 10,
+        6: 8, 7: 6, 8: 4, 9: 2, 10: 1
+    }
+
+    def __init__(self):
+        self.visible = False
+        self.podium_data = []  # List of dicts with driver info for P1, P2, P3
+        self._animation_started = False
+        self._animation_time = 0.0
+        self._reveal_delays = {3: 0.0, 2: 0.6, 1: 1.2}  # Staggered reveal (P3 first)
+        self._reveal_duration = 0.5  # Time to animate each podium block
+        self._text = arcade.Text("", 0, 0, arcade.color.WHITE, 14)
+        
+    def set_podium_data(self, podium_data: List[dict]):
+        """
+        Set the podium finishers data.
+        Each dict should contain: code, team_color, race_time, gap, grid_pos, 
+        final_pos, fastest_lap, wdc_position, team_name, full_name
+        """
+        self.podium_data = podium_data
+        
+    def show(self):
+        """Show the podium overlay and start animation."""
+        self.visible = True
+        self._animation_started = True
+        self._animation_time = 0.0
+        
+    def hide(self):
+        """Hide the podium overlay."""
+        self.visible = False
+        self._animation_started = False
+        self._animation_time = 0.0
+        
+    def on_update(self, delta_time: float):
+        """Update animation state."""
+        if self._animation_started:
+            self._animation_time += delta_time
+            
+    def _get_reveal_progress(self, position: int) -> float:
+        """Get animation progress (0-1) for a podium position."""
+        delay = self._reveal_delays.get(position, 0.0)
+        elapsed = self._animation_time - delay
+        if elapsed <= 0:
+            return 0.0
+        progress = min(1.0, elapsed / self._reveal_duration)
+        # Ease-out cubic for smooth deceleration
+        return 1.0 - (1.0 - progress) ** 3
+        
+    def draw(self, window):
+        if not self.visible or not self.podium_data:
+            return
+            
+        # Semi-transparent overlay background
+        overlay_rect = arcade.XYWH(window.width / 2, window.height / 2, window.width, window.height)
+        arcade.draw_rect_filled(overlay_rect, (0, 0, 0, 200))
+        
+        # Title
+        title_y = window.height - 60
+        arcade.Text("🏁 RACE FINISHED 🏁", window.width / 2, title_y,
+                   arcade.color.WHITE, 36, bold=True,
+                   anchor_x="center", anchor_y="center").draw()
+        
+        # Podium layout calculations
+        center_x = window.width / 2
+        base_y = 120  # Bottom of podium blocks
+        
+        # Podium block dimensions
+        block_width = min(220, (window.width - 100) / 3.5)
+        p1_height = 180
+        p2_height = 140
+        p3_height = 100
+        
+        # Horizontal positions (P2 left, P1 center, P3 right)
+        spacing = block_width + 30
+        positions_x = {
+            2: center_x - spacing,
+            1: center_x,
+            3: center_x + spacing,
+        }
+        heights = {1: p1_height, 2: p2_height, 3: p3_height}
+        
+        # Draw podium blocks and driver info (P3 -> P2 -> P1 reveal order)
+        for data in self.podium_data:
+            pos = data.get('final_pos', 0)
+            if pos not in [1, 2, 3]:
+                continue
+                
+            progress = self._get_reveal_progress(pos)
+            if progress <= 0:
+                continue
+                
+            x = positions_x[pos]
+            block_height = heights[pos] * progress
+            block_y = base_y + block_height / 2
+            
+            # Team color for block
+            team_color = data.get('team_color', (100, 100, 100))
+            if isinstance(team_color, (list, tuple)) and len(team_color) >= 3:
+                team_color = tuple(team_color[:3])
+            else:
+                team_color = (100, 100, 100)
+            
+            # Draw podium block with team color
+            block_rect = arcade.XYWH(x, block_y, block_width, block_height)
+            arcade.draw_rect_filled(block_rect, team_color)
+            arcade.draw_rect_outline(block_rect, self.PODIUM_COLORS[pos], 3)
+            
+            # Position number on block
+            if progress > 0.5:
+                alpha = int(255 * min(1.0, (progress - 0.5) * 2))
+                pos_text_y = base_y + block_height - 30
+                arcade.Text(str(pos), x, pos_text_y,
+                           (*arcade.color.WHITE[:3], alpha), 48, bold=True,
+                           anchor_x="center", anchor_y="center").draw()
+            
+            # Driver info card above podium
+            if progress >= 1.0:
+                self._draw_driver_card(window, data, x, base_y + heights[pos] + 20, block_width)
+                
+    def _draw_driver_card(self, window, data: dict, x: float, base_y: float, width: float):
+        """Draw the stats card for a driver above their podium block."""
+        card_height = 200
+        card_y = base_y + card_height / 2 + 10
