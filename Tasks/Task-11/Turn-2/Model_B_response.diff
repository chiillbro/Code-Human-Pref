index 0000000..023ec65
--- /dev/null
+++ b/src/ui_components_incidents.py
@@ -0,0 +1,361 @@
+"""
+Incident panel UI component for F1 race replay.
+
+Displays detected race incidents with color-coded types,
+scrolling support, and filtering capabilities.
+"""
+
+import arcade
+from typing import List, Optional
+from src.ui_components import BaseComponent
+from src.incident_detection import Incident, IncidentType
+
+
+class IncidentPanelComponent(BaseComponent):
+    """
+    Displays detected race incidents with color-coded types.
+    Supports scrolling, filtering by type, and keyboard navigation.
+    """
+
+    # Color scheme for incident types
+    COLORS = {
+        IncidentType.OVERTAKE: (50, 200, 50),      # Green
+        IncidentType.NEAR_MISS: (255, 165, 0),     # Orange
+        IncidentType.PIT_STOP: (100, 149, 237),    # Cornflower blue
+    }
+
+    TYPE_LABELS = {
+        IncidentType.OVERTAKE: "OVT",
+        IncidentType.NEAR_MISS: "NM",
+        IncidentType.PIT_STOP: "PIT",
+    }
+
+    FILTER_CYCLE = [None, IncidentType.OVERTAKE, IncidentType.NEAR_MISS, IncidentType.PIT_STOP]
+
+    def __init__(self, x: int = 20, width: int = 280, visible: bool = True):
+        self.x = x
+        self.width = width
+        self._visible = visible
+        self.incidents: List[Incident] = []
+        self.selected_index: int = -1
+        self.scroll_offset: int = 0
+        self.active_filter: Optional[IncidentType] = None
+        self.row_height = 28
+        self.max_visible_rows = 12
+        self.header_height = 50
+        self._text = arcade.Text("", 0, 0, arcade.color.WHITE, 12)
+        self._panel_top = 0
+        self._panel_height = 0
+
+    @property
+    def visible(self) -> bool:
+        return self._visible
+
+    @visible.setter
+    def visible(self, value: bool):
+        self._visible = value
+
+    def toggle_visibility(self) -> bool:
+        self._visible = not self._visible
+        return self._visible
+
+    def set_incidents(self, incidents: List[Incident]):
+        """Set the full list of incidents."""
+        self.incidents = incidents
+        self.selected_index = -1
+        self.scroll_offset = 0
+
+    def get_filtered_incidents(self) -> List[Incident]:
+        """Get incidents filtered by active filter."""
+        if self.active_filter is None:
+            return self.incidents
+        return [i for i in self.incidents if i.incident_type == self.active_filter]
+
+    def cycle_filter(self):
+        """Cycle through filter options: All -> Overtakes -> Near-miss -> Pit stops -> All"""
+        current_idx = self.FILTER_CYCLE.index(self.active_filter)
+        next_idx = (current_idx + 1) % len(self.FILTER_CYCLE)
+        self.active_filter = self.FILTER_CYCLE[next_idx]
+        self.scroll_offset = 0
+        # Reset selection when filter changes
+        self.selected_index = -1
+
+    def get_filter_label(self) -> str:
+        """Get display label for current filter."""
+        if self.active_filter is None:
+            return "All"
+        return {
+            IncidentType.OVERTAKE: "Overtakes",
+            IncidentType.NEAR_MISS: "Near-miss",
+            IncidentType.PIT_STOP: "Pit Stops",
+        }.get(self.active_filter, "All")
+
+    def select_next(self) -> Optional[Incident]:
+        """Select next incident, returns the incident to jump to."""
+        filtered = self.get_filtered_incidents()
+        if not filtered:
+            return None
+
+        self.selected_index = min(self.selected_index + 1, len(filtered) - 1)
+        self._ensure_selected_visible()
+        return filtered[self.selected_index]
+
+    def select_previous(self) -> Optional[Incident]:
+        """Select previous incident, returns the incident to jump to."""
+        filtered = self.get_filtered_incidents()
+        if not filtered:
+            return None
+
+        if self.selected_index < 0:
+            self.selected_index = len(filtered) - 1
+        else:
+            self.selected_index = max(0, self.selected_index - 1)
+
+        self._ensure_selected_visible()
+        return filtered[self.selected_index]
+
+    def select_nearest(self, current_frame: int) -> Optional[Incident]:
+        """Select incident nearest to current frame, returns it."""
+        filtered = self.get_filtered_incidents()
+        if not filtered:
+            return None
+
+        min_dist = float('inf')
+        nearest_idx = 0
+
+        for i, incident in enumerate(filtered):
+            dist = abs(incident.frame - current_frame)
+            if dist < min_dist:
+                min_dist = dist
+                nearest_idx = i
+
+        self.selected_index = nearest_idx
+        self._ensure_selected_visible()
+        return filtered[self.selected_index]
+
+    def _ensure_selected_visible(self):
+        """Adjust scroll offset to keep selected item visible."""
+        if self.selected_index < 0:
+            return
+
+        # If selection is above visible area
+        if self.selected_index < self.scroll_offset:
+            self.scroll_offset = self.selected_index
+
+        # If selection is below visible area
+        if self.selected_index >= self.scroll_offset + self.max_visible_rows:
+            self.scroll_offset = self.selected_index - self.max_visible_rows + 1
+
+    def on_resize(self, window):
+        """Recalculate panel dimensions on window resize."""
+        self.max_visible_rows = max(5, min(15, (window.height - 200) // self.row_height))
+
+    def draw(self, window):
+        if not self._visible:
+            return
+
+        filtered = self.get_filtered_incidents()
+
+        # Panel dimensions
+        self._panel_top = window.height - 80
+        visible_rows = min(len(filtered), self.max_visible_rows)
+        self._panel_height = self.header_height + (visible_rows * self.row_height) + 20
+
+        panel_left = self.x
+        panel_right = self.x + self.width
+        panel_bottom = self._panel_top - self._panel_height
+
+        # Draw panel background
+        center_x = (panel_left + panel_right) / 2
+        center_y = (self._panel_top + panel_bottom) / 2
+        rect = arcade.XYWH(center_x, center_y, self.width, self._panel_height)
+        arcade.draw_rect_filled(rect, (20, 20, 20, 230))
+        arcade.draw_rect_outline(rect, arcade.color.GRAY, 2)
+
+        # Draw header
+        header_y = self._panel_top - 15
+        self._text.font_size = 14
+        self._text.bold = True
+        self._text.color = arcade.color.WHITE
+        self._text.anchor_x = "left"
+        self._text.anchor_y = "center"
+        self._text.text = f"Incidents ({len(filtered)})"
+        self._text.x = panel_left + 10
+        self._text.y = header_y
+        self._text.draw()
+
+        # Filter indicator
+        filter_text = f"[F] {self.get_filter_label()}"
+        self._text.font_size = 11
+        self._text.bold = False
+        self._text.color = arcade.color.LIGHT_GRAY
+        self._text.text = filter_text
+        self._text.x = panel_right - 80
+        self._text.draw()
+
+        # Draw legend row
+        legend_y = self._panel_top - 38
+        legend_x = panel_left + 10
+        for inc_type in [IncidentType.OVERTAKE, IncidentType.NEAR_MISS, IncidentType.PIT_STOP]:
+            color = self.COLORS[inc_type]
+            label = self.TYPE_LABELS[inc_type]
+
+            arcade.draw_rect_filled(arcade.XYWH(legend_x + 8, legend_y, 16, 12), color)
+
+            self._text.font_size = 10
+            self._text.color = arcade.color.LIGHT_GRAY
+            self._text.text = label
+            self._text.x = legend_x + 20
+            self._text.y = legend_y
+            self._text.draw()
+
+            legend_x += 55
+
+        # Draw incident rows
+        row_y = self._panel_top - self.header_height - 5
+
+        # Clamp scroll offset
+        max_scroll = max(0, len(filtered) - self.max_visible_rows)
+        self.scroll_offset = max(0, min(self.scroll_offset, max_scroll))
+
+        visible_incidents = filtered[self.scroll_offset:self.scroll_offset + self.max_visible_rows]
+
+        for i, incident in enumerate(visible_incidents):
+            actual_idx = self.scroll_offset + i
+            self._draw_incident_row(
+                incident, panel_left, row_y, self.width,
+                selected=(actual_idx == self.selected_index)
+            )
+            row_y -= self.row_height
+
+        # Draw scroll indicators if needed
+        if self.scroll_offset > 0:
+            arcade.draw_triangle_filled(
+                center_x - 5, self._panel_top - self.header_height + 8,
+                center_x + 5, self._panel_top - self.header_height + 8,
+                center_x, self._panel_top - self.header_height + 15,
+                arcade.color.LIGHT_GRAY
+            )
+
+        if self.scroll_offset + self.max_visible_rows < len(filtered):
+            arcade.draw_triangle_filled(
+                center_x - 5, panel_bottom + 15,
+                center_x + 5, panel_bottom + 15,
+                center_x, panel_bottom + 8,
+                arcade.color.LIGHT_GRAY
+            )
+
+        # Help text at bottom
+        help_y = panel_bottom + 5
+        self._text.font_size = 9
+        self._text.color = (150, 150, 150)
+        self._text.text = "N/P: Next/Prev | C: Hide | F: Filter"
+        self._text.x = panel_left + 10
+        self._text.y = help_y
+        self._text.draw()
+
+    def _draw_incident_row(self, incident: Incident, left: float, y: float,
+                           width: float, selected: bool = False):
+        """Draw a single incident row."""
+        row_height = self.row_height - 4
+        center_y = y - row_height / 2
+
+        # Selection highlight
+        if selected:
+            rect = arcade.XYWH(left + width / 2, center_y, width - 8, row_height)
+            arcade.draw_rect_filled(rect, (60, 60, 80, 200))
+            arcade.draw_rect_outline(rect, arcade.color.WHITE, 1)
+
+        # Type indicator
+        color = self.COLORS.get(incident.incident_type, arcade.color.GRAY)
+        arcade.draw_rect_filled(
+            arcade.XYWH(left + 14, center_y, 8, row_height - 4),
+            color
+        )
+
+        # Lap number
+        self._text.font_size = 11
+        self._text.bold = True
+        self._text.color = arcade.color.WHITE
+        self._text.text = f"L{incident.lap}"
+        self._text.x = left + 25
+        self._text.y = center_y
+        self._text.anchor_x = "left"
+        self._text.anchor_y = "center"
+        self._text.draw()
+
+        # Drivers
+        drivers_str = ", ".join(incident.drivers[:2])
+        if len(incident.drivers) > 2:
+            drivers_str += f" +{len(incident.drivers) - 2}"
+
+        self._text.font_size = 11
+        self._text.bold = False
+        self._text.color = arcade.color.WHITE if selected else arcade.color.LIGHT_GRAY
+        self._text.text = drivers_str
+        self._text.x = left + 60
+        self._text.draw()
+
+        # Type label on the right
+        type_label = self.TYPE_LABELS.get(incident.incident_type, "?")
+        self._text.font_size = 10
+        self._text.color = color
+        self._text.text = type_label
+        self._text.x = left + width - 35
+        self._text.anchor_x = "right"
+        self._text.draw()
+
+    def on_mouse_press(self, window, x: float, y: float, button: int, modifiers: int) -> bool:
+        if not self._visible:
+            return False
+
+        # Check if click is within panel bounds
+        panel_left = self.x
+        panel_right = self.x + self.width
+        panel_bottom = self._panel_top - self._panel_height
+
+        if not (panel_left <= x <= panel_right and panel_bottom <= y <= self._panel_top):
+            return False
+
+        # Check if click is on incident rows
+        row_start_y = self._panel_top - self.header_height
+
+        filtered = self.get_filtered_incidents()
+        for i in range(min(len(filtered) - self.scroll_offset, self.max_visible_rows)):
+            row_top = row_start_y - (i * self.row_height)
+            row_bottom = row_top - self.row_height
+
+            if row_bottom <= y <= row_top:
+                self.selected_index = self.scroll_offset + i
+                incident = filtered[self.selected_index]
+
+                # Jump to incident frame and pause
+                if hasattr(window, 'frame_index'):
+                    window.frame_index = float(incident.frame)
+                if hasattr(window, 'paused'):
+                    window.paused = True
+
+                return True
+
+        return True  # Consume click if within panel
+
+    def on_mouse_scroll(self, window, x: float, y: float, scroll_x: int, scroll_y: int) -> bool:
+        """Handle mouse scroll for scrolling the incident list."""
+        if not self._visible:
+            return False
+
+        panel_left = self.x
+        panel_right = self.x + self.width
+        panel_bottom = self._panel_top - self._panel_height
+
+        if not (panel_left <= x <= panel_right and panel_bottom <= y <= self._panel_top):
+            return False
+
+        # Scroll the list
+        filtered = self.get_filtered_incidents()
+        max_scroll = max(0, len(filtered) - self.max_visible_rows)
+
+        self.scroll_offset -= int(scroll_y)
+        self.scroll_offset = max(0, min(self.scroll_offset, max_scroll))
+
+        return True
