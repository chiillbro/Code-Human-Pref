+"""
+Incident detection system for F1 race replay.
+
+Analyzes telemetry frames to detect race incidents:
+- Overtakes: Position changes between consecutive frames
+- Near-misses: Cars within close proximity at high relative speed
+- Pit stops: When a driver enters/exits the pit lane
+"""
+
+from dataclasses import dataclass
+from enum import Enum
+from typing import List, Dict, Optional, Tuple
+import numpy as np
+
+
+class IncidentType(Enum):
+    OVERTAKE = "overtake"
+    NEAR_MISS = "near_miss"
+    PIT_STOP = "pit_stop"
+
+
+@dataclass
+class Incident:
+    frame: int
+    lap: int
+    incident_type: IncidentType
+    drivers: List[str]
+    description: str
+
+    def __post_init__(self):
+        if isinstance(self.incident_type, str):
+            self.incident_type = IncidentType(self.incident_type)
+
+
+class IncidentDetector:
+    """Analyzes telemetry frames to detect race incidents."""
+
+    # Detection thresholds
+    NEAR_MISS_DISTANCE = 50.0  # meters (world coordinates) - catches exciting close racing
+    NEAR_MISS_MIN_SPEED = 150.0  # km/h minimum speed for near-miss
+    PIT_SPEED_THRESHOLD = 80.0  # km/h - pit lane speed limit
+    PIT_CONSECUTIVE_FRAMES = 50  # frames at low speed to confirm pit entry
+    MIN_FRAMES_BETWEEN_OVERTAKES = 75  # ~3 seconds at 25 FPS to avoid duplicate detections
+
+    def __init__(self, frames: List[dict], total_laps: Optional[int] = None):
+        self.frames = frames
+        self.total_laps = total_laps
+        self.incidents: List[Incident] = []
+
+    def analyze(self) -> List[Incident]:
+        """Run all incident detection algorithms and return sorted incidents."""
+        self.incidents = []
+
+        if not self.frames:
+            return self.incidents
+
+        self._detect_overtakes()
+        self._detect_near_misses()
+        self._detect_pit_stops()
+
+        # Sort by frame number
+        self.incidents.sort(key=lambda x: x.frame)
+        return self.incidents
+
+    def _detect_overtakes(self):
+        """Detect position changes between drivers."""
+        if len(self.frames) < 2:
+            return
+
+        # Track recent overtakes to avoid duplicates (driver_pair -> last_frame)
+        recent_overtakes: Dict[Tuple[str, str], int] = {}
+
+        prev_positions = self._get_driver_positions(self.frames[0])
+
+        for frame_idx in range(1, len(self.frames)):
+            frame = self.frames[frame_idx]
+            curr_positions = self._get_driver_positions(frame)
+
+            # Compare positions to find overtakes
+            for driver, curr_pos in curr_positions.items():
+                if driver not in prev_positions:
+                    continue
+
+                prev_pos = prev_positions[driver]
+
+                # Driver improved position
+                if curr_pos < prev_pos:
+                    # Find who they overtook
+                    for other_driver, other_curr_pos in curr_positions.items():
+                        if other_driver == driver:
+                            continue
+                        if other_driver not in prev_positions:
+                            continue
+
+                        other_prev_pos = prev_positions[other_driver]
+
+                        # Check if positions swapped (driver passed other_driver)
+                        if other_prev_pos < prev_pos and other_curr_pos > curr_pos:
+                            pair = tuple(sorted([driver, other_driver]))
+                            last_frame = recent_overtakes.get(pair, -self.MIN_FRAMES_BETWEEN_OVERTAKES)
+
+                            if frame_idx - last_frame >= self.MIN_FRAMES_BETWEEN_OVERTAKES:
+                                recent_overtakes[pair] = frame_idx
+
+                                lap = self._get_leader_lap(frame)
+                                self.incidents.append(Incident(
+                                    frame=frame_idx,
+                                    lap=lap,
+                                    incident_type=IncidentType.OVERTAKE,
+                                    drivers=[driver, other_driver],
+                                    description=f"{driver} overtakes {other_driver} for P{curr_pos}"
+                                ))
+
+            prev_positions = curr_positions
+
+    def _detect_near_misses(self):
+        """Detect cars in very close proximity at high speed."""
+        # Track recent near-misses to avoid spam
+        recent_near_misses: Dict[Tuple[str, str], int] = {}
+        min_frames_between = 100  # ~4 seconds
+
+        # Sample every few frames for performance
+        sample_rate = 5
+
+        for frame_idx in range(0, len(self.frames), sample_rate):
+            frame = self.frames[frame_idx]
+            drivers_data = frame.get("drivers", {})
+            driver_codes = list(drivers_data.keys())
+
+            for i in range(len(driver_codes)):
+                for j in range(i + 1, len(driver_codes)):
+                    d1, d2 = driver_codes[i], driver_codes[j]
+                    p1, p2 = drivers_data[d1], drivers_data[d2]
+
+                    # Calculate distance between cars
+                    dx = p1.get("x", 0) - p2.get("x", 0)
+                    dy = p1.get("y", 0) - p2.get("y", 0)
+                    distance = np.sqrt(dx * dx + dy * dy)
+
+                    # Check speed - both cars should be at racing speed
+                    speed1 = p1.get("speed", 0)
+                    speed2 = p2.get("speed", 0)
+                    avg_speed = (speed1 + speed2) / 2
+
+                    if distance < self.NEAR_MISS_DISTANCE and avg_speed > self.NEAR_MISS_MIN_SPEED:
+                        pair = tuple(sorted([d1, d2]))
+                        last_frame = recent_near_misses.get(pair, -min_frames_between)
+
+                        if frame_idx - last_frame >= min_frames_between:
+                            recent_near_misses[pair] = frame_idx
+
+                            lap = self._get_leader_lap(frame)
+                            self.incidents.append(Incident(
+                                frame=frame_idx,
+                                lap=lap,
+                                incident_type=IncidentType.NEAR_MISS,
+                                drivers=[d1, d2],
+                                description=f"Close battle between {d1} and {d2} ({distance:.0f}m)"
+                            ))
+
+    def _detect_pit_stops(self):
+        """Detect pit stop events based on speed patterns."""
+        if len(self.frames) < self.PIT_CONSECUTIVE_FRAMES:
+            return
+
+        # Track pit state per driver
+        driver_pit_state: Dict[str, dict] = {}
+
+        for frame_idx, frame in enumerate(self.frames):
+            drivers_data = frame.get("drivers", {})
+
+            for driver, data in drivers_data.items():
+                speed = data.get("speed", 200)
+                lap = int(round(data.get("lap", 1)))
+
+                if driver not in driver_pit_state:
+                    driver_pit_state[driver] = {
+                        "low_speed_frames": 0,
+                        "in_pit": False,
+                        "pit_entry_frame": None,
+                        "pit_entry_lap": None
+                    }
+
+                state = driver_pit_state[driver]
+
+                if speed < self.PIT_SPEED_THRESHOLD:
+                    state["low_speed_frames"] += 1
+
+                    # Confirm pit entry after sustained low speed
+                    if (state["low_speed_frames"] >= self.PIT_CONSECUTIVE_FRAMES
+                            and not state["in_pit"]):
+                        state["in_pit"] = True
+                        state["pit_entry_frame"] = frame_idx - self.PIT_CONSECUTIVE_FRAMES
+                        state["pit_entry_lap"] = lap
+
+                        self.incidents.append(Incident(
+                            frame=state["pit_entry_frame"],
+                            lap=lap,
+                            incident_type=IncidentType.PIT_STOP,
+                            drivers=[driver],
+                            description=f"{driver} pit stop on Lap {lap}"
+                        ))
+                else:
+                    # Reset if speed is high
+                    if state["in_pit"]:
+                        state["in_pit"] = False
+                    state["low_speed_frames"] = 0
+
+    def _get_driver_positions(self, frame: dict) -> Dict[str, int]:
+        """Extract driver positions from frame, sorting by progress."""
+        drivers_data = frame.get("drivers", {})
+
+        if not drivers_data:
+            return {}
+
+        # Sort drivers by lap and distance to get positions
+        driver_progress = []
+        for code, data in drivers_data.items():
+            lap = data.get("lap", 1)
+            dist = data.get("dist", 0)
+            driver_progress.append((code, lap, dist))
+
+        # Sort by lap (desc) then distance (desc)
+        driver_progress.sort(key=lambda x: (x[1], x[2]), reverse=True)
+
+        return {code: pos + 1 for pos, (code, _, _) in enumerate(driver_progress)}
+
+    def _get_leader_lap(self, frame: dict) -> int:
+        """Get the current lap number from the race leader."""
+        positions = self._get_driver_positions(frame)
+        if not positions:
+            return 1
+
+        drivers_data = frame.get("drivers", {})
+        # Find driver in P1
+        for driver, pos in positions.items():
+            if pos == 1:
+                return int(round(drivers_data.get(driver, {}).get("lap", 1)))
+        return 1
+
+    def get_incidents_by_type(self, incident_type: IncidentType) -> List[Incident]:
+        """Filter incidents by type."""
+        return [i for i in self.incidents if i.incident_type == incident_type]
+
+    def get_incident_at_frame(self, frame: int, tolerance: int = 50) -> Optional[Incident]:
+        """Find incident closest to the given frame within tolerance."""
+        closest = None
+        min_dist = float('inf')
+
+        for incident in self.incidents:
+            dist = abs(incident.frame - frame)
+            if dist < min_dist and dist <= tolerance:
+                min_dist = dist
+                closest = incident
+
+        return closest
