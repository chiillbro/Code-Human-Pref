@@ -0,0 +1,281 @@
+import arcade
+from typing import List, Optional, Set
+from src.incident_detection import Incident, IncidentType
+
+
+class IncidentPanelComponent:
+    COLORS = {
+        IncidentType.OVERTAKE: (0, 200, 100),
+        IncidentType.NEAR_MISS: (255, 165, 0),
+        IncidentType.PIT_STOP: (100, 149, 237),
+    }
+
+    LABELS = {
+        IncidentType.OVERTAKE: "OVT",
+        IncidentType.NEAR_MISS: "NM",
+        IncidentType.PIT_STOP: "PIT",
+    }
+
+    def __init__(self, x: int = 20, width: int = 280, visible: bool = True):
+        self.x = x
+        self.width = width
+        self.visible = visible
+        self.incidents: List[Incident] = []
+        self.selected_index: int = -1
+        self.active_filters: Set[IncidentType] = set(IncidentType)
+        self.row_height = 24
+        self.max_visible_rows = 12
+        self.scroll_offset = 0
+        self._header_height = 60
+        self._filter_row_height = 30
+        self._text = arcade.Text("", 0, 0, arcade.color.WHITE, 12)
+
+    def set_incidents(self, incidents: List[Incident]):
+        self.incidents = incidents
+        self.selected_index = -1
+        self.scroll_offset = 0
+
+    def toggle_visibility(self) -> bool:
+        self.visible = not self.visible
+        return self.visible
+
+    def cycle_filter(self):
+        filter_list = list(IncidentType)
+        current_count = len(self.active_filters)
+
+        if current_count == len(filter_list):
+            self.active_filters = {IncidentType.OVERTAKE}
+        elif current_count == 1:
+            current = list(self.active_filters)[0]
+            idx = filter_list.index(current)
+            next_idx = (idx + 1) % len(filter_list)
+            if next_idx == 0:
+                self.active_filters = set(IncidentType)
+            else:
+                self.active_filters = {filter_list[next_idx]}
+        else:
+            self.active_filters = set(IncidentType)
+
+        self.scroll_offset = 0
+        if self.selected_index >= 0:
+            self.selected_index = 0 if self._get_filtered_incidents() else -1
+
+    def _get_filtered_incidents(self) -> List[Incident]:
+        return [inc for inc in self.incidents if inc.incident_type in self.active_filters]
+
+    def select_next(self) -> Optional[Incident]:
+        filtered = self._get_filtered_incidents()
+        if not filtered:
+            return None
+
+        if self.selected_index < 0:
+            self.selected_index = 0
+        else:
+            self.selected_index = min(self.selected_index + 1, len(filtered) - 1)
+
+        self._ensure_selected_visible()
+        return filtered[self.selected_index]
+
+    def select_previous(self) -> Optional[Incident]:
+        filtered = self._get_filtered_incidents()
+        if not filtered:
+            return None
+
+        if self.selected_index < 0:
+            self.selected_index = len(filtered) - 1
+        else:
+            self.selected_index = max(self.selected_index - 1, 0)
+
+        self._ensure_selected_visible()
+        return filtered[self.selected_index]
+
+    def get_selected_incident(self) -> Optional[Incident]:
+        filtered = self._get_filtered_incidents()
+        if 0 <= self.selected_index < len(filtered):
+            return filtered[self.selected_index]
+        return None
+
+    def _ensure_selected_visible(self):
+        if self.selected_index < self.scroll_offset:
+            self.scroll_offset = self.selected_index
+        elif self.selected_index >= self.scroll_offset + self.max_visible_rows:
+            self.scroll_offset = self.selected_index - self.max_visible_rows + 1
+
+    def on_resize(self, window):
+        available_height = window.height - 200 - self._header_height - self._filter_row_height
+        self.max_visible_rows = max(4, int(available_height / self.row_height))
+
+    def draw(self, window):
+        if not self.visible:
+            return
+
+        filtered = self._get_filtered_incidents()
+        panel_height = self._header_height + self._filter_row_height + (min(len(filtered), self.max_visible_rows) * self.row_height) + 20
+        panel_top = window.height - 180
+
+        rect = arcade.XYWH(
+            self.x + self.width / 2,
+            panel_top - panel_height / 2,
+            self.width,
+            panel_height
+        )
+        arcade.draw_rect_filled(rect, (20, 20, 20, 220))
+        arcade.draw_rect_outline(rect, arcade.color.GRAY, 1)
+
+        header_y = panel_top - 15
+        self._text.text = "Incidents"
+        self._text.x = self.x + 10
+        self._text.y = header_y
+        self._text.font_size = 16
+        self._text.bold = True
+        self._text.color = arcade.color.WHITE
+        self._text.draw()
+
+        count_text = f"({len(filtered)}/{len(self.incidents)})"
+        self._text.text = count_text
+        self._text.x = self.x + self.width - 10
+        self._text.font_size = 11
+        self._text.bold = False
+        self._text.color = arcade.color.LIGHT_GRAY
+        self._text.anchor_x = "right"
+        self._text.draw()
+        self._text.anchor_x = "left"
+
+        filter_y = header_y - 35
+        filter_x = self.x + 10
+        for inc_type in IncidentType:
+            is_active = inc_type in self.active_filters
+            color = self.COLORS[inc_type] if is_active else (80, 80, 80)
+            label = self.LABELS[inc_type]
+
+            badge_width = 45
+            badge_height = 18
+            badge_rect = arcade.XYWH(filter_x + badge_width / 2, filter_y, badge_width, badge_height)
+            arcade.draw_rect_filled(badge_rect, color)
+
+            self._text.text = label
+            self._text.x = filter_x + badge_width / 2
+            self._text.y = filter_y
+            self._text.font_size = 10
+            self._text.bold = True
+            self._text.color = arcade.color.WHITE if is_active else arcade.color.GRAY
+            self._text.anchor_x = "center"
+            self._text.anchor_y = "center"
+            self._text.draw()
+            self._text.anchor_x = "left"
+            self._text.anchor_y = "baseline"
+
+            filter_x += badge_width + 8
+
+        self._text.text = "[F]"
+        self._text.x = self.x + self.width - 10
+        self._text.y = filter_y
+        self._text.font_size = 9
+        self._text.color = arcade.color.DARK_GRAY
+        self._text.anchor_x = "right"
+        self._text.anchor_y = "center"
+        self._text.draw()
+        self._text.anchor_x = "left"
+        self._text.anchor_y = "baseline"
+
+        list_top = filter_y - 25
+        visible_incidents = filtered[self.scroll_offset:self.scroll_offset + self.max_visible_rows]
+
+        for idx, incident in enumerate(visible_incidents):
+            actual_idx = self.scroll_offset + idx
+            row_y = list_top - (idx * self.row_height)
+            is_selected = actual_idx == self.selected_index
+
+            if is_selected:
+                sel_rect = arcade.XYWH(
+                    self.x + self.width / 2,
+                    row_y - self.row_height / 2 + 8,
+                    self.width - 10,
+                    self.row_height - 2
+                )
+                arcade.draw_rect_filled(sel_rect, (60, 60, 80))
+
+            type_color = self.COLORS[incident.incident_type]
+            arcade.draw_circle_filled(self.x + 18, row_y, 5, type_color)
+
+            lap_text = f"L{incident.lap}"
+            self._text.text = lap_text
+            self._text.x = self.x + 30
+            self._text.y = row_y
+            self._text.font_size = 10
+            self._text.bold = False
+            self._text.color = arcade.color.LIGHT_GRAY
+            self._text.anchor_y = "center"
+            self._text.draw()
+
+            drivers_text = ", ".join(incident.involved_drivers[:2])
+            if len(incident.involved_drivers) > 2:
+                drivers_text += f" +{len(incident.involved_drivers) - 2}"
+
+            self._text.text = drivers_text
+            self._text.x = self.x + 60
+            self._text.font_size = 11
+            self._text.color = arcade.color.WHITE if is_selected else arcade.color.LIGHT_GRAY
+            self._text.draw()
+
+            self._text.anchor_y = "baseline"
+
+        if len(filtered) > self.max_visible_rows:
+            scroll_x = self.x + self.width - 8
+            scroll_track_top = list_top
+            scroll_track_bottom = list_top - (self.max_visible_rows * self.row_height)
+            scroll_track_height = scroll_track_top - scroll_track_bottom
+
+            arcade.draw_line(scroll_x, scroll_track_top, scroll_x, scroll_track_bottom, (60, 60, 60), 4)
+
+            thumb_ratio = self.max_visible_rows / len(filtered)
+            thumb_height = max(20, scroll_track_height * thumb_ratio)
+            scroll_ratio = self.scroll_offset / max(1, len(filtered) - self.max_visible_rows)
+            thumb_top = scroll_track_top - (scroll_track_height - thumb_height) * scroll_ratio
+
+            arcade.draw_line(scroll_x, thumb_top, scroll_x, thumb_top - thumb_height, (120, 120, 120), 4)
+
+    def on_mouse_press(self, window, x: float, y: float, button: int, modifiers: int) -> bool:
+        if not self.visible:
+            return False
+
+        panel_top = window.height - 180
+        list_top = panel_top - self._header_height - self._filter_row_height - 5
+        filtered = self._get_filtered_incidents()
+
+        for idx in range(min(len(filtered) - self.scroll_offset, self.max_visible_rows)):
+            actual_idx = self.scroll_offset + idx
+            row_y = list_top - (idx * self.row_height)
+            row_top = row_y + self.row_height / 2
+            row_bottom = row_y - self.row_height / 2
+
+            if self.x <= x <= self.x + self.width and row_bottom <= y <= row_top:
+                self.selected_index = actual_idx
+                incident = filtered[actual_idx]
+                if hasattr(window, 'frame_index'):
+                    window.frame_index = float(incident.frame)
+                    window.paused = True
+                return True
+
+        return False
+
+    def on_mouse_scroll(self, window, x: float, y: float, scroll_x: int, scroll_y: int) -> bool:
+        if not self.visible:
+            return False
+
+        panel_top = window.height - 180
+        panel_height = self._header_height + self._filter_row_height + (self.max_visible_rows * self.row_height) + 20
+        panel_bottom = panel_top - panel_height
+
+        if self.x <= x <= self.x + self.width and panel_bottom <= y <= panel_top:
+            filtered = self._get_filtered_incidents()
+            max_scroll = max(0, len(filtered) - self.max_visible_rows)
+
+            if scroll_y > 0:
+                self.scroll_offset = max(0, self.scroll_offset - 1)
+            elif scroll_y < 0:
+                self.scroll_offset = min(max_scroll, self.scroll_offset + 1)
+
+            return True
+
+        return False
