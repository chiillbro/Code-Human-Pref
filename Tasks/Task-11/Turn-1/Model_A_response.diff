@@ -0,0 +1,163 @@
+from enum import Enum
+from typing import List, Dict, Optional, Tuple
+from dataclasses import dataclass, field
+import numpy as np
+
+
+class IncidentType(Enum):
+    OVERTAKE = "overtake"
+    NEAR_MISS = "near_miss"
+    PIT_STOP = "pit_stop"
+
+
+@dataclass
+class Incident:
+    frame: int
+    lap: int
+    incident_type: IncidentType
+    involved_drivers: List[str]
+    description: str = ""
+
+
+class IncidentDetector:
+    NEAR_MISS_DISTANCE_THRESHOLD = 50.0
+    NEAR_MISS_SPEED_THRESHOLD = 150.0
+    OVERTAKE_POSITION_CHANGE_WINDOW = 25
+    PIT_LANE_SPEED_THRESHOLD = 80.0
+    PIT_LANE_REL_DIST_LOW = 0.85
+    PIT_LANE_REL_DIST_HIGH = 0.15
+
+    def __init__(self, frames: List[dict]):
+        self.frames = frames
+        self.incidents: List[Incident] = []
+
+    def detect_all_incidents(self) -> List[Incident]:
+        self.incidents = []
+        self._detect_overtakes()
+        self._detect_near_misses()
+        self._detect_pit_stops()
+        self.incidents.sort(key=lambda inc: inc.frame)
+        return self.incidents
+
+    def _detect_overtakes(self):
+        if len(self.frames) < 2:
+            return
+
+        prev_positions: Dict[str, int] = {}
+
+        for frame_idx, frame in enumerate(self.frames):
+            drivers_data = frame.get("drivers", {})
+            if not drivers_data:
+                continue
+
+            driver_list = []
+            for code, data in drivers_data.items():
+                lap = data.get("lap", 1)
+                dist = data.get("dist", 0.0)
+                driver_list.append((code, lap, dist))
+
+            driver_list.sort(key=lambda x: (x[1], x[2]), reverse=True)
+            current_positions = {code: idx + 1 for idx, (code, _, _) in enumerate(driver_list)}
+
+            if prev_positions:
+                for code, curr_pos in current_positions.items():
+                    prev_pos = prev_positions.get(code)
+                    if prev_pos is not None and curr_pos < prev_pos:
+                        passed_drivers = [
+                            other_code for other_code, other_pos in prev_positions.items()
+                            if other_code != code and other_pos < prev_pos and current_positions.get(other_code, 0) > curr_pos
+                        ]
+                        if passed_drivers:
+                            lap = drivers_data.get(code, {}).get("lap", frame.get("lap", 1))
+                            for passed in passed_drivers:
+                                incident = Incident(
+                                    frame=frame_idx,
+                                    lap=lap,
+                                    incident_type=IncidentType.OVERTAKE,
+                                    involved_drivers=[code, passed],
+                                    description=f"{code} overtook {passed}"
+                                )
+                                self.incidents.append(incident)
+
+            prev_positions = current_positions
+
+    def _detect_near_misses(self):
+        recent_near_misses: Dict[Tuple[str, str], int] = {}
+        cooldown_frames = 75
+
+        for frame_idx, frame in enumerate(self.frames):
+            drivers_data = frame.get("drivers", {})
+            if len(drivers_data) < 2:
+                continue
+
+            driver_codes = list(drivers_data.keys())
+
+            for i in range(len(driver_codes)):
+                for j in range(i + 1, len(driver_codes)):
+                    code1, code2 = driver_codes[i], driver_codes[j]
+                    data1, data2 = drivers_data[code1], drivers_data[code2]
+
+                    x1, y1 = data1.get("x", 0), data1.get("y", 0)
+                    x2, y2 = data2.get("x", 0), data2.get("y", 0)
+                    distance = np.sqrt((x2 - x1) ** 2 + (y2 - y1) ** 2)
+
+                    if distance < self.NEAR_MISS_DISTANCE_THRESHOLD:
+                        speed1 = data1.get("speed", 0)
+                        speed2 = data2.get("speed", 0)
+                        avg_speed = (speed1 + speed2) / 2
+
+                        if avg_speed >= self.NEAR_MISS_SPEED_THRESHOLD:
+                            pair_key = tuple(sorted([code1, code2]))
+                            last_frame = recent_near_misses.get(pair_key, -cooldown_frames - 1)
+
+                            if frame_idx - last_frame > cooldown_frames:
+                                lap = frame.get("lap", 1)
+                                incident = Incident(
+                                    frame=frame_idx,
+                                    lap=lap,
+                                    incident_type=IncidentType.NEAR_MISS,
+                                    involved_drivers=[code1, code2],
+                                    description=f"Close battle between {code1} and {code2}"
+                                )
+                                self.incidents.append(incident)
+                                recent_near_misses[pair_key] = frame_idx
+
+    def _detect_pit_stops(self):
+        driver_in_pit: Dict[str, Optional[int]] = {}
+        min_pit_frames = 25
+
+        for frame_idx, frame in enumerate(self.frames):
+            drivers_data = frame.get("drivers", {})
+
+            for code, data in drivers_data.items():
+                speed = data.get("speed", 200)
+                rel_dist = data.get("rel_dist", 0.5)
+
+                is_pit_area = (rel_dist > self.PIT_LANE_REL_DIST_LOW or rel_dist < self.PIT_LANE_REL_DIST_HIGH)
+                is_slow = speed < self.PIT_LANE_SPEED_THRESHOLD
+
+                if is_pit_area and is_slow:
+                    if code not in driver_in_pit or driver_in_pit[code] is None:
+                        driver_in_pit[code] = frame_idx
+                else:
+                    if code in driver_in_pit and driver_in_pit[code] is not None:
+                        pit_start = driver_in_pit[code]
+                        pit_duration = frame_idx - pit_start
+
+                        if pit_duration >= min_pit_frames:
+                            lap = data.get("lap", frame.get("lap", 1))
+                            incident = Incident(
+                                frame=pit_start,
+                                lap=lap,
+                                incident_type=IncidentType.PIT_STOP,
+                                involved_drivers=[code],
+                                description=f"{code} pit stop"
+                            )
+                            self.incidents.append(incident)
+
+                        driver_in_pit[code] = None
+
+
+def analyze_race_incidents(frames: List[dict]) -> List[Incident]:
+    detector = IncidentDetector(frames)
+    return detector.detect_all_incidents()
