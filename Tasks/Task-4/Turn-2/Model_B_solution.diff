diff --git a/src/services/load_from_json_manager.py b/src/services/load_from_json_manager.py
new file mode 100644
index 00000000..6c1b2f6b
--- /dev/null
+++ b/src/services/load_from_json_manager.py
@@ -0,0 +1,43 @@
+from __future__ import annotations
+
+import json
+from collections.abc import Sequence
+
+from src.services.load_from_xml_manager import get_skill_data
+
+CLASSES_DATA_PATH = "data/classes.json"
+
+
+def load_classes() -> dict[str, dict[str, any]]:
+    """
+    Load classes data from JSON file.
+
+    :return: Dictionary containing class data
+    """
+    with open(CLASSES_DATA_PATH, "r", encoding="utf-8") as classes_file:
+        classes_json = json.load(classes_file)
+
+    classes = {}
+    for class_name, class_data in classes_json.items():
+        classes[class_name] = {
+            "constitution": class_data.get("constitution", 0),
+            "move": class_data.get("move", 0),
+            "stats_up": _load_stats_up(class_data["stats_up"]),
+            "skills": [get_skill_data(skill) for skill in class_data.get("skills", [])],
+        }
+    return classes
+
+
+def _load_stats_up(stats_up_data: dict) -> dict[str, Sequence[int]]:
+    """
+    Convert stats_up data from JSON format to internal format.
+
+    :param stats_up_data: Dictionary containing stats_up data from JSON
+    :return: Dictionary with internal stat keys
+    """
+    return {
+        "hp": stats_up_data["hp"],
+        "str": stats_up_data["strength"],
+        "def": stats_up_data["defense"],
+        "res": stats_up_data["resistance"],
+    }
