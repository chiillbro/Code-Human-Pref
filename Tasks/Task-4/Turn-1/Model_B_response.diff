diff --git a/src/services/load_from_json_manager.py b/src/services/load_from_json_manager.py
new file mode 100644
index 00000000..f0f5473c
--- /dev/null
+++ b/src/services/load_from_json_manager.py
@@ -0,0 +1,54 @@
+"""
+Service module for loading game data from JSON files.
+Provides functionality to load class definitions with their stats and skills.
+"""
+
+from __future__ import annotations
+
+import json
+from collections.abc import Sequence
+from typing import Any
+
+from src.services.load_from_xml_manager import get_skill_data
+
+CLASSES_JSON_PATH = "data/classes.json"
+
+
+def load_classes() -> dict[str, dict[str, Any]]:
+    """
+    Load all character class definitions from the JSON data file.
+
+    Returns:
+        Dictionary mapping class names to their data (constitution, move, stats_up, skills)
+    """
+    with open(CLASSES_JSON_PATH, "r", encoding="utf-8") as classes_file:
+        classes_raw = json.load(classes_file)
+
+    classes = {}
+    for class_name, class_data in classes_raw.items():
+        classes[class_name] = {
+            "constitution": class_data.get("constitution", 0),
+            "move": class_data.get("move", 0),
+            "stats_up": _load_stats_up(class_data["stats_up"]),
+            "skills": [get_skill_data(skill_name) for skill_name in class_data.get("skills", [])],
+        }
+    return classes
+
+
+def _load_stats_up(stats_up_data: dict[str, list[int]]) -> dict[str, Sequence[int]]:
+    """
+    Transform stats_up data from JSON format to internal format.
+    Maps JSON keys (defense, resistance, strength) to internal keys (def, res, str).
+
+    Arguments:
+        stats_up_data -- dictionary containing stat progression arrays
+
+    Returns:
+        Dictionary with internal stat keys mapping to progression arrays
+    """
+    return {
+        "hp": stats_up_data["hp"],
+        "def": stats_up_data["defense"],
+        "res": stats_up_data["resistance"],
+        "str": stats_up_data["strength"],
+    }
