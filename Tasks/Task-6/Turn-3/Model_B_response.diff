 class ClassStub(Stub):
+    """Represents a class in a stub file.
+
+    Supports nested classes via the class_stubs parameter. When rendered, nested
+    classes are indented inside their parent class to produce valid Python syntax:
+
+        class Outer:
+            class Inner:
+                def method(self) -> None: ...
+
+    The nesting structure is built by _build_module_stub() which walks the qualname
+    path (e.g., "Outer.Inner.method") and creates/traverses ClassStub.class_stubs
+    dictionaries accordingly.
+    """
+
     def __init__(
         self,
         name: str,
         function_stubs: Optional[Iterable[FunctionStub]] = None,
         attribute_stubs: Optional[Iterable[AttributeStub]] = None,
+        class_stubs: Optional[Iterable["ClassStub"]] = None,
     ) -> None:
         self.name = name
         self.function_stubs: Dict[str, FunctionStub] = {}
         self.attribute_stubs = attribute_stubs or []
+        # Nested class stubs, keyed by class name
+        self.class_stubs: Dict[str, "ClassStub"] = {}
+        if class_stubs is not None:
+            self.class_stubs = {stub.name: stub for stub in class_stubs}
         if function_stubs is not None:
             self.function_stubs = {stub.name: stub for stub in function_stubs}
 
-    def render(self) -> str:
+    def render(self, prefix: str = "") -> str:
+        """Render this class stub with proper indentation.
+
+        Args:
+            prefix: Indentation prefix for this class (empty string for top-level).
+
+        Returns:
+            The rendered class definition with all members properly indented.
+        """
+        nested_prefix = prefix + "    "
         parts = [
-            f"class {self.name}:",
+            f"{prefix}class {self.name}:",
             *[
-                stub.render(prefix="    ")
+                stub.render(prefix=nested_prefix)
                 for stub in sorted(self.attribute_stubs, key=lambda stub: stub.name)
             ],
             *[
-                stub.render(prefix="    ")
+                stub.render(prefix=nested_prefix)
                 for _, stub in sorted(self.function_stubs.items())
             ],
+            # Render nested classes with increased indentation
+            *[stub.render(prefix=nested_prefix) for stub in self.class_stubs.values()],
         ]
         return "\n".join(parts)
 
     def __repr__(self) -> str:
-        return "ClassStub(%s, %s, %s)" % (
+        return "ClassStub(%s, %s, %s, %s)" % (
             repr(self.name),
             tuple(self.function_stubs.values()),
             tuple(self.attribute_stubs),
+            tuple(self.class_stubs),
         )
 
 
