+class TooltipTest(BaseTest):
+
+    def test_tooltip_creation_defaults(self) -> None:
+        """
+        Test tooltip creation with default values.
+        """
+        tooltip = WidgetTooltip(
+            text='Test tooltip',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+        self.assertEqual(tooltip.get_text(), 'Test tooltip')
+        self.assertEqual(tooltip.get_delay(), 500)
+        self.assertFalse(tooltip.is_visible())
+
+        # Size should be positive
+        width, height = tooltip.get_size()
+        self.assertGreater(width, 0)
+        self.assertGreater(height, 0)
+
+    def test_tooltip_creation_custom(self) -> None:
+        """
+        Test tooltip creation with custom values.
+        """
+        tooltip = WidgetTooltip(
+            text='Custom tooltip',
+            font=FONT_OPEN_SANS,
+            font_size=20,
+            font_color=(255, 0, 0),
+            background_color=(0, 255, 0),
+            border_color=(0, 0, 255),
+            border_width=2,
+            padding=(10, 15),
+            delay=1000,
+            font_antialias=False
+        )
+        self.assertEqual(tooltip.get_text(), 'Custom tooltip')
+        self.assertEqual(tooltip.get_delay(), 1000)
+
+    def test_tooltip_text_modification(self) -> None:
+        """
+        Test tooltip text can be modified.
+        """
+        tooltip = WidgetTooltip(
+            text='Original',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+        self.assertEqual(tooltip.get_text(), 'Original')
+
+        tooltip.set_text('Modified')
+        self.assertEqual(tooltip.get_text(), 'Modified')
+
+    def test_tooltip_delay_modification(self) -> None:
+        """
+        Test tooltip delay can be modified.
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14,
+            delay=500
+        )
+        self.assertEqual(tooltip.get_delay(), 500)
+
+        tooltip.set_delay(1000)
+        self.assertEqual(tooltip.get_delay(), 1000)
+
+    def test_tooltip_hover_visibility(self) -> None:
+        """
+        Test tooltip visibility based on hover timing.
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14,
+            delay=50  # Short delay for testing
+        )
+
+        # Initially not visible
+        self.assertFalse(tooltip.is_visible())
+
+        # Start hovering
+        tooltip.on_hover_start()
+
+        # Still not visible (delay not passed)
+        self.assertFalse(tooltip.is_visible())
+
+        # Wait for delay
+        time.sleep(0.1)
+
+        # Now should be visible
+        self.assertTrue(tooltip.is_visible())
+
+        # End hovering
+        tooltip.on_hover_end()
+
+        # No longer visible
+        self.assertFalse(tooltip.is_visible())
+
+    def test_tooltip_hover_reset(self) -> None:
+        """
+        Test tooltip resets properly when hover ends.
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14,
+            delay=50
+        )
+
+        # Hover and wait
+        tooltip.on_hover_start()
+        time.sleep(0.1)
+        self.assertTrue(tooltip.is_visible())
+
+        # End hover
+        tooltip.on_hover_end()
+        self.assertFalse(tooltip.is_visible())
+
+        # Hover again - should need to wait again
+        tooltip.on_hover_start()
+        self.assertFalse(tooltip.is_visible())
+
+    def test_tooltip_position_normal(self) -> None:
+        """
+        Test tooltip positioning in normal case (no edge overflow).
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+
+        mouse_pos = (100, 100)
+        window_size = (800, 600)
+        offset = (10, 20)
+
+        pos = tooltip.get_position(mouse_pos, window_size, offset)
+
+        # Should be offset from mouse position
+        self.assertEqual(pos[0], 110)
+        self.assertEqual(pos[1], 120)
+
+    def test_tooltip_position_right_edge(self) -> None:
+        """
+        Test tooltip repositions when near right edge.
+        """
+        tooltip = WidgetTooltip(
+            text='Test tooltip',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+
+        tooltip_width, _ = tooltip.get_size()
+        window_size = (800, 600)
+        # Place mouse near right edge
+        mouse_pos = (window_size[0] - 5, 100)
+        offset = (10, 20)
+
+        pos = tooltip.get_position(mouse_pos, window_size, offset)
+
+        # Should flip to left of cursor
+        self.assertLess(pos[0] + tooltip_width, window_size[0])
+
+    def test_tooltip_position_bottom_edge(self) -> None:
+        """
+        Test tooltip repositions when near bottom edge.
+        """
+        tooltip = WidgetTooltip(
+            text='Test tooltip',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+
+        _, tooltip_height = tooltip.get_size()
+        window_size = (800, 600)
+        # Place mouse near bottom edge
+        mouse_pos = (100, window_size[1] - 5)
+        offset = (10, 20)
+
+        pos = tooltip.get_position(mouse_pos, window_size, offset)
+
+        # Should flip to above cursor
+        self.assertLess(pos[1] + tooltip_height, window_size[1])
+
+    def test_tooltip_position_corner(self) -> None:
+        """
+        Test tooltip repositions when near corner.
+        """
+        tooltip = WidgetTooltip(
+            text='Test tooltip',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+
+        tooltip_width, tooltip_height = tooltip.get_size()
+        window_size = (800, 600)
+        # Place mouse near bottom-right corner
+        mouse_pos = (window_size[0] - 5, window_size[1] - 5)
+        offset = (10, 20)
+
+        pos = tooltip.get_position(mouse_pos, window_size, offset)
+
+        # Should be visible within window
+        self.assertLess(pos[0] + tooltip_width, window_size[0])
+        self.assertLess(pos[1] + tooltip_height, window_size[1])
+
+    def test_tooltip_position_clamped_to_zero(self) -> None:
+        """
+        Test tooltip position is clamped to (0, 0) minimum.
+        """
+        tooltip = WidgetTooltip(
+            text='Test tooltip',
+            font=FONT_OPEN_SANS,
+            font_size=14
+        )
+
+        # Very small window and mouse near top-left
+        window_size = (50, 50)
+        mouse_pos = (5, 5)
+        offset = (10, 20)
+
+        pos = tooltip.get_position(mouse_pos, window_size, offset)
+
+        # Position should be clamped to (0, 0) minimum
+        self.assertGreaterEqual(pos[0], 0)
+        self.assertGreaterEqual(pos[1], 0)
+
+    def test_tooltip_draw(self) -> None:
+        """
+        Test tooltip drawing.
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14,
+            delay=0  # No delay for testing
+        )
+
+        # Start hover immediately
+        tooltip.on_hover_start()
+
+        test_surface = pygame.Surface((800, 600))
+        mouse_pos = (100, 100)
+
+        # Should draw and return True
+        drawn = tooltip.draw(test_surface, mouse_pos)
+        self.assertTrue(drawn)
+
+    def test_tooltip_draw_not_visible(self) -> None:
+        """
+        Test tooltip doesn't draw when not visible.
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14,
+            delay=10000  # Long delay
+        )
+
+        # Start hover but don't wait
+        tooltip.on_hover_start()
+
+        test_surface = pygame.Surface((800, 600))
+        mouse_pos = (100, 100)
+
+        # Should not draw
+        drawn = tooltip.draw(test_surface, mouse_pos)
+        self.assertFalse(drawn)
+
+    def test_tooltip_reset(self) -> None:
+        """
+        Test tooltip reset method.
+        """
+        tooltip = WidgetTooltip(
+            text='Test',
+            font=FONT_OPEN_SANS,
+            font_size=14,
+            delay=50
+        )
+
+        # Hover and wait
+        tooltip.on_hover_start()
+        time.sleep(0.1)
+        self.assertTrue(tooltip.is_visible())
+
+        # Reset
+        tooltip.reset()
+        self.assertFalse(tooltip.is_visible())
+
+    def test_tooltip_invalid_parameters(self) -> None:
+        """
+        Test tooltip raises errors for invalid parameters.
+        """
+        # Invalid text
+        self.assertRaises(
+            AssertionError,
+            lambda: WidgetTooltip(text=123, font=FONT_OPEN_SANS, font_size=14)
+        )
+
+        # Invalid font_size
+        self.assertRaises(
+            AssertionError,
+            lambda: WidgetTooltip(text='Test', font=FONT_OPEN_SANS, font_size=0)
+        )
+
+        # Invalid border_width
+        self.assertRaises(
+            AssertionError,
+            lambda: WidgetTooltip(text='Test', font=FONT_OPEN_SANS, font_size=14, border_width=-1)
+        )
+
+        # Invalid delay
+        self.assertRaises(
+            AssertionError,
+            lambda: WidgetTooltip(text='Test', font=FONT_OPEN_SANS, font_size=14, delay=-1)
+        )
+
+        # Invalid padding
+        self.assertRaises(
+            AssertionError,
+            lambda: WidgetTooltip(text='Test', font=FONT_OPEN_SANS, font_size=14, padding=(-1, 5))
+        )
