+        self.assertIsNotNone(button.get_tooltip())
+        self.assertEqual(button.get_tooltip().get_text(), 'This is a test button')
+
+    def test_widget_remove_tooltip(self) -> None:
+        """
+        Test removing tooltip from a widget.
+        """
+        menu = MenuUtils.generic_menu()
+        button = menu.add.button('Test Button', lambda: None)
+
+        button.set_tooltip('Tooltip')
+        self.assertTrue(button.has_tooltip())
+
+        button.set_tooltip(None)
+        self.assertFalse(button.has_tooltip())
+
+    def test_widget_tooltip_uses_theme(self) -> None:
+        """
+        Test widget tooltip uses theme settings.
+        """
