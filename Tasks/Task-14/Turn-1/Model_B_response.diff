@@ -0,0 +1,202 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TOOLTIP
+Widget tooltip class for displaying contextual help on hover.
+"""
+
+__all__ = ['WidgetTooltip']
+
+import time
+from typing import Optional, Tuple, TYPE_CHECKING
+
+import pygame
+
+from pygame_menu.font import FontType, get_font
+
+if TYPE_CHECKING:
+    from pygame_menu.widgets.core.widget import Widget
+
+ColorType = Tuple[int, int, int, int]
+
+
+class WidgetTooltip:
+    """
+    Tooltip class for widgets that displays contextual help when hovering.
+
+    :param widget: The widget this tooltip is attached to
+    :param text: Tooltip text to display
+    :param font: Font for the tooltip text
+    :param font_size: Font size in pixels
+    :param font_color: Font color (R, G, B, A)
+    :param background_color: Background color (R, G, B, A)
+    :param border_color: Border color (R, G, B, A)
+    :param border_width: Border width in pixels
+    :param padding: Padding inside the tooltip (top, right, bottom, left)
+    :param delay: Delay in milliseconds before showing tooltip
+    """
+
+    _widget: 'Widget'
+    _text: str
+    _font: FontType
+    _font_size: int
+    _font_color: ColorType
+    _background_color: ColorType
+    _border_color: ColorType
+    _border_width: int
+    _padding: Tuple[int, int, int, int]
+    _delay: int
+    _hover_start_time: Optional[float]
+    _surface: Optional['pygame.Surface']
+    _visible: bool
+
+    def __init__(
+            self,
+            widget: 'Widget',
+            text: str,
+            font: FontType,
+            font_size: int = 14,
+            font_color: ColorType = (0, 0, 0, 255),
+            background_color: ColorType = (255, 255, 220, 255),
+            border_color: ColorType = (100, 100, 100, 255),
+            border_width: int = 1,
+            padding: Tuple[int, int, int, int] = (4, 8, 4, 8),
+            delay: int = 500
+    ) -> None:
+        self._widget = widget
+        self._text = text
+        self._font = font
+        self._font_size = font_size
+        self._font_color = font_color
+        self._background_color = background_color
+        self._border_color = border_color
+        self._border_width = border_width
+        self._padding = padding
+        self._delay = delay
+        self._hover_start_time = None
+        self._surface = None
+        self._visible = False
+        self._render_surface()
+
+    def _render_surface(self) -> None:
+        """Render the tooltip surface."""
+        font_obj = get_font(self._font, self._font_size)
+        text_surface = font_obj.render(self._text, True, self._font_color[:3])
+        text_width, text_height = text_surface.get_size()
+
+        total_width = text_width + self._padding[1] + self._padding[3] + 2 * self._border_width
+        total_height = text_height + self._padding[0] + self._padding[2] + 2 * self._border_width
+
+        self._surface = pygame.Surface((total_width, total_height), pygame.SRCALPHA)
+        self._surface.fill((0, 0, 0, 0))
+
+        # Draw background
+        bg_rect = pygame.Rect(
+            self._border_width,
+            self._border_width,
+            total_width - 2 * self._border_width,
+            total_height - 2 * self._border_width
+        )
+        pygame.draw.rect(self._surface, self._background_color, bg_rect)
+
+        # Draw border
+        if self._border_width > 0:
+            border_rect = pygame.Rect(0, 0, total_width, total_height)
+            pygame.draw.rect(self._surface, self._border_color, border_rect, self._border_width)
+
+        # Draw text
+        text_x = self._border_width + self._padding[3]
+        text_y = self._border_width + self._padding[0]
+        self._surface.blit(text_surface, (text_x, text_y))
+
+    def set_text(self, text: str) -> 'WidgetTooltip':
+        """
+        Set the tooltip text.
+
+        :param text: New tooltip text
+        :return: Self reference
+        """
+        self._text = text
+        self._render_surface()
+        return self
+
+    def set_delay(self, delay: int) -> 'WidgetTooltip':
+        """
+        Set the hover delay before showing tooltip.
+
+        :param delay: Delay in milliseconds
+        :return: Self reference
+        """
+        self._delay = delay
+        return self
+
+    def update(self) -> None:
+        """Update the tooltip state based on widget hover status."""
+        if self._widget._mouseover:
+            if self._hover_start_time is None:
+                self._hover_start_time = time.time()
+            elapsed_ms = (time.time() - self._hover_start_time) * 1000
+            self._visible = elapsed_ms >= self._delay
+        else:
+            self._hover_start_time = None
+            self._visible = False
+
+    def is_visible(self) -> bool:
+        """
+        Check if tooltip should be visible.
+
+        :return: True if tooltip should be displayed
+        """
+        return self._visible
+
+    def get_position(self, mouse_pos: Tuple[int, int], window_size: Tuple[int, int]) -> Tuple[int, int]:
+        """
+        Calculate tooltip position with smart positioning to avoid window overflow.
+
+        :param mouse_pos: Current mouse position (x, y)
+        :param window_size: Window dimensions (width, height)
+        :return: Tooltip position (x, y)
+        """
+        if self._surface is None:
+            return mouse_pos
+
+        tooltip_width, tooltip_height = self._surface.get_size()
+        cursor_offset_x = 16
+        cursor_offset_y = 16
+
+        # Default position: below and to the right of cursor
+        x = mouse_pos[0] + cursor_offset_x
+        y = mouse_pos[1] + cursor_offset_y
+
+        # Check right edge overflow - move to left of cursor
+        if x + tooltip_width > window_size[0]:
+            x = mouse_pos[0] - tooltip_width - cursor_offset_x
+
+        # Check bottom edge overflow - move above cursor
+        if y + tooltip_height > window_size[1]:
+            y = mouse_pos[1] - tooltip_height - cursor_offset_y
+
+        # Ensure tooltip doesn't go off the left edge
+        if x < 0:
+            x = 0
+
+        # Ensure tooltip doesn't go off the top edge
+        if y < 0:
+            y = 0
+
+        return (x, y)
+
+    def draw(self, surface: 'pygame.Surface', mouse_pos: Tuple[int, int]) -> None:
+        """
+        Draw the tooltip on the given surface.
+
+        :param surface: Pygame surface to draw on
+        :param mouse_pos: Current mouse position
+        """
+        if not self._visible or self._surface is None:
+            return
+
+        window_size = surface.get_size()
+        pos = self.get_position(mouse_pos, window_size)
+        surface.blit(self._surface, pos)
