diff --git a/pygame_menu/widgets/core/tooltip.py b/pygame_menu/widgets/core/tooltip.py
new file mode 100644
index 00000000..571ad5c6
--- /dev/null
+++ b/pygame_menu/widgets/core/tooltip.py
@@ -0,0 +1,371 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TOOLTIP
+Widget tooltip class for displaying contextual help on hover.
+"""
+
+__all__ = [
+    'WidgetTooltip',
+    'TOOLTIP_DEFAULT_BACKGROUND_COLOR',
+    'TOOLTIP_DEFAULT_BORDER_COLOR',
+    'TOOLTIP_DEFAULT_BORDER_WIDTH',
+    'TOOLTIP_DEFAULT_DELAY',
+    'TOOLTIP_DEFAULT_FONT_ANTIALIAS',
+    'TOOLTIP_DEFAULT_FONT_COLOR',
+    'TOOLTIP_DEFAULT_FONT_SIZE',
+    'TOOLTIP_DEFAULT_MAX_WIDTH',
+    'TOOLTIP_DEFAULT_PADDING'
+]
+
+import time
+
+import pygame
+
+from pygame_menu.font import FontType, get_font, FONT_OPEN_SANS
+from pygame_menu.utils import make_surface, assert_color
+
+from pygame_menu._types import Optional, ColorType, NumberType, Tuple2IntType, NumberInstance
+
+# Default tooltip values - shared constants to avoid duplication
+TOOLTIP_DEFAULT_BACKGROUND_COLOR: ColorType = (255, 255, 225)
+TOOLTIP_DEFAULT_BORDER_COLOR: ColorType = (0, 0, 0)
+TOOLTIP_DEFAULT_BORDER_WIDTH: int = 1
+TOOLTIP_DEFAULT_DELAY: NumberType = 500
+TOOLTIP_DEFAULT_FONT: FontType = FONT_OPEN_SANS
+TOOLTIP_DEFAULT_FONT_ANTIALIAS: bool = True
+TOOLTIP_DEFAULT_FONT_COLOR: ColorType = (0, 0, 0)
+TOOLTIP_DEFAULT_FONT_SIZE: int = 14
+TOOLTIP_DEFAULT_MAX_WIDTH: int = 0  # 0 means no limit
+TOOLTIP_DEFAULT_PADDING: Tuple2IntType = (5, 8)
+
+
+class WidgetTooltip:
+    """
+    Tooltip class for widgets. Handles delay tracking, rendering, and smart positioning.
+
+    :param text: Tooltip text to display
+    :param font: Font name or path
+    :param font_size: Font size in px
+    :param font_color: Font color
+    :param background_color: Background color of the tooltip
+    :param border_color: Border color of the tooltip
+    :param border_width: Border width in px
+    :param padding: Padding (vertical, horizontal) in px
+    :param delay: Delay in milliseconds before showing the tooltip
+    :param font_antialias: Enable antialiasing for font rendering
+    :param max_width: Maximum width before text wraps. 0 means no limit
+    """
+    _background_color: ColorType
+    _border_color: ColorType
+    _border_width: int
+    _delay: NumberType
+    _font: 'pygame.font.Font'
+    _font_antialias: bool
+    _font_color: ColorType
+    _hover_start_time: Optional[float]
+    _is_visible: bool
+    _max_width: int
+    _needs_render: bool
+    _padding: Tuple2IntType
+    _surface: Optional['pygame.Surface']
+    _text: str
+
+    def __init__(
+            self,
+            text: str,
+            font: FontType = TOOLTIP_DEFAULT_FONT,
+            font_size: int = TOOLTIP_DEFAULT_FONT_SIZE,
+            font_color: ColorType = TOOLTIP_DEFAULT_FONT_COLOR,
+            background_color: ColorType = TOOLTIP_DEFAULT_BACKGROUND_COLOR,
+            border_color: ColorType = TOOLTIP_DEFAULT_BORDER_COLOR,
+            border_width: int = TOOLTIP_DEFAULT_BORDER_WIDTH,
+            padding: Tuple2IntType = TOOLTIP_DEFAULT_PADDING,
+            delay: NumberType = TOOLTIP_DEFAULT_DELAY,
+            font_antialias: bool = TOOLTIP_DEFAULT_FONT_ANTIALIAS,
+            max_width: int = TOOLTIP_DEFAULT_MAX_WIDTH
+    ) -> None:
+        assert isinstance(text, str), 'text must be a string'
+        assert isinstance(font_size, int) and font_size > 0, 'font_size must be a positive integer'
+        assert isinstance(border_width, int) and border_width >= 0, 'border_width must be a non-negative integer'
+        assert isinstance(delay, NumberInstance) and delay >= 0, 'delay must be a non-negative number'
+        assert isinstance(font_antialias, bool), 'font_antialias must be a boolean'
+        assert len(padding) == 2, 'padding must be a tuple of 2 elements (vertical, horizontal)'
+        assert padding[0] >= 0 and padding[1] >= 0, 'padding values must be non-negative'
+        assert isinstance(max_width, int) and max_width >= 0, 'max_width must be a non-negative integer'
+
+        self._text = text
+        self._font = get_font(font, font_size)
+        self._font_color = assert_color(font_color)
+        self._font_antialias = font_antialias
+        self._background_color = assert_color(background_color)
+        self._border_color = assert_color(border_color)
+        self._border_width = border_width
+        self._padding = (int(padding[0]), int(padding[1]))
+        self._delay = delay
+        self._max_width = max_width
+
+        self._hover_start_time = None
+        self._is_visible = False
+        self._surface = None
+        self._needs_render = True
+
+    def _wrap_text(self, text: str, max_width: int) -> list:
+        """
+        Wrap text to fit within max_width.
+
+        :param text: Text to wrap
+        :param max_width: Maximum width in pixels (content area, excluding padding/border)
+        :return: List of wrapped lines
+        """
+        if max_width <= 0:
+            return [text]
+
+        words = text.split(' ')
+        lines = []
+        current_line = []
+
+        for word in words:
+            test_line = ' '.join(current_line + [word])
+            test_width, _ = self._font.size(test_line)
+
+            if test_width <= max_width:
+                current_line.append(word)
+            else:
+                if current_line:
+                    lines.append(' '.join(current_line))
+                    current_line = [word]
+                else:
+                    # Word is longer than max_width, add it anyway
+                    lines.append(word)
+
+        if current_line:
+            lines.append(' '.join(current_line))
+
+        return lines if lines else [text]
+
+    def _render(self) -> None:
+        """
+        Render the tooltip surface.
+        """
+        pad_v, pad_h = self._padding
+        content_max_width = self._max_width - 2 * pad_h - 2 * self._border_width if self._max_width > 0 else 0
+
+        lines = self._wrap_text(self._text, content_max_width)
+
+        line_surfaces = []
+        max_line_width = 0
+        total_height = 0
+        line_height = self._font.get_linesize()
+
+        for line in lines:
+            line_surface = self._font.render(line, self._font_antialias, self._font_color)
+            line_surfaces.append(line_surface)
+            line_width = line_surface.get_width()
+            if line_width > max_line_width:
+                max_line_width = line_width
+            total_height += line_height
+
+        surface_width = max_line_width + 2 * pad_h + 2 * self._border_width
+        surface_height = total_height + 2 * pad_v + 2 * self._border_width
+
+        self._surface = make_surface(surface_width, surface_height, alpha=True)
+
+        if len(self._background_color) == 4 and self._background_color[3] == 0:
+            pass
+        else:
+            self._surface.fill(self._background_color)
+
+        if self._border_width > 0:
+            border_rect = pygame.Rect(0, 0, surface_width, surface_height)
+            pygame.draw.rect(self._surface, self._border_color, border_rect, self._border_width)
+
+        text_x = pad_h + self._border_width
+        text_y = pad_v + self._border_width
+
+        for line_surface in line_surfaces:
+            self._surface.blit(line_surface, (text_x, text_y))
+            text_y += line_height
+
+        self._needs_render = False
+
+    def _ensure_rendered(self) -> None:
+        """
+        Ensure the tooltip surface is rendered (lazy rendering).
+        """
+        if self._needs_render or self._surface is None:
+            self._render()
+
+    def get_text(self) -> str:
+        """
+        Return the tooltip text.
+
+        :return: Tooltip text
+        """
+        return self._text
+
+    def set_text(self, text: str) -> 'WidgetTooltip':
+        """
+        Set the tooltip text and mark for re-render.
+
+        :param text: New tooltip text
+        :return: Self reference
+        """
+        assert isinstance(text, str), 'text must be a string'
+        self._text = text
+        self._needs_render = True
+        return self
+
+    def get_delay(self) -> NumberType:
+        """
+        Return the hover delay in milliseconds.
+
+        :return: Delay in ms
+        """
+        return self._delay
+
+    def set_delay(self, delay: NumberType) -> 'WidgetTooltip':
+        """
+        Set the hover delay.
+
+        :param delay: Delay in milliseconds
+        :return: Self reference
+        """
+        assert isinstance(delay, NumberInstance) and delay >= 0, 'delay must be a non-negative number'
+        self._delay = delay
+        return self
+
+    def get_max_width(self) -> int:
+        """
+        Return the maximum width for text wrapping.
+
+        :return: Max width in pixels, 0 means no limit
+        """
+        return self._max_width
+
+    def set_max_width(self, max_width: int) -> 'WidgetTooltip':
+        """
+        Set the maximum width for text wrapping.
+
+        :param max_width: Max width in pixels, 0 means no limit
+        :return: Self reference
+        """
+        assert isinstance(max_width, int) and max_width >= 0, 'max_width must be a non-negative integer'
+        self._max_width = max_width
+        self._needs_render = True
+        return self
+
+    def get_size(self) -> Tuple2IntType:
+        """
+        Return the tooltip surface size.
+
+        :return: (width, height) tuple
+        """
+        self._ensure_rendered()
+        if self._surface is None:
+            return 0, 0
+        return self._surface.get_size()
+
+    def on_hover_start(self) -> None:
+        """
+        Called when mouse starts hovering over the widget.
+        """
+        if self._hover_start_time is None:
+            self._hover_start_time = time.time()
+
+    def on_hover_end(self) -> None:
+        """
+        Called when mouse stops hovering over the widget.
+        """
+        self._hover_start_time = None
+        self._is_visible = False
+
+    def is_visible(self) -> bool:
+        """
+        Check if the tooltip should be visible (delay has passed).
+
+        :return: True if tooltip should be displayed
+        """
+        if self._hover_start_time is None:
+            return False
+
+        elapsed_ms = (time.time() - self._hover_start_time) * 1000
+        self._is_visible = elapsed_ms >= self._delay
+        return self._is_visible
+
+    def get_position(
+            self,
+            mouse_pos: Tuple2IntType,
+            window_size: Tuple2IntType,
+            offset: Tuple2IntType = (10, 20)
+    ) -> Tuple2IntType:
+        """
+        Calculate the tooltip position with smart edge detection.
+        Tooltip will be repositioned to avoid overflowing window boundaries.
+
+        :param mouse_pos: Current mouse position (x, y)
+        :param window_size: Window dimensions (width, height)
+        :param offset: Offset from cursor (x, y)
+        :return: Position (x, y) for tooltip
+        """
+        self._ensure_rendered()
+        if self._surface is None:
+            return mouse_pos
+
+        tooltip_width, tooltip_height = self.get_size()
+        window_width, window_height = window_size
+        mouse_x, mouse_y = mouse_pos
+        offset_x, offset_y = offset
+
+        pos_x = mouse_x + offset_x
+        pos_y = mouse_y + offset_y
+
+        if pos_x + tooltip_width > window_width:
+            pos_x = mouse_x - tooltip_width - offset_x
+
+        if pos_y + tooltip_height > window_height:
+            pos_y = mouse_y - tooltip_height - offset_y
+
+        pos_x = max(0, pos_x)
+        pos_y = max(0, pos_y)
+
+        return int(pos_x), int(pos_y)
+
+    def draw(
+            self,
+            surface: 'pygame.Surface',
+            mouse_pos: Tuple2IntType,
+            window_size: Optional[Tuple2IntType] = None
+    ) -> bool:
+        """
+        Draw the tooltip on the given surface if visible.
+
+        :param surface: Pygame surface to draw on
+        :param mouse_pos: Current mouse position
+        :param window_size: Window size for edge detection. If None, uses surface size
+        :return: True if tooltip was drawn
+        """
+        if not self.is_visible():
+            return False
+
+        self._ensure_rendered()
+        if self._surface is None:
+            return False
+
+        if window_size is None:
+            window_size = surface.get_size()
+
+        pos = self.get_position(mouse_pos, window_size)
+        surface.blit(self._surface, pos)
+        return True
+
+    def reset(self) -> 'WidgetTooltip':
+        """
+        Reset the tooltip state.
+
+        :return: Self reference
+        """
+        self._hover_start_time = None
+        self._is_visible = False
+        return self
