+class SessionInfoBannerComponent(BaseComponent):
+    """Top-center banner showing session metadata (event, round, circuit, laps, date)."""
+
+    # Colour palette kept subtle so the banner provides context without
+    # competing visually with live race data (leaderboard, flags, etc.).
+    COLORS = {
+        "background": (25, 25, 25, 200),
+        "border": (90, 90, 90),
+        "title": (255, 255, 255),
+        "detail": (185, 185, 185),
+    }
+
+    def __init__(self,
+                 left_margin: int = 340,
+                 right_margin: int = 260,
+                 top_offset: int = 10,
+                 height: int = 52,
+                 padding_x: int = 16,
+                 visible: bool = True):
+        """
+        Args:
+            left_margin: Pixels reserved on the left for the existing HUD
+                column — the banner centres itself in the remaining space.
+            right_margin: Pixels reserved on the right for the leaderboard.
+            top_offset: Gap between the top of the window and the banner.
+            height: Total height of the banner box (clamped to fit two rows
+                of text — title + detail line).
+            padding_x: Horizontal padding inside the banner box.
+            visible: Initial visibility; wired to the HUD visibility flag.
+        """
+        self.left_margin = left_margin
+        self.right_margin = right_margin
+        self.top_offset = top_offset
+        self.height = max(40, height)
+        self.padding_x = padding_x
+        self._visible: bool = visible
+
+        # Session metadata — ``None`` until ``set_info()`` is called.
+        self._info: Optional[dict] = None
+        # Pre-formatted strings — computed once in ``set_info()`` so the
+        # draw loop only mutates Text positions (fast path).
+        self._title_str: str = ""
+        self._detail_str: str = ""
+
+        # Cached layout — recalculated on resize.
+        self._center_x: float = 0.0
+        self._center_y: float = 0.0
+        self._bar_width: float = 0.0
+
+        # Persistent Text objects — allocate once, reuse every frame.
+        # The title is slightly larger and bold so the event name stands out;
+        # the detail row packs round / circuit / country / date on one line.
+        self._title_text = arcade.Text(
+            "", 0, 0, self.COLORS["title"], 16,
+            anchor_x="center", anchor_y="center", bold=True,
+        )
+        self._detail_text = arcade.Text(
+            "", 0, 0, self.COLORS["detail"], 12,
+            anchor_x="center", anchor_y="center",
+        )
+
+    # --- Visibility API (mirrors WeatherComponent / LeaderboardComponent) ---
+
+    @property
+    def visible(self) -> bool:
+        return self._visible
+
+    @visible.setter
+    def visible(self, value: bool):
+        self._visible = value
+
+    def toggle_visibility(self) -> bool:
+        """Toggle visibility and return the new state."""
+        self._visible = not self._visible
+        return self._visible
+
+    def set_visible(self):
+        """Force the banner to show (matches the existing HUD API)."""
+        self._visible = True
+
+    # --- Data injection -----------------------------------------------------
+
+    def set_info(self, info: Optional[dict]):
+        """Set session metadata dict and pre-format the banner text."""
+        self._info = info
+
+        if not info:
+            # Fall back to an empty banner — ``draw()`` will no-op.
+            self._title_str = ""
+            self._detail_str = ""
+            return
+
+        def _present(key):
+            v = info.get(key)
+            # Guard against pandas ``NaT`` / ``nan`` sneaking in from the
+            # event Series — the string ``"nan"``/``"NaT"`` should not be
+            # shown to the user.
+            if v is None:
+                return None
+            s = str(v).strip()
+            if not s or s.lower() in ("nan", "nat", "none"):
+                return None
+            return s
+
+        event_name = _present("event_name") or ""
+        session_name = _present("session_name")
+
+        # Title line: "<Event Name> — <Session>"
+        if event_name and session_name:
+            self._title_str = f"{event_name} — {session_name}"
+        else:
+            # Whichever is available, or the window title as a last resort.
+            self._title_str = event_name or session_name or (_present("title") or "")
+
+        # Detail line — join only the pieces that actually exist so the
+        # banner gracefully adapts to older fastf1 schemas / missing data.
+        detail_parts = []
+        year = _present("year")
+        rnd = _present("round_number")
+        if year and rnd:
+            detail_parts.append(f"Round {rnd} · {year}")
+        elif rnd:
+            detail_parts.append(f"Round {rnd}")
+        elif year:
+            detail_parts.append(year)
+
+        location = _present("location")
+        country = _present("country")
+        if location and country and location != country:
+            detail_parts.append(f"{location}, {country}")
+        elif location or country:
+            detail_parts.append(location or country)
+
+        # total_laps: only show when it's a meaningful positive value —
+        # the race window passes ``total_laps or 0`` downstream, so a zero
+        # here means "unknown" and should be omitted.
+        total_laps_raw = info.get("total_laps")
+        try:
+            if total_laps_raw and int(total_laps_raw) > 0:
+                detail_parts.append(f"{int(total_laps_raw)} Laps")
+        except (TypeError, ValueError):
+            pass
+
+        date_str = _present("date")
+        if date_str:
+            detail_parts.append(date_str)
+
+        self._detail_str = "   •   ".join(detail_parts)
+
+    # --- Layout -------------------------------------------------------------
+
+    def _calculate_layout(self, window):
+        """Centre the banner horizontally above the track, inside the
+        reserved UI margins, and pin it to the top of the window."""
+        inner_w = max(1.0, window.width - self.left_margin - self.right_margin)
+        # Keep a sensible minimum so the text doesn't get squashed on tiny
+        # windows, and cap the width so it doesn't stretch wall-to-wall
+        # on ultra-wide monitors.
+        self._bar_width = max(240.0, min(inner_w - 20.0, 720.0))
+        self._center_x = self.left_margin + inner_w / 2.0
+        self._center_y = window.height - self.top_offset - self.height / 2.0
+
+    def on_resize(self, window):
+        self._calculate_layout(window)
+
+    # --- Draw ---------------------------------------------------------------
+
+    def draw(self, window):
+        # Skip entirely when hidden or when no info has been provided —
+        # the banner is purely contextual so there is nothing to show.
+        if not self._visible or not self._title_str:
+            return
+
+        # Recompute layout lazily — cheap, and covers the case where the
+        # window was created at a different size before ``on_resize()`` fired.
+        self._calculate_layout(window)
+
+        # 1. Subtle rounded-look panel so the text is readable over the
+        #    background texture / track lines.
+        bg_rect = arcade.XYWH(self._center_x, self._center_y, self._bar_width, self.height)
+        arcade.draw_rect_filled(bg_rect, self.COLORS["background"])
+        arcade.draw_rect_outline(bg_rect, self.COLORS["border"], 1)
+
+        # 2. Two-row text layout — title on top, details below.
+        #    The two rows are evenly spaced within the banner box.
+        top_row_y = self._center_y + self.height * 0.22
+        bottom_row_y = self._center_y - self.height * 0.22
+
+        self._title_text.text = self._title_str
+        self._title_text.x = self._center_x
+        self._title_text.y = top_row_y if self._detail_str else self._center_y
+        self._title_text.draw()
+
+        if self._detail_str:
+            self._detail_text.text = self._detail_str
+            self._detail_text.x = self._center_x
+            self._detail_text.y = bottom_row_y
+            self._detail_text.draw()
+
