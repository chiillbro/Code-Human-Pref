     return circuit.rotation
 
+# Short session code -> human-readable session name (fallback for when
+# ``session.name`` is unavailable on older fastf1 versions).
+SESSION_TYPE_NAMES = {
+    "R": "Race",
+    "S": "Sprint",
+    "Q": "Qualifying",
+    "SQ": "Sprint Qualifying",
+    "FP1": "Practice 1",
+    "FP2": "Practice 2",
+    "FP3": "Practice 3",
+}
+
+def build_session_info(session, session_type='R', fallback_title=None):
+    """
+    Extract a plain dict of session metadata from a fastf1 Session so the
+    UI layer (SessionInfoBannerComponent) stays decoupled from fastf1.
+
+    Every lookup is guarded so callers never receive pandas NaT/nan or
+    raise on a missing key — all keys are always present in the returned
+    dict, with None for anything unavailable.
+    """
+    info = {
+        "event_name": None,
+        "session_name": None,
+        "round_number": None,
+        "year": None,
+        "location": None,
+        "country": None,
+        "date": None,
+        "title": fallback_title,
+    }
+
+    if session is None:
+        return info
+
+    # Prefer session.name (fastf1 3.x); fall back to mapping the short code.
+    info["session_name"] = (
+        getattr(session, "name", None)
+        or SESSION_TYPE_NAMES.get(str(session_type or "").upper())
+    )
+
+    # session.event is a pandas Series — key set varies by fastf1 version,
+    # so every lookup is individually guarded.
+    event = getattr(session, "event", None)
+
+    def _safe_get(key):
+        try:
+            return event[key]
+        except Exception:
+            return None
+
+    if event is not None:
+        info["event_name"] = _safe_get("EventName")
+        info["round_number"] = _safe_get("RoundNumber")
+        info["location"] = _safe_get("Location")
+        info["country"] = _safe_get("Country")
+
+        ev_date = _safe_get("EventDate")
+        if ev_date is not None:
+            try:
+                # pandas.Timestamp / datetime -> "06 Jul 2025"
+                info["year"] = ev_date.year
+                info["date"] = ev_date.strftime("%d %b %Y")
+            except Exception:
+                date_str = str(ev_date)
+                if date_str and date_str.lower() not in ("nat", "nan"):
+                    info["date"] = date_str
+
+    return info
+
