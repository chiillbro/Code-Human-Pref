 def _format_wind_direction(degrees: Optional[float]) -> str:
   if degrees is None:
       return "N/A"
   deg_norm = degrees % 360
   dirs = [
       "N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE",
       "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW",
   ]
   idx = int((deg_norm / 22.5) + 0.5) % len(dirs)
   return dirs[idx]
 
 class BaseComponent:
     def on_resize(self, window): pass
     def draw(self, window): pass
     def on_mouse_press(self, window, x: float, y: float, button: int, modifiers: int) -> bool: return False
 
+
+class SessionInfoBannerComponent(BaseComponent):
+    """
+    A banner component that displays session metadata at the top of the screen.
+    Shows event name, session type, year, and round number prominently.
+    """
+    
+    COLORS = {
+        "background": (20, 20, 20, 220),
+        "border": (200, 0, 0),
+        "title": (255, 255, 255),
+        "subtitle": (180, 180, 180),
+        "accent": (255, 24, 1),  # F1 red
+    }
+    
+    def __init__(
+        self,
+        session_info: Optional[SessionInfo] = None,
+        top_margin: int = 10,
+        title_font_size: int = 20,
+        subtitle_font_size: int = 12,
+        padding: int = 12,
+        min_width: int = 300,
+    ):
+        self.session_info = session_info
+        self.top_margin = top_margin
+        self.title_font_size = title_font_size
+        self.subtitle_font_size = subtitle_font_size
+        self.padding = padding
+        self.min_width = min_width
+        
+        self._visible = session_info is not None
+        self._center_x: Optional[float] = None
+        self._cached_title: Optional[arcade.Text] = None
+        self._cached_subtitle: Optional[arcade.Text] = None
+    
+    @property
+    def visible(self) -> bool:
+        return self._visible
+    
+    @visible.setter
+    def visible(self, value: bool):
+        self._visible = value
+    
+    def toggle_visibility(self) -> bool:
+        self._visible = not self._visible
+        return self._visible
+    
+    def set_session_info(self, session_info: Optional[SessionInfo]):
+        self.session_info = session_info
+        self._visible = session_info is not None
+        self._cached_title = None
+        self._cached_subtitle = None
+    
+    def _format_title_line(self) -> str:
+        if not self.session_info:
+            return ""
+        return f"{self.session_info.event_name} — {self.session_info.session_type_display}"
+    
+    def _format_subtitle_line(self) -> str:
+        if not self.session_info:
+            return ""
+        parts = [str(self.session_info.year), f"Round {self.session_info.round_number}"]
+        if self.session_info.country:
+            parts.append(self.session_info.country)
+        return " · ".join(parts)
+    
+    def on_resize(self, window):
+        self._center_x = window.width // 2
+        self._cached_title = None
+        self._cached_subtitle = None
+    
+    def draw(self, window):
+        if not self._visible or not self.session_info:
+            return
+        
+        if self._center_x is None:
+            self._center_x = window.width // 2
+        
+        title_text = self._format_title_line()
+        subtitle_text = self._format_subtitle_line()
+        
+        if self._cached_title is None:
+            self._cached_title = arcade.Text(
+                title_text,
+                self._center_x, 0,
+                self.COLORS["title"],
+                self.title_font_size,
+                anchor_x="center",
+                anchor_y="top",
+                bold=True,
+            )
+        else:
+            self._cached_title.text = title_text
+            self._cached_title.x = self._center_x
+        
+        if self._cached_subtitle is None:
+            self._cached_subtitle = arcade.Text(
+                subtitle_text,
+                self._center_x, 0,
+                self.COLORS["subtitle"],
+                self.subtitle_font_size,
+                anchor_x="center",
+                anchor_y="top",
+            )
+        else:
+            self._cached_subtitle.text = subtitle_text
+            self._cached_subtitle.x = self._center_x
+        
+        title_height = self.title_font_size + 4
+        subtitle_height = self.subtitle_font_size + 4
+        total_text_height = title_height + subtitle_height
+        banner_height = total_text_height + self.padding * 2
+        
+        title_width = self._cached_title.content_width
+        subtitle_width = self._cached_subtitle.content_width
+        content_width = max(title_width, subtitle_width)
+        banner_width = max(self.min_width, content_width + self.padding * 2)
+        
+        banner_top = window.height - self.top_margin
+        banner_center_y = banner_top - banner_height / 2
+        
+        # Draw background
+        bg_rect = arcade.XYWH(self._center_x, banner_center_y, banner_width, banner_height)
+        arcade.draw_rect_filled(bg_rect, self.COLORS["background"])
+        
+        # Draw accent line at top
+        accent_y = banner_top
+        arcade.draw_line(
+            self._center_x - banner_width / 2, accent_y,
+            self._center_x + banner_width / 2, accent_y,
+            self.COLORS["accent"], 3
+        )
+        
+        # Draw title
+        self._cached_title.y = banner_top - self.padding
+        self._cached_title.draw()
+        
+        # Draw subtitle
+        self._cached_subtitle.y = banner_top - self.padding - title_height
+        self._cached_subtitle.draw()
+
+
