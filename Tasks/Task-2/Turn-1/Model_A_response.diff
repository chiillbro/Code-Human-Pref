+class SessionInfo:
+    """Session metadata container for the banner component."""
+    
+    def __init__(
+        self,
+        event_name: str,
+        session_type: str,
+        year: int,
+        round_number: int,
+        country: Optional[str] = None,
+        circuit_name: Optional[str] = None,
+    ):
+        self.event_name = event_name
+        self.session_type = session_type
+        self.year = year
+        self.round_number = round_number
+        self.country = country
+        self.circuit_name = circuit_name
+    
+    @property
+    def session_type_display(self) -> str:
+        """Human-readable session type."""
+        type_map = {
+            'R': 'Race',
+            'S': 'Sprint',
+            'Q': 'Qualifying',
+            'SQ': 'Sprint Qualifying',
+            'FP1': 'Practice 1',
+            'FP2': 'Practice 2',
+            'FP3': 'Practice 3',
+        }
+        return type_map.get(self.session_type, self.session_type)
+    
+    @classmethod
+    def from_fastf1_session(cls, session, session_type: str) -> 'SessionInfo':
+        """Create SessionInfo from a fastf1 session object."""
+        event = session.event
+        year = 2024
+        event_date = event.get('EventDate', None)
+        if event_date is not None and hasattr(event_date, 'year'):
+            year = int(event_date.year)
+        
+        return cls(
+            event_name=event.get('EventName', 'Unknown Event'),
+            session_type=session_type,
+            year=year,
+            round_number=int(event.get('RoundNumber', 0)),
+            country=event.get('Country'),
+            circuit_name=event.get('Location'),
+        )
+
