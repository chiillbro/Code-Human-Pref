+    def _extract_with_tables(self, file_content: bytes) -> str:
+        """Extract PDF content with tables converted to markdown format."""
+        # First, use pdfplumber to find all tables and their positions
+        table_regions: List[_TableRegion] = []
+
+        with pdfplumber.open(io.BytesIO(file_content)) as pdf:
+            for page_num, page in enumerate(pdf.pages):
+                tables = page.find_tables()
+                for table in tables:
+                    table_data = table.extract()
+                    markdown_table = self._table_to_markdown(table_data)
+                    if markdown_table:
+                        # pdfplumber uses top-down coordinates, pdfminer uses bottom-up
+                        # Store in pdfplumber's coordinate system for now
+                        table_regions.append(
+                            _TableRegion(
+                                page_num=page_num,
+                                x0=table.bbox[0],
+                                top=table.bbox[1],
+                                x1=table.bbox[2],
+                                bottom=table.bbox[3],
+                                markdown=markdown_table,
+                            )
+                        )
+
+        # If no tables found, just use pdfminer for everything
+        if not table_regions:
+            return pdfminer.high_level.extract_text(io.BytesIO(file_content))
+
+        # Extract text using pdfminer with layout analysis
+        return self._extract_text_with_table_regions(file_content, table_regions)
+
+    def _extract_text_with_table_regions(
+        self, file_content: bytes, table_regions: List[_TableRegion]
+    ) -> str:
+        """Extract text using pdfminer, inserting tables at appropriate positions."""
+        rsrcmgr = PDFResourceManager()
+        laparams = LAParams()
+        device = PDFPageAggregator(rsrcmgr, laparams=laparams)
+        interpreter = PDFPageInterpreter(rsrcmgr, device)
+
+        result_parts = []
+
+        with io.BytesIO(file_content) as fp:
+            # Also open with pdfplumber to get page heights for coordinate conversion
+            with pdfplumber.open(io.BytesIO(file_content)) as plumber_pdf:
+                for page_num, page in enumerate(
+                    PDFPage.get_pages(fp, check_extractable=True)
+                ):
+                    interpreter.process_page(page)
+                    layout = device.get_result()
+
+                    # Get page height for coordinate conversion
+                    page_height = plumber_pdf.pages[page_num].height
+
+                    # Get tables for this page
+                    page_tables = [t for t in table_regions if t.page_num == page_num]
+
+                    page_content = self._process_page_layout(
+                        layout, page_tables, page_height
+                    )
+                    if page_content.strip():
+                        result_parts.append(page_content)
+
+        return "\n\n".join(result_parts)
+
+    def _process_page_layout(
+        self,
+        layout,
+        table_regions: List[_TableRegion],
+        page_height: float,
+    ) -> str:
+        """Process a page layout, integrating tables with text."""
+        blocks: List[_ContentBlock] = []
+
+        # Add table blocks (convert from pdfplumber to pdfminer coordinates)
+        for table in table_regions:
+            # pdfplumber: origin at top-left, y increases downward
+            # pdfminer: origin at bottom-left, y increases upward
+            # Convert: pdfminer_y = page_height - pdfplumber_y
+            miner_top = page_height - table.top
+            miner_bottom = page_height - table.bottom
+            blocks.append(
+                _ContentBlock(
+                    top=miner_top,  # In pdfminer coords, top has higher y
+                    bottom=miner_bottom,
+                    content_type="table",
+                    content=table.markdown,
+                )
+            )
+
+        # Extract text elements, excluding those in table regions
+        for element in layout:
+            if isinstance(element, LTTextContainer):
+                text = element.get_text().strip()
+                if not text:
+                    continue
+
+                # Get element bounding box (in pdfminer coordinates)
+                elem_x0 = element.x0
+                elem_x1 = element.x1
+                elem_y0 = element.y0  # bottom in pdfminer
+                elem_y1 = element.y1  # top in pdfminer
+
+                # Check if this text element overlaps with any table
+                is_in_table = False
+                for table in table_regions:
+                    # Convert table coords to pdfminer system
+                    table_miner_bottom = page_height - table.bottom
+                    table_miner_top = page_height - table.top
+
+                    # Check overlap
+                    if (
+                        elem_y0 < table_miner_top
+                        and elem_y1 > table_miner_bottom
+                        and elem_x0 < table.x1
+                        and elem_x1 > table.x0
+                    ):
+                        is_in_table = True
+                        break
+
+                if not is_in_table:
+                    blocks.append(
+                        _ContentBlock(
+                            top=elem_y1,
+                            bottom=elem_y0,
+                            content_type="text",
+                            content=text,
+                        )
+                    )
+
+        # Sort blocks by vertical position (top to bottom means higher y first)
+        blocks.sort(key=lambda b: -b.top)
+
+        # Build output
+        parts = []
+        for block in blocks:
+            if block.content_type == "table":
+                parts.append("\n" + block.content + "\n")
+            else:
+                parts.append(block.content)
+
+        return "\n\n".join(parts)
+
+    def _table_to_markdown(self, table_data: List[List[Optional[str]]]) -> str:
+        """Convert a 2D table to markdown format."""
+        if not table_data or not table_data[0]:
+            return ""
+
+        # Clean up None values and normalize cells
+        cleaned = []
+        for row in table_data:
+            cleaned_row = []
+            for cell in row:
+                cell_text = str(cell) if cell is not None else ""
+                # Escape pipe characters and normalize whitespace
+                cell_text = cell_text.replace("|", "\\|").replace("\n", " ").strip()
+                cleaned_row.append(cell_text)
+            cleaned.append(cleaned_row)
+
+        if not cleaned:
+            return ""
+
+        # Determine number of columns from max row length
+        num_cols = max(len(row) for row in cleaned)
+        if num_cols == 0:
+            return ""
+
+        # Normalize all rows to same number of columns
+        for row in cleaned:
+            while len(row) < num_cols:
+                row.append("")
+
+        lines = []
+        # Header row
+        lines.append("| " + " | ".join(cleaned[0]) + " |")
+        # Separator row
+        lines.append("| " + " | ".join(["---"] * num_cols) + " |")
+        # Data rows
+        for row in cleaned[1:]:
+            lines.append("| " + " | ".join(row) + " |")
+
+        return "\n".join(lines)
