+    def _normalize_race_name(self, event_name):
+        """Extract a normalized race name for matching across years.
+        
+        Handles variations like 'Monaco Grand Prix', 'British Grand Prix', etc.
+        Returns a canonical name that can be used for matching.
+        """
+        name = event_name.strip()
+        # Remove common suffixes for comparison
+        for suffix in self.RACE_NAME_SUFFIXES:
+            if name.endswith(suffix):
+                name = name[:-len(suffix)].strip()
+                break
+        return name
+
+    def _load_all_years_for_filter(self):
+        """Load events from all available years to populate the race name filter."""
+        current_year = int(self.year_combo.currentText())
+        years = list(range(self.min_year, current_year + 1))
+        
+        self.multi_year_worker = FetchMultiYearScheduleWorker(years)
+        self.multi_year_worker.result.connect(self._on_all_years_loaded)
+        self.multi_year_worker.error.connect(lambda _: None)  # Silently ignore errors
+        self.multi_year_worker.start()
+
+    def _on_all_years_loaded(self, all_events):
+        """Handle completion of multi-year event loading."""
+        # Cache events by year
+        for event in all_events:
+            year = event.get("year")
+            if year not in self.all_events_cache:
+                self.all_events_cache[year] = []
+            self.all_events_cache[year].append(event)
+        
+        # Extract unique race names
+        race_names = set()
+        for event in all_events:
+            normalized = self._normalize_race_name(event.get("event_name", ""))
+            if normalized:
+                race_names.add(normalized)
+        
+        self.unique_race_names = sorted(race_names)
+        
+        # Populate the filter combobox
+        self.race_filter_combo.blockSignals(True)
+        self.race_filter_combo.clear()
+        self.race_filter_combo.addItem("All Races")
+        for name in self.unique_race_names:
+            self.race_filter_combo.addItem(name)
+        self.race_filter_combo.blockSignals(False)
+        self.race_filter_combo.setEnabled(True)
+
