+class FetchMultiYearScheduleWorker(QThread):
+    """Worker thread to fetch schedules from multiple years for race name filtering."""
+    result = Signal(object)
+    error = Signal(str)
+
+    def __init__(self, years, parent=None):
+        super().__init__(parent)
+        self.years = years
+
+    def run(self):
+        try:
+            try:
+                from src.f1_data import enable_cache
+                enable_cache()
+            except Exception:
+                pass
+            
+            all_events = []
+            for year in self.years:
+                try:
+                    events = get_race_weekends_by_year(year)
+                    for event in events:
+                        event["year"] = year
+                    all_events.extend(events)
+                except Exception:
+                    # Skip years that fail to load
+                    continue
+            self.result.emit(all_events)
+        except Exception as e:
+            self.error.emit(str(e))
