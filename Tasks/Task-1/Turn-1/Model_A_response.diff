+
+    def _group_words_into_lines(
+        self, words: List[dict], tolerance: float = 3.0
+    ) -> List[Tuple[float, str]]:
+        """
+        Group words into lines based on their vertical position.
+        Returns list of (top_position, line_text) tuples.
+        """
+        if not words:
+            return []
+
+        # Sort words by vertical then horizontal position
+        sorted_words = sorted(words, key=lambda w: (w["top"], w["x0"]))
+
+        lines: List[Tuple[float, str]] = []
+        current_line_words: List[dict] = []
+        current_line_top: Optional[float] = None
+
+        for word in sorted_words:
+            if current_line_top is None:
+                current_line_top = word["top"]
+                current_line_words = [word]
+            elif abs(word["top"] - current_line_top) <= tolerance:
+                current_line_words.append(word)
+            else:
+                # Finalize current line
+                line_text = " ".join(
+                    w["text"] for w in sorted(current_line_words, key=lambda w: w["x0"])
+                )
+                lines.append((current_line_top, line_text))
+                current_line_top = word["top"]
+                current_line_words = [word]
+
+        # Don't forget the last line
+        if current_line_words and current_line_top is not None:
+            line_text = " ".join(
+                w["text"] for w in sorted(current_line_words, key=lambda w: w["x0"])
+            )
+            lines.append((current_line_top, line_text))
+
+        return lines
+
+    def _group_lines_into_paragraphs(
+        self, lines: List[Tuple[float, str]], tolerance: float = 15.0
+    ) -> List[Tuple[float, str]]:
+        """
+        Group consecutive lines into paragraphs.
+        Lines with larger vertical gaps are considered separate paragraphs.
+        Returns list of (top_position, paragraph_text) tuples.
+        """
+        if not lines:
+            return []
+
+        paragraphs: List[Tuple[float, str]] = []
+        current_para_lines: List[Tuple[float, str]] = []
+        current_para_top: Optional[float] = None
+
+        for top, text in lines:
+            if current_para_top is None:
+                current_para_top = top
+                current_para_lines = [(top, text)]
+            elif current_para_lines and (top - current_para_lines[-1][0]) <= tolerance:
+                current_para_lines.append((top, text))
+            else:
+                # Finalize current paragraph
+                para_text = "\n".join(t for _, t in current_para_lines)
+                paragraphs.append((current_para_top, para_text))
+                current_para_top = top
+                current_para_lines = [(top, text)]
+
+        # Don't forget the last paragraph
+        if current_para_lines and current_para_top is not None:
+            para_text = "\n".join(t for _, t in current_para_lines)
+            paragraphs.append((current_para_top, para_text))
+
+        return paragraphs
+
+    def _table_to_markdown(self, table_data: List[List[Any]]) -> str:
+        """
+        Convert extracted table data to a Markdown table.
+        """
+        if not table_data or not table_data[0]:
+            return ""
+
+        # Clean cells: handle None, escape pipes, normalize whitespace
+        def clean_cell(cell: Any) -> str:
+            if cell is None:
+                return ""
+            return str(cell).replace("|", "\\|").replace("\n", " ").strip()
+
+        cleaned = [[clean_cell(cell) for cell in row] for row in table_data]
+
+        # Ensure all rows have the same number of columns
+        max_cols = max(len(row) for row in cleaned)
+        for row in cleaned:
+            while len(row) < max_cols:
+                row.append("")
+
+        lines = []
+        # Header row
+        lines.append("| " + " | ".join(cleaned[0]) + " |")
+        # Separator row
+        lines.append("| " + " | ".join(["---"] * max_cols) + " |")
+        # Data rows
+        for row in cleaned[1:]:
+            lines.append("| " + " | ".join(row) + " |")
+
+        return "\n".join(lines)
