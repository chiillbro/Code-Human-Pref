+# Standard suffixes to strip when normalizing race names
+_RACE_NAME_SUFFIXES = ["Grand Prix", "GP"]
+
+
+def _normalize_race_name(event_name):
+    """Normalize a race event name for consistent matching across years.
+    
+    Strips common suffixes like 'Grand Prix' and 'GP' to enable matching
+    events like 'Monaco Grand Prix' across different years.
+    """
+    name = event_name.strip()
+    for suffix in _RACE_NAME_SUFFIXES:
+        if name.endswith(suffix):
+            return name[:-len(suffix)].strip()
+    return name
+
+
+def get_unique_race_names(years):
+    """Get all unique normalized race event names across the specified years.
+    
+    Args:
+        years: List of years to scan for race events.
+        
+    Returns:
+        Sorted list of unique normalized race names (e.g., ['Australian', 'Bahrain', ...]).
+    """
+    enable_cache()
+    race_names = set()
+    
+    for year in years:
+        try:
+            schedule = fastf1.get_event_schedule(year)
+            for _, event in schedule.iterrows():
+                if event.is_testing():
+                    continue
+                normalized = _normalize_race_name(event["EventName"])
+                if normalized:
+                    race_names.add(normalized)
+        except Exception:
+            # Skip years that fail to load
+            continue
+    
+    return sorted(race_names)
+
+
+def get_race_weekends_by_name(race_name, years):
+    """Get all race weekends matching a specific race name across years.
+    
+    Args:
+        race_name: Normalized race name to filter by (e.g., 'Monaco').
+        years: List of years to search.
+        
+    Returns:
+        List of race weekend dicts with 'year' included, sorted by year descending.
+    """
+    enable_cache()
+    matching_events = []
+    
+    for year in years:
+        try:
+            schedule = fastf1.get_event_schedule(year)
+            for _, event in schedule.iterrows():
+                if event.is_testing():
+                    continue
+                normalized = _normalize_race_name(event["EventName"])
+                if normalized == race_name:
+                    matching_events.append({
+                        "year": year,
+                        "round_number": event["RoundNumber"],
+                        "event_name": event["EventName"],
+                        "date": str(event["EventDate"].date()),
+                        "country": event["Country"],
+                        "type": event["EventFormat"],
+                    })
+        except Exception:
+            # Skip years that fail to load
+            continue
+    
+    # Sort by year descending (most recent first)
+    matching_events.sort(key=lambda e: e["year"], reverse=True)
+    return matching_events
+
+
