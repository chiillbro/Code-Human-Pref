+"""Tests for time formatting and parsing utility functions."""
+
+import pytest
+from src.lib.time import format_time, parse_time_string
+
+
+class TestFormatTime:
+    """Tests for format_time function."""
+
+    @pytest.mark.parametrize("seconds,expected", [
+        (0, "00:00.000"),
+        (1, "00:01.000"),
+        (59, "00:59.000"),
+        (60, "01:00.000"),
+        (61, "01:01.000"),
+        (90, "01:30.000"),
+        (3600, "60:00.000"),
+    ])
+    def test_standard_whole_seconds(self, seconds, expected):
+        """Whole second values should format correctly."""
+        assert format_time(seconds) == expected
+
+    @pytest.mark.parametrize("seconds,expected", [
+        (0.001, "00:00.001"),
+        (0.123, "00:00.123"),
+        (1.5, "00:01.500"),
+        (90.123, "01:30.123"),
+        (90.999, "01:30.999"),
+    ])
+    def test_millisecond_precision(self, seconds, expected):
+        """Millisecond precision should be maintained."""
+        assert format_time(seconds) == expected
+
+    @pytest.mark.parametrize("seconds,expected", [
+        (90.1234, "01:30.123"),
+        (90.1235, "01:30.124"),
+        (90.1239, "01:30.124"),
+        (0.0001, "00:00.000"),
+        (0.0005, "00:00.001"),
+        (0.0009, "00:00.001"),
+    ])
+    def test_rounding_behavior(self, seconds, expected):
+        """Values with more than 3 decimal places should round correctly."""
+        assert format_time(seconds) == expected
+
+    def test_none_input_returns_na(self):
+        """None input should return 'N/A'."""
+        assert format_time(None) == "N/A"
+
+    @pytest.mark.parametrize("seconds", [-1, -0.001, -60, -3600])
+    def test_negative_values_return_na(self, seconds):
+        """Negative values should return 'N/A'."""
+        assert format_time(seconds) == "N/A"
+
+    @pytest.mark.parametrize("seconds,expected", [
+        (3599.999, "59:59.999"),
+        (3661.123, "61:01.123"),
+        (7200, "120:00.000"),
+    ])
+    def test_large_values(self, seconds, expected):
+        """Large time values (over an hour) should format correctly."""
+        assert format_time(seconds) == expected
+
+    @pytest.mark.parametrize("seconds,expected", [
+        (0.0, "00:00.000"),
+        (1.0, "00:01.000"),
+        (60.0, "01:00.000"),
+    ])
+    def test_float_whole_numbers(self, seconds, expected):
+        """Float values equal to whole numbers should format correctly."""
+        assert format_time(seconds) == expected
+
+    def test_zero_is_valid(self):
+        """Zero should be a valid time value."""
+        assert format_time(0) == "00:00.000"
+        assert format_time(0.0) == "00:00.000"
+
+
+class TestParseTimeString:
+    """Tests for parse_time_string function."""
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("01:26", 86.0),
+        ("00:30", 30.0),
+        ("10:00", 600.0),
+        ("00:01", 1.0),
+    ])
+    def test_mm_ss_format(self, time_str, expected):
+        """MM:SS format should parse correctly."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("01:26.123", 86.123),
+        ("01:26.500", 86.5),
+        ("00:30.001", 30.001),
+        ("1:30.500", 90.5),
+    ])
+    def test_mm_ss_micro_format(self, time_str, expected):
+        """MM:SS.micro format should parse correctly."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("00:01:26.123000", 86.123),
+        ("00:01:26:123000", 86.123),
+        ("00:00:30.500000", 30.5),
+        ("01:00:00.000000", 3600.0),
+    ])
+    def test_hh_mm_ss_micro_format(self, time_str, expected):
+        """HH:MM:SS.micro format should parse correctly."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("00:01:26", 86.0),
+        ("01:30:00", 5400.0),
+        ("00:00:01", 1.0),
+    ])
+    def test_hh_mm_ss_format(self, time_str, expected):
+        """HH:MM:SS format (no microseconds) should parse correctly."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("0 days 00:01:27.060000", 87.06),
+        ("0 days 00:00:30.500000", 30.5),
+    ])
+    def test_timedelta_format(self, time_str, expected):
+        """Pandas timedelta format '0 days HH:MM:SS.micro' should parse correctly."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("1 days 00:00:00.000000", 0.0),
+        ("2 days 01:30:00.000000", 5400.0),
+    ])
+    def test_timedelta_format_ignores_days(self, time_str, expected):
+        """Days component is stripped, only time part is parsed."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str", [
+        "",
+        "   ",
+        "invalid",
+        "abc:def",
+    ])
+    def test_invalid_strings_return_none(self, time_str):
+        """Invalid time strings should return None."""
+        assert parse_time_string(time_str) is None
+
+    def test_single_number_returns_none(self):
+        """Single number without colons should return None."""
+        assert parse_time_string("12") is None
+
+    @pytest.mark.parametrize("time_str,expected", [
+        ("01:26.123", 86.123),
+        ("01:26.1234", 86.123),
+        ("01:26.12345", 86.123),
+        ("01:26.123456", 86.123),
+    ])
+    def test_variable_microsecond_precision(self, time_str, expected):
+        """Microseconds with 3+ digits should parse correctly."""
+        assert parse_time_string(time_str) == expected
+
+    @pytest.mark.parametrize("time_str", [
+        "01:26.1",
+        "01:26.12",
+    ])
+    def test_short_microseconds_treated_as_hh_mm_ss(self, time_str):
+        """1-2 digit fractions are ambiguously parsed as HH:MM:SS."""
+        # This is actual behavior: "01:26.1" splits to ['01', '26', '1']
+        # and since len('1') <= 2, it's treated as HH:MM:SS format
+        result = parse_time_string(time_str)
+        assert result is not None
+
+    def test_trailing_whitespace_handled(self):
+        """Trailing whitespace should be stripped."""
+        assert parse_time_string("01:26.123 ") == 86.123
+
+    @pytest.mark.parametrize("time_str", [
+        " 01:26.123",
+        " 01:26.123 ",
+    ])
+    def test_leading_whitespace_returns_none(self, time_str):
+        """Leading whitespace causes parsing to fail (splits on space first)."""
+        assert parse_time_string(time_str) is None
+
+    def test_trailing_text_stripped(self):
+        """Text after space in time string should be stripped."""
+        assert parse_time_string("01:26.123 some text") == 86.123
+
+
+class TestTimeRoundTrip:
+    """Tests for round-trip conversion between format and parse."""
+
+    @pytest.mark.parametrize("seconds", [
+        0, 1, 30, 60, 90, 90.123, 3600, 3661.456
+    ])
+    def test_format_then_parse(self, seconds):
+        """Formatting then parsing should return approximately the original value."""
+        formatted = format_time(seconds)
+        parsed = parse_time_string(formatted)
+        assert parsed == pytest.approx(seconds, abs=0.001)
+
+    @pytest.mark.parametrize("time_str,expected_seconds", [
+        ("01:30.000", 90.0),
+        ("00:01.500", 1.5),
+        ("10:00.000", 600.0),
+    ])
+    def test_parse_then_format(self, time_str, expected_seconds):
+        """Parsing then formatting should return the original string."""
+        parsed = parse_time_string(time_str)
+        formatted = format_time(parsed)
+        assert formatted == time_str
