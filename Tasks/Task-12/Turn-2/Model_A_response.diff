+
+def extract_function_from_source(filepath: str, function_name: str):
+    """
+    Extract and compile a single function from a source file.
+    This avoids issues with Python 3.10+ type hints in the rest of the module.
+    """
+    import re
+    from typing import Optional
+
+    with open(filepath, 'r') as f:
+        source = f.read()
+
+    # Find the function definition using regex
+    pattern = rf'^(def {function_name}\([^)]*\)[^:]*:.*?)(?=\n(?:def |class |\Z))'
+    match = re.search(pattern, source, re.MULTILINE | re.DOTALL)
+
+    if not match:
+        raise ValueError(f"Function {function_name} not found in {filepath}")
+
+    func_source = match.group(1)
+
+    # Create a namespace with required imports
+    namespace = {'Optional': Optional}
+
+    # Compile and execute the function definition
+    exec(compile(func_source, filepath, 'exec'), namespace)
+
+    return namespace[function_name]
+
+
