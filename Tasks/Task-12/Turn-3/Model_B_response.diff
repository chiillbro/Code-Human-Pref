+"""
+Tests for utility functions in src/ui_components.py.
+
+Note: The source file uses Python 3.10+ type hints (tuple | None) which are not
+compatible with older Python versions. We extract and test _format_wind_direction
+by reading the source and compiling just that function, ensuring we test the
+actual source code while avoiding the incompatible syntax elsewhere in the module.
+"""
+import ast
+import textwrap
+from pathlib import Path
+from typing import Optional
+
+import pytest
+
+
+def _extract_format_wind_direction():
+    """
+    Extract _format_wind_direction from source file and compile it.
+    This avoids importing the full module which has Python 3.10+ type hints.
+    """
+    source_path = Path(__file__).parent.parent / "src" / "ui_components.py"
+    source_code = source_path.read_text()
+
+    tree = ast.parse(source_code)
+
+    for node in ast.walk(tree):
+        if isinstance(node, ast.FunctionDef) and node.name == "_format_wind_direction":
+            func_source = ast.get_source_segment(source_code, node)
+            local_ns = {"Optional": Optional}
+            exec(compile(ast.parse(func_source), "<string>", "exec"), local_ns)
+            return local_ns["_format_wind_direction"]
+
+    raise RuntimeError("Could not find _format_wind_direction in source")
+
+
+_format_wind_direction = _extract_format_wind_direction()
+
