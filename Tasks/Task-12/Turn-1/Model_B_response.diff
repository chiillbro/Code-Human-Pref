+import pytest
+from src.lib.tyres import get_tyre_compound_int, get_tyre_compound_str
+
+
+class TestGetTyreCompoundInt:
+    """Tests for get_tyre_compound_int function."""
+
+    @pytest.mark.parametrize("compound_str,expected", [
+        ("SOFT", 0),
+        ("MEDIUM", 1),
+        ("HARD", 2),
+        ("INTERMEDIATE", 3),
+        ("WET", 4),
+    ])
+    def test_standard_compounds(self, compound_str, expected):
+        """Valid compound strings should return their corresponding integers."""
+        assert get_tyre_compound_int(compound_str) == expected
+
+    @pytest.mark.parametrize("compound_str,expected", [
+        ("soft", 0),
+        ("Soft", 0),
+        ("SoFt", 0),
+        ("medium", 1),
+        ("Medium", 1),
+        ("hard", 2),
+        ("Hard", 2),
+        ("intermediate", 3),
+        ("Intermediate", 3),
+        ("wet", 4),
+        ("Wet", 4),
+    ])
+    def test_case_insensitivity(self, compound_str, expected):
+        """Compound strings should be case-insensitive."""
+        assert get_tyre_compound_int(compound_str) == expected
+
+    @pytest.mark.parametrize("compound_str", [
+        "UNKNOWN",
+        "ULTRASOFT",
+        "SUPERSOFT",
+        "HYPERSOFT",
+        "",
+        "invalid",
+        "S",
+        "M",
+        "H",
+        "I",
+        "W",
+    ])
+    def test_invalid_compounds_return_negative_one(self, compound_str):
+        """Invalid compound strings should return -1."""
+        assert get_tyre_compound_int(compound_str) == -1
+
+    @pytest.mark.parametrize("compound_str", [
+        " SOFT",
+        "SOFT ",
+        " SOFT ",
+        "SO FT",
+    ])
+    def test_whitespace_in_input_returns_negative_one(self, compound_str):
+        """Strings with extra whitespace should return -1."""
+        assert get_tyre_compound_int(compound_str) == -1
+
+
+class TestGetTyreCompoundStr:
+    """Tests for get_tyre_compound_str function."""
+
+    @pytest.mark.parametrize("compound_int,expected", [
+        (0, "SOFT"),
+        (1, "MEDIUM"),
+        (2, "HARD"),
+        (3, "INTERMEDIATE"),
+        (4, "WET"),
+    ])
+    def test_standard_compounds(self, compound_int, expected):
+        """Valid compound integers should return their corresponding strings."""
+        assert get_tyre_compound_str(compound_int) == expected
+
+    @pytest.mark.parametrize("compound_int", [
+        -1,
+        5,
+        10,
+        100,
+        -100,
+    ])
+    def test_invalid_integers_return_unknown(self, compound_int):
+        """Invalid compound integers should return 'UNKNOWN'."""
+        assert get_tyre_compound_str(compound_int) == "UNKNOWN"
+
+    @pytest.mark.parametrize("compound_int", [
+        0.0,
+        1.0,
+        2.0,
+        3.0,
+        4.0,
+    ])
+    def test_float_equivalents(self, compound_int):
+        """Float values equal to valid integers should work due to Python equality."""
+        expected_map = {0.0: "SOFT", 1.0: "MEDIUM", 2.0: "HARD", 3.0: "INTERMEDIATE", 4.0: "WET"}
+        assert get_tyre_compound_str(compound_int) == expected_map[compound_int]
+
+    @pytest.mark.parametrize("compound_int", [
+        0.5,
+        1.5,
+        2.5,
+        -0.5,
+    ])
+    def test_non_integer_floats_return_unknown(self, compound_int):
+        """Float values that don't equal valid integers should return 'UNKNOWN'."""
+        assert get_tyre_compound_str(compound_int) == "UNKNOWN"
+
+
+class TestRoundTripConversion:
+    """Tests for round-trip conversion between int and string."""
+
+    @pytest.mark.parametrize("compound_str", [
+        "SOFT",
+        "MEDIUM",
+        "HARD",
+        "INTERMEDIATE",
+        "WET",
+    ])
+    def test_string_to_int_to_string(self, compound_str):
+        """Converting string to int and back should return original string."""
+        compound_int = get_tyre_compound_int(compound_str)
+        result = get_tyre_compound_str(compound_int)
+        assert result == compound_str
+
+    @pytest.mark.parametrize("compound_int", [0, 1, 2, 3, 4])
+    def test_int_to_string_to_int(self, compound_int):
+        """Converting int to string and back should return original int."""
+        compound_str = get_tyre_compound_str(compound_int)
+        result = get_tyre_compound_int(compound_str)
+        assert result == compound_int
diff --git a/tests/test_ui_components.py b/tests/test_ui_components.py
