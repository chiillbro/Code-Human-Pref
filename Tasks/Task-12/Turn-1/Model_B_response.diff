+import pytest
+from typing import Optional
+
+
+def _format_wind_direction(degrees: Optional[float]) -> str:
+    """
+    Local copy of the function from src/ui_components.py for isolated testing.
+    This avoids importing the entire module which has heavy dependencies (arcade)
+    and Python 3.10+ type hints incompatible with older Python versions.
+    """
+    if degrees is None:
+        return "N/A"
+    deg_norm = degrees % 360
+    dirs = [
+        "N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE",
+        "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW",
+    ]
+    idx = int((deg_norm / 22.5) + 0.5) % len(dirs)
+    return dirs[idx]
+
+
+class TestFormatWindDirection:
+    """Tests for _format_wind_direction function."""
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (0, "N"),
+        (90, "E"),
+        (180, "S"),
+        (270, "W"),
+    ])
+    def test_cardinal_directions(self, degrees, expected):
+        """Cardinal directions (N, E, S, W) at exact angles."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (45, "NE"),
+        (135, "SE"),
+        (225, "SW"),
+        (315, "NW"),
+    ])
+    def test_intercardinal_directions(self, degrees, expected):
+        """Intercardinal directions (NE, SE, SW, NW) at 45-degree intervals."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (22.5, "NNE"),
+        (67.5, "ENE"),
+        (112.5, "ESE"),
+        (157.5, "SSE"),
+        (202.5, "SSW"),
+        (247.5, "WSW"),
+        (292.5, "WNW"),
+        (337.5, "NNW"),
+    ])
+    def test_secondary_intercardinal_directions(self, degrees, expected):
+        """Secondary intercardinal directions at 22.5-degree intervals."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (360, "N"),
+        (450, "E"),
+        (540, "S"),
+        (720, "N"),
+        (810, "E"),
+    ])
+    def test_degrees_above_360_normalized(self, degrees, expected):
+        """Degrees >= 360 should be normalized using modulo."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (-90, "W"),
+        (-180, "S"),
+        (-270, "E"),
+        (-360, "N"),
+        (-45, "NW"),
+    ])
+    def test_negative_degrees_normalized(self, degrees, expected):
+        """Negative degrees should be normalized correctly."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (11.24, "N"),
+        (11.25, "NNE"),  # Exact boundary rounds to next direction
+        (11.26, "NNE"),
+        (33.74, "NNE"),
+        (33.75, "NE"),  # Exact boundary rounds to next direction
+        (33.76, "NE"),
+        (348.75, "N"),  # 348.75 / 22.5 + 0.5 = 16, wraps to 0 (N)
+        (348.74, "NNW"),
+    ])
+    def test_boundary_conditions(self, degrees, expected):
+        """Test values at direction boundaries (rounding behavior)."""
+        assert _format_wind_direction(degrees) == expected
+
+    def test_none_input_returns_na(self):
+        """None input should return 'N/A'."""
+        assert _format_wind_direction(None) == "N/A"
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (0.0, "N"),
+        (90.0, "E"),
+        (180.0, "S"),
+        (270.0, "W"),
+        (45.0, "NE"),
+    ])
+    def test_float_inputs(self, degrees, expected):
+        """Float inputs should work the same as integers."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees,expected", [
+        (359.9, "N"),
+        (0.1, "N"),
+        (89.9, "E"),
+        (90.1, "E"),
+    ])
+    def test_near_cardinal_directions(self, degrees, expected):
+        """Values very close to cardinal directions should round correctly."""
+        assert _format_wind_direction(degrees) == expected
+
+    @pytest.mark.parametrize("degrees", [
+        1000,
+        -1000,
+        3600,
+        -3600,
+    ])
+    def test_extreme_values(self, degrees):
+        """Extreme positive and negative values should normalize correctly."""
+        result = _format_wind_direction(degrees)
+        valid_directions = ["N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE",
+                           "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW"]
+        assert result in valid_directions
+
+    def test_all_16_directions_coverage(self):
+        """Verify all 16 compass directions can be reached."""
+        expected_directions = ["N", "NNE", "NE", "ENE", "E", "ESE", "SE", "SSE",
+                               "S", "SSW", "SW", "WSW", "W", "WNW", "NW", "NNW"]
+        results = set()
+        for i in range(16):
+            degrees = i * 22.5
+            results.add(_format_wind_direction(degrees))
+        assert results == set(expected_directions)
