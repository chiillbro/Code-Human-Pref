+class _TooltipManager(object):
+    """
+    Manages tooltip display for a single Menu instance.
+
+    Tracks which widget the mouse is currently hovering over (via the global
+    WIDGET_MOUSEOVER list) and draws a styled tooltip box after the configured
+    delay has elapsed.
+    """
+
+    def __init__(self, menu: 'Menu') -> None:
+        self._menu = menu
+        # Widget currently being tracked for tooltip
+        self._tracked_widget: Optional['Widget'] = None
+        # Time (seconds) when the current widget was first entered
+        self._hover_start: float = 0.0
+        # Cached rendered tooltip surface so it is not re-rendered every frame
+        self._cached_widget: Optional['Widget'] = None
+        self._cached_surface: Optional['pygame.Surface'] = None
+
+    def _get_padding(self) -> Tuple:
+        """Return tooltip padding as (top, right, bottom, left)."""
+        p = self._menu._theme.tooltip_padding
+        if isinstance(p, (int, float)):
+            return int(p), int(p), int(p), int(p)
+        if len(p) == 2:
+            return int(p[0]), int(p[1]), int(p[0]), int(p[1])
+        if len(p) == 3:
+            return int(p[0]), int(p[1]), int(p[2]), int(p[1])
+        return int(p[0]), int(p[1]), int(p[2]), int(p[3])
+
+    def _build_surface(self, widget: 'Widget') -> Optional['pygame.Surface']:
+        """Build and return the tooltip surface for *widget*."""
+        from pygame_menu.font import get_font
+        theme = self._menu._theme
+        text = widget._tooltip
+        if not text:
+            return None
+
+        font_obj = get_font(theme.widget_font, theme.tooltip_font_size)
+        # Use only RGB channels for font rendering (alpha not supported in all pygame versions)
+        font_color = theme.tooltip_font_color[:3]
+        text_surf = font_obj.render(text, True, font_color)
+        tw, th = text_surf.get_size()
+
+        pad_t, pad_r, pad_b, pad_l = self._get_padding()
+        box_w = tw + pad_l + pad_r
+        box_h = th + pad_t + pad_b
+
+        bg = theme.tooltip_background_color
+        # Support alpha channel
+        surf = pygame.Surface((box_w, box_h), pygame.SRCALPHA)
+        surf.fill(bg)
+
+        # Border
+        bw = theme.tooltip_border_width
+        if bw > 0:
+            pygame.draw.rect(surf, theme.tooltip_border_color,
+                             pygame.Rect(0, 0, box_w, box_h), bw)
+
+        surf.blit(text_surf, (pad_l, pad_t))
+        return surf
+
+    def draw(self, surface: 'pygame.Surface') -> None:
+        """Draw the tooltip onto *surface* if conditions are met."""
+        # Determine which widget the mouse is over right now
+        current_widget: Optional['Widget'] = WIDGET_MOUSEOVER[0]
+
+        # Only show tooltips for widgets that belong to this menu
+        if current_widget is not None and \
+                (current_widget._menu is not self._menu or
+                 not hasattr(current_widget, '_tooltip') or
+                 not current_widget._tooltip):
+            current_widget = None
+
+        if current_widget is not self._tracked_widget:
+            # Widget changed – reset timer and cache
+            self._tracked_widget = current_widget
+            self._hover_start = time.time()
+            self._cached_widget = None
+            self._cached_surface = None
+
+        if self._tracked_widget is None:
+            return
+
+        theme = self._menu._theme
+        delay_s = theme.tooltip_delay / 1000.0
+        if time.time() - self._hover_start < delay_s:
+            return
+
+        # Build or reuse cached surface
+        if self._cached_widget is not self._tracked_widget:
+            self._cached_surface = self._build_surface(self._tracked_widget)
+            self._cached_widget = self._tracked_widget
+
+        if self._cached_surface is None:
+            return
+
+        # Position tooltip near cursor, offset slightly below-right
+        mx, my = pygame.mouse.get_pos()
+        sw, sh = self._cached_surface.get_size()
+        disp_w, disp_h = surface.get_size()
+
+        tip_x = mx + 14
+        tip_y = my + 14
+
+        # Keep inside display bounds
+        if tip_x + sw > disp_w:
+            tip_x = mx - sw - 6
+        if tip_y + sh > disp_h:
+            tip_y = my - sh - 6
+
+        surface.blit(self._cached_surface, (tip_x, tip_y))
+
