+class TestValidationThemeIntegration:
+    def test_theme_defaults_present(self):
+        t = pygame_menu.themes.THEME_DEFAULT
+        # Theme has defaults registered; reading the attribute should work.
+        assert hasattr(t, "widget_validation_error_color")
+        assert hasattr(t, "widget_validation_error_border_width")
+        assert hasattr(t, "widget_validation_error_background_color")
+
+    def test_custom_theme_values(self):
+        theme = pygame_menu.Theme(
+            widget_validation_error_color=(0, 255, 0),
+            widget_validation_error_border_width=5,
+            widget_validation_error_background_color=(10, 10, 10, 128),
+        )
+        theme.validate()
+        assert theme.widget_validation_error_color == (0, 255, 0, 255)
+        assert theme.widget_validation_error_border_width == 5
+        assert theme.widget_validation_error_background_color == (10, 10, 10, 128)
+
+    def test_invalid_border_width_rejected(self):
+        theme = pygame_menu.Theme(widget_validation_error_border_width=-1)
+        with pytest.raises(AssertionError):
+            theme.validate()
+
+    def test_widget_uses_theme_colours(self):
+        theme = pygame_menu.themes.THEME_DEFAULT.copy()
+        theme.widget_validation_error_color = (123, 45, 67, 255)
+        theme.widget_validation_error_border_width = 7
+        menu = MenuUtils.generic_menu(theme=theme)
+        ti = menu.add.text_input("X: ")
+        ti.add_validator(Required())
+        ti.set_value("")
+        ti.validate()
+        assert ti._get_validation_error_color() == (123, 45, 67, 255)
+        assert ti._get_validation_error_border_width() == 7
