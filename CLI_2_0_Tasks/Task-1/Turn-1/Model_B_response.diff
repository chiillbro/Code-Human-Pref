+class TestFormValidation:
+    def _build_form(self, pwd_val="hunter2", conf_val="hunter2", email_val="foo@bar.com"):
+        menu = MenuUtils.generic_menu()
+        email = menu.add.text_input("Email: ", textinput_id="email")
+        email.set_value(email_val)
+        email.add_validator(Required())
+        email.add_validator(Email())
+
+        pwd = menu.add.text_input("Password: ", textinput_id="pwd")
+        pwd.set_value(pwd_val)
+        pwd.add_validator(MinLength(4, message="too short"))
+
+        conf = menu.add.text_input("Confirm: ", textinput_id="conf")
+        conf.set_value(conf_val)
+        return menu, email, pwd, conf
+
+    def test_happy_path(self):
+        menu, *_ = self._build_form()
+        menu.add_form_validator(FieldsMatch(["pwd", "conf"]))
+        assert menu.is_form_valid()
+        assert menu.get_form_validation_errors() == []
+
+    def test_password_mismatch_surfaces_form_error(self):
+        menu, _, _, conf = self._build_form(conf_val="different")
+        menu.add_form_validator(
+            FieldsMatch(["pwd", "conf"], message="Passwords do not match")
+        )
+        result = menu.validate_form()
+        assert not result.is_valid
+        assert any(
+            "Passwords do not match" == err.message for err in result.errors
+        )
+        assert menu.get_form_validation_errors(), "form errors should be cached"
+
+    def test_collect_all_returns_widget_and_form_errors(self):
+        menu, email, _, _ = self._build_form(
+            email_val="", pwd_val="x", conf_val="y"
+        )
+        menu.add_form_validator(
+            FieldsMatch(["pwd", "conf"], message="mismatch")
+        )
+        result = menu.validate_form(collect_all=True)
+        # Required + Email (email widget) + MinLength (pwd) + mismatch
+        assert len(result.errors) >= 4
+
+    def test_stop_at_first_failure(self):
+        menu, email, _, _ = self._build_form(email_val="")
+        menu.add_form_validator(FieldsMatch(["pwd", "conf"]))
+        result = menu.validate_form(collect_all=False)
+        assert len(result.errors) == 1
+
+    def test_custom_cross_validator(self):
+        menu, *_ = self._build_form()
+        # total length of all fields must be > 10
+        v = CustomCrossValidator(
+            ["email", "pwd", "conf"],
+            func=lambda values: sum(len(str(v)) for v in values) > 10,
+            message="sum too short",
+        )
+        menu.add_form_validator(v)
+        assert menu.is_form_valid()
+
+    def test_cross_validator_with_missing_widget_passes(self):
+        menu, *_ = self._build_form()
+        # 'ghost' does not exist — validator should be a no-op.
+        menu.add_form_validator(FieldsMatch(["pwd", "ghost"]))
+        assert menu.is_form_valid()
+
+    def test_cross_validator_widget_reference(self):
+        menu, _, pwd, conf = self._build_form()
+        menu.add_form_validator(FieldsMatch([pwd, conf]))
+        assert menu.is_form_valid()
+
+    def test_add_form_validator_type_checked(self):
+        menu = MenuUtils.generic_menu()
+        with pytest.raises(TypeError):
+            menu.add_form_validator(Required())
+
+    def test_remove_unknown_form_validator(self):
+        menu = MenuUtils.generic_menu()
+        with pytest.raises(ValueError):
+            menu.remove_form_validator(FieldsMatch(["a", "b"]))
+
+    def test_clear_form_validators(self):
+        menu, *_ = self._build_form()
+        menu.add_form_validator(FieldsMatch(["pwd", "conf"]))
+        menu.validate_form()
+        menu.clear_form_validators()
+        assert menu.get_form_validators() == []
+        assert menu.get_form_validation_errors() == []
+
+    def test_clear_validation_errors_clears_widgets(self):
+        menu, email, _, _ = self._build_form(email_val="")
+        menu.validate_form(collect_all=True)
+        assert email.has_validation_error()
+        menu.clear_validation_errors()
+        assert not email.has_validation_error()
+
+    def test_widget_level_cross_validator(self):
+        menu, _, pwd, conf = self._build_form(conf_val="different")
+        conf.add_validator(FieldsMatch([pwd, conf], message="mismatch"))
+        result = conf.validate(collect_all=True)
+        assert not result.is_valid
+        assert result.messages == ["mismatch"]
