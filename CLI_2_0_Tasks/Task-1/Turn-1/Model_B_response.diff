+        color = self._get_validation_error_color()
+        if color is None:
+            return
+        rect = self.get_rect(
+            inflate=(
+                self._border_inflate[0] + self._background_inflate[0],
+                self._border_inflate[1] + self._background_inflate[1],
+            )
+        )
+        bg = self._get_validation_error_background_color()
+        if bg is not None:
+            bg_surface = make_surface(rect.width, rect.height, alpha=True)
+            bg_surface.fill(bg, bg_surface.get_rect())
+            surface.blit(bg_surface, rect)
+        pygame.draw.rect(surface, color, rect, border_width)
