@@ -0,0 +1,506 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST VALIDATORS
+Exercises the form validation framework: per-validator logic, widget-level
+API (add/remove/validate/is_valid), menu-level form validation, cross-widget
+validators, and theme-backed visual feedback.
+"""
+
+from __future__ import annotations
+
+import re
+
+import pytest
+
+import pygame_menu
+from pygame_menu.validators import (
+    CrossWidgetValidator,
+    Custom,
+    CustomCrossValidator,
+    Email,
+    FieldsMatch,
+    MaxLength,
+    MinLength,
+    Numeric,
+    Pattern,
+    Range,
+    Required,
+    ValidationError,
+    ValidationResult,
+    Validator,
+)
+from test._utils import MenuUtils, surface
+
+
+# ---------------------------------------------------------------------------
+# Individual validators
+# ---------------------------------------------------------------------------
+
+
+class TestRequired:
+    def test_rejects_empty_values(self):
+        r = Required()
+        assert r.validate("hello") is True
+        assert r.validate("") is False
+        assert r.validate("   ") is False
+        assert r.validate(None) is False
+        assert r.validate([]) is False
+        assert r.validate(["a"]) is True
+        assert r.validate(0) is True  # zero is considered present
+
+    def test_default_and_custom_message(self):
+        assert Required().get_message() == "This field is required"
+        assert Required("custom").get_message() == "custom"
+
+
+class TestMinMaxLength:
+    def test_min_length_boundary(self):
+        ml = MinLength(3)
+        assert ml.validate("abc") is True
+        assert ml.validate("ab") is False
+        assert ml.validate(None) is False
+        assert ml.validate(123) is True  # str(123) == '123'
+
+    def test_max_length_boundary(self):
+        maxl = MaxLength(4)
+        assert maxl.validate("abcd") is True
+        assert maxl.validate("abcde") is False
+        assert maxl.validate(None) is True
+
+    def test_rejects_invalid_arguments(self):
+        with pytest.raises(TypeError):
+            MinLength("3")
+        with pytest.raises(ValueError):
+            MinLength(-1)
+        with pytest.raises(TypeError):
+            MaxLength(3.0)
+        with pytest.raises(ValueError):
+            MaxLength(-1)
+
+
+class TestPattern:
+    def test_full_match_by_default(self):
+        p = Pattern(r"\d{3}")
+        assert p.validate("123") is True
+        assert p.validate("1234") is False  # fullmatch
+        assert p.validate("abc") is False
+        assert p.validate(None) is False
+
+    def test_search_mode(self):
+        p = Pattern(r"\d+", full_match=False)
+        assert p.validate("abc123") is True
+        assert p.validate("abc") is False
+
+    def test_accepts_compiled_pattern(self):
+        p = Pattern(re.compile(r"[A-Z]+"))
+        assert p.validate("ABC") is True
+        assert p.validate("abc") is False
+
+
+class TestEmail:
+    @pytest.mark.parametrize(
+        "value,expected",
+        [
+            ("foo@bar.com", True),
+            ("foo.bar@baz.co.uk", True),
+            ("foo@bar", False),
+            ("foo@.com", False),  # domain cannot start with a dot
+            ("foo@@bar.com", False),
+            ("", False),
+            (None, False),
+        ],
+    )
+    def test_accepts_common_forms(self, value, expected):
+        assert Email().validate(value) is expected
+
+    def test_custom_message(self):
+        assert Email(message="nope").get_message() == "nope"
+
+
+class TestNumeric:
+    def test_floats_by_default(self):
+        n = Numeric()
+        assert n.validate(1) is True
+        assert n.validate("1.5") is True
+        assert n.validate("abc") is False
+        assert n.validate(None) is False
+        assert n.validate(True) is False  # booleans are not numbers
+
+    def test_integer_only(self):
+        n = Numeric(integer_only=True)
+        assert n.validate("42") is True
+        assert n.validate("42.5") is False
+        assert n.validate(42) is True
+
+    def test_allow_negative_false(self):
+        n = Numeric(allow_negative=False)
+        assert n.validate(0) is True
+        assert n.validate(-1) is False
+
+
+class TestRange:
+    def test_bounds(self):
+        r = Range(min_value=0, max_value=10)
+        assert r.validate(0) is True
+        assert r.validate(10) is True
+        assert r.validate(-1) is False
+        assert r.validate(11) is False
+
+    def test_only_min(self):
+        r = Range(min_value=5)
+        assert r.validate(100) is True
+        assert r.validate(4) is False
+
+    def test_only_max(self):
+        r = Range(max_value=5)
+        assert r.validate(-100) is True
+        assert r.validate(6) is False
+
+    def test_invalid_bounds(self):
+        with pytest.raises(ValueError):
+            Range()
+        with pytest.raises(ValueError):
+            Range(min_value=10, max_value=5)
+
+
+class TestCustom:
+    def test_wraps_callable(self):
+        c = Custom(lambda v: v == "secret", message="must be secret", name="IsSecret")
+        assert c.name == "IsSecret"
+        assert c.validate("secret") is True
+        assert c.validate("other") is False
+        assert c.get_message() == "must be secret"
+
+    def test_rejects_non_callable(self):
+        with pytest.raises(TypeError):
+            Custom("not callable")
+
+    def test_exception_treated_as_failure(self):
+        def raises(v):
+            raise RuntimeError("boom")
+
+        c = Custom(raises)
+        result = c("anything")
+        assert not result.is_valid
+
+
+# ---------------------------------------------------------------------------
+# ValidationResult / ValidationError
+# ---------------------------------------------------------------------------
+
+
+class TestValidationResult:
+    def test_valid_result_is_truthy(self):
+        r = ValidationResult()
+        assert r.is_valid
+        assert bool(r) is True
+        assert len(r) == 0
+
+    def test_invalid_result_is_falsy(self):
+        r = ValidationResult([ValidationError("nope")])
+        assert not r.is_valid
+        assert bool(r) is False
+        assert len(r) == 1
+        assert r.messages == ["nope"]
+
+    def test_add_requires_validation_error(self):
+        r = ValidationResult()
+        with pytest.raises(TypeError):
+            r.add("plain string")
+
+    def test_iter(self):
+        errs = [ValidationError("a"), ValidationError("b")]
+        r = ValidationResult(errs)
+        assert list(r) == errs
+
+
+# ---------------------------------------------------------------------------
+# Widget-level validation API
+# ---------------------------------------------------------------------------
+
+
+class TestWidgetValidationAPI:
+    def _text_input(self, value: str = "") -> pygame_menu.widgets.Widget:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input("Name: ", textinput_id="name")
+        ti.set_value(value)
+        return ti
+
+    def test_add_and_get_validators(self):
+        ti = self._text_input()
+        required = Required()
+        ti.add_validator(required)
+        assert ti.get_validators() == [required]
+
+    def test_remove_unknown_raises(self):
+        ti = self._text_input()
+        with pytest.raises(ValueError):
+            ti.remove_validator(Required())
+
+    def test_add_validator_rejects_wrong_type(self):
+        ti = self._text_input()
+        with pytest.raises(TypeError):
+            ti.add_validator("not-a-validator")
+
+    def test_clear_validators_also_clears_errors(self):
+        ti = self._text_input("")
+        ti.add_validator(Required())
+        ti.validate()
+        assert ti.has_validation_error()
+        ti.clear_validators()
+        assert ti.get_validators() == []
+        assert not ti.has_validation_error()
+
+    def test_validate_stops_on_first_failure_by_default(self):
+        ti = self._text_input("")
+        ti.add_validator(Required(message="first"))
+        ti.add_validator(MinLength(10, message="second"))
+        result = ti.validate()
+        assert not result.is_valid
+        assert len(result.errors) == 1
+        assert result.messages == ["first"]
+
+    def test_validate_collect_all_aggregates(self):
+        ti = self._text_input("")
+        ti.add_validator(Required(message="first"))
+        ti.add_validator(MinLength(10, message="second"))
+        result = ti.validate(collect_all=True)
+        assert not result.is_valid
+        assert result.messages == ["first", "second"]
+
+    def test_is_valid_clears_when_happy(self):
+        ti = self._text_input("happy-path")
+        ti.add_validator(Required())
+        ti.add_validator(MinLength(3))
+        assert ti.is_valid()
+        assert not ti.has_validation_error()
+
+    def test_manual_set_validation_error(self):
+        ti = self._text_input("foo@bar.com")
+        ti.set_validation_error("Backend said no")
+        assert ti.has_validation_error()
+        assert ti.get_validation_messages() == ["Backend said no"]
+        ti.clear_validation_errors()
+        assert not ti.has_validation_error()
+
+    def test_set_validation_error_requires_non_empty(self):
+        ti = self._text_input()
+        with pytest.raises(ValueError):
+            ti.set_validation_error("")
