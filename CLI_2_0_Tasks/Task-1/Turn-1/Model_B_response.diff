+    # ------------------------------------------------------------------
+    # Validation API
+    # ------------------------------------------------------------------
+
+    def add_validator(
+        self, validator: Validator | CrossWidgetValidator
+    ) -> Widget:
+        """
+        Attach a validator to the widget.
+
+        Validators are evaluated in the order they are added. By default
+        :py:meth:`validate` short-circuits on the first failure; pass
+        ``collect_all=True`` to aggregate every error.
+
+        :param validator: :py:class:`pygame_menu.validators.Validator` or :py:class:`pygame_menu.validators.CrossWidgetValidator`
+        :return: Self reference
+        """
+        if not isinstance(validator, (Validator, CrossWidgetValidator)):
+            raise TypeError(
+                "validator must be a Validator or CrossWidgetValidator instance"
+            )
+        self._validators.append(validator)
+        return self
+
+    def remove_validator(
+        self, validator: Validator | CrossWidgetValidator
+    ) -> Widget:
+        """
+        Remove a previously added validator.
+
+        :param validator: Validator instance to remove
+        :return: Self reference
+        """
+        try:
+            self._validators.remove(validator)
+        except ValueError:
+            raise ValueError("validator is not attached to this widget")
+        return self
+
+    def clear_validators(self) -> Widget:
+        """
+        Detach every validator and clear any pending error state.
+
+        :return: Self reference
+        """
+        self._validators = []
+        if self._validation_errors:
+            self.clear_validation_errors()
+        return self
+
+    def get_validators(self) -> list[Validator | CrossWidgetValidator]:
+        """
+        Return a shallow copy of the validator list.
+
+        :return: List of validators (order preserved)
+        """
+        return list(self._validators)
+
+    def validate(self, collect_all: bool = False) -> ValidationResult:
+        """
+        Run each attached validator against the current widget value.
+
+        On completion the internal error list is updated, the widget is
+        re-rendered and the aggregated :py:class:`ValidationResult` is
+        returned.
+
+        :param collect_all: If ``True`` every validator is executed and all errors collected; otherwise the first failing validator stops the run
+        :return: Aggregated validation result
+        """
+        try:
+            value = self.get_value()
+        except ValueError:
+            value = None
+        result = ValidationResult()
+        for validator in self._validators:
+            if isinstance(validator, CrossWidgetValidator):
+                sub_result = validator(menu=self._menu, widget=self)
+            else:
+                sub_result = validator(value, widget=self)
+            if not sub_result.is_valid:
+                result.extend(sub_result.errors)
+                if not collect_all:
+                    break
+        self._validation_errors = list(result.errors)
+        self._force_render()
+        return result
+
+    def is_valid(self) -> bool:
+        """
+        Quick helper that runs :py:meth:`validate` (collecting every error)
+        and reports whether the widget is in a valid state.
+
+        :return: ``True`` if no validator failed
+        """
+        return self.validate(collect_all=True).is_valid
+
+    def has_validation_error(self) -> bool:
+        """
+        Return ``True`` when the last :py:meth:`validate` call left at least
+        one error on the widget.
+        """
+        return len(self._validation_errors) > 0
+
+    def get_validation_errors(self) -> list[ValidationError]:
+        """
+        Return a shallow copy of the currently-displayed validation errors.
+        """
+        return list(self._validation_errors)
+
+    def get_validation_messages(self) -> list[str]:
+        """
+        Return the human-readable messages for the currently-displayed errors.
+        """
+        return [e.message for e in self._validation_errors]
+
+    def clear_validation_errors(self) -> Widget:
+        """
+        Clear any stored validation error and force the widget to redraw.
+
+        :return: Self reference
+        """
+        if not self._validation_errors:
+            return self
+        self._validation_errors = []
+        self._force_render()
+        return self
+
+    def set_validation_error(
+        self, message: str, validator_name: str = "external"
+    ) -> Widget:
+        """
+        Manually flag the widget as invalid with a specific message.
+
+        Useful for server-side or asynchronous validation that does not map
+        to a :py:class:`Validator` subclass.
+
+        :param message: Error message to display
+        :param validator_name: Symbolic name of the validator (for introspection)
+        :return: Self reference
+        """
+        if not isinstance(message, str) or not message:
+            raise ValueError("message must be a non-empty string")
+        self._validation_errors.append(
+            ValidationError(
+                message=message,
+                validator_name=validator_name,
+                value=self._get_value_safe(),
+                widget=self,
+            )
+        )
+        self._force_render()
+        return self
+
+    def set_validation_style(
+        self,
+        color: ColorInputType | None = None,
+        border_width: int | None = None,
+        background_color: ColorInputType | None = None,
+    ) -> Widget:
+        """
+        Override the per-widget visual style used while an error is displayed.
+
+        Any parameter left as ``None`` is untouched; set ``border_width=0``
+        to disable the error border entirely for this widget.
+
+        :param color: Error highlight colour (border/outline)
+        :param border_width: Width of the error border in px
+        :param background_color: Optional background colour to apply while invalid
+        :return: Self reference
+        """
+        if color is not None:
+            self._validation_error_color = assert_color(color)
+        if border_width is not None:
+            if not isinstance(border_width, int) or border_width < 0:
+                raise ValueError("border_width must be a non-negative integer")
+            self._validation_error_border_width = border_width
+        if background_color is not None:
+            self._validation_error_background_color = assert_color(background_color)
+        self._force_render()
+        return self
+
+    def _get_value_safe(self) -> Any:
+        """Return the widget value, swallowing widgets that don't expose one."""
+        try:
+            return self.get_value()
+        except ValueError:
+            return None
+
+    def _get_validation_error_color(self) -> ColorType | None:
+        """
+        Resolve the active error colour, preferring the widget override and
+        falling back to the theme default when available.
+        """
+        if self._validation_error_color is not None:
+            return self._validation_error_color
+        if (
+            self._menu is not None
+            and getattr(self._menu, "_theme", None) is not None
+            and getattr(
+                self._menu._theme, "widget_validation_error_color", None
+            )
+            is not None
+        ):
+            return self._menu._theme.widget_validation_error_color
+        return (200, 0, 0)
+
+    def _get_validation_error_border_width(self) -> int:
+        """Resolve the active error border width."""
+        if self._validation_error_border_width:
+            return self._validation_error_border_width
+        if self._menu is not None and getattr(self._menu, "_theme", None) is not None:
+            width = getattr(
+                self._menu._theme, "widget_validation_error_border_width", None
+            )
+            if width:
+                return int(width)
+        return 2
+
+    def _get_validation_error_background_color(self) -> ColorType | None:
+        """Resolve the optional error background colour."""
+        if self._validation_error_background_color is not None:
+            return self._validation_error_background_color
+        if self._menu is not None and getattr(self._menu, "_theme", None) is not None:
+            return getattr(
+                self._menu._theme, "widget_validation_error_background_color", None
+            )
+        return None
+
+    def _draw_validation_error(self, surface: pygame.Surface) -> None:
+        """
+        Draw a coloured outline (and optional background tint) on top of the
+        widget to signal the validation error.
+
+        Called from :py:meth:`draw` after the normal border has been drawn.
+        """
+        if not self._validation_errors:
