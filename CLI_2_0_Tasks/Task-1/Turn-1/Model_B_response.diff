diff --git a/pygame_menu/validators.py b/pygame_menu/validators.py
new file mode 100644
index 00000000..f8b7adbf
--- /dev/null
+++ b/pygame_menu/validators.py
@@ -0,0 +1,622 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+VALIDATORS
+Form validation classes for widgets. Each validator runs against a widget
+value and reports whether the value meets a given constraint.
+
+Validators can be stacked on a single widget. By default they short-circuit
+on the first failure, but widget/menu validation can also be asked to collect
+every error.
+
+Cross-widget validators operate over two or more widgets (referenced by id or
+by direct reference), enabling checks such as "confirm password equals
+password".
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    # Data classes
+    "ValidationError",
+    "ValidationResult",
+    # Single-value validators
+    "Validator",
+    "Custom",
+    "Email",
+    "MaxLength",
+    "MinLength",
+    "Numeric",
+    "Pattern",
+    "Range",
+    "Required",
+    # Cross-widget validators
+    "CrossWidgetValidator",
+    "FieldsMatch",
+    "CustomCrossValidator",
+]
+
+import re
+from typing import TYPE_CHECKING, Any, Callable, Iterable
+
+if TYPE_CHECKING:
+    import pygame_menu
+
+
+class ValidationError:
+    """
+    Represents a single validation failure.
+
+    :param message: Human-readable error description
+    :param validator_name: Name of the validator that produced the error
+    :param value: The value that triggered the failure (may be ``None``)
+    :param widget: The widget that owns the error (may be ``None`` for cross-widget validators)
+    """
+
+    def __init__(
+        self,
+        message: str,
+        validator_name: str = "",
+        value: Any = None,
+        widget: "pygame_menu.widgets.Widget | None" = None,
+    ) -> None:
+        self.message = str(message)
+        self.validator_name = str(validator_name)
+        self.value = value
+        self.widget = widget
+
+    def __repr__(self) -> str:
+        name = self.validator_name or "ValidationError"
+        return f"<{name}: {self.message}>"
+
+    def __str__(self) -> str:
+        return self.message
+
+
+class ValidationResult:
+    """
+    Aggregates the result of one or more validator invocations.
+
+    A result is considered valid when there are no errors. The object is
+    truthy when valid; this lets callers write ``if result:``.
+
+    :param errors: Initial list of errors
+    """
+
+    def __init__(self, errors: Iterable[ValidationError] | None = None) -> None:
+        self.errors: list[ValidationError] = list(errors) if errors else []
+
+    @property
+    def is_valid(self) -> bool:
+        """Return True when no errors were recorded."""
+        return len(self.errors) == 0
+
+    @property
+    def messages(self) -> list[str]:
+        """Return the list of human-readable messages."""
+        return [e.message for e in self.errors]
+
+    def add(self, error: ValidationError) -> "ValidationResult":
+        """Append an error to the result and return self."""
+        if not isinstance(error, ValidationError):
+            raise TypeError("error must be a ValidationError instance")
+        self.errors.append(error)
+        return self
+
+    def extend(self, errors: Iterable[ValidationError]) -> "ValidationResult":
+        """Append multiple errors to the result."""
+        for e in errors:
+            self.add(e)
+        return self
+
+    def __bool__(self) -> bool:
+        return self.is_valid
+
+    def __len__(self) -> int:
+        return len(self.errors)
+
+    def __iter__(self):
+        return iter(self.errors)
+
+    def __repr__(self) -> str:
+        if self.is_valid:
+            return "<ValidationResult: valid>"
+        return f"<ValidationResult: {len(self.errors)} error(s): {self.messages}>"
+
+
+class Validator:
+    """
+    Base class for single-value validators.
+
+    Subclasses must override :py:meth:`validate`, returning ``True`` when the
+    value is acceptable. The base class turns a ``False`` result into a
+    :py:class:`ValidationError` with either the custom message or the default
+    message exposed via :py:meth:`default_message`.
+
+    :param message: Optional custom error message. If ``None`` the subclass default is used
+    """
+
+    def __init__(self, message: str | None = None) -> None:
+        if message is not None and not isinstance(message, str):
+            raise TypeError("message must be a string or None")
+        self._custom_message = message
+
+    @property
+    def name(self) -> str:
+        """Return a short name for the validator (defaults to the class name)."""
+        return type(self).__name__
+
+    def default_message(self) -> str:
+        """Return the default error message for this validator."""
+        return "Invalid value"
+
+    def get_message(self) -> str:
+        """Return the active error message (custom if provided, default otherwise)."""
+        return self._custom_message if self._custom_message else self.default_message()
+
+    def validate(self, value: Any) -> bool:
+        """
+        Return True if ``value`` passes the constraint.
+
+        :param value: Value to check
+        """
+        raise NotImplementedError("override is mandatory")
+
+    def __call__(
+        self,
+        value: Any,
+        widget: "pygame_menu.widgets.Widget | None" = None,
+    ) -> ValidationResult:
+        """Run the validator and return a :py:class:`ValidationResult`."""
+        result = ValidationResult()
+        try:
+            ok = bool(self.validate(value))
+        except Exception:
+            # A validator raising is treated as a validation failure.
+            ok = False
+        if not ok:
+            result.add(
+                ValidationError(
+                    message=self.get_message(),
+                    validator_name=self.name,
+                    value=value,
+                    widget=widget,
+                )
+            )
+        return result
+
+
+class Required(Validator):
+    """Ensure a value is present and non-empty (after stripping whitespace)."""
+
+    def default_message(self) -> str:
+        return "This field is required"
+
+    def validate(self, value: Any) -> bool:
+        if value is None:
+            return False
+        if isinstance(value, str):
+            return value.strip() != ""
+        if isinstance(value, (list, tuple, dict, set)):
+            return len(value) > 0
+        return True
+
+
+class MinLength(Validator):
+    """
+    Ensure the string representation of the value has at least ``min_length``
+    characters.
+    """
+
+    def __init__(self, min_length: int, message: str | None = None) -> None:
+        super().__init__(message)
+        if not isinstance(min_length, int):
+            raise TypeError("min_length must be an integer")
+        if min_length < 0:
+            raise ValueError("min_length cannot be negative")
+        self.min_length = min_length
+
+    def default_message(self) -> str:
+        return f"Must be at least {self.min_length} characters long"
+
+    def validate(self, value: Any) -> bool:
+        if value is None:
+            return self.min_length == 0
+        return len(str(value)) >= self.min_length
+
+
+class MaxLength(Validator):
+    """
+    Ensure the string representation of the value has at most ``max_length``
+    characters.
+    """
+
+    def __init__(self, max_length: int, message: str | None = None) -> None:
+        super().__init__(message)
+        if not isinstance(max_length, int):
+            raise TypeError("max_length must be an integer")
+        if max_length < 0:
+            raise ValueError("max_length cannot be negative")
+        self.max_length = max_length
+
+    def default_message(self) -> str:
+        return f"Must be at most {self.max_length} characters long"
+
+    def validate(self, value: Any) -> bool:
+        if value is None:
+            return True
+        return len(str(value)) <= self.max_length
+
+
+class Pattern(Validator):
+    """
+    Ensure the value matches a regular expression.
+
+    :param pattern: Regular expression. Can be a string or a compiled pattern
+    :param message: Custom error message
+    :param flags: Flags passed to ``re.compile`` when ``pattern`` is a string
+    :param full_match: If True (default) use ``re.fullmatch``, otherwise ``re.search``
+    """
+
+    def __init__(
+        self,
+        pattern: str | re.Pattern,
+        message: str | None = None,
+        flags: int = 0,
+        full_match: bool = True,
+    ) -> None:
+        super().__init__(message)
+        if isinstance(pattern, re.Pattern):
+            self._regex = pattern
+        else:
+            self._regex = re.compile(pattern, flags)
+        self._full_match = bool(full_match)
+
+    def default_message(self) -> str:
+        return "Value does not match the required format"
+
+    def validate(self, value: Any) -> bool:
+        if value is None:
+            return False
+        text = str(value)
+        if self._full_match:
+            return self._regex.fullmatch(text) is not None
+        return self._regex.search(text) is not None
+
+
+class Email(Pattern):
+    """
+    Convenience validator that checks simple e-mail syntax.
+
+    This is not a full RFC-5322 parser; it targets the most common mistakes
+    (missing ``@``, missing domain, whitespace, ``.``-less domain).
+    """
+
+    _EMAIL_RE = r"[^@\s]+@[^@\s]+\.[^@\s]+"
+
+    def __init__(self, message: str | None = None) -> None:
+        super().__init__(self._EMAIL_RE, message=message)
+
+    def default_message(self) -> str:
+        return "Invalid e-mail address"
+
+
+class Numeric(Validator):
+    """
+    Ensure the value is a number (or a string that parses to one).
+
+    :param integer_only: When True, only integers are accepted
+    :param allow_negative: When False, the value must be greater than or equal to zero
+    :param message: Custom error message
+    """
+
+    def __init__(
+        self,
+        integer_only: bool = False,
+        allow_negative: bool = True,
+        message: str | None = None,
+    ) -> None:
+        super().__init__(message)
+        self.integer_only = bool(integer_only)
+        self.allow_negative = bool(allow_negative)
+
+    def default_message(self) -> str:
+        if self.integer_only:
+            base = "Must be an integer number"
+        else:
+            base = "Must be a number"
+        if not self.allow_negative:
+            base += " greater than or equal to zero"
+        return base
+
+    def validate(self, value: Any) -> bool:
+        if value is None:
+            return False
+        try:
+            if isinstance(value, bool):
+                return False
+            if self.integer_only:
+                if isinstance(value, int):
+                    number: float = value
+                else:
+                    number = int(str(value))
+            else:
+                if isinstance(value, (int, float)):
+                    number = float(value)
+                else:
+                    number = float(str(value))
+        except (TypeError, ValueError):
+            return False
+        if not self.allow_negative and number < 0:
+            return False
+        return True
+
+
+class Range(Validator):
+    """
+    Ensure a numeric value lies within an inclusive range.
+
+    ``min_value`` and ``max_value`` are both optional so the validator can
+    represent "at least", "at most", or "between" semantics.
+    """
+
+    def __init__(
+        self,
+        min_value: float | int | None = None,
+        max_value: float | int | None = None,
+        message: str | None = None,
+    ) -> None:
+        super().__init__(message)
+        if min_value is None and max_value is None:
+            raise ValueError("at least one of min_value or max_value must be set")
+        if (
+            min_value is not None
+            and max_value is not None
+            and min_value > max_value
+        ):
+            raise ValueError("min_value cannot be greater than max_value")
+        self.min_value = min_value
+        self.max_value = max_value
+
+    def default_message(self) -> str:
+        if self.min_value is not None and self.max_value is not None:
+            return f"Must be between {self.min_value} and {self.max_value}"
+        if self.min_value is not None:
+            return f"Must be greater than or equal to {self.min_value}"
+        return f"Must be less than or equal to {self.max_value}"
+
+    def validate(self, value: Any) -> bool:
+        if value is None:
+            return False
+        try:
+            if isinstance(value, bool):
+                return False
+            if isinstance(value, (int, float)):
+                number: float = float(value)
+            else:
+                number = float(str(value))
+        except (TypeError, ValueError):
+            return False
+        if self.min_value is not None and number < self.min_value:
+            return False
+        if self.max_value is not None and number > self.max_value:
+            return False
+        return True
+
+
+class Custom(Validator):
+    """
+    Wrap an arbitrary predicate as a validator.
+
+    :param func: Callable ``(value) -> bool`` that returns ``True`` when valid
+    :param message: Custom error message
+    :param name: Optional name for the validator (used in errors)
+    """
+
+    def __init__(
+        self,
+        func: Callable[[Any], bool],
+        message: str | None = None,
+        name: str | None = None,
+    ) -> None:
+        super().__init__(message)
+        if not callable(func):
+            raise TypeError("func must be callable")
+        self._func = func
+        self._name = name
+
+    @property
+    def name(self) -> str:
+        return self._name if self._name else super().name
+
+    def default_message(self) -> str:
+        return "Invalid value"
+
+    def validate(self, value: Any) -> bool:
+        return bool(self._func(value))
+
+
+# ---------------------------------------------------------------------------
+# Cross-widget validators
+# ---------------------------------------------------------------------------
+
+
+class CrossWidgetValidator:
+    """
+    Base class for validators that compare two or more widgets.
+
+    A cross-widget validator is typically attached either to a widget (so it
+    runs whenever that widget is validated) or to the containing menu as a
+    form-level rule. Either way, the validator resolves each referenced
+    widget by id or by direct reference, then inspects their values to decide
+    if the constraint holds.
+
+    Subclasses must override :py:meth:`validate` and return ``True`` when the
+    values are acceptable.
+
+    :param widgets: Sequence of widget ids (str) or :py:class:`pygame_menu.widgets.Widget` instances
+    :param message: Optional custom error message
+    """
+
+    def __init__(
+        self,
+        widgets: Iterable[Any],
+        message: str | None = None,
+    ) -> None:
+        widget_refs = list(widgets)
+        if len(widget_refs) < 2:
+            raise ValueError(
+                "a cross-widget validator needs at least two widget references"
+            )
+        for ref in widget_refs:
+            if not isinstance(ref, str) and not hasattr(ref, "get_value"):
+                raise TypeError(
+                    "each widget reference must be a str id or a Widget instance"
+                )
+        if message is not None and not isinstance(message, str):
+            raise TypeError("message must be a string or None")
+        self._widget_refs = widget_refs
+        self._custom_message = message
+
+    @property
+    def name(self) -> str:
+        return type(self).__name__
+
+    @property
+    def widget_refs(self) -> list[Any]:
+        """Return the original widget references (ids or instances)."""
+        return list(self._widget_refs)
+
+    def default_message(self) -> str:
+        return "Cross-widget validation failed"
+
+    def get_message(self) -> str:
+        return self._custom_message if self._custom_message else self.default_message()
+
+    def resolve(
+        self,
+        menu: "pygame_menu.Menu | None" = None,
+        widget: "pygame_menu.widgets.Widget | None" = None,
+    ) -> list["pygame_menu.widgets.Widget | None"]:
+        """
+        Resolve the stored widget references into widget objects.
+
+        If a reference is a string id, the menu (or widget's menu) is used to
+        look it up. Unknown references resolve to ``None``.
+        """
+        if menu is None and widget is not None:
+            menu = widget.get_menu()
+        resolved: list[Any] = []
+        for ref in self._widget_refs:
+            if isinstance(ref, str):
+                found = None
+                if menu is not None:
+                    found = menu.get_widget(ref, recursive=True)
+                resolved.append(found)
+            else:
+                resolved.append(ref)
+        return resolved
+
+    def _values(self, widgets: list[Any]) -> list[Any]:
+        """Extract ``get_value()`` from each widget, returning ``None`` on failure."""
+        values: list[Any] = []
+        for w in widgets:
+            if w is None:
+                values.append(None)
+                continue
+            try:
+                values.append(w.get_value())
+            except (ValueError, AttributeError):
+                values.append(None)
+        return values
+
+    def validate(self, values: list[Any]) -> bool:
+        """
+        Return True if the list of widget values satisfies the constraint.
+
+        :param values: One value per resolved widget (same order as references)
+        """
+        raise NotImplementedError("override is mandatory")
+
+    def __call__(
+        self,
+        menu: "pygame_menu.Menu | None" = None,
+        widget: "pygame_menu.widgets.Widget | None" = None,
+    ) -> ValidationResult:
+        """
+        Resolve the widgets and run :py:meth:`validate` on their values.
+
+        The returned :py:class:`ValidationResult` attaches the owning widget
+        (if provided) so the error can be rendered on the appropriate widget.
+        """
+        resolved = self.resolve(menu=menu, widget=widget)
+        values = self._values(resolved)
+        # Any missing widget means the validator cannot run; treat as pass so
+        # the user is not spammed with errors when the menu is still being
+        # built up.
+        if any(w is None for w in resolved):
+            return ValidationResult()
+        result = ValidationResult()
+        try:
+            ok = bool(self.validate(values))
+        except Exception:
+            ok = False
+        if not ok:
+            result.add(
+                ValidationError(
+                    message=self.get_message(),
+                    validator_name=self.name,
+                    value=values,
+                    widget=widget,
+                )
+            )
+        return result
+
+
+class FieldsMatch(CrossWidgetValidator):
+    """
+    Ensure all referenced widgets expose the same value.
+
+    Typical use case: password / confirm password.
+    """
+
+    def default_message(self) -> str:
+        return "Fields do not match"
+
+    def validate(self, values: list[Any]) -> bool:
+        if not values:
+            return True
+        first = values[0]
+        return all(v == first for v in values[1:])
+
+
+class CustomCrossValidator(CrossWidgetValidator):
+    """
+    Cross-widget validator that delegates the decision to a user callable.
+
+    :param widgets: Sequence of widget ids or Widget instances
+    :param func: Callable ``(values: list) -> bool`` that returns ``True`` when valid
+    :param message: Optional custom error message
+    :param name: Optional name for the validator (used in errors)
+    """
+
+    def __init__(
+        self,
+        widgets: Iterable[Any],
+        func: Callable[[list[Any]], bool],
+        message: str | None = None,
+        name: str | None = None,
+    ) -> None:
+        super().__init__(widgets, message=message)
+        if not callable(func):
+            raise TypeError("func must be callable")
+        self._func = func
+        self._name = name
+
+    @property
+    def name(self) -> str:
+        return self._name if self._name else super().name
+
+    def validate(self, values: list[Any]) -> bool:
+        return bool(self._func(values))
