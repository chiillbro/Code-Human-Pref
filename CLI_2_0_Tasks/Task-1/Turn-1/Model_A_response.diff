+def test_validation_result_basic() -> None:
+    """Test ValidationResult construction and boolean behavior."""
+    r = ValidationResult()
+    assert r.valid is True
+    assert r.errors == []
+    assert bool(r) is True
+    assert r.first_error is None
+
+    r2 = ValidationResult(valid=False, errors=['bad'])
+    assert r2.valid is False
+    assert r2.errors == ['bad']
+    assert bool(r2) is False
+    assert r2.first_error == 'bad'
+
+
+def test_validation_result_merge() -> None:
+    """Test merging two results."""
+    r1 = ValidationResult(valid=True, errors=[])
+    r2 = ValidationResult(valid=False, errors=['err1', 'err2'])
+    r1.merge(r2)
+    assert r1.valid is False
+    assert r1.errors == ['err1', 'err2']
+
+    r3 = ValidationResult(valid=True)
+    r4 = ValidationResult(valid=True)
+    r3.merge(r4)
+    assert r3.valid is True
+    assert r3.errors == []
+
+
+def test_validation_result_repr() -> None:
+    """Test string representation."""
+    r = ValidationResult(valid=True, errors=[])
+    assert 'True' in repr(r)
+
