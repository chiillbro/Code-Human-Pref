+def test_required() -> None:
+    """Test Required validator."""
+    v = Required()
+    assert v('hello') is True
+    assert v('') is False
+    assert v('   ') is False
+    assert v(None) is False
+    assert v(0) is True  # Non-string truthy check
+    assert v(42) is True
+
+    # DropSelect-style tuple
+    assert v(('item', 0)) is True
+    assert v(('item', -1)) is False
+
