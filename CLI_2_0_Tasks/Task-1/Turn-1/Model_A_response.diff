+    def _draw_validation_border(self, surface: pygame.Surface) -> None:
+        """
+        Draw a red border around the widget when validation errors exist.
+
+        :param surface: Surface to draw on
+        """
+        if not self._validation_show_errors or not self._validation_errors:
+            return
+        color = self._get_validation_error_border_color()
+        rect = self.get_rect(inflate=self._get_background_inflate())
+        pygame.draw.rect(surface, color, rect, 2)
