+                    self._validation_error_font = get_font(self._font_name, font_size)
+                else:
+                    self._validation_error_font = pygame.font.SysFont('', font_size)
+            except Exception:
+                self._validation_error_font = pygame.font.SysFont('', font_size)
+
+        rect = self.get_rect()
+        y_offset = rect.bottom + 2
+        for msg in self._validation_errors:
+            err_surface = self._validation_error_font.render(msg, True, error_color[0:3])
+            surface.blit(err_surface, (rect.x, y_offset))
+            y_offset += err_surface.get_height() + 1
