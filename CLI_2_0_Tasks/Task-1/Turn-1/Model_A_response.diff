+def test_widget_validate_widget_without_get_value() -> None:
+    """Widgets that don't support get_value should still validate."""
+    menu = MenuUtils.generic_menu()
+    label = menu.add.label('Hello')
+    label.add_validator(Required())
+    result = label.validate()
+    # Label raises ValueError from get_value, so value=None, Required fails
+    assert not result.valid
