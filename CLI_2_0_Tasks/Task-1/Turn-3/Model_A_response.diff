+
+
+# =============================================================================
+# Auto validation on blur
+# =============================================================================
+
+
+def _select_and_blur(widget) -> None:
+    """Helper: select a widget then unselect it (triggering blur)."""
+    widget.select(True, update_menu=True)
+    widget.select(False, update_menu=True)
+
+
+def test_widget_validation_on_blur_default_off() -> None:
+    """By default, blur does not trigger validation."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    _select_and_blur(ti)
+
+    # Default is off: blur should NOT have run validate()
+    assert ti.get_validation_errors() == []
+
+
+def test_widget_validation_on_blur_enabled_per_widget() -> None:
+    """Per-widget enable makes blur auto-validate."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.set_validation_on_blur(True)
+
+    _select_and_blur(ti)
+
+    # Blur-validation populated errors without an explicit call to validate()
+    assert ti.get_validation_errors() != []
+
+
+def test_widget_validation_on_blur_passing_clears_errors() -> None:
+    """Blur auto-validate succeeds when value is valid; no errors shown."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name', default='Alice')
+    ti.add_validator(Required())
+    ti.set_validation_on_blur(True)
+
+    _select_and_blur(ti)
+
+    assert ti.get_validation_errors() == []
+
+
+def test_widget_validation_on_blur_disabled_per_widget() -> None:
+    """Per-widget disable overrides menu-level enable."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    # Explicitly opt this widget out
+    ti.set_validation_on_blur(False)
+
+    _select_and_blur(ti)
+
+    assert ti.get_validation_errors() == []
+
+
+def test_menu_validation_on_blur_affects_all_inheriting_widgets() -> None:
+    """Menu-level setting is inherited by widgets with value None."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    ti1 = menu.add.text_input('A: ', textinput_id='a')
+    ti1.add_validator(Required())
+    ti2 = menu.add.text_input('B: ', textinput_id='b')
+    ti2.add_validator(Required())
+
+    _select_and_blur(ti1)
+    _select_and_blur(ti2)
+
+    assert ti1.get_validation_errors() != []
+    assert ti2.get_validation_errors() != []
+
+
+def test_menu_validation_on_blur_default_is_false() -> None:
+    """Menu-level setting defaults to False."""
+    menu = MenuUtils.generic_menu()
+    assert menu.get_validation_on_blur() is False
+
+
+def test_widget_validation_on_blur_default_is_none() -> None:
+    """Widget-level setting defaults to None (inherit)."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    assert ti.get_validation_on_blur() is None
+
+
+def test_widget_validation_on_blur_accepts_none() -> None:
+    """Setting per-widget back to None restores inheritance."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    # Start with explicit False, then reset to None to inherit True
+    ti.set_validation_on_blur(False)
+    assert ti._should_validate_on_blur() is False
+
+    ti.set_validation_on_blur(None)
+    assert ti._should_validate_on_blur() is True
+
+
+def test_widget_validation_on_blur_rejects_bad_value() -> None:
+    """set_validation_on_blur only accepts True/False/None."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    for bad in (1, 0, 'yes', [], {}):
+        try:
+            ti.set_validation_on_blur(bad)  # type: ignore
+            assert False, f'Should have rejected {bad!r}'
+        except AssertionError:
+            pass
+
+
+def test_menu_set_validation_on_blur_rejects_non_bool() -> None:
+    """Menu.set_validation_on_blur rejects non-bool inputs."""
+    menu = MenuUtils.generic_menu()
+    for bad in (None, 1, 0, 'yes'):
+        try:
+            menu.set_validation_on_blur(bad)  # type: ignore
+            assert False, f'Should have rejected {bad!r}'
+        except AssertionError:
+            pass
+
+
+def test_blur_without_validators_is_noop() -> None:
+    """A widget with no validators does not trigger validation on blur."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    # No validators attached
+    _select_and_blur(ti)
+    assert ti.get_validation_errors() == []
+
+
+def test_blur_validation_on_textinput_subclass() -> None:
+    """TextInput._blur must call super()._blur() so validate-on-blur fires.
+
+    This guards against the regression of TextInput._blur not calling
+    super(): if it didn't, the base Widget._blur auto-validation hook
+    would never run for TextInput (the most common form input!).
+    """
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    # Set a TextInput-specific pre-blur state so we can verify the subclass
+    # logic ran AND the base class hook fired.
+    ti._mouse_is_pressed = True
+
+    _select_and_blur(ti)
+
+    # Base class auto-validation hook ran -> errors populated
+    assert ti.get_validation_errors() != []
+    # Subclass's own _blur logic also ran -> mouse press state reset
+    assert ti._mouse_is_pressed is False
+
+
+def test_blur_validation_on_rangeslider_subclass() -> None:
+    """RangeSlider._blur must call super()._blur() so validate-on-blur fires."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    rs = menu.add.range_slider('Range: ', 50, (0, 100), 1)
+    # Reject values >= 50 to force a failure at default
+    rs.add_validator(Custom(lambda v: v < 50, message='Too high'))
+
+    _select_and_blur(rs)
+
+    assert rs.get_validation_errors() == ['Too high']
+    # RangeSlider-specific blur side effect
+    assert rs._selected_mouse is False
+
+
+def test_blur_validation_on_rangeslider_passing() -> None:
+    """Blur-validation on a RangeSlider that passes leaves errors empty."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    rs = menu.add.range_slider('Range: ', 10, (0, 100), 1)
+    rs.add_validator(Custom(lambda v: v < 50, message='Too high'))
+
+    _select_and_blur(rs)
+
+    assert rs.get_validation_errors() == []
+
+
+def test_blur_widget_without_menu() -> None:
+    """Widget blur without an attached menu must not crash.
+
+    _should_validate_on_blur falls back to False when there is no menu,
+    so even with validators attached, blur must not auto-validate.
+    """
+    from pygame_menu.widgets import Label
+    label = Label('x')
+    # At construction, the widget is not attached to any menu
+    assert label._menu is None
+    label.add_validator(Required())
+    # Must not raise
+    label._blur()
+    # No auto-validation because no menu and no explicit per-widget setting
+    assert label.get_validation_errors() == []
+
+
+def test_blur_widget_without_menu_respects_explicit_setting() -> None:
+    """A detached widget with explicit True still auto-validates on blur."""
+    from pygame_menu.widgets import Label
+    label = Label('x')
+    label.add_validator(Required())
+    label.set_validation_on_blur(True)
+    # Label.get_value() raises ValueError, so Required sees None and fails
+    label._blur()
+    assert label.get_validation_errors() != []
+
+
+def test_blur_validation_updates_visual_state() -> None:
+    """When blur triggers failing validation, error footprint grows."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    assert ti.get_validation_footprint_height() == 0
+
+    _select_and_blur(ti)
+
+    assert ti.get_validation_footprint_height() > 0
+
+
+def test_explicit_per_widget_overrides_menu_setting() -> None:
+    """Explicit per-widget True overrides menu-level False."""
+    menu = MenuUtils.generic_menu()
+    # Menu default is False, widget explicitly True
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.set_validation_on_blur(True)
+
+    assert menu.get_validation_on_blur() is False
+    assert ti._should_validate_on_blur() is True
+
+    _select_and_blur(ti)
+    assert ti.get_validation_errors() != []
