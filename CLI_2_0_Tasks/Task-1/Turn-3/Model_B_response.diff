+def test_selector_blur_validates() -> None:
+    """Selector uses base Widget._blur, so auto-validation should work."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    sel = menu.add.selector(
+        'Diff: ', [('Easy', 1), ('Hard', 2)],
+    )
+    sel.add_validator(
+        Custom(lambda v: v[1] == 2, message='Must choose Hard')
+    )
+
+    sel.select(True)
+    sel.select(False)
+
+    # Default is index 0 (Easy), so validation fails
+    assert sel.get_validation_errors() != []
+
