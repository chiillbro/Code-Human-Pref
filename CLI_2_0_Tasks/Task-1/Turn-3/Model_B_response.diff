+def test_rangeslider_blur_calls_super_and_validates() -> None:
+    """RangeSlider._blur must call super()._blur() so auto-validation fires,
+    and must still execute its own cleanup (_selected_mouse reset)."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    rs = menu.add.range_slider(
+        'Rating', default=0, range_values=(0, 10), increment=1
+    )
+    rs.add_validator(Custom(lambda v: v >= 5, message='Must be >= 5'))
+
+    rs.select(True)
+    rs.select(False)
+
+    # Validation must have fired
+    assert rs.get_validation_errors() != []
+    assert 'Must be >= 5' in rs.get_validation_errors()
+
+    # RangeSlider cleanup must have run
+    assert rs._selected_mouse is False
+
