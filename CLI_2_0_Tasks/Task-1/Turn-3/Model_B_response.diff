+# =============================================================================
+# Validate on blur
+# =============================================================================
+
+
+def test_widget_blur_no_auto_validation_by_default() -> None:
+    """By default widgets do NOT auto-validate on blur."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    # Select then deselect (blur) the widget
+    ti.select(True)
+    ti.select(False)
+
+    # No validation should have fired
+    assert ti.get_validation_errors() == []
+
+
+def test_widget_blur_auto_validates_when_per_widget_enabled() -> None:
+    """Per-widget validation_on_blur=True triggers validate() on blur."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.set_validation_on_blur(True)
+
+    ti.select(True)
+    ti.select(False)  # blur
+
+    assert ti.get_validation_errors() != []
+    assert 'required' in ti.get_validation_errors()[0].lower()
+
+
+def test_widget_blur_auto_validates_when_menu_level_enabled() -> None:
+    """Menu-level validation_on_blur=True is inherited by widgets."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    ti.select(True)
+    ti.select(False)  # blur
+
+    assert ti.get_validation_errors() != []
+
+
+def test_widget_per_widget_overrides_menu_level() -> None:
+    """Per-widget setting overrides the menu default in both directions."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    # Widget explicitly disables
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.set_validation_on_blur(False)
+
+    ti.select(True)
+    ti.select(False)
+    assert ti.get_validation_errors() == []
+
+    # Menu has it off, widget explicitly enables
+    menu2 = MenuUtils.generic_menu()
+    ti2 = menu2.add.text_input('Name2: ', textinput_id='name2')
+    ti2.add_validator(Required())
+    ti2.set_validation_on_blur(True)
+
+    ti2.select(True)
+    ti2.select(False)
+    assert ti2.get_validation_errors() != []
+
+
+def test_widget_blur_no_validators_no_error() -> None:
