+# =============================================================================
+# Multiple widgets blur sequence
+# =============================================================================
+
+
+def test_blur_sequence_across_widgets() -> None:
+    """Selecting a new widget blurs the previous one, triggering validation."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    w1 = menu.add.text_input('First: ', textinput_id='w1')
+    w1.add_validator(Required())
+    w2 = menu.add.text_input('Second: ', textinput_id='w2')
+    w2.add_validator(Required())
+
+    # Select w1, then move to w2 (which blurs w1)
+    w1.select(True)
+    assert w1.get_validation_errors() == []  # no blur yet
+
+    # Blur w1 by selecting w2
+    w1.select(False)
+    w2.select(True)
+
+    # w1 was blurred -> should have errors
+    assert w1.get_validation_errors() != []
+    # w2 hasn't been blurred yet
+    assert w2.get_validation_errors() == []
+
+    # Now blur w2
+    w2.select(False)
+    assert w2.get_validation_errors() != []
+
