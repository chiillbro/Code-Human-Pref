+# =============================================================================
+# TextInput._blur calls super
+# =============================================================================
+
+
+def test_textinput_blur_calls_super_and_validates() -> None:
+    """TextInput._blur must call super()._blur() so auto-validation fires,
+    and must still execute its own cleanup (cursor hidden, text unselected)."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    ti = menu.add.text_input('Email: ', textinput_id='email')
+    ti.add_validator(Email())
+    ti.set_value('not-an-email')
+
+    # Focus then blur
+    ti.select(True)
+    assert ti._cursor_visible is True  # TextInput sets cursor visible on focus
+
+    ti.select(False)  # triggers _blur
+
+    # Validation must have fired (from super()._blur())
+    assert ti.get_validation_errors() != []
+
+    # TextInput cleanup must have run too
+    assert ti._cursor_visible is False
+    assert ti._mouse_is_pressed is False
+
+
+def test_textinput_blur_valid_value() -> None:
