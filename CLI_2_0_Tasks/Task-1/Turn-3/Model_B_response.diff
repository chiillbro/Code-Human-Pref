+def test_widget_blur_valid_value_clears_previous_errors() -> None:
+    """If the value is now valid, on-blur validation clears old errors."""
+    menu = MenuUtils.generic_menu()
+    menu.set_validation_on_blur(True)
+
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    # First blur with empty value
+    ti.select(True)
+    ti.select(False)
+    assert ti.get_validation_errors() != []
+
+    # Set a value and blur again
+    ti.set_value('Alice')
+    ti.select(True)
+    ti.select(False)
+    assert ti.get_validation_errors() == []
+    assert ti.get_validation_footprint_height() == 0
