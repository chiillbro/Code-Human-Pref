+def test_validate_marks_menu_surface_for_update_when_errors_change() -> None:
+    """A state change (errors appear/disappear) must invalidate the menu surface."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    # Reset the flag explicitly so we only observe the effect of validate()
+    menu._widgets_surface_need_update = False
+
+    # First validate() creates errors -> must invalidate
+    ti.validate()
+    assert menu._widgets_surface_need_update is True
+
+    # Reset again
+    menu._widgets_surface_need_update = False
+
+    # Re-validating with the same failure does NOT invalidate (state unchanged)
+    ti.validate()
+    assert menu._widgets_surface_need_update is False
+
+    # Resolving the error invalidates again
+    ti.set_value('Alice')
+    ti.validate()
+    assert menu._widgets_surface_need_update is True
+
