+def test_next_widget_pushed_below_error_label() -> None:
+    """A widget after an erroring one must be positioned below the error text.
+
+    Uses ``center_content=False`` so layout positions are only affected by the
+    per-widget stacking logic, not by whole-menu re-centering.
+    """
+    menu = MenuUtils.generic_menu(center_content=False)
+    first = menu.add.text_input('First: ', textinput_id='first')
+    first.add_validator(Required())
+    second = menu.add.text_input('Second: ', textinput_id='second')
+
+    # Positions without errors
+    menu.render()
+    first_bottom_before = first.get_rect().bottom
+    second_y_before = second.get_rect().y
+    gap_before = second_y_before - first_bottom_before
+
+    # Trigger error, which reserves error footprint below `first`
+    first.validate()
+    menu.render()
+
+    first_bottom_after = first.get_rect().bottom
+    second_y_after = second.get_rect().y
+
+    # first widget body is unchanged (no re-centering when center_content=False)
+    assert first_bottom_before == first_bottom_after
+
+    # second widget moved further down by at least the error footprint height
+    assert second_y_after > second_y_before
+    footprint = first.get_validation_footprint_height()
+    assert (second_y_after - second_y_before) >= footprint
+
+    # The gap between widgets grew by the footprint height
+    gap_after = second_y_after - first_bottom_after
+    assert (gap_after - gap_before) >= footprint
+
+
+def test_error_resolved_reclaims_layout_space() -> None:
+    """When errors are cleared, the layout reclaims the space."""
+    menu = MenuUtils.generic_menu(center_content=False)
+    first = menu.add.text_input('First: ', textinput_id='first')
+    first.add_validator(Required())
+    second = menu.add.text_input('Second: ', textinput_id='second')
+
+    menu.render()
+    baseline_second_y = second.get_rect().y
+
+    # Trigger error -> second pushed down
+    first.validate()
+    menu.render()
+    pushed_y = second.get_rect().y
+    assert pushed_y > baseline_second_y
+
+    # Resolve error by setting a value and revalidating
+    first.set_value('Alice')
+    first.validate()
+    menu.render()
+    resolved_y = second.get_rect().y
+    assert resolved_y == baseline_second_y
+
