+# =============================================================================
+# Email regex strictness
+# =============================================================================
+
+
+def test_email_rejects_leading_hyphen_in_domain() -> None:
+    """Email regex must reject a domain label that starts with '-'."""
+    v = Email()
+    assert v('user@-domain.com') is False
+    assert v('user@foo-.com') is False
+    assert v('a@-.com') is False
+
+
+def test_email_rejects_trailing_hyphen_in_domain() -> None:
+    """Email regex must reject a domain label that ends with '-'."""
+    v = Email()
+    assert v('user@domain-.com') is False
+    assert v('user@foo-.bar-.com') is False
+
+
+def test_email_rejects_consecutive_dots_in_domain() -> None:
+    """Email regex must reject consecutive dots in the domain."""
+    v = Email()
+    assert v('user@a..b.com') is False
+    assert v('user@foo.bar..baz.com') is False
+
+
+def test_email_rejects_consecutive_dots_in_local() -> None:
+    """Email regex must reject consecutive dots in the local part."""
+    v = Email()
+    assert v('a..b@example.com') is False
+
+
+def test_email_rejects_leading_trailing_dots() -> None:
+    """Email regex must reject leading/trailing dots."""
+    v = Email()
+    assert v('.user@example.com') is False
+    assert v('user.@example.com') is False
+    assert v('user@.example.com') is False
+    assert v('user@example.com.') is False
+
+
+def test_email_accepts_valid_with_hyphen_inside_label() -> None:
+    """Hyphens inside a label (not at edges) are allowed."""
+    v = Email()
+    assert v('user@my-domain.com') is True
+    assert v('user@a-b-c.org') is True
+    assert v('user+tag@sub-1.domain.co') is True
+
+
+def test_email_accepts_various_valid_forms() -> None:
+    """Sanity check: common valid emails still pass."""
+    v = Email()
+    assert v('user@example.com') is True
+    assert v('user.name@sub.domain.org') is True
+    assert v('u_s.e+r@example.co.uk') is True
+    assert v('x@y.zz') is True
+
+
+# =============================================================================
+# clear_validators clears visual error state
+# =============================================================================
+
+
+def test_clear_validators_clears_existing_errors() -> None:
+    """clear_validators must also drop stored errors and footprint."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.validate()
+
+    # Error is present and takes up layout footprint
+    assert ti.get_validation_errors() != []
+    assert ti.get_validation_footprint_height() > 0
+
+    ti.clear_validators()
+
+    # Errors gone, footprint reclaimed
+    assert ti.get_validators() == []
+    assert ti.get_validation_errors() == []
+    assert ti.get_validation_footprint_height() == 0
+
+
+def test_clear_validators_triggers_menu_relayout() -> None:
+    """clear_validators must invalidate _widgets_surface_need_update when
+    removing existing errors."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.validate()
+
+    # Reset the flag explicitly so we only observe the effect of clear_validators
+    menu._widgets_surface_need_update = False
+    ti.clear_validators()
+    assert menu._widgets_surface_need_update is True
+
+
+def test_clear_validators_on_widget_without_errors_is_idempotent() -> None:
+    """clear_validators on a widget without errors must not force a relayout."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name', default='John')
+    ti.add_validator(Required())
+    # Don't call validate(), so no errors are set yet
+    assert ti.get_validation_errors() == []
+
+    menu._widgets_surface_need_update = False
+    ti.clear_validators()
+    # No errors to clear, so no layout invalidation needed
+    assert menu._widgets_surface_need_update is False
+
