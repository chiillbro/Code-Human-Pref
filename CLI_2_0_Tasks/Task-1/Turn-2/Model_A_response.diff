+
+# =============================================================================
+# Layout behaviour — error labels affect widget height
+# =============================================================================
+
+
+def test_validation_errors_increase_widget_rect_height() -> None:
+    """Widget rect height must grow to include the error text area."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    rect_before = ti.get_rect()
+    height_before = rect_before.height
+
+    ti.validate()  # fails — empty field
+
+    rect_after = ti.get_rect()
+    height_after = rect_after.height
+    assert height_after > height_before, (
+        f'expected rect height to grow, got {height_before} -> {height_after}'
+    )
+    assert ti._validation_error_height > 0
+
+
+def test_validation_errors_shrink_back_on_clear() -> None:
+    """Widget rect height must shrink back when errors are cleared."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    height_clean = ti.get_rect().height
+
+    ti.validate()  # fails
+    assert ti.get_rect().height > height_clean
+
+    ti.clear_validation_errors()
+    assert ti.get_rect().height == height_clean
+    assert ti._validation_error_height == 0
+
+
+def test_validation_errors_shrink_back_on_valid() -> None:
+    """When a previously-invalid widget becomes valid the height resets."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    height_clean = ti.get_rect().height
+
+    ti.validate()  # fails — empty
+    assert ti.get_rect().height > height_clean
+
+    ti.set_value('John')
+    ti.validate()  # now passes
+    assert ti.get_rect().height == height_clean
+    assert ti._validation_error_height == 0
+
+
+def test_clear_validators_clears_error_state() -> None:
+    """clear_validators() must also remove existing error text/borders."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    ti.validate()  # fails
+    assert len(ti.get_validation_errors()) == 1
+    assert ti._validation_error_height > 0
+
+    ti.clear_validators()
+    assert len(ti.get_validators()) == 0
+    assert len(ti.get_validation_errors()) == 0
+    assert ti._validation_error_height == 0
+
+
+def test_validation_error_height_hidden_when_show_disabled() -> None:
+    """No extra height when _validation_show_errors is False."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.set_validation_show_errors(False)
+
+    height_before = ti.get_rect().height
+    ti.validate()
+    assert ti.get_rect().height == height_before
+    assert ti._validation_error_height == 0
+
+
+def test_multiple_errors_increase_height_more() -> None:
+    """Multiple error lines take more height than a single one."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+    ti.add_validator(MinLength(3))
+
+    # Single error (stop_on_first=True)
+    ti.validate(stop_on_first=True)
+    h_one = ti._validation_error_height
+    assert h_one > 0
+
+    # Two errors (stop_on_first=False)
+    ti.validate(stop_on_first=False)
+    h_two = ti._validation_error_height
+    assert h_two > h_one
+
+
+def test_validation_error_height_updates_menu_surface() -> None:
+    """Verifying that the menu surface is marked for update after validation."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input('Name: ', textinput_id='name')
+    ti.add_validator(Required())
+
+    # Draw once to settle the menu state
+    menu.draw(surface)
+    menu._widgets_surface_need_update = False
+
+    ti.validate()  # triggers _update_validation_error_height -> force_menu_surface_update
+    assert menu._widgets_surface_need_update is True
+
+
+def test_draw_after_validation_no_overlap() -> None:
+    """Draw a menu with two widgets; error text should not crash drawing."""
+    menu = MenuUtils.generic_menu()
+    ti1 = menu.add.text_input('Field 1: ', textinput_id='f1')
+    ti2 = menu.add.text_input('Field 2: ', textinput_id='f2')
+    ti1.add_validator(Required())
+    ti1.validate()
+
+    # Force the menu to recalculate positions
+    menu.render()
+
+    # The second widget should be pushed down
+    r1 = ti1.get_rect()
+    r2 = ti2.get_rect()
+    assert r2.top >= r1.bottom, (
+        f'second widget top ({r2.top}) should be >= first widget bottom ({r1.bottom})'
+    )
