+    def _ensure_validation_error_font(self) -> None:
+        """
+        Lazily create or recreate the font used for validation error text.
+        """
+        font_size = self._get_validation_error_font_size()
+        if (
+            self._validation_error_font is not None
+            and self._validation_error_font.size('A')[1] == font_size
+        ):
+            return
+        try:
+            if self._font_name:
+                from pygame_menu.font import get_font
+                self._validation_error_font = get_font(self._font_name, font_size)
+            else:
+                self._validation_error_font = pygame.font.SysFont('', font_size)
+        except Exception:
+            self._validation_error_font = pygame.font.SysFont('', font_size)
+
+    def _compute_validation_error_height(self) -> int:
+        """
+        Compute the total pixel height that the validation error labels
+        would occupy below the widget content.
+
+        :return: Height in pixels (0 when there are no errors to show)
+        """
+        if not self._validation_show_errors or not self._validation_errors:
+            return 0
+        self._ensure_validation_error_font()
+        gap = 2  # px gap between widget content and first error line
+        line_spacing = 1  # px between consecutive error lines
+        total = gap
+        for msg in self._validation_errors:
+            err_surface = self._validation_error_font.render(msg, True, (0, 0, 0))
+            total += err_surface.get_height() + line_spacing
+        return total
+
+    def _update_validation_error_height(self) -> None:
+        """
+        Recompute the validation error height, update
+        ``_rect_size_delta`` to include it, and invalidate the menu
+        layout so widgets are repositioned.
+        """
+        old_h = self._validation_error_height
+        new_h = self._compute_validation_error_height()
+        if new_h == old_h:
+            return
+        # Adjust _rect_size_delta: remove old contribution, add new one
+        self._rect_size_delta = (
+            self._rect_size_delta[0],
+            self._rect_size_delta[1] - old_h + new_h,
+        )
+        self._validation_error_height = new_h
+        self.force_menu_surface_update()
+
