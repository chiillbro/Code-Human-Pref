@@ -150,11 +150,31 @@ def test_max_value() -> None:
 def test_email() -> None:
     """Test Email validator."""
     v = Email()
+    # Valid addresses
     assert v('user@example.com') is True
     assert v('user@sub.domain.org') is True
+    assert v('first.last@example.com') is True
+    assert v('user+tag@example.com') is True
+    assert v('a@b.co') is True
+    assert v('user@my-domain.com') is True
+
+    # Invalid addresses
     assert v('not-an-email') is False
     assert v('@missing.com') is False
     assert v('missing@') is False
+
+    # Domain edge cases
+    assert v('user@-domain.com') is False  # domain starts with hyphen
+    assert v('user@domain-.com') is False  # domain label ends with hyphen
+    assert v('user@domain..com') is False  # consecutive dots in domain
+    assert v('user@.domain.com') is False  # domain starts with dot
+
+    # Local part edge cases
+    assert v('a..b@example.com') is False  # consecutive dots in local
+    assert v('.user@example.com') is False  # local starts with dot
+    assert v('user.@example.com') is False  # local ends with dot
+
+    # Empty / non-string
     assert v('') is True  # Empty passes (use Required for empty check)
     assert v('   ') is True  # Whitespace only passes
     assert v(42) is True  # Non-string passes
