+package com.piggymetrics.account.client;
+
+import com.piggymetrics.account.domain.Currency;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.math.BigDecimal;
+import java.util.EnumMap;
+import java.util.Map;
+
+@Component
+public class ExchangeRatesServiceClientFallback implements ExchangeRatesServiceClient {
+
+	private static final Logger log = LoggerFactory.getLogger(ExchangeRatesServiceClientFallback.class);
+
+	@Override
+	public Map<Currency, BigDecimal> getRates() {
+		log.warn("using fallback exchange rates — statistics-service is unavailable");
+
+		Map<Currency, BigDecimal> fallbackRates = new EnumMap<>(Currency.class);
+		fallbackRates.put(Currency.USD, BigDecimal.ONE);
+		fallbackRates.put(Currency.EUR, new BigDecimal("0.85"));
+		fallbackRates.put(Currency.RUB, new BigDecimal("75.00"));
+
+		return fallbackRates;
+	}
+}
