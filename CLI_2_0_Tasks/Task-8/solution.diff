diff --git a/account-service/src/main/java/com/piggymetrics/account/service/WalletServiceImpl.java b/account-service/src/main/java/com/piggymetrics/account/service/WalletServiceImpl.java
new file mode 100644
index 0000000..12133b5
--- /dev/null
+++ b/account-service/src/main/java/com/piggymetrics/account/service/WalletServiceImpl.java
@@ -0,0 +1,246 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.client.ExchangeRatesServiceClient;
+import com.piggymetrics.account.domain.*;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.WalletSnapshotRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+
+import java.math.BigDecimal;
+import java.math.RoundingMode;
+import java.time.Instant;
+import java.time.LocalDate;
+import java.time.ZoneId;
+import java.util.*;
+import java.util.stream.Collectors;
+
+@Service
+public class WalletServiceImpl implements WalletService {
+
+	private static final Logger log = LoggerFactory.getLogger(WalletServiceImpl.class);
+
+	/**
+	 * Monthly normalization factors: amount * (MONTHLY_DAYS / period_days) = monthly amount.
+	 * The statistics-service normalizes to DAY base using baseRatio (e.g., MONTH = 30.4368 days).
+	 * We convert to monthly by: monthlyAmount = amount * (MONTHLY_DAYS / periodDays).
+	 */
+	private static final BigDecimal MONTHLY_DAYS = new BigDecimal("30.4368");
+
+	private static final Map<TimePeriod, BigDecimal> PERIOD_TO_DAYS;
+	static {
+		Map<TimePeriod, BigDecimal> m = new EnumMap<>(TimePeriod.class);
+		m.put(TimePeriod.HOUR, new BigDecimal("0.0416"));
+		m.put(TimePeriod.DAY, BigDecimal.ONE);
+		m.put(TimePeriod.MONTH, new BigDecimal("30.4368"));
+		m.put(TimePeriod.QUARTER, new BigDecimal("91.3106"));
+		m.put(TimePeriod.YEAR, new BigDecimal("365.2425"));
+		PERIOD_TO_DAYS = Collections.unmodifiableMap(m);
+	}
+
+	@Autowired
+	private ExchangeRatesServiceClient ratesClient;
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private WalletSnapshotRepository snapshotRepository;
+
+	@Override
+	public Wallet recalculate(Account account) {
+
+		Map<Currency, BigDecimal> rates = ratesClient.getRates();
+
+		Currency baseCurrency = resolveBaseCurrency(account);
+
+		// Group items by currency and compute monthly native balances
+		Map<Currency, BigDecimal> monthlyIncomes = sumMonthlyByCurrency(account.getIncomes());
+		Map<Currency, BigDecimal> monthlyExpenses = sumMonthlyByCurrency(account.getExpenses());
+
+		// Collect all currencies involved
+		Set<Currency> allCurrencies = new HashSet<>();
+		allCurrencies.addAll(monthlyIncomes.keySet());
+		allCurrencies.addAll(monthlyExpenses.keySet());
+		if (account.getSaving() != null && account.getSaving().getCurrency() != null) {
+			allCurrencies.add(account.getSaving().getCurrency());
+		}
+
+		Date now = new Date();
+		BigDecimal totalIncome = BigDecimal.ZERO;
+		BigDecimal totalExpenses = BigDecimal.ZERO;
+		BigDecimal totalBalance = BigDecimal.ZERO;
+		List<CurrencyBalance> balances = new ArrayList<>();
+
+		for (Currency currency : allCurrencies) {
+			BigDecimal income = monthlyIncomes.getOrDefault(currency, BigDecimal.ZERO);
+			BigDecimal expense = monthlyExpenses.getOrDefault(currency, BigDecimal.ZERO);
+			BigDecimal nativeBalance = income.subtract(expense);
+
+			BigDecimal convertedIncome = convert(income, currency, baseCurrency, rates);
+			BigDecimal convertedExpense = convert(expense, currency, baseCurrency, rates);
+			BigDecimal convertedBalance = convert(nativeBalance, currency, baseCurrency, rates);
+
+			totalIncome = totalIncome.add(convertedIncome);
+			totalExpenses = totalExpenses.add(convertedExpense);
+			totalBalance = totalBalance.add(convertedBalance);
+
+			CurrencyBalance cb = new CurrencyBalance();
+			cb.setCurrency(currency);
+			cb.setNativeBalance(nativeBalance.setScale(4, RoundingMode.HALF_UP));
+			cb.setConvertedBalance(convertedBalance.setScale(4, RoundingMode.HALF_UP));
+			cb.setLastUpdated(now);
+			balances.add(cb);
+		}
+
+		// Include saving amount in total balance
+		if (account.getSaving() != null && account.getSaving().getAmount() != null) {
+			BigDecimal savingConverted = convert(
+					account.getSaving().getAmount(),
+					account.getSaving().getCurrency(),
+					baseCurrency,
+					rates);
+			totalBalance = totalBalance.add(savingConverted);
+		}
+
+		// Compute net savings rate: (totalIncome - totalExpenses) / totalIncome * 100
+		BigDecimal netSavingsRate;
+		if (totalIncome.compareTo(BigDecimal.ZERO) == 0) {
+			netSavingsRate = BigDecimal.ZERO;
+		} else {
+			netSavingsRate = totalIncome.subtract(totalExpenses)
+					.divide(totalIncome, 4, RoundingMode.HALF_UP)
+					.multiply(new BigDecimal("100"))
+					.setScale(2, RoundingMode.HALF_UP);
+		}
+
+		Wallet wallet = new Wallet();
+		wallet.setBaseCurrency(baseCurrency);
+		wallet.setBalances(balances);
+		wallet.setTotalBalance(totalBalance.setScale(4, RoundingMode.HALF_UP));
+		wallet.setTotalIncome(totalIncome.setScale(4, RoundingMode.HALF_UP));
+		wallet.setTotalExpenses(totalExpenses.setScale(4, RoundingMode.HALF_UP));
+		wallet.setNetSavingsRate(netSavingsRate);
+
+		account.setWallet(wallet);
+		accountRepository.save(account);
+
+		persistDailySnapshot(account, wallet);
+
+		log.debug("wallet recalculated for account {}", account.getName());
+
+		return wallet;
+	}
+
+	@Override
+	public Wallet changeBaseCurrency(Account account, Currency newBaseCurrency) {
+		if (account.getWallet() == null) {
+			account.setWallet(new Wallet());
+		}
+		account.getWallet().setBaseCurrency(newBaseCurrency);
+		return recalculate(account);
+	}
+
+	@Override
+	public List<WalletSnapshot> getHistory(String accountName, Date from, Date to) {
+		if (from != null && to != null) {
+			return snapshotRepository.findByAccountNameAndSnapshotDateBetweenOrderBySnapshotDateAsc(
+					accountName, from, to);
+		}
+		return snapshotRepository.findByAccountNameOrderBySnapshotDateDesc(accountName);
+	}
+
+	private Currency resolveBaseCurrency(Account account) {
+		if (account.getWallet() != null && account.getWallet().getBaseCurrency() != null) {
+			return account.getWallet().getBaseCurrency();
+		}
+		return Currency.getDefault();
+	}
+
+	private Map<Currency, BigDecimal> sumMonthlyByCurrency(List<Item> items) {
+		if (items == null || items.isEmpty()) {
+			return Collections.emptyMap();
+		}
+		return items.stream()
+				.filter(item -> item.getAmount() != null && item.getCurrency() != null && item.getPeriod() != null)
+				.collect(Collectors.groupingBy(
+						Item::getCurrency,
+						Collectors.reducing(BigDecimal.ZERO,
+								item -> normalizeToMonthly(item.getAmount(), item.getPeriod()),
+								BigDecimal::add)
+				));
+	}
+
+	/**
+	 * Normalizes an item amount to a monthly basis.
+	 * monthlyAmount = amount * (MONTHLY_DAYS / periodDaysBase)
+	 *
+	 * Examples:
+	 * - $12,000/YEAR  → 12000 * (30.4368 / 365.2425) ≈ $999.33/month
+	 * - $50/DAY       → 50 * (30.4368 / 1) = $1,521.84/month
+	 * - $3000/MONTH   → 3000 * (30.4368 / 30.4368) = $3000/month
+	 * - $9000/QUARTER → 9000 * (30.4368 / 91.3106) ≈ $2,999.45/month
+	 */
+	private BigDecimal normalizeToMonthly(BigDecimal amount, TimePeriod period) {
+		BigDecimal periodDays = PERIOD_TO_DAYS.get(period);
+		if (periodDays == null) {
+			return amount;
+		}
+		return amount.multiply(MONTHLY_DAYS).divide(periodDays, 4, RoundingMode.HALF_UP);
+	}
+
+	/**
+	 * Converts amount from one currency to another using the rates map.
+	 * Rates are relative to USD (base): rates[EUR] = 0.85 means 1 USD = 0.85 EUR.
+	 * To convert X EUR to USD: X / rates[EUR] * rates[USD] = X / 0.85
+	 * To convert X USD to EUR: X / rates[USD] * rates[EUR] = X * 0.85
+	 * General: result = amount * (rates[to] / rates[from])
+	 */
+	private BigDecimal convert(BigDecimal amount, Currency from, Currency to, Map<Currency, BigDecimal> rates) {
+		if (from == to || amount.compareTo(BigDecimal.ZERO) == 0) {
+			return amount;
+		}
+
+		BigDecimal fromRate = rates.getOrDefault(from, BigDecimal.ONE);
+		BigDecimal toRate = rates.getOrDefault(to, BigDecimal.ONE);
+
+		return amount.multiply(toRate).divide(fromRate, 4, RoundingMode.HALF_UP);
+	}
+
+	private void persistDailySnapshot(Account account, Wallet wallet) {
+		try {
+			Date today = truncateToDay(new Date());
+
+			WalletSnapshot existing = snapshotRepository.findByAccountNameAndSnapshotDate(
+					account.getName(), today);
+
+			WalletSnapshot snapshot;
+			if (existing != null) {
+				snapshot = existing;
+			} else {
+				snapshot = new WalletSnapshot();
+				snapshot.setAccountName(account.getName());
+				snapshot.setSnapshotDate(today);
+			}
+
+			snapshot.setBaseCurrency(wallet.getBaseCurrency());
+			snapshot.setTotalBalance(wallet.getTotalBalance());
+			snapshot.setTotalIncome(wallet.getTotalIncome());
+			snapshot.setTotalExpenses(wallet.getTotalExpenses());
+			snapshot.setNetSavingsRate(wallet.getNetSavingsRate());
+			snapshot.setBalances(new ArrayList<>(wallet.getBalances()));
+
+			snapshotRepository.save(snapshot);
+		} catch (Exception e) {
+			log.error("failed to persist wallet snapshot for account {}", account.getName(), e);
+		}
+	}
+
+	private Date truncateToDay(Date date) {
+		Instant instant = date.toInstant();
+		LocalDate localDate = instant.atZone(ZoneId.systemDefault()).toLocalDate();
+		return Date.from(localDate.atStartOfDay(ZoneId.systemDefault()).toInstant());
+	}
+}
