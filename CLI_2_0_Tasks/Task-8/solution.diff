+package com.piggymetrics.account.repository;
+
+import com.piggymetrics.account.domain.Currency;
+import com.piggymetrics.account.domain.WalletSnapshot;
+import org.junit.Test;
+import org.junit.runner.RunWith;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.autoconfigure.data.mongo.DataMongoTest;
+import org.springframework.test.context.junit4.SpringRunner;
+
+import java.math.BigDecimal;
+import java.time.LocalDate;
+import java.time.ZoneId;
+import java.util.Date;
+import java.util.List;
+
+import static org.junit.Assert.*;
+
+@RunWith(SpringRunner.class)
+@DataMongoTest
+public class WalletSnapshotRepositoryTest {
+
+	@Autowired
+	private WalletSnapshotRepository repository;
+
+	@Test
+	public void shouldFindSnapshotByAccountNameAndDate() {
+		Date today = truncateToDay(new Date());
+
+		WalletSnapshot snapshot = createSnapshot("test", today);
+		repository.save(snapshot);
+
+		WalletSnapshot found = repository.findByAccountNameAndSnapshotDate("test", today);
+		assertNotNull(found);
+		assertEquals("test", found.getAccountName());
+	}
+
+	@Test
+	public void shouldFindSnapshotsBetweenDates() {
+		Date day1 = toDate(2024, 1, 1);
+		Date day2 = toDate(2024, 1, 15);
+		Date day3 = toDate(2024, 2, 1);
+
+		repository.save(createSnapshot("test", day1));
+		repository.save(createSnapshot("test", day2));
+		repository.save(createSnapshot("test", day3));
+
+		List<WalletSnapshot> results = repository
+				.findByAccountNameAndSnapshotDateBetweenOrderBySnapshotDateAsc(
+						"test", toDate(2024, 1, 1), toDate(2024, 1, 31));
+
+		assertEquals(2, results.size());
+		assertTrue(results.get(0).getSnapshotDate().before(results.get(1).getSnapshotDate())
+				|| results.get(0).getSnapshotDate().equals(results.get(1).getSnapshotDate()));
+	}
+
+	@Test
+	public void shouldOverwriteSnapshotForSameDay() {
+		Date today = truncateToDay(new Date());
+
+		WalletSnapshot first = createSnapshot("overwrite-test", today);
+		first.setTotalBalance(new BigDecimal("1000"));
+		repository.save(first);
+
+		// Simulate overwrite: find existing, update, and save
+		WalletSnapshot existing = repository.findByAccountNameAndSnapshotDate("overwrite-test", today);
+		assertNotNull(existing);
+		existing.setTotalBalance(new BigDecimal("2000"));
+		repository.save(existing);
+
+		WalletSnapshot found = repository.findByAccountNameAndSnapshotDate("overwrite-test", today);
+		assertEquals(0, new BigDecimal("2000").compareTo(found.getTotalBalance()));
+	}
+
+	@Test
+	public void shouldReturnNullWhenNoSnapshotExists() {
+		WalletSnapshot found = repository.findByAccountNameAndSnapshotDate("nonexistent", new Date());
+		assertNull(found);
+	}
+
+	// ========================= helpers =========================
+
+	private WalletSnapshot createSnapshot(String accountName, Date date) {
+		WalletSnapshot snapshot = new WalletSnapshot();
+		snapshot.setAccountName(accountName);
+		snapshot.setSnapshotDate(date);
+		snapshot.setBaseCurrency(Currency.USD);
+		snapshot.setTotalBalance(new BigDecimal("10000"));
+		snapshot.setTotalIncome(new BigDecimal("9100"));
+		snapshot.setTotalExpenses(new BigDecimal("500"));
+		snapshot.setNetSavingsRate(new BigDecimal("94.51"));
+		return snapshot;
+	}
+
+	private Date truncateToDay(Date date) {
+		LocalDate localDate = date.toInstant().atZone(ZoneId.systemDefault()).toLocalDate();
+		return Date.from(localDate.atStartOfDay(ZoneId.systemDefault()).toInstant());
+	}
+
+	private Date toDate(int year, int month, int day) {
+		return Date.from(LocalDate.of(year, month, day)
+				.atStartOfDay(ZoneId.systemDefault()).toInstant());
+	}
+}
