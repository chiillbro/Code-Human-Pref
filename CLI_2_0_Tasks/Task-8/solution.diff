+	private Account createAccountSingleCurrency() {
+		Item salary = new Item();
+		salary.setTitle("Salary");
+		salary.setAmount(new BigDecimal("9100"));
+		salary.setCurrency(Currency.USD);
+		salary.setPeriod(TimePeriod.MONTH);
+		salary.setIcon("wallet");
+
+		Item grocery = new Item();
+		grocery.setTitle("Grocery");
+		grocery.setAmount(new BigDecimal("500"));
+		grocery.setCurrency(Currency.USD);
+		grocery.setPeriod(TimePeriod.MONTH);
+		grocery.setIcon("meal");
+
+		return createAccountWithItems(Collections.singletonList(salary), Collections.singletonList(grocery));
+	}
+
+	private Account createAccountMultiCurrency() {
+		Item salaryUsd = new Item();
+		salaryUsd.setTitle("Salary");
+		salaryUsd.setAmount(new BigDecimal("5000"));
+		salaryUsd.setCurrency(Currency.USD);
+		salaryUsd.setPeriod(TimePeriod.MONTH);
+		salaryUsd.setIcon("wallet");
+
+		Item freelanceEur = new Item();
+		freelanceEur.setTitle("Freelance");
+		freelanceEur.setAmount(new BigDecimal("2000"));
+		freelanceEur.setCurrency(Currency.EUR);
+		freelanceEur.setPeriod(TimePeriod.MONTH);
+		freelanceEur.setIcon("laptop");
+
+		Item rentUsd = new Item();
+		rentUsd.setTitle("Rent");
+		rentUsd.setAmount(new BigDecimal("1500"));
+		rentUsd.setCurrency(Currency.USD);
+		rentUsd.setPeriod(TimePeriod.MONTH);
+		rentUsd.setIcon("home");
+
+		Item subscriptionEur = new Item();
+		subscriptionEur.setTitle("Subscription");
+		subscriptionEur.setAmount(new BigDecimal("50"));
+		subscriptionEur.setCurrency(Currency.EUR);
+		subscriptionEur.setPeriod(TimePeriod.MONTH);
+		subscriptionEur.setIcon("tv");
+
+		return createAccountWithItems(
+				Arrays.asList(salaryUsd, freelanceEur),
+				Arrays.asList(rentUsd, subscriptionEur));
+	}
+
+	private Account createAccountWithItems(List<Item> incomes, List<Item> expenses) {
+		Saving saving = new Saving();
+		saving.setAmount(new BigDecimal("1500"));
+		saving.setCurrency(Currency.USD);
+		saving.setInterest(new BigDecimal("3.32"));
+		saving.setDeposit(true);
+		saving.setCapitalization(false);
+
+		Account account = new Account();
+		account.setName("test");
+		account.setNote("test note");
+		account.setLastSeen(new Date());
+		account.setSaving(saving);
+		account.setIncomes(incomes);
+		account.setExpenses(expenses);
+
+		return account;
+	}
+}
