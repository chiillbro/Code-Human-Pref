+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.Account;
+import com.piggymetrics.account.domain.Currency;
+import com.piggymetrics.account.domain.CurrencyBalance;
+import com.piggymetrics.account.domain.Item;
+import com.piggymetrics.account.domain.Saving;
+import com.piggymetrics.account.domain.TimePeriod;
+import com.piggymetrics.account.domain.Wallet;
+import com.piggymetrics.account.domain.WalletSnapshot;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.WalletSnapshotRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.math.BigDecimal;
+import java.math.RoundingMode;
+import java.text.SimpleDateFormat;
+import java.util.Date;
+import java.util.EnumMap;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+import java.util.TimeZone;
+
+@Service
+public class WalletServiceImpl implements WalletService {
+
+	private static final Logger log = LoggerFactory.getLogger(WalletServiceImpl.class);
+
+	private static final int MONEY_SCALE = 2;
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private WalletSnapshotRepository snapshotRepository;
+
+	@Autowired
+	private ExchangeRateProvider rateProvider;
+
+	@Override
+	public Wallet recalculate(String accountName) {
+		Assert.hasLength(accountName);
+		Account account = accountRepository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		Currency baseCurrency = currentBaseCurrency(account);
+		Wallet wallet = compute(account, baseCurrency);
+
+		account.setWallet(wallet);
+		accountRepository.save(account);
+
+		persistSnapshot(accountName, wallet);
+		return wallet;
+	}
+
+	@Override
+	public Wallet getWallet(String accountName) {
+		Account account = accountRepository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+		if (account.getWallet() != null) {
+			return account.getWallet();
+		}
+		return recalculate(accountName);
+	}
+
+	@Override
+	public Wallet changeBaseCurrency(String accountName, Currency baseCurrency) {
+		Assert.notNull(baseCurrency, "baseCurrency must not be null");
+		Account account = accountRepository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		Wallet wallet = compute(account, baseCurrency);
+		account.setWallet(wallet);
+		accountRepository.save(account);
+
+		persistSnapshot(accountName, wallet);
+		return wallet;
+	}
+
+	@Override
+	public List<WalletSnapshot> history(String accountName, Date from, Date to) {
+		Assert.hasLength(accountName);
+		Assert.notNull(from, "from must not be null");
+		Assert.notNull(to, "to must not be null");
+		return snapshotRepository.findByAccountNameAndDayBetweenOrderByDayAsc(
+				accountName, isoDay(from), isoDay(to));
+	}
+
+	// --- internals -----------------------------------------------------------
+
+	private Currency currentBaseCurrency(Account account) {
+		if (account.getWallet() != null && account.getWallet().getBaseDisplayCurrency() != null) {
+			return account.getWallet().getBaseDisplayCurrency();
+		}
+		return Currency.getDefault();
+	}
+
+	private Wallet compute(Account account, Currency baseCurrency) {
+		ExchangeRateProvider.Rates rates = rateProvider.getRates();
+
+		// Per-currency raw figures, normalized to monthly for items.
+		Map<Currency, CurrencyBalance> perCurrency = new EnumMap<>(Currency.class);
+
+		addItems(account.getIncomes(), perCurrency, /*income=*/true);
+		addItems(account.getExpenses(), perCurrency, /*income=*/false);
+		addSaving(account.getSaving(), perCurrency);
+
+		Wallet wallet = new Wallet();
+		wallet.setBaseDisplayCurrency(baseCurrency);
+		wallet.setUsedFallbackRates(rates.isUsedFallback());
+
+		BigDecimal totalBalance = BigDecimal.ZERO;
+		BigDecimal totalIncome = BigDecimal.ZERO;
+		BigDecimal totalExpenses = BigDecimal.ZERO;
+
+		Map<String, CurrencyBalance> out = new LinkedHashMap<>();
+		for (Currency c : Currency.values()) {
+			CurrencyBalance cb = perCurrency.get(c);
+			if (cb == null) {
+				continue;
+			}
+			// nativeBalance = savings + income - expenses (all in native currency)
+			BigDecimal nativeBalance = cb.getNativeSavings()
+					.add(cb.getNativeIncome())
+					.subtract(cb.getNativeExpenses());
+			cb.setNativeBalance(scale(nativeBalance));
+			cb.setNativeIncome(scale(cb.getNativeIncome()));
+			cb.setNativeExpenses(scale(cb.getNativeExpenses()));
+			cb.setNativeSavings(scale(cb.getNativeSavings()));
+
+			BigDecimal convBalance = convert(nativeBalance, c, baseCurrency, rates);
+			cb.setConvertedBalance(scale(convBalance));
+			out.put(c.name(), cb);
+
+			totalBalance = totalBalance.add(convBalance);
+			totalIncome = totalIncome.add(convert(cb.getNativeIncome(), c, baseCurrency, rates));
+			totalExpenses = totalExpenses.add(convert(cb.getNativeExpenses(), c, baseCurrency, rates));
+		}
+
+		wallet.setBalancesByCurrency(out);
+		wallet.setTotalBalance(scale(totalBalance));
+		wallet.setTotalIncome(scale(totalIncome));
+		wallet.setTotalExpenses(scale(totalExpenses));
+		wallet.setSavingsRatePercent(computeSavingsRate(totalIncome, totalExpenses));
+		wallet.setLastCalculated(new Date());
+		return wallet;
+	}
+
+	private void addItems(List<Item> items, Map<Currency, CurrencyBalance> out, boolean income) {
+		if (items == null) {
+			return;
+		}
+		for (Item item : items) {
+			if (item == null || item.getAmount() == null || item.getCurrency() == null || item.getPeriod() == null) {
+				continue;
+			}
+			BigDecimal monthly = toMonthly(item.getAmount(), item.getPeriod());
+			CurrencyBalance cb = out.computeIfAbsent(item.getCurrency(), CurrencyBalance::new);
+			if (income) {
+				cb.setNativeIncome(cb.getNativeIncome().add(monthly));
+			} else {
+				cb.setNativeExpenses(cb.getNativeExpenses().add(monthly));
+			}
+		}
+	}
+
+	private void addSaving(Saving saving, Map<Currency, CurrencyBalance> out) {
+		if (saving == null || saving.getAmount() == null || saving.getCurrency() == null) {
+			return;
+		}
+		CurrencyBalance cb = out.computeIfAbsent(saving.getCurrency(), CurrencyBalance::new);
+		cb.setNativeSavings(cb.getNativeSavings().add(saving.getAmount()));
+	}
+
+	/**
+	 * Normalize an amount expressed in {@code period} to a monthly figure.
+	 * monthly = amount * (MONTH_DAYS / PERIOD_DAYS). For an hourly $10 item
+	 * that yields roughly 730 hours * $10 = $7300/month; for a yearly $12000
+	 * item it yields $1000/month.
+	 */
+	static BigDecimal toMonthly(BigDecimal amount, TimePeriod period) {
+		BigDecimal ratio = TimePeriod.MONTH.getBaseRatio()
+				.divide(period.getBaseRatio(), 8, RoundingMode.HALF_UP);
+		return amount.multiply(ratio);
+	}
+
+	private static BigDecimal convert(BigDecimal amount, Currency from, Currency to,
+			ExchangeRateProvider.Rates rates) {
+		if (amount == null || amount.signum() == 0 || from == to) {
+			return amount == null ? BigDecimal.ZERO : amount;
+		}
+		BigDecimal fromRate = rates.get(from);
+		BigDecimal toRate = rates.get(to);
+		if (fromRate == null || toRate == null || fromRate.signum() == 0) {
+			log.warn("missing rate for {}->{}, skipping conversion", from, to);
+			return amount;
+		}
+		// rates are expressed as (currency per 1 USD); amount_in_to = amount * toRate / fromRate
+		BigDecimal ratio = toRate.divide(fromRate, 8, RoundingMode.HALF_UP);
+		return amount.multiply(ratio);
+	}
+
+	private static BigDecimal computeSavingsRate(BigDecimal income, BigDecimal expenses) {
+		if (income == null || income.signum() <= 0) {
+			return BigDecimal.ZERO;
+		}
+		BigDecimal net = income.subtract(expenses);
+		return net.multiply(new BigDecimal(100))
+				.divide(income, MONEY_SCALE, RoundingMode.HALF_UP);
+	}
+
+	private static BigDecimal scale(BigDecimal value) {
+		if (value == null) {
+			return BigDecimal.ZERO.setScale(MONEY_SCALE);
+		}
+		return value.setScale(MONEY_SCALE, RoundingMode.HALF_UP);
+	}
+
+	private void persistSnapshot(String accountName, Wallet wallet) {
+		String day = isoDay(wallet.getLastCalculated());
+		WalletSnapshot existing = snapshotRepository.findByAccountNameAndDay(accountName, day);
+		if (existing != null) {
+			// Collapse intra-day recalculations to the latest wallet state.
+			existing.setWallet(wallet);
+			existing.setCreatedAt(wallet.getLastCalculated());
+			snapshotRepository.save(existing);
+			return;
+		}
+		WalletSnapshot snap = new WalletSnapshot(accountName, day, wallet.getLastCalculated(), wallet);
+		snapshotRepository.save(snap);
+	}
+
+	private static String isoDay(Date date) {
+		SimpleDateFormat fmt = new SimpleDateFormat("yyyy-MM-dd");
+		fmt.setTimeZone(TimeZone.getTimeZone("UTC"));
+		return fmt.format(date);
+	}
+}
