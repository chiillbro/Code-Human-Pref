+
+	/**
+	 * Recomputes the wallet for the given account, persists the result onto
+	 * the Account document and writes at most one {@link WalletSnapshot} per
+	 * (accountName, calendar day). Returns the freshly computed wallet.
+	 */
+	Wallet recalculate(String accountName);
+
+	/**
+	 * Returns the wallet currently stored on the account, recomputing it on
+	 * the fly if no wallet has ever been calculated.
+	 */
+	Wallet getWallet(String accountName);
+
+	/**
+	 * Updates the user's preferred base display currency and recalculates.
+	 */
+	Wallet changeBaseCurrency(String accountName, Currency baseCurrency);
+
+	/**
+	 * Returns snapshots for the given account whose day falls within the
+	 * inclusive [from, to] window.
+	 */
+	List<WalletSnapshot> history(String accountName, Date from, Date to);
+}
