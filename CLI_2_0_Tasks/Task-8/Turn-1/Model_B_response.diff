+package com.piggymetrics.account.domain;
+
+import java.math.BigDecimal;
+
+/**
+ * Per-currency aggregate of wallet activity. Holds the native amount as-is
+ * and the equivalent amount converted into the wallet's base display currency.
+ */
+public class CurrencyBalance {
+
+	private Currency currency;
+
+	/** Monthly-normalized income expressed in the native currency. */
+	private BigDecimal nativeIncome = BigDecimal.ZERO;
+
+	/** Monthly-normalized expenses expressed in the native currency. */
+	private BigDecimal nativeExpenses = BigDecimal.ZERO;
+
+	/** Savings balance expressed in the native currency. */
+	private BigDecimal nativeSavings = BigDecimal.ZERO;
+
+	/** Sum of the above in native currency (savings + income - expenses). */
+	private BigDecimal nativeBalance = BigDecimal.ZERO;
+
+	/** nativeBalance converted to the wallet's base display currency. */
+	private BigDecimal convertedBalance = BigDecimal.ZERO;
+
+	public CurrencyBalance() {
+	}
+
+	public CurrencyBalance(Currency currency) {
+		this.currency = currency;
+	}
+
+	public Currency getCurrency() {
+		return currency;
+	}
+
+	public void setCurrency(Currency currency) {
+		this.currency = currency;
+	}
+
+	public BigDecimal getNativeIncome() {
+		return nativeIncome;
+	}
+
+	public void setNativeIncome(BigDecimal nativeIncome) {
+		this.nativeIncome = nativeIncome;
+	}
+
+	public BigDecimal getNativeExpenses() {
+		return nativeExpenses;
+	}
+
+	public void setNativeExpenses(BigDecimal nativeExpenses) {
+		this.nativeExpenses = nativeExpenses;
+	}
+
+	public BigDecimal getNativeSavings() {
+		return nativeSavings;
+	}
+
+	public void setNativeSavings(BigDecimal nativeSavings) {
+		this.nativeSavings = nativeSavings;
+	}
+
+	public BigDecimal getNativeBalance() {
+		return nativeBalance;
+	}
+
+	public void setNativeBalance(BigDecimal nativeBalance) {
+		this.nativeBalance = nativeBalance;
+	}
+
+	public BigDecimal getConvertedBalance() {
+		return convertedBalance;
+	}
+
+	public void setConvertedBalance(BigDecimal convertedBalance) {
+		this.convertedBalance = convertedBalance;
+	}
+}
