diff --git a/account-service/src/main/java/com/piggymetrics/account/service/ExchangeRateProvider.java b/account-service/src/main/java/com/piggymetrics/account/service/ExchangeRateProvider.java
new file mode 100644
index 0000000..00989b9
--- /dev/null
+++ b/account-service/src/main/java/com/piggymetrics/account/service/ExchangeRateProvider.java
@@ -0,0 +1,101 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.client.StatisticsServiceClient;
+import com.piggymetrics.account.domain.Currency;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Component;
+
+import java.math.BigDecimal;
+import java.util.EnumMap;
+import java.util.Map;
+
+/**
+ * Supplies exchange rates to the wallet layer. Prefers rates served by the
+ * statistics-service (which caches them from the external provider) and falls
+ * back to a hard-coded approximate table if statistics-service is unreachable
+ * or answers with an empty / partial map — wallet calculations must degrade
+ * gracefully rather than fail.
+ *
+ * Rates are expressed relative to USD (USD = 1), matching the statistics-service
+ * convention in {@code ExchangeRatesServiceImpl#getCurrentRates}.
+ */
+@Component
+public class ExchangeRateProvider {
+
+	private static final Logger log = LoggerFactory.getLogger(ExchangeRateProvider.class);
+
+	/**
+	 * Approximate rates used only when statistics-service cannot be reached.
+	 * Deliberately coarse — an out-of-date ballpark is better than a failed
+	 * wallet computation, and a warning flag is surfaced on the Wallet so
+	 * consumers know the number is approximate.
+	 */
+	private static final Map<Currency, BigDecimal> FALLBACK_RATES;
+
+	static {
+		FALLBACK_RATES = new EnumMap<>(Currency.class);
+		FALLBACK_RATES.put(Currency.USD, BigDecimal.ONE);
+		FALLBACK_RATES.put(Currency.EUR, new BigDecimal("0.92"));
+		FALLBACK_RATES.put(Currency.RUB, new BigDecimal("90.00"));
+	}
+
+	@Autowired
+	private StatisticsServiceClient statisticsClient;
+
+	/**
+	 * Result of a rate lookup, including a flag indicating whether the local
+	 * fallback table had to be used.
+	 */
+	public static final class Rates {
+		private final Map<Currency, BigDecimal> values;
+		private final boolean usedFallback;
+
+		Rates(Map<Currency, BigDecimal> values, boolean usedFallback) {
+			this.values = values;
+			this.usedFallback = usedFallback;
+		}
+
+		public BigDecimal get(Currency currency) {
+			return values.get(currency);
+		}
+
+		public boolean isUsedFallback() {
+			return usedFallback;
+		}
+	}
+
+	public Rates getRates() {
+		Map<Currency, BigDecimal> live = null;
+		try {
+			live = statisticsClient.getRates();
+		} catch (Exception ex) {
+			// Hystrix normally routes to the fallback, but defend against any leak.
+			log.warn("failed to fetch rates from statistics-service: {}", ex.toString());
+		}
+
+		if (live == null || live.isEmpty() || !hasAllCurrencies(live)) {
+			log.warn("using approximate fallback exchange rates");
+			return new Rates(new EnumMap<>(FALLBACK_RATES), true);
+		}
+
+		EnumMap<Currency, BigDecimal> copy = new EnumMap<>(Currency.class);
+		copy.putAll(live);
+		// USD is the base used by statistics-service; ensure it's present.
+		copy.putIfAbsent(Currency.USD, BigDecimal.ONE);
+		return new Rates(copy, false);
+	}
+
+	private static boolean hasAllCurrencies(Map<Currency, BigDecimal> rates) {
+		for (Currency c : Currency.values()) {
+			if (c == Currency.USD) {
+				continue;
+			}
+			if (rates.get(c) == null) {
+				return false;
+			}
+		}
+		return true;
+	}
+}
