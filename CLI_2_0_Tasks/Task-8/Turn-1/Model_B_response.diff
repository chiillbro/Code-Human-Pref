+package com.piggymetrics.account.controller;
+
+import com.piggymetrics.account.domain.Currency;
+import com.piggymetrics.account.domain.Wallet;
+import com.piggymetrics.account.domain.WalletSnapshot;
+import com.piggymetrics.account.service.WalletService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.format.annotation.DateTimeFormat;
+import org.springframework.web.bind.annotation.*;
+
+import java.security.Principal;
+import java.util.Date;
+import java.util.List;
+
+/**
+ * Wallet endpoints. Mounted under /current/wallet so they are scoped to the
+ * authenticated user, matching the convention of {@code /current} on
+ * {@link AccountController}.
+ */
+@RestController
+@RequestMapping("/current/wallet")
+public class WalletController {
+
+	@Autowired
+	private WalletService walletService;
+
+	/** Get the current wallet, calculating it on the fly if it doesn't exist yet. */
+	@RequestMapping(method = RequestMethod.GET)
+	public Wallet getCurrentWallet(Principal principal) {
+		return walletService.getWallet(principal.getName());
+	}
+
+	/** Force a fresh recalculation (also writes a snapshot, deduped per day). */
+	@RequestMapping(path = "/refresh", method = RequestMethod.POST)
+	public Wallet refresh(Principal principal) {
+		return walletService.recalculate(principal.getName());
+	}
+
+	/**
+	 * Change the user's base display currency and recalculate totals.
+	 * Body shape: { "currency": "EUR" }
+	 */
+	@RequestMapping(path = "/currency", method = RequestMethod.PUT)
+	public Wallet changeBaseCurrency(Principal principal, @RequestBody ChangeCurrencyRequest body) {
+		return walletService.changeBaseCurrency(principal.getName(), body.getCurrency());
+	}
+
+	/**
+	 * Returns snapshots in [from, to]. Dates are yyyy-MM-dd. If omitted,
+	 * defaults to the last 30 days ending today.
+	 */
+	@RequestMapping(path = "/history", method = RequestMethod.GET)
+	public List<WalletSnapshot> history(
+			Principal principal,
+			@RequestParam(value = "from", required = false)
+			@DateTimeFormat(pattern = "yyyy-MM-dd") Date from,
+			@RequestParam(value = "to", required = false)
+			@DateTimeFormat(pattern = "yyyy-MM-dd") Date to) {
+		Date toDate = to != null ? to : new Date();
+		Date fromDate = from != null ? from : new Date(toDate.getTime() - 30L * 24 * 60 * 60 * 1000);
+		return walletService.history(principal.getName(), fromDate, toDate);
+	}
+
+	public static class ChangeCurrencyRequest {
+		private Currency currency;
+
+		public Currency getCurrency() {
+			return currency;
+		}
+
+		public void setCurrency(Currency currency) {
+			this.currency = currency;
+		}
+	}
+}
