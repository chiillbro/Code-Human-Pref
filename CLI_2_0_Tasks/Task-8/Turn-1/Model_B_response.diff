+package com.piggymetrics.account.domain;
+
+import java.math.BigDecimal;
+import java.util.Date;
+import java.util.LinkedHashMap;
+import java.util.Map;
+
+/**
+ * Multi-currency wallet computed from the account's incomes, expenses and saving.
+ * All income/expense figures are normalized to a monthly basis before aggregation
+ * and then converted into {@link #baseDisplayCurrency} using rates fetched from
+ * the statistics-service.
+ *
+ * The wallet is a derived, denormalized view that lives on the Account document
+ * as a new field; nothing on the account that existed before is replaced.
+ */
+public class Wallet {
+
+	/** Currency chosen by the user for display (totals are expressed in this currency). */
+	private Currency baseDisplayCurrency = Currency.getDefault();
+
+	/** Per-currency breakdown keyed by the {@link Currency} name. */
+	private Map<String, CurrencyBalance> balancesByCurrency = new LinkedHashMap<>();
+
+	/** Sum of converted balances across all currencies, in the base display currency. */
+	private BigDecimal totalBalance = BigDecimal.ZERO;
+
+	/** Total monthly income (converted, in base display currency). */
+	private BigDecimal totalIncome = BigDecimal.ZERO;
+
+	/** Total monthly expenses (converted, in base display currency). */
+	private BigDecimal totalExpenses = BigDecimal.ZERO;
+
+	/** (income - expenses) / income * 100, in percent. Zero when income is zero. */
+	private BigDecimal savingsRatePercent = BigDecimal.ZERO;
+
+	/** Set to true when conversion used the local fallback rates instead of live ones. */
+	private boolean usedFallbackRates;
+
+	private Date lastCalculated;
+
+	public Currency getBaseDisplayCurrency() {
+		return baseDisplayCurrency;
+	}
+
+	public void setBaseDisplayCurrency(Currency baseDisplayCurrency) {
+		this.baseDisplayCurrency = baseDisplayCurrency;
+	}
+
+	public Map<String, CurrencyBalance> getBalancesByCurrency() {
+		return balancesByCurrency;
+	}
+
+	public void setBalancesByCurrency(Map<String, CurrencyBalance> balancesByCurrency) {
+		this.balancesByCurrency = balancesByCurrency;
+	}
+
+	public BigDecimal getTotalBalance() {
+		return totalBalance;
+	}
+
+	public void setTotalBalance(BigDecimal totalBalance) {
+		this.totalBalance = totalBalance;
+	}
+
+	public BigDecimal getTotalIncome() {
+		return totalIncome;
+	}
+
+	public void setTotalIncome(BigDecimal totalIncome) {
+		this.totalIncome = totalIncome;
+	}
+
+	public BigDecimal getTotalExpenses() {
+		return totalExpenses;
+	}
+
+	public void setTotalExpenses(BigDecimal totalExpenses) {
+		this.totalExpenses = totalExpenses;
+	}
+
+	public BigDecimal getSavingsRatePercent() {
+		return savingsRatePercent;
+	}
+
+	public void setSavingsRatePercent(BigDecimal savingsRatePercent) {
+		this.savingsRatePercent = savingsRatePercent;
+	}
+
+	public boolean isUsedFallbackRates() {
+		return usedFallbackRates;
+	}
+
+	public void setUsedFallbackRates(boolean usedFallbackRates) {
+		this.usedFallbackRates = usedFallbackRates;
+	}
+
+	public Date getLastCalculated() {
+		return lastCalculated;
+	}
+
+	public void setLastCalculated(Date lastCalculated) {
+		this.lastCalculated = lastCalculated;
+	}
+}
