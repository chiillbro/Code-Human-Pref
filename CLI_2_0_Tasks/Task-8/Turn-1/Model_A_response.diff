+package com.piggymetrics.account.controller;
+
+import com.piggymetrics.account.domain.Currency;
+import com.piggymetrics.account.domain.Wallet;
+import com.piggymetrics.account.domain.WalletSnapshot;
+import com.piggymetrics.account.service.WalletService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.format.annotation.DateTimeFormat;
+import org.springframework.web.bind.annotation.*;
+
+import java.security.Principal;
+import java.util.Date;
+import java.util.List;
+
+@RestController
+public class WalletController {
+
+	@Autowired
+	private WalletService walletService;
+
+	@RequestMapping(path = "/current/wallet", method = RequestMethod.GET)
+	public Wallet getCurrentWallet(Principal principal) {
+		return walletService.getWallet(principal.getName());
+	}
+
+	@RequestMapping(path = "/current/wallet/refresh", method = RequestMethod.POST)
+	public Wallet refreshCurrentWallet(Principal principal) {
+		return walletService.recalculate(principal.getName());
+	}
+
+	@RequestMapping(path = "/current/wallet/currency", method = RequestMethod.PUT)
+	public Wallet changeBaseCurrency(Principal principal, @RequestBody Currency currency) {
+		return walletService.changeBaseCurrency(principal.getName(), currency);
+	}
+
+	@RequestMapping(path = "/current/wallet/history", method = RequestMethod.GET)
+	public List<WalletSnapshot> getWalletHistory(
+			Principal principal,
+			@RequestParam @DateTimeFormat(iso = DateTimeFormat.ISO.DATE) Date from,
+			@RequestParam @DateTimeFormat(iso = DateTimeFormat.ISO.DATE) Date to) {
+		return walletService.getHistory(principal.getName(), from, to);
+	}
+}
