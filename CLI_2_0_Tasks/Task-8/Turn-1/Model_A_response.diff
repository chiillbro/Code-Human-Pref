+
+		Item salaryUsd = createItem("Salary", new BigDecimal("5000"), Currency.USD, TimePeriod.MONTH);
+		Item salaryEur = createItem("Freelance", new BigDecimal("1000"), Currency.EUR, TimePeriod.MONTH);
+		Item grocery = createItem("Grocery", new BigDecimal("300"), Currency.USD, TimePeriod.MONTH);
+
+		Saving saving = createSaving(new BigDecimal("2000"), Currency.USD);
+
+		Account account = new Account();
+		account.setName("test");
+		account.setIncomes(Arrays.asList(salaryUsd, salaryEur));
+		account.setExpenses(Arrays.asList(grocery));
+		account.setSaving(saving);
+
+		when(accountRepository.findByName("test")).thenReturn(account);
+
+		Wallet wallet = walletService.recalculate("test");
+
+		assertNotNull(wallet);
+		assertEquals(Currency.USD, wallet.getBaseCurrency());
+
+		// Should have balances for both USD and EUR
+		assertNotNull(wallet.getBalances());
+		assertTrue(wallet.getBalances().containsKey(Currency.USD));
+		assertTrue(wallet.getBalances().containsKey(Currency.EUR));
+
+		// USD balance: 5000 - 300 = 4700
+		assertEquals(0, new BigDecimal("4700").compareTo(wallet.getBalances().get(Currency.USD)));
+		// EUR balance: 1000 (income only)
+		assertEquals(0, new BigDecimal("1000.0000").compareTo(wallet.getBalances().get(Currency.EUR)));
+
+		assertNotNull(wallet.getConvertedBalances());
+		assertTrue(wallet.getTotalMonthlyIncome().compareTo(new BigDecimal("5000")) > 0);
+	}
