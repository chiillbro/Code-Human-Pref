+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.Currency;
+import com.piggymetrics.account.domain.Wallet;
+import com.piggymetrics.account.domain.WalletSnapshot;
+
+import java.util.Date;
+import java.util.List;
+
+public interface WalletService {
+
+	/**
+	 * Retrieves the current wallet for the given account.
+	 */
+	Wallet getWallet(String accountName);
+
+	/**
+	 * Force-recalculates the wallet for the given account.
+	 * Fetches fresh exchange rates, recomputes all aggregates,
+	 * persists to Account and creates/updates a daily snapshot.
+	 */
+	Wallet recalculate(String accountName);
+
+	/**
+	 * Changes the base display currency for the account's wallet
+	 * and triggers a recalculation.
+	 */
+	Wallet changeBaseCurrency(String accountName, Currency currency);
+
+	/**
+	 * Returns wallet snapshots for the given account within a date range.
+	 */
+	List<WalletSnapshot> getHistory(String accountName, Date from, Date to);
+}
diff --git a/account-service/src/main/java/com/piggymetrics/account/service/WalletServiceImpl.java b/account-service/src/main/java/com/piggymetrics/account/service/WalletServiceImpl.java
new file mode 100644
index 0000000..b842e1a
--- /dev/null
+++ b/account-service/src/main/java/com/piggymetrics/account/service/WalletServiceImpl.java
@@ -0,0 +1,204 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.client.StatisticsServiceClient;
+import com.piggymetrics.account.domain.*;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.WalletSnapshotRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.math.BigDecimal;
+import java.math.RoundingMode;
+import java.time.Instant;
+import java.time.LocalDate;
+import java.time.ZoneId;
+import java.util.Date;
+import java.util.HashMap;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Map;
+import java.util.Set;
+
+@Service
+public class WalletServiceImpl implements WalletService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private WalletSnapshotRepository snapshotRepository;
+
+	@Autowired
+	private StatisticsServiceClient statisticsClient;
+
+	@Override
+	public Wallet getWallet(String accountName) {
+		Assert.hasLength(accountName);
+		Account account = accountRepository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+		return account.getWallet();
+	}
+
+	@Override
+	public Wallet recalculate(String accountName) {
+		Assert.hasLength(accountName);
+		Account account = accountRepository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		Currency baseCurrency = Currency.getDefault();
+		if (account.getWallet() != null && account.getWallet().getBaseCurrency() != null) {
+			baseCurrency = account.getWallet().getBaseCurrency();
+		}
+
+		Wallet wallet = buildWallet(account, baseCurrency);
+
+		account.setWallet(wallet);
+		accountRepository.save(account);
+
+		saveSnapshot(accountName, wallet);
+
+		log.debug("wallet recalculated for account {}", accountName);
+		return wallet;
+	}
+
+	@Override
+	public Wallet changeBaseCurrency(String accountName, Currency currency) {
+		Assert.hasLength(accountName);
+		Assert.notNull(currency);
+
+		Account account = accountRepository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		Wallet wallet = buildWallet(account, currency);
+
+		account.setWallet(wallet);
+		accountRepository.save(account);
+
+		saveSnapshot(accountName, wallet);
+
+		log.debug("wallet base currency changed to {} for account {}", currency, accountName);
+		return wallet;
+	}
+
+	@Override
+	public List<WalletSnapshot> getHistory(String accountName, Date from, Date to) {
+		Assert.hasLength(accountName);
+		Assert.notNull(from);
+		Assert.notNull(to);
+		return snapshotRepository.findByIdAccountAndIdDateBetween(accountName, from, to);
+	}
+
+	Wallet buildWallet(Account account, Currency baseCurrency) {
+		Map<Currency, BigDecimal> rates = statisticsClient.getRates();
+
+		Map<Currency, BigDecimal> monthlyIncomeByCurrency = new HashMap<>();
+		if (account.getIncomes() != null) {
+			for (Item item : account.getIncomes()) {
+				BigDecimal monthlyAmount = item.getAmount()
+						.multiply(item.getPeriod().getMonthRatio())
+						.setScale(4, RoundingMode.HALF_UP);
+				monthlyIncomeByCurrency.merge(item.getCurrency(), monthlyAmount, BigDecimal::add);
+			}
+		}
+
+		Map<Currency, BigDecimal> monthlyExpenseByCurrency = new HashMap<>();
+		if (account.getExpenses() != null) {
+			for (Item item : account.getExpenses()) {
+				BigDecimal monthlyAmount = item.getAmount()
+						.multiply(item.getPeriod().getMonthRatio())
+						.setScale(4, RoundingMode.HALF_UP);
+				monthlyExpenseByCurrency.merge(item.getCurrency(), monthlyAmount, BigDecimal::add);
+			}
+		}
+
+		Set<Currency> allCurrencies = new HashSet<>();
+		allCurrencies.addAll(monthlyIncomeByCurrency.keySet());
+		allCurrencies.addAll(monthlyExpenseByCurrency.keySet());
+
+		Map<Currency, BigDecimal> balances = new HashMap<>();
+		for (Currency c : allCurrencies) {
+			BigDecimal income = monthlyIncomeByCurrency.getOrDefault(c, BigDecimal.ZERO);
+			BigDecimal expense = monthlyExpenseByCurrency.getOrDefault(c, BigDecimal.ZERO);
+			balances.put(c, income.subtract(expense));
+		}
+
+		Map<Currency, BigDecimal> convertedBalances = new HashMap<>();
+		for (Map.Entry<Currency, BigDecimal> entry : balances.entrySet()) {
+			convertedBalances.put(entry.getKey(),
+					convert(entry.getValue(), entry.getKey(), baseCurrency, rates));
+		}
+
+		BigDecimal totalMonthlyIncome = BigDecimal.ZERO;
+		for (Map.Entry<Currency, BigDecimal> entry : monthlyIncomeByCurrency.entrySet()) {
+			totalMonthlyIncome = totalMonthlyIncome.add(
+					convert(entry.getValue(), entry.getKey(), baseCurrency, rates));
+		}
+		totalMonthlyIncome = totalMonthlyIncome.setScale(4, RoundingMode.HALF_UP);
+
+		BigDecimal totalMonthlyExpenses = BigDecimal.ZERO;
+		for (Map.Entry<Currency, BigDecimal> entry : monthlyExpenseByCurrency.entrySet()) {
+			totalMonthlyExpenses = totalMonthlyExpenses.add(
+					convert(entry.getValue(), entry.getKey(), baseCurrency, rates));
+		}
+		totalMonthlyExpenses = totalMonthlyExpenses.setScale(4, RoundingMode.HALF_UP);
+
+		BigDecimal savingInBase = BigDecimal.ZERO;
+		if (account.getSaving() != null && account.getSaving().getAmount() != null) {
+			savingInBase = convert(account.getSaving().getAmount(),
+					account.getSaving().getCurrency(), baseCurrency, rates);
+		}
+
+		BigDecimal netMonthly = totalMonthlyIncome.subtract(totalMonthlyExpenses);
+		BigDecimal totalBalance = netMonthly.add(savingInBase).setScale(4, RoundingMode.HALF_UP);
+
+		BigDecimal savingsRate = BigDecimal.ZERO;
+		if (totalMonthlyIncome.compareTo(BigDecimal.ZERO) > 0) {
+			savingsRate = netMonthly
+					.divide(totalMonthlyIncome, 4, RoundingMode.HALF_UP)
+					.multiply(new BigDecimal("100"))
+					.setScale(2, RoundingMode.HALF_UP);
+		}
+
+		Wallet wallet = new Wallet();
+		wallet.setBalances(balances);
+		wallet.setConvertedBalances(convertedBalances);
+		wallet.setTotalBalance(totalBalance);
+		wallet.setTotalMonthlyIncome(totalMonthlyIncome);
+		wallet.setTotalMonthlyExpenses(totalMonthlyExpenses);
+		wallet.setNetSavingsRatePercent(savingsRate);
+		wallet.setBaseCurrency(baseCurrency);
+		wallet.setLastUpdated(new Date());
+
+		return wallet;
+	}
+
+	private BigDecimal convert(BigDecimal amount, Currency from, Currency to,
+							   Map<Currency, BigDecimal> rates) {
+		if (from == to) {
+			return amount;
+		}
+		BigDecimal fromRate = rates.getOrDefault(from, BigDecimal.ONE);
+		BigDecimal toRate = rates.getOrDefault(to, BigDecimal.ONE);
+		BigDecimal ratio = toRate.divide(fromRate, 4, RoundingMode.HALF_UP);
+		return amount.multiply(ratio).setScale(4, RoundingMode.HALF_UP);
+	}
+
+	private void saveSnapshot(String accountName, Wallet wallet) {
+		Instant instant = LocalDate.now().atStartOfDay()
+				.atZone(ZoneId.systemDefault()).toInstant();
+
+		WalletSnapshotId snapshotId = new WalletSnapshotId(accountName, Date.from(instant));
+
+		WalletSnapshot snapshot = new WalletSnapshot();
+		snapshot.setId(snapshotId);
+		snapshot.setWallet(wallet);
+
+		snapshotRepository.save(snapshot);
+		log.debug("wallet snapshot saved for account {} on {}", accountName, snapshotId.getDate());
+	}
+}
