+
+		// Monthly income: 120000 / 12 = 10000
+		assertEquals(0, new BigDecimal("10000.0000").compareTo(wallet.getTotalMonthlyIncome()));
+
+		// Monthly expense: 120 * 30.4368 = 3652.4160
+		assertEquals(0, new BigDecimal("3652.4160").compareTo(wallet.getTotalMonthlyExpenses()));
