+
+	@Before
+	public void setup() {
+		initMocks(this);
+
+		Map<Currency, BigDecimal> rates = new HashMap<>();
+		rates.put(Currency.USD, BigDecimal.ONE);
+		rates.put(Currency.EUR, new BigDecimal("0.9"));
+		rates.put(Currency.RUB, new BigDecimal("75.0"));
+		when(statisticsClient.getRates()).thenReturn(rates);
+	}
+
+	@Test
+	public void shouldRecalculateWalletWithSingleCurrency() {
+
+		Item salary = createItem("Salary", new BigDecimal("9100"), Currency.USD, TimePeriod.MONTH);
+		Item grocery = createItem("Grocery", new BigDecimal("500"), Currency.USD, TimePeriod.MONTH);
+
+		Saving saving = createSaving(new BigDecimal("1500"), Currency.USD);
+
+		Account account = new Account();
+		account.setName("test");
+		account.setIncomes(Arrays.asList(salary));
+		account.setExpenses(Arrays.asList(grocery));
+		account.setSaving(saving);
+
+		when(accountRepository.findByName("test")).thenReturn(account);
+
+		Wallet wallet = walletService.recalculate("test");
+
+		assertNotNull(wallet);
+		assertEquals(Currency.USD, wallet.getBaseCurrency());
+		assertEquals(0, new BigDecimal("9100.0000").compareTo(wallet.getTotalMonthlyIncome()));
+		assertEquals(0, new BigDecimal("500.0000").compareTo(wallet.getTotalMonthlyExpenses()));
+
+		// totalBalance = (9100 - 500) + 1500 = 10100
+		assertEquals(0, new BigDecimal("10100.0000").compareTo(wallet.getTotalBalance()));
+
+		// savingsRate = (9100-500)/9100 * 100 = 94.51%
+		assertTrue(wallet.getNetSavingsRatePercent().compareTo(BigDecimal.ZERO) > 0);
+
+		verify(accountRepository, times(1)).save(account);
+		verify(snapshotRepository, times(1)).save(any(WalletSnapshot.class));
+	}
