+
+	private Item createItem(String title, BigDecimal amount, Currency currency, TimePeriod period) {
+		Item item = new Item();
+		item.setTitle(title);
+		item.setAmount(amount);
+		item.setCurrency(currency);
+		item.setPeriod(period);
+		item.setIcon("icon");
+		return item;
+	}
+
+	private Saving createSaving(BigDecimal amount, Currency currency) {
+		Saving saving = new Saving();
+		saving.setAmount(amount);
+		saving.setCurrency(currency);
+		saving.setInterest(BigDecimal.ZERO);
+		saving.setDeposit(false);
+		saving.setCapitalization(false);
+		return saving;
+	}
+}
