 package com.piggymetrics.account.domain;
 
+import java.math.BigDecimal;
+
 public enum TimePeriod {
 
-	YEAR, QUARTER, MONTH, DAY, HOUR
+	YEAR(1.0 / 12.0),
+	QUARTER(1.0 / 3.0),
+	MONTH(1.0),
+	DAY(30.4368),
+	HOUR(30.4368 * 24.0);
+
+	private final double monthRatio;
+
+	TimePeriod(double monthRatio) {
+		this.monthRatio = monthRatio;
+	}
+
+	/**
+	 * Returns the multiplier to convert an amount in this period to a monthly amount.
+	 * monthlyAmount = amount * getMonthRatio()
+	 */
+	public BigDecimal getMonthRatio() {
+		return BigDecimal.valueOf(monthRatio);
+	}
 
+	public static TimePeriod getBase() {
+		return MONTH;
+	}
 }
