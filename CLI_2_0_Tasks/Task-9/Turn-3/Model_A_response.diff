+class GroupHavingTest(unittest.TestCase):
+    """group … having EXPR filters aggregated rows using the expression engine."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+        self.rows = read_rows(self.path)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    def test_having_filters_on_aggregate_alias(self):
+        g = Group.from_cli("dept:avg(salary) as avg_sal,count() having avg_sal > 100000")
+        out = g.apply(self.rows)
+        self.assertEqual(len(out), 1)
+        self.assertEqual(out[0]["dept"], "eng")
+        self.assertGreater(out[0]["avg_sal"], 100000)
+
+    def test_having_filters_on_default_alias(self):
+        """When no AS is given, alias defaults to fn_col → avg_salary."""
+        g = Group.from_cli("dept:avg(salary) having avg_salary > 100000")
+        out = g.apply(self.rows)
+        self.assertEqual([r["dept"] for r in out], ["eng"])
+
+    def test_having_on_count(self):
+        g = Group.from_cli("dept:count() having count > 1")
+        out = g.apply(self.rows)
+        depts = {r["dept"] for r in out}
+        self.assertEqual(depts, {"eng", "sales"})
+
+    def test_having_can_reference_group_key(self):
+        g = Group.from_cli('dept:count() having dept != "ops"')
+        out = g.apply(self.rows)
+        self.assertNotIn("ops", {r["dept"] for r in out})
+
+    def test_having_compound_expression(self):
+        g = Group.from_cli(
+            "dept:avg(salary) as a,count() having a > 70000 and count >= 2"
+        )
+        out = g.apply(self.rows)
+        depts = {r["dept"] for r in out}
+        self.assertEqual(depts, {"eng", "sales"})
+
+    def test_without_having_returns_all_groups(self):
+        """Backward compat: omitting having keeps all groups."""
+        g = Group.from_cli("dept:count()")
+        out = g.apply(self.rows)
+        self.assertEqual(len(out), 3)
+
+    def test_having_from_spec(self):
+        g = Group.from_spec({
+            "by": "dept",
+            "agg": ["avg(salary) as avg_sal"],
+            "having": "avg_sal > 100000",
+        })
+        out = g.apply(self.rows)
+        self.assertEqual([r["dept"] for r in out], ["eng"])
+
+    def test_having_via_cli_end_to_end(self):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            rc = cli_main([
+                self.path,
+                "--group", "dept:avg(salary) as a having a > 100000",
+                "-F", "json",
+            ])
+        finally:
+            sys.stdout = old_stdout
+        self.assertEqual(rc, 0)
+        rows = json.loads(buf.getvalue())
+        self.assertEqual(len(rows), 1)
+        self.assertEqual(rows[0]["dept"], "eng")
+
+
+class GroupHavingErrorTest(unittest.TestCase):
+    """having must fail fast on unknown aliases and surface a useful error."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+        self.rows = read_rows(self.path)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    def test_unknown_alias_raises_at_construction(self):
+        """The bad alias is caught before any rows are touched."""
+        with self.assertRaises(ColumnError) as ctx:
+            Group.from_cli("dept:avg(salary) as avg_sal having avgsal > 100000")
+        rendered = str(ctx.exception)
+        self.assertIn("avgsal", rendered)
+
+    def test_unknown_alias_shows_available_aliases(self):
+        with self.assertRaises(ColumnError) as ctx:
+            Group.from_cli("dept:avg(salary) as avg_sal having bogus > 1")
+        rendered = str(ctx.exception)
+        self.assertIn("bogus", rendered)
+        self.assertIn("available columns:", rendered)
+        # the listed columns must be the *output* columns of the group
+        self.assertIn("avg_sal", rendered)
+        self.assertIn("dept", rendered)
+
+    def test_unknown_alias_suggests_close_match(self):
+        with self.assertRaises(ColumnError) as ctx:
+            Group.from_cli("dept:count() having coumt > 1")
+        rendered = str(ctx.exception)
+        self.assertIn("did you mean", rendered)
+        self.assertIn("count", rendered)
+
+    def test_unknown_alias_from_spec(self):
+        with self.assertRaises(ColumnError):
+            Group.from_spec({
+                "by": "dept",
+                "agg": ["avg(salary) as a"],
+                "having": "wrong > 1",
+            })
+
+    def test_having_syntax_error_propagates(self):
+        with self.assertRaises(TablesmithError) as ctx:
+            Group.from_cli("dept:count() having count >")
+        self.assertIn("invalid expression", str(ctx.exception))
+
+    def test_validate_subcommand_catches_bad_having(self):
+        doc = {
+            "input": self.path,
+            "steps": [
+                {"op": "group", "by": "dept",
+                 "agg": ["avg(salary) as a"], "having": "wrong > 1"},
+            ],
+        }
+        pipe_path = _write_tmp(json.dumps(doc), suffix=".json")
+        try:
+            import io, sys
+            buf = io.StringIO()
+            old_stderr = sys.stderr
+            sys.stderr = buf
+            try:
+                rc = _cmd_validate([pipe_path])
+            finally:
+                sys.stderr = old_stderr
+            self.assertEqual(rc, 1)
+            self.assertIn("wrong", buf.getvalue())
+            self.assertIn("unknown column", buf.getvalue())
+        finally:
+            os.unlink(pipe_path)
+
+    def test_cli_reports_step_context(self):
+        """CLI error output includes step #N [group] context."""
+        import io, sys
+        buf = io.StringIO()
+        old_stderr = sys.stderr
+        sys.stderr = buf
+        try:
+            rc = cli_main([
+                self.path,
+                "--group", "dept:count() having nope > 1",
+            ])
+        finally:
+            sys.stderr = old_stderr
+        self.assertEqual(rc, 1)
+        msg = buf.getvalue()
+        self.assertIn("[group]", msg)
+        self.assertIn("nope", msg)
+
+
