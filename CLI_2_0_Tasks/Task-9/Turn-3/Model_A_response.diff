+class InspectDistinctMinMaxTest(unittest.TestCase):
+    """The schema must report distinct counts for every column and
+    min/max for numeric columns only."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    def _schema(self, path=None):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            rc = _cmd_inspect([path or self.path, "-F", "json"])
+        finally:
+            sys.stdout = old_stdout
+        self.assertEqual(rc, 0)
+        return {e["column"]: e for e in json.loads(buf.getvalue())}
+
+    # ---- distinct ----
+    def test_distinct_ignores_nulls(self):
+        s = self._schema()
+        # 6 rows, Frank's age is null → 5 distinct non-null ages
+        self.assertEqual(s["age"]["distinct"], 5)
+
+    def test_distinct_counts_unique_values(self):
+        s = self._schema()
+        # dept has eng,eng,sales,sales,eng,ops → 3 distinct
+        self.assertEqual(s["dept"]["distinct"], 3)
+        # id has 6 unique values
+        self.assertEqual(s["id"]["distinct"], 6)
+
+    def test_distinct_present_for_non_numeric(self):
+        s = self._schema()
+        self.assertIn("distinct", s["name"])
+        self.assertEqual(s["name"]["distinct"], 6)
+
+    # ---- min/max numeric ----
+    def test_minmax_for_int_column(self):
+        s = self._schema()
+        self.assertEqual(s["salary"]["min"], 61000)
+        self.assertEqual(s["salary"]["max"], 142000)
+        self.assertEqual(s["id"]["min"], 1)
+        self.assertEqual(s["id"]["max"], 6)
+
+    def test_minmax_ignores_nulls(self):
+        s = self._schema()
+        # age has a null (Frank); min/max computed over non-null only
+        self.assertEqual(s["age"]["min"], 23)
+        self.assertEqual(s["age"]["max"], 41)
+
+    def test_minmax_for_float_column(self):
+        path = _write_tmp("x\n1.5\n2.25\n0.5\n", suffix=".csv")
+        try:
+            s = self._schema(path)
+            self.assertEqual(s["x"]["type"], "float")
+            self.assertEqual(s["x"]["min"], 0.5)
+            self.assertEqual(s["x"]["max"], 2.25)
+        finally:
+            os.unlink(path)
+
+    # ---- min/max non-numeric ----
+    def test_minmax_null_for_string_column(self):
+        s = self._schema()
+        self.assertIsNone(s["name"]["min"])
+        self.assertIsNone(s["name"]["max"])
+        self.assertIsNone(s["dept"]["min"])
+        self.assertIsNone(s["dept"]["max"])
+
+    def test_minmax_null_for_bool_column(self):
+        path = _write_tmp("flag\ntrue\nfalse\ntrue\n", suffix=".csv")
+        try:
+            s = self._schema(path)
+            self.assertEqual(s["flag"]["type"], "bool")
+            self.assertIsNone(s["flag"]["min"])
+            self.assertIsNone(s["flag"]["max"])
+            self.assertEqual(s["flag"]["distinct"], 2)
+        finally:
+            os.unlink(path)
+
+    def test_minmax_null_for_all_null_column(self):
+        path = _write_tmp("a,b\n1,\n2,\n", suffix=".csv")
+        try:
+            s = self._schema(path)
+            self.assertIsNone(s["b"]["min"])
+            self.assertIsNone(s["b"]["max"])
+            self.assertEqual(s["b"]["distinct"], 0)
+        finally:
+            os.unlink(path)
+
+    # ---- text rendering ----
+    def test_text_output_has_new_columns(self):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            _cmd_inspect([self.path])
+        finally:
+            sys.stdout = old_stdout
+        header = buf.getvalue().splitlines()[0]
+        for col in ("Distinct", "Min", "Max"):
+            self.assertIn(col, header)
+
