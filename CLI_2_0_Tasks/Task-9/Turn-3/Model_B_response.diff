+class InspectDistinctMinMaxTest(unittest.TestCase):
+    """Inspect schema must include distinct count and min/max for numeric columns."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    def _get_schema(self):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            rc = _cmd_inspect([self.path, "-F", "json"])
+        finally:
+            sys.stdout = old_stdout
+        self.assertEqual(rc, 0)
+        return {e["column"]: e for e in json.loads(buf.getvalue())}
+
+    # ---- distinct ----
+
+    def test_distinct_present_in_schema(self):
+        by_col = self._get_schema()
+        for entry in by_col.values():
+            self.assertIn("distinct", entry)
+
+    def test_distinct_for_numeric_column(self):
+        by_col = self._get_schema()
+        # age has 5 non-null distinct values: 34, 29, 41, 23, 38
+        self.assertEqual(by_col["age"]["distinct"], 5)
+
+    def test_distinct_for_string_column(self):
+        by_col = self._get_schema()
+        # dept has 3 distinct values: eng, sales, ops
+        self.assertEqual(by_col["dept"]["distinct"], 3)
+
+    def test_distinct_for_unique_column(self):
+        by_col = self._get_schema()
+        # name has 6 unique values
+        self.assertEqual(by_col["name"]["distinct"], 6)
+
+    # ---- min / max for numeric ----
+
+    def test_min_max_for_int_column(self):
+        by_col = self._get_schema()
+        self.assertEqual(by_col["salary"]["min"], 61000)
+        self.assertEqual(by_col["salary"]["max"], 142000)
+
+    def test_min_max_for_int_with_nulls(self):
+        by_col = self._get_schema()
+        # age: min=23, max=41 (Frank's null is excluded)
+        self.assertEqual(by_col["age"]["min"], 23)
+        self.assertEqual(by_col["age"]["max"], 41)
+
+    def test_min_max_null_for_string_column(self):
+        by_col = self._get_schema()
+        self.assertIsNone(by_col["name"]["min"])
+        self.assertIsNone(by_col["name"]["max"])
+        self.assertIsNone(by_col["dept"]["min"])
+        self.assertIsNone(by_col["dept"]["max"])
+
+    # ---- backward compat ----
+
+    def test_existing_fields_still_present(self):
+        """New fields must not break the existing contract."""
+        by_col = self._get_schema()
+        required = {"column", "type", "nulls", "total", "samples", "distinct", "min", "max"}
+        for entry in by_col.values():
+            self.assertTrue(required <= set(entry.keys()), f"missing in {entry}")
+
+    # ---- text output ----
+
+    def test_text_output_includes_dist_header(self):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            _cmd_inspect([self.path])
+        finally:
+            sys.stdout = old_stdout
+        header = buf.getvalue().splitlines()[0]
+        self.assertIn("Dist", header)
+        self.assertIn("Min", header)
+        self.assertIn("Max", header)
+
+
+class GroupHavingTest(unittest.TestCase):
+    """Group operations must support a 'having' clause that filters
+    aggregated results using the existing expression parser."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+        self.rows = read_rows(self.path)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    # ---- basic having behaviour ----
+
+    def test_having_filters_aggregated_rows(self):
+        g = Group.from_cli("dept:avg(salary) as avg_sal,count() having avg_sal > 80000")
+        result = g.apply(self.rows)
+        depts = [r["dept"] for r in result]
+        # eng avg=119000 > 80000 ✓, sales avg=74500 ✗, ops avg=70000 ✗
+        self.assertEqual(depts, ["eng"])
+
+    def test_having_keeps_matching_groups(self):
+        g = Group.from_cli("dept:count() as n having n >= 2")
+        result = g.apply(self.rows)
+        depts = {r["dept"] for r in result}
+        # eng has 3, sales has 2, ops has 1
+        self.assertEqual(depts, {"eng", "sales"})
+
+    def test_having_can_use_group_key(self):
+        """Having can reference group-by columns, not just agg aliases."""
+        g = Group.from_cli('dept:count() having dept == "eng"')
+        result = g.apply(self.rows)
+        self.assertEqual(len(result), 1)
+        self.assertEqual(result[0]["dept"], "eng")
+
+    def test_no_having_returns_all_groups(self):
+        g = Group.from_cli("dept:count()")
+        result = g.apply(self.rows)
+        self.assertEqual(len(result), 3)
+
+    def test_having_removes_all_when_none_match(self):
+        g = Group.from_cli("dept:count() as n having n > 1000")
+        result = g.apply(self.rows)
+        self.assertEqual(result, [])
+
+    # ---- having via pipeline file ----
+
+    def test_having_from_spec(self):
+        spec = {
+            "by": "dept",
+            "aggs": "sum(salary) as total",
+            "having": "total > 200000",
+        }
+        g = Group.from_spec(spec)
+        result = g.apply(self.rows)
+        # eng total=357000 > 200000 ✓
+        self.assertEqual(len(result), 1)
+        self.assertEqual(result[0]["dept"], "eng")
+
+    # ---- having error propagation ----
+
+    def test_having_unknown_alias_fails_at_construction(self):
+        """Referencing a name that is neither a group key nor an agg alias
+        must fail immediately with ColumnError, not at apply time."""
+        with self.assertRaises(ColumnError) as ctx:
+            Group.from_cli("dept:avg(salary) having bogus > 100")
+        err = str(ctx.exception)
+        self.assertIn("bogus", err)
+        self.assertIn("unknown column", err)
+
+    def test_having_error_shows_available_aliases(self):
+        with self.assertRaises(ColumnError) as ctx:
+            Group.from_cli("dept:avg(salary) as avg_sal having bogus > 100")
+        err = str(ctx.exception)
+        self.assertIn("available columns:", err)
+        self.assertIn("avg_sal", err)
+        self.assertIn("dept", err)
+
+    def test_having_syntax_error_raises(self):
+        from tablesmith.errors import ExpressionError
+        with self.assertRaises(ExpressionError):
+            Group.from_cli("dept:count() having >!>")
+
+    def test_having_appears_in_describe(self):
+        g = Group.from_cli("dept:avg(salary) as avg_sal having avg_sal > 100000")
+        desc = g.describe()
+        self.assertIn("having", desc)
+        self.assertIn("avg_sal > 100000", desc)
+
+
 if __name__ == "__main__":
     unittest.main()
