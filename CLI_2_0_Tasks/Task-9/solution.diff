+"""Tests for transformation operations."""
+
+import json
+import os
+import tempfile
+
+import pytest
+
+from tablesmith.models import (
+    AggregateSpec,
+    JoinType,
+    NullOrder,
+    SortOrder,
+    SortSpec,
+    ValidationError,
+)
+from tablesmith.operations import (
+    op_distinct,
+    op_filter,
+    op_group,
+    op_having,
+    op_join_full,
+    op_limit,
+    op_project,
+    op_sort,
+    parse_agg_spec,
+)
+
+
+# ---------------------------------------------------------------------------
+# Filter tests
+# ---------------------------------------------------------------------------
+
+class TestFilter:
+    def test_simple_filter(self):
+        rows = [{"age": 25}, {"age": 35}, {"age": 20}]
+        result = list(op_filter(rows, "age > 30"))
+        assert len(result) == 1
+        assert result[0]["age"] == 35
+
+    def test_filter_with_null(self):
+        rows = [{"age": 25}, {"age": None}, {"age": 35}]
+        result = list(op_filter(rows, "age > 20"))
+        # NULL > 20 => NULL => filtered out
+        assert len(result) == 2
+        assert result[0]["age"] == 25
+        assert result[1]["age"] == 35
+
+    def test_compound_filter(self):
+        rows = [
+            {"age": 35, "dept": "Engineering"},
+            {"age": 25, "dept": "HR"},
+            {"age": 40, "dept": "Engineering"},
+        ]
+        result = list(op_filter(rows, "age > 30 AND dept = 'Engineering'"))
+        assert len(result) == 2
+
+    def test_or_filter(self):
+        rows = [{"x": 1}, {"x": 5}, {"x": 10}]
+        result = list(op_filter(rows, "x < 2 OR x > 8"))
+        assert len(result) == 2
+
+    def test_not_filter(self):
+        rows = [{"active": True}, {"active": False}]
+        result = list(op_filter(rows, "NOT active = false"))
+        assert len(result) == 1
+        assert result[0]["active"] is True
+
+    def test_is_null_filter(self):
+        rows = [{"a": 1}, {"a": None}, {"a": 3}]
+        result = list(op_filter(rows, "a is_null"))
+        assert len(result) == 1
+        assert result[0]["a"] is None
+
+    def test_is_not_null_filter(self):
+        rows = [{"a": 1}, {"a": None}, {"a": 3}]
+        result = list(op_filter(rows, "a is_not_null"))
+        assert len(result) == 2
+
+    def test_string_with_spaces(self):
+        rows = [{"name": "John Doe"}, {"name": "Jane"}]
+        result = list(op_filter(rows, "name = 'John Doe'"))
+        assert len(result) == 1
+
+    def test_keyword_in_string(self):
+        """String containing 'AND' should not break parsing."""
+        rows = [{"dept": "ANDROID Team"}, {"dept": "iOS"}]
+        result = list(op_filter(rows, "dept = 'ANDROID Team'"))
+        assert len(result) == 1
+
+    def test_streaming_behavior(self):
+        """Filter should be lazy — works as generator without materializing."""
+        call_count = 0
+        def counted_rows():
+            nonlocal call_count
+            for i in range(20):
+                call_count += 1
+                yield {"x": i % 5}  # yields 0,1,2,3,4,0,1,2,...
+        # Take only 3 matches; filter is lazy, doesn't build a list
+        result = list(op_limit(op_filter(counted_rows(), "x < 3"), 3))
+        assert len(result) == 3
+        assert call_count < 20  # Streaming: should stop early
+
