+"""Tests for pipeline loading, validation, and execution."""
+
+import json
+import os
+import tempfile
+
+import pytest
+
+from tablesmith.models import ValidationError
+from tablesmith.pipeline import execute_pipeline, load_pipeline, validate_pipeline
+
+
+class TestValidation:
+    def _write_pipeline(self, data: dict) -> str:
+        f = tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False, encoding="utf-8")
+        json.dump(data, f)
+        f.close()
+        return f.name
+
+    def test_valid_pipeline(self):
+        data = {
+            "input": "test.csv",
+            "steps": [
+                {"op": "filter", "expr": "age > 30"},
+                {"op": "limit", "n": 10},
+            ],
+        }
+        errors = validate_pipeline(data)
+        assert errors == []
+
+    def test_unknown_operation(self):
+        data = {"steps": [{"op": "explode"}]}
+        errors = validate_pipeline(data)
+        assert len(errors) == 1
+        assert "unknown operation" in errors[0].lower()
+
+    def test_missing_expr_in_filter(self):
+        data = {"steps": [{"op": "filter"}]}
+        errors = validate_pipeline(data)
+        assert any("expr" in e for e in errors)
+
+    def test_missing_pipeline_file(self):
+        with pytest.raises(ValidationError, match="not found"):
+            load_pipeline("/nonexistent/pipeline.json")
+
+
+class TestPipelineExecution:
+    def _write_csv(self, content: str) -> str:
+        f = tempfile.NamedTemporaryFile(mode="w", suffix=".csv", delete=False, encoding="utf-8")
+        f.write(content)
+        f.close()
+        return f.name
+
+    def test_filter_then_limit(self):
+        csv_path = self._write_csv("name,age\nAlice,30\nBob,25\nCarol,35\nDave,40\n")
+        try:
+            data = {
+                "input": csv_path,
+                "steps": [
+                    {"op": "filter", "expr": "age > 28"},
+                    {"op": "limit", "n": 2},
+                ],
+            }
+            rows = list(execute_pipeline(data))
+            assert len(rows) == 2
+            assert all(r["age"] > 28 for r in rows)
+        finally:
+            os.unlink(csv_path)
+
+    def test_group_and_sort(self):
+        csv_path = self._write_csv(
+            "dept,salary\nA,50000\nA,60000\nB,70000\nB,80000\nB,90000\n"
+        )
+        try:
+            data = {
+                "input": csv_path,
+                "steps": [
+                    {"op": "group", "by": ["dept"], "aggs": ["count(*) AS cnt", "avg(salary) AS avg_sal"]},
+                    {"op": "sort", "by": [{"column": "cnt", "order": "desc"}]},
+                ],
+            }
+            rows = list(execute_pipeline(data))
+            assert len(rows) == 2
+            assert rows[0]["dept"] == "B"
+            assert rows[0]["cnt"] == 3
+        finally:
+            os.unlink(csv_path)
+
+    def test_project_with_computed(self):
+        csv_path = self._write_csv("name,salary\nAlice,50000\nBob,60000\n")
+        try:
+            data = {
+                "input": csv_path,
+                "steps": [
+                    {"op": "project", "columns": ["name", "salary * 12 AS annual"]},
+                ],
+            }
+            rows = list(execute_pipeline(data))
+            assert rows[0]["annual"] == 600000
+        finally:
+            os.unlink(csv_path)
