+    def test_inner_join(self):
+        right_path = self._write_csv("id,salary\n1,50000\n2,60000\n3,70000\n")
+        try:
+            left = [{"id": 1, "name": "Alice"}, {"id": 2, "name": "Bob"}, {"id": 4, "name": "Dave"}]
+            result = op_join_full(left, right_path, ["id"], JoinType.INNER)
+            assert len(result) == 2  # id=4 has no match
+            names = {r["name"] for r in result}
+            assert names == {"Alice", "Bob"}
+        finally:
+            os.unlink(right_path)
+
+    def test_left_join(self):
+        right_path = self._write_csv("id,salary\n1,50000\n")
+        try:
+            left = [{"id": 1, "name": "Alice"}, {"id": 2, "name": "Bob"}]
+            result = op_join_full(left, right_path, ["id"], JoinType.LEFT)
+            assert len(result) == 2
+            bob = [r for r in result if r["name"] == "Bob"][0]
+            assert bob["salary"] is None  # No match → NULL
+        finally:
+            os.unlink(right_path)
+
+    def test_right_join(self):
+        right_path = self._write_csv("id,salary\n1,50000\n3,70000\n")
+        try:
+            left = [{"id": 1, "name": "Alice"}]
+            result = op_join_full(left, right_path, ["id"], JoinType.RIGHT)
+            assert len(result) == 2
+            unmatched = [r for r in result if r["id"] == 3][0]
+            assert unmatched["name"] is None
+        finally:
+            os.unlink(right_path)
+
+    def test_full_join(self):
+        right_path = self._write_csv("id,salary\n1,50000\n3,70000\n")
+        try:
+            left = [{"id": 1, "name": "Alice"}, {"id": 2, "name": "Bob"}]
+            result = op_join_full(left, right_path, ["id"], JoinType.FULL)
+            assert len(result) == 3  # 1 match + 1 left-only + 1 right-only
+        finally:
+            os.unlink(right_path)
+
+    def test_join_no_matches(self):
+        right_path = self._write_csv("id,salary\n99,1000\n")
+        try:
+            left = [{"id": 1, "name": "Alice"}]
+            result = op_join_full(left, right_path, ["id"], JoinType.INNER)
+            assert len(result) == 0
+        finally:
+            os.unlink(right_path)
+
+    def test_join_column_conflict(self):
+        """Non-join columns with same name get aliases."""
+        right_path = self._write_csv("id,name\n1,Engineering\n")
+        try:
+            left = [{"id": 1, "name": "Alice"}]
+            result = op_join_full(left, right_path, ["id"], JoinType.INNER)
+            assert len(result) == 1
+            row = result[0]
+            # Both sides have 'name' — should be aliased
