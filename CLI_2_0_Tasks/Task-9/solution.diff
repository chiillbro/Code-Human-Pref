+"""Tests for output writers."""
+
+import io
+import json
+
+import pytest
+
+from tablesmith.writers import write_csv, write_json, write_jsonl, write_table
+
+
+class TestCSVWriter:
+    def test_basic(self):
+        rows = [{"name": "Alice", "age": 30}, {"name": "Bob", "age": 25}]
+        buf = io.StringIO()
+        write_csv(rows, output=buf)
+        lines = buf.getvalue().strip().split("\n")
+        assert lines[0] == "name,age"
+        assert lines[1] == "Alice,30"
+
+    def test_null_values(self):
+        rows = [{"a": None}]
+        buf = io.StringIO()
+        write_csv(rows, output=buf)
+        lines = buf.getvalue().strip().split("\n")
+        # csv module quotes empty-string fields as ""
+        assert lines[1] in ("", '""')
+
+
+class TestJSONWriter:
+    def test_basic(self):
+        rows = [{"name": "Alice", "age": 30}]
+        buf = io.StringIO()
+        write_json(rows, output=buf)
+        data = json.loads(buf.getvalue())
+        assert len(data) == 1
+        assert data[0]["name"] == "Alice"
+
+
+class TestJSONLWriter:
+    def test_basic(self):
+        rows = [{"a": 1}, {"a": 2}]
+        buf = io.StringIO()
+        write_jsonl(rows, output=buf)
+        lines = buf.getvalue().strip().split("\n")
+        assert len(lines) == 2
+        assert json.loads(lines[0]) == {"a": 1}
+
+
+class TestTableWriter:
+    def test_basic_formatting(self):
+        rows = [{"name": "Alice", "age": 30}, {"name": "Bob", "age": 25}]
+        buf = io.StringIO()
+        write_table(rows, output=buf)
+        output = buf.getvalue()
+        assert "Alice" in output
+        assert "Bob" in output
+        assert "(2 rows)" in output
+
+    def test_empty_result(self):
+        buf = io.StringIO()
+        write_table([], output=buf)
+        assert "empty result set" in buf.getvalue()
+
+    def test_null_displayed(self):
+        rows = [{"a": None}]
+        buf = io.StringIO()
+        write_table(rows, output=buf)
+        assert "NULL" in buf.getvalue()
