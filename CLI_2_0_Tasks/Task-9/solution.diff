+"""Core data types for tablesmith."""
+
+from __future__ import annotations
+
+import enum
+from dataclasses import dataclass, field
+from typing import Any
+
+
+class ColumnType(enum.Enum):
+    INTEGER = "integer"
+    FLOAT = "float"
+    BOOLEAN = "boolean"
+    STRING = "string"
+
+
+class JoinType(enum.Enum):
+    INNER = "inner"
+    LEFT = "left"
+    RIGHT = "right"
+    FULL = "full"
+
+
+class SortOrder(enum.Enum):
+    ASC = "asc"
+    DESC = "desc"
+
+
+class NullOrder(enum.Enum):
+    NULLS_FIRST = "nulls_first"
+    NULLS_LAST = "nulls_last"
+
+
+# Sentinel for NULL values (distinct from None in Python semantics context,
+# but we use None throughout for simplicity — this constant documents intent).
+NULL = None
+
+
+@dataclass
+class Column:
+    name: str
+    col_type: ColumnType = ColumnType.STRING
+
+
+@dataclass
+class Schema:
+    columns: list[Column] = field(default_factory=list)
+
+    @property
+    def column_names(self) -> list[str]:
+        return [c.name for c in self.columns]
+
+    def get_type(self, name: str) -> ColumnType | None:
+        for c in self.columns:
+            if c.name == name:
+                return c.col_type
+        return None
+
+    def has_column(self, name: str) -> bool:
+        return any(c.name == name for c in self.columns)
+
+
+# A Row is a dict mapping column names to values.
+# NULL is represented by Python None.
+Row = dict[str, Any]
+
+
+@dataclass
+class SortSpec:
+    column: str
+    order: SortOrder = SortOrder.ASC
+    null_order: NullOrder = NullOrder.NULLS_LAST
+
+
+@dataclass
+class AggregateSpec:
+    func: str  # count, count_distinct, sum, avg, min, max
+    column: str | None  # None for count(*)
+    alias: str
+
+
+class TablesmithError(Exception):
+    """Base error for tablesmith."""
+
+
+class ValidationError(TablesmithError):
+    """Pipeline or schema validation error."""
+
+
+class DataError(TablesmithError):
+    """Runtime data processing error."""
+
+
+class ExpressionError(TablesmithError):
+    """Expression parsing or evaluation error."""
