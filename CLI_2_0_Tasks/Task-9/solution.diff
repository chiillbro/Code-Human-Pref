+"""Tests for the expression tokenizer, parser, and evaluator."""
+
+import pytest
+
+from tablesmith.expression import (
+    AliasNode,
+    BinaryOpNode,
+    ColumnRefNode,
+    LiteralNode,
+    NullCheckNode,
+    UnaryOpNode,
+    eval_filter,
+    evaluate,
+    parse_filter,
+    parse_project_list,
+    tokenize,
+    TT,
+)
+from tablesmith.models import ExpressionError, Schema, Column, ColumnType
+
+
+# ---------------------------------------------------------------------------
+# Tokenizer tests
+# ---------------------------------------------------------------------------
+
+class TestTokenizer:
+    def test_simple_comparison(self):
+        tokens = tokenize("age > 30")
+        types = [t.tt for t in tokens]
+        assert types == [TT.IDENT, TT.GT, TT.INTEGER, TT.EOF]
+
+    def test_string_literal_with_spaces(self):
+        tokens = tokenize("name = 'John Doe'")
+        assert tokens[0].tt == TT.IDENT
+        assert tokens[0].value == "name"
+        assert tokens[1].tt == TT.EQ
+        assert tokens[2].tt == TT.STRING
+        assert tokens[2].value == "John Doe"
+
+    def test_string_literal_with_escaped_quote(self):
+        tokens = tokenize(r"name = 'O\'Brien'")
+        assert tokens[2].value == "O'Brien"
+
+    def test_keyword_in_string_not_matched(self):
+        """'ANDROID Team' should be a single string, not broken by 'AND'."""
+        tokens = tokenize("dept = 'ANDROID Team'")
+        assert tokens[2].tt == TT.STRING
+        assert tokens[2].value == "ANDROID Team"
+
+    def test_compound_expression(self):
+        tokens = tokenize("age > 30 AND dept != 'HR'")
+        types = [t.tt for t in tokens]
+        assert TT.AND in types
+        assert TT.NEQ in types
+
+    def test_parentheses(self):
+        tokens = tokenize("(a > 1) OR (b < 2)")
+        types = [t.tt for t in tokens]
+        assert types.count(TT.LPAREN) == 2
+        assert types.count(TT.RPAREN) == 2
+
+    def test_float_literal(self):
+        tokens = tokenize("salary > 50000.50")
+        assert tokens[2].tt == TT.FLOAT
+        assert tokens[2].value == 50000.50
+
+    def test_boolean_literal(self):
+        tokens = tokenize("active = true")
+        assert tokens[2].tt == TT.BOOLEAN
+        assert tokens[2].value is True
+
+    def test_null_literal(self):
+        tokens = tokenize("val = NULL")
+        assert tokens[2].tt == TT.NULL_LIT
+
+    def test_concat_operator(self):
+        tokens = tokenize("a || b")
+        assert tokens[1].tt == TT.CONCAT
+
+    def test_is_null_operator(self):
+        tokens = tokenize("email is_null")
+        assert tokens[1].tt == TT.IS_NULL
+
+    def test_is_not_null_operator(self):
+        tokens = tokenize("email is_not_null")
+        assert tokens[1].tt == TT.IS_NOT_NULL
+
+    def test_unterminated_string(self):
+        with pytest.raises(ExpressionError, match="Unterminated string"):
+            tokenize("name = 'abc")
+
+    def test_unexpected_character(self):
+        with pytest.raises(ExpressionError, match="Unexpected character"):
+            tokenize("a @ b")
+
+
+# ---------------------------------------------------------------------------
+# Parser tests
+# ---------------------------------------------------------------------------
+
+class TestParser:
+    def test_simple_comparison(self):
+        ast = parse_filter("age > 30")
+        assert isinstance(ast, BinaryOpNode)
+        assert ast.op == ">"
+        assert isinstance(ast.left, ColumnRefNode)
+        assert isinstance(ast.right, LiteralNode)
+        assert ast.right.value == 30
+
+    def test_and_or_precedence(self):
+        """AND binds tighter than OR."""
+        ast = parse_filter("a = 1 OR b = 2 AND c = 3")
+        # Should parse as: a=1 OR (b=2 AND c=3)
+        assert isinstance(ast, BinaryOpNode)
+        assert ast.op == "OR"
+        assert isinstance(ast.right, BinaryOpNode)
+        assert ast.right.op == "AND"
+
+    def test_not_operator(self):
+        ast = parse_filter("NOT active = true")
+        assert isinstance(ast, UnaryOpNode)
+        assert ast.op == "NOT"
+
+    def test_parentheses_override_precedence(self):
+        ast = parse_filter("(a = 1 OR b = 2) AND c = 3")
+        assert isinstance(ast, BinaryOpNode)
+        assert ast.op == "AND"
+        assert isinstance(ast.left, BinaryOpNode)
+        assert ast.left.op == "OR"
+
+    def test_is_null(self):
+        ast = parse_filter("email is_null")
+        assert isinstance(ast, NullCheckNode)
+        assert ast.is_null is True
+
+    def test_is_not_null(self):
+        ast = parse_filter("email is_not_null")
+        assert isinstance(ast, NullCheckNode)
+        assert ast.is_null is False
+
+    def test_string_operators(self):
+        for op in ["contains", "startswith", "endswith"]:
+            ast = parse_filter(f"name {op} 'test'")
+            assert isinstance(ast, BinaryOpNode)
+            assert ast.op == op
+
+    def test_arithmetic_in_filter(self):
+        ast = parse_filter("salary * 1.1 > 50000")
+        assert isinstance(ast, BinaryOpNode)
+        assert ast.op == ">"
+        assert isinstance(ast.left, BinaryOpNode)
+        assert ast.left.op == "*"
+
+
+class TestProjectParser:
+    def test_simple_columns(self):
+        items = parse_project_list("name, age, dept")
+        assert len(items) == 3
+        assert all(isinstance(i, AliasNode) for i in items)
+        assert items[0].alias == "name"
+        assert items[1].alias == "age"
+
+    def test_alias(self):
+        items = parse_project_list("salary * 1.1 AS adjusted")
+        assert len(items) == 1
+        assert items[0].alias == "adjusted"
+
+    def test_concat(self):
+        items = parse_project_list("first || ' ' || last AS full_name")
+        assert items[0].alias == "full_name"
+
+    def test_mixed(self):
+        items = parse_project_list("name, salary * 12 AS annual")
+        assert len(items) == 2
+        assert items[0].alias == "name"
+        assert items[1].alias == "annual"
+
+
+# ---------------------------------------------------------------------------
+# Evaluator tests — NULL semantics (SQL three-valued logic)
+# ---------------------------------------------------------------------------
+
+class TestEvaluatorNulls:
+    def test_null_equals_null_is_null(self):
+        row = {"a": None}
+        ast = parse_filter("a = NULL")
+        result = evaluate(ast, row)
+        assert result is None  # NULL = NULL => NULL
+
+    def test_null_gt_number_is_null(self):
+        row = {"a": None}
+        ast = parse_filter("a > 5")
+        result = evaluate(ast, row)
+        assert result is None
+
+    def test_not_null_comparison_is_null(self):
+        """NOT (NULL > 5) => NOT NULL => NULL."""
+        row = {"a": None}
+        ast = parse_filter("NOT (a > 5)")
+        result = evaluate(ast, row)
+        assert result is None
+
+    def test_is_null_on_null(self):
+        row = {"a": None}
+        assert eval_filter("a is_null", row) is True
+
+    def test_is_null_on_value(self):
+        row = {"a": 5}
+        assert eval_filter("a is_null", row) is False
+
+    def test_is_not_null_on_null(self):
+        row = {"a": None}
+        assert eval_filter("a is_not_null", row) is False
+
+    def test_is_not_null_on_value(self):
+        row = {"a": 5}
+        assert eval_filter("a is_not_null", row) is True
+
+    def test_null_and_true_is_null(self):
+        row = {"a": None, "b": 5}
+        ast = parse_filter("a > 1 AND b > 1")
+        result = evaluate(ast, row)
+        # a>1 is NULL, b>1 is True => NULL AND True => NULL
+        assert result is None
+
+    def test_false_and_null_is_false(self):
+        row = {"a": None, "b": 0}
+        ast = parse_filter("b > 1 AND a > 1")
+        result = evaluate(ast, row)
+        # b>1 is False => False AND anything => False
+        assert result is False
+
+    def test_null_or_true_is_true(self):
+        row = {"a": None, "b": 5}
+        ast = parse_filter("a > 1 OR b > 1")
+        result = evaluate(ast, row)
+        assert result is True
+
+    def test_null_or_false_is_null(self):
+        row = {"a": None, "b": 0}
+        ast = parse_filter("a > 1 OR b > 1")
+        result = evaluate(ast, row)
+        assert result is None
+
+    def test_null_arithmetic_yields_null(self):
+        row = {"a": None, "b": 5}
+        ast = parse_filter("a + b > 0")
+        result = evaluate(ast, row)
+        assert result is None  # NULL + 5 => NULL, NULL > 0 => NULL
+
+    def test_eval_filter_null_is_false(self):
+        """eval_filter converts NULL to False for filtering."""
+        row = {"a": None}
+        assert eval_filter("a > 5", row) is False
+
+
+class TestEvaluatorComparisons:
+    def test_eq(self):
+        assert eval_filter("x = 10", {"x": 10}) is True
+        assert eval_filter("x = 10", {"x": 5}) is False
+
+    def test_neq(self):
+        assert eval_filter("x != 10", {"x": 5}) is True
+
+    def test_gt_lt(self):
+        assert eval_filter("x > 5", {"x": 10}) is True
+        assert eval_filter("x < 5", {"x": 10}) is False
+
+    def test_gte_lte(self):
+        assert eval_filter("x >= 10", {"x": 10}) is True
+        assert eval_filter("x <= 10", {"x": 10}) is True
+
+    def test_string_comparison(self):
+        assert eval_filter("name = 'Alice'", {"name": "Alice"}) is True
+        assert eval_filter("name != 'Alice'", {"name": "Bob"}) is True
+
+    def test_contains(self):
+        assert eval_filter("msg contains 'error'", {"msg": "fatal error occurred"}) is True
+        assert eval_filter("msg contains 'error'", {"msg": "all good"}) is False
+
+    def test_startswith(self):
+        assert eval_filter("name startswith 'Al'", {"name": "Alice"}) is True
+
+    def test_endswith(self):
+        assert eval_filter("name endswith 'ce'", {"name": "Alice"}) is True
+
+    def test_division_by_zero_yields_null(self):
+        row = {"a": 10, "b": 0}
+        ast = parse_filter("a / b > 0")
+        result = evaluate(ast, row)
+        assert result is None  # 10/0 => NULL, NULL > 0 => NULL
+
+    def test_column_not_found(self):
+        with pytest.raises(ExpressionError, match="not found"):
+            eval_filter("nonexistent > 5", {"x": 1})
+
+
+class TestEvaluatorArithmetic:
+    def test_add_int(self):
+        items = parse_project_list("a + b AS total")
+        result = evaluate(items[0], {"a": 3, "b": 4})
+        assert result == 7
+
+    def test_int_plus_float(self):
+        items = parse_project_list("a + b AS total")
+        result = evaluate(items[0], {"a": 3, "b": 1.5})
+        assert result == 4.5
+
+    def test_multiply(self):
+        items = parse_project_list("salary * 1.1 AS adjusted")
+        result = evaluate(items[0], {"salary": 50000})
+        assert result == pytest.approx(55000.0)
+
+    def test_divide_by_zero(self):
+        items = parse_project_list("a / b AS ratio")
+        result = evaluate(items[0], {"a": 10, "b": 0})
+        assert result is None
+
+    def test_null_arithmetic(self):
+        items = parse_project_list("a + b AS total")
+        result = evaluate(items[0], {"a": None, "b": 5})
+        assert result is None
+
+    def test_string_concat(self):
+        items = parse_project_list("first || ' ' || last AS name")
+        result = evaluate(items[0], {"first": "John", "last": "Doe"})
+        assert result == "John Doe"
+
+    def test_unary_minus(self):
+        items = parse_project_list("-salary AS neg")
+        result = evaluate(items[0], {"salary": 50000})
+        assert result == -50000
