+"""Data readers for CSV, JSON, and JSONL with type inference and streaming."""
+
+from __future__ import annotations
+
+import csv
+import io
+import json
+import sys
+from pathlib import Path
+from typing import Generator, TextIO
+
+from tablesmith.models import Column, ColumnType, DataError, Row, Schema
+
+
+# ---------------------------------------------------------------------------
+# Type inference
+# ---------------------------------------------------------------------------
+
+_TYPE_SAMPLE_SIZE = 100
+
+
+def _try_int(v: str) -> bool:
+    try:
+        int(v)
+        return True
+    except (ValueError, OverflowError):
+        return False
+
+
+def _try_float(v: str) -> bool:
+    try:
+        float(v)
+        return True
+    except (ValueError, OverflowError):
+        return False
+
+
+def _is_bool(v: str) -> bool:
+    return v.lower() in ("true", "false", "1", "0")
+
+
+def infer_column_type(values: list[Any]) -> ColumnType:
+    """Infer the column type from a sample of non-null values."""
+    non_null = [v for v in values if v is not None]
+    if not non_null:
+        return ColumnType.STRING  # All nulls — default to string
+
+    # Check if already typed (from JSON)
+    if all(isinstance(v, bool) for v in non_null):
+        return ColumnType.BOOLEAN
+    if all(isinstance(v, int) and not isinstance(v, bool) for v in non_null):
+        return ColumnType.INTEGER
+    if all(isinstance(v, (int, float)) and not isinstance(v, bool) for v in non_null):
+        return ColumnType.FLOAT
+
+    # String-based inference (from CSV)
+    str_vals = [str(v) for v in non_null]
+
+    if all(_is_bool(s) for s in str_vals):
+        return ColumnType.BOOLEAN
+    if all(_try_int(s) for s in str_vals):
+        return ColumnType.INTEGER
+    if all(_try_float(s) for s in str_vals):
+        return ColumnType.FLOAT
+    return ColumnType.STRING
+
+
+def _coerce_value(value: Any, col_type: ColumnType) -> Any:
+    """Coerce a raw value to its inferred type."""
+    if value is None:
+        return None
+    if col_type == ColumnType.INTEGER:
+        try:
+            return int(value) if not isinstance(value, int) or isinstance(value, bool) else value
+        except (ValueError, TypeError):
+            return value
+    if col_type == ColumnType.FLOAT:
+        try:
+            return float(value) if not isinstance(value, float) else value
+        except (ValueError, TypeError):
+            return value
+    if col_type == ColumnType.BOOLEAN:
+        if isinstance(value, bool):
+            return value
+        s = str(value).lower()
+        if s in ("true", "1"):
+            return True
+        if s in ("false", "0"):
+            return False
+        return value
+    return value  # STRING
+
+
+# We need Any for type inference
+from typing import Any
+
+
+# ---------------------------------------------------------------------------
+# CSV Reader
+# ---------------------------------------------------------------------------
+
+class CSVReader:
+    """Streaming CSV reader with type inference."""
+
+    def __init__(
+        self,
+        path: str | Path,
+        delimiter: str = ",",
+        quotechar: str = '"',
+        encoding: str = "utf-8",
+    ) -> None:
+        self._path = Path(path)
+        self._delimiter = delimiter
+        self._quotechar = quotechar
+        self._encoding = encoding
+        self._schema: Schema | None = None
+        self._skipped_count = 0
+
+    @property
+    def schema(self) -> Schema:
+        if self._schema is None:
+            self._infer_schema()
+        return self._schema  # type: ignore[return-value]
+
+    @property
+    def skipped_count(self) -> int:
+        return self._skipped_count
+
+    def _infer_schema(self) -> None:
+        samples: dict[str, list[Any]] = {}
+        headers: list[str] = []
+        count = 0
+
+        with open(self._path, "r", encoding=self._encoding, newline="") as f:
+            reader = csv.reader(f, delimiter=self._delimiter, quotechar=self._quotechar)
+            headers = next(reader)
+            for h in headers:
+                samples[h] = []
+
+            for row_values in reader:
+                if count >= _TYPE_SAMPLE_SIZE:
+                    break
+                if len(row_values) != len(headers):
+                    continue  # Skip malformed for inference
+                for h, v in zip(headers, row_values):
+                    samples[h].append(None if v == "" else v)
+                count += 1
+
+        columns = []
+        for h in headers:
+            col_type = infer_column_type(samples.get(h, []))
+            columns.append(Column(name=h, col_type=col_type))
+        self._schema = Schema(columns=columns)
+
+    def read(self) -> Generator[Row, None, None]:
+        """Yield rows one at a time as dicts, coercing to inferred types."""
+        schema = self.schema
+        headers = schema.column_names
+        col_types = {c.name: c.col_type for c in schema.columns}
+        self._skipped_count = 0
+        line_num = 1  # Header is line 1
+
+        with open(self._path, "r", encoding=self._encoding, newline="") as f:
+            reader = csv.reader(f, delimiter=self._delimiter, quotechar=self._quotechar)
+            next(reader)  # Skip header
+            for row_values in reader:
+                line_num += 1
+                if len(row_values) != len(headers):
+                    print(
+                        f"Warning: {self._path}:{line_num}: expected {len(headers)} "
+                        f"columns, got {len(row_values)} — skipping row",
+                        file=sys.stderr,
+                    )
+                    self._skipped_count += 1
+                    continue
+                row: Row = {}
+                for h, v in zip(headers, row_values):
+                    raw = None if v == "" else v
+                    row[h] = _coerce_value(raw, col_types[h])
+                yield row
+
+
+# ---------------------------------------------------------------------------
+# JSON Reader
+# ---------------------------------------------------------------------------
+
+class JSONReader:
+    """Reader for JSON arrays of objects."""
+
+    def __init__(self, path: str | Path) -> None:
+        self._path = Path(path)
+        self._schema: Schema | None = None
+
+    @property
+    def schema(self) -> Schema:
+        if self._schema is None:
+            self._infer_schema()
+        return self._schema  # type: ignore[return-value]
+
+    def _infer_schema(self) -> None:
+        data = self._load_all()
+        if not data:
+            self._schema = Schema(columns=[])
+            return
+
+        # Collect all column names preserving first-seen order
+        col_names: list[str] = []
+        seen: set[str] = set()
+        samples: dict[str, list[Any]] = {}
+
+        for i, obj in enumerate(data):
+            for key in obj:
+                if key not in seen:
+                    col_names.append(key)
+                    seen.add(key)
+                    samples[key] = []
+
+            if i < _TYPE_SAMPLE_SIZE:
+                for key in col_names:
+                    val = obj.get(key)  # Missing key → None
+                    samples.setdefault(key, []).append(val)
+
+        columns = [Column(name=n, col_type=infer_column_type(samples.get(n, []))) for n in col_names]
+        self._schema = Schema(columns=columns)
+
+    def _load_all(self) -> list[dict]:
+        with open(self._path, "r", encoding="utf-8") as f:
+            data = json.load(f)
+        if not isinstance(data, list):
+            raise DataError(f"{self._path}: expected a JSON array at top level")
+        return data
+
+    def read(self) -> Generator[Row, None, None]:
+        schema = self.schema
+        col_types = {c.name: c.col_type for c in schema.columns}
+        headers = set(schema.column_names)
+        data = self._load_all()
+
+        for obj in data:
+            row: Row = {}
+            for h in schema.column_names:
+                raw = obj.get(h)
+                row[h] = _coerce_value(raw, col_types[h])
+            yield row
+
+
+# ---------------------------------------------------------------------------
+# JSONL Reader
+# ---------------------------------------------------------------------------
+
+class JSONLReader:
+    """Streaming reader for JSON Lines (one JSON object per line)."""
+
+    def __init__(self, path: str | Path) -> None:
+        self._path = Path(path)
+        self._schema: Schema | None = None
+        self._skipped_count = 0
+
+    @property
+    def schema(self) -> Schema:
+        if self._schema is None:
+            self._infer_schema()
+        return self._schema  # type: ignore[return-value]
+
+    @property
+    def skipped_count(self) -> int:
+        return self._skipped_count
+
+    def _infer_schema(self) -> None:
+        col_names: list[str] = []
+        seen: set[str] = set()
+        samples: dict[str, list[Any]] = {}
+        count = 0
+
+        with open(self._path, "r", encoding="utf-8") as f:
+            for line in f:
+                line = line.strip()
+                if not line:
+                    continue
+                try:
+                    obj = json.loads(line)
+                except json.JSONDecodeError:
+                    continue
+                if not isinstance(obj, dict):
+                    continue
+
+                for key in obj:
+                    if key not in seen:
+                        col_names.append(key)
+                        seen.add(key)
+                        samples[key] = []
+
+                if count < _TYPE_SAMPLE_SIZE:
+                    for key in col_names:
+                        samples.setdefault(key, []).append(obj.get(key))
+
+                count += 1
+                if count >= _TYPE_SAMPLE_SIZE:
+                    break
+
+        columns = [Column(name=n, col_type=infer_column_type(samples.get(n, []))) for n in col_names]
+        self._schema = Schema(columns=columns)
+
+    def read(self) -> Generator[Row, None, None]:
+        schema = self.schema
+        col_types = {c.name: c.col_type for c in schema.columns}
+        self._skipped_count = 0
+        line_num = 0
+
+        with open(self._path, "r", encoding="utf-8") as f:
+            for line in f:
+                line_num += 1
+                line = line.strip()
+                if not line:
+                    continue
+                try:
+                    obj = json.loads(line)
+                except json.JSONDecodeError as e:
+                    print(
+                        f"Warning: {self._path}:{line_num}: invalid JSON — {e} — skipping",
+                        file=sys.stderr,
+                    )
+                    self._skipped_count += 1
+                    continue
+                if not isinstance(obj, dict):
+                    self._skipped_count += 1
+                    continue
+
+                row: Row = {}
+                for h in schema.column_names:
+                    raw = obj.get(h)
+                    row[h] = _coerce_value(raw, col_types[h])
+                yield row
+
+
+# ---------------------------------------------------------------------------
+# Factory
+# ---------------------------------------------------------------------------
+
+def detect_format(path: str | Path) -> str:
+    """Detect file format by extension."""
+    p = Path(path)
+    ext = p.suffix.lower()
+    if ext == ".csv":
+        return "csv"
+    if ext == ".json":
+        return "json"
+    if ext == ".jsonl":
+        return "jsonl"
+    raise DataError(
+        f"Cannot detect format for '{p.name}'. "
+        "Use --format=csv|json|jsonl to specify explicitly."
+    )
+
+
+def make_reader(
+    path: str | Path,
+    fmt: str | None = None,
+    delimiter: str = ",",
+    quotechar: str = '"',
+    encoding: str = "utf-8",
+) -> CSVReader | JSONReader | JSONLReader:
+    """Create a reader for the given file path and format."""
+    if fmt is None:
+        fmt = detect_format(path)
+
+    if fmt == "csv":
+        return CSVReader(path, delimiter=delimiter, quotechar=quotechar, encoding=encoding)
+    if fmt == "json":
+        return JSONReader(path)
+    if fmt == "jsonl":
+        return JSONLReader(path)
+    raise DataError(f"Unknown format: {fmt!r}")
diff --git a/src/tablesmith/writers.py b/src/tablesmith/writers.py
new file mode 100644
index 0000000..75378f0
--- /dev/null
+++ b/src/tablesmith/writers.py
@@ -0,0 +1,177 @@
+"""Output writers: CSV, JSON, JSONL, and formatted table."""
+
+from __future__ import annotations
+
+import csv
+import io
+import json
+import sys
+from pathlib import Path
+from typing import Any, Iterable, TextIO
+
+from tablesmith.models import Row
+
+
+# ---------------------------------------------------------------------------
+# CSV Writer
+# ---------------------------------------------------------------------------
+
+def write_csv(
+    rows: Iterable[Row],
+    output: TextIO | None = None,
+    delimiter: str = ",",
+    quotechar: str = '"',
+) -> None:
+    """Write rows as CSV to *output* (defaults to stdout)."""
+    out = output or sys.stdout
+    writer = None
+    headers: list[str] | None = None
+
+    for row in rows:
+        if headers is None:
+            headers = list(row.keys())
+            writer = csv.writer(
+                out, delimiter=delimiter, quotechar=quotechar,
+                lineterminator="\n",
+            )
+            writer.writerow(headers)
+        assert writer is not None
+        writer.writerow([_csv_encode(row.get(h)) for h in headers])
+
+
+def _csv_encode(value: Any) -> str:
+    if value is None:
+        return ""
+    if isinstance(value, bool):
+        return str(value).lower()
+    return str(value)
+
+
+# ---------------------------------------------------------------------------
+# JSON Writer
+# ---------------------------------------------------------------------------
+
+def write_json(
+    rows: Iterable[Row],
+    output: TextIO | None = None,
+) -> None:
+    """Write rows as a JSON array to *output* (defaults to stdout)."""
+    out = output or sys.stdout
+    materialized = list(rows)
+    # Convert None to JSON null (json.dumps handles this natively)
+    json.dump(materialized, out, indent=2, default=str)
+    out.write("\n")
+
+
+# ---------------------------------------------------------------------------
+# JSONL Writer
+# ---------------------------------------------------------------------------
+
+def write_jsonl(
+    rows: Iterable[Row],
+    output: TextIO | None = None,
+) -> None:
+    """Write rows as JSON Lines to *output* (defaults to stdout)."""
+    out = output or sys.stdout
+    for row in rows:
+        json.dump(row, out, default=str)
+        out.write("\n")
+
+
+# ---------------------------------------------------------------------------
+# Table Writer (human-readable)
+# ---------------------------------------------------------------------------
+
+_MAX_COL_WIDTH = 40
+
+
+def write_table(
+    rows: Iterable[Row],
+    output: TextIO | None = None,
+) -> None:
+    """Write rows as a human-readable aligned table to *output*."""
+    out = output or sys.stdout
+    materialized = list(rows)
+
+    if not materialized:
+        out.write("(empty result set)\n")
+        return
+
+    headers = list(materialized[0].keys())
+
+    # Compute column widths
+    widths: dict[str, int] = {}
+    for h in headers:
+        widths[h] = len(h)
+    for row in materialized:
+        for h in headers:
+            val = _format_cell(row.get(h))
+            widths[h] = max(widths[h], len(val))
+
+    # Cap at max width
+    for h in headers:
+        widths[h] = min(widths[h], _MAX_COL_WIDTH)
+
+    # Header row
+    header_line = " | ".join(h.ljust(widths[h])[:widths[h]] for h in headers)
+    separator = "-+-".join("-" * widths[h] for h in headers)
+    out.write(header_line + "\n")
+    out.write(separator + "\n")
+
+    # Data rows
+    for row in materialized:
+        cells = []
+        for h in headers:
+            val = _format_cell(row.get(h))
+            if len(val) > widths[h]:
+                val = val[: widths[h] - 3] + "..."
+            cells.append(val.ljust(widths[h]))
+        out.write(" | ".join(cells) + "\n")
+
+    out.write(f"\n({len(materialized)} row{'s' if len(materialized) != 1 else ''})\n")
+
+
+def _format_cell(value: Any) -> str:
+    if value is None:
+        return "NULL"
+    if isinstance(value, bool):
+        return str(value).lower()
+    if isinstance(value, float):
+        # Avoid excessive decimals
+        if value == int(value):
+            return str(int(value))
+        return f"{value:.4f}".rstrip("0").rstrip(".")
+    return str(value)
+
+
+# ---------------------------------------------------------------------------
+# Writer dispatch
+# ---------------------------------------------------------------------------
+
+def write_output(
+    rows: Iterable[Row],
+    fmt: str = "table",
+    path: str | None = None,
+    delimiter: str = ",",
+    quotechar: str = '"',
+) -> None:
+    """Write rows in the specified format to a path or stdout."""
+    if path:
+        f = open(path, "w", encoding="utf-8")
+    else:
+        f = None
+
+    try:
+        if fmt == "csv":
+            write_csv(rows, output=f, delimiter=delimiter, quotechar=quotechar)
+        elif fmt == "json":
+            write_json(rows, output=f)
+        elif fmt == "jsonl":
+            write_jsonl(rows, output=f)
+        elif fmt == "table":
+            write_table(rows, output=f)
+        else:
+            raise ValueError(f"Unknown output format: {fmt!r}")
+    finally:
+        if f is not None:
+            f.close()
