diff --git a/src/tablesmith/cli.py b/src/tablesmith/cli.py
new file mode 100644
index 0000000..f222d90
--- /dev/null
+++ b/src/tablesmith/cli.py
@@ -0,0 +1,265 @@
+"""CLI entry point for tablesmith."""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from typing import Iterable
+
+from tablesmith import __version__
+from tablesmith.models import (
+    DataError,
+    ExpressionError,
+    JoinType,
+    NullOrder,
+    Row,
+    Schema,
+    SortOrder,
+    SortSpec,
+    ValidationError,
+)
+from tablesmith.operations import (
+    op_distinct,
+    op_filter,
+    op_group,
+    op_having,
+    op_join_full,
+    op_limit,
+    op_project,
+    op_sort,
+    parse_agg_spec,
+)
+from tablesmith.pipeline import execute_pipeline, load_pipeline, validate_pipeline
+from tablesmith.readers import make_reader
+from tablesmith.writers import write_output
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(
+        prog="tablesmith",
+        description="Tabular data transformation pipeline engine",
+    )
+    parser.add_argument("--version", action="version", version=f"tablesmith {__version__}")
+
+    sub = parser.add_subparsers(dest="command")
+
+    # --- run ---------------------------------------------------------------
+    run_p = sub.add_parser("run", help="Execute a pipeline definition file")
+    run_p.add_argument("pipeline", help="Path to pipeline JSON file")
+
+    # --- query -------------------------------------------------------------
+    query_p = sub.add_parser("query", help="Ad-hoc query with inline flags")
+    query_p.add_argument("file", help="Input data file")
+    query_p.add_argument("--filter", dest="filter_expr", help="Filter expression")
+    query_p.add_argument("--project", dest="project_cols", help="Comma-separated column specs")
+    query_p.add_argument("--sort", dest="sort_spec", help="Sort spec: col[:asc|desc],...")
+    query_p.add_argument("--group-by", dest="group_by", help="Group-by columns (comma-separated)")
+    query_p.add_argument("--aggs", dest="aggs", help="Aggregate expressions (comma-separated)")
+    query_p.add_argument("--having", dest="having_expr", help="Having expression")
+    query_p.add_argument("--limit", dest="limit_n", type=int, help="Limit N rows")
+    query_p.add_argument("--distinct", dest="distinct_cols", nargs="?", const="__all__", help="Distinct (optionally specify cols)")
+    query_p.add_argument("--output", dest="output_path", help="Output file path")
+    query_p.add_argument("--format", dest="output_format", default="table", choices=["csv", "json", "jsonl", "table"])
+    query_p.add_argument("--input-format", dest="input_format", choices=["csv", "json", "jsonl"])
+    query_p.add_argument("--delimiter", default=",")
+    query_p.add_argument("--quotechar", default='"')
+
+    # --- inspect -----------------------------------------------------------
+    inspect_p = sub.add_parser("inspect", help="Print inferred schema for a data file")
+    inspect_p.add_argument("file", help="Input data file")
+    inspect_p.add_argument("--format", dest="input_format", choices=["csv", "json", "jsonl"])
+
+    # --- validate ----------------------------------------------------------
+    validate_p = sub.add_parser("validate", help="Validate a pipeline definition file")
+    validate_p.add_argument("pipeline", help="Path to pipeline JSON file")
+
+    # --- version -----------------------------------------------------------
+    sub.add_parser("version", help="Print version")
+
+    args = parser.parse_args(argv)
+
+    if args.command is None:
+        parser.print_help()
+        return 1
+
+    try:
+        if args.command == "version":
+            print(f"tablesmith {__version__}")
+            return 0
+
+        if args.command == "validate":
+            return _cmd_validate(args)
+
+        if args.command == "inspect":
+            return _cmd_inspect(args)
+
+        if args.command == "run":
+            return _cmd_run(args)
+
+        if args.command == "query":
+            return _cmd_query(args)
+
+    except ValidationError as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return 1
+    except DataError as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return 2
+    except ExpressionError as e:
+        print(f"Expression error: {e}", file=sys.stderr)
+        return 1
+
+    return 0
+
+
+# ---------------------------------------------------------------------------
+# Subcommands
+# ---------------------------------------------------------------------------
+
+def _cmd_validate(args: argparse.Namespace) -> int:
+    data = load_pipeline(args.pipeline)
+    errors = validate_pipeline(data)
+    if errors:
+        print("Pipeline validation failed:", file=sys.stderr)
+        for err in errors:
+            print(f"  - {err}", file=sys.stderr)
+        return 1
+    print("Pipeline is valid.")
+    return 0
+
+
+def _cmd_inspect(args: argparse.Namespace) -> int:
+    reader = make_reader(args.file, fmt=args.input_format)
+    schema = reader.schema
+
+    # Count rows and nulls
+    total = 0
+    null_counts: dict[str, int] = {c.name: 0 for c in schema.columns}
+    samples: dict[str, list] = {c.name: [] for c in schema.columns}
+
+    for row in reader.read():
+        total += 1
+        for c in schema.columns:
+            val = row.get(c.name)
+            if val is None:
+                null_counts[c.name] += 1
+            elif len(samples[c.name]) < 3:
+                samples[c.name].append(val)
+
+    # Print schema table
+    print(f"File: {args.file}")
+    print(f"Rows: {total}")
+    print()
+    print(f"{'Column':<25} {'Type':<10} {'Nulls':<8} {'Sample Values'}")
+    print(f"{'-'*25} {'-'*10} {'-'*8} {'-'*30}")
+    for c in schema.columns:
+        sample_str = ", ".join(repr(v) for v in samples[c.name])
+        print(f"{c.name:<25} {c.col_type.value:<10} {null_counts[c.name]:<8} {sample_str}")
+
+    return 0
+
+
+def _cmd_run(args: argparse.Namespace) -> int:
+    data = load_pipeline(args.pipeline)
+
+    # Validate first
+    errors = validate_pipeline(data)
+    if errors:
+        print("Pipeline validation failed:", file=sys.stderr)
+        for err in errors:
+            print(f"  - {err}", file=sys.stderr)
+        return 1
+
+    rows = execute_pipeline(data)
+
+    # Output
+    output_conf = data.get("output", {})
+    fmt = output_conf.get("format", "table")
+    path = output_conf.get("path")
+
+    write_output(rows, fmt=fmt, path=path)
+    return 0
+
+
+def _cmd_query(args: argparse.Namespace) -> int:
+    reader = make_reader(
+        args.file,
+        fmt=args.input_format,
+        delimiter=args.delimiter,
+        quotechar=args.quotechar,
+    )
+    schema = reader.schema
+    rows: Iterable[Row] = reader.read()
+
+    # Apply operations in a standard order: filter, join (not in query mode),
+    # project, group, having, sort, distinct, limit.
+
+    if args.filter_expr:
+        rows = op_filter(rows, args.filter_expr, schema)
+
+    if args.project_cols:
+        rows = op_project(rows, args.project_cols, schema)
+
+    if args.group_by:
+        group_cols = [c.strip() for c in args.group_by.split(",")]
+        agg_texts = [a.strip() for a in args.aggs.split(",")] if args.aggs else []
+        agg_specs = [parse_agg_spec(a) for a in agg_texts]
+        rows = op_group(rows, group_cols, agg_specs)
+
+    if args.having_expr:
+        rows = op_having(rows, args.having_expr, schema)
+
+    if args.sort_spec:
+        specs = _parse_cli_sort(args.sort_spec)
+        rows = op_sort(rows, specs)
+
+    if args.distinct_cols:
+        if args.distinct_cols == "__all__":
+            rows = op_distinct(rows)
+        else:
+            cols = [c.strip() for c in args.distinct_cols.split(",")]
+            rows = op_distinct(rows, columns=cols)
+
+    if args.limit_n is not None:
+        rows = op_limit(rows, args.limit_n)
+
+    write_output(
+        rows,
+        fmt=args.output_format,
+        path=args.output_path,
+        delimiter=args.delimiter,
+        quotechar=args.quotechar,
+    )
+
+    # Report skipped rows if applicable
+    if hasattr(reader, "skipped_count") and reader.skipped_count > 0:
+        print(
+            f"\nWarning: {reader.skipped_count} malformed row(s) skipped.",
+            file=sys.stderr,
+        )
+
+    return 0
+
+
+def _parse_cli_sort(spec_str: str) -> list[SortSpec]:
+    """Parse CLI sort spec like 'name:asc,salary:desc:nulls_first'."""
+    specs: list[SortSpec] = []
+    for part in spec_str.split(","):
+        parts = part.strip().split(":")
+        col = parts[0]
+        order = SortOrder.ASC
+        null_order = NullOrder.NULLS_LAST
+
+        for p in parts[1:]:
+            low = p.lower()
+            if low in ("asc", "desc"):
+                order = SortOrder(low)
+            elif low in ("nulls_first", "nulls_last"):
+                null_order = NullOrder(low)
+
+        specs.append(SortSpec(column=col, order=order, null_order=null_order))
+    return specs
+
+
+if __name__ == "__main__":
+    sys.exit(main())
diff --git a/src/tablesmith/expression.py b/src/tablesmith/expression.py
