+
+import pytest
+
+from tablesmith.cli import main
+from tablesmith.pipeline import execute_pipeline
+from tablesmith.writers import write_output
+
+
+class TestEndToEndPipeline:
+    """Full pipeline: multi-step transforms on real CSV data."""
+
+    def _write_csv(self, name: str, content: str) -> str:
+        f = tempfile.NamedTemporaryFile(
+            mode="w", suffix=f"_{name}.csv", delete=False, encoding="utf-8"
+        )
+        f.write(content)
+        f.close()
+        return f.name
+
+    def test_filter_join_group_sort_limit(self):
+        """filter → join → group → sort → limit pipeline."""
+        employees_csv = self._write_csv(
+            "employees",
+            "id,name,age,dept\n"
+            "1,Alice,35,Engineering\n"
+            "2,Bob,28,HR\n"
+            "3,Carol,40,Engineering\n"
+            "4,Dave,32,Engineering\n"
+            "5,Eve,25,Marketing\n"
+            "6,Frank,38,HR\n"
+        )
+        salaries_csv = self._write_csv(
+            "salaries",
+            "id,salary\n"
+            "1,90000\n"
+            "2,60000\n"
+            "3,95000\n"
+            "4,85000\n"
+            "5,70000\n"
+            "6,65000\n"
+        )
+        try:
+            data = {
+                "input": employees_csv,
+                "steps": [
+                    {"op": "filter", "expr": "age > 27"},
+                    {"op": "join", "file": salaries_csv, "on": ["id"], "type": "left"},
+                    {"op": "group", "by": ["dept"], "aggs": [
+                        "count(*) AS headcount",
+                        "avg(salary) AS avg_salary",
+                    ]},
+                    {"op": "sort", "by": [{"column": "avg_salary", "order": "desc"}]},
+                    {"op": "limit", "n": 10},
+                ],
+            }
+            rows = list(execute_pipeline(data))
+
+            # After filter (age>27): Alice(35), Carol(40), Dave(32), Frank(38), Bob(28)
+            # After join: adds salary column
+            # After group: Engineering(Alice,Carol,Dave), HR(Bob,Frank)
+            # avg_salary for Engineering = (90000+95000+85000)/3 = 90000
+            # avg_salary for HR = (60000+65000)/2 = 62500
+            assert len(rows) >= 1
+            assert rows[0]["dept"] == "Engineering"
+            assert rows[0]["avg_salary"] == 90000.0
+        finally:
+            os.unlink(employees_csv)
+            os.unlink(salaries_csv)
+
+    def test_project_with_concat_and_arithmetic(self):
+        csv_path = self._write_csv(
+            "people",
+            "first,last,hourly_rate,hours\n"
+            "John,Doe,25,40\n"
+            "Jane,Smith,30,35\n"
+        )
+        try:
+            data = {
+                "input": csv_path,
+                "steps": [
+                    {"op": "project", "columns": [
+                        "first || ' ' || last AS full_name",
+                        "hourly_rate * hours AS total_pay",
+                    ]},
+                ],
+            }
+            rows = list(execute_pipeline(data))
+            assert rows[0]["full_name"] == "John Doe"
+            assert rows[0]["total_pay"] == 1000
+            assert rows[1]["total_pay"] == 1050
+        finally:
+            os.unlink(csv_path)
+
+    def test_distinct_operation(self):
+        csv_path = self._write_csv(
+            "dupes",
+            "dept,role\nA,dev\nA,dev\nA,mgr\nB,dev\n"
+        )
+        try:
+            data = {
+                "input": csv_path,
+                "steps": [{"op": "distinct"}],
+            }
+            rows = list(execute_pipeline(data))
+            assert len(rows) == 3  # 3 unique rows
+        finally:
+            os.unlink(csv_path)
