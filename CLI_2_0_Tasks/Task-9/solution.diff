+"""Pipeline definition loader, validator, and executor."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any, Generator, Iterable
+
+from tablesmith.models import (
+    JoinType,
+    NullOrder,
+    Row,
+    Schema,
+    SortOrder,
+    SortSpec,
+    ValidationError,
+)
+from tablesmith.operations import (
+    op_distinct,
+    op_filter,
+    op_group,
+    op_having,
+    op_join_full,
+    op_limit,
+    op_project,
+    op_sort,
+    parse_agg_spec,
+)
+from tablesmith.readers import make_reader
+
+
+def load_pipeline(path: str | Path) -> dict[str, Any]:
+    """Load a pipeline definition from a JSON file."""
+    p = Path(path)
+    if not p.exists():
+        raise ValidationError(f"Pipeline file not found: {p}")
+    with open(p, "r", encoding="utf-8") as f:
+        try:
+            data = json.load(f)
+        except json.JSONDecodeError as e:
+            raise ValidationError(f"Invalid JSON in pipeline file: {e}") from e
+
+    if "steps" not in data:
+        raise ValidationError("Pipeline must have a 'steps' array")
+    if not isinstance(data["steps"], list):
+        raise ValidationError("'steps' must be a JSON array")
+    return data
+
+
+def validate_pipeline(data: dict[str, Any]) -> list[str]:
+    """Validate a pipeline definition and return a list of error messages."""
+    errors: list[str] = []
+
+    if "input" not in data and "steps" in data:
+        # input can be implicit for piped data, but we flag it
+        pass
+
+    steps = data.get("steps", [])
+    valid_ops = {"filter", "project", "sort", "group", "having", "join", "limit", "distinct"}
+
+    for i, step in enumerate(steps):
+        if not isinstance(step, dict):
+            errors.append(f"Step {i}: must be a JSON object")
+            continue
+        op = step.get("op")
+        if op not in valid_ops:
+            errors.append(f"Step {i}: unknown operation '{op}'. Valid: {', '.join(sorted(valid_ops))}")
+            continue
+
+        if op == "filter" and "expr" not in step:
+            errors.append(f"Step {i} (filter): missing 'expr'")
+        if op == "project" and "columns" not in step:
+            errors.append(f"Step {i} (project): missing 'columns'")
+        if op == "sort" and "by" not in step:
+            errors.append(f"Step {i} (sort): missing 'by'")
+        if op == "group" and ("by" not in step or "aggs" not in step):
+            errors.append(f"Step {i} (group): missing 'by' and/or 'aggs'")
+        if op == "having" and "expr" not in step:
+            errors.append(f"Step {i} (having): missing 'expr'")
+        if op == "join":
+            if "file" not in step:
+                errors.append(f"Step {i} (join): missing 'file'")
+            if "on" not in step:
+                errors.append(f"Step {i} (join): missing 'on'")
+        if op == "limit" and "n" not in step:
+            errors.append(f"Step {i} (limit): missing 'n'")
+
+    return errors
+
+
+def execute_pipeline(data: dict[str, Any]) -> Iterable[Row]:
+    """Execute a pipeline and return the resulting rows (may be a generator)."""
+    input_path = data.get("input")
+    if not input_path:
+        raise ValidationError("Pipeline must specify an 'input' file path")
+
+    input_format = data.get("input_format")
+    reader = make_reader(input_path, fmt=input_format)
+    schema = reader.schema
+    rows: Iterable[Row] = reader.read()
+
+    for step in data["steps"]:
+        rows = _execute_step(step, rows, schema)
+        # After materializing operations, update schema if we can
+        # (operations that materialize return lists, not generators)
+
+    return rows
+
+
+def _execute_step(step: dict, rows: Iterable[Row], schema: Schema) -> Iterable[Row]:
+    """Execute a single pipeline step."""
+    op = step["op"]
+
+    if op == "filter":
+        return op_filter(rows, step["expr"], schema)
+
+    if op == "project":
+        cols = step["columns"]
+        return op_project(rows, cols, schema)
+
+    if op == "sort":
+        specs = _parse_sort_specs(step["by"])
+        return op_sort(rows, specs)
+
+    if op == "group":
+        group_cols = step["by"]
+        agg_texts = step["aggs"]
+        agg_specs = [parse_agg_spec(a) for a in agg_texts]
+        return op_group(rows, group_cols, agg_specs)
+
+    if op == "having":
+        return op_having(rows, step["expr"], schema)
+
+    if op == "join":
+        join_type = JoinType(step.get("type", "inner"))
+        on_cols = step["on"]
+        right_fmt = step.get("format")
+        left_alias = step.get("left_alias", "_left")
+        right_alias = step.get("right_alias", "_right")
+        return op_join_full(
+            rows, step["file"], on_cols, join_type,
+            right_format=right_fmt,
+            left_alias=left_alias,
+            right_alias=right_alias,
+        )
+
+    if op == "limit":
+        return op_limit(rows, int(step["n"]))
+
+    if op == "distinct":
+        cols = step.get("columns")
+        return op_distinct(rows, columns=cols)
+
+    raise ValidationError(f"Unknown operation: {op!r}")
+
+
+def _parse_sort_specs(by: list) -> list[SortSpec]:
+    """Parse sort specification from pipeline JSON."""
+    specs: list[SortSpec] = []
+    for item in by:
+        if isinstance(item, str):
+            specs.append(SortSpec(column=item))
+        elif isinstance(item, dict):
+            col = item["column"]
+            order = SortOrder(item.get("order", "asc"))
+            null_order_str = item.get("nulls", "nulls_last")
+            null_order = NullOrder(null_order_str)
+            specs.append(SortSpec(column=col, order=order, null_order=null_order))
+        else:
+            raise ValidationError(f"Invalid sort spec: {item!r}")
+    return specs
