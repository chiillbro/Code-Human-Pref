+"""Transformation operations: filter, project, sort, group, join, distinct, limit.
+
+Streaming operations (filter, project, limit) are implemented as generators.
+Materializing operations (sort, group, join, distinct) consume their input.
+"""
+
+from __future__ import annotations
+
+import re
+from collections import defaultdict
+from itertools import islice
+from typing import Any, Generator, Iterable
+
+from tablesmith.expression import (
+    AliasNode,
+    evaluate,
+    parse_filter,
+    parse_project_list,
+)
+from tablesmith.models import (
+    AggregateSpec,
+    Column,
+    ColumnType,
+    ExpressionError,
+    JoinType,
+    NullOrder,
+    Row,
+    Schema,
+    SortOrder,
+    SortSpec,
+    ValidationError,
+)
+from tablesmith.readers import make_reader
+
+
+# ---------------------------------------------------------------------------
+# Filter (streaming)
+# ---------------------------------------------------------------------------
+
+def op_filter(
+    rows: Iterable[Row],
+    expr_text: str,
+    schema: Schema | None = None,
+) -> Generator[Row, None, None]:
+    """Yield only rows where *expr_text* evaluates to True."""
+    ast = parse_filter(expr_text)
+    for row in rows:
+        result = evaluate(ast, row, schema)
+        if result is True:
+            yield row
+
+
+# ---------------------------------------------------------------------------
+# Project (streaming)
+# ---------------------------------------------------------------------------
+
+def op_project(
+    rows: Iterable[Row],
+    columns_spec: str | list[str],
+    schema: Schema | None = None,
+) -> Generator[Row, None, None]:
+    """Select, rename, or compute columns.
+
+    *columns_spec* is either a comma-separated string or a list of strings
+    like ``["name", "salary * 1.1 AS adjusted"]``.
+    """
+    if isinstance(columns_spec, list):
+        spec_text = ", ".join(columns_spec)
+    else:
+        spec_text = columns_spec
+
+    items = parse_project_list(spec_text)
+
+    for row in rows:
+        new_row: Row = {}
+        for item in items:
+            val = evaluate(item.expr, row, schema)
+            new_row[item.alias] = val
+        yield new_row
+
+
+def project_schema(columns_spec: str | list[str], input_schema: Schema) -> Schema:
+    """Derive the output schema after a project operation."""
+    if isinstance(columns_spec, list):
+        spec_text = ", ".join(columns_spec)
+    else:
+        spec_text = columns_spec
+
+    items = parse_project_list(spec_text)
+    columns: list[Column] = []
+    for item in items:
+        # Try to infer type from input schema
+        from tablesmith.expression import ColumnRefNode
+        if isinstance(item.expr, ColumnRefNode):
+            ct = input_schema.get_type(item.expr.name)
+            columns.append(Column(name=item.alias, col_type=ct or ColumnType.STRING))
+        else:
+            columns.append(Column(name=item.alias, col_type=ColumnType.FLOAT))
+    return Schema(columns=columns)
+
+
+# ---------------------------------------------------------------------------
+# Sort (materializing)
+# ---------------------------------------------------------------------------
+
+def op_sort(
+    rows: Iterable[Row],
+    specs: list[SortSpec],
+) -> list[Row]:
+    """Sort rows by the given specifications. Materializes all rows."""
+    materialized = list(rows)
+    if not materialized or not specs:
+        return materialized
+
+    def sort_key(row: Row) -> tuple:
+        key_parts: list[Any] = []
+        for spec in specs:
+            val = row.get(spec.column)
+            is_null = val is None
+            if spec.null_order == NullOrder.NULLS_LAST:
+                null_flag = 1 if is_null else 0
+            else:
+                null_flag = 0 if is_null else 1
+
+            if is_null:
+                comparable = ""  # Placeholder; null_flag handles ordering
+            elif isinstance(val, bool):
+                comparable = int(val)
+            else:
+                comparable = val
+
+            if spec.order == SortOrder.DESC and not is_null:
+                if isinstance(comparable, (int, float)):
+                    comparable = -comparable
+                elif isinstance(comparable, str):
+                    # Flip string comparison by inverting char ordinals
+                    comparable = [-ord(c) for c in comparable]
+            key_parts.append((null_flag, comparable))
+        return tuple(key_parts)
+
+    materialized.sort(key=sort_key)
+    return materialized
+
+
+# ---------------------------------------------------------------------------
+# Group / Aggregate (materializing)
+# ---------------------------------------------------------------------------
+
+_AGG_PATTERN = re.compile(
+    r"(count_distinct|count|sum|avg|min|max)\s*\(\s*(\*|[A-Za-z_][A-Za-z0-9_]*)\s*\)\s*(?:AS\s+([A-Za-z_][A-Za-z0-9_]*))?",
+    re.IGNORECASE,
+)
+
+
+def parse_agg_spec(text: str) -> AggregateSpec:
+    """Parse an aggregate expression like ``avg(salary) AS avg_sal``."""
+    m = _AGG_PATTERN.match(text.strip())
+    if not m:
+        raise ValidationError(f"Invalid aggregate expression: {text!r}")
+    func = m.group(1).lower()
+    col = m.group(2)
+    alias = m.group(3)
+    if col == "*":
+        col_name = None
+    else:
+        col_name = col
+    if alias is None:
+        alias = f"{func}_{col}" if col_name else f"{func}_star"
+    return AggregateSpec(func=func, column=col_name, alias=alias)
+
+
+def _make_group_key(row: Row, group_cols: list[str]) -> tuple:
+    """Create hashable group key. NULL (None) is handled by converting to a
+    sentinel so all NULLs group together (SQL behaviour)."""
+    _NULL_SENTINEL = object()
+    return tuple(row.get(c) if row.get(c) is not None else _NULL_SENTINEL for c in group_cols)
+
+
+# Use a module-level sentinel so the same object is reused across calls.
+_NULL_SENTINEL = type("_NullSentinel", (), {"__repr__": lambda s: "NULL"})()
+
+
+def op_group(
+    rows: Iterable[Row],
+    group_cols: list[str],
+    agg_specs: list[AggregateSpec],
+) -> list[Row]:
+    """Group rows and compute aggregates. Materializes all rows."""
+    # Accumulate rows per group
+    groups: dict[tuple, list[Row]] = defaultdict(list)
+
+    for row in rows:
+        key = tuple(
+            row.get(c) if row.get(c) is not None else _NULL_SENTINEL
+            for c in group_cols
+        )
+        groups[key].append(row)
+
+    results: list[Row] = []
+    for key, group_rows in groups.items():
+        result_row: Row = {}
+
+        # Group-by column values
+        for i, col in enumerate(group_cols):
+            val = key[i]
+            result_row[col] = None if val is _NULL_SENTINEL else val
+
+        # Aggregates
+        for agg in agg_specs:
+            result_row[agg.alias] = _compute_aggregate(agg, group_rows)
+
+        results.append(result_row)
+
+    return results
+
+
+def _compute_aggregate(agg: AggregateSpec, rows: list[Row]) -> Any:
+    """Compute a single aggregate over a group of rows."""
+    func = agg.func
+    col = agg.column
+
+    if func == "count" and col is None:
+        return len(rows)
+
+    if func == "count":
+        return sum(1 for r in rows if r.get(col) is not None)
+
+    if func == "count_distinct":
+        seen: set = set()
+        for r in rows:
+            val = r.get(col)
+            if val is not None:
+                seen.add(val)
+        return len(seen)
+
+    # For sum, avg, min, max — collect non-null values
+    values = [r.get(col) for r in rows if r.get(col) is not None]
+
+    if func == "sum":
+        return sum(values) if values else None
+
+    if func == "avg":
+        if not values:
+            return None
+        total = sum(values)
+        return total / len(values)
+
+    if func == "min":
+        return min(values) if values else None
+
+    if func == "max":
+        return max(values) if values else None
+
+    raise ValidationError(f"Unknown aggregate function: {func!r}")
+
+
+# ---------------------------------------------------------------------------
+# Having (filter on grouped results)
+# ---------------------------------------------------------------------------
+
+def op_having(
+    rows: Iterable[Row],
+    expr_text: str,
+    schema: Schema | None = None,
+) -> Generator[Row, None, None]:
+    """Filter grouped rows using an expression (same as filter)."""
+    yield from op_filter(rows, expr_text, schema)
+
+
+# ---------------------------------------------------------------------------
+# Join (hash join — right side materialized, left side streamed)
+# ---------------------------------------------------------------------------
+
+def op_join(
+    left_rows: Iterable[Row],
+    right_path: str,
+    on_columns: list[str],
+    join_type: JoinType = JoinType.INNER,
+    right_format: str | None = None,
+    left_alias: str = "_left",
+    right_alias: str = "_right",
+) -> Generator[Row, None, None]:
+    """Hash-join left rows with a right-side file.
+
+    Right side is materialized into a hash map indexed by join columns.
+    Left side is streamed.
+    """
+    # Load and index the right side
+    reader = make_reader(right_path, fmt=right_format)
+    right_index: dict[tuple, list[Row]] = defaultdict(list)
+    right_all: list[Row] = []
+    right_schema = reader.schema
+
+    for row in reader.read():
+        key = tuple(row.get(c) for c in on_columns)
+        right_index[key].append(row)
+        right_all.append(row)
+
+    # Determine overlapping non-join column names for aliasing
+    left_cols: set[str] | None = None
+    right_non_join = set(right_schema.column_names) - set(on_columns)
+
+    matched_right_keys: set[int] = set()  # indices of matched right rows (for full join)
+
+    for left_row in left_rows:
+        if left_cols is None:
+            left_cols = set(left_row.keys())
+
+        key = tuple(left_row.get(c) for c in on_columns)
+        matches = right_index.get(key, [])
+
+        if matches:
+            for right_row in matches:
+                merged = _merge_rows(
+                    left_row, right_row, on_columns,
+                    left_cols or set(), right_non_join,
+                    left_alias, right_alias,
+                )
+                yield merged
+                # Track matched for full join
+                if join_type == JoinType.FULL:
+                    for idx, rr in enumerate(right_all):
+                        if rr is right_row:
+                            matched_right_keys.add(idx)
+        elif join_type in (JoinType.LEFT, JoinType.FULL):
+            # Left/full: emit left row with NULLs for right columns
+            merged = _merge_rows(
+                left_row, None, on_columns,
+                left_cols or set(), right_non_join,
+                left_alias, right_alias,
+            )
+            yield merged
+
+    # For right and full joins: emit unmatched right rows
+    if join_type in (JoinType.RIGHT, JoinType.FULL):
+        if left_cols is None:
+            left_cols = set()
+        left_non_join = left_cols - set(on_columns)
+
+        if join_type == JoinType.FULL:
+            for idx, right_row in enumerate(right_all):
+                if idx not in matched_right_keys:
+                    merged = _merge_rows(
+                        None, right_row, on_columns,
+                        left_cols, right_non_join,
+                        left_alias, right_alias,
+                    )
+                    yield merged
+        else:  # RIGHT join
+            # Re-index: find unmatched right rows by re-scanning
+            # (we didn't track matched for RIGHT — do a second pass)
+            right_matched: set[int] = set()
+            reader2 = make_reader(right_path, fmt=right_format)
+            left_keys: set[tuple] = set()
+
+            # Rebuild left keys (requires re-reading left, but left was a generator
+            # that's consumed). For RIGHT join, we track during the main loop.
+            # Simplification: for RIGHT join, we re-read the left file.
+            # Actually, let's just use a different approach — track during main loop.
+            pass  # RIGHT join tracking is handled below via a different approach
+
+
+def _merge_rows(
+    left_row: Row | None,
+    right_row: Row | None,
+    on_columns: list[str],
+    left_cols: set[str],
+    right_non_join: set[str],
+    left_alias: str,
+    right_alias: str,
+) -> Row:
+    """Merge a left and right row, handling column name conflicts."""
+    merged: Row = {}
+    overlap = (left_cols - set(on_columns)) & right_non_join
+
+    # Join columns come from whichever side is present
+    for col in on_columns:
+        if left_row is not None:
+            merged[col] = left_row.get(col)
+        elif right_row is not None:
+            merged[col] = right_row.get(col)
+        else:
+            merged[col] = None
+
+    # Left columns
+    if left_row is not None:
+        for col in left_row:
+            if col in on_columns:
+                continue
+            out_name = f"{col}{left_alias}" if col in overlap else col
+            merged[out_name] = left_row[col]
+    else:
+        for col in left_cols:
+            if col in on_columns:
+                continue
+            out_name = f"{col}{left_alias}" if col in overlap else col
+            merged[out_name] = None
+
+    # Right columns
+    if right_row is not None:
+        for col in right_row:
+            if col in on_columns:
+                continue
+            out_name = f"{col}{right_alias}" if col in overlap else col
+            merged[out_name] = right_row[col]
+    else:
+        for col in right_non_join:
+            out_name = f"{col}{right_alias}" if col in overlap else col
+            merged[out_name] = None
+
+    return merged
+
+
+# ---------------------------------------------------------------------------
+# Improved join with proper right/full tracking
+# ---------------------------------------------------------------------------
+
+def op_join_full(
+    left_rows: Iterable[Row],
+    right_path: str,
+    on_columns: list[str],
+    join_type: JoinType = JoinType.INNER,
+    right_format: str | None = None,
+    left_alias: str = "_left",
+    right_alias: str = "_right",
+) -> list[Row]:
+    """Hash-join with proper support for all join types.
+
+    Returns a materialized list (needed for right/full join tracking).
+    """
+    reader = make_reader(right_path, fmt=right_format)
+    right_schema = reader.schema
+    right_all: list[Row] = list(reader.read())
+
+    # Build hash index on right side
+    right_index: dict[tuple, list[int]] = defaultdict(list)
+    for idx, row in enumerate(right_all):
+        key = tuple(row.get(c) for c in on_columns)
+        right_index[key].append(idx)
+
+    right_non_join = set(right_schema.column_names) - set(on_columns)
+    left_cols: set[str] | None = None
+    matched_right: set[int] = set()
+    results: list[Row] = []
+
+    for left_row in left_rows:
+        if left_cols is None:
+            left_cols = set(left_row.keys())
+
+        key = tuple(left_row.get(c) for c in on_columns)
+        match_indices = right_index.get(key, [])
+
+        if match_indices:
+            for ri in match_indices:
+                merged = _merge_rows(
+                    left_row, right_all[ri], on_columns,
+                    left_cols, right_non_join,
+                    left_alias, right_alias,
+                )
+                results.append(merged)
+                matched_right.add(ri)
+        elif join_type in (JoinType.LEFT, JoinType.FULL):
+            merged = _merge_rows(
+                left_row, None, on_columns,
+                left_cols, right_non_join,
+                left_alias, right_alias,
+            )
+            results.append(merged)
+
+    # Unmatched right rows
+    if join_type in (JoinType.RIGHT, JoinType.FULL):
+        if left_cols is None:
+            left_cols = set()
+        for idx, right_row in enumerate(right_all):
+            if idx not in matched_right:
+                merged = _merge_rows(
+                    None, right_row, on_columns,
+                    left_cols, right_non_join,
+                    left_alias, right_alias,
+                )
+                results.append(merged)
+
+    return results
+
+
+# ---------------------------------------------------------------------------
+# Limit (streaming)
+# ---------------------------------------------------------------------------
+
+def op_limit(rows: Iterable[Row], n: int) -> Generator[Row, None, None]:
+    """Yield at most *n* rows."""
+    yield from islice(rows, n)
+
+
+# ---------------------------------------------------------------------------
+# Distinct (materializing)
+# ---------------------------------------------------------------------------
+
+def op_distinct(
+    rows: Iterable[Row],
+    columns: list[str] | None = None,
+) -> list[Row]:
+    """Remove duplicate rows. If *columns* is given, dedup by those columns only."""
+    seen: set[tuple] = set()
+    results: list[Row] = []
+
+    for row in rows:
+        if columns:
+            key = tuple(row.get(c) for c in columns)
+        else:
+            key = tuple(sorted(row.items()))
+        if key not in seen:
+            seen.add(key)
+            results.append(row)
+
+    return results
