index 0000000..c72a175
--- /dev/null
+++ b/src/tablesmith/expression.py
@@ -0,0 +1,587 @@
+"""Expression tokenizer, parser, and evaluator with SQL three-valued NULL logic.
+
+Grammar (recursive descent):
+    expr       -> or_expr
+    or_expr    -> and_expr ('OR' and_expr)*
+    and_expr   -> not_expr ('AND' not_expr)*
+    not_expr   -> 'NOT' not_expr | comparison
+    comparison -> operand (comp_op operand | null_op | string_op operand)?
+    operand    -> '(' expr ')' | literal | column_ref | arith_expr
+    arith_expr -> term (('+' | '-' | '||') term)*
+    term       -> factor (('*' | '/') factor)*
+    factor     -> '(' arith_expr ')' | literal | column_ref | unary_minus factor
+"""
+
+from __future__ import annotations
+
+import enum
+import re
+from dataclasses import dataclass
+from typing import Any
+
+from tablesmith.models import ColumnType, ExpressionError, Row, Schema
+
+
+# ---------------------------------------------------------------------------
+# Token types
+# ---------------------------------------------------------------------------
+
+class TT(enum.Enum):
+    # Literals
+    INTEGER = "INTEGER"
+    FLOAT = "FLOAT"
+    STRING = "STRING"
+    BOOLEAN = "BOOLEAN"
+    NULL_LIT = "NULL"
+
+    # Identifiers (column names)
+    IDENT = "IDENT"
+
+    # Comparison operators
+    EQ = "="
+    NEQ = "!="
+    GT = ">"
+    LT = "<"
+    GTE = ">="
+    LTE = "<="
+
+    # String operators
+    CONTAINS = "contains"
+    STARTSWITH = "startswith"
+    ENDSWITH = "endswith"
+
+    # NULL operators
+    IS_NULL = "is_null"
+    IS_NOT_NULL = "is_not_null"
+
+    # Logical operators
+    AND = "AND"
+    OR = "OR"
+    NOT = "NOT"
+
+    # Arithmetic / concat
+    PLUS = "+"
+    MINUS = "-"
+    STAR = "*"
+    SLASH = "/"
+    CONCAT = "||"
+
+    # Grouping
+    LPAREN = "("
+    RPAREN = ")"
+
+    # Alias
+    AS = "AS"
+    COMMA = ","
+
+    EOF = "EOF"
+
+
+# Keywords that must not be treated as identifiers.
+_KEYWORDS = {
+    "and": TT.AND,
+    "or": TT.OR,
+    "not": TT.NOT,
+    "true": TT.BOOLEAN,
+    "false": TT.BOOLEAN,
+    "null": TT.NULL_LIT,
+    "is_null": TT.IS_NULL,
+    "is_not_null": TT.IS_NOT_NULL,
+    "contains": TT.CONTAINS,
+    "startswith": TT.STARTSWITH,
+    "endswith": TT.ENDSWITH,
+    "as": TT.AS,
+}
+
+
+@dataclass
+class Token:
+    tt: TT
+    value: Any
+    pos: int
+
+
+# ---------------------------------------------------------------------------
+# Tokenizer
+# ---------------------------------------------------------------------------
+
+def tokenize(text: str) -> list[Token]:
+    """Lex *text* into a list of Tokens."""
+    tokens: list[Token] = []
+    i = 0
+    n = len(text)
+
+    while i < n:
+        # Skip whitespace
+        if text[i].isspace():
+            i += 1
+            continue
+
+        # Two-char operators
+        two = text[i: i + 2]
+        if two == "!=":
+            tokens.append(Token(TT.NEQ, "!=", i)); i += 2; continue
+        if two == ">=":
+            tokens.append(Token(TT.GTE, ">=", i)); i += 2; continue
+        if two == "<=":
+            tokens.append(Token(TT.LTE, "<=", i)); i += 2; continue
+        if two == "||":
+            tokens.append(Token(TT.CONCAT, "||", i)); i += 2; continue
+
+        # Single-char operators
+        ch = text[i]
+        if ch == "=":
+            tokens.append(Token(TT.EQ, "=", i)); i += 1; continue
+        if ch == ">":
+            tokens.append(Token(TT.GT, ">", i)); i += 1; continue
+        if ch == "<":
+            tokens.append(Token(TT.LT, "<", i)); i += 1; continue
+        if ch == "+":
+            tokens.append(Token(TT.PLUS, "+", i)); i += 1; continue
+        if ch == "-":
+            tokens.append(Token(TT.MINUS, "-", i)); i += 1; continue
+        if ch == "*":
+            tokens.append(Token(TT.STAR, "*", i)); i += 1; continue
+        if ch == "/":
+            tokens.append(Token(TT.SLASH, "/", i)); i += 1; continue
+        if ch == "(":
+            tokens.append(Token(TT.LPAREN, "(", i)); i += 1; continue
+        if ch == ")":
+            tokens.append(Token(TT.RPAREN, ")", i)); i += 1; continue
+        if ch == ",":
+            tokens.append(Token(TT.COMMA, ",", i)); i += 1; continue
+
+        # String literals: single-quoted with \' escape
+        if ch == "'":
+            j = i + 1
+            parts: list[str] = []
+            while j < n:
+                if text[j] == "\\" and j + 1 < n and text[j + 1] == "'":
+                    parts.append("'")
+                    j += 2
+                elif text[j] == "'":
+                    break
+                else:
+                    parts.append(text[j])
+                    j += 1
+            if j >= n:
+                raise ExpressionError(f"Unterminated string literal starting at position {i}")
+            tokens.append(Token(TT.STRING, "".join(parts), i))
+            i = j + 1
+            continue
+
+        # Numbers
+        if ch.isdigit() or (ch == "." and i + 1 < n and text[i + 1].isdigit()):
+            m = re.match(r"(\d+\.\d*|\.\d+|\d+)", text[i:])
+            if m:
+                raw = m.group(0)
+                if "." in raw:
+                    tokens.append(Token(TT.FLOAT, float(raw), i))
+                else:
+                    tokens.append(Token(TT.INTEGER, int(raw), i))
+                i += len(raw)
+                continue
+
+        # Identifiers / keywords
+        if ch.isalpha() or ch == "_":
+            m = re.match(r"[A-Za-z_][A-Za-z0-9_]*", text[i:])
+            if m:
+                word = m.group(0)
+                low = word.lower()
+                if low in _KEYWORDS:
+                    tt = _KEYWORDS[low]
+                    val: Any = word
+                    if tt == TT.BOOLEAN:
+                        val = low == "true"
+                    elif tt == TT.NULL_LIT:
+                        val = None
+                    tokens.append(Token(tt, val, i))
+                else:
+                    tokens.append(Token(TT.IDENT, word, i))
+                i += len(word)
+                continue
+
+        raise ExpressionError(f"Unexpected character {ch!r} at position {i}")
+
+    tokens.append(Token(TT.EOF, None, i))
+    return tokens
+
+
+# ---------------------------------------------------------------------------
+# AST nodes
+# ---------------------------------------------------------------------------
+
+@dataclass
+class LiteralNode:
+    value: Any  # int, float, str, bool, or None (NULL)
+
+@dataclass
+class ColumnRefNode:
+    name: str
+
+@dataclass
+class BinaryOpNode:
+    op: str  # +, -, *, /, ||, =, !=, >, <, >=, <=, contains, startswith, endswith, AND, OR
+    left: Any
+    right: Any
+
+@dataclass
+class UnaryOpNode:
+    op: str  # NOT, unary_minus
+    operand: Any
+
+@dataclass
+class NullCheckNode:
+    column: Any
+    is_null: bool  # True for is_null, False for is_not_null
+
+@dataclass
+class AliasNode:
+    expr: Any
+    alias: str
+
+
+# ---------------------------------------------------------------------------
+# Parser (recursive descent)
+# ---------------------------------------------------------------------------
+
+class Parser:
+    """Recursive descent parser for filter and project expressions."""
+
+    def __init__(self, tokens: list[Token]) -> None:
+        self._tokens = tokens
+        self._pos = 0
+
+    def _peek(self) -> Token:
+        return self._tokens[self._pos]
+
+    def _advance(self) -> Token:
+        tok = self._tokens[self._pos]
+        self._pos += 1
+        return tok
+
+    def _expect(self, tt: TT) -> Token:
+        tok = self._advance()
+        if tok.tt != tt:
+            raise ExpressionError(
+                f"Expected {tt.value} but got {tok.value!r} at position {tok.pos}"
+            )
+        return tok
+
+    # --- public entry points -----------------------------------------------
+
+    def parse_filter_expr(self) -> Any:
+        node = self._or_expr()
+        if self._peek().tt != TT.EOF:
+            tok = self._peek()
+            raise ExpressionError(
+                f"Unexpected token {tok.value!r} at position {tok.pos}"
+            )
+        return node
+
+    def parse_project_item(self) -> Any:
+        """Parse a single projection item: expr [AS alias]."""
+        node = self._arith_expr()
+        if self._peek().tt == TT.AS:
+            self._advance()
+            alias_tok = self._expect(TT.IDENT)
+            return AliasNode(expr=node, alias=alias_tok.value)
+        # Plain column ref — use the column name as the alias
+        if isinstance(node, ColumnRefNode):
+            return AliasNode(expr=node, alias=node.name)
+        raise ExpressionError("Computed column expression requires an AS alias")
+
+    # --- filter expression hierarchy ---------------------------------------
+
+    def _or_expr(self) -> Any:
+        left = self._and_expr()
+        while self._peek().tt == TT.OR:
+            self._advance()
+            right = self._and_expr()
+            left = BinaryOpNode("OR", left, right)
+        return left
+
+    def _and_expr(self) -> Any:
+        left = self._not_expr()
+        while self._peek().tt == TT.AND:
+            self._advance()
+            right = self._not_expr()
+            left = BinaryOpNode("AND", left, right)
+        return left
+
+    def _not_expr(self) -> Any:
+        if self._peek().tt == TT.NOT:
+            self._advance()
+            operand = self._not_expr()
+            return UnaryOpNode("NOT", operand)
+        return self._comparison()
+
+    def _comparison(self) -> Any:
+        left = self._arith_expr()
+
+        tt = self._peek().tt
+
+        # Null operators
+        if tt == TT.IS_NULL:
+            self._advance()
+            return NullCheckNode(left, is_null=True)
+        if tt == TT.IS_NOT_NULL:
+            self._advance()
+            return NullCheckNode(left, is_null=False)
+
+        # Comparison operators
+        comp_ops = {TT.EQ, TT.NEQ, TT.GT, TT.LT, TT.GTE, TT.LTE}
+        str_ops = {TT.CONTAINS, TT.STARTSWITH, TT.ENDSWITH}
+
+        if tt in comp_ops or tt in str_ops:
+            op_tok = self._advance()
+            right = self._arith_expr()
+            return BinaryOpNode(op_tok.value, left, right)
+
+        return left
+
+    # --- arithmetic expression hierarchy -----------------------------------
+
+    def _arith_expr(self) -> Any:
+        left = self._term()
+        while self._peek().tt in (TT.PLUS, TT.MINUS, TT.CONCAT):
+            op_tok = self._advance()
+            right = self._term()
+            left = BinaryOpNode(op_tok.value, left, right)
+        return left
+
+    def _term(self) -> Any:
+        left = self._factor()
+        while self._peek().tt in (TT.STAR, TT.SLASH):
+            op_tok = self._advance()
+            right = self._factor()
+            left = BinaryOpNode(op_tok.value, left, right)
+        return left
+
+    def _factor(self) -> Any:
+        tok = self._peek()
+
+        if tok.tt == TT.LPAREN:
+            self._advance()
+            node = self._or_expr()
+            self._expect(TT.RPAREN)
+            return node
+
+        if tok.tt == TT.MINUS:
+            self._advance()
+            operand = self._factor()
+            return UnaryOpNode("unary_minus", operand)
+
+        return self._atom()
+
+    def _atom(self) -> Any:
+        tok = self._advance()
+
+        if tok.tt == TT.INTEGER:
+            return LiteralNode(tok.value)
+        if tok.tt == TT.FLOAT:
+            return LiteralNode(tok.value)
+        if tok.tt == TT.STRING:
+            return LiteralNode(tok.value)
+        if tok.tt == TT.BOOLEAN:
+            return LiteralNode(tok.value)
+        if tok.tt == TT.NULL_LIT:
+            return LiteralNode(None)
+        if tok.tt == TT.IDENT:
+            return ColumnRefNode(tok.value)
+
+        raise ExpressionError(
+            f"Unexpected token {tok.value!r} at position {tok.pos}"
+        )
+
+
+# ---------------------------------------------------------------------------
+# Evaluator with SQL three-valued NULL logic
+# ---------------------------------------------------------------------------
+
+def evaluate(node: Any, row: Row, schema: Schema | None = None) -> Any:
+    """Evaluate an AST node against a row.
+
+    Returns the result value.  For filter expressions the caller should
+    treat non-True results (including None/NULL) as False.
+    """
+    if isinstance(node, LiteralNode):
+        return node.value
+
+    if isinstance(node, ColumnRefNode):
+        if node.name not in row:
+            available = ", ".join(sorted(row.keys()))
+            raise ExpressionError(
+                f"Column '{node.name}' not found. Available columns: {available}"
+            )
+        return row[node.name]
+
+    if isinstance(node, NullCheckNode):
+        val = evaluate(node.column, row, schema)
+        if node.is_null:
+            return val is None
+        return val is not None
+
+    if isinstance(node, UnaryOpNode):
+        if node.op == "NOT":
+            val = evaluate(node.operand, row, schema)
+            if val is None:
+                return None  # NOT NULL => NULL (three-valued logic)
+            return not val
+        if node.op == "unary_minus":
+            val = evaluate(node.operand, row, schema)
+            if val is None:
+                return None
+            if not isinstance(val, (int, float)):
+                raise ExpressionError(
+                    f"Cannot negate non-numeric value: {val!r}"
+                )
+            return -val
+
+    if isinstance(node, BinaryOpNode):
+        return _eval_binary(node, row, schema)
+
+    if isinstance(node, AliasNode):
+        return evaluate(node.expr, row, schema)
+
+    raise ExpressionError(f"Unknown AST node type: {type(node).__name__}")
+
+
+def _eval_binary(node: BinaryOpNode, row: Row, schema: Schema | None) -> Any:
+    op = node.op
+
+    # Short-circuit logical operators with three-valued logic
+    if op == "AND":
+        left = evaluate(node.left, row, schema)
+        if left is False:
+            return False  # False AND anything => False
+        right = evaluate(node.right, row, schema)
+        if right is False:
+            return False
+        if left is None or right is None:
+            return None
+        return left and right
+
+    if op == "OR":
+        left = evaluate(node.left, row, schema)
+        if left is True:
+            return True  # True OR anything => True
+        right = evaluate(node.right, row, schema)
+        if right is True:
+            return True
+        if left is None or right is None:
+            return None
+        return left or right
+
+    left = evaluate(node.left, row, schema)
+    right = evaluate(node.right, row, schema)
+
+    # Arithmetic / concatenation
+    if op in ("+", "-", "*", "/"):
+        if left is None or right is None:
+            return None
+        if op == "/" and right == 0:
+            return None  # Division by zero => NULL
+        if not isinstance(left, (int, float)) or not isinstance(right, (int, float)):
+            raise ExpressionError(
+                f"Cannot apply '{op}' to non-numeric values: {left!r}, {right!r}"
+            )
+        if op == "+":
+            result = left + right
+        elif op == "-":
+            result = left - right
+        elif op == "*":
+            result = left * right
+        else:
+            result = left / right
+        # Preserve integer type when possible
+        if isinstance(result, float) and result == int(result) and isinstance(left, int) and isinstance(right, int):
+            return int(result)
+        return result
+
+    if op == "||":
+        if left is None or right is None:
+            return None
+        return str(left) + str(right)
+
+    # Comparison operators — NULL propagation
+    if op in ("=", "!=", ">", "<", ">=", "<="):
+        if left is None or right is None:
+            return None  # Any comparison with NULL => NULL
+
+        # Type checking for comparisons
+        if isinstance(left, str) != isinstance(right, str):
+            # One is a string the other isn't — allow comparing with literals
+            if isinstance(left, str) and isinstance(right, (int, float)):
+                raise ExpressionError(
+                    f"Cannot compare string '{left}' with number {right}"
+                )
+            if isinstance(right, str) and isinstance(left, (int, float)):
+                raise ExpressionError(
+                    f"Cannot compare number {left} with string '{right}'"
+                )
+
+        if op == "=":
+            return left == right
+        if op == "!=":
+            return left != right
+        if op == ">":
+            return left > right
+        if op == "<":
+            return left < right
+        if op == ">=":
+            return left >= right
+        if op == "<=":
+            return left <= right
+
+    # String operators — NULL propagation
+    if op in ("contains", "startswith", "endswith"):
+        if left is None or right is None:
+            return None
+        left_str = str(left)
+        right_str = str(right)
+        if op == "contains":
+            return right_str in left_str
+        if op == "startswith":
+            return left_str.startswith(right_str)
+        if op == "endswith":
+            return left_str.endswith(right_str)
+
+    raise ExpressionError(f"Unknown operator: {op!r}")
+
+
+# ---------------------------------------------------------------------------
+# Convenience helpers
+# ---------------------------------------------------------------------------
+
+def parse_filter(text: str) -> Any:
+    """Parse a filter expression string into an AST."""
+    tokens = tokenize(text)
+    return Parser(tokens).parse_filter_expr()
+
+
+def parse_project_list(text: str) -> list[AliasNode]:
+    """Parse a comma-separated list of projection items.
+
+    E.g. "name, salary * 1.1 AS adjusted, dept"
+    """
+    # We tokenize the full string then parse comma-separated items.
+    tokens = tokenize(text)
+    parser = Parser(tokens)
+    items: list[AliasNode] = []
+
+    while parser._peek().tt != TT.EOF:
+        item = parser.parse_project_item()
+        items.append(item)
+        if parser._peek().tt == TT.COMMA:
+            parser._advance()
+
+    return items
+
+
+def eval_filter(expr_text: str, row: Row, schema: Schema | None = None) -> bool:
+    """Parse and evaluate a filter expression, returning True/False."""
+    ast = parse_filter(expr_text)
+    result = evaluate(ast, row, schema)
+    # In SQL three-valued logic NULL evaluates to false in filter context
+    return result is True
