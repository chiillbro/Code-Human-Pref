+"""Tests for data readers and type inference."""
+
+import json
+import os
+import tempfile
+from pathlib import Path
+
+import pytest
+
+from tablesmith.models import ColumnType
+from tablesmith.readers import (
+    CSVReader,
+    JSONLReader,
+    JSONReader,
+    detect_format,
+    infer_column_type,
+    make_reader,
+)
+
+
+# ---------------------------------------------------------------------------
+# Type inference tests
+# ---------------------------------------------------------------------------
+
+class TestTypeInference:
+    def test_all_integers(self):
+        assert infer_column_type([1, 2, 3]) == ColumnType.INTEGER
+        assert infer_column_type(["1", "2", "3"]) == ColumnType.INTEGER
+
+    def test_mixed_int_float(self):
+        assert infer_column_type([1, 2.5, 3]) == ColumnType.FLOAT
+
+    def test_all_floats(self):
+        assert infer_column_type([1.1, 2.2, 3.3]) == ColumnType.FLOAT
+
+    def test_string_float_mix(self):
+        assert infer_column_type(["1.1", "2.2"]) == ColumnType.FLOAT
+
+    def test_mixed_types_default_to_string(self):
+        assert infer_column_type(["hello", "123", "true"]) == ColumnType.STRING
+
+    def test_boolean(self):
+        assert infer_column_type([True, False]) == ColumnType.BOOLEAN
+        assert infer_column_type(["true", "false"]) == ColumnType.BOOLEAN
+        assert infer_column_type(["1", "0"]) == ColumnType.BOOLEAN
+
+    def test_all_nulls(self):
+        assert infer_column_type([None, None, None]) == ColumnType.STRING
+
+    def test_nulls_with_integers(self):
+        assert infer_column_type([None, 1, None, 2]) == ColumnType.INTEGER
+
+
+# ---------------------------------------------------------------------------
+# CSV Reader tests
+# ---------------------------------------------------------------------------
+
+class TestCSVReader:
+    def _write_csv(self, content: str) -> str:
+        f = tempfile.NamedTemporaryFile(mode="w", suffix=".csv", delete=False, encoding="utf-8")
+        f.write(content)
+        f.close()
+        return f.name
+
+    def test_basic_read(self):
+        path = self._write_csv("name,age,salary\nAlice,30,50000\nBob,25,45000\n")
+        try:
+            reader = CSVReader(path)
+            assert reader.schema.column_names == ["name", "age", "salary"]
+            rows = list(reader.read())
+            assert len(rows) == 2
+            assert rows[0]["name"] == "Alice"
+            assert rows[0]["age"] == 30
+            assert rows[0]["salary"] == 50000
+        finally:
+            os.unlink(path)
+
+    def test_null_handling(self):
+        path = self._write_csv("name,age\nAlice,30\nBob,\n")
+        try:
+            reader = CSVReader(path)
+            rows = list(reader.read())
+            assert rows[1]["age"] is None  # Empty cell → NULL
+        finally:
+            os.unlink(path)
+
+    def test_malformed_row_skipped(self, capsys):
+        path = self._write_csv("a,b\n1,2\n3\n4,5\n")
+        try:
+            reader = CSVReader(path)
+            rows = list(reader.read())
+            assert len(rows) == 2
+            assert reader.skipped_count == 1
+        finally:
+            os.unlink(path)
+
+    def test_empty_file_headers_only(self):
+        path = self._write_csv("a,b,c\n")
+        try:
+            reader = CSVReader(path)
+            rows = list(reader.read())
+            assert len(rows) == 0
+            assert reader.schema.column_names == ["a", "b", "c"]
+        finally:
+            os.unlink(path)
+
+    def test_type_inference_integer(self):
+        path = self._write_csv("val\n1\n2\n3\n")
+        try:
+            reader = CSVReader(path)
+            assert reader.schema.get_type("val") == ColumnType.INTEGER
+        finally:
+            os.unlink(path)
+
+    def test_type_inference_float(self):
+        path = self._write_csv("val\n1.1\n2.2\n3.3\n")
+        try:
+            reader = CSVReader(path)
+            assert reader.schema.get_type("val") == ColumnType.FLOAT
+        finally:
+            os.unlink(path)
+
+    def test_single_row(self):
+        path = self._write_csv("x\n42\n")
