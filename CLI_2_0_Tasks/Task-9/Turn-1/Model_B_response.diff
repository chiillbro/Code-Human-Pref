+"""Command-line interface for tablesmith."""
+
+import argparse
+import sys
+
+from .errors import handle_error, TablesmithError
+from .io import read_input, write_output
+from .ops import (
+    filter_rows, select_columns, rename_columns, sort_rows,
+    group_by, join, head, tail, count, describe,
+)
+from .pipeline import load_pipeline, run_pipeline
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(
+        prog="tablesmith",
+        description="A lightweight pipeline engine for transforming tabular data.",
+        epilog=(
+            "examples:\n"
+            "  tablesmith data.csv --filter 'age > 30' --select name,age\n"
+            "  tablesmith data.json --sort salary:desc --head 10 -o top.csv\n"
+            "  tablesmith data.csv --group-by dept --agg salary:mean,salary:max\n"
+            "  tablesmith data.csv --join teams.csv --join-on team_id=id\n"
+            "  tablesmith --pipeline transform.json data.csv -o result.json\n"
+            "  cat data.csv | tablesmith --filter 'status == \"active\"'\n"
+        ),
+        formatter_class=argparse.RawDescriptionHelpFormatter,
+    )
+
+    parser.add_argument("input", nargs="?", default=None, help="input file (default: stdin)")
+
+    io_grp = parser.add_argument_group("input/output")
+    io_grp.add_argument("-o", "--output", default=None, help="output file (default: stdout)")
+    io_grp.add_argument(
+        "-f", "--format", default=None, dest="output_format",
+        choices=["csv", "json", "jsonl", "tsv"],
+        help="output format (auto-detected from extension)",
+    )
+    io_grp.add_argument(
+        "-F", "--input-format", default=None,
+        choices=["csv", "json", "jsonl", "tsv"],
+        help="input format (auto-detected from extension)",
+    )
+
+    ops_grp = parser.add_argument_group("operations (applied in order)")
+    ops_grp.add_argument(
+        "--filter", action="append", default=[], metavar="EXPR",
+        help="filter rows (e.g. 'age > 30'). repeatable",
+    )
+    ops_grp.add_argument("--select", default=None, metavar="COLS", help="select columns (comma-separated)")
+    ops_grp.add_argument("--rename", default=None, metavar="MAP", help="rename columns (old:new,...)")
+    ops_grp.add_argument("--sort", default=None, metavar="SPEC", help="sort by columns (col:asc,...)")
+    ops_grp.add_argument("--group-by", default=None, metavar="COLS", help="group by columns")
+    ops_grp.add_argument("--agg", default=None, metavar="SPEC", help="aggregations (col:func,...)")
+    ops_grp.add_argument("--join", default=None, metavar="FILE", help="join with another file")
+    ops_grp.add_argument("--join-on", default=None, metavar="SPEC", help="join key (col or left=right)")
+    ops_grp.add_argument(
+        "--join-how", default="inner",
+        choices=["inner", "left", "right", "outer"],
+        help="join type (default: inner)",
+    )
+
+    util_grp = parser.add_argument_group("utility")
+    util_grp.add_argument("--head", type=int, default=None, metavar="N", help="first N rows")
+    util_grp.add_argument("--tail", type=int, default=None, metavar="N", help="last N rows")
+    util_grp.add_argument("--count", action="store_true", help="count rows")
+    util_grp.add_argument("--describe", action="store_true", help="show column types and stats")
+
+    pipe_grp = parser.add_argument_group("pipeline")
+    pipe_grp.add_argument("--pipeline", default=None, metavar="FILE", help="run from a JSON pipeline file")
+
+    return parser
+
+
+def _validate_args(args):
+    if args.group_by and not args.agg:
+        raise TablesmithError(
+            "--group-by requires --agg",
+            hint="e.g. --agg 'salary:sum,salary:count'",
+        )
+    if args.agg and not args.group_by:
+        raise TablesmithError(
+            "--agg requires --group-by",
+            hint="e.g. --group-by 'department'",
+        )
+    if args.join and not args.join_on:
+        raise TablesmithError(
+            "--join requires --join-on",
+            hint="e.g. --join-on 'id' or --join-on 'dept_id=id'",
+        )
+    if args.join_on and not args.join:
+        raise TablesmithError("--join-on requires --join")
+
+    has_inline = (
+        args.filter or args.select or args.rename or args.sort
+        or args.group_by or args.join
+        or args.head is not None or args.tail is not None
+        or args.count or args.describe
+    )
+    if args.pipeline and has_inline:
+        raise TablesmithError(
+            "cannot combine --pipeline with inline operations",
+            hint="use either --pipeline or inline flags, not both",
+        )
+
+
+def _apply_inline_ops(rows, args):
+    """Apply inline operations in a fixed, predictable order."""
+    for expr in args.filter:
+        rows = filter_rows(rows, expr)
+
+    if args.rename:
+        rows = rename_columns(rows, args.rename)
+
+    if args.join:
+        right_rows = read_input(args.join)
+        rows = join(rows, right_rows, args.join_on, args.join_how)
+
+    if args.select:
+        rows = select_columns(rows, args.select)
+
+    if args.group_by:
+        rows = group_by(rows, args.group_by, args.agg)
+
+    if args.sort:
+        rows = sort_rows(rows, args.sort)
+
+    if args.head is not None:
+        rows = head(rows, args.head)
+
+    if args.tail is not None:
+        rows = tail(rows, args.tail)
+
+    if args.describe:
+        rows = describe(rows)
+
+    if args.count:
+        rows = count(rows)
+
+    return rows
+
+
+@handle_error
+def main(argv=None):
+    parser = build_parser()
+    args = parser.parse_args(argv)
+
+    if args.input is None and sys.stdin.isatty() and not args.pipeline:
+        parser.print_help(sys.stderr)
+        sys.exit(1)
+
+    _validate_args(args)
+
+    rows = read_input(args.input, fmt=args.input_format)
+
+    if args.pipeline:
+        steps = load_pipeline(args.pipeline)
+        rows = run_pipeline(rows, steps)
+    else:
+        rows = _apply_inline_ops(rows, args)
+
+    write_output(rows, args.output, fmt=args.output_format)
