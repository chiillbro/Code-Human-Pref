index 0000000..ff8d0dc
--- /dev/null
+++ b/tablesmith/expr.py
@@ -0,0 +1,416 @@
+"""Expression parser for filter operations.
+
+Supports:
+  Comparisons:  age > 30, name == "Alice"
+  Logical:      expr and expr, expr or expr, not expr
+  Parentheses:  (age > 30) and (name == "Alice")
+  String ops:   name contains "ali", name startswith "A", name endswith "z"
+  Null checks:  age is null, age is not null
+  In lists:     status in ("active", "pending")
+  Quoted cols:  `column name` > 10
+"""
+
+from .errors import ParseError
+
+
+class _T:
+    IDENT = "IDENT"
+    STRING = "STRING"
+    NUMBER = "NUMBER"
+    OP = "OP"
+    AND = "AND"
+    OR = "OR"
+    NOT = "NOT"
+    IS = "IS"
+    NULL = "NULL"
+    IN = "IN"
+    CONTAINS = "CONTAINS"
+    STARTSWITH = "STARTSWITH"
+    ENDSWITH = "ENDSWITH"
+    LPAREN = "LPAREN"
+    RPAREN = "RPAREN"
+    COMMA = "COMMA"
+    EOF = "EOF"
+
+
+_KEYWORDS = {
+    "and": _T.AND,
+    "or": _T.OR,
+    "not": _T.NOT,
+    "is": _T.IS,
+    "null": _T.NULL,
+    "none": _T.NULL,
+    "in": _T.IN,
+    "contains": _T.CONTAINS,
+    "startswith": _T.STARTSWITH,
+    "endswith": _T.ENDSWITH,
+}
+
+_TWO_CHAR_OPS = {"==", "!=", ">=", "<="}
+
+
+class Token:
+    __slots__ = ("type", "value", "pos")
+
+    def __init__(self, type, value, pos):
+        self.type = type
+        self.value = value
+        self.pos = pos
+
+
+def tokenize(expr):
+    """Tokenize a filter expression string."""
+    tokens = []
+    i = 0
+    n = len(expr)
+
+    while i < n:
+        if expr[i].isspace():
+            i += 1
+            continue
+
+        # Backtick-quoted identifiers (for column names with spaces)
+        if expr[i] == "`":
+            start = i
+            i += 1
+            while i < n and expr[i] != "`":
+                i += 1
+            if i >= n:
+                raise ParseError(
+                    f"unterminated backtick identifier at position {start}",
+                    hint="close it with another backtick: `column name`",
+                )
+            tokens.append(Token(_T.IDENT, expr[start + 1:i], start))
+            i += 1
+            continue
+
+        # String literals
+        if expr[i] in ('"', "'"):
+            quote = expr[i]
+            start = i
+            i += 1
+            parts = []
+            while i < n and expr[i] != quote:
+                if expr[i] == "\\" and i + 1 < n:
+                    i += 1
+                parts.append(expr[i])
+                i += 1
+            if i >= n:
+                raise ParseError(
+                    f"unterminated string starting at position {start}",
+                    hint="make sure quotes are balanced",
+                )
+            i += 1
+            tokens.append(Token(_T.STRING, "".join(parts), start))
+            continue
+
+        # Numbers
+        if expr[i].isdigit() or (
+            expr[i] == "-" and i + 1 < n and expr[i + 1].isdigit()
+        ):
+            start = i
+            if expr[i] == "-":
+                i += 1
+            while i < n and expr[i].isdigit():
+                i += 1
+            if i < n and expr[i] == ".":
+                i += 1
+                while i < n and expr[i].isdigit():
+                    i += 1
+                tokens.append(Token(_T.NUMBER, float(expr[start:i]), start))
+            else:
+                tokens.append(Token(_T.NUMBER, int(expr[start:i]), start))
+            continue
+
+        # Two-char operators
+        if i + 1 < n and expr[i:i + 2] in _TWO_CHAR_OPS:
+            tokens.append(Token(_T.OP, expr[i:i + 2], i))
+            i += 2
+            continue
+
+        # Single-char operators
+        if expr[i] in (">", "<"):
+            tokens.append(Token(_T.OP, expr[i], i))
+            i += 1
+            continue
+
+        # Bare = treated as ==
+        if expr[i] == "=":
+            tokens.append(Token(_T.OP, "==", i))
+            i += 1
+            continue
+
+        # Parentheses and comma
+        if expr[i] == "(":
+            tokens.append(Token(_T.LPAREN, "(", i))
+            i += 1
+            continue
+        if expr[i] == ")":
+            tokens.append(Token(_T.RPAREN, ")", i))
+            i += 1
+            continue
+        if expr[i] == ",":
+            tokens.append(Token(_T.COMMA, ",", i))
+            i += 1
+            continue
+
+        # Identifiers and keywords
+        if expr[i].isalpha() or expr[i] == "_":
+            start = i
+            while i < n and (expr[i].isalnum() or expr[i] in ("_", ".")):
+                i += 1
+            word = expr[start:i]
+            lower = word.lower()
+            if lower in _KEYWORDS:
+                tokens.append(Token(_KEYWORDS[lower], lower, start))
+            elif lower == "true":
+                tokens.append(Token(_T.NUMBER, True, start))
+            elif lower == "false":
+                tokens.append(Token(_T.NUMBER, False, start))
+            else:
+                tokens.append(Token(_T.IDENT, word, start))
+            continue
+
+        raise ParseError(
+            f"unexpected character '{expr[i]}' at position {i}",
+            hint=f"in expression: {expr}",
+        )
+
+    tokens.append(Token(_T.EOF, None, n))
+    return tokens
+
+
+class _Parser:
+    """Recursive descent parser for filter expressions."""
+
+    def __init__(self, tokens, source):
+        self.tokens = tokens
+        self.source = source
+        self.pos = 0
+
+    def peek(self):
+        return self.tokens[self.pos]
+
+    def advance(self):
+        tok = self.tokens[self.pos]
+        self.pos += 1
+        return tok
+
+    def expect(self, ttype):
+        tok = self.peek()
+        if tok.type != ttype:
+            raise ParseError(
+                f"expected {ttype} but got {tok.type} ({tok.value!r}) "
+                f"at position {tok.pos}",
+                hint=f"in expression: {self.source}",
+            )
+        return self.advance()
+
+    def parse(self):
+        node = self._or()
+        if self.peek().type != _T.EOF:
+            tok = self.peek()
+            raise ParseError(
+                f"unexpected token {tok.value!r} at position {tok.pos}",
+                hint=f"in expression: {self.source}",
+            )
+        return node
+
+    def _or(self):
+        left = self._and()
+        while self.peek().type == _T.OR:
+            self.advance()
+            left = ("or", left, self._and())
+        return left
+
+    def _and(self):
+        left = self._not()
+        while self.peek().type == _T.AND:
+            self.advance()
+            left = ("and", left, self._not())
+        return left
+
+    def _not(self):
+        if self.peek().type == _T.NOT:
+            self.advance()
+            return ("not", self._not())
+        return self._primary()
+
+    def _primary(self):
+        if self.peek().type == _T.LPAREN:
+            self.advance()
+            node = self._or()
+            self.expect(_T.RPAREN)
+            return node
+        return self._comparison()
+
+    def _comparison(self):
+        left = self._value()
+        tok = self.peek()
+
+        if tok.type == _T.OP:
+            op = self.advance().value
+            return ("cmp", op, left, self._value())
+
+        if tok.type == _T.IS:
+            self.advance()
+            if self.peek().type == _T.NOT:
+                self.advance()
+                self.expect(_T.NULL)
+                return ("is_not_null", left)
+            self.expect(_T.NULL)
+            return ("is_null", left)
+
+        if tok.type == _T.CONTAINS:
+            self.advance()
+            return ("contains", left, self._value())
+
+        if tok.type == _T.STARTSWITH:
+            self.advance()
+            return ("startswith", left, self._value())
+
+        if tok.type == _T.ENDSWITH:
+            self.advance()
+            return ("endswith", left, self._value())
+
+        if tok.type == _T.IN:
+            self.advance()
+            self.expect(_T.LPAREN)
+            values = [self._value()]
+            while self.peek().type == _T.COMMA:
+                self.advance()
+                values.append(self._value())
+            self.expect(_T.RPAREN)
+            return ("in", left, values)
+
+        # Bare value used as truthy check
+        return ("truthy", left)
+
+    def _value(self):
+        tok = self.peek()
+        if tok.type == _T.IDENT:
+            self.advance()
+            return ("col", tok.value)
+        if tok.type == _T.STRING:
+            self.advance()
+            return ("lit", tok.value)
+        if tok.type == _T.NUMBER:
+            self.advance()
+            return ("lit", tok.value)
+        if tok.type == _T.NULL:
+            self.advance()
+            return ("lit", None)
+        raise ParseError(
+            f"expected a value but got {tok.type} ({tok.value!r}) "
+            f"at position {tok.pos}",
+            hint=f"in expression: {self.source}",
+        )
+
+
+def parse_expression(expr_str):
+    """Parse a filter expression string into an AST."""
+    tokens = tokenize(expr_str)
+    return _Parser(tokens, expr_str).parse()
+
+
+def _resolve(node, row):
+    """Resolve an AST value node against a row."""
+    if node[0] == "col":
+        col_name = node[1]
+        if col_name in row:
+            return row[col_name]
+        # Case-insensitive fallback
+        for k in row:
+            if k.lower() == col_name.lower():
+                return row[k]
+        return None
+    if node[0] == "lit":
+        return node[1]
+    raise ParseError(f"unexpected node in value position: {node}")
+
+
+def _safe_compare(a, b, op):
+    """Compare two values, handling type mismatches and nulls."""
+    if a is None or b is None:
+        if op == "==":
+            return a is None and b is None
+        if op == "!=":
+            return not (a is None and b is None)
+        return False
+
+    # Coerce for cross-type numeric comparison
+    try:
+        if isinstance(a, str) and isinstance(b, (int, float)):
+            a = float(a)
+        elif isinstance(b, str) and isinstance(a, (int, float)):
+            b = float(b)
+    except (ValueError, TypeError):
+        pass
+
+    try:
+        if op == "==":
+            return a == b
+        if op == "!=":
+            return a != b
+        if op == ">":
+            return a > b
+        if op == "<":
+            return a < b
+        if op == ">=":
+            return a >= b
+        if op == "<=":
+            return a <= b
+    except TypeError:
+        return False
+    return False
+
+
+def evaluate(ast, row):
+    """Evaluate a parsed expression against a row dict."""
+    op = ast[0]
+
+    if op == "cmp":
+        _, cmp_op, left, right = ast
+        return _safe_compare(_resolve(left, row), _resolve(right, row), cmp_op)
+
+    if op == "and":
+        return evaluate(ast[1], row) and evaluate(ast[2], row)
+
+    if op == "or":
+        return evaluate(ast[1], row) or evaluate(ast[2], row)
+
+    if op == "not":
+        return not evaluate(ast[1], row)
+
+    if op == "is_null":
+        return _resolve(ast[1], row) is None
+
+    if op == "is_not_null":
+        return _resolve(ast[1], row) is not None
+
+    if op == "contains":
+        a, b = _resolve(ast[1], row), _resolve(ast[2], row)
+        if a is None or b is None:
+            return False
+        return str(b).lower() in str(a).lower()
+
+    if op == "startswith":
+        a, b = _resolve(ast[1], row), _resolve(ast[2], row)
+        if a is None or b is None:
+            return False
+        return str(a).lower().startswith(str(b).lower())
+
+    if op == "endswith":
+        a, b = _resolve(ast[1], row), _resolve(ast[2], row)
+        if a is None or b is None:
+            return False
+        return str(a).lower().endswith(str(b).lower())
+
+    if op == "in":
+        a = _resolve(ast[1], row)
+        return a in [_resolve(v, row) for v in ast[2]]
+
+    if op == "truthy":
+        return bool(_resolve(ast[1], row))
+
+    raise ParseError(f"unknown expression node: {op}")
