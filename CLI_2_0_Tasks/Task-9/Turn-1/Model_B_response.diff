@@ -0,0 +1,166 @@
+"""Input/output handling for CSV, JSON, and JSONL formats."""
+
+import csv
+import json
+import sys
+
+from .errors import IOError_
+from .types import infer_types
+
+
+def detect_format(path, default="csv"):
+    """Detect format from file extension."""
+    if path is None:
+        return default
+    lower = path.lower()
+    if lower.endswith(".json"):
+        return "json"
+    if lower.endswith(".jsonl") or lower.endswith(".ndjson"):
+        return "jsonl"
+    if lower.endswith(".tsv"):
+        return "tsv"
+    return "csv"
+
+
+def read_csv(stream, delimiter=","):
+    """Read CSV from a text stream."""
+    reader = csv.DictReader(stream, delimiter=delimiter)
+    rows = []
+    for i, row in enumerate(reader, 1):
+        try:
+            rows.append(dict(row))
+        except Exception as e:
+            raise IOError_(f"error reading CSV row {i}: {e}")
+    return rows
+
+
+def read_json(stream):
+    """Read JSON (array of objects) from a text stream."""
+    try:
+        data = json.load(stream)
+    except json.JSONDecodeError as e:
+        raise IOError_(f"invalid JSON: {e}")
+
+    if isinstance(data, list):
+        for i, item in enumerate(data):
+            if not isinstance(item, dict):
+                raise IOError_(
+                    f"JSON array element {i} is not an object",
+                    hint="expected an array of objects like [{...}, {...}]",
+                )
+        return data
+    if isinstance(data, dict):
+        return [data]
+    raise IOError_(
+        "expected a JSON array of objects or a single object",
+        hint="input should look like [{...}, {...}] or {...}",
+    )
+
+
+def read_jsonl(stream):
+    """Read JSONL (one JSON object per line) from a text stream."""
+    rows = []
+    for i, line in enumerate(stream, 1):
+        line = line.strip()
+        if not line:
+            continue
+        try:
+            obj = json.loads(line)
+        except json.JSONDecodeError as e:
+            raise IOError_(f"invalid JSON on line {i}: {e}")
+        if not isinstance(obj, dict):
+            raise IOError_(f"line {i} is not a JSON object")
+        rows.append(obj)
+    return rows
+
+
+def read_input(source=None, fmt=None):
+    """Read tabular data from a file or stdin."""
+    if fmt is None:
+        fmt = detect_format(source)
+
+    try:
+        if source is None or source == "-":
+            stream = sys.stdin
+        else:
+            stream = open(source, "r", newline="" if fmt in ("csv", "tsv") else None)
+    except FileNotFoundError:
+        raise IOError_(f"file not found: {source}")
+    except PermissionError:
+        raise IOError_(f"permission denied: {source}")
+
+    try:
+        if fmt == "csv":
+            rows = read_csv(stream)
+        elif fmt == "tsv":
+            rows = read_csv(stream, delimiter="\t")
+        elif fmt == "json":
+            rows = read_json(stream)
+        elif fmt == "jsonl":
+            rows = read_jsonl(stream)
+        else:
+            raise IOError_(
+                f"unknown format: {fmt}",
+                hint="supported formats: csv, json, jsonl, tsv",
+            )
+    finally:
+        if stream is not sys.stdin:
+            stream.close()
+
+    return infer_types(rows)
+
+
+def write_csv(rows, stream, delimiter=","):
+    """Write rows as CSV to a text stream."""
+    if not rows:
+        return
+    fieldnames = list(rows[0].keys())
+    writer = csv.DictWriter(stream, fieldnames=fieldnames, delimiter=delimiter)
+    writer.writeheader()
+    for row in rows:
+        writer.writerow({k: ("" if v is None else v) for k, v in row.items()})
+
+
+def write_json(rows, stream):
+    """Write rows as JSON array to a text stream."""
+    json.dump(rows, stream, indent=2, default=str)
+    stream.write("\n")
+
+
+def write_jsonl(rows, stream):
+    """Write rows as JSONL to a text stream."""
+    for row in rows:
+        json.dump(row, stream, default=str)
+        stream.write("\n")
+
+
+def write_output(rows, dest=None, fmt=None):
+    """Write tabular data to a file or stdout."""
+    if fmt is None:
+        fmt = detect_format(dest)
+
+    try:
+        if dest is None or dest == "-":
+            stream = sys.stdout
+        else:
+            stream = open(dest, "w", newline="" if fmt in ("csv", "tsv") else None)
+    except PermissionError:
+        raise IOError_(f"permission denied: {dest}")
+
+    try:
+        if fmt == "csv":
+            write_csv(rows, stream)
+        elif fmt == "tsv":
+            write_csv(rows, stream, delimiter="\t")
+        elif fmt == "json":
+            write_json(rows, stream)
+        elif fmt == "jsonl":
+            write_jsonl(rows, stream)
+        else:
+            raise IOError_(
+                f"unknown output format: {fmt}",
+                hint="supported formats: csv, json, jsonl, tsv",
+            )
+    finally:
+        if stream is not sys.stdout:
+            stream.close()
diff --git a/tablesmith/ops.py b/tablesmith/ops.py
new file mode 100644
index 0000000..fbbadb4
--- /dev/null
+++ b/tablesmith/ops.py
@@ -0,0 +1,287 @@
+"""Data transformation operations."""
+
+from .errors import ColumnNotFoundError, OperationError, ParseError
+from .expr import parse_expression, evaluate
+
+
+def _get_columns(rows):
+    if not rows:
+        return set()
+    return set(rows[0].keys())
+
+
+def _validate_columns(rows, columns, operation):
+    if not rows:
+        return
+    available = _get_columns(rows)
+    for col in columns:
+        if col not in available:
+            raise ColumnNotFoundError(col, available)
+
+
+def filter_rows(rows, expr_str):
+    """Filter rows matching an expression."""
+    if not rows:
+        return rows
+    ast = parse_expression(expr_str)
+    return [row for row in rows if evaluate(ast, row)]
+
+
+def select_columns(rows, columns_str):
+    """Select specific columns (comma-separated)."""
+    if not rows:
+        return rows
+    columns = [c.strip() for c in columns_str.split(",")]
+    _validate_columns(rows, columns, "select")
+    return [{col: row.get(col) for col in columns} for row in rows]
+
+
+def rename_columns(rows, rename_str):
+    """Rename columns. Format: old:new,old2:new2"""
+    if not rows:
+        return rows
+
+    mapping = {}
+    for pair in rename_str.split(","):
+        pair = pair.strip()
+        if ":" not in pair:
+            raise OperationError(
+                f"invalid rename spec '{pair}'",
+                hint="expected format: old_name:new_name",
+            )
+        old, new = pair.split(":", 1)
+        mapping[old.strip()] = new.strip()
+
+    _validate_columns(rows, mapping.keys(), "rename")
+
+    result = []
+    for row in rows:
+        new_row = {}
+        for key, val in row.items():
+            new_row[mapping.get(key, key)] = val
+        result.append(new_row)
+    return result
+
+
+def sort_rows(rows, sort_str):
+    """Sort rows. Format: col:asc,col2:desc (default asc)."""
+    if not rows:
+        return rows
+
+    sort_keys = []
+    for spec in sort_str.split(","):
+        spec = spec.strip()
+        if ":" in spec:
+            col, direction = spec.rsplit(":", 1)
+            col = col.strip()
+            direction = direction.strip().lower()
+            if direction not in ("asc", "desc"):
+                raise OperationError(
+                    f"invalid sort direction '{direction}'",
+                    hint="use 'asc' or 'desc'",
+                )
+            reverse = direction == "desc"
+        else:
+            col = spec
+            reverse = False
+        sort_keys.append((col, reverse))
+
+    _validate_columns(rows, [k[0] for k in sort_keys], "sort")
+
+    # Stable sort: apply from last key to first
+    result = list(rows)
+    for col, reverse in reversed(sort_keys):
+        def make_key(c):
+            def sort_key(row):
+                v = row.get(c)
+                # Nulls always sort last
+                if v is None:
+                    return (1, "")
+                return (0, v)
+            return sort_key
+        result.sort(key=make_key(col), reverse=reverse)
+    return result
+
+
+def _parse_agg_spec(agg_str):
+    aggs = []
+    for spec in agg_str.split(","):
+        spec = spec.strip()
+        if ":" not in spec:
+            raise OperationError(
+                f"invalid aggregation spec '{spec}'",
+                hint="expected format: column:function (e.g. salary:sum)",
+            )
+        col, func = spec.split(":", 1)
+        func = func.strip().lower()
+        valid = ("sum", "mean", "avg", "min", "max", "count", "first", "last")
+        if func not in valid:
+            raise OperationError(
+                f"unknown aggregation function '{func}'",
+                hint=f"supported: {', '.join(valid)}",
+            )
+        aggs.append((col.strip(), func))
+    return aggs
+
+
+def _aggregate(values, func):
+    non_null = [v for v in values if v is not None]
+    if func == "count":
+        return len(non_null)
+    if func == "first":
+        return values[0] if values else None
+    if func == "last":
+        return values[-1] if values else None
+    if not non_null:
+        return None
+    if func == "sum":
+        return sum(non_null)
+    if func in ("mean", "avg"):
+        return sum(non_null) / len(non_null)
+    if func == "min":
+        return min(non_null)
+    if func == "max":
+        return max(non_null)
+
+
+def group_by(rows, group_str, agg_str):
+    """Group rows by columns and aggregate."""
+    if not rows:
+        return rows
+
+    group_cols = [c.strip() for c in group_str.split(",")]
+    aggs = _parse_agg_spec(agg_str)
+
+    _validate_columns(rows, group_cols, "group-by")
+    _validate_columns(rows, [a[0] for a in aggs], "aggregate")
+
+    groups = {}
+    for row in rows:
+        key = tuple(row.get(col) for col in group_cols)
+        groups.setdefault(key, []).append(row)
+
+    result = []
+    for key, group_rows in groups.items():
+        new_row = dict(zip(group_cols, key))
+        for col, func in aggs:
+            values = [r.get(col) for r in group_rows]
+            new_row[f"{col}_{func}"] = _aggregate(values, func)
+        result.append(new_row)
+    return result
+
+
+def join(left_rows, right_rows, on_str, how="inner"):
+    """Join left rows with right rows.
+
+    on_str: "col" for same-name key or "left_col=right_col".
+    how: inner, left, right, outer.
+    """
+    if "=" in on_str:
+        left_col, right_col = [s.strip() for s in on_str.split("=", 1)]
+    else:
+        left_col = right_col = on_str.strip()
+
+    if left_rows:
+        _validate_columns(left_rows, [left_col], "join (left)")
+    if right_rows:
+        _validate_columns(right_rows, [right_col], "join (right)")
+
+    # Index the right side
+    right_index = {}
+    for row in right_rows:
+        key = row.get(right_col)
+        right_index.setdefault(key, []).append(row)
+
+    result = []
+    right_matched = set()
+
+    for left_row in left_rows:
+        key = left_row.get(left_col)
+        matches = right_index.get(key, [])
+
+        if matches:
+            for right_row in matches:
+                merged = dict(left_row)
+                for k, v in right_row.items():
+                    if k == right_col and left_col == right_col:
+                        continue  # don't duplicate the join key
+                    if k in merged:
+                        merged[f"right_{k}"] = v
+                    else:
+                        merged[k] = v
+                result.append(merged)
+                right_matched.add(id(right_row))
+        elif how in ("left", "outer"):
+            merged = dict(left_row)
+            if right_rows:
+                for k in right_rows[0]:
+                    if k not in merged:
+                        merged[k] = None
+            result.append(merged)
+
+    if how in ("right", "outer"):
+        for right_row in right_rows:
+            if id(right_row) not in right_matched:
+                merged = {}
+                if left_rows:
+                    for k in left_rows[0]:
+                        merged[k] = None
+                merged.update(right_row)
+                result.append(merged)
+
+    return result
+
+
+def head(rows, n):
+    """First n rows."""
+    return rows[:n]
+
+
+def tail(rows, n):
+    """Last n rows."""
+    return rows[-n:] if n else rows
+
+
+def count(rows):
+    """Single row with the count."""
+    return [{"count": len(rows)}]
+
+
+def _column_type_name(values):
+    if not values:
+        return "empty"
+    types = set(type(v).__name__ for v in values)
+    if types == {"int"}:
+        return "integer"
+    if types <= {"int", "float"}:
+        return "number"
+    if types == {"bool"}:
+        return "boolean"
+    if types == {"str"}:
+        return "string"
+    return "mixed"
+
+
+def describe(rows):
+    """Summary statistics for each column."""
+    if not rows:
+        return [{"info": "no data"}]
+
+    result = []
+    for col in rows[0].keys():
+        values = [r.get(col) for r in rows]
+        non_null = [v for v in values if v is not None]
+        info = {
+            "column": col,
+            "type": _column_type_name(non_null),
+            "non_null": len(non_null),
+            "null": len(values) - len(non_null),
+            "unique": len(set(str(v) for v in non_null)),
+        }
+        numeric = [v for v in non_null if isinstance(v, (int, float))]
+        if numeric:
+            info["min"] = min(numeric)
+            info["max"] = max(numeric)
+            info["mean"] = round(sum(numeric) / len(numeric), 2)
+        result.append(info)
+    return result
