+++ b/tablesmith/pipeline.py
@@ -0,0 +1,135 @@
+"""Pipeline definition file loading and execution."""
+
+import json
+
+from .errors import IOError_, OperationError, ParseError
+from . import ops
+from .io import read_input
+
+
+def load_pipeline(path):
+    """Load a pipeline from a JSON definition file.
+
+    Format:
+    {
+      "steps": [
+        {"op": "filter", "expr": "age > 30"},
+        {"op": "select", "columns": "name,age"},
+        {"op": "sort", "by": "age:desc"},
+        {"op": "rename", "columns": "old:new"},
+        {"op": "group", "by": "dept", "agg": "salary:mean"},
+        {"op": "join", "file": "other.csv", "on": "id", "how": "left"},
+        {"op": "head", "n": 10},
+        {"op": "tail", "n": 5},
+        {"op": "count"},
+        {"op": "describe"}
+      ]
+    }
+    """
+    try:
+        with open(path, "r") as f:
+            data = json.load(f)
+    except FileNotFoundError:
+        raise IOError_(f"pipeline file not found: {path}")
+    except json.JSONDecodeError as e:
+        raise ParseError(
+            f"invalid JSON in pipeline file: {e}",
+            hint="pipeline files must be valid JSON",
+        )
+
+    if not isinstance(data, dict) or "steps" not in data:
+        raise ParseError(
+            "pipeline file must contain a 'steps' array",
+            hint='expected: {"steps": [{"op": "...", ...}, ...]}',
+        )
+
+    steps = data["steps"]
+    if not isinstance(steps, list):
+        raise ParseError("'steps' must be an array")
+
+    for i, step in enumerate(steps):
+        if not isinstance(step, dict):
+            raise ParseError(f"step {i + 1} must be an object")
+        if "op" not in step:
+            raise ParseError(
+                f"step {i + 1} is missing the 'op' field",
+                hint="each step needs an 'op' like 'filter', 'select', 'sort', etc.",
+            )
+
+    return steps
+
+
+def run_pipeline(rows, steps):
+    """Execute a list of pipeline steps."""
+    for i, step in enumerate(steps, 1):
+        op = step["op"]
+        try:
+            rows = _execute_step(rows, step)
+        except (ParseError, IOError_, OperationError):
+            raise
+        except Exception as e:
+            raise OperationError(f"step {i} ({op}) failed: {e}")
+    return rows
+
+
+def _require(step, field, op):
+    if field not in step:
+        raise ParseError(
+            f"'{op}' step requires a '{field}' field",
+            hint=f'example: {{"op": "{op}", "{field}": "..."}}',
+        )
+    return step[field]
+
+
+_VALID_OPS = (
+    "filter", "select", "rename", "sort", "group",
+    "join", "head", "tail", "count", "describe",
+)
+
+
+def _execute_step(rows, step):
+    op = step["op"]
+
+    if op == "filter":
+        return ops.filter_rows(rows, _require(step, "expr", op))
+
+    if op == "select":
+        return ops.select_columns(rows, _require(step, "columns", op))
+
+    if op == "rename":
+        return ops.rename_columns(rows, _require(step, "columns", op))
+
+    if op == "sort":
+        return ops.sort_rows(rows, _require(step, "by", op))
+
+    if op == "group":
+        return ops.group_by(
+            rows,
+            _require(step, "by", op),
+            _require(step, "agg", op),
+        )
+
+    if op == "join":
+        right = read_input(_require(step, "file", op))
+        return ops.join(
+            rows, right,
+            _require(step, "on", op),
+            step.get("how", "inner"),
+        )
+
+    if op == "head":
+        return ops.head(rows, int(step.get("n", 10)))
+
+    if op == "tail":
+        return ops.tail(rows, int(step.get("n", 10)))
+
+    if op == "count":
+        return ops.count(rows)
+
+    if op == "describe":
+        return ops.describe(rows)
+
+    raise OperationError(
+        f"unknown operation '{op}'",
+        hint=f"supported: {', '.join(_VALID_OPS)}",
+    )
diff --git a/tablesmith/types.py b/tablesmith/types.py
new file mode 100644
index 0000000..41dbc44
--- /dev/null
+++ b/tablesmith/types.py
@@ -0,0 +1,45 @@
+"""Automatic type inference for tabular data."""
+
+
+_NULL_VALUES = {"", "null", "none", "na", "n/a", "nan", "-"}
+
+
+def infer_value(value):
+    """Infer the type of a single value and return the cast version."""
+    if value is None:
+        return None
+    if not isinstance(value, str):
+        return value  # already typed (e.g. from JSON)
+
+    stripped = value.strip()
+    if stripped.lower() in _NULL_VALUES:
+        return None
+
+    # Try int
+    try:
+        return int(stripped)
+    except ValueError:
+        pass
+
+    # Try float
+    try:
+        return float(stripped)
+    except ValueError:
+        pass
+
+    # Only auto-cast unambiguous booleans
+    lower = stripped.lower()
+    if lower == "true":
+        return True
+    if lower == "false":
+        return False
+
+    return value
+
+
+def infer_types(rows):
+    """Infer and cast types for all values in all rows. Modifies rows in place."""
+    for row in rows:
+        for key in row:
+            row[key] = infer_value(row[key])
+    return rows
