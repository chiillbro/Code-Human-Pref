@@ -0,0 +1,60 @@
+"""User-friendly error handling for tablesmith."""
+
+import sys
+
+
+class TablesmithError(Exception):
+    """Base error for all tablesmith errors."""
+
+    def __init__(self, message, hint=None):
+        self.hint = hint
+        super().__init__(message)
+
+    def format(self):
+        msg = f"error: {self}"
+        if self.hint:
+            msg += f"\n  hint: {self.hint}"
+        return msg
+
+
+class ColumnNotFoundError(TablesmithError):
+    """A referenced column does not exist in the data."""
+
+    def __init__(self, column, available):
+        self.column = column
+        self.available = available
+        avail_str = ", ".join(sorted(available)) if available else "(none)"
+        super().__init__(
+            f"column '{column}' not found",
+            hint=f"available columns: {avail_str}",
+        )
+
+
+class ParseError(TablesmithError):
+    """Error parsing a filter expression or pipeline file."""
+    pass
+
+
+class IOError_(TablesmithError):
+    """Error reading or writing data."""
+    pass
+
+
+class OperationError(TablesmithError):
+    """Error during a data operation."""
+    pass
+
+
+def handle_error(func):
+    """Decorator that catches TablesmithError and prints a friendly message."""
+    def wrapper(*args, **kwargs):
+        try:
+            return func(*args, **kwargs)
+        except TablesmithError as e:
+            print(f"tablesmith: {e.format()}", file=sys.stderr)
+            sys.exit(1)
+        except BrokenPipeError:
+            sys.exit(0)
+        except KeyboardInterrupt:
+            sys.exit(130)
+    return wrapper
diff --git a/tablesmith/expr.py b/tablesmith/expr.py
