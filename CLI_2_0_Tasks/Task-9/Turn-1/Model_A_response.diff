+++ b/tablesmith/ioformats.py
@@ -0,0 +1,220 @@
+"""Readers and writers for CSV, JSON (array-of-objects) and JSONL.
+
+All readers yield a list of dict rows. All writers take an iterable of dict
+rows. Format is detected from file extension when not specified; `-` means
+stdin/stdout.
+"""
+from __future__ import annotations
+
+import csv
+import io
+import json
+import os
+import sys
+from typing import Any, Dict, Iterable, List, Optional, TextIO
+
+from .errors import FormatError
+from .typeinfer import infer_columns
+
+FORMATS = ("csv", "json", "jsonl")
+
+_EXT_MAP = {
+    ".csv": "csv",
+    ".tsv": "csv",
+    ".json": "json",
+    ".jsonl": "jsonl",
+    ".ndjson": "jsonl",
+}
+
+
+def detect_format(path: Optional[str], explicit: Optional[str], default: str = "csv") -> str:
+    if explicit:
+        f = explicit.lower()
+        if f not in FORMATS:
+            raise FormatError(
+                f"unsupported format '{explicit}'",
+                hint=f"supported formats: {', '.join(FORMATS)}",
+            )
+        return f
+    if path and path != "-":
+        ext = os.path.splitext(path)[1].lower()
+        if ext in _EXT_MAP:
+            return _EXT_MAP[ext]
+    return default
+
+
+def _open_read(path: Optional[str]) -> TextIO:
+    if path is None or path == "-":
+        return sys.stdin
+    try:
+        return open(path, "r", encoding="utf-8", newline="")
+    except FileNotFoundError:
+        raise FormatError(f"input file not found: {path}", source=path)
+    except OSError as e:
+        raise FormatError(f"could not open input file: {e}", source=path)
+
+
+def _open_write(path: Optional[str]) -> TextIO:
+    if path is None or path == "-":
+        return sys.stdout
+    try:
+        return open(path, "w", encoding="utf-8", newline="")
+    except OSError as e:
+        raise FormatError(f"could not open output file: {e}", source=path)
+
+
+# ---------------------------------------------------------------- readers ---
+
+def read_rows(
+    path: Optional[str],
+    fmt: Optional[str] = None,
+    *,
+    delimiter: Optional[str] = None,
+    no_infer: bool = False,
+) -> List[Dict[str, Any]]:
+    f = detect_format(path, fmt)
+    fh = _open_read(path)
+    close = fh is not sys.stdin
+    try:
+        if f == "csv":
+            rows = _read_csv(fh, path, delimiter)
+            if not no_infer:
+                infer_columns(rows)
+            return rows
+        if f == "json":
+            return _read_json(fh, path)
+        if f == "jsonl":
+            return _read_jsonl(fh, path)
+        raise FormatError(f"unsupported format '{f}'")
+    finally:
+        if close:
+            fh.close()
+
+
+def _read_csv(fh: TextIO, path: Optional[str], delimiter: Optional[str]) -> List[Dict[str, Any]]:
+    delim = delimiter
+    if delim is None and path and path.lower().endswith(".tsv"):
+        delim = "\t"
+    if delim is None:
+        # sniff, fall back to comma
+        head = fh.read(8192)
+        try:
+            dialect = csv.Sniffer().sniff(head, delimiters=",;\t|")
+            delim = dialect.delimiter
+        except csv.Error:
+            delim = ","
+        fh = io.StringIO(head + fh.read())
+    reader = csv.DictReader(fh, delimiter=delim)
+    try:
+        rows = [dict(r) for r in reader]
+    except csv.Error as e:
+        raise FormatError(
+            f"malformed CSV: {e}",
+            source=path or "<stdin>",
+            hint="check delimiter and quoting; use --delimiter to override",
+        )
+    return rows
+
+
+def _read_json(fh: TextIO, path: Optional[str]) -> List[Dict[str, Any]]:
+    try:
+        data = json.load(fh)
+    except json.JSONDecodeError as e:
+        raise FormatError(
+            f"invalid JSON at line {e.lineno}, col {e.colno}: {e.msg}",
+            source=path or "<stdin>",
+            hint="if the file has one object per line, use --input-format jsonl",
+        )
+    if isinstance(data, dict):
+        # single object → one row; or {"data":[...]} style wrapper
+        for key in ("data", "rows", "records", "items"):
+            if key in data and isinstance(data[key], list):
+                data = data[key]
+                break
+        else:
+            data = [data]
+    if not isinstance(data, list):
+        raise FormatError(
+            "JSON input must be an array of objects",
+            source=path or "<stdin>",
+        )
+    rows = []
+    for i, r in enumerate(data):
+        if not isinstance(r, dict):
+            raise FormatError(
+                f"JSON element {i} is {type(r).__name__}, expected object",
+                source=path or "<stdin>",
+            )
+        rows.append(dict(r))
+    return rows
+
+
+def _read_jsonl(fh: TextIO, path: Optional[str]) -> List[Dict[str, Any]]:
+    rows = []
+    for lineno, line in enumerate(fh, 1):
+        line = line.strip()
+        if not line:
+            continue
+        try:
+            obj = json.loads(line)
+        except json.JSONDecodeError as e:
+            raise FormatError(
+                f"invalid JSON on line {lineno}: {e.msg}",
+                source=path or "<stdin>",
+            )
+        if not isinstance(obj, dict):
+            raise FormatError(
+                f"line {lineno} is {type(obj).__name__}, expected object",
+                source=path or "<stdin>",
+            )
+        rows.append(obj)
+    return rows
+
+
+# ---------------------------------------------------------------- writers ---
+
+def _collect_columns(rows: Iterable[Dict[str, Any]]) -> List[str]:
+    cols: List[str] = []
+    seen = set()
+    for r in rows:
+        for k in r:
+            if k not in seen:
+                seen.add(k)
+                cols.append(k)
+    return cols
+
+
+def write_rows(
+    rows: List[Dict[str, Any]],
+    path: Optional[str],
+    fmt: Optional[str] = None,
+    *,
+    delimiter: str = ",",
+) -> None:
+    f = detect_format(path, fmt, default="csv")
+    fh = _open_write(path)
+    close = fh is not sys.stdout
+    try:
+        if f == "csv":
+            _write_csv(rows, fh, delimiter)
+        elif f == "json":
+            json.dump(rows, fh, indent=2, default=str)
+            fh.write("\n")
+        elif f == "jsonl":
+            for r in rows:
+                fh.write(json.dumps(r, default=str))
+                fh.write("\n")
+        else:
+            raise FormatError(f"unsupported output format '{f}'")
+    finally:
+        if close:
+            fh.close()
+
+
+def _write_csv(rows: List[Dict[str, Any]], fh: TextIO, delimiter: str) -> None:
+    cols = _collect_columns(rows)
+    writer = csv.DictWriter(fh, fieldnames=cols, delimiter=delimiter, extrasaction="ignore")
+    writer.writeheader()
+    for r in rows:
+        out = {k: ("" if v is None else v) for k, v in r.items()}
+        writer.writerow(out)
