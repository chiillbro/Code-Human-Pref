@@ -0,0 +1,756 @@
+"""Row-transforming operations.
+
+Every operation is a callable object with:
+  * name           — the op keyword used on the CLI / in pipeline files
+  * from_cli(arg)  — parse the string given after the inline flag
+  * from_spec(d)   — build from a dict (pipeline file)
+  * apply(rows)    — transform and return a new list of row dicts
+
+Ops never mutate input rows in place; they return fresh lists/dicts so that
+upstream references stay valid (important for joins and for error reporting).
+"""
+from __future__ import annotations
+
+import statistics
+from collections import OrderedDict
+from typing import Any, Callable, Dict, List, Optional, Sequence, Tuple
+
+from .errors import TablesmithError, unknown_column
+from .expr import Expression
+from .ioformats import read_rows, detect_format
+
+Row = Dict[str, Any]
+Rows = List[Row]
+
+REGISTRY: Dict[str, "type[Op]"] = {}
+
+
+def register(cls):
+    REGISTRY[cls.name] = cls
+    for a in getattr(cls, "aliases", ()):
+        REGISTRY[a] = cls
+    return cls
+
+
+def _columns_of(rows: Rows) -> List[str]:
+    cols: List[str] = []
+    seen = set()
+    for r in rows:
+        for k in r:
+            if k not in seen:
+                seen.add(k)
+                cols.append(k)
+    return cols
+
+
+def _require_columns(rows: Rows, wanted: Sequence[str]) -> None:
+    have = set(_columns_of(rows))
+    for c in wanted:
+        if c not in have:
+            raise unknown_column(c, have)
+
+
+class Op:
+    name: str = ""
+    aliases: Tuple[str, ...] = ()
+    cli_help: str = ""
+
+    @classmethod
+    def from_cli(cls, arg: str) -> "Op":
+        raise NotImplementedError
+
+    @classmethod
+    def from_spec(cls, spec: Dict[str, Any]) -> "Op":
+        raise NotImplementedError
+
+    def apply(self, rows: Rows) -> Rows:
+        raise NotImplementedError
+
+    def describe(self) -> str:
+        return self.name
+
+
+# ------------------------------------------------------------------ filter
+@register
+class Filter(Op):
+    name = "filter"
+    aliases = ("where",)
+    cli_help = "EXPR — keep rows where EXPR is truthy, e.g. 'age > 30 and city == \"NYC\"'"
+
+    def __init__(self, expr: str):
+        self.expr_src = expr
+        self.expr = Expression(expr)
+
+    @classmethod
+    def from_cli(cls, arg: str) -> "Filter":
+        if not arg.strip():
+            raise TablesmithError("filter requires an expression", step="filter")
+        return cls(arg)
+
+    @classmethod
+    def from_spec(cls, spec):
+        return cls(spec["expr"])
+
+    def apply(self, rows: Rows) -> Rows:
+        # validate referenced columns once up front for a nicer error
+        refs = self.expr.referenced_columns()
+        if rows and refs:
+            have = set(_columns_of(rows))
+            for c in refs:
+                if c not in have:
+                    raise unknown_column(c, have)
+        out = []
+        for i, r in enumerate(rows):
+            try:
+                if self.expr.eval(r):
+                    out.append(r)
+            except TablesmithError as e:
+                e.row_index = i
+                raise
+        return out
+
+    def describe(self):
+        return f"filter {self.expr_src}"
+
+
+# ------------------------------------------------------------------ select
+@register
+class Select(Op):
+    """select / project columns, with optional rename via `old:new` or `old AS new`."""
+
+    name = "select"
+    aliases = ("project", "cols")
+    cli_help = "COLS — comma-separated columns; rename with old:new, e.g. 'id,name:full_name'"
+
+    def __init__(self, mapping: List[Tuple[str, str]]):
+        self.mapping = mapping  # list of (src, dst)
+
+    @staticmethod
+    def _parse_cols(arg: str) -> List[Tuple[str, str]]:
+        pairs: List[Tuple[str, str]] = []
+        for raw in arg.split(","):
+            tok = raw.strip()
+            if not tok:
+                continue
+            low = tok.lower()
+            if " as " in low:
+                idx = low.index(" as ")
+                src, dst = tok[:idx].strip(), tok[idx + 4 :].strip()
+            elif ":" in tok:
+                src, dst = (p.strip() for p in tok.split(":", 1))
+            else:
+                src = dst = tok
+            if not src or not dst:
+                raise TablesmithError(
+                    f"invalid column spec '{raw}'",
+                    step="select",
+                    hint="use 'col' or 'old:new' or 'old AS new'",
+                )
+            pairs.append((src, dst))
+        if not pairs:
+            raise TablesmithError("select requires at least one column", step="select")
+        return pairs
+
+    @classmethod
+    def from_cli(cls, arg: str) -> "Select":
+        return cls(cls._parse_cols(arg))
+
+    @classmethod
+    def from_spec(cls, spec):
+        cols = spec["columns"]
+        mapping: List[Tuple[str, str]] = []
+        if isinstance(cols, dict):
+            mapping = [(k, v) for k, v in cols.items()]
+        else:
+            for c in cols:
+                if isinstance(c, dict):
+                    ((src, dst),) = c.items()
+                    mapping.append((src, dst))
+                elif ":" in c:
+                    s, d = c.split(":", 1)
+                    mapping.append((s.strip(), d.strip()))
+                else:
+                    mapping.append((c, c))
+        return cls(mapping)
+
+    def apply(self, rows: Rows) -> Rows:
+        _require_columns(rows, [s for s, _ in self.mapping])
+        out = []
+        for r in rows:
+            out.append({dst: r.get(src) for src, dst in self.mapping})
+        return out
+
+    def describe(self):
+        return "select " + ",".join(
+            s if s == d else f"{s}:{d}" for s, d in self.mapping
+        )
+
+
+# ------------------------------------------------------------------ rename
+@register
+class Rename(Op):
+    name = "rename"
+    cli_help = "old:new[,old2:new2,…] — rename columns, keep all others"
+
+    def __init__(self, mapping: Dict[str, str]):
+        self.mapping = mapping
+
+    @classmethod
+    def from_cli(cls, arg: str) -> "Rename":
+        m: Dict[str, str] = {}
+        for raw in arg.split(","):
+            tok = raw.strip()
+            if not tok:
+                continue
+            if ":" not in tok:
+                raise TablesmithError(
+                    f"invalid rename spec '{tok}'",
+                    step="rename",
+                    hint="use old:new",
+                )
+            s, d = tok.split(":", 1)
+            m[s.strip()] = d.strip()
+        if not m:
+            raise TablesmithError("rename requires at least one old:new pair", step="rename")
+        return cls(m)
+
+    @classmethod
+    def from_spec(cls, spec):
+        return cls(dict(spec["columns"]))
+
+    def apply(self, rows: Rows) -> Rows:
+        _require_columns(rows, list(self.mapping))
+        out = []
+        for r in rows:
+            nr = {}
+            for k, v in r.items():
+                nr[self.mapping.get(k, k)] = v
+            out.append(nr)
+        return out
+
+
+# -------------------------------------------------------------------- drop
+@register
+class Drop(Op):
+    name = "drop"
+    cli_help = "COLS — comma-separated columns to remove"
+
+    def __init__(self, cols: List[str]):
+        self.cols = cols
+
+    @classmethod
+    def from_cli(cls, arg):
+        cols = [c.strip() for c in arg.split(",") if c.strip()]
+        if not cols:
+            raise TablesmithError("drop requires at least one column", step="drop")
+        return cls(cols)
+
+    @classmethod
+    def from_spec(cls, spec):
+        return cls(list(spec["columns"]))
+
+    def apply(self, rows: Rows) -> Rows:
+        kill = set(self.cols)
+        return [{k: v for k, v in r.items() if k not in kill} for r in rows]
+
+
+# -------------------------------------------------------------------- sort
+@register
+class Sort(Op):
+    name = "sort"
+    aliases = ("order",)
+    cli_help = "KEYS — comma-separated keys; prefix '-' or suffix ':desc' for descending"
+
+    def __init__(self, keys: List[Tuple[str, bool]]):
+        self.keys = keys  # list of (col, desc)
+
+    @classmethod
+    def from_cli(cls, arg):
+        keys: List[Tuple[str, bool]] = []
+        for raw in arg.split(","):
+            tok = raw.strip()
+            if not tok:
+                continue
+            desc = False
+            if tok.startswith("-"):
+                desc, tok = True, tok[1:]
+            elif ":" in tok:
+                col, d = tok.rsplit(":", 1)
+                if d.lower() in ("desc", "d"):
+                    desc, tok = True, col
+                elif d.lower() in ("asc", "a"):
+                    tok = col
+            keys.append((tok, desc))
+        if not keys:
+            raise TablesmithError("sort requires at least one key", step="sort")
+        return cls(keys)
+
+    @classmethod
+    def from_spec(cls, spec):
+        by = spec["by"]
+        if isinstance(by, str):
+            by = [by]
+        desc = spec.get("desc", False)
+        keys: List[Tuple[str, bool]] = []
+        for k in by:
+            if isinstance(k, str) and k.startswith("-"):
+                keys.append((k[1:], True))
+            else:
+                keys.append((k, bool(desc)))
+        return cls(keys)
+
+    def apply(self, rows: Rows) -> Rows:
+        _require_columns(rows, [c for c, _ in self.keys])
+        out = list(rows)
+        # stable sort: apply keys right-to-left
+        for col, desc in reversed(self.keys):
+            out.sort(key=lambda r: _SortKey(r.get(col)), reverse=desc)
+        return out
+
+
+class _SortKey:
+    """Wrapper that orders None first and compares heterogeneous types by
+    (type-rank, value) so mixed columns don't crash."""
+
+    _RANK = {type(None): 0, bool: 1, int: 2, float: 2, str: 3}
+
+    __slots__ = ("rank", "val")
+
+    def __init__(self, v):
+        self.rank = self._RANK.get(type(v), 4)
+        self.val = "" if v is None else v
+
+    def __lt__(self, other):
+        if self.rank != other.rank:
+            return self.rank < other.rank
+        try:
+            return self.val < other.val
+        except TypeError:
+            return str(self.val) < str(other.val)
+
+    def __eq__(self, other):
+        return self.rank == other.rank and self.val == other.val
+
+
+# ------------------------------------------------------------------- group
+_AGGS: Dict[str, Callable[[List[Any]], Any]] = {
+    "count": len,
+    "sum": lambda xs: sum(x for x in xs if x is not None),
+    "min": lambda xs: min((x for x in xs if x is not None), default=None),
+    "max": lambda xs: max((x for x in xs if x is not None), default=None),
+    "avg": lambda xs: (statistics.fmean([x for x in xs if x is not None]) if any(x is not None for x in xs) else None),
+    "mean": lambda xs: (statistics.fmean([x for x in xs if x is not None]) if any(x is not None for x in xs) else None),
+    "median": lambda xs: (statistics.median([x for x in xs if x is not None]) if any(x is not None for x in xs) else None),
+    "first": lambda xs: xs[0] if xs else None,
+    "last": lambda xs: xs[-1] if xs else None,
+    "list": list,
+    "nunique": lambda xs: len(set(xs)),
+}
+
+
+@register
+class Group(Op):
+    name = "group"
+    aliases = ("groupby", "agg")
+    cli_help = (
+        "KEYS:AGGS — e.g. 'dept:sum(salary),avg(age),count()' ; "
+        "aggregates: " + ", ".join(sorted(set(_AGGS)))
+    )
+
+    def __init__(self, by: List[str], aggs: List[Tuple[str, Optional[str], str]]):
+        # aggs: list of (func, column_or_None, output_name)
+        self.by = by
+        self.aggs = aggs
+
+    @classmethod
+    def from_cli(cls, arg):
+        if ":" not in arg:
+            raise TablesmithError(
+                "group requires 'KEYS:AGGS'",
+                step="group",
+                hint="e.g. --group 'dept:sum(salary),count()'",
+            )
+        keys_part, aggs_part = arg.split(":", 1)
+        by = [k.strip() for k in keys_part.split(",") if k.strip()]
+        aggs = cls._parse_aggs(aggs_part)
+        if not by:
+            raise TablesmithError("group requires at least one key column", step="group")
+        return cls(by, aggs)
+
+    @staticmethod
+    def _parse_aggs(s: str) -> List[Tuple[str, Optional[str], str]]:
+        out: List[Tuple[str, Optional[str], str]] = []
+        for raw in s.split(","):
+            tok = raw.strip()
+            if not tok:
+                continue
+            alias = None
+            low = tok.lower()
+            if " as " in low:
+                idx = low.index(" as ")
+                tok, alias = tok[:idx].strip(), tok[idx + 4 :].strip()
+            if "(" not in tok or not tok.endswith(")"):
+                raise TablesmithError(
+                    f"invalid aggregate '{raw}'",
+                    step="group",
+                    hint="use func(col) or count(), e.g. sum(salary)",
+                )
+            fn, rest = tok.split("(", 1)
+            fn = fn.strip().lower()
+            col = rest[:-1].strip() or None
+            if col == "*":
+                col = None
+            if fn not in _AGGS:
+                raise TablesmithError(
+                    f"unknown aggregate '{fn}'",
+                    step="group",
+                    hint="available: " + ", ".join(sorted(set(_AGGS))),
+                )
+            if alias is None:
+                alias = fn if col is None else f"{fn}_{col}"
+            out.append((fn, col, alias))
+        if not out:
+            raise TablesmithError("group requires at least one aggregate", step="group")
+        return out
+
+    @classmethod
+    def from_spec(cls, spec):
+        by = spec["by"]
+        if isinstance(by, str):
+            by = [by]
+        raw_aggs = spec.get("agg") or spec.get("aggs") or []
+        aggs: List[Tuple[str, Optional[str], str]] = []
+        if isinstance(raw_aggs, str):
+            aggs = cls._parse_aggs(raw_aggs)
+        elif isinstance(raw_aggs, list):
+            for a in raw_aggs:
+                if isinstance(a, str):
+                    aggs.extend(cls._parse_aggs(a))
+                else:
+                    fn = a["fn"].lower()
+                    col = a.get("col")
+                    alias = a.get("as") or (fn if col is None else f"{fn}_{col}")
+                    if fn not in _AGGS:
+                        raise TablesmithError(
+                            f"unknown aggregate '{fn}'", step="group",
+                            hint="available: " + ", ".join(sorted(set(_AGGS))),
+                        )
+                    aggs.append((fn, col, alias))
+        if not aggs:
+            aggs = [("count", None, "count")]
+        return cls(list(by), aggs)
+
+    def apply(self, rows: Rows) -> Rows:
+        needed = list(self.by) + [c for _, c, _ in self.aggs if c]
+        _require_columns(rows, needed)
+        buckets: "OrderedDict[Tuple, Rows]" = OrderedDict()
+        for r in rows:
+            key = tuple(r.get(k) for k in self.by)
+            buckets.setdefault(key, []).append(r)
+        out: Rows = []
+        for key, grp in buckets.items():
+            nr: Row = {k: v for k, v in zip(self.by, key)}
+            for fn, col, alias in self.aggs:
+                if col is None:
+                    vals = grp if fn in ("count",) else [None] * len(grp)
+                    nr[alias] = _AGGS[fn](vals) if fn != "count" else len(grp)
+                else:
+                    vals = [g.get(col) for g in grp]
+                    try:
+                        nr[alias] = _AGGS[fn](vals)
+                    except (TypeError, statistics.StatisticsError) as e:
+                        raise TablesmithError(
+                            f"aggregate {fn}({col}) failed: {e}",
+                            step="group",
+                            hint=f"check that column '{col}' is numeric",
+                        )
+            out.append(nr)
+        return out
+
+
+# -------------------------------------------------------------------- join
+@register
+class Join(Op):
+    name = "join"
+    cli_help = (
+        "PATH[:FMT] on LEFT[=RIGHT] [how inner|left|right|outer] [prefix PFX] — "
+        "join against another file"
+    )
+
+    def __init__(
+        self,
+        right_rows: Rows,
+        left_key: str,
+        right_key: str,
+        how: str = "inner",
+        prefix: Optional[str] = None,
+        source: str = "<right>",
+    ):
+        self.right = right_rows
+        self.left_key = left_key
+        self.right_key = right_key
+        self.how = how
+        self.prefix = prefix
+        self.source = source
+
+    @classmethod
+    def from_cli(cls, arg: str) -> "Join":
+        # very small keyword parser: PATH[ :FMT] on L[=R] [how H] [prefix P]
+        toks = arg.split()
+        if not toks:
+            raise TablesmithError("join requires a file path", step="join")
+        path_tok = toks[0]
+        fmt = None
+        if ":" in path_tok and not path_tok.startswith(("http:", "https:")):
+            maybe_path, maybe_fmt = path_tok.rsplit(":", 1)
+            if maybe_fmt.lower() in ("csv", "json", "jsonl"):
+                path_tok, fmt = maybe_path, maybe_fmt
+        kw: Dict[str, str] = {}
+        i = 1
+        while i < len(toks) - 0:
+            if i + 1 >= len(toks) + 0:
+                break
+            if i + 1 <= len(toks) - 1:
+                kw[toks[i].lower()] = toks[i + 1]
+                i += 2
+            else:
+                break
+        if "on" not in kw:
+            raise TablesmithError(
+                "join requires 'on <key>'",
+                step="join",
+                hint="e.g. --join 'other.csv on id' or 'other.csv on user_id=id'",
+            )
+        on = kw["on"]
+        if "=" in on:
+            lk, rk = (p.strip() for p in on.split("=", 1))
+        else:
+            lk = rk = on.strip()
+        how = kw.get("how", "inner").lower()
+        if how not in ("inner", "left", "right", "outer", "full"):
+            raise TablesmithError(
+                f"unknown join type '{how}'",
+                step="join",
+                hint="use one of: inner, left, right, outer",
+            )
+        if how == "full":
+            how = "outer"
+        prefix = kw.get("prefix")
+        right = read_rows(path_tok, fmt)
+        return cls(right, lk, rk, how, prefix, source=path_tok)
+
+    @classmethod
+    def from_spec(cls, spec):
+        path = spec["path"]
+        fmt = spec.get("format")
+        on = spec["on"]
+        if isinstance(on, dict):
+            ((lk, rk),) = on.items()
+        elif isinstance(on, (list, tuple)) and len(on) == 2:
+            lk, rk = on
+        elif "=" in on:
+            lk, rk = (p.strip() for p in on.split("=", 1))
+        else:
+            lk = rk = on
+        how = spec.get("how", "inner").lower()
+        if how == "full":
+            how = "outer"
+        prefix = spec.get("prefix")
+        right = read_rows(path, fmt)
+        return cls(right, lk, rk, how, prefix, source=path)
+
+    def apply(self, rows: Rows) -> Rows:
+        _require_columns(rows, [self.left_key])
+        if self.right:
+            rcols = set(_columns_of(self.right))
+            if self.right_key not in rcols:
+                raise unknown_column(self.right_key, rcols)
+        # index right side (multi-map)
+        index: Dict[Any, Rows] = {}
+        for r in self.right:
+            index.setdefault(r.get(self.right_key), []).append(r)
+
+        left_cols = _columns_of(rows)
+        right_cols = [c for c in _columns_of(self.right) if c != self.right_key]
+
+        def merge(l: Optional[Row], r: Optional[Row]) -> Row:
+            nr: Row = {}
+            for c in left_cols:
+                nr[c] = (l or {}).get(c)
+            for c in right_cols:
+                out_name = c
+                if self.prefix:
+                    out_name = f"{self.prefix}{c}"
+                elif c in nr:
+                    out_name = f"r_{c}"
+                nr[out_name] = (r or {}).get(c)
+            return nr
+
+        out: Rows = []
+        matched_right: set = set()
+        for l in rows:
+            k = l.get(self.left_key)
+            matches = index.get(k, [])
+            if matches:
+                for r in matches:
+                    out.append(merge(l, r))
+                matched_right.add(k)
+            elif self.how in ("left", "outer"):
+                out.append(merge(l, None))
+        if self.how in ("right", "outer"):
+            for k, rs in index.items():
+                if k in matched_right:
+                    continue
+                for r in rs:
+                    nr = merge(None, r)
+                    nr[self.left_key] = r.get(self.right_key)
+                    out.append(nr)
+        return out
+
+    def describe(self):
+        return f"join {self.source} on {self.left_key}={self.right_key} ({self.how})"
+
+
+# ----------------------------------------------------------------- compute
+@register
+class Compute(Op):
+    name = "compute"
+    aliases = ("add", "derive", "mutate")
+    cli_help = "NAME=EXPR — add/overwrite a column from an expression"
+
+    def __init__(self, col: str, expr: str):
+        self.col = col
+        self.expr_src = expr
+        self.expr = Expression(expr)
+
+    @classmethod
+    def from_cli(cls, arg):
+        if "=" not in arg:
+            raise TablesmithError(
+                "compute requires NAME=EXPR",
+                step="compute",
+                hint="e.g. --compute 'total=price*qty'",
+            )
+        name, expr = arg.split("=", 1)
+        return cls(name.strip(), expr.strip())
+
+    @classmethod
+    def from_spec(cls, spec):
+        return cls(spec["column"], spec["expr"])
+
+    def apply(self, rows: Rows) -> Rows:
+        out = []
+        for i, r in enumerate(rows):
+            try:
+                val = self.expr.eval(r)
+            except TablesmithError as e:
+                e.row_index = i
+                raise
+            nr = dict(r)
+            nr[self.col] = val
+            out.append(nr)
+        return out
+
+    def describe(self):
+        return f"compute {self.col}={self.expr_src}"
+
+
+# ------------------------------------------------------------------- limit
+@register
+class Limit(Op):
+    name = "limit"
+    aliases = ("head",)
+    cli_help = "N[,OFFSET] — keep at most N rows, optionally skipping OFFSET"
+
+    def __init__(self, n: int, offset: int = 0):
+        self.n = n
+        self.offset = offset
+
+    @classmethod
+    def from_cli(cls, arg):
+        parts = [p.strip() for p in arg.split(",")]
+        try:
+            n = int(parts[0])
+            off = int(parts[1]) if len(parts) > 1 else 0
+        except (ValueError, IndexError):
+            raise TablesmithError(
+                f"invalid limit '{arg}'", step="limit", hint="use N or N,OFFSET"
+            )
+        return cls(n, off)
+
+    @classmethod
+    def from_spec(cls, spec):
+        return cls(int(spec["n"]), int(spec.get("offset", 0)))
+
+    def apply(self, rows: Rows) -> Rows:
+        return rows[self.offset : self.offset + self.n]
+
+
+# ---------------------------------------------------------------- distinct
+@register
+class Distinct(Op):
+    name = "distinct"
+    aliases = ("unique", "dedup")
+    cli_help = "[COLS] — drop duplicate rows (optionally judged on a subset of columns)"
+
+    def __init__(self, cols: Optional[List[str]] = None):
+        self.cols = cols
+
+    @classmethod
+    def from_cli(cls, arg):
+        cols = [c.strip() for c in arg.split(",") if c.strip()] if arg else None
+        return cls(cols)
+
+    @classmethod
+    def from_spec(cls, spec):
+        c = spec.get("columns")
+        return cls(list(c) if c else None)
+
+    def apply(self, rows: Rows) -> Rows:
+        if self.cols:
+            _require_columns(rows, self.cols)
+        seen = set()
+        out = []
+        for r in rows:
+            if self.cols:
+                key = tuple(r.get(c) for c in self.cols)
+            else:
+                key = tuple(sorted(r.items()))
+            if key in seen:
+                continue
+            seen.add(key)
+            out.append(r)
+        return out
+
+
+# ----------------------------------------------------------- build helpers
+def build_from_cli(name: str, arg: str) -> Op:
+    cls = REGISTRY.get(name)
+    if cls is None:
+        raise TablesmithError(
+            f"unknown operation '{name}'",
+            hint="available: " + ", ".join(sorted(set(c.name for c in REGISTRY.values()))),
+        )
+    return cls.from_cli(arg)
+
+
+def build_from_spec(spec: Dict[str, Any]) -> Op:
+    if "op" not in spec:
+        raise TablesmithError(
+            "pipeline step is missing required field 'op'",
+            hint=f"got keys: {', '.join(spec.keys())}",
+        )
+    name = spec["op"]
+    cls = REGISTRY.get(name)
+    if cls is None:
+        raise TablesmithError(
+            f"unknown operation '{name}'",
+            hint="available: " + ", ".join(sorted(set(c.name for c in REGISTRY.values()))),
+        )
+    try:
+        return cls.from_spec({k: v for k, v in spec.items() if k != "op"})
+    except KeyError as e:
+        raise TablesmithError(
+            f"step '{name}' is missing required field {e}",
+            step=name,
+        )
