@@ -0,0 +1,111 @@
+"""Automatic type inference for string-valued cells (CSV in particular).
+
+Strategy: per-column, sample up to N non-empty values, try to parse each as
+int → float → bool → null; if *every* sample parses as the same type, coerce
+the whole column. Otherwise leave as string. Individual unparseable cells in
+a coerced column fall back to their raw string (never crash on inference).
+"""
+from __future__ import annotations
+
+from typing import Any, Dict, Iterable, List, Optional
+
+_NULLS = {"", "null", "none", "na", "n/a", "nan"}
+_TRUE = {"true", "t", "yes", "y", "1"}
+_FALSE = {"false", "f", "no", "n", "0"}
+
+
+def _try_int(s: str):
+    try:
+        if s.strip().lower().startswith("0x"):
+            return None  # avoid surprising hex parse
+        i = int(s)
+        return i
+    except (ValueError, TypeError):
+        return None
+
+
+def _try_float(s: str):
+    try:
+        f = float(s)
+        return f
+    except (ValueError, TypeError):
+        return None
+
+
+def _try_bool(s: str):
+    low = s.strip().lower()
+    if low in _TRUE:
+        return True
+    if low in _FALSE:
+        return False
+    return None
+
+
+def infer_scalar(s: Any) -> Any:
+    """Best-effort coerce a single raw string cell."""
+    if s is None:
+        return None
+    if not isinstance(s, str):
+        return s  # already typed (e.g. from JSON)
+    low = s.strip().lower()
+    if low in _NULLS:
+        return None
+    i = _try_int(s)
+    if i is not None:
+        return i
+    f = _try_float(s)
+    if f is not None:
+        return f
+    b = _try_bool(s)
+    if b is not None:
+        return b
+    return s
+
+
+def infer_columns(rows: List[Dict[str, Any]], sample: int = 200) -> List[Dict[str, Any]]:
+    """Infer a type per column from a sample, then coerce all rows in place.
+
+    Only touches cells that are currently `str`. JSON-sourced rows that are
+    already typed pass through unchanged.
+    """
+    if not rows:
+        return rows
+
+    cols: List[str] = []
+    for r in rows:
+        for k in r:
+            if k not in cols:
+                cols.append(k)
+
