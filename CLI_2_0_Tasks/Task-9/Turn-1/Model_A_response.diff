@@ -0,0 +1,81 @@
+"""Structured, human-friendly errors.
+
+Every error carries enough context to tell the user *where* in the pipeline
+things went wrong, *what* was wrong, and — when we can guess — *how to fix it*.
+"""
+from __future__ import annotations
+
+import difflib
+from typing import Iterable, Optional
+
+
+class TablesmithError(Exception):
+    """Base error. Renders a multi-line, contextual message."""
+
+    def __init__(
+        self,
+        message: str,
+        *,
+        step: Optional[str] = None,
+        step_index: Optional[int] = None,
+        row_index: Optional[int] = None,
+        hint: Optional[str] = None,
+        source: Optional[str] = None,
+    ):
+        self.message = message
+        self.step = step
+        self.step_index = step_index
+        self.row_index = row_index
+        self.hint = hint
+        self.source = source
+        super().__init__(self.render())
+
+    def render(self) -> str:
+        lines = []
+        header = "error"
+        loc = []
+        if self.step is not None:
+            idx = f" #{self.step_index + 1}" if self.step_index is not None else ""
+            loc.append(f"step{idx} [{self.step}]")
+        if self.row_index is not None:
+            loc.append(f"row {self.row_index + 1}")
+        if self.source:
+            loc.append(f"in {self.source}")
+        if loc:
+            header += " (" + ", ".join(loc) + ")"
+        lines.append(f"{header}: {self.message}")
+        if self.hint:
+            for h in self.hint.splitlines():
+                lines.append(f"  hint: {h}")
+        return "\n".join(lines)
+
+    def __str__(self) -> str:
+        return self.render()
+
+
+class ColumnError(TablesmithError):
+    pass
+
+
+class ExpressionError(TablesmithError):
+    pass
+
+
+class FormatError(TablesmithError):
+    pass
+
+
+class PipelineFileError(TablesmithError):
+    pass
+
+
+def unknown_column(name: str, available: Iterable[str], **ctx) -> ColumnError:
+    cols = list(available)
+    hint = None
+    close = difflib.get_close_matches(name, cols, n=1)
+    if close:
+        hint = f"did you mean '{close[0]}'?"
+    elif cols:
+        preview = ", ".join(cols[:8]) + (" …" if len(cols) > 8 else "")
+        hint = f"available columns: {preview}"
+    return ColumnError(f"unknown column '{name}'", hint=hint, **ctx)
