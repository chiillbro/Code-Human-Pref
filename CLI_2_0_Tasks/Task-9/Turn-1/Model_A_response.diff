+"""A small, safe expression evaluator over row dicts.
+
+Supports:
+  * column references by bare name:       age, first_name
+  * literals:                              42, 3.14, "foo", True, False, None
+  * comparisons:                           ==, !=, <, <=, >, >=, in, not in
+  * boolean logic:                         and, or, not
+  * arithmetic:                            +, -, *, /, //, %, ** , unary -
+  * a small function whitelist:            len, abs, round, min, max, str,
+                                           int, float, lower, upper, strip,
+                                           startswith, endswith, contains,
+                                           coalesce
+
+Anything outside this grammar raises ExpressionError with a pointer to the
+offending fragment. No attribute access, no subscripts on arbitrary objects,
+no `__` names — so no escape hatch to builtins.
+"""
+from __future__ import annotations
+
+import ast
+import operator
+import re
+from typing import Any, Callable, Dict, Iterable, Mapping, Optional
+
+from .errors import ExpressionError, unknown_column
+
+_BIN_OPS: Dict[type, Callable[[Any, Any], Any]] = {
+    ast.Add: operator.add,
+    ast.Sub: operator.sub,
+    ast.Mult: operator.mul,
+    ast.Div: operator.truediv,
+    ast.FloorDiv: operator.floordiv,
+    ast.Mod: operator.mod,
+    ast.Pow: operator.pow,
+}
+
+_CMP_OPS: Dict[type, Callable[[Any, Any], bool]] = {
+    ast.Eq: operator.eq,
+    ast.NotEq: operator.ne,
+    ast.Lt: operator.lt,
+    ast.LtE: operator.le,
+    ast.Gt: operator.gt,
+    ast.GtE: operator.ge,
+    ast.In: lambda a, b: a in b,
+    ast.NotIn: lambda a, b: a not in b,
+}
+
+_UNARY_OPS: Dict[type, Callable[[Any], Any]] = {
+    ast.USub: operator.neg,
+    ast.UAdd: operator.pos,
+    ast.Not: operator.not_,
+}
+
+_CONSTS = {"True": True, "False": False, "None": None, "null": None}
+
+
+def _coalesce(*args):
+    for a in args:
+        if a is not None:
+            return a
+    return None
+
+
+_FUNCS: Dict[str, Callable[..., Any]] = {
+    "len": len,
+    "abs": abs,
+    "round": round,
+    "min": min,
+    "max": max,
+    "str": str,
+    "int": int,
+    "float": float,
+    "bool": bool,
+    "lower": lambda s: str(s).lower(),
+    "upper": lambda s: str(s).upper(),
+    "strip": lambda s: str(s).strip(),
+    "startswith": lambda s, p: str(s).startswith(p),
+    "endswith": lambda s, p: str(s).endswith(p),
+    "contains": lambda s, p: p in str(s),
+    "coalesce": _coalesce,
+    "matches": lambda s, pat: re.search(pat, str(s)) is not None,
+}
+
+
+class Expression:
+    """A compiled expression that can be evaluated against row dicts."""
+
+    def __init__(self, source: str, columns: Optional[Iterable[str]] = None):
+        self.source = source
+        self._columns = set(columns) if columns is not None else None
+        try:
+            self._tree = ast.parse(source, mode="eval")
+        except SyntaxError as e:
+            pointer = self._pointer(e.offset or 1)
+            raise ExpressionError(
+                f"invalid expression: {e.msg}",
+                hint=f"{source}\n{pointer}",
+            )
+        self._validate(self._tree.body)
+
+    # ---- validation -----------------------------------------------------
+    def _validate(self, node: ast.AST) -> None:
+        if isinstance(node, ast.BoolOp):
+            for v in node.values:
+                self._validate(v)
+        elif isinstance(node, ast.BinOp):
+            if type(node.op) not in _BIN_OPS:
+                self._bad(node, f"operator '{type(node.op).__name__}' not allowed")
+            self._validate(node.left)
+            self._validate(node.right)
+        elif isinstance(node, ast.UnaryOp):
+            if type(node.op) not in _UNARY_OPS:
+                self._bad(node, f"unary operator '{type(node.op).__name__}' not allowed")
+            self._validate(node.operand)
+        elif isinstance(node, ast.Compare):
+            self._validate(node.left)
+            for op, comp in zip(node.ops, node.comparators):
+                if type(op) not in _CMP_OPS:
+                    self._bad(node, f"comparison '{type(op).__name__}' not allowed")
+                self._validate(comp)
+        elif isinstance(node, ast.Call):
+            if not isinstance(node.func, ast.Name) or node.func.id not in _FUNCS:
+                name = getattr(node.func, "id", ast.dump(node.func))
+                self._bad(
+                    node,
+                    f"function '{name}' is not allowed",
+                    hint="allowed: " + ", ".join(sorted(_FUNCS)),
+                )
+            for a in node.args:
+                self._validate(a)
+            if node.keywords:
+                self._bad(node, "keyword arguments are not supported in expressions")
+        elif isinstance(node, ast.Name):
+            if node.id in _CONSTS or node.id in _FUNCS:
+                return
+            if "__" in node.id:
+                self._bad(node, f"illegal identifier '{node.id}'")
+            if self._columns is not None and node.id not in self._columns:
+                raise unknown_column(node.id, self._columns)
+        elif isinstance(node, ast.Constant):
+            return
+        elif isinstance(node, (ast.List, ast.Tuple, ast.Set)):
+            for e in node.elts:
+                self._validate(e)
+        elif isinstance(node, ast.IfExp):
+            self._validate(node.test)
+            self._validate(node.body)
+            self._validate(node.orelse)
+        else:
+            self._bad(node, f"unsupported syntax: {type(node).__name__}")
+
+    def _bad(self, node: ast.AST, msg: str, hint: Optional[str] = None):
+        col = getattr(node, "col_offset", 0) + 1
+        pointer = self._pointer(col)
+        raise ExpressionError(msg, hint=(hint or f"{self.source}\n{pointer}"))
+
+    def _pointer(self, col: int) -> str:
+        return " " * max(0, col - 1) + "^"
+
+    # ---- evaluation -----------------------------------------------------
+    def referenced_columns(self) -> set:
+        cols = set()
+        for n in ast.walk(self._tree):
+            if isinstance(n, ast.Name) and n.id not in _CONSTS and n.id not in _FUNCS:
+                cols.add(n.id)
+        return cols
+
+    def eval(self, row: Mapping[str, Any]) -> Any:
+        return self._eval(self._tree.body, row)
+
+    def _eval(self, node: ast.AST, row: Mapping[str, Any]) -> Any:
+        if isinstance(node, ast.BoolOp):
+            if isinstance(node.op, ast.And):
+                r = True
+                for v in node.values:
+                    r = self._eval(v, row)
+                    if not r:
+                        return r
+                return r
+            else:  # Or
+                r = False
+                for v in node.values:
+                    r = self._eval(v, row)
+                    if r:
+                        return r
+                return r
+        if isinstance(node, ast.BinOp):
+            left = self._eval(node.left, row)
+            right = self._eval(node.right, row)
+            try:
+                return _BIN_OPS[type(node.op)](left, right)
+            except TypeError as e:
+                raise ExpressionError(
+                    f"cannot apply operator to {type(left).__name__} and "
+                    f"{type(right).__name__}: {e}",
+                    hint=self.source,
+                )
+            except ZeroDivisionError:
+                raise ExpressionError("division by zero", hint=self.source)
+        if isinstance(node, ast.UnaryOp):
+            return _UNARY_OPS[type(node.op)](self._eval(node.operand, row))
+        if isinstance(node, ast.Compare):
+            left = self._eval(node.left, row)
+            for op, comp in zip(node.ops, node.comparators):
+                right = self._eval(comp, row)
+                try:
+                    ok = _CMP_OPS[type(op)](left, right)
+                except TypeError:
+                    # None compared to number etc. → treat as non-match
+                    return False
+                if not ok:
+                    return False
+                left = right
+            return True
+        if isinstance(node, ast.Call):
+            fn = _FUNCS[node.func.id]
+            args = [self._eval(a, row) for a in node.args]
+            try:
+                return fn(*args)
+            except Exception as e:
+                raise ExpressionError(
+                    f"error calling {node.func.id}(): {e}", hint=self.source
+                )
+        if isinstance(node, ast.IfExp):
+            return (
+                self._eval(node.body, row)
+                if self._eval(node.test, row)
+                else self._eval(node.orelse, row)
+            )
+        if isinstance(node, ast.Name):
+            if node.id in _CONSTS:
+                return _CONSTS[node.id]
+            if node.id in row:
+                return row[node.id]
+            raise unknown_column(node.id, row.keys())
+        if isinstance(node, ast.Constant):
+            return node.value
+        if isinstance(node, (ast.List, ast.Tuple, ast.Set)):
+            vals = [self._eval(e, row) for e in node.elts]
+            if isinstance(node, ast.Set):
+                return set(vals)
+            if isinstance(node, ast.Tuple):
+                return tuple(vals)
+            return vals
+        raise ExpressionError(f"unsupported syntax: {type(node).__name__}")
