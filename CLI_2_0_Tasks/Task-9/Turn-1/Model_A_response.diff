+"""Command-line interface for tablesmith."""
+from __future__ import annotations
+
+import argparse
+import sys
+import traceback
+from typing import List, Optional, Tuple
+
+from . import __version__
+from .errors import TablesmithError
+from .ioformats import FORMATS
+from .ops import REGISTRY, build_from_cli
+from .pipeline import Pipeline
+
+
+class _StepAction(argparse.Action):
+    """Append (op_name, raw_arg) to a shared ordered list so that
+    `--filter x --sort y --filter z` runs in exactly that order."""
+
+    def __init__(self, option_strings, dest, op_name: str, **kw):
+        self.op_name = op_name
+        super().__init__(option_strings, dest, **kw)
+
+    def __call__(self, parser, namespace, values, option_string=None):
+        steps: List[Tuple[str, str]] = getattr(namespace, "steps", None) or []
+        steps.append((self.op_name, values if values is not None else ""))
+        setattr(namespace, "steps", steps)
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    # canonical op names, de-duplicated
+    canon = sorted({cls.name: cls for cls in REGISTRY.values()}.items())
+
+    epilog_lines = ["operations (applied in the order given on the command line):"]
+    for name, cls in canon:
+        epilog_lines.append(f"  --{name:<9} {cls.cli_help}")
+    epilog_lines += [
+        "",
+        "examples:",
+        "  tablesmith data.csv --filter 'age >= 18' --select 'name,age' --sort '-age'",
+        "  cat data.jsonl | tablesmith - -i jsonl --group 'dept:avg(salary),count()' -F json",
+        "  tablesmith --pipeline transform.json",
+    ]
+
+    p = argparse.ArgumentParser(
+        prog="tablesmith",
+        description=(
+            "A lightweight pipeline engine for tabular data (CSV / JSON / JSONL).\n"
+            "Chain operations with inline flags, or run a saved pipeline file."
+        ),
+        epilog="\n".join(epilog_lines),
+        formatter_class=argparse.RawDescriptionHelpFormatter,
+    )
+    p.add_argument(
+        "input",
+        nargs="?",
+        default=None,
+        help="input file path, or '-' for stdin (default: stdin)",
+    )
+    p.add_argument("-o", "--output", default=None, help="output file path (default: stdout)")
+    p.add_argument(
+        "-i", "--input-format", choices=FORMATS, default=None,
+        help="force input format (default: detect from extension, else csv)",
+    )
+    p.add_argument(
+        "-F", "--output-format", choices=FORMATS, default=None,
+        help="force output format (default: detect from extension, else csv)",
+    )
+    p.add_argument("--delimiter", default=None, help="CSV delimiter (input); auto-sniffed by default")
+    p.add_argument(
+        "--no-infer", action="store_true",
+        help="disable automatic type inference (keep all CSV values as strings)",
+    )
+    p.add_argument(
+        "-p", "--pipeline", default=None, metavar="FILE",
+        help="run a JSON pipeline definition file (steps run before any inline flags)",
+    )
+    p.add_argument(
+        "--explain", action="store_true",
+        help="print the resolved pipeline and exit without running it",
+    )
+    p.add_argument("--debug", action="store_true", help="show full Python traceback on error")
+    p.add_argument("-V", "--version", action="version", version=f"tablesmith {__version__}")
+
+    # one flag per canonical op; aliases become additional option strings
+    p.set_defaults(steps=[])
+    for name, cls in canon:
+        opts = [f"--{name}"]
+        for a in getattr(cls, "aliases", ()):
+            if a not in {n for n, _ in canon}:
+                opts.append(f"--{a}")
+        nargs = "?" if name == "distinct" else None
+        p.add_argument(
+            *opts,
+            action=_StepAction,
+            op_name=name,
+            dest="_ignored_" + name,  # value goes into namespace.steps, not here
+            metavar="ARG",
+            nargs=nargs,
+            help=argparse.SUPPRESS,  # documented in epilog instead
+        )
+    return p
+
+
+def main(argv: Optional[List[str]] = None) -> int:
+    parser = _build_parser()
+    args = parser.parse_args(argv)
+
+    try:
+        if args.pipeline:
+            pipe = Pipeline.from_file(args.pipeline)
+        else:
+            pipe = Pipeline()
+
+        for idx, (name, raw) in enumerate(args.steps):
+            try:
+                pipe.add(build_from_cli(name, raw))
+            except TablesmithError as e:
+                if e.step is None:
+                    e.step = name
+                if e.step_index is None:
+                    e.step_index = len(pipe.steps)
+                raise
+
+        if args.explain:
+            print(pipe.describe())
+            return 0
+
+        in_path = args.input
+        if in_path is None and pipe.input_spec is None:
+            in_path = "-"
+
+        pipe.run_io(
+            in_path=in_path,
+            in_fmt=args.input_format,
+            out_path=args.output,
+            out_fmt=args.output_format,
+            delimiter=args.delimiter,
+            no_infer=args.no_infer,
+        )
+        return 0
+
+    except TablesmithError as e:
+        print(f"tablesmith: {e}", file=sys.stderr)
+        if args.debug:
+            traceback.print_exc()
+        return 1
+    except BrokenPipeError:
+        # downstream closed (e.g. `| head`); exit quietly
+        try:
+            sys.stderr.close()
+        except Exception:
+            pass
+        return 0
+    except KeyboardInterrupt:
+        print("tablesmith: interrupted", file=sys.stderr)
+        return 130
+
+
+if __name__ == "__main__":  # pragma: no cover
+    raise SystemExit(main())
