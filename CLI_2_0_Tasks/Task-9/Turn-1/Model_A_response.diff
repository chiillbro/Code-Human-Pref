@@ -0,0 +1,136 @@
+"""Pipeline execution and pipeline-file loading."""
+from __future__ import annotations
+
+import json
+from typing import Any, Dict, List, Optional
+
+from .errors import PipelineFileError, TablesmithError
+from .ioformats import read_rows, write_rows
+from .ops import Op, build_from_spec
+
+
+class Pipeline:
+    def __init__(self, steps: Optional[List[Op]] = None):
+        self.steps: List[Op] = list(steps or [])
+        self.input_spec: Optional[Dict[str, Any]] = None
+        self.output_spec: Optional[Dict[str, Any]] = None
+
+    # ------------------------------------------------------------ build --
+    def add(self, op: Op) -> "Pipeline":
+        self.steps.append(op)
+        return self
+
+    @classmethod
+    def from_file(cls, path: str) -> "Pipeline":
+        try:
+            with open(path, "r", encoding="utf-8") as fh:
+                raw = fh.read()
+        except FileNotFoundError:
+            raise PipelineFileError(f"pipeline file not found: {path}", source=path)
+        except OSError as e:
+            raise PipelineFileError(f"could not read pipeline file: {e}", source=path)
+        try:
+            doc = json.loads(raw)
+        except json.JSONDecodeError as e:
+            raise PipelineFileError(
+                f"invalid JSON in pipeline file at line {e.lineno}, col {e.colno}: {e.msg}",
+                source=path,
+            )
+        return cls.from_dict(doc, source=path)
+
+    @classmethod
+    def from_dict(cls, doc: Dict[str, Any], source: str = "<pipeline>") -> "Pipeline":
+        if not isinstance(doc, dict):
+            raise PipelineFileError(
+                "pipeline file must be a JSON object with a 'steps' array",
+                source=source,
+            )
+        steps_spec = doc.get("steps")
+        if steps_spec is None:
+            raise PipelineFileError(
+                "pipeline file is missing 'steps'",
+                source=source,
+                hint='expected: {"steps": [{"op": "filter", "expr": "..."}]}',
+            )
+        if not isinstance(steps_spec, list):
+            raise PipelineFileError("'steps' must be an array", source=source)
+
+        p = cls()
+        p.input_spec = _norm_io(doc.get("input"))
+        p.output_spec = _norm_io(doc.get("output"))
+        for i, spec in enumerate(steps_spec):
+            if not isinstance(spec, dict):
+                raise PipelineFileError(
+                    f"step #{i + 1} must be an object", source=source
+                )
+            try:
+                op = build_from_spec(spec)
+            except TablesmithError as e:
+                e.step_index = i
+                e.source = source
+                if e.step is None:
+                    e.step = spec.get("op", "?")
+                raise
+            p.add(op)
+        return p
+
+    # -------------------------------------------------------------- run --
+    def run(self, rows: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
+        cur = rows
+        for i, op in enumerate(self.steps):
+            try:
+                cur = op.apply(cur)
+            except TablesmithError as e:
+                if e.step is None:
+                    e.step = op.name
+                if e.step_index is None:
+                    e.step_index = i
+                raise
+            except Exception as e:  # pragma: no cover — safety net
+                raise TablesmithError(
+                    f"unexpected {type(e).__name__}: {e}",
+                    step=op.name,
+                    step_index=i,
+                    hint="this is likely a bug in tablesmith; please report it",
+                ) from e
+        return cur
+
+    def run_io(
+        self,
+        in_path: Optional[str] = None,
+        in_fmt: Optional[str] = None,
+        out_path: Optional[str] = None,
+        out_fmt: Optional[str] = None,
+        delimiter: Optional[str] = None,
+        no_infer: bool = False,
+    ) -> None:
+        ispec = self.input_spec or {}
+        ospec = self.output_spec or {}
+        rows = read_rows(
+            in_path if in_path is not None else ispec.get("path"),
+            in_fmt or ispec.get("format"),
+            delimiter=delimiter or ispec.get("delimiter"),
+            no_infer=no_infer,
+        )
+        rows = self.run(rows)
+        write_rows(
+            rows,
+            out_path if out_path is not None else ospec.get("path"),
+            out_fmt or ospec.get("format"),
+            delimiter=(ospec.get("delimiter") or ","),
+        )
+
+    def describe(self) -> str:
+        return " | ".join(op.describe() for op in self.steps) or "(empty pipeline)"
+
+
+def _norm_io(v: Any) -> Optional[Dict[str, Any]]:
+    if v is None:
+        return None
+    if isinstance(v, str):
+        return {"path": v}
+    if isinstance(v, dict):
+        return v
+    raise PipelineFileError(
+        f"'input'/'output' must be a string path or object, got {type(v).__name__}"
+    )
