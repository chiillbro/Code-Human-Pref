+class PipelineInlineCombinedTest(unittest.TestCase):
+    """Pipeline file steps + inline flags must run in the combined order:
+    file steps first, inline steps appended after."""
+
+    def setUp(self):
+        self.csv_path = _write_tmp(_PEOPLE_CSV)
+
+    def tearDown(self):
+        os.unlink(self.csv_path)
+        if hasattr(self, "pipe_path"):
+            os.unlink(self.pipe_path)
+
+    def test_inline_appended_after_pipeline(self):
+        """Pipeline selects name+salary; inline sort+limit narrows further."""
+        doc = {
+            "input": self.csv_path,
+            "steps": [
+                {"op": "filter", "expr": "salary > 80000"},
+                {"op": "select", "columns": ["name", "salary"]},
+            ],
+        }
+        self.pipe_path = _write_tmp(json.dumps(doc), suffix=".json")
+
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            rc = cli_main([
+                "-p", self.pipe_path,
+                "--sort", "salary:desc",
+                "--limit", "2",
+                "-F", "json",
+            ])
+        finally:
+            sys.stdout = old_stdout
+
+        self.assertEqual(rc, 0)
+        rows = json.loads(buf.getvalue())
+        self.assertEqual(len(rows), 2)
+        self.assertEqual(rows[0]["name"], "Eve")
+        self.assertEqual(rows[0]["salary"], 142000)
+        self.assertEqual(rows[1]["name"], "Alice")
+
+    def test_execution_order_matters(self):
+        """The inline filter uses a column that only exists AFTER the
+        pipeline's compute step — proves ordering is file-then-inline."""
+        doc = {
+            "input": self.csv_path,
+            "steps": [
+                {"op": "compute", "column": "bonus", "expr": "salary * 0.1"},
+            ],
+        }
+        self.pipe_path = _write_tmp(json.dumps(doc), suffix=".json")
+
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            rc = cli_main([
+                "-p", self.pipe_path,
+                "--filter", "bonus > 10000",
+                "--select", "name,bonus",
+                "-F", "json",
+            ])
+        finally:
+            sys.stdout = old_stdout
+
+        self.assertEqual(rc, 0)
+        rows = json.loads(buf.getvalue())
+        # only Alice (12000) and Eve (14200) have bonus > 10000
+        names = {r["name"] for r in rows}
+        self.assertEqual(names, {"Alice", "Eve"})
+
+    def test_inline_only_still_works(self):
