@@ -0,0 +1,511 @@
+"""Tests for hardening: fail-fast column errors, inspect, validate, pipeline+inline."""
+from __future__ import annotations
+
+import json
+import os
+import tempfile
+import textwrap
+import unittest
+
+from tablesmith.cli import main as cli_main, _cmd_inspect, _cmd_validate
+from tablesmith.errors import ColumnError, TablesmithError
+from tablesmith.ioformats import read_rows
+from tablesmith.ops import Filter, Select, Sort, Group, Compute, _columns_of
+from tablesmith.pipeline import Pipeline
+
+
+# ---------------------------------------------------------------- helpers --
+
+def _write_tmp(content: str, suffix: str = ".csv") -> str:
+    fd, path = tempfile.mkstemp(suffix=suffix)
+    with os.fdopen(fd, "w") as f:
+        f.write(content)
+    return path
+
+
+_PEOPLE_CSV = textwrap.dedent("""\
+    id,name,age,dept,salary
+    1,Alice,34,eng,120000
+    2,Bob,29,eng,95000
+    3,Carol,41,sales,88000
+    4,Dave,23,sales,61000
+    5,Eve,38,eng,142000
+    6,Frank,,ops,70000
+""")
+
+
+class FilterColumnFailFastTest(unittest.TestCase):
+    """Unknown columns in filter expressions must raise ColumnError with
+    the bad name, available columns, and — when close — a suggestion."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+        self.rows = read_rows(self.path)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    def test_typo_column_raises_column_error(self):
+        """filter on 'agee' (typo) must raise, not silently skip."""
+        f = Filter("agee > 10")
+        with self.assertRaises(ColumnError) as ctx:
+            f.apply(self.rows)
+        err = ctx.exception
+        self.assertIn("agee", err.message)
+
+    def test_typo_column_shows_suggestion(self):
+        f = Filter("agee > 10")
+        with self.assertRaises(ColumnError) as ctx:
+            f.apply(self.rows)
+        rendered = str(ctx.exception)
+        self.assertIn("did you mean", rendered)
+        self.assertIn("age", rendered)
+
+    def test_typo_column_always_shows_available(self):
+        """Even when there is a did-you-mean, the available columns must
+        also be listed so the user can see what's there."""
+        f = Filter("agee > 10")
+        with self.assertRaises(ColumnError) as ctx:
+            f.apply(self.rows)
+        rendered = str(ctx.exception)
+        self.assertIn("available columns:", rendered)
+
+    def test_totally_wrong_column_shows_available(self):
+        """A column name with no close match still lists what's available."""
+        f = Filter("zzz > 0")
+        with self.assertRaises(ColumnError) as ctx:
+            f.apply(self.rows)
+        rendered = str(ctx.exception)
+        self.assertIn("zzz", rendered)
+        self.assertIn("available columns:", rendered)
+
+    def test_filter_never_silently_returns_empty(self):
+        """Ensure a bad column doesn't just produce an empty result."""
+        f = Filter("nonexistent == 1")
+        with self.assertRaises(ColumnError):
+            f.apply(self.rows)
+
+    def test_compute_bad_column_fails_fast(self):
+        """compute also uses expressions; same fail-fast behaviour."""
+        c = Compute("x", "nonexistent * 2")
+        with self.assertRaises(ColumnError):
+            c.apply(self.rows)
+
+    def test_select_bad_column_fails(self):
+        s = Select.from_cli("name,nonexistent")
+        with self.assertRaises(ColumnError) as ctx:
+            s.apply(self.rows)
+        self.assertIn("nonexistent", str(ctx.exception))
+
+    def test_sort_bad_column_fails(self):
+        s = Sort.from_cli("nonexistent:desc")
+        with self.assertRaises(ColumnError):
+            s.apply(self.rows)
+
+
+class InspectOutputShapeTest(unittest.TestCase):
+    """tablesmith inspect must produce a well-structured schema."""
+
+    def setUp(self):
+        self.path = _write_tmp(_PEOPLE_CSV)
+
+    def tearDown(self):
+        os.unlink(self.path)
+
+    def test_inspect_json_has_all_fields(self):
+        """Each entry in JSON inspect output must have column/type/nulls/total/samples."""
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            rc = _cmd_inspect([self.path, "-F", "json"])
+        finally:
+            sys.stdout = old_stdout
+        self.assertEqual(rc, 0)
+        schema = json.loads(buf.getvalue())
+        self.assertIsInstance(schema, list)
+        self.assertEqual(len(schema), 5)  # id, name, age, dept, salary
+        required_keys = {"column", "type", "nulls", "total", "samples"}
+        for entry in schema:
+            self.assertTrue(
+                required_keys <= set(entry.keys()),
+                f"missing keys in {entry}",
+            )
+
+    def test_inspect_types_inferred(self):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            _cmd_inspect([self.path, "-F", "json"])
+        finally:
+            sys.stdout = old_stdout
+        schema = json.loads(buf.getvalue())
+        by_col = {e["column"]: e for e in schema}
+        self.assertEqual(by_col["id"]["type"], "int")
+        self.assertEqual(by_col["name"]["type"], "str")
+        self.assertEqual(by_col["age"]["type"], "int")
+        self.assertEqual(by_col["salary"]["type"], "int")
+
+    def test_inspect_null_count(self):
+        import io, sys
+        buf = io.StringIO()
+        old_stdout = sys.stdout
+        sys.stdout = buf
+        try:
+            _cmd_inspect([self.path, "-F", "json"])
+        finally:
+            sys.stdout = old_stdout
