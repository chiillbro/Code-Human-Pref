+# -------------------------------------------------------------- inspect ---
+
+def _infer_type_label(values: list) -> str:
+    """Given the typed values for a column, return a human label."""
+    types = set()
+    for v in values:
+        if v is None:
+            continue
+        types.add(type(v).__name__)
+    if not types:
+        return "null"
+    if types == {"int"}:
+        return "int"
+    if types <= {"int", "float"}:
+        return "float"
+    if types == {"float"}:
+        return "float"
+    if types == {"bool"}:
+        return "bool"
+    if types == {"str"}:
+        return "str"
+    return "/".join(sorted(types))
+
+
+def _format_sample(v: Any) -> str:
+    if v is None:
+        return "null"
+    if isinstance(v, str):
+        if len(v) > 30:
+            return f'"{v[:27]}..."'
+        return f'"{v}"'
+    return str(v)
+
+
+def _cmd_inspect(argv: List[str]) -> int:
+    p = argparse.ArgumentParser(
+        prog="tablesmith inspect",
+        description="Print inferred schema: column names, types, null counts and sample values.",
+    )
+    p.add_argument("file", help="input file to inspect")
+    p.add_argument("-i", "--input-format", choices=FORMATS, default=None)
+    p.add_argument("--delimiter", default=None)
+    p.add_argument("--no-infer", action="store_true")
+    p.add_argument("-F", "--output-format", choices=("text", "json"), default="text")
+    p.add_argument("--debug", action="store_true")
+    args = p.parse_args(argv)
+
+    try:
+        rows = read_rows(
+            args.file,
+            args.input_format,
+            delimiter=args.delimiter,
+            no_infer=args.no_infer,
+        )
+    except TablesmithError as e:
+        print(f"tablesmith inspect: {e}", file=sys.stderr)
+        return 1
+
+    cols = _columns_of(rows) if rows else []
+
+    schema: List[Dict[str, Any]] = []
+    for col in cols:
+        values = [r.get(col) for r in rows]
+        nulls = sum(1 for v in values if v is None)
+        non_null = [v for v in values if v is not None]
+        samples = non_null[:5]
+        schema.append({
+            "column": col,
+            "type": _infer_type_label(values),
+            "nulls": nulls,
+            "total": len(values),
+            "samples": samples,
+        })
+
+    if args.output_format == "json":
+        json.dump(schema, sys.stdout, indent=2, default=str)
+        sys.stdout.write("\n")
+        return 0
+
+    # text table
+    if not schema:
+        print("(no columns)")
+        return 0
+
+    name_w = max(len(s["column"]) for s in schema)
+    name_w = max(name_w, 6)  # min "Column"
+    type_w = max(len(s["type"]) for s in schema)
+    type_w = max(type_w, 4)
+
+    header = (
+        f"{'Column':<{name_w}}  {'Type':<{type_w}}  "
+        f"{'Nulls':>5}  {'Total':>5}  Sample"
+    )
+    sep = f"{'─' * name_w}  {'─' * type_w}  {'─' * 5}  {'─' * 5}  {'─' * 30}"
+    print(header)
+    print(sep)
+    for s in schema:
+        sample_str = ", ".join(_format_sample(v) for v in s["samples"])
+        print(
+            f"{s['column']:<{name_w}}  {s['type']:<{type_w}}  "
+            f"{s['nulls']:>5}  {s['total']:>5}  {sample_str}"
+        )
+    return 0
+
+
+# ------------------------------------------------------------ validate ---
+
+def _cmd_validate(argv: List[str]) -> int:
+    p = argparse.ArgumentParser(
+        prog="tablesmith validate",
+        description="Validate a pipeline file's structure and column references.",
+    )
+    p.add_argument("pipeline", help="pipeline JSON file to validate")
+    p.add_argument(
+        "--input", default=None,
+        help="input data file (enables column-reference validation across steps)",
+    )
+    p.add_argument("-i", "--input-format", choices=FORMATS, default=None)
+    p.add_argument("--delimiter", default=None)
+    p.add_argument("--no-infer", action="store_true")
+    p.add_argument("--debug", action="store_true")
+    args = p.parse_args(argv)
+
+    # 1. structural validation — parse the pipeline file
+    try:
+        pipe = Pipeline.from_file(args.pipeline)
+    except TablesmithError as e:
+        print(f"tablesmith validate: {e}", file=sys.stderr)
+        return 1
+
+    n = len(pipe.steps)
+    steps_desc = ", ".join(op.name for op in pipe.steps)
+
+    # 2. column-reference validation (if input is available)
+    in_path = args.input
+    if in_path is None and pipe.input_spec:
+        in_path = pipe.input_spec.get("path")
+
+    if in_path and in_path != "-":
+        try:
+            rows = read_rows(
+                in_path,
+                args.input_format or (pipe.input_spec or {}).get("format"),
+                delimiter=args.delimiter,
+                no_infer=args.no_infer,
+            )
+            columns = _columns_of(rows) if rows else []
+            pipe.validate_columns(columns)
+        except TablesmithError as e:
+            print(f"tablesmith validate: {e}", file=sys.stderr)
+            return 1
+        print(
+            f"ok: {args.pipeline} is valid ({n} step{'s' if n != 1 else ''}: "
+            f"{steps_desc}) — columns checked against {in_path}"
+        )
+    else:
+        print(
+            f"ok: {args.pipeline} is valid ({n} step{'s' if n != 1 else ''}: "
+            f"{steps_desc}) — pass --input FILE to also check column references"
+        )
+    return 0
+
+
+# ---------------------------------------------------------- entry point ---
+
+def main(argv: Optional[List[str]] = None) -> int:
+    raw = argv if argv is not None else sys.argv[1:]
+
+    # detect subcommands before argparse touches argv
+    if raw and raw[0] in ("inspect", "validate"):
+        cmd = raw[0]
+        try:
+            if cmd == "inspect":
+                return _cmd_inspect(raw[1:])
+            else:
+                return _cmd_validate(raw[1:])
+        except BrokenPipeError:
+            try:
+                sys.stderr.close()
+            except Exception:
+                pass
+            return 0
+        except KeyboardInterrupt:
+            print("tablesmith: interrupted", file=sys.stderr)
+            return 130
+
+    return _cmd_run(raw)
+
+
 if __name__ == "__main__":  # pragma: no cover
     raise SystemExit(main())
