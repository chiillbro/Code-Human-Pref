+# ----------------------------------------------------------------------- #
+# 2. `tablesmith inspect` — schema shape: name, inferred type, null count,
+#    sample values.
+# ----------------------------------------------------------------------- #
+class TestInspect(unittest.TestCase):
+    def test_infer_schema_shape(self):
+        rows = [
+            {"id": 1, "name": "Alice", "age": 34},
+            {"id": 2, "name": "Bob", "age": None},
+        ]
+        schema = infer_schema(rows, samples=2)
+        by_col = {d["column"]: d for d in schema}
+
+        # every descriptor carries the required keys
+        for d in schema:
+            for k in ("column", "type", "nulls", "non_null", "total", "samples"):
+                self.assertIn(k, d)
+
+        self.assertEqual(by_col["id"]["type"], "int")
+        self.assertEqual(by_col["name"]["type"], "str")
+        self.assertEqual(by_col["age"]["nulls"], 1)
+        self.assertEqual(by_col["age"]["non_null"], 1)
+        self.assertEqual(by_col["id"]["total"], 2)
+        self.assertIsInstance(by_col["name"]["samples"], list)
+        self.assertIn("Alice", by_col["name"]["samples"])
+
+    def test_cli_inspect_table_output(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            code, out, err = run_cli(["inspect", data])
+        self.assertEqual(code, 0, err)
+        # header line with row / column counts
+        self.assertIn("6 rows", out)
+        self.assertIn("5 columns", out)
+        # table header contains all four concepts the spec asks for
+        for h in ("column", "type", "nulls", "samples"):
+            self.assertIn(h, out)
+        # at least one row of the table is rendered with inferred int type
+        self.assertRegex(out, r"age\s+int\s+1\b")
+
+    def test_cli_inspect_json_output(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            code, out, err = run_cli(["inspect", data, "--json"])
+        self.assertEqual(code, 0, err)
+        doc = json.loads(out)
+        self.assertEqual(doc["rows"], 6)
+        self.assertEqual(len(doc["columns"]), 5)
+        age = next(c for c in doc["columns"] if c["column"] == "age")
+        self.assertEqual(age["type"], "int")
+        self.assertEqual(age["nulls"], 1)
+        self.assertTrue(age["samples"])  # non-empty sample list
+
