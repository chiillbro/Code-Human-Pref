+"""Schema inspection — compute per-column type, null count and samples.
+
+Used by `tablesmith inspect`. Kept separate from typeinfer because this
+reports on *already-coerced* rows (post-inference) rather than deciding how
+to coerce them.
+"""
+from __future__ import annotations
+
+from typing import Any, Dict, List
+
+
+def _type_name(values: List[Any]) -> str:
+    """Single human-readable type label for a column's non-null values."""
+    kinds = set()
+    for v in values:
+        if v is None:
+            continue
+        if isinstance(v, bool):
+            kinds.add("bool")
+        elif isinstance(v, int):
+            kinds.add("int")
+        elif isinstance(v, float):
+            kinds.add("float")
+        elif isinstance(v, str):
+            kinds.add("str")
+        else:
+            kinds.add(type(v).__name__)
+    if not kinds:
+        return "null"
+    if kinds == {"int", "float"}:
+        return "float"
+    if len(kinds) == 1:
+        return next(iter(kinds))
+    return "mixed(" + ",".join(sorted(kinds)) + ")"
+
+
+def infer_schema(rows: List[Dict[str, Any]], samples: int = 3) -> List[Dict[str, Any]]:
+    """Return one descriptor dict per column, in first-seen order.
+
+    Each descriptor has: column, type, nulls, non_null, total, samples.
+    """
+    cols: List[str] = []
+    seen = set()
+    for r in rows:
+        for k in r:
+            if k not in seen:
+                seen.add(k)
+                cols.append(k)
+
+    n = len(rows)
+    out: List[Dict[str, Any]] = []
+    for c in cols:
+        vals = [r.get(c) for r in rows]
+        non_null = [v for v in vals if v is not None]
+        uniq: List[Any] = []
+        s2: set = set()
+        for v in non_null:
+            key = v if isinstance(v, (int, float, str, bool)) else repr(v)
+            if key in s2:
+                continue
+            s2.add(key)
+            uniq.append(v)
+            if len(uniq) >= samples:
+                break
+        out.append(
+            {
+                "column": c,
+                "type": _type_name(vals),
+                "nulls": n - len(non_null),
+                "non_null": len(non_null),
+                "total": n,
+                "samples": uniq,
+            }
+        )
+    return out
+
+
+def render_schema_table(schema: List[Dict[str, Any]]) -> str:
+    """Render the schema as a fixed-width text table."""
+    headers = ["column", "type", "nulls", "non_null", "samples"]
+    rows = []
+    for d in schema:
+        sample_str = ", ".join(repr(v) for v in d["samples"]) or "—"
+        if len(sample_str) > 48:
+            sample_str = sample_str[:45] + "..."
+        rows.append(
+            [d["column"], d["type"], str(d["nulls"]), str(d["non_null"]), sample_str]
+        )
+    widths = [
+        max(len(h), *(len(r[i]) for r in rows)) if rows else len(h)
+        for i, h in enumerate(headers)
+    ]
+    fmt = "  ".join("{:<" + str(w) + "}" for w in widths)
+    lines = [fmt.format(*headers), fmt.format(*("-" * w for w in widths))]
+    for r in rows:
+        lines.append(fmt.format(*r))
+    return "\n".join(lines)
