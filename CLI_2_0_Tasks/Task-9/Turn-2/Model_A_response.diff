+# ----------------------------------------------------------------------- #
+# 1. Unknown column in a filter expression must fail fast with a useful
+#    error — never fall through silently.
+# ----------------------------------------------------------------------- #
+class TestFilterUnknownColumn(unittest.TestCase):
+    def test_library_raises_column_error(self):
+        rows = [{"age": 30, "name": "Alice"}, {"age": 22, "name": "Bob"}]
+        op = Filter("agee > 10")
+        with self.assertRaises(ColumnError) as cm:
+            op.apply(rows)
+        msg = str(cm.exception)
+        # offending name is named explicitly
+        self.assertIn("'agee'", msg)
+        # closest-match suggestion is offered
+        self.assertIn("did you mean 'age'", msg)
+        # AND the available column list is present — both, not either/or
+        self.assertIn("available columns", msg)
+        self.assertIn("name", msg)
+
+    def test_cli_exits_nonzero_with_actionable_message(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            code, out, err = run_cli([data, "--filter", "agee > 10"])
+        self.assertEqual(code, 1, "must exit non-zero on unknown column")
+        self.assertEqual(out, "", "must not emit partial results on failure")
+        self.assertIn("unknown column 'agee'", err)
+        self.assertIn("did you mean 'age'", err)
+        self.assertIn("available columns", err)
+        # error is attributed to the right pipeline step
+        self.assertIn("[filter]", err)
+
+    def test_no_silent_fallback_when_no_close_match(self):
+        """Even with no plausible suggestion, the column list is shown."""
+        rows = [{"age": 1}]
+        with self.assertRaises(ColumnError) as cm:
+            Filter("completely_bogus > 0").apply(rows)
+        msg = str(cm.exception)
+        self.assertIn("'completely_bogus'", msg)
+        self.assertIn("available columns", msg)
+        self.assertIn("age", msg)
+
