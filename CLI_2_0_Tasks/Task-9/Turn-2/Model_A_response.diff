 # ----------------------------------------------------------- build helpers
+def step_column_flow(op: Op, cols: Optional[set]) -> Optional[set]:
+    """Given the column set entering ``op``, return the column set leaving it.
+
+    Raises :class:`~tablesmith.errors.ColumnError` (via ``unknown_column``)
+    if the op references a column that is not in ``cols``. When ``cols`` is
+    ``None`` (unknown input schema) only the *output* shape that the op fully
+    determines on its own is reported; otherwise ``None`` is propagated.
+    """
+    def need(names):
+        if cols is None:
+            return
+        for n in names:
+            if n not in cols:
+                raise unknown_column(n, cols, step=op.name)
+
+    if isinstance(op, Filter):
+        need(op.expr.referenced_columns())
+        return cols
+    if isinstance(op, Select):
+        need([s for s, _ in op.mapping])
+        return {d for _, d in op.mapping}
+    if isinstance(op, Rename):
+        need(list(op.mapping))
+        if cols is None:
+            return None
+        return {op.mapping.get(c, c) for c in cols}
+    if isinstance(op, Drop):
+        if cols is None:
+            return None
+        return cols - set(op.cols)
+    if isinstance(op, Sort):
+        need([c for c, _ in op.keys])
+        return cols
+    if isinstance(op, Group):
+        need(list(op.by) + [c for _, c, _ in op.aggs if c])
+        return set(op.by) | {alias for _, _, alias in op.aggs}
+    if isinstance(op, Join):
+        need([op.left_key])
+        rcols = set()
+        for r in op.right:
+            rcols.update(r.keys())
+        if op.right_key not in rcols and rcols:
+            raise unknown_column(op.right_key, rcols, step=op.name)
+        if cols is None:
+            return None
+        out = set(cols)
+        for c in rcols:
+            if c == op.right_key:
+                continue
+            if op.prefix:
+                out.add(f"{op.prefix}{c}")
+            elif c in out:
+                out.add(f"r_{c}")
+            else:
+                out.add(c)
+        return out
+    if isinstance(op, Compute):
+        need(op.expr.referenced_columns())
+        return (cols | {op.col}) if cols is not None else None
+    if isinstance(op, (Limit, Distinct)):
+        if isinstance(op, Distinct) and op.cols:
+            need(op.cols)
+        return cols
+    # unknown op type — pass through
+    return cols
+
