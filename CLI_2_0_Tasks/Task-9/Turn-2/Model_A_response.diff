+# ----------------------------------------------------------------------- #
+# 4. Pipeline file + inline flags: inline ops are APPENDED after the file's
+#    steps, in command-line order. Mixed usage must not be rejected.
+# ----------------------------------------------------------------------- #
+class TestPipelinePlusInline(unittest.TestCase):
+    def test_inline_appended_after_file_steps(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            pipe = ws.write(
+                "p.json",
+                json.dumps(
+                    {
+                        "input": data,
+                        "steps": [
+                            {"op": "filter", "expr": "age >= 25"},
+                            {"op": "select", "columns": ["name", "age"]},
+                        ],
+                    }
+                ),
+            )
+            # Append two inline ops: sort desc then limit 2.
+            code, out, err = run_cli(
+                [
+                    "-p", pipe,
+                    "--sort", "age:desc",
+                    "--limit", "2",
+                    "-F", "jsonl",
+                ]
+            )
+        self.assertEqual(code, 0, err)
+        rows = [json.loads(l) for l in out.strip().splitlines()]
+        # file filter (age>=25) keeps Alice34 Bob29 Carol41 Eve38;
+        # inline sort desc → Carol41, Eve38, Alice34, Bob29;
+        # inline limit 2 → Carol, Eve. Order proves inline ran AFTER file.
+        self.assertEqual([r["name"] for r in rows], ["Carol", "Eve"])
+        self.assertEqual([r["age"] for r in rows], [41, 38])
+
+    def test_explain_shows_combined_order(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            pipe = ws.write(
+                "p.json",
+                json.dumps({"input": data, "steps": [{"op": "filter", "expr": "age>0"}]}),
+            )
+            code, out, err = run_cli(
+                ["-p", pipe, "--select", "name", "--limit", "1", "--explain"]
+            )
+        self.assertEqual(code, 0, err)
+        parts = [p.strip().split()[0] for p in out.strip().split("|")]
+        self.assertEqual(parts, ["filter", "select", "limit"])
+
+    def test_inline_step_index_accounts_for_file_steps(self):
+        """An error in an inline op is reported with its position in the
+        *combined* pipeline, not its position among inline flags alone."""
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            pipe = ws.write(
+                "p.json",
+                json.dumps({"input": data, "steps": [{"op": "filter", "expr": "age>0"}]}),
+            )
+            code, out, err = run_cli(["-p", pipe, "--select", "nosuch"])
+        self.assertEqual(code, 1)
+        # file has 1 step, inline select is step #2
+        self.assertIn("step #2", err)
+        self.assertIn("unknown column 'nosuch'", err)
+
