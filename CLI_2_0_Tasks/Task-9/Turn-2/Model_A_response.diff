+"""Correctness / hardening tests for tablesmith.
+
+These tests are pure stdlib (``unittest``) so they can run anywhere the
+package runs. They exercise the CLI surface via ``cli.main([...])`` rather
+than spawning subprocesses, which keeps them fast and lets us assert on
+captured stdout/stderr directly.
+"""
+from __future__ import annotations
+
+import contextlib
+import io
+import json
+import os
+import tempfile
+import textwrap
+import unittest
+
+from tablesmith import cli
+from tablesmith.errors import ColumnError
+from tablesmith.ops import Filter
+from tablesmith.pipeline import Pipeline
+from tablesmith.schema import infer_schema
+
+
+PEOPLE_CSV = textwrap.dedent(
+    """\
+    id,name,age,dept,salary
+    1,Alice,34,eng,120000
+    2,Bob,29,eng,95000
+    3,Carol,41,sales,88000
+    4,Dave,23,sales,61000
+    5,Eve,38,eng,142000
+    6,Frank,,ops,70000
+    """
+)
+
+
+class _Workspace:
+    """Temp directory with helper to write fixture files."""
+
+    def __enter__(self):
+        self._td = tempfile.TemporaryDirectory()
+        self.path = self._td.name
+        return self
+
+    def __exit__(self, *exc):
+        self._td.cleanup()
+
+    def write(self, name: str, content: str) -> str:
+        p = os.path.join(self.path, name)
+        with open(p, "w", encoding="utf-8") as fh:
+            fh.write(content)
+        return p
+
+
+def run_cli(argv):
+    """Invoke the CLI and capture (exit_code, stdout, stderr)."""
+    out, err = io.StringIO(), io.StringIO()
+    with contextlib.redirect_stdout(out), contextlib.redirect_stderr(err):
+        code = cli.main(list(argv))
+    return code, out.getvalue(), err.getvalue()
+
