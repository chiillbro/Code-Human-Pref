+# ----------------------------------------------------------------------- #
+# 3. `tablesmith validate` — catches malformed steps & missing fields and
+#    exits non-zero; passes a well-formed pipeline.
+# ----------------------------------------------------------------------- #
+class TestValidate(unittest.TestCase):
+    def test_valid_pipeline_passes(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            pipe = ws.write(
+                "ok.json",
+                json.dumps(
+                    {
+                        "input": data,
+                        "steps": [
+                            {"op": "filter", "expr": "age > 20"},
+                            {"op": "select", "columns": ["name", "age"]},
+                        ],
+                    }
+                ),
+            )
+            code, out, err = run_cli(["validate", pipe])
+        self.assertEqual(code, 0, err)
+        self.assertIn("ok: 2 step(s) valid", out)
+
+    def test_missing_required_field_fails(self):
+        with _Workspace() as ws:
+            pipe = ws.write(
+                "bad.json", json.dumps({"steps": [{"op": "filter"}]})
+            )
+            code, out, err = run_cli(["validate", pipe])
+        self.assertEqual(code, 1)
+        self.assertIn("filter", err)
+        self.assertIn("missing required field", err)
+        self.assertIn("expr", err)
+
+    def test_unknown_op_fails(self):
+        with _Workspace() as ws:
+            pipe = ws.write(
+                "bad.json", json.dumps({"steps": [{"op": "fliter", "expr": "x>1"}]})
+            )
+            code, out, err = run_cli(["validate", pipe])
+        self.assertEqual(code, 1)
+        self.assertIn("unknown operation 'fliter'", err)
+
+    def test_malformed_step_not_an_object(self):
+        with _Workspace() as ws:
+            pipe = ws.write("bad.json", json.dumps({"steps": ["filter age>1"]}))
+            code, out, err = run_cli(["validate", pipe])
+        self.assertEqual(code, 1)
+        self.assertIn("step #1", err)
+        self.assertIn("object", err)
+
+    def test_missing_steps_array(self):
+        with _Workspace() as ws:
+            pipe = ws.write("bad.json", json.dumps({"input": "x.csv"}))
+            code, out, err = run_cli(["validate", pipe])
+        self.assertEqual(code, 1)
+        self.assertIn("missing 'steps'", err)
+
+    def test_column_reference_checked_against_input(self):
+        with _Workspace() as ws:
+            data = ws.write("people.csv", PEOPLE_CSV)
+            pipe = ws.write(
+                "bad.json",
+                json.dumps(
+                    {
+                        "input": data,
+                        "steps": [{"op": "select", "columns": ["name", "agee"]}],
+                    }
+                ),
+            )
+            code, out, err = run_cli(["validate", pipe])
+        self.assertEqual(code, 1)
+        self.assertIn("unknown column 'agee'", err)
+        self.assertIn("available columns", err)
+
