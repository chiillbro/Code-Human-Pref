@@ -0,0 +1,136 @@
+from __future__ import annotations
+
+import argparse
+import sys
+from pathlib import Path
+
+from . import __version__, service, storage
+from .models import WEEKDAYS, ValidationError, parse_availability_spec
+
+
+def _cmd_init(args: argparse.Namespace) -> int:
+    path = storage.init_db(timezone=args.timezone)
+    print(f"initialized schedmax at {path} (timezone={args.timezone})")
+    return 0
+
+
+def _cmd_resource_add(args: argparse.Namespace) -> int:
+    slots = parse_availability_spec(args.availability or "")
+    r = service.add_resource(args.name, args.description or "", slots)
+    print(f"added resource '{r.name}' with {len(r.availability)} availability slot(s)")
+    return 0
+
+
+def _cmd_resource_list(_: argparse.Namespace) -> int:
+    resources = service.list_resources()
+    if not resources:
+        print("(no resources)")
+        return 0
+    for r in resources:
+        desc = f" - {r.description}" if r.description else ""
+        print(f"{r.name}{desc}")
+        if r.availability:
+            for s in r.availability:
+                print(f"    {WEEKDAYS[s.weekday]} {s.start}-{s.end}")
+        else:
+            print("    (no availability defined)")
+    return 0
+
+
+def _cmd_book(args: argparse.Namespace) -> int:
+    b = service.create_booking(
+        resource_name=args.resource,
+        start_s=args.start,
+        end_s=args.end,
+        title=args.title,
+        booked_by=args.by,
+    )
+    print(f"booked {b.id}: {b.resource} {b.start} -> {b.end} '{b.title}' by {b.booked_by}")
+    return 0
+
+
+def _cmd_cancel(args: argparse.Namespace) -> int:
+    b = service.cancel_booking(args.id)
+    print(f"cancelled {b.id} ({b.resource} {b.start} -> {b.end})")
+    return 0
+
+
+def _cmd_list(args: argparse.Namespace) -> int:
+    bookings = service.list_bookings(resource=args.resource, include_past=args.all)
+    if not bookings:
+        print("(no bookings)")
+        return 0
+    for b in bookings:
+        print(
+            f"{b.id}  {b.resource:<16}  {b.start} -> {b.end}  "
+            f"{b.title!r} by {b.booked_by}"
+        )
+    return 0
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="schedctl",
+        description="schedmax: self-contained resource scheduling CLI",
+    )
+    parser.add_argument("--version", action="version", version=f"schedmax {__version__}")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_init = sub.add_parser("init", help="initialize a schedmax database in cwd")
+    p_init.add_argument("--timezone", default="UTC", help="IANA timezone (default UTC)")
+    p_init.set_defaults(func=_cmd_init)
+
+    p_res = sub.add_parser("resource", help="manage resources")
+    res_sub = p_res.add_subparsers(dest="resource_cmd", required=True)
+
+    p_res_add = res_sub.add_parser("add", help="add a resource")
+    p_res_add.add_argument("--name", required=True)
+    p_res_add.add_argument("--description", default="")
+    p_res_add.add_argument(
+        "--availability",
+        default="",
+        help="comma-separated slots like 'MON 09:00-17:00,TUE 09:00-12:00'",
+    )
+    p_res_add.set_defaults(func=_cmd_resource_add)
+
+    p_res_list = res_sub.add_parser("list", help="list resources")
+    p_res_list.set_defaults(func=_cmd_resource_list)
+
+    p_book = sub.add_parser("book", help="create a booking")
+    p_book.add_argument("--resource", required=True)
+    p_book.add_argument("--start", required=True, help="'YYYY-MM-DD HH:MM' or ISO-8601")
+    p_book.add_argument("--end", required=True, help="'YYYY-MM-DD HH:MM' or ISO-8601")
+    p_book.add_argument("--title", required=True)
+    p_book.add_argument("--by", required=True, help="name of the person booking")
+    p_book.set_defaults(func=_cmd_book)
+
+    p_cancel = sub.add_parser("cancel", help="cancel a booking by id")
+    p_cancel.add_argument("--id", required=True)
+    p_cancel.set_defaults(func=_cmd_cancel)
+
+    p_list = sub.add_parser("list", help="list bookings")
+    p_list.add_argument("--resource", default=None)
+    p_list.add_argument("--all", action="store_true", help="include past bookings")
+    p_list.set_defaults(func=_cmd_list)
+
+    return parser
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = build_parser()
+    args = parser.parse_args(argv)
+    try:
+        return args.func(args)
+    except ValidationError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+    except FileNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+    except FileExistsError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
