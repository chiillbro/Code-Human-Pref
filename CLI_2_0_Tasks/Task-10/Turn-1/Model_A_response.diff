@@ -0,0 +1,173 @@
+import uuid
+
+from schedmax import store
+from schedmax.validators import (
+    check_availability_overlaps,
+    parse_availability,
+    parse_datetime,
+    validate_booking,
+    validate_resource_name,
+)
+
+
+def init_cmd(args):
+    if store.is_initialized():
+        print("Already initialized.")
+        return 1
+    store.init()
+    print("Initialized schedmax store in .schedmax/")
+    return 0
+
+
+def resource_add_cmd(args):
+    data = store.load()
+
+    name = args.name
+    err = validate_resource_name(name)
+    if err:
+        print(f"Error: {err}")
+        return 1
+
+    if name in data["resources"]:
+        print(f"Error: resource '{name}' already exists.")
+        return 1
+
+    availability = []
+    for raw in args.availability or []:
+        try:
+            slot = parse_availability(raw)
+        except ValueError as e:
+            print(f"Error: {e}")
+            return 1
+        availability.append(slot)
+
+    if not availability:
+        print("Error: at least one --availability slot is required (e.g. 'mon 09:00-17:00').")
+        return 1
+
+    overlap_err = check_availability_overlaps(availability)
+    if overlap_err:
+        print(f"Error: {overlap_err}")
+        return 1
+
+    resource = {
+        "name": name,
+        "description": args.description or "",
+        "availability": availability,
+    }
+    data["resources"][name] = resource
+    store.save(data)
+    print(f"Resource '{name}' added.")
+    return 0
+
+
+def resource_list_cmd(args):
+    data = store.load()
+    resources = data["resources"]
+
+    if not resources:
+        print("No resources defined.")
+        return 0
+
+    for name, res in sorted(resources.items()):
+        desc = f" — {res['description']}" if res.get("description") else ""
+        print(f"  {name}{desc}")
+        for slot in res.get("availability", []):
+            print(f"    {slot['day'].capitalize():12s} {slot['start']}-{slot['end']}")
+
+    return 0
+
+
+def book_cmd(args):
+    data = store.load()
+
+    resource_name = args.resource
+    if resource_name not in data["resources"]:
+        print(f"Error: resource '{resource_name}' not found.")
+        return 1
+
+    resource = data["resources"][resource_name]
+
+    try:
+        start_dt = parse_datetime(args.start)
+        end_dt = parse_datetime(args.end)
+    except ValueError as e:
+        print(f"Error: {e}")
+        return 1
+
+    resource_bookings = [b for b in data["bookings"] if b["resource"] == resource_name]
+    errors = validate_booking(resource, start_dt, end_dt, resource_bookings)
+    if errors:
+        for err in errors:
+            print(f"Error: {err}")
+        return 1
+
+    booking_id = uuid.uuid4().hex[:8]
+    booking = {
+        "id": booking_id,
+        "resource": resource_name,
+        "title": args.title,
+        "booked_by": args.by,
+        "start": start_dt.strftime("%Y-%m-%dT%H:%M"),
+        "end": end_dt.strftime("%Y-%m-%dT%H:%M"),
+    }
+    data["bookings"].append(booking)
+    store.save(data)
+
+    print(f"Booked '{args.title}' on {resource_name}")
+    print(f"  {start_dt.strftime('%Y-%m-%d %H:%M')} to {end_dt.strftime('%H:%M')}")
+    print(f"  ID: {booking_id}")
+    return 0
+
+
+def cancel_cmd(args):
+    data = store.load()
+
+    booking_id = args.id
+    for i, b in enumerate(data["bookings"]):
+        if b["id"] == booking_id:
+            removed = data["bookings"].pop(i)
+            store.save(data)
+            print(f"Cancelled booking '{removed['title']}' ({removed['id']})")
+            return 0
+
+    print(f"Error: booking '{booking_id}' not found.")
+    return 1
+
+
+def list_cmd(args):
+    data = store.load()
+    bookings = data["bookings"]
+
+    if args.resource:
+        bookings = [b for b in bookings if b["resource"] == args.resource]
+
+    if args.date:
+        try:
+            from datetime import datetime
+
+            filter_date = datetime.strptime(args.date, "%Y-%m-%d").date()
+        except ValueError:
+            print(f"Error: invalid date '{args.date}'. Expected YYYY-MM-DD.")
+            return 1
+        bookings = [b for b in bookings if parse_datetime(b["start"]).date() == filter_date]
+
+    bookings.sort(key=lambda b: b["start"])
+
+    if not args.all and not args.date:
+        from datetime import datetime
+
+        now = datetime.now()
+        bookings = [b for b in bookings if parse_datetime(b["end"]) > now]
+
+    if not bookings:
+        print("No bookings found.")
+        return 0
+
+    for b in bookings:
+        start = parse_datetime(b["start"])
+        end = parse_datetime(b["end"])
+        print(f"  [{b['id']}] {b['resource']} | {b['title']}")
+        print(f"           {start.strftime('%Y-%m-%d %H:%M')} — {end.strftime('%H:%M')} | by {b['booked_by']}")
+
+    return 0
