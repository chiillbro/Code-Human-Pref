@@ -0,0 +1,237 @@
+import json
+import os
+import shutil
+import tempfile
+import unittest
+from unittest.mock import patch
+
+from schedmax import store
+from schedmax.commands import (
+    book_cmd,
+    cancel_cmd,
+    init_cmd,
+    list_cmd,
+    resource_add_cmd,
+    resource_list_cmd,
+)
+
+
+class CommandTestBase(unittest.TestCase):
+    """Run each test inside a fresh temporary directory."""
+
+    def setUp(self):
+        self._orig_dir = os.getcwd()
+        self._tmp_dir = tempfile.mkdtemp()
+        os.chdir(self._tmp_dir)
+
+    def tearDown(self):
+        os.chdir(self._orig_dir)
+        shutil.rmtree(self._tmp_dir)
+
+    @staticmethod
+    def _args(**kwargs):
+        class Args:
+            pass
+        a = Args()
+        for k, v in kwargs.items():
+            setattr(a, k, v)
+        return a
+
+
+class TestInit(CommandTestBase):
+    def test_init_creates_store(self):
+        rc = init_cmd(self._args())
+        self.assertEqual(rc, 0)
+        self.assertTrue(store.is_initialized())
+        data = store.load()
+        self.assertEqual(data, {"resources": {}, "bookings": []})
+
+    def test_double_init(self):
+        init_cmd(self._args())
+        rc = init_cmd(self._args())
+        self.assertEqual(rc, 1)
+
+
+class TestResourceAdd(CommandTestBase):
+    def setUp(self):
+        super().setUp()
+        init_cmd(self._args())
+
+    def test_add_resource(self):
+        args = self._args(
+            name="room-101",
+            description="First floor",
+            availability=["mon 09:00-17:00", "tue 09:00-17:00"],
+        )
+        rc = resource_add_cmd(args)
+        self.assertEqual(rc, 0)
+        data = store.load()
+        self.assertIn("room-101", data["resources"])
+        self.assertEqual(len(data["resources"]["room-101"]["availability"]), 2)
+
+    def test_duplicate_resource(self):
+        args = self._args(name="room-101", description="", availability=["mon 09:00-17:00"])
+        resource_add_cmd(args)
+        rc = resource_add_cmd(args)
+        self.assertEqual(rc, 1)
+
+    def test_no_availability(self):
+        args = self._args(name="room-101", description="", availability=None)
+        rc = resource_add_cmd(args)
+        self.assertEqual(rc, 1)
+
+    def test_invalid_availability(self):
+        args = self._args(name="room-101", description="", availability=["bad"])
+        rc = resource_add_cmd(args)
+        self.assertEqual(rc, 1)
+
+    def test_overlapping_availability(self):
+        args = self._args(
+            name="room-101", description="",
+            availability=["mon 09:00-14:00", "mon 13:00-17:00"],
+        )
+        rc = resource_add_cmd(args)
+        self.assertEqual(rc, 1)
+
+    def test_invalid_name(self):
+        args = self._args(name="room 101", description="", availability=["mon 09:00-17:00"])
+        rc = resource_add_cmd(args)
+        self.assertEqual(rc, 1)
+
+
+class TestResourceList(CommandTestBase):
+    def setUp(self):
+        super().setUp()
+        init_cmd(self._args())
+
+    def test_empty_list(self):
+        rc = resource_list_cmd(self._args())
+        self.assertEqual(rc, 0)
+
+    def test_list_resources(self):
+        resource_add_cmd(self._args(
+            name="room-101", description="Big room",
+            availability=["mon 09:00-17:00"],
+        ))
+        rc = resource_list_cmd(self._args())
+        self.assertEqual(rc, 0)
+
+
+class TestBookAndCancel(CommandTestBase):
+    def setUp(self):
+        super().setUp()
+        init_cmd(self._args())
+        resource_add_cmd(self._args(
+            name="room-101", description="",
+            availability=[f"{d} 09:00-17:00" for d in ("mon", "tue", "wed", "thu", "fri")],
+        ))
+
+    def _next_weekday_at(self, hour):
+        from datetime import datetime, timedelta
+        now = datetime.now()
+        # Find next weekday (mon-fri)
+        days = 1
+        while True:
+            candidate = now + timedelta(days=days)
+            if candidate.weekday() < 5:
+                return candidate.replace(hour=hour, minute=0, second=0, microsecond=0)
+            days += 1
+
+    def test_book_and_list(self):
+        dt = self._next_weekday_at(10)
+        end = self._next_weekday_at(11)
+        args = self._args(
+            resource="room-101",
+            title="Standup",
+            by="alice",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        )
+        rc = book_cmd(args)
+        self.assertEqual(rc, 0)
+
+        data = store.load()
+        self.assertEqual(len(data["bookings"]), 1)
+        self.assertEqual(data["bookings"][0]["title"], "Standup")
+
+        # List
+        rc = list_cmd(self._args(resource=None, date=None, all=False))
+        self.assertEqual(rc, 0)
+
+    def test_book_nonexistent_resource(self):
+        dt = self._next_weekday_at(10)
+        end = self._next_weekday_at(11)
+        args = self._args(
+            resource="nope",
+            title="X",
+            by="bob",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        )
+        rc = book_cmd(args)
+        self.assertEqual(rc, 1)
+
+    def test_overlapping_booking(self):
+        dt = self._next_weekday_at(10)
+        end = self._next_weekday_at(11)
+        book_cmd(self._args(
+            resource="room-101", title="A", by="alice",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        ))
+        rc = book_cmd(self._args(
+            resource="room-101", title="B", by="bob",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        ))
+        self.assertEqual(rc, 1)
+
+    def test_cancel(self):
+        dt = self._next_weekday_at(10)
+        end = self._next_weekday_at(11)
+        book_cmd(self._args(
+            resource="room-101", title="Meeting", by="alice",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        ))
+        data = store.load()
+        bid = data["bookings"][0]["id"]
+
+        rc = cancel_cmd(self._args(id=bid))
+        self.assertEqual(rc, 0)
+        data = store.load()
+        self.assertEqual(len(data["bookings"]), 0)
+
+    def test_cancel_nonexistent(self):
+        rc = cancel_cmd(self._args(id="nonexist"))
+        self.assertEqual(rc, 1)
+
+    def test_list_filter_by_resource(self):
+        dt = self._next_weekday_at(14)
+        end = self._next_weekday_at(15)
+        book_cmd(self._args(
+            resource="room-101", title="X", by="a",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        ))
+        rc = list_cmd(self._args(resource="room-101", date=None, all=False))
+        self.assertEqual(rc, 0)
+        rc = list_cmd(self._args(resource="nope", date=None, all=False))
+        self.assertEqual(rc, 0)  # no error, just empty
+
+    def test_list_filter_by_date(self):
+        dt = self._next_weekday_at(14)
+        end = self._next_weekday_at(15)
+        book_cmd(self._args(
+            resource="room-101", title="X", by="a",
+            start=dt.strftime("%Y-%m-%d %H:%M"),
+            end=end.strftime("%Y-%m-%d %H:%M"),
+        ))
+        rc = list_cmd(self._args(
+            resource=None, date=dt.strftime("%Y-%m-%d"), all=False,
+        ))
+        self.assertEqual(rc, 0)
+
+
+if __name__ == "__main__":
+    unittest.main()
