+import re
+from datetime import datetime
+
+DAY_NAMES = [
+    "monday", "tuesday", "wednesday", "thursday",
+    "friday", "saturday", "sunday",
+]
+DAY_ABBREVS = {
+    "mon": "monday", "tue": "tuesday", "wed": "wednesday",
+    "thu": "thursday", "fri": "friday", "sat": "saturday", "sun": "sunday",
+}
+
+
+def validate_resource_name(name):
+    if not name:
+        return "Resource name cannot be empty."
+    if len(name) > 64:
+        return "Resource name must be 64 characters or fewer."
+    if not re.match(r"^[a-zA-Z0-9_-]+$", name):
+        return "Resource name can only contain letters, numbers, hyphens, and underscores."
+    return None
+
+
+def parse_availability(raw):
+    """Parse 'mon 09:00-17:00' into {'day': 'monday', 'start': '09:00', 'end': '17:00'}."""
+    parts = raw.strip().split()
+    if len(parts) != 2:
+        raise ValueError(f"Invalid availability format: '{raw}'. Expected: 'mon 09:00-17:00'")
+
+    day_str, time_range = parts
+    day_str = day_str.lower()
+
+    if day_str in DAY_ABBREVS:
+        day = DAY_ABBREVS[day_str]
+    elif day_str in DAY_NAMES:
+        day = day_str
+    else:
+        raise ValueError(f"Invalid day: '{day_str}'. Use: mon, tue, wed, thu, fri, sat, sun")
+
+    time_parts = time_range.split("-")
+    if len(time_parts) != 2:
+        raise ValueError(f"Invalid time range: '{time_range}'. Expected: 'HH:MM-HH:MM'")
+
+    start_str, end_str = time_parts
+    for t in (start_str, end_str):
+        try:
+            datetime.strptime(t, "%H:%M")
+        except ValueError:
+            raise ValueError(f"Invalid time: '{t}'. Expected HH:MM format.")
+
+    if start_str >= end_str:
+        raise ValueError(f"Start time must be before end time: {start_str}-{end_str}")
+
+    return {"day": day, "start": start_str, "end": end_str}
+
+
+def parse_datetime(raw):
+    """Parse 'YYYY-MM-DD HH:MM' or 'YYYY-MM-DDTHH:MM'."""
+    for fmt in ("%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M", "%Y-%m-%d %H:%M:%S", "%Y-%m-%dT%H:%M:%S"):
+        try:
+            return datetime.strptime(raw, fmt)
+        except ValueError:
+            continue
+    raise ValueError(f"Invalid datetime: '{raw}'. Expected: 'YYYY-MM-DD HH:MM'")
+
+
+def check_availability_overlaps(slots):
+    """Check for overlapping availability slots on the same day. Returns error string or None."""
+    by_day = {}
+    for slot in slots:
+        day = slot["day"]
+        if day not in by_day:
+            by_day[day] = []
+        for existing in by_day[day]:
+            if slot["start"] < existing["end"] and slot["end"] > existing["start"]:
+                return (
+                    f"Overlapping availability on {day}: "
+                    f"{existing['start']}-{existing['end']} and {slot['start']}-{slot['end']}"
+                )
+        by_day[day].append(slot)
+    return None
+
+
+def validate_booking(resource, start_dt, end_dt, existing_bookings):
+    """Validate a booking. Returns list of error strings (empty if valid)."""
+    errors = []
+
+    now = datetime.now()
+    if start_dt <= now:
+        errors.append("Booking start time is in the past.")
+
+    if end_dt <= start_dt:
+        errors.append("End time must be after start time.")
+
+    if start_dt.date() != end_dt.date():
+        errors.append("Booking must start and end on the same day.")
+
+    if errors:
+        return errors
+
+    booking_day = DAY_NAMES[start_dt.weekday()]
+    booking_start = start_dt.strftime("%H:%M")
+    booking_end = end_dt.strftime("%H:%M")
+
+    available = any(
+        slot["day"] == booking_day
+        and slot["start"] <= booking_start
+        and slot["end"] >= booking_end
+        for slot in resource.get("availability", [])
+    )
+
+    if not available:
+        errors.append(
+            f"Booking time ({booking_day} {booking_start}-{booking_end}) "
+            f"is outside the resource's availability."
+        )
+
+    for existing in existing_bookings:
+        ex_start = parse_datetime(existing["start"])
+        ex_end = parse_datetime(existing["end"])
+        if start_dt < ex_end and end_dt > ex_start:
+            errors.append(
+                f"Overlaps with existing booking '{existing['title']}' "
+                f"({existing['start']} to {existing['end']})."
+            )
+
+    return errors
