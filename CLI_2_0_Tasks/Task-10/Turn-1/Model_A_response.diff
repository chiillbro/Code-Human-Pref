+import unittest
+from datetime import datetime, timedelta
+
+from schedmax.validators import (
+    check_availability_overlaps,
+    parse_availability,
+    parse_datetime,
+    validate_booking,
+    validate_resource_name,
+)
+
+
+class TestResourceNameValidation(unittest.TestCase):
+    def test_valid_names(self):
+        for name in ("room-101", "projector_2", "A", "desk-3B"):
+            self.assertIsNone(validate_resource_name(name))
+
+    def test_empty_name(self):
+        self.assertIsNotNone(validate_resource_name(""))
+
+    def test_special_characters(self):
+        self.assertIsNotNone(validate_resource_name("room 101"))
+        self.assertIsNotNone(validate_resource_name("room@101"))
+
+    def test_too_long(self):
+        self.assertIsNotNone(validate_resource_name("x" * 65))
+        self.assertIsNone(validate_resource_name("x" * 64))
+
+
+class TestParseAvailability(unittest.TestCase):
+    def test_abbreviation(self):
+        slot = parse_availability("mon 09:00-17:00")
+        self.assertEqual(slot, {"day": "monday", "start": "09:00", "end": "17:00"})
+
+    def test_full_day_name(self):
+        slot = parse_availability("friday 08:00-12:00")
+        self.assertEqual(slot, {"day": "friday", "start": "08:00", "end": "12:00"})
+
+    def test_case_insensitive(self):
+        slot = parse_availability("MON 09:00-17:00")
+        self.assertEqual(slot["day"], "monday")
+
+    def test_invalid_day(self):
+        with self.assertRaises(ValueError):
+            parse_availability("xyz 09:00-17:00")
+
+    def test_invalid_format(self):
+        with self.assertRaises(ValueError):
+            parse_availability("mon")
+
+    def test_start_after_end(self):
+        with self.assertRaises(ValueError):
+            parse_availability("mon 17:00-09:00")
+
+    def test_equal_start_end(self):
+        with self.assertRaises(ValueError):
+            parse_availability("mon 09:00-09:00")
+
+    def test_invalid_time(self):
+        with self.assertRaises(ValueError):
+            parse_availability("mon 25:00-17:00")
+
+
+class TestAvailabilityOverlaps(unittest.TestCase):
+    def test_no_overlap(self):
+        slots = [
+            {"day": "monday", "start": "09:00", "end": "12:00"},
+            {"day": "monday", "start": "13:00", "end": "17:00"},
+        ]
+        self.assertIsNone(check_availability_overlaps(slots))
+
+    def test_overlap(self):
+        slots = [
+            {"day": "monday", "start": "09:00", "end": "14:00"},
+            {"day": "monday", "start": "13:00", "end": "17:00"},
+        ]
+        self.assertIsNotNone(check_availability_overlaps(slots))
+
+    def test_different_days_no_overlap(self):
+        slots = [
+            {"day": "monday", "start": "09:00", "end": "17:00"},
+            {"day": "tuesday", "start": "09:00", "end": "17:00"},
+        ]
+        self.assertIsNone(check_availability_overlaps(slots))
+
