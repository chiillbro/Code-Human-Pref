+class TestValidateBooking(unittest.TestCase):
+    def _resource(self, availability=None):
+        if availability is None:
+            availability = [{"day": "wednesday", "start": "09:00", "end": "17:00"}]
+        return {"name": "room-101", "availability": availability}
+
+    def _future_wed(self):
+        """Return next Wednesday at 10:00."""
+        now = datetime.now()
+        days_ahead = 2 - now.weekday()  # wednesday = 2
+        if days_ahead <= 0:
+            days_ahead += 7
+        return now.replace(hour=10, minute=0, second=0, microsecond=0) + timedelta(days=days_ahead)
+
+    def test_valid_booking(self):
+        start = self._future_wed()
+        end = start.replace(hour=11)
+        errors = validate_booking(self._resource(), start, end, [])
+        self.assertEqual(errors, [])
+
+    def test_past_booking(self):
+        start = datetime(2020, 1, 1, 10, 0)
+        end = datetime(2020, 1, 1, 11, 0)
+        errors = validate_booking(self._resource(), start, end, [])
+        self.assertTrue(any("past" in e.lower() for e in errors))
+
+    def test_end_before_start(self):
+        start = self._future_wed()
+        end = start.replace(hour=9)
+        errors = validate_booking(self._resource(), start, end, [])
+        self.assertTrue(any("after" in e.lower() for e in errors))
+
+    def test_multi_day_booking(self):
+        start = self._future_wed()
+        end = start + timedelta(days=1)
+        errors = validate_booking(self._resource(), start, end, [])
+        self.assertTrue(any("same day" in e.lower() for e in errors))
+
+    def test_outside_availability(self):
+        start = self._future_wed().replace(hour=7)
+        end = start.replace(hour=8)
+        errors = validate_booking(self._resource(), start, end, [])
+        self.assertTrue(any("availability" in e.lower() for e in errors))
+
+    def test_wrong_day(self):
+        # Book on Thursday when only Wednesday is available
+        start = self._future_wed() + timedelta(days=1)
+        end = start.replace(hour=11)
+        errors = validate_booking(self._resource(), start, end, [])
+        self.assertTrue(any("availability" in e.lower() for e in errors))
+
+    def test_overlap_detection(self):
+        start = self._future_wed()
+        end = start.replace(hour=11)
+        existing = [{
+            "title": "Existing",
+            "start": start.strftime("%Y-%m-%dT%H:%M"),
+            "end": end.strftime("%Y-%m-%dT%H:%M"),
+        }]
+        new_start = start.replace(hour=10, minute=30)
+        new_end = start.replace(hour=11, minute=30)
+        errors = validate_booking(self._resource(), new_start, new_end, existing)
+        self.assertTrue(any("overlap" in e.lower() for e in errors))
+
+    def test_adjacent_no_overlap(self):
+        start = self._future_wed()
+        end = start.replace(hour=11)
+        existing = [{
+            "title": "Existing",
+            "start": start.strftime("%Y-%m-%dT%H:%M"),
+            "end": end.strftime("%Y-%m-%dT%H:%M"),
+        }]
+        new_start = start.replace(hour=11)
+        new_end = start.replace(hour=12)
+        errors = validate_booking(self._resource(), new_start, new_end, existing)
+        self.assertEqual(errors, [])
+
+
+if __name__ == "__main__":
+    unittest.main()
