+import argparse
+import sys
+
+from schedmax.commands import (
+    book_cmd,
+    cancel_cmd,
+    init_cmd,
+    list_cmd,
+    resource_add_cmd,
+    resource_list_cmd,
+)
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(
+        prog="schedctl",
+        description="SchedMax — resource scheduling CLI",
+    )
+    sub = parser.add_subparsers(dest="command")
+
+    sub.add_parser("init", help="Initialize the schedmax store")
+
+    res_parser = sub.add_parser("resource", help="Manage resources")
+    res_sub = res_parser.add_subparsers(dest="resource_command")
+
+    add_p = res_sub.add_parser("add", help="Add a new resource")
+    add_p.add_argument("name", help="Unique resource name (e.g. room-101)")
+    add_p.add_argument("--description", "-d", default="", help="Resource description")
+    add_p.add_argument(
+        "--availability", "-a", action="append",
+        help="Availability slot, e.g. 'mon 09:00-17:00' (repeatable)",
+    )
+
+    res_sub.add_parser("list", help="List all resources")
+
+    book_p = sub.add_parser("book", help="Create a booking")
+    book_p.add_argument("resource", help="Resource name to book")
+    book_p.add_argument("--title", "-t", required=True, help="Booking title")
+    book_p.add_argument("--by", "-b", required=True, help="Person making the booking")
+    book_p.add_argument("--start", "-s", required=True, help="Start time (YYYY-MM-DD HH:MM)")
+    book_p.add_argument("--end", "-e", required=True, help="End time (YYYY-MM-DD HH:MM)")
+
+    cancel_p = sub.add_parser("cancel", help="Cancel a booking")
+    cancel_p.add_argument("id", help="Booking ID to cancel")
+
+    list_p = sub.add_parser("list", help="List bookings")
+    list_p.add_argument("--resource", "-r", help="Filter by resource name")
+    list_p.add_argument("--date", "-d", help="Filter by date (YYYY-MM-DD)")
+    list_p.add_argument("--all", action="store_true", help="Include past bookings")
+
+    return parser
+
+
+def main():
+    parser = build_parser()
+    args = parser.parse_args()
+
+    if args.command is None:
+        parser.print_help()
+        return 1
+
+    dispatch = {
+        "init": init_cmd,
+        "book": book_cmd,
+        "cancel": cancel_cmd,
+        "list": list_cmd,
+    }
+
+    if args.command in dispatch:
+        return dispatch[args.command](args)
+
+    if args.command == "resource":
+        if getattr(args, "resource_command", None) is None:
+            parser.parse_args(["resource", "--help"])
+            return 1
+        resource_dispatch = {"add": resource_add_cmd, "list": resource_list_cmd}
+        return resource_dispatch[args.resource_command](args)
+
+    parser.print_help()
+    return 1
