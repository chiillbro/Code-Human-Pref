@@ -0,0 +1,34 @@
+import json
+from pathlib import Path
+
+STORE_DIR = ".schedmax"
+STORE_FILE = "data.json"
+
+
+def _store_path():
+    return Path(STORE_DIR) / STORE_FILE
+
+
+def is_initialized():
+    return _store_path().exists()
+
+
+def init():
+    path = _store_path()
+    if path.exists():
+        return False
+    Path(STORE_DIR).mkdir(parents=True, exist_ok=True)
+    data = {"resources": {}, "bookings": []}
+    path.write_text(json.dumps(data, indent=2))
+    return True
+
+
+def load():
+    path = _store_path()
+    if not path.exists():
+        raise SystemExit("Error: not initialized. Run 'schedctl init' first.")
+    return json.loads(path.read_text())
+
+
+def save(data):
+    _store_path().write_text(json.dumps(data, indent=2))
