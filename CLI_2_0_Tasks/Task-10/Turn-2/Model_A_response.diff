+"""Unit tests for schedmax.
+
+Run: `python -m unittest discover -s tests -v` from the repo root.
+"""
+from __future__ import annotations
+
+import io
+import json
+import tempfile
+import unittest
+from contextlib import redirect_stderr, redirect_stdout
+from datetime import datetime, timedelta, timezone
+from pathlib import Path
+from unittest import mock
+
+from schedmax import cli, service, storage
+from schedmax.models import (
+    AvailabilitySlot,
+    ValidationError,
+    containing_window,
+    parse_availability_spec,
+)
+
+
+def _fake_now(utc_iso: str):
+    """Return a mock datetime.now-like replacement for service._validate_booking_inputs."""
+    fixed = datetime.fromisoformat(utc_iso)
+    return fixed
+
