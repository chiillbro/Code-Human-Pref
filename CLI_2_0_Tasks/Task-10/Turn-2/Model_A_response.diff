+class TestCrossMidnight(unittest.TestCase):
+    def test_wraps_midnight_detection(self):
+        self.assertTrue(AvailabilitySlot(4, "22:00", "02:00").wraps_midnight())
+        self.assertFalse(AvailabilitySlot(4, "09:00", "17:00").wraps_midnight())
+
+    def test_containing_window_non_wrapping(self):
+        slots = parse_availability_spec("MON 09:00-17:00")
+        # Monday 2026-04-20 10:00 -> 11:00
+        w = containing_window(
+            datetime(2026, 4, 20, 10, 0), datetime(2026, 4, 20, 11, 0), slots
+        )
+        self.assertIsNotNone(w)
+
+    def test_containing_window_wrapping_covers_both_sides(self):
+        slots = parse_availability_spec("FRI 22:00-02:00")
+        # Booking entirely before midnight on Friday.
+        self.assertIsNotNone(containing_window(
+            datetime(2026, 4, 24, 22, 30), datetime(2026, 4, 24, 23, 30), slots
+        ))
+        # Booking crossing midnight.
+        self.assertIsNotNone(containing_window(
+            datetime(2026, 4, 24, 23, 30), datetime(2026, 4, 25, 1, 30), slots
+        ))
+        # Booking entirely in the Saturday AM tail.
+        self.assertIsNotNone(containing_window(
+            datetime(2026, 4, 25, 0, 30), datetime(2026, 4, 25, 1, 30), slots
+        ))
+        # Booking starting inside the Saturday tail but ending past slot end.
+        self.assertIsNone(containing_window(
+            datetime(2026, 4, 25, 1, 30), datetime(2026, 4, 25, 3, 0), slots
+        ))
+        # Booking on Saturday daytime — not covered (slot's weekday anchor is FRI).
+        self.assertIsNone(containing_window(
+            datetime(2026, 4, 25, 10, 0), datetime(2026, 4, 25, 11, 0), slots
+        ))
+
