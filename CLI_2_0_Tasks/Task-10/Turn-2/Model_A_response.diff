+    def test_add_resource_with_valid_iana_tz(self):
+        r = service.add_resource("conf-tokyo", "", [], tz_name="Asia/Tokyo")
+        self.assertEqual(r.timezone, "Asia/Tokyo")
+
+    def test_add_resource_rejects_unknown_tz(self):
+        with self.assertRaises(ValidationError):
+            service.add_resource("bad", "", [], tz_name="Mars/Olympus_Mons")
+
+    def test_add_resource_defaults_to_db_default_tz(self):
+        r = service.add_resource("conf-utc", "", [])
+        self.assertEqual(r.timezone, "UTC")
+
+    def test_init_cli_rejects_unknown_tz(self):
+        # Wipe the already-initialized DB, then try init via CLI with bad tz.
+        import shutil
+
+        shutil.rmtree(self.tmp_path / storage.DB_DIRNAME)
+        buf = io.StringIO()
+        with redirect_stderr(buf):
+            rc = cli.main(["init", "--timezone", "Not/A_Zone"])
+        self.assertEqual(rc, 2)
+        self.assertIn("unknown IANA timezone", buf.getvalue())
+        # Crucially, no .schedmax dir was left behind.
