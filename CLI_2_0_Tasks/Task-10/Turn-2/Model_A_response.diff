+class _DBTestCase(unittest.TestCase):
+    """Gives each test its own .schedmax DB by chdir'ing into a temp dir."""
+
+    def setUp(self) -> None:
+        self._tmp = tempfile.TemporaryDirectory()
+        self.tmp_path = Path(self._tmp.name)
+        self._cwd_patch = mock.patch("pathlib.Path.cwd", return_value=self.tmp_path)
+        self._cwd_patch.start()
+
+    def tearDown(self) -> None:
+        self._cwd_patch.stop()
+        self._tmp.cleanup()
+
+
+class TestInitRobustness(_DBTestCase):
+    def test_init_creates_db(self):
+        path = storage.init_db(default_timezone="UTC")
+        self.assertTrue(path.exists())
+        data = json.loads(path.read_text())
+        self.assertEqual(data["version"], storage.DB_VERSION)
+        self.assertEqual(data["default_timezone"], "UTC")
+
+    def test_init_refuses_to_overwrite_existing_db(self):
+        storage.init_db()
+        with self.assertRaises(FileExistsError):
+            storage.init_db()
+
+    def test_init_refuses_partial_directory(self):
+        # Simulate a partially-initialized state: the dir exists but no db.json.
+        (self.tmp_path / storage.DB_DIRNAME).mkdir()
+        (self.tmp_path / storage.DB_DIRNAME / "stray.txt").write_text("hi")
+        with self.assertRaises(FileExistsError) as ctx:
+            storage.init_db()
+        self.assertIn("contains no", str(ctx.exception))
+        # Original dir and contents untouched.
+        self.assertTrue((self.tmp_path / storage.DB_DIRNAME / "stray.txt").exists())
+
+    def test_load_rejects_corrupt_db(self):
+        storage.init_db()
+        storage.db_path().write_text("{ not json")
+        with self.assertRaises(RuntimeError):
+            storage.load()
+
+    def test_load_rejects_wrong_version(self):
+        storage.init_db()
+        p = storage.db_path()
+        data = json.loads(p.read_text())
+        data["version"] = 99
+        p.write_text(json.dumps(data))
+        with self.assertRaises(RuntimeError):
+            storage.load()
