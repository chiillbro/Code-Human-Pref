+class TestResourceLocalBookingSemantics(_DBTestCase):
+    """9am in Tokyo == 9am local for conf-tokyo, regardless of caller's clock."""
+
+    def setUp(self):
+        super().setUp()
+        storage.init_db()
+        service.add_resource(
+            "conf-tokyo",
+            "",
+            parse_availability_spec("MON 09:00-17:00,TUE 09:00-17:00"),
+            tz_name="Asia/Tokyo",
+        )
+        service.add_resource(
+            "conf-nyc",
+            "",
+            parse_availability_spec("MON 09:00-17:00,TUE 09:00-17:00"),
+            tz_name="America/New_York",
+        )
+
+    def test_local_time_stored_as_utc(self):
+        # 2026-04-21 is a Tuesday.
+        now = datetime(2026, 4, 20, 0, 0, tzinfo=timezone.utc)
+        b = service.create_booking(
+            "conf-tokyo",
+            "2026-04-21 09:00",
+            "2026-04-21 10:00",
+            "standup",
+            "alice",
+            now_utc=now,
+        )
+        # Tokyo is UTC+9, so 09:00 JST == 00:00 UTC.
+        self.assertEqual(b.start, "2026-04-21T00:00:00+00:00")
+        self.assertEqual(b.end, "2026-04-21T01:00:00+00:00")
+
+    def test_same_wallclock_in_different_tz_does_not_conflict(self):
+        now = datetime(2026, 4, 20, 0, 0, tzinfo=timezone.utc)
+        service.create_booking(
+            "conf-tokyo", "2026-04-21 09:00", "2026-04-21 10:00",
+            "t", "a", now_utc=now,
+        )
+        # Same wallclock (09:00) on NYC resource should succeed; different UTC.
+        b = service.create_booking(
+            "conf-nyc", "2026-04-21 09:00", "2026-04-21 10:00",
+            "t", "a", now_utc=now,
+        )
+        self.assertEqual(b.start, "2026-04-21T13:00:00+00:00")  # EDT = UTC-4
+
+    def test_overlap_detected_when_utc_intervals_collide(self):
+        """A Tokyo booking and an NYC booking pointed at the same UTC moment
+        on the same resource must conflict; on different resources they don't."""
+        now = datetime(2026, 4, 20, 0, 0, tzinfo=timezone.utc)
+        service.create_booking(
+            "conf-tokyo", "2026-04-21 09:00", "2026-04-21 10:00",
+            "t1", "a", now_utc=now,
+        )
+        # Same resource, ISO input expressing the exact same UTC instant.
+        with self.assertRaises(ValidationError) as ctx:
+            service.create_booking(
+                "conf-tokyo",
+                "2026-04-21T00:30:00+00:00",
+                "2026-04-21T01:30:00+00:00",
+                "t2", "b", now_utc=now,
+            )
+        self.assertIn("overlaps", str(ctx.exception))
+
