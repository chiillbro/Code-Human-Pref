+class TestSlotWindow(unittest.TestCase):
+    """Test _slot_window (concrete time-range generation)."""
+
+    def test_normal_matching_day(self):
+        slot = AvailabilitySlot(weekday=2, start="09:00", end="17:00")
+        # 2026-04-22 = Wednesday (weekday 2)
+        from datetime import date
+        window = _slot_window(slot, date(2026, 4, 22))
+        self.assertIsNotNone(window)
+        self.assertEqual(window[0], datetime(2026, 4, 22, 9, 0))
+        self.assertEqual(window[1], datetime(2026, 4, 22, 17, 0))
+
+    def test_normal_wrong_day(self):
+        slot = AvailabilitySlot(weekday=0, start="09:00", end="17:00")
+        from datetime import date
+        self.assertIsNone(_slot_window(slot, date(2026, 4, 22)))
+
+    def test_cross_midnight_evening(self):
+        slot = AvailabilitySlot(weekday=4, start="22:00", end="02:00")
+        from datetime import date
+        # 2026-04-24 = Friday (weekday 4)
+        window = _slot_window(slot, date(2026, 4, 24))
+        self.assertIsNotNone(window)
+        self.assertEqual(window[0], datetime(2026, 4, 24, 22, 0))
+        self.assertEqual(window[1], datetime(2026, 4, 25, 2, 0))
+
+    def test_cross_midnight_morning_after(self):
+        slot = AvailabilitySlot(weekday=4, start="22:00", end="02:00")
+        from datetime import date
+        # 2026-04-25 = Saturday (weekday 5), day after Friday
+        window = _slot_window(slot, date(2026, 4, 25))
+        self.assertIsNotNone(window)
+        self.assertEqual(window[0], datetime(2026, 4, 24, 22, 0))
+        self.assertEqual(window[1], datetime(2026, 4, 25, 2, 0))
+
+    def test_cross_midnight_unrelated_day(self):
+        slot = AvailabilitySlot(weekday=4, start="22:00", end="02:00")
+        from datetime import date
+        # 2026-04-22 = Wednesday — not Friday or Saturday
+        self.assertIsNone(_slot_window(slot, date(2026, 4, 22)))
+
+    def test_sunday_cross_midnight_into_monday(self):
+        slot = AvailabilitySlot(weekday=6, start="23:00", end="01:00")
+        from datetime import date
+        # 2026-04-26 = Sunday
+        window = _slot_window(slot, date(2026, 4, 26))
+        self.assertEqual(window[0], datetime(2026, 4, 26, 23, 0))
+        self.assertEqual(window[1], datetime(2026, 4, 27, 1, 0))
+        # Monday morning-after check
+        window2 = _slot_window(slot, date(2026, 4, 27))
+        self.assertEqual(window2[0], datetime(2026, 4, 26, 23, 0))
+        self.assertEqual(window2[1], datetime(2026, 4, 27, 1, 0))
+
