+import json
+import os
+import shutil
+import tempfile
+import unittest
+from pathlib import Path
+
+from schedmax import storage
+
+
+class TestInitDb(unittest.TestCase):
+    def setUp(self):
+        self.tmpdir = tempfile.mkdtemp()
+        self.orig_cwd = os.getcwd()
+        os.chdir(self.tmpdir)
+
+    def tearDown(self):
+        os.chdir(self.orig_cwd)
+        shutil.rmtree(self.tmpdir)
+
+    def test_fresh_init(self):
+        path = storage.init_db()
+        self.assertTrue(path.exists())
+        data = storage.load()
+        self.assertEqual(data["version"], 1)
+        self.assertEqual(data["resources"], [])
+        self.assertEqual(data["bookings"], [])
+
+    def test_double_init_rejected(self):
+        storage.init_db()
+        with self.assertRaises(FileExistsError) as ctx:
+            storage.init_db()
+        self.assertIn("already initialized", str(ctx.exception))
+
+    def test_partial_init_dir_only(self):
+        (Path(self.tmpdir) / ".schedmax").mkdir()
+        path = storage.init_db()
+        self.assertTrue(path.exists())
+        data = storage.load()
+        self.assertEqual(data["version"], 1)
+
+    def test_corrupt_db_without_force(self):
+        path = storage.db_path()
+        path.parent.mkdir(parents=True)
+        path.write_text("{bad json", encoding="utf-8")
+        with self.assertRaises(FileExistsError) as ctx:
+            storage.init_db()
+        self.assertIn("corrupt", str(ctx.exception))
+        self.assertIn("--force", str(ctx.exception))
+
+    def test_corrupt_db_with_force(self):
+        path = storage.db_path()
+        path.parent.mkdir(parents=True)
+        path.write_text("{bad json", encoding="utf-8")
+        storage.init_db(force=True)
+        data = storage.load()
+        self.assertEqual(data["version"], 1)
+
+    def test_force_overwrites_valid_db(self):
+        storage.init_db()
+        data = storage.load()
+        data["resources"].append({"name": "old"})
+        storage.save(data)
+        storage.init_db(force=True)
+        data = storage.load()
+        self.assertEqual(data["resources"], [])
+
+    def test_explicit_root(self):
+        subdir = Path(self.tmpdir) / "sub"
+        subdir.mkdir()
+        path = storage.init_db(root=subdir)
+        self.assertTrue((subdir / ".schedmax" / "db.json").exists())
+
+
