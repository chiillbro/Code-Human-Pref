+from __future__ import annotations
+
+import argparse
+import sys
+
+from . import __version__, service, storage
+from .models import WEEKDAYS, ValidationError, parse_availability_spec
+
+
+def _cmd_init(args: argparse.Namespace) -> int:
+    path = storage.init_db(force=args.force)
+    action = "reinitialized" if args.force else "initialized"
+    print(f"{action} schedmax at {path}")
+    return 0
+
+
+def _cmd_resource_add(args: argparse.Namespace) -> int:
+    slots = parse_availability_spec(args.availability or "")
+    r = service.add_resource(
+        args.name, args.description or "", slots, timezone=args.timezone
+    )
+    print(f"added resource '{r.name}' ({r.timezone}) with {len(r.availability)} availability slot(s)")
+    return 0
+
+
+def _cmd_resource_list(_: argparse.Namespace) -> int:
+    resources = service.list_resources()
+    if not resources:
+        print("(no resources)")
+        return 0
+    for r in resources:
+        desc = f" - {r.description}" if r.description else ""
+        print(f"{r.name} ({r.timezone}){desc}")
+        if r.availability:
+            for s in r.availability:
+                suffix = " [overnight]" if s.crosses_midnight else ""
+                print(f"    {WEEKDAYS[s.weekday]} {s.start}-{s.end}{suffix}")
+        else:
+            print("    (no availability defined)")
+    return 0
+
+
+def _cmd_book(args: argparse.Namespace) -> int:
+    b = service.create_booking(
+        resource_name=args.resource,
+        start_s=args.start,
+        end_s=args.end,
+        title=args.title,
+        booked_by=args.by,
+    )
+    print(f"booked {b.id}: {b.resource} {b.start} -> {b.end} (UTC) '{b.title}' by {b.booked_by}")
+    return 0
+
+
+def _cmd_cancel(args: argparse.Namespace) -> int:
+    b = service.cancel_booking(args.id)
+    print(f"cancelled {b.id} ({b.resource} {b.start} -> {b.end})")
+    return 0
+
+
+def _cmd_list(args: argparse.Namespace) -> int:
+    bookings = service.list_bookings(resource=args.resource, include_past=args.all)
+    if not bookings:
+        print("(no bookings)")
+        return 0
+    resources = {r.name: r for r in service.list_resources()}
+    for b in bookings:
+        res = resources.get(b.resource)
+        if res:
+            tz = service.validate_timezone(res.timezone)
+            local_start = b.start_dt().astimezone(tz)
+            local_end = b.end_dt().astimezone(tz)
+            time_str = (
+                f"{local_start.strftime('%Y-%m-%d %H:%M')} -> "
+                f"{local_end.strftime('%Y-%m-%d %H:%M')} {res.timezone}"
+            )
+        else:
+            time_str = f"{b.start} -> {b.end} UTC"
+        print(
+            f"{b.id}  {b.resource:<16}  {time_str}  "
+            f"{b.title!r} by {b.booked_by}"
+        )
+    return 0
+
+
+def _cmd_check(args: argparse.Namespace) -> int:
+    result = service.check_availability(
+        resource_name=args.resource,
+        start_s=args.start,
+        end_s=args.end,
+    )
+    r = result.resource
+    start_wd = WEEKDAYS[result.start.weekday()]
+    end_wd = WEEKDAYS[result.end.weekday()]
+
+    print(f"resource: {r.name} ({r.timezone})")
+    if result.start.date() == result.end.date():
+        print(
+            f"requested: {result.start.strftime('%Y-%m-%d %H:%M')} -> "
+            f"{result.end.strftime('%H:%M')} ({start_wd})"
+        )
+    else:
+        print(
+            f"requested: {result.start.strftime('%Y-%m-%d %H:%M')} ({start_wd}) -> "
+            f"{result.end.strftime('%Y-%m-%d %H:%M')} ({end_wd})"
+        )
+    print()
+
+    if result.within_availability:
+        slot = result.matching_slot
+        tag = " [overnight]" if slot.crosses_midnight else ""
+        print(f"availability: OK (within {WEEKDAYS[slot.weekday]} {slot.start}-{slot.end}{tag})")
+    else:
+        print("availability: OUTSIDE defined availability windows")
+
+    if result.conflicts:
+        tz = service.validate_timezone(r.timezone)
+        print(f"conflicts: {len(result.conflicts)}")
+        for c in result.conflicts:
+            local_s = c.start_dt().astimezone(tz)
+            local_e = c.end_dt().astimezone(tz)
+            print(
+                f"  - {c.id}: '{c.title}' by {c.booked_by} "
+                f"({local_s.strftime('%H:%M')} -> {local_e.strftime('%H:%M')})"
+            )
+    else:
+        print("conflicts: none")
+
+    print()
+    if result.available:
+        print("result: AVAILABLE")
+    else:
+        reasons = []
+        if not result.within_availability:
+            reasons.append("outside availability")
+        if result.conflicts:
+            reasons.append(f"{len(result.conflicts)} conflict(s)")
+        print(f"result: NOT AVAILABLE ({', '.join(reasons)})")
+
+    return 0 if result.available else 1
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="schedctl",
+        description="schedmax: self-contained resource scheduling CLI",
+    )
+    parser.add_argument("--version", action="version", version=f"schedmax {__version__}")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_init = sub.add_parser("init", help="initialize a schedmax database in cwd")
+    p_init.add_argument("--force", action="store_true", help="overwrite existing database")
+    p_init.set_defaults(func=_cmd_init)
+
+    p_res = sub.add_parser("resource", help="manage resources")
+    res_sub = p_res.add_subparsers(dest="resource_cmd", required=True)
+
+    p_res_add = res_sub.add_parser("add", help="add a resource")
+    p_res_add.add_argument("--name", required=True)
+    p_res_add.add_argument("--description", default="")
+    p_res_add.add_argument("--timezone", default="UTC", help="IANA timezone (default UTC)")
+    p_res_add.add_argument(
+        "--availability",
+        default="",
+        help="comma-separated slots like 'MON 09:00-17:00,FRI 22:00-02:00'",
+    )
+    p_res_add.set_defaults(func=_cmd_resource_add)
+
+    p_res_list = res_sub.add_parser("list", help="list resources")
+    p_res_list.set_defaults(func=_cmd_resource_list)
+
+    p_book = sub.add_parser("book", help="create a booking")
+    p_book.add_argument("--resource", required=True)
+    p_book.add_argument("--start", required=True, help="'YYYY-MM-DD HH:MM' in resource timezone")
+    p_book.add_argument("--end", required=True, help="'YYYY-MM-DD HH:MM' in resource timezone")
+    p_book.add_argument("--title", required=True)
+    p_book.add_argument("--by", required=True, help="name of the person booking")
+    p_book.set_defaults(func=_cmd_book)
+
+    p_cancel = sub.add_parser("cancel", help="cancel a booking by id")
+    p_cancel.add_argument("--id", required=True)
+    p_cancel.set_defaults(func=_cmd_cancel)
+
+    p_list = sub.add_parser("list", help="list bookings")
+    p_list.add_argument("--resource", default=None)
+    p_list.add_argument("--all", action="store_true", help="include past bookings")
+    p_list.set_defaults(func=_cmd_list)
+
+    p_check = sub.add_parser("check", help="check availability without booking")
+    p_check.add_argument("--resource", required=True)
+    p_check.add_argument("--start", required=True, help="'YYYY-MM-DD HH:MM' in resource timezone")
+    p_check.add_argument("--end", required=True, help="'YYYY-MM-DD HH:MM' in resource timezone")
+    p_check.set_defaults(func=_cmd_check)
+
+    return parser
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = build_parser()
+    args = parser.parse_args(argv)
+    try:
+        return args.func(args)
+    except ValidationError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+    except FileNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+    except FileExistsError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
diff --git a/schedmax/models.py b/schedmax/models.py
