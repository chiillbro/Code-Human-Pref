+            description="test",
+            timezone="Asia/Tokyo",
+            availability=[AvailabilitySlot(0, "09:00", "17:00")],
+        )
+        r2 = Resource.from_dict(r.to_dict())
+        self.assertEqual(r.name, r2.name)
+        self.assertEqual(r.timezone, r2.timezone)
+        self.assertEqual(r.description, r2.description)
