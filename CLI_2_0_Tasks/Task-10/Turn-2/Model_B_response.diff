@@ -0,0 +1,68 @@
+import json
+import os
+from pathlib import Path
+
+DB_DIRNAME = ".schedmax"
+DB_FILENAME = "db.json"
+
+
+def db_path(root: Path | None = None) -> Path:
+    root = root or Path.cwd()
+    return root / DB_DIRNAME / DB_FILENAME
+
+
+def find_db(start: Path | None = None) -> Path | None:
+    cur = (start or Path.cwd()).resolve()
+    for p in [cur, *cur.parents]:
+        candidate = p / DB_DIRNAME / DB_FILENAME
+        if candidate.exists():
+            return candidate
+    return None
+
+
+def init_db(root: Path | None = None, force: bool = False) -> Path:
+    path = db_path(root)
+    if path.exists():
+        if not force:
+            try:
+                with open(path, "r", encoding="utf-8") as f:
+                    json.load(f)
+                raise FileExistsError(f"schedmax already initialized at {path}")
+            except json.JSONDecodeError:
+                raise FileExistsError(
+                    f"corrupt database at {path}, use `schedctl init --force` to reinitialize"
+                )
+    path.parent.mkdir(parents=True, exist_ok=True)
+    data = {"version": 1, "resources": [], "bookings": []}
+    _write(path, data)
+    return path
+
+
+def load(path: Path | None = None) -> dict:
+    p = path or find_db()
+    if p is None:
+        raise FileNotFoundError(
+            "No schedmax database found. Run `schedctl init` first."
+        )
+    try:
+        with open(p, "r", encoding="utf-8") as f:
+            return json.load(f)
+    except json.JSONDecodeError as exc:
+        raise FileNotFoundError(
+            f"corrupt database at {p}, reinitialize with `schedctl init --force`"
+        ) from exc
+
+
+def save(data: dict, path: Path | None = None) -> None:
+    p = path or find_db()
+    if p is None:
+        raise FileNotFoundError("No schedmax database found.")
+    _write(p, data)
+
+
+def _write(path: Path, data: dict) -> None:
+    tmp = path.with_suffix(path.suffix + ".tmp")
+    with open(tmp, "w", encoding="utf-8") as f:
+        json.dump(data, f, indent=2, sort_keys=False)
+        f.write("\n")
+    os.replace(tmp, path)
