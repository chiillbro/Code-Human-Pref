new file mode 100644
index 0000000..7de76fc
--- /dev/null
+++ b/schedmax/service.py
@@ -0,0 +1,207 @@
+from __future__ import annotations
+
+import uuid
+from datetime import datetime, timedelta
+from zoneinfo import ZoneInfo, ZoneInfoNotFoundError
+
+from . import storage
+from .models import (
+    AvailabilitySlot,
+    Booking,
+    CheckResult,
+    Resource,
+    ValidationError,
+    find_matching_slot,
+    fits_within_availability,
+    overlaps,
+)
+
+MIN_BOOKING = timedelta(minutes=1)
+MAX_BOOKING = timedelta(days=1)
+UTC = ZoneInfo("UTC")
+
+
+def validate_timezone(name: str) -> ZoneInfo:
+    if not name or not name.strip():
+        raise ValidationError("timezone is required")
+    try:
+        return ZoneInfo(name)
+    except (KeyError, ZoneInfoNotFoundError) as exc:
+        raise ValidationError(f"unknown timezone '{name}'") from exc
+
+
+def _resource_tz(resource: Resource) -> ZoneInfo:
+    return validate_timezone(resource.timezone)
+
+
+def add_resource(
+    name: str,
+    description: str,
+    availability: list[AvailabilitySlot],
+    timezone: str = "UTC",
+) -> Resource:
+    validate_timezone(timezone)
+    data = storage.load()
+    if any(r["name"] == name for r in data["resources"]):
+        raise ValidationError(f"resource '{name}' already exists")
+    resource = Resource(
+        name=name, description=description, timezone=timezone, availability=availability
+    )
+    resource.validate()
+    data["resources"].append(resource.to_dict())
+    storage.save(data)
+    return resource
+
+
+def list_resources() -> list[Resource]:
+    data = storage.load()
+    return [Resource.from_dict(r) for r in data["resources"]]
+
+
+def _get_resource(data: dict, name: str) -> Resource:
+    for r in data["resources"]:
+        if r["name"] == name:
+            return Resource.from_dict(r)
+    raise ValidationError(f"resource '{name}' not found")
+
+
+def parse_dt(s: str, tz: ZoneInfo) -> datetime:
+    s = s.strip()
+    try:
+        if "T" in s:
+            dt = datetime.fromisoformat(s)
+        else:
+            dt = datetime.strptime(s, "%Y-%m-%d %H:%M")
+    except ValueError as exc:
+        raise ValidationError(
+            f"invalid datetime '{s}', expected 'YYYY-MM-DD HH:MM' or ISO-8601"
+        ) from exc
+    if dt.tzinfo is None:
+        dt = dt.replace(tzinfo=tz)
+    return dt
+
+
+def create_booking(
+    resource_name: str,
+    start_s: str,
+    end_s: str,
+    title: str,
+    booked_by: str,
+    now: datetime | None = None,
+) -> Booking:
+    if not title.strip():
+        raise ValidationError("title is required")
+    if not booked_by.strip():
+        raise ValidationError("booked_by is required")
+
+    data = storage.load()
+    resource = _get_resource(data, resource_name)
+    tz = _resource_tz(resource)
+
+    start = parse_dt(start_s, tz)
+    end = parse_dt(end_s, tz)
+    current = now or datetime.now(tz=UTC)
+
+    if end <= start:
+        raise ValidationError("end must be after start")
+    duration = end - start
+    if duration < MIN_BOOKING:
+        raise ValidationError("booking duration must be at least 1 minute")
+    if duration > MAX_BOOKING:
+        raise ValidationError("booking duration must not exceed 24 hours")
+    if start < current:
+        raise ValidationError("cannot book in the past")
+
+    if not fits_within_availability(start, end, resource.availability):
+        raise ValidationError(
+            f"booking is outside '{resource.name}' availability"
+        )
+
+    start_utc = start.astimezone(UTC)
+    end_utc = end.astimezone(UTC)
+
+    for b in data["bookings"]:
+        if b["resource"] != resource.name:
+            continue
+        existing = Booking.from_dict(b)
+        if overlaps(start_utc, end_utc, existing.start_dt(), existing.end_dt()):
+            raise ValidationError(
+                f"overlaps existing booking {existing.id} "
+                f"({existing.start} -> {existing.end})"
+            )
+
+    booking = Booking(
+        id=uuid.uuid4().hex[:8],
+        resource=resource.name,
+        start=start_utc.isoformat(),
+        end=end_utc.isoformat(),
+        title=title.strip(),
+        booked_by=booked_by.strip(),
+    )
+    data["bookings"].append(booking.to_dict())
+    storage.save(data)
+    return booking
+
+
+def cancel_booking(booking_id: str) -> Booking:
+    data = storage.load()
+    for i, b in enumerate(data["bookings"]):
+        if b["id"] == booking_id:
+            removed = Booking.from_dict(data["bookings"].pop(i))
+            storage.save(data)
+            return removed
+    raise ValidationError(f"booking '{booking_id}' not found")
+
+
+def list_bookings(
+    resource: str | None = None, include_past: bool = False
+) -> list[Booking]:
+    data = storage.load()
+    now = datetime.now(tz=UTC)
+    out: list[Booking] = []
+    for b in data["bookings"]:
+        if resource and b["resource"] != resource:
+            continue
+        bk = Booking.from_dict(b)
+        if not include_past and bk.end_dt() < now:
+            continue
+        out.append(bk)
+    out.sort(key=lambda x: x.start_dt())
+    return out
+
+
+def check_availability(
+    resource_name: str,
+    start_s: str,
+    end_s: str,
+) -> CheckResult:
+    data = storage.load()
+    resource = _get_resource(data, resource_name)
+    tz = _resource_tz(resource)
+
+    start = parse_dt(start_s, tz)
+    end = parse_dt(end_s, tz)
+
+    if end <= start:
+        raise ValidationError("end must be after start")
+
+    matching = find_matching_slot(start, end, resource.availability)
+
+    start_utc = start.astimezone(UTC)
+    end_utc = end.astimezone(UTC)
+    conflicts: list[Booking] = []
+    for b in data["bookings"]:
+        if b["resource"] != resource.name:
+            continue
+        existing = Booking.from_dict(b)
+        if overlaps(start_utc, end_utc, existing.start_dt(), existing.end_dt()):
+            conflicts.append(existing)
+
+    return CheckResult(
+        resource=resource,
+        start=start,
+        end=end,
+        within_availability=matching is not None,
+        matching_slot=matching,
+        conflicts=conflicts,
+    )
