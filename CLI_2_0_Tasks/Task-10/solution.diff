+"""Tests for the scheduler: overlap detection, validation, conflict resolution."""
+
+from __future__ import annotations
+
+from datetime import date, datetime, time, timedelta, timezone
+from zoneinfo import ZoneInfo
+
+import pytest
+
+from schedctl.models import (
+    AvailabilityWindow,
+    Booking,
+    ConflictError,
+    Recurrence,
+    RecurrenceRule,
+    Resource,
+    ValidationError,
+    has_higher_priority,
+)
+from schedctl.scheduler import (
+    create_booking,
+    find_conflicts,
+    overlaps,
+    suggest_nearest_slots,
+    validate_booking_request,
+)
+
+
+UTC = timezone.utc
+
+
+def make_resource():
+    return Resource(
+        name="room-A",
+        tz="UTC",
+        availability=[AvailabilityWindow(
+            start_date=date(2025, 3, 1),
+            start_time=time(0, 0),
+            end_time=time(23, 59, 59),
+            recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+        )],
+    )
+
+
+def mk_booking(start_hour: int, end_hour: int, priority: int = 5, title="t", id_="b1") -> Booking:
+    return Booking(
+        id=id_,
+        resource="room-A",
+        title=title,
+        start_utc=datetime(2025, 3, 15, start_hour, 0, tzinfo=UTC),
+        end_utc=datetime(2025, 3, 15, end_hour, 0, tzinfo=UTC),
+        priority=priority,
+        booker="alice",
+    )
+
+
+class TestPriorityHelper:
+    def test_lower_number_is_higher(self):
+        assert has_higher_priority(1, 10)
+        assert has_higher_priority(3, 5)
+
+    def test_equal_is_not_higher(self):
+        assert not has_higher_priority(5, 5)
+
+    def test_larger_is_not_higher(self):
+        assert not has_higher_priority(7, 3)
+
+
+class TestOverlap:
+    def test_no_overlap(self):
+        a_start = datetime(2025, 3, 15, 9, tzinfo=UTC)
+        a_end = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        b_start = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        b_end = datetime(2025, 3, 15, 12, tzinfo=UTC)
+        assert not overlaps(a_start, a_end, b_start, b_end)
+
+    def test_touching_is_not_overlap(self):
+        a_start = datetime(2025, 3, 15, 9, tzinfo=UTC)
+        a_end = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        b_start = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        b_end = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        assert not overlaps(a_start, a_end, b_start, b_end)
+
+    def test_partial_overlap(self):
+        a_start = datetime(2025, 3, 15, 9, tzinfo=UTC)
+        a_end = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        b_start = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        b_end = datetime(2025, 3, 15, 12, tzinfo=UTC)
+        assert overlaps(a_start, a_end, b_start, b_end)
+
+    def test_full_containment(self):
+        a_start = datetime(2025, 3, 15, 9, tzinfo=UTC)
+        a_end = datetime(2025, 3, 15, 17, tzinfo=UTC)
+        b_start = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        b_end = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        assert overlaps(a_start, a_end, b_start, b_end)
+
+
+class TestValidation:
+    def test_zero_duration_rejected(self):
+        res = make_resource()
+        s = datetime.now(tz=UTC) + timedelta(days=1)
+        with pytest.raises(ValidationError, match="duration"):
+            validate_booking_request(res, s, s, 5)
+
+    def test_past_booking_rejected(self):
+        res = make_resource()
+        s = datetime.now(tz=UTC) - timedelta(days=1)
+        e = s + timedelta(hours=1)
+        with pytest.raises(ValidationError, match="past"):
+            validate_booking_request(res, s, e, 5)
+
+    def test_invalid_priority_rejected(self):
+        res = make_resource()
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        s = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        with pytest.raises(ValidationError, match="Priority"):
+            validate_booking_request(res, s, e, 0, now_utc=now)
+        with pytest.raises(ValidationError, match="Priority"):
+            validate_booking_request(res, s, e, 11, now_utc=now)
+
+    def test_outside_availability_rejected(self):
+        # Resource only available 09:00-17:00
+        res = Resource(
+            name="room-A",
+            tz="UTC",
+            availability=[AvailabilityWindow(
+                start_date=date(2025, 3, 1),
+                start_time=time(9, 0),
+                end_time=time(17, 0),
+                recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+            )],
+        )
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        s = datetime(2025, 3, 15, 18, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 19, tzinfo=UTC)
+        with pytest.raises(ValidationError, match="outside"):
+            validate_booking_request(res, s, e, 5, now_utc=now)
+
+
+class TestCreateBooking:
+    def test_no_conflict_creates_booking(self):
+        res = make_resource()
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        s = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        new, disp = create_booking(res, [], "Meeting", s, e, "alice", now_utc=now)
+        assert len(new) == 1
+        assert disp == []
+        assert new[0].title == "Meeting"
+
+    def test_conflict_without_force_raises(self):
+        res = make_resource()
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        existing = [mk_booking(10, 12)]
+        s = datetime(2025, 3, 15, 11, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 13, tzinfo=UTC)
