+"""JSON file-based persistence."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+from schedctl.models import (
+    Booking,
+    Resource,
+    ResourceNotFoundError,
+    StorageError,
+    ValidationError,
+    WaitlistEntry,
+)
+
+
+DEFAULT_DB = "schedctl.json"
+
+
+class Database:
+    """In-memory working copy of the schedctl database backed by a JSON file."""
+
+    def __init__(self, path: str | Path):
+        self.path = Path(path)
+        self.resources: dict[str, Resource] = {}
+        self.bookings: list[Booking] = []
+        self.waitlist: list[WaitlistEntry] = []
+
+    # ------------------------------------------------------------------
+    # Load / save
+    # ------------------------------------------------------------------
+
+    @classmethod
+    def init(cls, path: str | Path) -> "Database":
+        p = Path(path)
+        if p.exists():
+            raise StorageError(f"Database already exists: {p}")
+        db = cls(p)
+        db.save()
+        return db
+
+    @classmethod
+    def load(cls, path: str | Path) -> "Database":
+        p = Path(path)
+        if not p.exists():
+            raise StorageError(f"Database not found: {p}")
+        try:
+            with p.open("r", encoding="utf-8") as f:
+                data = json.load(f)
+        except (OSError, json.JSONDecodeError) as e:
+            raise StorageError(f"Failed to read database {p}: {e}") from e
+
+        db = cls(p)
+        for r in data.get("resources", []):
+            res = Resource.from_dict(r)
+            db.resources[res.name] = res
+        db.bookings = [Booking.from_dict(b) for b in data.get("bookings", [])]
+        db.waitlist = [WaitlistEntry.from_dict(w) for w in data.get("waitlist", [])]
+        return db
+
+    def save(self) -> None:
+        data = {
+            "resources": [r.to_dict() for r in self.resources.values()],
+            "bookings": [b.to_dict() for b in self.bookings],
+            "waitlist": [w.to_dict() for w in self.waitlist],
+        }
+        tmp = self.path.with_suffix(self.path.suffix + ".tmp")
+        try:
+            with tmp.open("w", encoding="utf-8") as f:
+                json.dump(data, f, indent=2)
+            tmp.replace(self.path)
+        except OSError as e:
+            raise StorageError(f"Failed to write database {self.path}: {e}") from e
+
+    # ------------------------------------------------------------------
+    # Resource CRUD
+    # ------------------------------------------------------------------
+
+    def add_resource(self, resource: Resource) -> None:
+        if resource.name in self.resources:
+            raise ValidationError(f"Resource '{resource.name}' already exists")
+        self.resources[resource.name] = resource
+
+    def get_resource(self, name: str) -> Resource:
+        if name not in self.resources:
+            raise ResourceNotFoundError(f"Resource '{name}' not found")
+        return self.resources[name]
+
+    # ------------------------------------------------------------------
+    # Booking helpers
+    # ------------------------------------------------------------------
+
+    def bookings_for(self, resource_name: str) -> list[Booking]:
+        return [b for b in self.bookings if b.resource == resource_name]
+
+    def waitlist_for(self, resource_name: str) -> list[WaitlistEntry]:
+        return [w for w in self.waitlist if w.resource == resource_name]
+
+    def find_booking(self, booking_id: str) -> Booking:
+        for b in self.bookings:
+            if b.id == booking_id:
+                return b
+        raise ValidationError(f"Booking '{booking_id}' not found")
