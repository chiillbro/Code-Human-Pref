@@ -0,0 +1,83 @@
+"""Waitlist management: priority ordering and cascading promotion."""
+
+from __future__ import annotations
+
+from datetime import datetime
+from typing import Iterable
+
+from schedctl.models import (
+    AvailabilityWindow,
+    Booking,
+    WaitlistEntry,
+)
+from schedctl.recurrence import is_contained_in_availability
+from schedctl.scheduler import overlaps
+
+
+def sort_waitlist(entries: Iterable[WaitlistEntry]) -> list[WaitlistEntry]:
+    """Sort by priority ascending (lower number = higher priority),
+    then creation timestamp ascending (earlier first)."""
+    return sorted(entries, key=lambda e: (e.priority, e.created_at))
+
+
+def _fits(
+    entry: WaitlistEntry,
+    active_bookings: list[Booking],
+    availability: list[AvailabilityWindow],
+    tz: str,
+) -> bool:
+    """An entry fits if its time range doesn't overlap any active booking
+    AND is fully inside availability."""
+    for b in active_bookings:
+        if overlaps(entry.start_utc, entry.end_utc, b.start_utc, b.end_utc):
+            return False
+    if not is_contained_in_availability(availability, tz, entry.start_utc, entry.end_utc):
+        return False
+    # Also must not be in the past — but we assume caller filters that.
+    return True
+
+
+def promote_from_waitlist(
+    waitlist: list[WaitlistEntry],
+    active_bookings: list[Booking],
+    availability: list[AvailabilityWindow],
+    tz: str,
+) -> tuple[list[Booking], list[WaitlistEntry], list[WaitlistEntry]]:
+    """Perform cascading promotion.
+
+    Returns (promoted_bookings, removed_waitlist_entries, remaining_waitlist).
+
+    The algorithm:
+      1. Sort waitlist by priority, then creation time.
+      2. Walk the sorted list; for each entry, if it fits given the current
+         set of active bookings (original + already-promoted), promote it.
+      3. After any promotion, re-sort and re-walk until a full pass produces
+         no further promotions.
+    """
+    promoted: list[Booking] = []
+    removed_ids: set[str] = set()
+
+    # Work with mutable copies
+    current_active = list(active_bookings)
+    remaining = list(waitlist)
+
+    changed = True
+    while changed:
+        changed = False
+        remaining_sorted = sort_waitlist(remaining)
+        for entry in remaining_sorted:
+            if entry.id in removed_ids:
+                continue
+            if _fits(entry, current_active, availability, tz):
+                b = entry.to_booking()
+                promoted.append(b)
+                current_active.append(b)
+                removed_ids.add(entry.id)
+                changed = True
+                # break to re-sort and re-walk (cascade)
+                break
+        # update `remaining` to drop promoted ones
+        remaining = [e for e in remaining if e.id not in removed_ids]
+
+    removed = [e for e in waitlist if e.id in removed_ids]
+    return promoted, removed, remaining
