index 0000000..e1da47d
--- /dev/null
+++ b/src/schedctl/models.py
@@ -0,0 +1,274 @@
+"""Data models for schedctl."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from datetime import date, datetime, time
+from enum import Enum
+from typing import Any
+
+
+class Recurrence(str, Enum):
+    NONE = "none"
+    DAILY = "daily"
+    WEEKLY = "weekly"
+    MONTHLY = "monthly"
+    YEARLY = "yearly"
+
+
+class Weekday(str, Enum):
+    MON = "mon"
+    TUE = "tue"
+    WED = "wed"
+    THU = "thu"
+    FRI = "fri"
+    SAT = "sat"
+    SUN = "sun"
+
+    @classmethod
+    def from_str(cls, s: str) -> "Weekday":
+        s = s.lower().strip()
+        for w in cls:
+            if w.value == s:
+                return w
+        raise ValueError(f"Invalid weekday: {s}")
+
+    def to_int(self) -> int:
+        """Python's weekday(): Mon=0, Sun=6."""
+        return ["mon", "tue", "wed", "thu", "fri", "sat", "sun"].index(self.value)
+
+
+class SchedctlError(Exception):
+    """Base for all schedctl errors."""
+
+
+class ValidationError(SchedctlError):
+    pass
+
+
+class ConflictError(SchedctlError):
+    def __init__(self, message: str, conflicts: list["Booking"] | None = None):
+        super().__init__(message)
+        self.conflicts = conflicts or []
+
+
+class ResourceNotFoundError(SchedctlError):
+    pass
+
+
+class StorageError(SchedctlError):
+    pass
+
+
+@dataclass
+class RecurrenceRule:
+    kind: Recurrence = Recurrence.NONE
+    interval: int = 1
+    until: date | None = None
+    exceptions: list[date] = field(default_factory=list)
+    weekdays: list[Weekday] = field(default_factory=list)
+
+    def to_dict(self) -> dict:
+        return {
+            "kind": self.kind.value,
+            "interval": self.interval,
+            "until": self.until.isoformat() if self.until else None,
+            "exceptions": [d.isoformat() for d in self.exceptions],
+            "weekdays": [w.value for w in self.weekdays],
+        }
+
+    @classmethod
+    def from_dict(cls, d: dict) -> "RecurrenceRule":
+        return cls(
+            kind=Recurrence(d.get("kind", "none")),
+            interval=int(d.get("interval", 1)),
+            until=date.fromisoformat(d["until"]) if d.get("until") else None,
+            exceptions=[date.fromisoformat(x) for x in d.get("exceptions", [])],
+            weekdays=[Weekday(w) for w in d.get("weekdays", [])],
+        )
+
+
+@dataclass
+class AvailabilityWindow:
+    """A time window during which a resource may be booked.
+
+    start_time / end_time are *local* wall-clock times in the resource's
+    timezone. start_date is the first date (in the resource's timezone) when
+    this window applies. Recurrence is applied from start_date onward.
+
+    If end_time <= start_time, the window spans midnight (ends next day).
+    """
+    start_date: date
+    start_time: time
+    end_time: time
+    recurrence: RecurrenceRule = field(default_factory=RecurrenceRule)
+
+    def to_dict(self) -> dict:
+        return {
+            "start_date": self.start_date.isoformat(),
+            "start_time": self.start_time.isoformat(),
+            "end_time": self.end_time.isoformat(),
+            "recurrence": self.recurrence.to_dict(),
+        }
+
+    @classmethod
+    def from_dict(cls, d: dict) -> "AvailabilityWindow":
+        return cls(
+            start_date=date.fromisoformat(d["start_date"]),
+            start_time=time.fromisoformat(d["start_time"]),
+            end_time=time.fromisoformat(d["end_time"]),
+            recurrence=RecurrenceRule.from_dict(d.get("recurrence", {})),
+        )
+
+
+@dataclass
+class Resource:
+    name: str
+    tz: str  # IANA timezone name
+    description: str = ""
+    availability: list[AvailabilityWindow] = field(default_factory=list)
+
+    def to_dict(self) -> dict:
+        return {
+            "name": self.name,
+            "tz": self.tz,
+            "description": self.description,
+            "availability": [a.to_dict() for a in self.availability],
+        }
+
+    @classmethod
+    def from_dict(cls, d: dict) -> "Resource":
+        return cls(
+            name=d["name"],
+            tz=d["tz"],
+            description=d.get("description", ""),
+            availability=[AvailabilityWindow.from_dict(a) for a in d.get("availability", [])],
+        )
+
+
+@dataclass
+class Booking:
+    """A booking reserves a resource. Times are stored in UTC."""
+    id: str
+    resource: str
+    title: str
+    start_utc: datetime  # tz-aware UTC
+    end_utc: datetime    # tz-aware UTC
+    priority: int = 5
+    booker: str = ""
+    created_at: datetime = field(default_factory=lambda: datetime.now(tz=__import__("datetime").timezone.utc))
+
+    def to_dict(self) -> dict:
+        return {
+            "id": self.id,
+            "resource": self.resource,
+            "title": self.title,
+            "start_utc": self.start_utc.isoformat(),
+            "end_utc": self.end_utc.isoformat(),
+            "priority": self.priority,
+            "booker": self.booker,
+            "created_at": self.created_at.isoformat(),
+        }
+
+    @classmethod
+    def from_dict(cls, d: dict) -> "Booking":
+        return cls(
+            id=d["id"],
+            resource=d["resource"],
+            title=d["title"],
+            start_utc=datetime.fromisoformat(d["start_utc"]),
+            end_utc=datetime.fromisoformat(d["end_utc"]),
+            priority=int(d.get("priority", 5)),
+            booker=d.get("booker", ""),
+            created_at=datetime.fromisoformat(d["created_at"]),
+        )
+
+
+@dataclass
+class WaitlistEntry:
+    """An entry on a resource's waitlist."""
+    id: str
+    resource: str
+    title: str
+    start_utc: datetime
+    end_utc: datetime
+    priority: int
+    booker: str
+    created_at: datetime
+
+    def to_dict(self) -> dict:
+        return {
+            "id": self.id,
+            "resource": self.resource,
+            "title": self.title,
+            "start_utc": self.start_utc.isoformat(),
+            "end_utc": self.end_utc.isoformat(),
+            "priority": self.priority,
+            "booker": self.booker,
+            "created_at": self.created_at.isoformat(),
+        }
+
+    @classmethod
+    def from_dict(cls, d: dict) -> "WaitlistEntry":
+        return cls(
+            id=d["id"],
+            resource=d["resource"],
+            title=d["title"],
+            start_utc=datetime.fromisoformat(d["start_utc"]),
+            end_utc=datetime.fromisoformat(d["end_utc"]),
+            priority=int(d["priority"]),
+            booker=d.get("booker", ""),
+            created_at=datetime.fromisoformat(d["created_at"]),
+        )
+
+    def to_booking(self) -> Booking:
+        return Booking(
+            id=self.id,
+            resource=self.resource,
+            title=self.title,
+            start_utc=self.start_utc,
+            end_utc=self.end_utc,
+            priority=self.priority,
+            booker=self.booker,
+            created_at=self.created_at,
+        )
+
+    @classmethod
+    def from_booking(cls, b: Booking) -> "WaitlistEntry":
+        return cls(
+            id=b.id,
+            resource=b.resource,
+            title=b.title,
+            start_utc=b.start_utc,
+            end_utc=b.end_utc,
+            priority=b.priority,
+            booker=b.booker,
+            created_at=b.created_at,
+        )
+
+
+@dataclass
+class UtilizationReport:
+    resource: str
+    from_utc: datetime
+    to_utc: datetime
+    available_hours: float
+    booked_hours: float
+    utilization_pct: float
+    busiest_day: date | None
+    conflicts_encountered: int
+    by_priority: dict[str, int]  # "high" | "medium" | "low" -> count
+
+
+# ---------------------------------------------------------------------------
+# Priority comparison — ONE helper, used everywhere
+# ---------------------------------------------------------------------------
+
+def has_higher_priority(a: int, b: int) -> bool:
+    """Return True iff priority *a* is strictly higher than priority *b*.
+
+    Priority 1 is the highest, 10 is the lowest. So "higher priority" means
+    a numerically SMALLER value. Centralised here to avoid the classic
+    inversion bug (`a > b` when it should be `a < b`).
+    """
+    return a < b
