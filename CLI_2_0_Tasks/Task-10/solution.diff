+        tz = "UTC"
+        # Booking 18:00-19:00 UTC on Mar 12 — outside
+        s = datetime(2025, 3, 12, 18, 0, tzinfo=UTC)
+        e = datetime(2025, 3, 12, 19, 0, tzinfo=UTC)
