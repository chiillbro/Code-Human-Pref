+"""End-to-end CLI integration tests."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from datetime import date, datetime, timedelta, timezone
+from pathlib import Path
+
+import pytest
+
+from schedctl.cli import main as cli_main
+
+
+UTC = timezone.utc
+
+
+def run(argv: list[str], capsys) -> tuple[int, str, str]:
+    """Invoke the CLI entry point in-process and capture output."""
+    code = cli_main(argv)
+    captured = capsys.readouterr()
+    return code, captured.out, captured.err
+
+
+def future(days_from_now: int, hour: int) -> str:
+    """Build an ISO 8601 datetime in UTC at the given hour, N days from today."""
+    dt = datetime.now(tz=UTC).replace(microsecond=0, second=0, minute=0, hour=hour)
+    dt = dt + timedelta(days=days_from_now)
+    return dt.strftime("%Y-%m-%dT%H:%M:%S+00:00")
+
+
+def future_date(days_from_now: int) -> str:
+    d = (datetime.now(tz=UTC) + timedelta(days=days_from_now)).date()
+    return d.isoformat()
+
+
+@pytest.fixture
+def db_path(tmp_path) -> str:
+    return str(tmp_path / "schedctl.json")
+
+
+def test_init_and_list_resources(db_path, capsys):
+    code, out, _ = run(["--db", db_path, "init"], capsys)
+    assert code == 0
+    assert Path(db_path).exists()
+
+    code, out, _ = run(["--db", db_path, "resource", "list"], capsys)
+    assert code == 0
+    assert "no resources" in out
+
+
+def test_full_workflow(db_path, capsys):
+    # init
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+
+    # add resource
+    code, out, _ = run([
+        "--db", db_path, "resource", "add", "room-A",
+        "--tz", "UTC", "--description", "Main",
+    ], capsys)
+    assert code == 0
+
+    # add daily availability 00:00-23:59
+    code, out, err = run([
+        "--db", db_path, "resource", "availability", "room-A",
+        "--start", "00:00", "--end", "23:59",
+        "--start-date", future_date(0),
+        "--recurrence", "daily",
+    ], capsys)
+    assert code == 0, err
+
+    # book priority-3
+    code, out, err = run([
+        "--db", db_path, "book", "room-A",
+        "--title", "meeting",
+        "--start", future(3, 10),
+        "--end", future(3, 11),
+        "--booker", "alice",
+        "--priority", "3",
+    ], capsys)
+    assert code == 0, err
+    assert "Booked" in out
+
+    # list bookings
+    code, out, _ = run(["--db", db_path, "list", "room-A"], capsys)
+    assert code == 0
+    assert "meeting" in out
+
+    # try conflicting booking without --force -> exit 2
+    code, _, err = run([
+        "--db", db_path, "book", "room-A",
+        "--title", "conflict",
+        "--start", future(3, 10),
+        "--end", future(3, 11),
+        "--booker", "bob",
+        "--priority", "5",
+    ], capsys)
+    assert code == 2  # CONFLICT
+    assert "conflict" in err.lower()
+
+
+def test_priority_displacement_and_waitlist(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "add", "room-A", "--tz", "UTC",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "availability", "room-A",
+        "--start", "00:00", "--end", "23:59",
+        "--start-date", future_date(0),
+        "--recurrence", "daily",
+    ], capsys)[0] == 0
+
+    # Alice books at priority 5
+    assert run([
+        "--db", db_path, "book", "room-A",
+        "--title", "alice-mtg",
+        "--start", future(3, 10), "--end", future(3, 11),
+        "--booker", "alice", "--priority", "5",
+    ], capsys)[0] == 0
+
+    # Bob displaces with priority 1 using --force --strategy=priority
+    code, out, err = run([
+        "--db", db_path, "book", "room-A",
+        "--title", "bob-urgent",
+        "--start", future(3, 10), "--end", future(3, 11),
+        "--booker", "bob", "--priority", "1",
+        "--force", "--strategy", "priority",
+    ], capsys)
+    assert code == 0, err
+    assert "Displaced" in out
+
+    # Alice's booking should be on waitlist
+    code, out, _ = run(["--db", db_path, "waitlist", "room-A"], capsys)
+    assert code == 0
+    assert "alice-mtg" in out
+
+    # Only bob's booking is active
+    code, out, _ = run(["--db", db_path, "list", "room-A"], capsys)
+    assert "bob-urgent" in out
+    assert "alice-mtg" not in out
+
+
+def test_cancel_triggers_cascading_waitlist_promotion(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "add", "room-A", "--tz", "UTC",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "availability", "room-A",
+        "--start", "00:00", "--end", "23:59",
+        "--start-date", future_date(0),
+        "--recurrence", "daily",
+    ], capsys)[0] == 0
+
+    # Active: priority-5 at 10-11
+    assert run([
+        "--db", db_path, "book", "room-A",
+        "--title", "a", "--start", future(3, 10), "--end", future(3, 11),
+        "--booker", "alice", "--priority", "5",
+    ], capsys)[0] == 0
+
+    # Displace: priority-1 wins
+    code, out, err = run([
+        "--db", db_path, "book", "room-A",
+        "--title", "b", "--start", future(3, 10), "--end", future(3, 11),
+        "--booker", "bob", "--priority", "1",
+        "--force", "--strategy", "priority",
+    ], capsys)
+    assert code == 0, err
+
+    # Find bob's booking id
+    data = json.loads(Path(db_path).read_text())
+    assert len(data["bookings"]) == 1
+    bob_id = data["bookings"][0]["id"]
+    assert len(data["waitlist"]) == 1
+
+    # Cancel bob -> alice should promote from waitlist
+    code, out, err = run(["--db", db_path, "cancel", bob_id], capsys)
+    assert code == 0, err
+
+    data = json.loads(Path(db_path).read_text())
+    assert len(data["bookings"]) == 1
+    assert data["bookings"][0]["title"] == "a"
+    assert len(data["waitlist"]) == 0
+
+
+def test_report_command(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "add", "room-A", "--tz", "UTC",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "availability", "room-A",
+        "--start", "09:00", "--end", "17:00",
+        "--start-date", future_date(0),
+        "--recurrence", "daily",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "book", "room-A",
+        "--title", "m", "--start", future(3, 10), "--end", future(3, 12),
+        "--booker", "a", "--priority", "3",
+    ], capsys)[0] == 0
+
+    # Report for day 3
+    code, out, err = run([
+        "--db", db_path, "report", "room-A",
+        "--from", future(3, 0), "--to", future(4, 0),
+    ], capsys)
+    assert code == 0, err
+    assert "Utilization report" in out
+    assert "Available hours : 8.0" in out
+    assert "Booked hours    : 2.0" in out
+
+
+def test_check_command(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "add", "room-A", "--tz", "UTC",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "availability", "room-A",
+        "--start", "00:00", "--end", "23:59",
+        "--start-date", future_date(0),
+        "--recurrence", "daily",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "book", "room-A",
+        "--title", "m", "--start", future(3, 10), "--end", future(3, 11),
+        "--booker", "a", "--priority", "5",
+    ], capsys)[0] == 0
+
+    # Check a free slot
+    code, out, _ = run([
+        "--db", db_path, "check", "room-A",
+        "--start", future(3, 14), "--end", future(3, 15),
+    ], capsys)
+    assert code == 0
+    assert "Available" in out
+
+    # Check a conflicting slot
+    code, out, _ = run([
+        "--db", db_path, "check", "room-A",
+        "--start", future(3, 10), "--end", future(3, 11),
+    ], capsys)
+    assert code == 0
+    assert "Not available" in out
+
+
+def test_version(db_path, capsys):
+    code, out, _ = run(["--db", db_path, "version"], capsys)
+    assert code == 0
+    assert "schedctl" in out
+
+
+def test_unknown_resource_name_format(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    code, _, err = run([
+        "--db", db_path, "resource", "add", "bad name!", "--tz", "UTC",
+    ], capsys)
+    assert code == 1
+
+
+def test_unknown_timezone_rejected(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    code, _, err = run([
+        "--db", db_path, "resource", "add", "room", "--tz", "Mars/Olympus",
+    ], capsys)
+    assert code == 1
+
+
+def test_past_booking_rejected(db_path, capsys):
+    assert run(["--db", db_path, "init"], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "add", "room-A", "--tz", "UTC",
+    ], capsys)[0] == 0
+    assert run([
+        "--db", db_path, "resource", "availability", "room-A",
+        "--start", "00:00", "--end", "23:59",
+        "--start-date", "2020-01-01",
+        "--recurrence", "daily",
+    ], capsys)[0] == 0
+
+    code, _, err = run([
+        "--db", db_path, "book", "room-A",
+        "--title", "m",
+        "--start", "2020-01-01T10:00:00+00:00",
+        "--end", "2020-01-01T11:00:00+00:00",
+        "--booker", "a", "--priority", "5",
+    ], capsys)
+    assert code == 1
