+"""Utilization reporting."""
+
+from __future__ import annotations
+
+from collections import Counter
+from datetime import date, datetime, timedelta
+from zoneinfo import ZoneInfo
+
+from schedctl.models import Booking, Resource, UtilizationReport
+from schedctl.recurrence import expand_all
+
+
+def _interval_hours(intervals: list[tuple[datetime, datetime]]) -> float:
+    return sum((e - s).total_seconds() for s, e in intervals) / 3600.0
+
+
+def _clip(intervals: list[tuple[datetime, datetime]], lo: datetime, hi: datetime) -> list[tuple[datetime, datetime]]:
+    out = []
+    for s, e in intervals:
+        s2 = max(s, lo)
+        e2 = min(e, hi)
+        if s2 < e2:
+            out.append((s2, e2))
+    return out
+
+
+def _priority_bucket(priority: int) -> str:
+    if 1 <= priority <= 3:
+        return "high"
+    if 4 <= priority <= 7:
+        return "medium"
+    return "low"
+
+
+def compute_report(
+    resource: Resource,
+    bookings: list[Booking],
+    from_utc: datetime,
+    to_utc: datetime,
+    conflicts_encountered: int = 0,
+) -> UtilizationReport:
+    zone = ZoneInfo(resource.tz)
+
+    # Available hours = sum of expanded availability clipped to range
+    avail = expand_all(resource.availability, resource.tz, from_utc, to_utc)
+    available_hours = _interval_hours(avail)
+
+    # Booked hours = sum of bookings clipped to range, intersected with availability
+    booked_intervals_raw = [(b.start_utc, b.end_utc) for b in bookings]
+    booked_intervals = _clip(booked_intervals_raw, from_utc, to_utc)
+    # We count booked time only within availability (avoids DB-inconsistency skew)
+    booked_in_avail: list[tuple[datetime, datetime]] = []
+    for s, e in booked_intervals:
+        for as_, ae in avail:
+            s2 = max(s, as_)
+            e2 = min(e, ae)
+            if s2 < e2:
+                booked_in_avail.append((s2, e2))
+    booked_hours = _interval_hours(booked_in_avail)
+
+    utilization_pct = (100.0 * booked_hours / available_hours) if available_hours > 0 else 0.0
+
+    # Busiest day (local date in resource's tz) by booked minutes
+    by_day: Counter[date] = Counter()
+    for s, e in booked_in_avail:
+        # Split at local-midnight boundaries
+        cur = s
+        while cur < e:
+            local = cur.astimezone(zone)
+            next_day_local = datetime.combine(
+                local.date() + timedelta(days=1),
+                local.time().replace(hour=0, minute=0, second=0, microsecond=0),
+                tzinfo=zone,
+            ).replace(hour=0, minute=0, second=0, microsecond=0)
+            next_day_utc = next_day_local.astimezone(ZoneInfo("UTC"))
+            seg_end = min(e, next_day_utc)
+            by_day[local.date()] += int((seg_end - cur).total_seconds())
+            cur = seg_end
+    busiest_day = max(by_day, key=lambda d: by_day[d]) if by_day else None
+
+    by_priority: dict[str, int] = {"high": 0, "medium": 0, "low": 0}
+    for b in bookings:
+        if b.end_utc <= from_utc or b.start_utc >= to_utc:
+            continue
+        by_priority[_priority_bucket(b.priority)] += 1
+
+    return UtilizationReport(
+        resource=resource.name,
+        from_utc=from_utc,
+        to_utc=to_utc,
+        available_hours=round(available_hours, 2),
+        booked_hours=round(booked_hours, 2),
+        utilization_pct=round(utilization_pct, 2),
+        busiest_day=busiest_day,
+        conflicts_encountered=conflicts_encountered,
+        by_priority=by_priority,
+    )
+
+
+def format_report(report: UtilizationReport, tz: str) -> str:
+    zone = ZoneInfo(tz)
+    lines = [
+        f"Utilization report: {report.resource}",
+        f"  Range: {report.from_utc.astimezone(zone):%Y-%m-%d %H:%M %Z} "
+        f"- {report.to_utc.astimezone(zone):%Y-%m-%d %H:%M %Z}",
+        f"  Available hours : {report.available_hours}",
+        f"  Booked hours    : {report.booked_hours}",
+        f"  Utilization     : {report.utilization_pct}%",
+        f"  Busiest day     : {report.busiest_day.isoformat() if report.busiest_day else '(none)'}",
+        f"  Conflicts seen  : {report.conflicts_encountered}",
+        f"  By priority     : high={report.by_priority['high']} "
+        f"medium={report.by_priority['medium']} low={report.by_priority['low']}",
+    ]
+    return "\n".join(lines)
