@@ -0,0 +1,308 @@
+"""Tests for recurrence expansion: DST correctness, monthly clamping, weekday filtering."""
+
+from __future__ import annotations
+
+from datetime import date, datetime, time, timedelta
+from zoneinfo import ZoneInfo
+
+import pytest
+
+from schedctl.models import AvailabilityWindow, Recurrence, RecurrenceRule, Weekday
+from schedctl.recurrence import (
+    _add_months,
+    _add_years,
+    expand_all,
+    expand_window,
+    is_contained_in_availability,
+    iter_occurrence_dates,
+)
+
+
+UTC = ZoneInfo("UTC")
+
+
+class TestDateMath:
+    def test_add_months_basic(self):
+        assert _add_months(date(2025, 1, 15), 1) == date(2025, 2, 15)
+
+    def test_add_months_day_31_to_feb_non_leap(self):
+        assert _add_months(date(2025, 1, 31), 1) == date(2025, 2, 28)
+
+    def test_add_months_day_31_to_feb_leap(self):
+        assert _add_months(date(2024, 1, 31), 1) == date(2024, 2, 29)
+
+    def test_add_months_day_31_to_apr(self):
+        assert _add_months(date(2025, 3, 31), 1) == date(2025, 4, 30)
