+"""Recurring availability expansion.
+
+DST-correct: recurrence operates on naive local dates in the resource's
+timezone, then each expanded occurrence is converted to UTC via zoneinfo.
+Adding a fixed 24-hour timedelta across a DST boundary would shift the
+local wall-clock time by an hour — that is the classic bug this module
+explicitly avoids.
+"""
+
+from __future__ import annotations
+
+import calendar
+from datetime import date, datetime, time, timedelta
+from typing import Iterator
+from zoneinfo import ZoneInfo
+
+from schedctl.models import (
+    AvailabilityWindow,
+    Recurrence,
+    RecurrenceRule,
+    ValidationError,
+    Weekday,
+)
+
+
+# ---------------------------------------------------------------------------
+# Date math — all DST-independent (operates on naive dates)
+# ---------------------------------------------------------------------------
+
+def _add_months(d: date, months: int) -> date:
+    """Add *months* to *d*, clamping the day to the last day of the target
+    month when the source day doesn't exist there (e.g., Jan 31 + 1 month
+    → Feb 28/29)."""
+    year = d.year + (d.month - 1 + months) // 12
+    month = (d.month - 1 + months) % 12 + 1
+    last_day = calendar.monthrange(year, month)[1]
+    day = min(d.day, last_day)
+    return date(year, month, day)
+
+
+def _add_years(d: date, years: int) -> date:
+    """Add *years* to *d*, clamping Feb 29 → Feb 28 in non-leap target years."""
+    target_year = d.year + years
+    last_day = calendar.monthrange(target_year, d.month)[1]
+    return date(target_year, d.month, min(d.day, last_day))
+
+
+# ---------------------------------------------------------------------------
+# Occurrence date iteration (naive dates, no timezone math)
+# ---------------------------------------------------------------------------
+
+def iter_occurrence_dates(
+    window: AvailabilityWindow,
+    range_start: date,
+    range_end: date,
+) -> Iterator[date]:
+    """Yield every date in [range_start, range_end] (inclusive) on which
+    the availability window begins, honouring recurrence rules and exceptions.
+
+    All dates are naive — timezone handling happens when we combine the date
+    with the window's local time and convert to UTC.
+    """
+    rule = window.recurrence
+    start = window.start_date
+
+    # Hard cap: never emit dates past the recurrence's `until` or before
+    # the window's own start_date.
+    effective_end = range_end
+    if rule.until is not None and rule.until < effective_end:
+        effective_end = rule.until
+
+    if start > effective_end:
+        return
+
+    exceptions = set(rule.exceptions)
+
+    if rule.kind == Recurrence.NONE:
+        if start < range_start or start > effective_end or start in exceptions:
+            return
+        yield start
+        return
+
+    interval = max(1, rule.interval)
+
+    if rule.kind == Recurrence.DAILY:
+        cur = start
+        while cur <= effective_end:
+            if cur >= range_start and cur not in exceptions:
+                yield cur
+            cur = cur + timedelta(days=interval)
+
+    elif rule.kind == Recurrence.WEEKLY:
+        # If weekdays is specified, emit only on those weekdays within each
+        # interval-aligned week. If not specified, emit on start.weekday()
+        # every `interval` weeks.
+        allowed_weekdays = {w.to_int() for w in rule.weekdays}
+        if not allowed_weekdays:
+            allowed_weekdays = {start.weekday()}
+
+        # Align to the Monday of start's week to have a consistent anchor
+        # for "every N weeks" calculations.
+        anchor_monday = start - timedelta(days=start.weekday())
+        cur_monday = anchor_monday
+        while cur_monday <= effective_end:
+            for wd in range(7):
+                d = cur_monday + timedelta(days=wd)
+                if d < start or d > effective_end or d < range_start:
+                    continue
+                if wd not in allowed_weekdays:
+                    continue
+                if d in exceptions:
+                    continue
+                yield d
+            cur_monday = cur_monday + timedelta(weeks=interval)
+
+    elif rule.kind == Recurrence.MONTHLY:
+        cur = start
+        n = 0
+        while cur <= effective_end:
+            if cur >= range_start and cur not in exceptions:
+                yield cur
+            n += 1
+            cur = _add_months(start, n * interval)
+
+    elif rule.kind == Recurrence.YEARLY:
+        cur = start
+        n = 0
+        while cur <= effective_end:
+            if cur >= range_start and cur not in exceptions:
+                yield cur
+            n += 1
+            cur = _add_years(start, n * interval)
+
+    else:
+        raise ValidationError(f"Unknown recurrence kind: {rule.kind}")
+
+
+# ---------------------------------------------------------------------------
+# Window expansion — produces (start_utc, end_utc) pairs
+# ---------------------------------------------------------------------------
+
+def expand_window(
+    window: AvailabilityWindow,
+    tz: str,
+    range_start_utc: datetime,
+    range_end_utc: datetime,
+) -> Iterator[tuple[datetime, datetime]]:
+    """Expand *window* into concrete (start_utc, end_utc) pairs that
+    intersect [range_start_utc, range_end_utc].
+
+    DST-correct: we build each occurrence by combining the occurrence date
+    (naive, in the resource's local timezone) with the window's fixed
+    local start/end time, then convert to UTC. The local wall-clock time
+    stays constant across DST transitions.
+    """
+    zone = ZoneInfo(tz)
+
+    # Convert the UTC range bounds into the resource's local timezone to
+    # determine which local dates we need to consider. We widen by one day
+    # on either side to catch cross-midnight windows.
+    local_start = range_start_utc.astimezone(zone).date() - timedelta(days=1)
+    local_end = range_end_utc.astimezone(zone).date() + timedelta(days=1)
+
+    for occ_date in iter_occurrence_dates(window, local_start, local_end):
+        # Combine the date with the window's local times. If end_time <= start_time,
+        # the window spans midnight and ends on the following date.
+        start_local = datetime.combine(occ_date, window.start_time, tzinfo=zone)
+        if window.end_time > window.start_time:
+            end_local = datetime.combine(occ_date, window.end_time, tzinfo=zone)
+        else:
+            end_local = datetime.combine(occ_date + timedelta(days=1), window.end_time, tzinfo=zone)
+
+        start_utc = start_local.astimezone(ZoneInfo("UTC"))
+        end_utc = end_local.astimezone(ZoneInfo("UTC"))
+
+        # Intersection test with the requested range
+        if end_utc <= range_start_utc or start_utc >= range_end_utc:
+            continue
+        yield start_utc, end_utc
+
+
+def is_contained_in_availability(
+    windows: list[AvailabilityWindow],
+    tz: str,
+    booking_start_utc: datetime,
+    booking_end_utc: datetime,
+) -> bool:
+    """Return True iff the booking's time slot lies entirely within at least
+    one expanded availability window."""
+    # Expand with a small buffer around the booking range
+    search_start = booking_start_utc - timedelta(days=2)
+    search_end = booking_end_utc + timedelta(days=2)
+
+    for window in windows:
+        for win_start, win_end in expand_window(window, tz, search_start, search_end):
+            if win_start <= booking_start_utc and win_end >= booking_end_utc:
+                return True
+    return False
+
+
+def expand_all(
+    windows: list[AvailabilityWindow],
+    tz: str,
+    range_start_utc: datetime,
+    range_end_utc: datetime,
+) -> list[tuple[datetime, datetime]]:
+    """Expand and merge all availability windows in the range. Returns a
+    sorted, non-overlapping list of (start_utc, end_utc) pairs."""
+    raw: list[tuple[datetime, datetime]] = []
+    for window in windows:
+        raw.extend(expand_window(window, tz, range_start_utc, range_end_utc))
+    if not raw:
+        return []
+    raw.sort()
+    merged: list[tuple[datetime, datetime]] = [raw[0]]
+    for s, e in raw[1:]:
+        ls, le = merged[-1]
+        if s <= le:
+            merged[-1] = (ls, max(le, e))
+        else:
+            merged.append((s, e))
+    # Clip to the requested range
+    clipped: list[tuple[datetime, datetime]] = []
+    for s, e in merged:
+        s2 = max(s, range_start_utc)
+        e2 = min(e, range_end_utc)
+        if s2 < e2:
+            clipped.append((s2, e2))
+    return clipped
