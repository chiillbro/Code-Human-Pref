+
+class TestSplitStrategy:
+    def test_split_around_middle_conflict(self):
+        res = make_resource()
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        existing = [mk_booking(10, 11)]  # 10:00-11:00
+        s = datetime(2025, 3, 15, 9, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 12, tzinfo=UTC)
+        new, disp = create_booking(
+            res, existing, "Split", s, e, "bob",
+            force=True, strategy="split", now_utc=now,
+        )
+        assert len(new) == 2
+        # First segment 9:00-10:00, second 11:00-12:00
+        assert new[0].start_utc == datetime(2025, 3, 15, 9, tzinfo=UTC)
+        assert new[0].end_utc == datetime(2025, 3, 15, 10, tzinfo=UTC)
+        assert new[1].start_utc == datetime(2025, 3, 15, 11, tzinfo=UTC)
+        assert new[1].end_utc == datetime(2025, 3, 15, 12, tzinfo=UTC)
+
+    def test_split_discards_segments_shorter_than_15min(self):
+        res = make_resource()
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        # Conflict 10:05 - 11:55 — segments are 5min and 5min
+        existing = [Booking(
+            id="b1", resource="room-A", title="exist",
+            start_utc=datetime(2025, 3, 15, 10, 5, tzinfo=UTC),
+            end_utc=datetime(2025, 3, 15, 11, 55, tzinfo=UTC),
+            priority=5, booker="alice",
+        )]
+        s = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 12, tzinfo=UTC)
+        with pytest.raises(ConflictError, match="15 minutes"):
+            create_booking(
+                res, existing, "S", s, e, "bob",
+                force=True, strategy="split", now_utc=now,
+            )
+
+    def test_split_total_overlap_rejected(self):
+        res = make_resource()
+        now = datetime(2025, 3, 1, tzinfo=UTC)
+        existing = [mk_booking(9, 13)]  # fully contains new
+        s = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 12, tzinfo=UTC)
+        with pytest.raises(ConflictError):
+            create_booking(
+                res, existing, "S", s, e, "bob",
+                force=True, strategy="split", now_utc=now,
+            )
+
+
+class TestNearestSlots:
+    def test_before_and_after_suggested(self):
+        res = make_resource()
+        existing = [mk_booking(10, 12)]
+        s = datetime(2025, 3, 15, 10, tzinfo=UTC)
+        e = datetime(2025, 3, 15, 12, tzinfo=UTC)
+        before, after = suggest_nearest_slots(res, existing, s, e)
+        assert before is not None
+        assert after is not None
+        # Before ends at s (at latest) — here before end <= 10:00
+        assert before[1] <= s
+        # After starts at or after e
+        assert after[0] >= e
