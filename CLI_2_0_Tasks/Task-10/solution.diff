@@ -0,0 +1,273 @@
+"""Core scheduling logic: booking validation, conflict detection, resolution."""
+
+from __future__ import annotations
+
+import uuid
+from datetime import datetime, timedelta, timezone
+from typing import Iterable
+
+from schedctl.models import (
+    AvailabilityWindow,
+    Booking,
+    ConflictError,
+    Resource,
+    ResourceNotFoundError,
+    ValidationError,
+    WaitlistEntry,
+    has_higher_priority,
+)
+from schedctl.recurrence import expand_all, is_contained_in_availability
+
+
+MIN_SEGMENT = timedelta(minutes=15)
+
+
+def new_booking_id() -> str:
+    return uuid.uuid4().hex[:12]
+
+
+# ---------------------------------------------------------------------------
+# Overlap detection
+# ---------------------------------------------------------------------------
+
+def overlaps(a_start: datetime, a_end: datetime, b_start: datetime, b_end: datetime) -> bool:
+    """Return True iff [a_start, a_end) and [b_start, b_end) overlap.
+
+    Touching boundaries (a_end == b_start) do NOT overlap.
+    """
+    return a_start < b_end and b_start < a_end
+
+
+def find_conflicts(
+    start_utc: datetime,
+    end_utc: datetime,
+    bookings: Iterable[Booking],
+) -> list[Booking]:
+    return [b for b in bookings if overlaps(start_utc, end_utc, b.start_utc, b.end_utc)]
+
+
+# ---------------------------------------------------------------------------
+# Booking validation
+# ---------------------------------------------------------------------------
+
+def validate_booking_request(
+    resource: Resource,
+    start_utc: datetime,
+    end_utc: datetime,
+    priority: int,
+    now_utc: datetime | None = None,
+) -> None:
+    """Raise ValidationError for: zero-duration, past bookings, outside
+    availability, invalid priority."""
+    if now_utc is None:
+        now_utc = datetime.now(tz=timezone.utc)
+
+    if start_utc.tzinfo is None or end_utc.tzinfo is None:
+        raise ValidationError("Booking datetimes must be timezone-aware")
+
+    if end_utc <= start_utc:
+        raise ValidationError("Booking must have positive duration (end > start)")
+
+    if start_utc < now_utc:
+        raise ValidationError("Booking start is in the past")
+
+    if not (1 <= priority <= 10):
+        raise ValidationError(f"Priority must be 1-10 (got {priority})")
+
+    if not is_contained_in_availability(
+        resource.availability, resource.tz, start_utc, end_utc
+    ):
+        raise ValidationError(
+            f"Booking time {start_utc.isoformat()} - {end_utc.isoformat()} "
+            f"is outside resource '{resource.name}' availability"
+        )
+
+
+# ---------------------------------------------------------------------------
+# Nearest available slot
+# ---------------------------------------------------------------------------
+
+def suggest_nearest_slots(
+    resource: Resource,
+    existing_bookings: list[Booking],
+    requested_start: datetime,
+    requested_end: datetime,
+    search_days: int = 7,
+) -> tuple[tuple[datetime, datetime] | None, tuple[datetime, datetime] | None]:
+    """Return (before, after) — the nearest free slot of at least the
+    requested duration before and after the requested time, within the
+    next `search_days` days of availability."""
+    duration = requested_end - requested_start
+    search_start = requested_start - timedelta(days=search_days)
+    search_end = requested_end + timedelta(days=search_days)
+
+    # Free intervals = availability minus existing bookings
+    avail = expand_all(resource.availability, resource.tz, search_start, search_end)
+    free = _subtract_bookings(avail, existing_bookings)
+
+    before: tuple[datetime, datetime] | None = None
+    after: tuple[datetime, datetime] | None = None
+
+    for s, e in free:
+        if (e - s) < duration:
+            continue
+        if e <= requested_start:
+            # Entirely before — prefer the LATEST such slot, anchored to its end
+            slot = (e - duration, e)
+            before = slot
+        elif s >= requested_end:
+            # Entirely after — prefer the EARLIEST such slot, anchored to its start
+            if after is None:
+                after = (s, s + duration)
+        # Overlapping free intervals that don't fully fit are ignored here;
+        # the conflict check will have already said "unavailable".
+    return before, after
+
+
+def _subtract_bookings(
+    avail: list[tuple[datetime, datetime]],
+    bookings: list[Booking],
+) -> list[tuple[datetime, datetime]]:
+    """Subtract booking intervals from the availability intervals."""
+    # Sort bookings
+    busy = sorted([(b.start_utc, b.end_utc) for b in bookings])
+    result: list[tuple[datetime, datetime]] = []
+    for s, e in avail:
+        segments = [(s, e)]
+        for bs, be in busy:
+            new_segs: list[tuple[datetime, datetime]] = []
+            for ss, se in segments:
+                if be <= ss or bs >= se:
+                    new_segs.append((ss, se))
+                    continue
+                # Overlap
+                if bs > ss:
+                    new_segs.append((ss, bs))
+                if be < se:
+                    new_segs.append((be, se))
+            segments = new_segs
+            if not segments:
+                break
+        result.extend(segments)
+    return [(s, e) for s, e in result if s < e]
+
+
+# ---------------------------------------------------------------------------
+# Booking creation with conflict resolution
+# ---------------------------------------------------------------------------
+
+def create_booking(
+    resource: Resource,
+    existing_bookings: list[Booking],
+    title: str,
+    start_utc: datetime,
+    end_utc: datetime,
+    booker: str,
+    priority: int = 5,
+    force: bool = False,
+    strategy: str | None = None,
+    now_utc: datetime | None = None,
+) -> tuple[list[Booking], list[Booking]]:
+    """Attempt to create a booking on *resource*.
+
+    Returns ``(new_bookings, displaced_bookings)``:
+    - ``new_bookings`` — one or more bookings to add (split strategy can
+      produce several).
+    - ``displaced_bookings`` — existing bookings that must be removed from
+      active bookings and pushed onto the waitlist (priority strategy).
+
+    Raises :class:`ConflictError` if the request cannot be satisfied.
+    """
+    validate_booking_request(resource, start_utc, end_utc, priority, now_utc=now_utc)
+
+    conflicts = find_conflicts(start_utc, end_utc, existing_bookings)
+
+    if not conflicts:
+        b = Booking(
+            id=new_booking_id(),
+            resource=resource.name,
+            title=title,
+            start_utc=start_utc,
+            end_utc=end_utc,
+            priority=priority,
+            booker=booker,
+        )
+        return [b], []
+
+    if not force:
+        raise ConflictError(
+            f"Booking conflicts with {len(conflicts)} existing booking(s)",
+            conflicts=conflicts,
+        )
+
+    if strategy == "priority":
+        # New booking must be strictly higher priority than ALL conflicts
+        for c in conflicts:
+            if not has_higher_priority(priority, c.priority):
+                raise ConflictError(
+                    f"Cannot displace booking '{c.title}' (priority {c.priority}) "
+                    f"with priority {priority}",
+                    conflicts=conflicts,
+                )
+        b = Booking(
+            id=new_booking_id(),
+            resource=resource.name,
+            title=title,
+            start_utc=start_utc,
+            end_utc=end_utc,
+            priority=priority,
+            booker=booker,
+        )
+        return [b], conflicts
+
+    if strategy == "split":
+        segments = _split_around_conflicts(start_utc, end_utc, conflicts)
+        segments = [(s, e) for s, e in segments if (e - s) >= MIN_SEGMENT]
+        if not segments:
+            raise ConflictError(
+                "Split produced no usable segments (all shorter than 15 minutes)",
+                conflicts=conflicts,
+            )
+        # Each split segment must still lie within availability
+        new: list[Booking] = []
+        for s, e in segments:
+            if not is_contained_in_availability(resource.availability, resource.tz, s, e):
+                raise ConflictError(
+                    "Split segment falls outside availability",
+                    conflicts=conflicts,
+                )
+            new.append(Booking(
+                id=new_booking_id(),
+                resource=resource.name,
+                title=title,
+                start_utc=s,
+                end_utc=e,
+                priority=priority,
+                booker=booker,
+            ))
+        return new, []
+
+    raise ValidationError(f"Unknown conflict resolution strategy: {strategy!r}")
+
+
+def _split_around_conflicts(
+    start_utc: datetime,
+    end_utc: datetime,
+    conflicts: list[Booking],
+) -> list[tuple[datetime, datetime]]:
+    """Return the portions of [start_utc, end_utc) that don't overlap any
+    conflict. Conflicts may be outside the requested range; we clip."""
+    segments: list[tuple[datetime, datetime]] = [(start_utc, end_utc)]
+    sorted_conflicts = sorted(conflicts, key=lambda b: b.start_utc)
+    for c in sorted_conflicts:
+        new_segs: list[tuple[datetime, datetime]] = []
+        for s, e in segments:
+            if c.end_utc <= s or c.start_utc >= e:
+                new_segs.append((s, e))
+                continue
+            if c.start_utc > s:
+                new_segs.append((s, c.start_utc))
+            if c.end_utc < e:
+                new_segs.append((c.end_utc, e))
+        segments = new_segs
+    return segments
