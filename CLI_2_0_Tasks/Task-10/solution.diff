+        s = datetime(2025, 3, 12, 16, 0, tzinfo=UTC)
+        e = datetime(2025, 3, 12, 18, 0, tzinfo=UTC)
+        assert not is_contained_in_availability([w], tz, s, e)
+
+    def test_booking_dst_aware(self):
+        """Booking at 09:00 local in New York stays valid across DST."""
+        w = AvailabilityWindow(
+            start_date=date(2025, 3, 8),
+            start_time=time(9, 0),
+            end_time=time(17, 0),
+            recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+        )
+        tz = "America/New_York"
+        # Pre-DST, Mar 8 at 09:00 EST = 14:00 UTC
+        s1 = datetime(2025, 3, 8, 14, 0, tzinfo=UTC)
+        e1 = datetime(2025, 3, 8, 15, 0, tzinfo=UTC)
+        assert is_contained_in_availability([w], tz, s1, e1)
+        # Post-DST, Mar 12 at 09:00 EDT = 13:00 UTC
+        s2 = datetime(2025, 3, 12, 13, 0, tzinfo=UTC)
+        e2 = datetime(2025, 3, 12, 14, 0, tzinfo=UTC)
+        assert is_contained_in_availability([w], tz, s2, e2)
