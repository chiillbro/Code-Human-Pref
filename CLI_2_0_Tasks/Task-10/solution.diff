+            recurrence=RecurrenceRule(kind=Recurrence.MONTHLY),
+        )
+        dates = list(iter_occurrence_dates(w, date(2025, 1, 1), date(2025, 6, 30)))
+        assert dates == [
+            date(2025, 1, 31),
