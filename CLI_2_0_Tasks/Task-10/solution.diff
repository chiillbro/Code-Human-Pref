+class TestExpandWindowDST:
+    """Critical: wall-clock local time must stay fixed across DST transitions."""
+
+    def test_daily_across_spring_forward(self):
+        """US spring forward 2025: Sun Mar 9. Before: EST (UTC-5). After: EDT (UTC-4)."""
+        # A window from 09:00-17:00 daily in America/New_York.
+        w = AvailabilityWindow(
+            start_date=date(2025, 3, 8),
+            start_time=time(9, 0),
+            end_time=time(17, 0),
+            recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+        )
+        tz = "America/New_York"
+        # Query a range spanning the DST transition
+        range_start = datetime(2025, 3, 8, 0, 0, tzinfo=UTC)
+        range_end = datetime(2025, 3, 11, 0, 0, tzinfo=UTC)
+
+        occs = list(expand_window(w, tz, range_start, range_end))
+        # Should be 3 occurrences: Mar 8, 9, 10
+        assert len(occs) == 3
+
+        # On Mar 8 (pre-DST, EST), 09:00 local = 14:00 UTC
+        s0, e0 = occs[0]
+        assert s0.astimezone(ZoneInfo(tz)).time() == time(9, 0)
+        assert e0.astimezone(ZoneInfo(tz)).time() == time(17, 0)
+        assert s0 == datetime(2025, 3, 8, 14, 0, tzinfo=UTC)
+
+        # On Mar 10 (post-DST, EDT), 09:00 local = 13:00 UTC
+        s2, e2 = occs[2]
+        assert s2.astimezone(ZoneInfo(tz)).time() == time(9, 0)
+        assert e2.astimezone(ZoneInfo(tz)).time() == time(17, 0)
+        assert s2 == datetime(2025, 3, 10, 13, 0, tzinfo=UTC)
+
+    def test_window_spanning_midnight(self):
+        """22:00-06:00 window covers 22:00 on day N through 06:00 on day N+1."""
+        w = AvailabilityWindow(
+            start_date=date(2025, 3, 10),
+            start_time=time(22, 0),
+            end_time=time(6, 0),
+        )
+        tz = "UTC"
+        range_start = datetime(2025, 3, 10, 0, 0, tzinfo=UTC)
+        range_end = datetime(2025, 3, 12, 0, 0, tzinfo=UTC)
+        occs = list(expand_window(w, tz, range_start, range_end))
+        assert len(occs) == 1
+        s, e = occs[0]
+        assert s == datetime(2025, 3, 10, 22, 0, tzinfo=UTC)
+        assert e == datetime(2025, 3, 11, 6, 0, tzinfo=UTC)
+
