+"""Tests for waitlist management: priority ordering and cascading promotion."""
+
+from __future__ import annotations
+
+from datetime import date, datetime, time, timedelta, timezone
+
+import pytest
+
+from schedctl.models import (
+    AvailabilityWindow,
+    Booking,
+    Recurrence,
+    RecurrenceRule,
+    WaitlistEntry,
+)
+from schedctl.waitlist import promote_from_waitlist, sort_waitlist
+
+
+UTC = timezone.utc
+
+AVAIL = [AvailabilityWindow(
+    start_date=date(2025, 3, 1),
+    start_time=time(0, 0),
+    end_time=time(23, 59, 59),
+    recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+)]
+
+
+def mk_entry(id_: str, start_h: int, end_h: int, priority: int, created_minute: int = 0) -> WaitlistEntry:
+    return WaitlistEntry(
+        id=id_,
+        resource="room-A",
+        title=f"entry-{id_}",
+        start_utc=datetime(2025, 3, 15, start_h, 0, tzinfo=UTC),
+        end_utc=datetime(2025, 3, 15, end_h, 0, tzinfo=UTC),
+        priority=priority,
+        booker="bob",
+        created_at=datetime(2025, 3, 1, 0, created_minute, tzinfo=UTC),
+    )
+
+
+class TestSortWaitlist:
+    def test_priority_first(self):
+        entries = [
+            mk_entry("a", 10, 11, priority=5),
+            mk_entry("b", 10, 11, priority=1),
+            mk_entry("c", 10, 11, priority=3),
+        ]
+        sorted_ = sort_waitlist(entries)
+        assert [e.id for e in sorted_] == ["b", "c", "a"]
+
+    def test_created_at_tiebreaker(self):
+        entries = [
+            mk_entry("a", 10, 11, priority=5, created_minute=5),
+            mk_entry("b", 10, 11, priority=5, created_minute=1),
+            mk_entry("c", 10, 11, priority=5, created_minute=3),
+        ]
+        sorted_ = sort_waitlist(entries)
+        assert [e.id for e in sorted_] == ["b", "c", "a"]
+
+
+class TestPromotion:
+    def test_basic_promotion(self):
+        # Empty schedule, one waitlist entry that fits
+        wl = [mk_entry("a", 10, 11, priority=5)]
+        promoted, removed, remaining = promote_from_waitlist(wl, [], AVAIL, "UTC")
+        assert len(promoted) == 1
+        assert promoted[0].id == "a"
+        assert remaining == []
+
+    def test_priority_ordering_in_promotion(self):
+        # Two entries both fit — higher priority (lower number) wins
+        wl = [
+            mk_entry("low", 10, 11, priority=8),
+            mk_entry("high", 10, 11, priority=2),
+        ]
+        promoted, removed, remaining = promote_from_waitlist(wl, [], AVAIL, "UTC")
+        # Only "high" can promote because it conflicts with "low"
+        assert len(promoted) == 1
+        assert promoted[0].id == "high"
+        assert len(remaining) == 1
+        assert remaining[0].id == "low"
+
+    def test_waitlist_entry_too_large_not_promoted(self):
+        """A waitlisted entry that overlaps an existing active booking is not promoted."""
+        active = [Booking(
+            id="active1", resource="room-A", title="act",
+            start_utc=datetime(2025, 3, 15, 10, 30, tzinfo=UTC),
+            end_utc=datetime(2025, 3, 15, 11, 30, tzinfo=UTC),
+            priority=5, booker="x",
+        )]
+        wl = [mk_entry("big", 10, 12, priority=1)]  # overlaps active
+        promoted, removed, remaining = promote_from_waitlist(wl, active, AVAIL, "UTC")
+        assert promoted == []
+        assert len(remaining) == 1
+
+    def test_cascading_promotion(self):
+        """Cancel freed 10:00-12:00; waitlist has a 10:00-11:00 entry, then
+        after promotion, another 11:00-12:00 entry can slot in."""
+        wl = [
+            mk_entry("small1", 10, 11, priority=3, created_minute=1),
+            mk_entry("small2", 11, 12, priority=5, created_minute=2),
+            # Large entry that can't fit
+            mk_entry("big", 9, 13, priority=2, created_minute=3),
+        ]
+        # Active: busy 9:00-10:00 and 12:00-13:00 — free slot is 10:00-12:00
+        active = [
+            Booking(id="a", resource="room-A", title="a",
+                    start_utc=datetime(2025, 3, 15, 9, tzinfo=UTC),
+                    end_utc=datetime(2025, 3, 15, 10, tzinfo=UTC),
+                    priority=5, booker="x"),
+            Booking(id="b", resource="room-A", title="b",
+                    start_utc=datetime(2025, 3, 15, 12, tzinfo=UTC),
+                    end_utc=datetime(2025, 3, 15, 13, tzinfo=UTC),
+                    priority=5, booker="x"),
+        ]
+        promoted, removed, remaining = promote_from_waitlist(wl, active, AVAIL, "UTC")
+        promoted_ids = {p.id for p in promoted}
+        assert "small1" in promoted_ids
+        assert "small2" in promoted_ids
+        # "big" can't fit
+        assert "big" not in promoted_ids
+        assert len(remaining) == 1
+        assert remaining[0].id == "big"
+
+    def test_promotion_respects_availability(self):
+        """If a waitlist entry is outside availability, it can't be promoted."""
+        limited_avail = [AvailabilityWindow(
+            start_date=date(2025, 3, 1),
+            start_time=time(9, 0),
+            end_time=time(17, 0),
+            recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+        )]
+        wl = [mk_entry("after_hours", 18, 19, priority=1)]
+        promoted, removed, remaining = promote_from_waitlist(wl, [], limited_avail, "UTC")
+        assert promoted == []
+        assert len(remaining) == 1
