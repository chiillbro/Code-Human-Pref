index 0000000..0cd63f2
--- /dev/null
+++ b/src/schedctl/cli.py
@@ -0,0 +1,498 @@
+"""Command-line interface for schedctl."""
+
+from __future__ import annotations
+
+import argparse
+import re
+import sys
+from datetime import date, datetime, time, timezone
+from zoneinfo import ZoneInfo, ZoneInfoNotFoundError
+
+import schedctl
+from schedctl.models import (
+    AvailabilityWindow,
+    ConflictError,
+    Recurrence,
+    RecurrenceRule,
+    Resource,
+    ResourceNotFoundError,
+    SchedctlError,
+    StorageError,
+    ValidationError,
+    WaitlistEntry,
+    Weekday,
+)
+from schedctl.recurrence import expand_all
+from schedctl.reporter import compute_report, format_report
+from schedctl.scheduler import create_booking, suggest_nearest_slots, find_conflicts
+from schedctl.storage import DEFAULT_DB, Database
+from schedctl.waitlist import promote_from_waitlist
+
+
+NAME_RE = re.compile(r"^[A-Za-z0-9_-]+$")
+
+EXIT_OK = 0
+EXIT_VALIDATION = 1
+EXIT_CONFLICT = 2
+EXIT_NOT_FOUND = 3
+EXIT_IO = 4
+
+
+# ---------------------------------------------------------------------------
+# Datetime parsing
+# ---------------------------------------------------------------------------
+
+def parse_datetime(s: str, default_tz: str | None = None) -> datetime:
+    """Parse ISO 8601 datetime. If no tz offset present, apply *default_tz*."""
+    s = s.strip()
+    # Accept trailing Z
+    if s.endswith("Z"):
+        s = s[:-1] + "+00:00"
+    try:
+        dt = datetime.fromisoformat(s)
+    except ValueError as e:
+        raise ValidationError(f"Invalid datetime '{s}': {e}") from e
+    if dt.tzinfo is None:
+        if default_tz is None:
+            raise ValidationError(f"Datetime '{s}' has no timezone and no default was provided")
+        dt = dt.replace(tzinfo=ZoneInfo(default_tz))
+    return dt.astimezone(timezone.utc)
+
+
+def parse_time(s: str) -> time:
+    try:
+        return time.fromisoformat(s)
+    except ValueError as e:
+        raise ValidationError(f"Invalid time '{s}': {e}") from e
+
+
+def parse_date(s: str) -> date:
+    try:
+        return date.fromisoformat(s)
+    except ValueError as e:
+        raise ValidationError(f"Invalid date '{s}': {e}") from e
+
+
+# ---------------------------------------------------------------------------
+# Commands
+# ---------------------------------------------------------------------------
+
+def _cmd_init(args: argparse.Namespace) -> int:
+    try:
+        Database.init(args.db)
+    except StorageError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_IO
+    print(f"Initialized database: {args.db}")
+    return EXIT_OK
+
+
+def _cmd_resource_add(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    if not NAME_RE.match(args.name):
+        print(f"error: invalid resource name '{args.name}' "
+              f"(alphanumeric/_/- only)", file=sys.stderr)
+        return EXIT_VALIDATION
+    try:
+        ZoneInfo(args.tz)
+    except ZoneInfoNotFoundError:
+        print(f"error: unknown timezone '{args.tz}'", file=sys.stderr)
+        return EXIT_VALIDATION
+    try:
+        db.add_resource(Resource(
+            name=args.name,
+            tz=args.tz,
+            description=args.description or "",
+        ))
+    except ValidationError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_VALIDATION
+    db.save()
+    print(f"Added resource '{args.name}' ({args.tz})")
+    return EXIT_OK
+
+
+def _cmd_resource_list(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    if not db.resources:
+        print("(no resources)")
+        return EXIT_OK
+    width_name = max(len("NAME"), max(len(r.name) for r in db.resources.values()))
+    width_tz = max(len("TIMEZONE"), max(len(r.tz) for r in db.resources.values()))
+    print(f"{'NAME':<{width_name}}  {'TIMEZONE':<{width_tz}}  DESCRIPTION")
+    for r in db.resources.values():
+        print(f"{r.name:<{width_name}}  {r.tz:<{width_tz}}  {r.description}")
+    return EXIT_OK
+
+
+def _cmd_resource_availability(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        res = db.get_resource(args.name)
+    except ResourceNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+
+    try:
+        st = parse_time(args.start)
+        et = parse_time(args.end)
+        kind = Recurrence(args.recurrence)
+    except (ValidationError, ValueError) as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    weekdays: list[Weekday] = []
+    if args.weekdays:
+        if kind != Recurrence.WEEKLY:
+            print(f"error: --weekdays is only valid with --recurrence=weekly",
+                  file=sys.stderr)
+            return EXIT_VALIDATION
+        try:
+            weekdays = [Weekday.from_str(w) for w in args.weekdays.split(",")]
+        except ValueError as e:
+            print(f"error: {e}", file=sys.stderr)
+            return EXIT_VALIDATION
+
+    until: date | None = None
+    if args.until:
+        until = parse_date(args.until)
+
+    exceptions: list[date] = []
+    if args.except_dates:
+        exceptions = [parse_date(x) for x in args.except_dates.split(",")]
+
+    start_date = parse_date(args.start_date) if args.start_date else datetime.now(
+        tz=ZoneInfo(res.tz)
+    ).date()
+
+    rule = RecurrenceRule(
+        kind=kind,
+        interval=args.interval,
+        until=until,
+        exceptions=exceptions,
+        weekdays=weekdays,
+    )
+    res.availability.append(AvailabilityWindow(
+        start_date=start_date,
+        start_time=st,
+        end_time=et,
+        recurrence=rule,
+    ))
+    db.save()
+    print(f"Added availability window to '{res.name}'")
+    return EXIT_OK
+
+
+def _cmd_book(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        res = db.get_resource(args.resource)
+    except ResourceNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+
+    try:
+        start_utc = parse_datetime(args.start, default_tz=res.tz)
+        end_utc = parse_datetime(args.end, default_tz=res.tz)
+    except ValidationError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    existing = db.bookings_for(res.name)
+
+    try:
+        new_bookings, displaced = create_booking(
+            res,
+            existing,
+            title=args.title,
+            start_utc=start_utc,
+            end_utc=end_utc,
+            booker=args.booker,
+            priority=args.priority,
+            force=args.force,
+            strategy=args.strategy,
+        )
+    except ValidationError as e:
+        print(f"error: {e}", file=sys.stderr)
+        # If outside availability, print nearest slots
+        before, after = suggest_nearest_slots(res, existing, start_utc, end_utc)
+        zone = ZoneInfo(res.tz)
+        if before:
+            print(f"  Nearest before: {before[0].astimezone(zone):%Y-%m-%d %H:%M %Z} "
+                  f"- {before[1].astimezone(zone):%H:%M %Z}", file=sys.stderr)
+        if after:
+            print(f"  Nearest after:  {after[0].astimezone(zone):%Y-%m-%d %H:%M %Z} "
+                  f"- {after[1].astimezone(zone):%H:%M %Z}", file=sys.stderr)
+        return EXIT_VALIDATION
+    except ConflictError as e:
+        print(f"conflict: {e}", file=sys.stderr)
+        zone = ZoneInfo(res.tz)
+        for c in e.conflicts:
+            print(f"  - {c.id}: '{c.title}' "
+                  f"({c.start_utc.astimezone(zone):%Y-%m-%d %H:%M %Z} "
+                  f"- {c.end_utc.astimezone(zone):%H:%M %Z}) "
+                  f"priority={c.priority} by {c.booker}", file=sys.stderr)
+        return EXIT_CONFLICT
+
+    # Move displaced bookings to waitlist
+    if displaced:
+        for d in displaced:
+            db.bookings.remove(d)
+            db.waitlist.append(WaitlistEntry.from_booking(d))
+
+    db.bookings.extend(new_bookings)
+    db.save()
+
+    zone = ZoneInfo(res.tz)
+    for b in new_bookings:
+        print(f"Booked {b.id}: '{b.title}' "
+              f"{b.start_utc.astimezone(zone):%Y-%m-%d %H:%M %Z} "
+              f"- {b.end_utc.astimezone(zone):%H:%M %Z}")
+    if displaced:
+        print(f"Displaced {len(displaced)} booking(s) to waitlist")
+    return EXIT_OK
+
+
+def _cmd_cancel(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        b = db.find_booking(args.booking_id)
+    except ValidationError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+    db.bookings.remove(b)
+
+    # Trigger cascading waitlist promotion on this resource
+    res = db.resources.get(b.resource)
+    if res:
+        wl = db.waitlist_for(res.name)
+        active = db.bookings_for(res.name)
+        promoted, removed, _ = promote_from_waitlist(wl, active, res.availability, res.tz)
+        if removed:
+            # Remove from db.waitlist
+            removed_ids = {e.id for e in removed}
+            db.waitlist = [e for e in db.waitlist if e.id not in removed_ids]
+            db.bookings.extend(promoted)
+
+    db.save()
+    print(f"Cancelled booking {b.id}")
+    return EXIT_OK
+
+
+def _cmd_list(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        res = db.get_resource(args.resource)
+    except ResourceNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+
+    bookings = db.bookings_for(res.name)
+    if args.from_dt:
+        f = parse_datetime(args.from_dt, default_tz=res.tz)
+        bookings = [b for b in bookings if b.end_utc > f]
+    if args.to_dt:
+        t = parse_datetime(args.to_dt, default_tz=res.tz)
+        bookings = [b for b in bookings if b.start_utc < t]
+
+    bookings.sort(key=lambda b: b.start_utc)
+    zone = ZoneInfo(res.tz)
+    if not bookings:
+        print("(no bookings)")
+        return EXIT_OK
+    for b in bookings:
+        print(f"{b.id}  {b.start_utc.astimezone(zone):%Y-%m-%d %H:%M %Z} "
+              f"- {b.end_utc.astimezone(zone):%H:%M %Z}  "
+              f"p={b.priority}  '{b.title}'  ({b.booker})")
+    return EXIT_OK
+
+
+def _cmd_waitlist(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        res = db.get_resource(args.resource)
+    except ResourceNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+    from schedctl.waitlist import sort_waitlist
+    entries = sort_waitlist(db.waitlist_for(res.name))
+    if not entries:
+        print("(waitlist is empty)")
+        return EXIT_OK
+    zone = ZoneInfo(res.tz)
+    for e in entries:
+        print(f"{e.id}  p={e.priority}  "
+              f"{e.start_utc.astimezone(zone):%Y-%m-%d %H:%M %Z} "
+              f"- {e.end_utc.astimezone(zone):%H:%M %Z}  "
+              f"'{e.title}'  ({e.booker})")
+    return EXIT_OK
+
+
+def _cmd_check(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        res = db.get_resource(args.resource)
+    except ResourceNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+
+    start_utc = parse_datetime(args.start, default_tz=res.tz)
+    end_utc = parse_datetime(args.end, default_tz=res.tz)
+    existing = db.bookings_for(res.name)
+    conflicts = find_conflicts(start_utc, end_utc, existing)
+    zone = ZoneInfo(res.tz)
+    if not conflicts:
+        print("Available")
+        return EXIT_OK
+    print("Not available. Conflicts:")
+    for c in conflicts:
+        print(f"  - {c.id}: {c.start_utc.astimezone(zone):%Y-%m-%d %H:%M %Z} "
+              f"- {c.end_utc.astimezone(zone):%H:%M %Z} '{c.title}'")
+    before, after = suggest_nearest_slots(res, existing, start_utc, end_utc)
+    if before:
+        print(f"Nearest before: {before[0].astimezone(zone):%Y-%m-%d %H:%M %Z} "
+              f"- {before[1].astimezone(zone):%H:%M %Z}")
+    if after:
+        print(f"Nearest after:  {after[0].astimezone(zone):%Y-%m-%d %H:%M %Z} "
+              f"- {after[1].astimezone(zone):%H:%M %Z}")
+    return EXIT_OK
+
+
+def _cmd_report(args: argparse.Namespace) -> int:
+    db = Database.load(args.db)
+    try:
+        res = db.get_resource(args.resource)
+    except ResourceNotFoundError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_NOT_FOUND
+    from_utc = parse_datetime(args.from_dt, default_tz=res.tz) if args.from_dt else datetime.now(
+        tz=timezone.utc
+    ).replace(microsecond=0)
+    to_utc = parse_datetime(args.to_dt, default_tz=res.tz) if args.to_dt else (
+        from_utc.replace(year=from_utc.year + (1 if from_utc.month == 12 else 0),
+                         month=(from_utc.month % 12) + 1)
+    )
+    rep = compute_report(res, db.bookings_for(res.name), from_utc, to_utc)
+    print(format_report(rep, res.tz))
+    return EXIT_OK
+
+
+def _cmd_version(args: argparse.Namespace) -> int:
+    print(f"schedctl {schedctl.__version__}")
+    return EXIT_OK
+
+
+# ---------------------------------------------------------------------------
+# Parser
+# ---------------------------------------------------------------------------
+
+def build_parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(prog="schedctl")
+    p.add_argument("--db", default=DEFAULT_DB, help="Path to database file")
+    sub = p.add_subparsers(dest="command")
+
+    sp = sub.add_parser("init")
+
+    sp_res = sub.add_parser("resource")
+    sub_res = sp_res.add_subparsers(dest="resource_command")
+
+    sp_ra = sub_res.add_parser("add")
+    sp_ra.add_argument("name")
+    sp_ra.add_argument("--tz", required=True)
+    sp_ra.add_argument("--description", default="")
+
+    sp_rl = sub_res.add_parser("list")
+
+    sp_rav = sub_res.add_parser("availability")
+    sp_rav.add_argument("name")
+    sp_rav.add_argument("--start", required=True, help="Local start time, HH:MM[:SS]")
+    sp_rav.add_argument("--end", required=True, help="Local end time, HH:MM[:SS]")
+    sp_rav.add_argument("--start-date", dest="start_date", help="First applicable date (YYYY-MM-DD)")
+    sp_rav.add_argument(
+        "--recurrence", default="none",
+        choices=[r.value for r in Recurrence],
+    )
+    sp_rav.add_argument("--interval", type=int, default=1)
+    sp_rav.add_argument("--until")
+    sp_rav.add_argument("--except", dest="except_dates", help="Comma-separated dates")
+    sp_rav.add_argument("--weekdays", help="Comma-separated, mon,tue,...")
+
+    sp_bk = sub.add_parser("book")
+    sp_bk.add_argument("resource")
+    sp_bk.add_argument("--title", required=True)
+    sp_bk.add_argument("--start", required=True)
+    sp_bk.add_argument("--end", required=True)
+    sp_bk.add_argument("--booker", required=True)
+    sp_bk.add_argument("--priority", type=int, default=5)
+    sp_bk.add_argument("--force", action="store_true")
+    sp_bk.add_argument("--strategy", choices=["priority", "split"])
+
+    sp_cn = sub.add_parser("cancel")
+    sp_cn.add_argument("booking_id")
+
+    sp_ls = sub.add_parser("list")
+    sp_ls.add_argument("resource")
+    sp_ls.add_argument("--from", dest="from_dt")
+    sp_ls.add_argument("--to", dest="to_dt")
+
+    sp_wl = sub.add_parser("waitlist")
+    sp_wl.add_argument("resource")
+
+    sp_ck = sub.add_parser("check")
+    sp_ck.add_argument("resource")
+    sp_ck.add_argument("--start", required=True)
+    sp_ck.add_argument("--end", required=True)
+
+    sp_rp = sub.add_parser("report")
+    sp_rp.add_argument("resource")
+    sp_rp.add_argument("--from", dest="from_dt")
+    sp_rp.add_argument("--to", dest="to_dt")
+
+    sub.add_parser("version")
+
+    return p
+
+
+COMMAND_DISPATCH = {
+    "init": _cmd_init,
+    "book": _cmd_book,
+    "cancel": _cmd_cancel,
+    "list": _cmd_list,
+    "waitlist": _cmd_waitlist,
+    "check": _cmd_check,
+    "report": _cmd_report,
+    "version": _cmd_version,
+}
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = build_parser()
+    args = parser.parse_args(argv)
+
+    if args.command is None:
+        parser.print_help()
+        return EXIT_VALIDATION
+
+    if args.command == "resource":
+        rc = args.resource_command
+        if rc == "add":
+            return _cmd_resource_add(args)
+        if rc == "list":
+            return _cmd_resource_list(args)
+        if rc == "availability":
+            return _cmd_resource_availability(args)
+        parser.print_help()
+        return EXIT_VALIDATION
+
+    try:
+        return COMMAND_DISPATCH[args.command](args)
+    except StorageError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_IO
+    except SchedctlError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
diff --git a/src/schedctl/models.py b/src/schedctl/models.py
