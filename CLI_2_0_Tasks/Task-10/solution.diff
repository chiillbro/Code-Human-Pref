+        dates = list(iter_occurrence_dates(w, date(2025, 3, 10), date(2025, 4, 10)))
+        assert dates == [date(2025, 3, 10), date(2025, 3, 24), date(2025, 4, 7)]
+
+    def test_monthly_day_31_clamps(self):
+        w = AvailabilityWindow(
+            start_date=date(2025, 1, 31),
+            start_time=time(9, 0),
