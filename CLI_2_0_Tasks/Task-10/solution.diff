+"""Tests for JSON file-based persistence."""
+
+from __future__ import annotations
+
+from datetime import date, datetime, time, timezone
+
+import pytest
+
+from schedctl.models import (
+    AvailabilityWindow,
+    Booking,
+    Recurrence,
+    RecurrenceRule,
+    Resource,
+    ResourceNotFoundError,
+    StorageError,
+    ValidationError,
+    WaitlistEntry,
+)
+from schedctl.storage import Database
+
+
+UTC = timezone.utc
+
+
+def test_init_creates_file(tmp_path):
+    path = tmp_path / "s.json"
+    db = Database.init(path)
+    assert path.exists()
+    assert db.resources == {}
+    assert db.bookings == []
+    assert db.waitlist == []
+
+
+def test_init_fails_if_exists(tmp_path):
+    path = tmp_path / "s.json"
+    Database.init(path)
+    with pytest.raises(StorageError):
+        Database.init(path)
+
+
+def test_load_fails_if_missing(tmp_path):
+    with pytest.raises(StorageError):
+        Database.load(tmp_path / "nope.json")
+
+
+def test_round_trip(tmp_path):
+    path = tmp_path / "s.json"
+    db = Database.init(path)
+    r = Resource(
+        name="room-A",
+        tz="America/New_York",
+        description="Main conf room",
+        availability=[AvailabilityWindow(
+            start_date=date(2025, 1, 1),
+            start_time=time(9, 0),
+            end_time=time(17, 0),
+            recurrence=RecurrenceRule(kind=Recurrence.DAILY),
+        )],
+    )
+    db.add_resource(r)
+    b = Booking(
+        id="abc", resource="room-A", title="mtg",
+        start_utc=datetime(2025, 5, 1, 14, tzinfo=UTC),
+        end_utc=datetime(2025, 5, 1, 15, tzinfo=UTC),
+        priority=3, booker="alice",
+    )
+    db.bookings.append(b)
+    w = WaitlistEntry(
+        id="w1", resource="room-A", title="wmtg",
+        start_utc=datetime(2025, 5, 1, 14, tzinfo=UTC),
+        end_utc=datetime(2025, 5, 1, 15, tzinfo=UTC),
+        priority=5, booker="bob",
+        created_at=datetime(2025, 4, 1, tzinfo=UTC),
+    )
+    db.waitlist.append(w)
+    db.save()
+
+    db2 = Database.load(path)
+    assert "room-A" in db2.resources
+    assert db2.resources["room-A"].tz == "America/New_York"
+    assert len(db2.resources["room-A"].availability) == 1
+    assert len(db2.bookings) == 1
+    assert db2.bookings[0].id == "abc"
+    assert db2.bookings[0].priority == 3
+    assert len(db2.waitlist) == 1
+    assert db2.waitlist[0].id == "w1"
+
+
+def test_add_duplicate_resource_raises(tmp_path):
+    path = tmp_path / "s.json"
+    db = Database.init(path)
+    db.add_resource(Resource(name="r1", tz="UTC"))
+    with pytest.raises(ValidationError):
+        db.add_resource(Resource(name="r1", tz="UTC"))
+
+
+def test_get_resource_not_found(tmp_path):
+    db = Database.init(tmp_path / "s.json")
+    with pytest.raises(ResourceNotFoundError):
+        db.get_resource("nope")
+
+
+def test_find_booking_missing(tmp_path):
+    db = Database.init(tmp_path / "s.json")
+    with pytest.raises(ValidationError):
+        db.find_booking("missing-id")
+
+
+def test_bookings_and_waitlist_for_filter_by_resource(tmp_path):
+    db = Database.init(tmp_path / "s.json")
+    b1 = Booking(id="1", resource="A", title="t1",
+                 start_utc=datetime(2025, 5, 1, tzinfo=UTC),
+                 end_utc=datetime(2025, 5, 1, 1, tzinfo=UTC),
+                 priority=5, booker="x")
+    b2 = Booking(id="2", resource="B", title="t2",
+                 start_utc=datetime(2025, 5, 1, tzinfo=UTC),
+                 end_utc=datetime(2025, 5, 1, 1, tzinfo=UTC),
+                 priority=5, booker="x")
+    db.bookings.extend([b1, b2])
+    assert [b.id for b in db.bookings_for("A")] == ["1"]
+    assert [b.id for b in db.bookings_for("B")] == ["2"]
+
+
+def test_atomic_save_no_tmp_left(tmp_path):
+    path = tmp_path / "s.json"
+    db = Database.init(path)
+    db.save()
+    # No .tmp file should remain after a successful save
+    tmp = path.with_suffix(path.suffix + ".tmp")
+    assert not tmp.exists()
+    assert path.exists()
+
+
+def test_corrupted_json_raises(tmp_path):
+    path = tmp_path / "s.json"
+    path.write_text("{not valid json")
+    with pytest.raises(StorageError):
+        Database.load(path)
