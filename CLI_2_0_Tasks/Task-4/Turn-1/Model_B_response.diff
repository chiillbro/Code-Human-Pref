diff --git a/statistics-service/src/main/java/com/piggymetrics/statistics/service/BudgetEvaluationServiceImpl.java b/statistics-service/src/main/java/com/piggymetrics/statistics/service/BudgetEvaluationServiceImpl.java
new file mode 100644
index 0000000..eaa6a09
--- /dev/null
+++ b/statistics-service/src/main/java/com/piggymetrics/statistics/service/BudgetEvaluationServiceImpl.java
@@ -0,0 +1,119 @@
+package com.piggymetrics.statistics.service;
+
+import com.piggymetrics.statistics.domain.Budget;
+import com.piggymetrics.statistics.domain.BudgetEvaluation;
+import com.piggymetrics.statistics.domain.Currency;
+import com.piggymetrics.statistics.domain.BudgetStatus;
+import com.piggymetrics.statistics.domain.timeseries.DataPoint;
+import com.piggymetrics.statistics.domain.timeseries.ItemMetric;
+import com.piggymetrics.statistics.repository.DataPointRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.math.BigDecimal;
+import java.math.RoundingMode;
+import java.time.LocalDate;
+import java.time.ZoneId;
+import java.util.ArrayList;
+import java.util.Date;
+import java.util.List;
+
+/**
+ * Aggregates daily datapoints into actual spending and compares it
+ * to a caller-supplied {@link Budget}.
+ *
+ * <p><b>Normalization.</b> Each {@link ItemMetric} is already stored
+ * in base currency (USD) on a per-day ratio (see
+ * {@link StatisticsServiceImpl#createItemMetric}). Summing those
+ * per-day amounts over the days present in the current period
+ * therefore yields the total spent in USD for that period. We then
+ * convert to the budget's own currency so the user sees numbers in
+ * the unit they defined the budget in.
+ */
+@Service
+public class BudgetEvaluationServiceImpl implements BudgetEvaluationService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private DataPointRepository repository;
+
+	@Autowired
+	private ExchangeRatesService ratesService;
+
+	@Override
+	public List<BudgetEvaluation> evaluate(String accountName, List<Budget> budgets) {
+		Assert.hasLength(accountName);
+		if (budgets == null || budgets.isEmpty()) {
+			return new ArrayList<>();
+		}
+
+		LocalDate today = LocalDate.now();
+		List<BudgetEvaluation> results = new ArrayList<>(budgets.size());
+
+		for (Budget budget : budgets) {
+			Assert.notNull(budget.getPeriod(), "budget period must not be null");
+			Assert.notNull(budget.getCurrency(), "budget currency must not be null");
+			Assert.notNull(budget.getLimit(), "budget limit must not be null");
+
+			Date periodStart = Date.from(budget.getPeriod().startOfPeriod(today)
+					.atStartOfDay(ZoneId.systemDefault()).toInstant());
+
+			List<DataPoint> points = repository.findByIdAccountAndIdDateGreaterThanEqual(accountName, periodStart);
+
+			BigDecimal actualInBase = sumMatching(points, budget.getCategory());
+			BigDecimal actual = ratesService
+					.convert(Currency.getBase(), budget.getCurrency(), actualInBase)
+					.setScale(2, RoundingMode.HALF_UP);
+
+			results.add(toEvaluation(budget, actual));
+		}
+
+		log.debug("evaluated {} budgets for {}", results.size(), accountName);
+		return results;
+	}
+
+	private BigDecimal sumMatching(List<DataPoint> points, String category) {
+		boolean matchAll = Budget.TOTAL_CATEGORY.equalsIgnoreCase(category);
+		BigDecimal sum = BigDecimal.ZERO;
+		for (DataPoint point : points) {
+			if (point.getExpenses() == null) continue;
+			for (ItemMetric expense : point.getExpenses()) {
+				if (matchAll || category.equalsIgnoreCase(expense.getTitle())) {
+					sum = sum.add(expense.getAmount());
+				}
+			}
+		}
+		return sum;
+	}
+
+	private BudgetEvaluation toEvaluation(Budget budget, BigDecimal actual) {
+		BigDecimal limit = budget.getLimit();
+		double percent = limit.signum() == 0
+				? 0.0
+				: actual.divide(limit, 4, RoundingMode.HALF_UP).doubleValue();
+
+		BudgetStatus status;
+		if (percent >= 1.0) {
+			status = BudgetStatus.EXCEEDED;
+		} else if (percent >= budget.getEffectiveWarningThreshold()) {
+			status = BudgetStatus.WARNING;
+		} else {
+			status = BudgetStatus.UNDER_BUDGET;
+		}
+
+		BudgetEvaluation evaluation = new BudgetEvaluation();
+		evaluation.setBudgetId(budget.getId());
+		evaluation.setCategory(budget.getCategory());
+		evaluation.setPeriod(budget.getPeriod());
+		evaluation.setCurrency(budget.getCurrency());
+		evaluation.setLimit(limit);
+		evaluation.setActual(actual);
+		evaluation.setPercentUsed(percent);
+		evaluation.setStatus(status);
+		return evaluation;
+	}
+}
