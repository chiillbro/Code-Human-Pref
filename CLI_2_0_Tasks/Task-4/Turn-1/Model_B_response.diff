+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.domain.BudgetEvaluation;
+
+import java.util.List;
+
+public interface BudgetService {
+
+	/**
+	 * Creates a new budget for the given account.
+	 * Rejects duplicates of active budgets in the same (category, period).
+	 */
+	Budget create(String accountName, Budget budget);
+
+	/**
+	 * Returns all non-deleted budgets for the account.
+	 */
+	List<Budget> findAll(String accountName);
+
+	/**
+	 * Returns all active, non-deleted budgets for the account.
+	 * Used by evaluation and notification flows.
+	 */
+	List<Budget> findActive(String accountName);
+
+	/**
+	 * Applies mutable field updates to an existing budget.
+	 * Enforces ownership and re-checks duplicate constraint.
+	 */
+	Budget update(String accountName, String budgetId, Budget update);
+
+	/**
+	 * Soft-deletes the budget. History is preserved for audit
+	 * and so that cooldowns on already-sent alerts remain meaningful.
+	 */
+	void softDelete(String accountName, String budgetId);
+
+	/**
+	 * Evaluates all active budgets for the account by delegating to
+	 * statistics-service. Returns an empty list if the downstream
+	 * fallback is triggered.
+	 */
+	List<BudgetEvaluation> evaluate(String accountName);
+
+}
diff --git a/account-service/src/main/java/com/piggymetrics/account/service/BudgetServiceImpl.java b/account-service/src/main/java/com/piggymetrics/account/service/BudgetServiceImpl.java
new file mode 100644
index 0000000..1d2c2e6
--- /dev/null
+++ b/account-service/src/main/java/com/piggymetrics/account/service/BudgetServiceImpl.java
@@ -0,0 +1,143 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.client.BudgetEvaluationClient;
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.domain.BudgetEvaluation;
+import com.piggymetrics.account.repository.BudgetRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.util.Collections;
+import java.util.Date;
+import java.util.List;
+import java.util.Optional;
+
+@Service
+public class BudgetServiceImpl implements BudgetService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private BudgetRepository repository;
+
+	@Autowired
+	private BudgetEvaluationClient evaluationClient;
+
+	@Override
+	public Budget create(String accountName, Budget budget) {
+		Assert.hasLength(accountName);
+		Assert.notNull(budget, "budget must not be null");
+		Assert.notNull(budget.getCategory(), "category must not be null");
+		Assert.notNull(budget.getPeriod(), "period must not be null");
+		Assert.notNull(budget.getLimit(), "limit must not be null");
+		Assert.notNull(budget.getCurrency(), "currency must not be null");
+
+		ensureNoActiveDuplicate(accountName, budget.getCategory(), budget.getPeriod(), null);
+
+		Date now = new Date();
+		budget.setId(null);
+		budget.setAccountName(accountName);
+		budget.setActive(Boolean.TRUE);
+		budget.setDeleted(Boolean.FALSE);
+		budget.setCreatedAt(now);
+		budget.setUpdatedAt(now);
+
+		Budget saved = repository.save(budget);
+		log.info("budget created for {}: category={} period={}", accountName, saved.getCategory(), saved.getPeriod());
+		return saved;
+	}
+
+	@Override
+	public List<Budget> findAll(String accountName) {
+		Assert.hasLength(accountName);
+		return repository.findByAccountNameAndDeletedFalse(accountName);
+	}
+
+	@Override
+	public List<Budget> findActive(String accountName) {
+		Assert.hasLength(accountName);
+		return repository.findByAccountNameAndActiveTrueAndDeletedFalse(accountName);
+	}
+
+	@Override
+	public Budget update(String accountName, String budgetId, Budget update) {
+		Assert.hasLength(accountName);
+		Assert.hasLength(budgetId);
+		Assert.notNull(update, "update payload must not be null");
+
+		Budget existing = loadOwned(accountName, budgetId);
+
+		String newCategory = update.getCategory() != null ? update.getCategory() : existing.getCategory();
+		com.piggymetrics.account.domain.BudgetPeriod newPeriod =
+				update.getPeriod() != null ? update.getPeriod() : existing.getPeriod();
+		// Null = "don't change"; otherwise the caller explicitly toggled it.
+		boolean willBeActive = update.getActive() == null ? existing.isActive() : update.getActive();
+
+		if (willBeActive && (!newCategory.equals(existing.getCategory())
+				|| !newPeriod.equals(existing.getPeriod())
+				|| !existing.isActive())) {
+			ensureNoActiveDuplicate(accountName, newCategory, newPeriod, budgetId);
+		}
+
+		existing.setCategory(newCategory);
+		existing.setPeriod(newPeriod);
+		if (update.getLimit() != null) existing.setLimit(update.getLimit());
+		if (update.getCurrency() != null) existing.setCurrency(update.getCurrency());
+		if (update.getWarningThreshold() != null) existing.setWarningThreshold(update.getWarningThreshold());
+		existing.setActive(willBeActive);
+		existing.setUpdatedAt(new Date());
+
+		Budget saved = repository.save(existing);
+		log.info("budget {} updated for {}", budgetId, accountName);
+		return saved;
+	}
+
+	@Override
+	public void softDelete(String accountName, String budgetId) {
+		Assert.hasLength(accountName);
+		Assert.hasLength(budgetId);
+
+		Budget existing = loadOwned(accountName, budgetId);
+		if (existing.isDeleted()) {
+			return;
+		}
+		existing.setDeleted(Boolean.TRUE);
+		existing.setActive(Boolean.FALSE);
+		existing.setUpdatedAt(new Date());
+		repository.save(existing);
+		log.info("budget {} soft-deleted for {}", budgetId, accountName);
+	}
+
+	@Override
+	public List<BudgetEvaluation> evaluate(String accountName) {
+		Assert.hasLength(accountName);
+		List<Budget> active = findActive(accountName);
+		if (active.isEmpty()) {
+			return Collections.emptyList();
+		}
+		return evaluationClient.evaluate(accountName, active);
+	}
+
+	private Budget loadOwned(String accountName, String budgetId) {
+		Optional<Budget> existing = repository.findById(budgetId);
+		Assert.isTrue(existing.isPresent(), "budget not found: " + budgetId);
+		Budget budget = existing.get();
+		Assert.isTrue(accountName.equals(budget.getAccountName()),
+				"budget does not belong to account: " + accountName);
+		return budget;
+	}
+
+	private void ensureNoActiveDuplicate(String accountName, String category,
+										 com.piggymetrics.account.domain.BudgetPeriod period,
+										 String ignoreId) {
+		Optional<Budget> duplicate = repository
+				.findByAccountNameAndCategoryAndPeriodAndActiveTrueAndDeletedFalse(accountName, category, period);
+		if (duplicate.isPresent() && (ignoreId == null || !ignoreId.equals(duplicate.get().getId()))) {
+			throw new IllegalArgumentException(
+					"active budget already exists for category '" + category + "' and period " + period);
+		}
+	}
+}
