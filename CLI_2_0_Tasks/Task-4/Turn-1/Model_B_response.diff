@@ -0,0 +1,34 @@
+package com.piggymetrics.statistics.domain;
+
+import java.time.LocalDate;
+import java.time.Month;
+
+/**
+ * Calendar-aligned budget window. Provides helpers to compute
+ * the period-start and period-length in days used for
+ * currency / period-ratio normalization.
+ */
+public enum BudgetPeriod {
+
+	MONTH, QUARTER, YEAR;
+
+	/**
+	 * First day of the current period aligned to the calendar:
+	 * MONTH = first of the current month, QUARTER = first day of
+	 * the current calendar quarter, YEAR = January 1st.
+	 */
+	public LocalDate startOfPeriod(LocalDate today) {
+		switch (this) {
+			case MONTH:
+				return today.withDayOfMonth(1);
+			case QUARTER:
+				int quarterStartMonth = ((today.getMonthValue() - 1) / 3) * 3 + 1;
+				return LocalDate.of(today.getYear(), Month.of(quarterStartMonth), 1);
+			case YEAR:
+				return today.withDayOfYear(1);
+			default:
+				throw new IllegalStateException("unknown period: " + this);
+		}
+	}
+
+}
