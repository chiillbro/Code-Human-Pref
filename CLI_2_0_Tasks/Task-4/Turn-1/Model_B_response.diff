@@ -0,0 +1,27 @@
+package com.piggymetrics.account.client;
+
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.domain.BudgetEvaluation;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.util.Collections;
+import java.util.List;
+
+/**
+ * Fallback returns an empty evaluation list so that callers
+ * (UI, notification cron) degrade gracefully when
+ * statistics-service is unavailable.
+ */
+@Component
+public class BudgetEvaluationClientFallback implements BudgetEvaluationClient {
+
+	private static final Logger LOGGER = LoggerFactory.getLogger(BudgetEvaluationClientFallback.class);
+
+	@Override
+	public List<BudgetEvaluation> evaluate(String accountName, List<Budget> budgets) {
+		LOGGER.error("statistics-service unavailable, returning empty budget evaluations for account: {}", accountName);
+		return Collections.emptyList();
+	}
+}
