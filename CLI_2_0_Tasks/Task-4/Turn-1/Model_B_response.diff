+package com.piggymetrics.account.controller;
+
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.domain.BudgetEvaluation;
+import com.piggymetrics.account.service.BudgetService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.http.ResponseEntity;
+import org.springframework.security.access.prepost.PreAuthorize;
+import org.springframework.web.bind.annotation.*;
+
+import javax.validation.Valid;
+import java.security.Principal;
+import java.util.List;
+
+/**
+ * Budget CRUD for end users plus an internal read endpoint
+ * used by notification-service (server scope only).
+ */
+@RestController
+@RequestMapping("/budgets")
+public class BudgetController {
+
+	@Autowired
+	private BudgetService budgetService;
+
+	// ---- User-scoped endpoints -------------------------------------------------
+
+	@RequestMapping(path = "/current", method = RequestMethod.GET)
+	public List<Budget> listCurrent(Principal principal) {
+		return budgetService.findAll(principal.getName());
+	}
+
+	@RequestMapping(path = "/current", method = RequestMethod.POST)
+	public Budget createCurrent(Principal principal, @Valid @RequestBody Budget budget) {
+		return budgetService.create(principal.getName(), budget);
+	}
+
+	@RequestMapping(path = "/current/{budgetId}", method = RequestMethod.PUT)
+	public Budget updateCurrent(Principal principal,
+								@PathVariable String budgetId,
+								@Valid @RequestBody Budget budget) {
+		return budgetService.update(principal.getName(), budgetId, budget);
+	}
+
+	@RequestMapping(path = "/current/{budgetId}", method = RequestMethod.DELETE)
+	public ResponseEntity<Void> deleteCurrent(Principal principal, @PathVariable String budgetId) {
+		budgetService.softDelete(principal.getName(), budgetId);
+		return ResponseEntity.noContent().build();
+	}
+
+	@RequestMapping(path = "/current/status", method = RequestMethod.GET)
+	public List<BudgetEvaluation> currentStatus(Principal principal) {
+		return budgetService.evaluate(principal.getName());
+	}
+
+	// ---- Server-scoped endpoints (internal) -----------------------------------
+
+	/**
+	 * Returns active budgets for the given account.
+	 * Restricted to service-to-service calls (notification cron).
+	 */
+	@PreAuthorize("#oauth2.hasScope('server')")
+	@RequestMapping(path = "/{accountName}/active", method = RequestMethod.GET)
+	public List<Budget> listActive(@PathVariable String accountName) {
+		return budgetService.findActive(accountName);
+	}
+
+	@PreAuthorize("#oauth2.hasScope('server')")
+	@RequestMapping(path = "/{accountName}/status", method = RequestMethod.GET)
+	public List<BudgetEvaluation> statusFor(@PathVariable String accountName) {
+		return budgetService.evaluate(accountName);
+	}
+}
diff --git a/account-service/src/main/java/com/piggymetrics/account/domain/Budget.java b/account-service/src/main/java/com/piggymetrics/account/domain/Budget.java
