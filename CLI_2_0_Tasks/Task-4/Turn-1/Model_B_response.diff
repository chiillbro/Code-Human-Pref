+import org.springframework.data.annotation.Id;
+import org.springframework.data.mongodb.core.index.CompoundIndex;
+import org.springframework.data.mongodb.core.index.CompoundIndexes;
+import org.springframework.data.mongodb.core.mapping.Document;
+
+import java.util.Date;
+
+/**
+ * Tracks the last budget alert emitted for a specific
+ * {@code (accountName, budgetId)} pair. The {@code lastAlertedAt}
+ * timestamp drives the cooldown that prevents spamming the user.
+ *
+ * <p>We intentionally key off {@code budgetId} (stable across
+ * category/period edits) rather than {@code category+period} so that
+ * renaming or re-scoping a budget resets the cooldown correctly.
+ */
+@Document(collection = "budgetAlertStates")
+@CompoundIndexes({
+		@CompoundIndex(name = "idx_account_budget", unique = true,
+				def = "{'accountName': 1, 'budgetId': 1}")
+})
+public class BudgetAlertState {
+
+	@Id
