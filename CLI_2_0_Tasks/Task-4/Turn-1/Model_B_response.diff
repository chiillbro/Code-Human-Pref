+package com.piggymetrics.notification.client;
+
+import com.piggymetrics.notification.domain.BudgetEvaluation;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.util.Collections;
+import java.util.List;
+
+/**
+ * Behaviour on failure is per-endpoint:
+ * <ul>
+ *   <li>{@link #getAccount(String)} throws so that the existing
+ *       backup flow's try/catch skips the recipient (no email sent
+ *       without its payload — matches prior behaviour).</li>
+ *   <li>{@link #getBudgetStatus(String)} returns an empty list so
+ *       that the scheduled sweep keeps making progress across
+ *       recipients and only this one is skipped for this run.</li>
+ * </ul>
+ */
+@Component
+public class AccountServiceClientFallback implements AccountServiceClient {
+
+	private static final Logger LOGGER = LoggerFactory.getLogger(AccountServiceClientFallback.class);
+
+	@Override
+	public String getAccount(String accountName) {
+		LOGGER.error("account-service unavailable, cannot fetch backup for {}", accountName);
+		throw new IllegalStateException("account-service unavailable: " + accountName);
+	}
+
+	@Override
+	public List<BudgetEvaluation> getBudgetStatus(String accountName) {
+		LOGGER.error("account-service unavailable, cannot fetch budget status for {}", accountName);
+		return Collections.emptyList();
+	}
+}
