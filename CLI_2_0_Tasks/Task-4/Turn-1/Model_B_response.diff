+package com.piggymetrics.notification.service;
+
+/**
+ * Runs periodically to evaluate every account's budgets and
+ * notify its recipient when any of them are in
+ * {@link com.piggymetrics.notification.domain.BudgetStatus#WARNING}
+ * or {@link com.piggymetrics.notification.domain.BudgetStatus#EXCEEDED}.
+ *
+ * Uses an async dispatch per recipient and a per-budget cooldown
+ * to avoid re-alerting on unchanged state.
+ */
+public interface BudgetAlertService {
+
+	/**
+	 * Scheduled entry point. Exposed on the interface so it can be
+	 * invoked manually from tests.
+	 */
+	void sendBudgetAlerts();
+
+}
diff --git a/notification-service/src/main/java/com/piggymetrics/notification/service/BudgetAlertServiceImpl.java b/notification-service/src/main/java/com/piggymetrics/notification/service/BudgetAlertServiceImpl.java
new file mode 100644
index 0000000..93bb5c3
--- /dev/null
+++ b/notification-service/src/main/java/com/piggymetrics/notification/service/BudgetAlertServiceImpl.java
@@ -0,0 +1,151 @@
+package com.piggymetrics.notification.service;
+
+import com.piggymetrics.notification.client.AccountServiceClient;
+import com.piggymetrics.notification.domain.BudgetAlertState;
+import com.piggymetrics.notification.domain.BudgetEvaluation;
+import com.piggymetrics.notification.domain.BudgetStatus;
+import com.piggymetrics.notification.domain.NotificationType;
+import com.piggymetrics.notification.domain.Recipient;
+import com.piggymetrics.notification.repository.BudgetAlertStateRepository;
+import com.piggymetrics.notification.repository.RecipientRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.cloud.context.config.annotation.RefreshScope;
+import org.springframework.core.env.Environment;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Service;
+
+import java.text.MessageFormat;
+import java.util.Date;
+import java.util.List;
+import java.util.Optional;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.TimeUnit;
+
+/**
+ * Scheduled budget alert sweep.
+ *
+ * <p>For every recipient who has opted in to {@code BUDGET_ALERT},
+ * we asynchronously:
+ * <ol>
+ *   <li>ask account-service for its evaluated budgets (which itself
+ *       delegates to statistics-service via Feign + fallback),</li>
+ *   <li>for each evaluation in WARNING or EXCEEDED that is past the
+ *       configured cooldown, send an email and record the alert
+ *       in {@code budgetAlertStates}.</li>
+ * </ol>
+ *
+ * <p>The cooldown is keyed off {@code (accountName, budgetId)} and
+ * is reset whenever the status transitions (e.g. UNDER_BUDGET →
+ * WARNING should fire regardless of a prior EXCEEDED alert that's
+ * still inside its cooldown window — transitions are more
+ * informative than duplicates, so we treat them as "new" alerts).
+ */
+@Service
+@RefreshScope
+public class BudgetAlertServiceImpl implements BudgetAlertService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private AccountServiceClient accountClient;
+
+	@Autowired
+	private RecipientRepository recipientRepository;
+
+	@Autowired
+	private BudgetAlertStateRepository alertStateRepository;
+
+	@Autowired
+	private EmailService emailService;
+
+	@Autowired
+	private Environment env;
+
+	/** How long to wait before re-alerting on the same status for the same budget. */
+	@Value("${budget.alert.cooldown.hours:24}")
+	private long cooldownHours;
+
+	@Override
+	@Scheduled(cron = "${budget.alert.cron:0 0 * * * *}")
+	public void sendBudgetAlerts() {
+		List<Recipient> recipients = recipientRepository.findWithBudgetAlertsActive();
+		log.info("found {} recipients for budget alerts", recipients.size());
+
+		recipients.forEach(recipient -> CompletableFuture.runAsync(() -> processRecipient(recipient)));
+	}
+
+	private void processRecipient(Recipient recipient) {
+		try {
+			List<BudgetEvaluation> evaluations = accountClient.getBudgetStatus(recipient.getAccountName());
+			for (BudgetEvaluation evaluation : evaluations) {
+				if (shouldAlert(recipient.getAccountName(), evaluation)) {
+					sendAlert(recipient, evaluation);
+				}
+			}
+		} catch (Throwable t) {
+			log.error("an error during budget alert evaluation for {}", recipient, t);
+		}
+	}
+
+	private boolean shouldAlert(String accountName, BudgetEvaluation evaluation) {
+		BudgetStatus status = evaluation.getStatus();
+		if (status != BudgetStatus.WARNING && status != BudgetStatus.EXCEEDED) {
+			return false;
+		}
+
+		Optional<BudgetAlertState> previous = alertStateRepository
+				.findByAccountNameAndBudgetId(accountName, evaluation.getBudgetId());
+		if (!previous.isPresent()) {
+			return true;
+		}
+
+		BudgetAlertState state = previous.get();
+		// Re-alert immediately on status transition (e.g. WARNING -> EXCEEDED).
+		if (state.getLastStatus() != status) {
+			return true;
+		}
+		// Otherwise respect the cooldown window.
+		long cooldownMs = TimeUnit.HOURS.toMillis(cooldownHours);
+		return state.getLastAlertedAt() == null
+				|| System.currentTimeMillis() - state.getLastAlertedAt().getTime() >= cooldownMs;
+	}
+
+	private void sendAlert(Recipient recipient, BudgetEvaluation evaluation) {
+		try {
+			String subjectTemplate = env.getProperty(NotificationType.BUDGET_ALERT.getSubject(),
+					"PiggyMetrics budget alert: {0}");
+			String bodyTemplate = env.getProperty(NotificationType.BUDGET_ALERT.getText(),
+					"Hey, {0}! Your {1} budget is at {2,number,percent} of the {3} {4} limit " +
+							"for this {5} (current spend: {6} {4}).");
+
+			String subject = MessageFormat.format(subjectTemplate, evaluation.getCategory());
+			String body = MessageFormat.format(bodyTemplate,
+					recipient.getAccountName(),
+					evaluation.getCategory(),
+					evaluation.getPercentUsed(),
+					evaluation.getLimit(),
+					evaluation.getCurrency(),
+					evaluation.getPeriod(),
+					evaluation.getActual());
+
+			emailService.sendFormatted(NotificationType.BUDGET_ALERT, recipient, subject, body);
+			recordAlert(recipient.getAccountName(), evaluation);
+		} catch (Throwable t) {
+			log.error("failed to send budget alert to {} for budget {}", recipient, evaluation.getBudgetId(), t);
+		}
+	}
+
+	private void recordAlert(String accountName, BudgetEvaluation evaluation) {
+		BudgetAlertState state = alertStateRepository
+				.findByAccountNameAndBudgetId(accountName, evaluation.getBudgetId())
+				.orElseGet(BudgetAlertState::new);
+		state.setAccountName(accountName);
+		state.setBudgetId(evaluation.getBudgetId());
+		state.setLastStatus(evaluation.getStatus());
+		state.setLastAlertedAt(new Date());
+		alertStateRepository.save(state);
+	}
+}
