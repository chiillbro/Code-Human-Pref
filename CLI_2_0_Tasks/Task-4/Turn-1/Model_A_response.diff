+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.repository.BudgetRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.util.Date;
+import java.util.List;
+
+@Service
+public class BudgetServiceImpl implements BudgetService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private BudgetRepository repository;
+
+	@Override
+	public Budget create(String accountName, Budget budget) {
+
+		Budget existing = repository.findByAccountNameAndCategoryAndPeriodAndActiveTrue(
+				accountName, budget.getCategory(), budget.getPeriod());
+		Assert.isNull(existing, "active budget already exists for category '"
+				+ budget.getCategory() + "' and period " + budget.getPeriod());
+
+		budget.setAccountName(accountName);
+		budget.setActive(true);
+		budget.setCreatedDate(new Date());
+		budget.setUpdatedDate(new Date());
+
+		repository.save(budget);
+
+		log.info("new budget has been created for account {}: {} {}", accountName, budget.getCategory(), budget.getPeriod());
+
+		return budget;
+	}
+
+	@Override
+	public List<Budget> findByAccountName(String accountName) {
+		Assert.hasLength(accountName);
+		return repository.findByAccountNameAndActiveTrue(accountName);
+	}
+
+	@Override
+	public Budget update(String accountName, String budgetId, Budget update) {
+
+		Budget budget = repository.findById(budgetId).orElse(null);
+		Assert.notNull(budget, "can't find budget with id " + budgetId);
+		Assert.isTrue(budget.getAccountName().equals(accountName), "budget does not belong to account " + accountName);
+		Assert.isTrue(budget.isActive(), "budget is not active");
+
+		if (update.getCategory() != null && update.getPeriod() != null) {
+			if (!budget.getCategory().equals(update.getCategory()) || !budget.getPeriod().equals(update.getPeriod())) {
+				Budget duplicate = repository.findByAccountNameAndCategoryAndPeriodAndActiveTrue(
+						accountName, update.getCategory(), update.getPeriod());
+				Assert.isNull(duplicate, "active budget already exists for category '"
+						+ update.getCategory() + "' and period " + update.getPeriod());
+			}
+		}
+
+		if (update.getCategory() != null) {
+			budget.setCategory(update.getCategory());
+		}
+		if (update.getLimitAmount() != null) {
+			budget.setLimitAmount(update.getLimitAmount());
+		}
+		if (update.getLimitCurrency() != null) {
+			budget.setLimitCurrency(update.getLimitCurrency());
+		}
+		if (update.getPeriod() != null) {
+			budget.setPeriod(update.getPeriod());
+		}
+		if (update.getWarningThreshold() != null) {
+			budget.setWarningThreshold(update.getWarningThreshold());
+		}
+		budget.setUpdatedDate(new Date());
+
+		repository.save(budget);
+
+		log.info("budget {} has been updated for account {}", budgetId, accountName);
+
+		return budget;
+	}
+
+	@Override
+	public void delete(String accountName, String budgetId) {
+
+		Budget budget = repository.findById(budgetId).orElse(null);
+		Assert.notNull(budget, "can't find budget with id " + budgetId);
+		Assert.isTrue(budget.getAccountName().equals(accountName), "budget does not belong to account " + accountName);
+
+		budget.setActive(false);
+		budget.setUpdatedDate(new Date());
+		repository.save(budget);
+
+		log.info("budget {} has been soft-deleted for account {}", budgetId, accountName);
+	}
+}
