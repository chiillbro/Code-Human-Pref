+package com.piggymetrics.account.controller;
+
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.service.BudgetService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.security.access.prepost.PreAuthorize;
+import org.springframework.web.bind.annotation.*;
+
+import javax.validation.Valid;
+import java.security.Principal;
+import java.util.List;
+
+@RestController
+@RequestMapping("/budgets")
+public class BudgetController {
+
+	@Autowired
+	private BudgetService budgetService;
+
+	@RequestMapping(path = "/current", method = RequestMethod.GET)
+	public List<Budget> getCurrentAccountBudgets(Principal principal) {
+		return budgetService.findByAccountName(principal.getName());
+	}
+
+	@PreAuthorize("#oauth2.hasScope('server')")
+	@RequestMapping(path = "/{accountName}", method = RequestMethod.GET)
+	public List<Budget> getBudgetsByAccountName(@PathVariable String accountName) {
+		return budgetService.findByAccountName(accountName);
+	}
+
+	@RequestMapping(path = "/current", method = RequestMethod.POST)
+	public Budget createBudget(Principal principal, @Valid @RequestBody Budget budget) {
+		return budgetService.create(principal.getName(), budget);
+	}
+
+	@RequestMapping(path = "/current/{budgetId}", method = RequestMethod.PUT)
+	public Budget updateBudget(Principal principal, @PathVariable String budgetId, @RequestBody Budget budget) {
+		return budgetService.update(principal.getName(), budgetId, budget);
+	}
+
+	@RequestMapping(path = "/current/{budgetId}", method = RequestMethod.DELETE)
+	public void deleteBudget(Principal principal, @PathVariable String budgetId) {
+		budgetService.delete(principal.getName(), budgetId);
+	}
+}
