+	@Override
+	@Scheduled(cron = "${budget.alert.cron}")
+	public void sendBudgetAlertNotifications() {
+
+		final NotificationType type = NotificationType.BUDGET_ALERT;
+
+		List<Recipient> recipients = recipientService.findReadyToNotify(type);
+		log.info("found {} recipients for budget alert notification", recipients.size());
+
+		recipients.forEach(recipient -> CompletableFuture.runAsync(() -> {
+			try {
+				List<BudgetAlert> evaluations = statisticsClient.getBudgetEvaluations(recipient.getAccountName());
+
+				List<BudgetAlert> alertable = evaluations.stream()
+						.filter(e -> "WARNING".equals(e.getStatus()) || "EXCEEDED".equals(e.getStatus()))
+						.collect(Collectors.toList());
+
+				if (!alertable.isEmpty()) {
+					String alertText = buildAlertText(alertable);
+					emailService.send(type, recipient, alertText);
+					recipientService.markNotified(type, recipient);
+					log.info("budget alert sent to {} for {} budget(s)", recipient.getAccountName(), alertable.size());
+				}
+			} catch (Throwable t) {
+				log.error("an error during budget alert notification for {}", recipient, t);
+			}
+		}));
+	}
+
+	private String buildAlertText(List<BudgetAlert> alerts) {
+		StringBuilder sb = new StringBuilder();
+		for (BudgetAlert alert : alerts) {
+			sb.append(String.format("- %s (%s): %s%% used of %s %s limit [%s]%n",
+					alert.getCategory(),
+					alert.getPeriod(),
+					alert.getUsagePercentage(),
+					alert.getLimitAmount(),
+					alert.getLimitCurrency(),
+					alert.getStatus()));
+		}
+		return sb.toString();
+	}
 }
