+package com.piggymetrics.notification.service;
+
+import com.google.common.collect.ImmutableList;
+import com.piggymetrics.notification.client.AccountServiceClient;
+import com.piggymetrics.notification.client.StatisticsServiceClient;
+import com.piggymetrics.notification.domain.BudgetAlert;
+import com.piggymetrics.notification.domain.NotificationType;
+import com.piggymetrics.notification.domain.Recipient;
+import org.junit.Before;
+import org.junit.Test;
+import org.mockito.InjectMocks;
+import org.mockito.Mock;
+
+import java.math.BigDecimal;
+import java.util.Collections;
+
+import static org.mockito.Mockito.*;
+import static org.mockito.MockitoAnnotations.initMocks;
+
+public class BudgetAlertNotificationTest {
+
+	@InjectMocks
+	private NotificationServiceImpl notificationService;
+
+	@Mock
+	private RecipientService recipientService;
+
+	@Mock
+	private AccountServiceClient client;
+
+	@Mock
+	private StatisticsServiceClient statisticsClient;
+
+	@Mock
+	private EmailService emailService;
+
+	@Before
+	public void setup() {
+		initMocks(this);
+	}
+
+	@Test
+	public void shouldSendBudgetAlertWhenBudgetExceeded() throws Exception {
+
+		Recipient recipient = new Recipient();
+		recipient.setAccountName("test");
+		recipient.setEmail("test@example.com");
+
+		BudgetAlert alert = new BudgetAlert();
+		alert.setCategory("Grocery");
+		alert.setPeriod("MONTH");
+		alert.setLimitAmount(new BigDecimal(500));
+		alert.setLimitCurrency("USD");
+		alert.setActualAmount(new BigDecimal(600));
+		alert.setUsagePercentage(new BigDecimal("120.00"));
+		alert.setStatus("EXCEEDED");
+
+		when(recipientService.findReadyToNotify(NotificationType.BUDGET_ALERT))
+				.thenReturn(ImmutableList.of(recipient));
+		when(statisticsClient.getBudgetEvaluations("test"))
+				.thenReturn(ImmutableList.of(alert));
+
+		notificationService.sendBudgetAlertNotifications();
+
+		verify(emailService, timeout(100)).send(eq(NotificationType.BUDGET_ALERT), eq(recipient), anyString());
+		verify(recipientService, timeout(100)).markNotified(NotificationType.BUDGET_ALERT, recipient);
+	}
+
+	@Test
+	public void shouldNotSendAlertWhenAllBudgetsUnderBudget() throws Exception {
+
+		Recipient recipient = new Recipient();
+		recipient.setAccountName("test");
+		recipient.setEmail("test@example.com");
+
+		BudgetAlert alert = new BudgetAlert();
+		alert.setCategory("Grocery");
+		alert.setStatus("UNDER_BUDGET");
+
+		when(recipientService.findReadyToNotify(NotificationType.BUDGET_ALERT))
+				.thenReturn(ImmutableList.of(recipient));
+		when(statisticsClient.getBudgetEvaluations("test"))
+				.thenReturn(ImmutableList.of(alert));
+
+		notificationService.sendBudgetAlertNotifications();
+
+		// Give async time to complete
+		Thread.sleep(100);
+
+		verify(emailService, never()).send(eq(NotificationType.BUDGET_ALERT), any(Recipient.class), anyString());
+		verify(recipientService, never()).markNotified(eq(NotificationType.BUDGET_ALERT), any(Recipient.class));
+	}
+
+	@Test
+	public void shouldHandleErrorsDuringBudgetAlertNotification() throws Exception {
+
+		Recipient withError = new Recipient();
+		withError.setAccountName("with-error");
+
+		Recipient withNoError = new Recipient();
+		withNoError.setAccountName("with-no-error");
+
+		BudgetAlert alert = new BudgetAlert();
+		alert.setCategory("Grocery");
+		alert.setPeriod("MONTH");
+		alert.setLimitAmount(new BigDecimal(500));
+		alert.setLimitCurrency("USD");
+		alert.setUsagePercentage(new BigDecimal("90.00"));
+		alert.setStatus("WARNING");
+
+		when(recipientService.findReadyToNotify(NotificationType.BUDGET_ALERT))
+				.thenReturn(ImmutableList.of(withNoError, withError));
+		when(statisticsClient.getBudgetEvaluations("with-error"))
+				.thenThrow(new RuntimeException());
+		when(statisticsClient.getBudgetEvaluations("with-no-error"))
+				.thenReturn(ImmutableList.of(alert));
+
+		notificationService.sendBudgetAlertNotifications();
+
+		verify(emailService, timeout(100)).send(eq(NotificationType.BUDGET_ALERT), eq(withNoError), anyString());
+		verify(recipientService, timeout(100)).markNotified(NotificationType.BUDGET_ALERT, withNoError);
+		verify(recipientService, never()).markNotified(NotificationType.BUDGET_ALERT, withError);
+	}
+}
