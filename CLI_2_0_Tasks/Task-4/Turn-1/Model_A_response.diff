+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.Budget;
+import com.piggymetrics.account.domain.BudgetPeriod;
+import com.piggymetrics.account.domain.Currency;
+import com.piggymetrics.account.repository.BudgetRepository;
+import org.junit.Before;
+import org.junit.Test;
+import org.mockito.InjectMocks;
+import org.mockito.Mock;
+
+import java.math.BigDecimal;
+import java.util.Arrays;
+import java.util.List;
+import java.util.Optional;
+
+import static org.junit.Assert.*;
+import static org.mockito.Mockito.*;
+import static org.mockito.MockitoAnnotations.initMocks;
+
+public class BudgetServiceTest {
+
+	@InjectMocks
+	private BudgetServiceImpl budgetService;
+
+	@Mock
+	private BudgetRepository repository;
+
+	@Before
+	public void setup() {
+		initMocks(this);
+	}
+
+	@Test
+	public void shouldCreateBudget() {
+
+		Budget budget = new Budget();
+		budget.setCategory("Grocery");
+		budget.setLimitAmount(new BigDecimal(500));
+		budget.setLimitCurrency(Currency.USD);
+		budget.setPeriod(BudgetPeriod.MONTH);
+
+		when(repository.findByAccountNameAndCategoryAndPeriodAndActiveTrue("test", "Grocery", BudgetPeriod.MONTH))
+				.thenReturn(null);
+
+		Budget result = budgetService.create("test", budget);
+
+		assertEquals("test", result.getAccountName());
+		assertEquals("Grocery", result.getCategory());
+		assertTrue(result.isActive());
+		assertNotNull(result.getCreatedDate());
+		assertNotNull(result.getUpdatedDate());
+
+		verify(repository, times(1)).save(budget);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailWhenDuplicateActiveBudgetExists() {
+
+		Budget existing = new Budget();
+		existing.setCategory("Grocery");
+		existing.setPeriod(BudgetPeriod.MONTH);
+
+		Budget budget = new Budget();
+		budget.setCategory("Grocery");
+		budget.setPeriod(BudgetPeriod.MONTH);
+		budget.setLimitAmount(new BigDecimal(500));
+		budget.setLimitCurrency(Currency.USD);
+
+		when(repository.findByAccountNameAndCategoryAndPeriodAndActiveTrue("test", "Grocery", BudgetPeriod.MONTH))
+				.thenReturn(existing);
+
+		budgetService.create("test", budget);
+	}
+
+	@Test
+	public void shouldFindBudgetsByAccountName() {
+
+		Budget budget = new Budget();
+		budget.setCategory("Grocery");
+
+		when(repository.findByAccountNameAndActiveTrue("test")).thenReturn(Arrays.asList(budget));
+
+		List<Budget> result = budgetService.findByAccountName("test");
+		assertEquals(1, result.size());
+		assertEquals("Grocery", result.get(0).getCategory());
+	}
+
+	@Test
+	public void shouldUpdateBudget() {
+
+		Budget existing = new Budget();
+		existing.setId("budget1");
+		existing.setAccountName("test");
+		existing.setCategory("Grocery");
+		existing.setPeriod(BudgetPeriod.MONTH);
+		existing.setLimitAmount(new BigDecimal(500));
+		existing.setLimitCurrency(Currency.USD);
+		existing.setActive(true);
+
+		Budget update = new Budget();
+		update.setLimitAmount(new BigDecimal(600));
+
+		when(repository.findById("budget1")).thenReturn(Optional.of(existing));
+
+		Budget result = budgetService.update("test", "budget1", update);
+
+		assertEquals(new BigDecimal(600), result.getLimitAmount());
+		assertNotNull(result.getUpdatedDate());
+		verify(repository, times(1)).save(existing);
+	}
+
+	@Test
+	public void shouldSoftDeleteBudget() {
+
+		Budget existing = new Budget();
+		existing.setId("budget1");
+		existing.setAccountName("test");
+		existing.setActive(true);
+
+		when(repository.findById("budget1")).thenReturn(Optional.of(existing));
+
+		budgetService.delete("test", "budget1");
+
+		assertFalse(existing.isActive());
+		assertNotNull(existing.getUpdatedDate());
+		verify(repository, times(1)).save(existing);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailToDeleteBudgetOfAnotherAccount() {
+
+		Budget existing = new Budget();
+		existing.setId("budget1");
+		existing.setAccountName("other");
+
+		when(repository.findById("budget1")).thenReturn(Optional.of(existing));
+
+		budgetService.delete("test", "budget1");
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailWhenFindByNameIsEmpty() {
+		budgetService.findByAccountName("");
+	}
+}
