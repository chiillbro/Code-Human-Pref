+package com.piggymetrics.statistics.service;
+
+import com.piggymetrics.statistics.client.AccountServiceClient;
+import com.piggymetrics.statistics.domain.*;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.math.BigDecimal;
+import java.math.RoundingMode;
+import java.util.Collections;
+import java.util.List;
+import java.util.stream.Collectors;
+
+@Service
+public class BudgetEvaluationServiceImpl implements BudgetEvaluationService {
+
+	private static final String TOTAL_CATEGORY = "_TOTAL";
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private AccountServiceClient accountClient;
+
+	@Autowired
+	private ExchangeRatesService ratesService;
+
+	@Override
+	public List<BudgetEvaluation> evaluate(String accountName) {
+
+		Assert.hasLength(accountName);
+
+		List<Budget> budgets = accountClient.getBudgets(accountName);
+		if (budgets == null || budgets.isEmpty()) {
+			return Collections.emptyList();
+		}
+
+		Account account = accountClient.getAccount(accountName);
+		if (account == null || account.getExpenses() == null) {
+			return Collections.emptyList();
+		}
+
+		List<Item> expenses = account.getExpenses();
+
+		return budgets.stream()
+				.map(budget -> evaluateBudget(budget, expenses))
+				.collect(Collectors.toList());
+	}
+
+	private BudgetEvaluation evaluateBudget(Budget budget, List<Item> expenses) {
+
+		BigDecimal actualAmount = calculateActualSpending(budget, expenses);
+
+		BigDecimal limitInBase = ratesService.convert(
+				budget.getLimitCurrency(), Currency.getBase(), budget.getLimitAmount());
+
+		BigDecimal usagePercentage = BigDecimal.ZERO;
+		if (limitInBase.compareTo(BigDecimal.ZERO) > 0) {
+			usagePercentage = actualAmount
+					.multiply(new BigDecimal("100"))
+					.divide(limitInBase, 2, RoundingMode.HALF_UP);
+		}
+
+		BudgetStatus status = determineStatus(usagePercentage, budget.getWarningThreshold());
+
+		BudgetEvaluation evaluation = new BudgetEvaluation();
+		evaluation.setBudgetId(budget.getId());
+		evaluation.setCategory(budget.getCategory());
+		evaluation.setPeriod(budget.getPeriod());
+		evaluation.setLimitAmount(budget.getLimitAmount());
+		evaluation.setLimitCurrency(budget.getLimitCurrency());
+		evaluation.setActualAmount(actualAmount);
+		evaluation.setUsagePercentage(usagePercentage);
+		evaluation.setStatus(status);
+
+		log.debug("budget evaluation for {}: {}% - {}", budget.getCategory(), usagePercentage, status);
+
+		return evaluation;
+	}
+
+	private BigDecimal calculateActualSpending(Budget budget, List<Item> expenses) {
+
+		BigDecimal budgetPeriodDays = budget.getPeriod().getDays();
+
+		return expenses.stream()
+				.filter(item -> TOTAL_CATEGORY.equals(budget.getCategory())
+						|| item.getTitle().equalsIgnoreCase(budget.getCategory()))
+				.map(item -> {
+					BigDecimal amountInBase = ratesService.convert(
+							item.getCurrency(), Currency.getBase(), item.getAmount());
+					BigDecimal dailyAmount = amountInBase.divide(
+							item.getPeriod().getBaseRatio(), 4, RoundingMode.HALF_UP);
+					return dailyAmount.multiply(budgetPeriodDays);
+				})
+				.reduce(BigDecimal.ZERO, BigDecimal::add)
+				.setScale(2, RoundingMode.HALF_UP);
+	}
+
+	private BudgetStatus determineStatus(BigDecimal usagePercentage, BigDecimal warningThreshold) {
+
+		BigDecimal warningPercent = warningThreshold.multiply(new BigDecimal("100"));
+
+		if (usagePercentage.compareTo(new BigDecimal("100")) >= 0) {
+			return BudgetStatus.EXCEEDED;
+		} else if (usagePercentage.compareTo(warningPercent) >= 0) {
+			return BudgetStatus.WARNING;
+		}
+		return BudgetStatus.UNDER_BUDGET;
+	}
+}
