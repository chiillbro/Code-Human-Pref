+	/**
+	 * {@inheritDoc}
+	 */
+	@Override
+	public Budget createBudget(String accountName, Budget budget) {
+
+		Account account = repository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		validateBudgetFields(budget);
+		checkForDuplicateBudget(account, budget.getCategory(), budget.getPeriod(), null);
+
+		budget.setBudgetId(UUID.randomUUID().toString());
+		budget.setCreatedDate(new Date());
+		budget.setActive(true);
+		budget.setLastTriggeredDate(null);
+
+		if (account.getBudgets() == null) {
+			account.setBudgets(new ArrayList<>());
+		}
+		account.getBudgets().add(budget);
+		repository.save(account);
+
+		log.info("new budget '{}' created for account {}", budget.getCategory(), accountName);
+
+		return budget;
+	}
+
+	/**
+	 * {@inheritDoc}
+	 */
+	@Override
+	public List<Budget> getBudgets(String accountName) {
+
+		Account account = repository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		if (account.getBudgets() == null) {
+			return new ArrayList<>();
+		}
+
+		return account.getBudgets().stream()
+				.filter(Budget::isActive)
+				.collect(Collectors.toList());
+	}
+
+	/**
+	 * {@inheritDoc}
+	 */
+	@Override
+	public Budget updateBudget(String accountName, String budgetId, Budget update) {
+
+		Account account = repository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		Budget existing = findBudgetById(account, budgetId);
+		validateBudgetFields(update);
+		checkForDuplicateBudget(account, update.getCategory(), update.getPeriod(), budgetId);
+
+		existing.setCategory(update.getCategory());
+		existing.setLimit(update.getLimit());
+		existing.setPeriod(update.getPeriod());
+		existing.setCurrency(update.getCurrency());
+		existing.setThresholdPercent(update.getThresholdPercent());
+
+		repository.save(account);
+
+		log.info("budget '{}' updated for account {}", budgetId, accountName);
+
+		return existing;
+	}
+
+	/**
+	 * {@inheritDoc}
+	 */
+	@Override
+	public void deleteBudget(String accountName, String budgetId) {
+
+		Account account = repository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		Budget existing = findBudgetById(account, budgetId);
+		existing.setActive(false);
+		repository.save(account);
+
+		log.info("budget '{}' soft-deleted for account {}", budgetId, accountName);
+	}
+
+	private Budget findBudgetById(Account account, String budgetId) {
+		if (account.getBudgets() == null) {
+			throw new IllegalArgumentException("budget not found: " + budgetId);
+		}
+		return account.getBudgets().stream()
+				.filter(b -> b.isActive() && budgetId.equals(b.getBudgetId()))
+				.findFirst()
+				.orElseThrow(() -> new IllegalArgumentException("budget not found: " + budgetId));
+	}
+
+	private void validateBudgetFields(Budget budget) {
+		Assert.notNull(budget.getCategory(), "budget category is required");
+		Assert.hasLength(budget.getCategory(), "budget category must not be empty");
+		Assert.notNull(budget.getLimit(), "budget limit is required");
+		Assert.isTrue(budget.getLimit().compareTo(BigDecimal.ZERO) > 0, "budget limit must be positive");
+		Assert.notNull(budget.getPeriod(), "budget period is required");
+		Assert.notNull(budget.getCurrency(), "budget currency is required");
+		Assert.isTrue(budget.getThresholdPercent() >= 1 && budget.getThresholdPercent() <= 100,
+				"thresholdPercent must be between 1 and 100");
+	}
+
+	private void checkForDuplicateBudget(Account account, String category, com.piggymetrics.account.domain.TimePeriod period, String excludeBudgetId) {
+		if (account.getBudgets() == null) {
+			return;
+		}
+		boolean duplicate = account.getBudgets().stream()
+				.filter(Budget::isActive)
+				.filter(b -> excludeBudgetId == null || !excludeBudgetId.equals(b.getBudgetId()))
+				.anyMatch(b -> b.getCategory().equalsIgnoreCase(category) && b.getPeriod() == period);
+		Assert.isTrue(!duplicate, "an active budget already exists for category '" + category + "' and period " + period);
+	}
+
+	/**
+	 * {@inheritDoc}
+	 */
+	@Override
+	public List<BudgetStatus> evaluateBudgets(String accountName) {
+
+		Account account = repository.findByName(accountName);
+		Assert.notNull(account, "can't find account with name " + accountName);
+
+		List<Budget> activeBudgets = account.getBudgets() == null
+				? new ArrayList<>()
+				: account.getBudgets().stream().filter(Budget::isActive).collect(Collectors.toList());
+
+		if (activeBudgets.isEmpty()) {
+			return new ArrayList<>();
+		}
+
+		BudgetEvaluationRequest request = new BudgetEvaluationRequest(activeBudgets, account);
+		List<BudgetStatus> statuses = statisticsClient.evaluateBudgets(accountName, request);
+
+		log.info("evaluated {} budgets for account {}", activeBudgets.size(), accountName);
+
+		return statuses;
+	}
 }
