@@ -0,0 +1,140 @@
+package com.piggymetrics.statistics.service;
+
+import com.piggymetrics.statistics.domain.*;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.math.BigDecimal;
+import java.math.RoundingMode;
+import java.util.List;
+import java.util.Map;
+import java.util.stream.Collectors;
+
+@Service
+public class BudgetEvaluationServiceImpl implements BudgetEvaluationService {
+
+	private static final String TOTAL_CATEGORY = "_TOTAL";
+	private static final int SCALE = 4;
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private ExchangeRatesService ratesService;
+
+	@Override
+	public List<BudgetStatus> evaluate(List<BudgetItem> budgets, Account account) {
+		Assert.notNull(budgets, "budgets must not be null");
+		Assert.notNull(account, "account must not be null");
+
+		Map<Currency, BigDecimal> rates = ratesService.getCurrentRates();
+
+		return budgets.stream()
+				.map(budget -> evaluateSingleBudget(budget, account, rates))
+				.collect(Collectors.toList());
+	}
+
+	private BudgetStatus evaluateSingleBudget(BudgetItem budget, Account account, Map<Currency, BigDecimal> rates) {
+		BigDecimal spent = computeSpentAmount(budget, account.getExpenses(), rates);
+		BigDecimal percentUsed = computePercentUsed(spent, budget.getLimit());
+		BudgetStatus.BudgetStatusType statusType = classifyStatus(percentUsed, budget.getThresholdPercent());
+
+		BudgetStatus status = new BudgetStatus();
+		status.setBudgetId(budget.getBudgetId());
+		status.setCategory(budget.getCategory());
+		status.setLimit(budget.getLimit());
+		status.setSpent(spent);
+		status.setPercentUsed(percentUsed);
+		status.setStatus(statusType);
+
+		log.debug("budget '{}' evaluated: spent={}, limit={}, percent={}%, status={}",
+				budget.getCategory(), spent, budget.getLimit(), percentUsed, statusType);
+
+		return status;
+	}
+
+	private BigDecimal computeSpentAmount(BudgetItem budget, List<Item> expenses, Map<Currency, BigDecimal> rates) {
+		if (expenses == null || expenses.isEmpty()) {
+			return BigDecimal.ZERO;
+		}
+
+		List<Item> relevantExpenses = filterExpenses(budget.getCategory(), expenses);
+
+		return relevantExpenses.stream()
+				.map(expense -> normalizeExpense(expense, budget.getCurrency(), budget.getPeriod(), rates))
+				.reduce(BigDecimal.ZERO, BigDecimal::add);
+	}
+
+	private List<Item> filterExpenses(String category, List<Item> expenses) {
+		if (TOTAL_CATEGORY.equals(category)) {
+			return expenses;
+		}
+		return expenses.stream()
+				.filter(e -> e.getTitle() != null && e.getTitle().equalsIgnoreCase(category))
+				.collect(Collectors.toList());
+	}
+
+	/**
+	 * Normalizes an expense to the budget's target currency and target period.
+	 *
+	 * Step 1: Convert the expense amount from its native currency to the budget's currency.
+	 * Step 2: Convert the expense from its native period to the budget's period.
+	 *
+	 * The existing TimePeriod.getBaseRatio() normalizes to DAY (e.g., MONTH=30.4368, YEAR=365.2425).
+	 * To convert from expensePeriod to budgetPeriod:
+	 *   normalizedAmount = amount * (budgetPeriod.baseRatio / expensePeriod.baseRatio)
+	 *
+	 * Example: $1200/YEAR expense against a MONTH budget:
+	 *   1200 * (30.4368 / 365.2425) = ~$100/month
+	 */
+	private BigDecimal normalizeExpense(Item expense, Currency targetCurrency, TimePeriod targetPeriod, Map<Currency, BigDecimal> rates) {
+		BigDecimal convertedAmount = convertCurrency(expense.getAmount(), expense.getCurrency(), targetCurrency, rates);
+		return convertPeriod(convertedAmount, expense.getPeriod(), targetPeriod);
+	}
+
+	private BigDecimal convertCurrency(BigDecimal amount, Currency from, Currency to, Map<Currency, BigDecimal> rates) {
+		if (from == to) {
+			return amount;
+		}
+		BigDecimal fromRate = rates.get(from);
+		BigDecimal toRate = rates.get(to);
+		Assert.notNull(fromRate, "exchange rate not found for " + from);
+		Assert.notNull(toRate, "exchange rate not found for " + to);
+
+		// rates are relative to USD base: to convert from A to B => amount * (rateB / rateA)
+		BigDecimal ratio = toRate.divide(fromRate, SCALE, RoundingMode.HALF_UP);
+		return amount.multiply(ratio).setScale(SCALE, RoundingMode.HALF_UP);
+	}
+
+	private BigDecimal convertPeriod(BigDecimal amount, TimePeriod fromPeriod, TimePeriod toPeriod) {
+		if (fromPeriod == toPeriod) {
+			return amount;
+		}
+		// amount is "per fromPeriod". To convert to toPeriod:
+		// result = amount * (toPeriod.baseRatio / fromPeriod.baseRatio)
+		return amount
+				.multiply(toPeriod.getBaseRatio())
+				.divide(fromPeriod.getBaseRatio(), SCALE, RoundingMode.HALF_UP);
+	}
+
+	private BigDecimal computePercentUsed(BigDecimal spent, BigDecimal limit) {
+		if (limit.compareTo(BigDecimal.ZERO) == 0) {
+			return spent.compareTo(BigDecimal.ZERO) > 0 ? new BigDecimal("100.00") : BigDecimal.ZERO;
+		}
+		return spent
+				.multiply(new BigDecimal("100"))
+				.divide(limit, 2, RoundingMode.HALF_UP);
+	}
+
+	private BudgetStatus.BudgetStatusType classifyStatus(BigDecimal percentUsed, int thresholdPercent) {
+		if (percentUsed.compareTo(new BigDecimal("100")) >= 0) {
+			return BudgetStatus.BudgetStatusType.EXCEEDED;
+		}
+		if (percentUsed.compareTo(new BigDecimal(thresholdPercent)) >= 0) {
+			return BudgetStatus.BudgetStatusType.WARNING;
+		}
+		return BudgetStatus.BudgetStatusType.UNDER_BUDGET;
+	}
+}
