+public interface BudgetEvaluationService {
+
+	/**
+	 * Evaluates a list of budgets against the given account data.
+	 * Normalizes expenses to each budget's currency and period,
+	 * then computes spent amounts and status for each budget.
+	 *
+	 * @param budgets the budgets to evaluate
