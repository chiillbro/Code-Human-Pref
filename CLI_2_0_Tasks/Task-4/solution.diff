+	private BudgetItem createBudgetItem(String id, String category, BigDecimal limit,
+										TimePeriod period, Currency currency, int thresholdPercent) {
+		BudgetItem item = new BudgetItem();
+		item.setBudgetId(id);
+		item.setCategory(category);
+		item.setLimit(limit);
+		item.setPeriod(period);
+		item.setCurrency(currency);
+		item.setThresholdPercent(thresholdPercent);
+		return item;
+	}
