new file mode 100644
index 0000000..a4268fb
--- /dev/null
+++ b/lib/context.js
@@ -0,0 +1,161 @@
+'use strict'
+
+// Request-scoped context for pino, backed by AsyncLocalStorage.
+//
+// The ALS instance is created lazily, the first time any context API is
+// invoked. This keeps the logging fast path untouched for users that do
+// not opt in: `getContextStore()` returns `undefined` via a single null
+// check when no scope has ever been entered.
+
+let AsyncLocalStorage = null
+try {
+  ({ AsyncLocalStorage } = require('node:async_hooks'))
+} catch (_) {
+  // async_hooks is unavailable (e.g. some non-Node runtimes). We keep
+  // AsyncLocalStorage as null and surface a clear error if the user
+  // actually tries to use the context API.
+}
+
+let als = null
+
+function ensureAls () {
+  if (als !== null) return als
+  if (AsyncLocalStorage === null || typeof AsyncLocalStorage !== 'function') {
+    throw new Error(
+      'pino.context requires AsyncLocalStorage, which is not available in this environment'
+    )
+  }
+  als = new AsyncLocalStorage()
+  return als
+}
+
+function assertFields (fields, apiName) {
+  if (fields === null || typeof fields !== 'object' || Array.isArray(fields)) {
+    throw new TypeError(`${apiName} requires a plain object of fields`)
+  }
+}
+
+/**
+ * Runs `fn` inside a new context scope with `fields` merged over the
+ * current scope (if any). Nested scopes inherit from their parent; inner
+ * fields override outer fields of the same name.
+ *
+ * @param {object} fields
+ * @param {Function} fn
+ * @param  {...any} args Forwarded to `fn`.
+ * @returns The return value of `fn`.
+ */
+function context (fields, fn, ...args) {
+  assertFields(fields, 'pino.context')
+  if (typeof fn !== 'function') {
+    throw new TypeError('pino.context requires a callback function')
+  }
+  const storage = ensureAls()
+  const parent = storage.getStore()
+  const merged = parent ? Object.assign({}, parent, fields) : Object.assign({}, fields)
+  return storage.run(merged, fn, ...args)
+}
+
+/**
+ * Returns the fields bound to the current context scope, or `undefined`
+ * if no scope is active.
+ *
+ * @returns {object|undefined}
+ */
+function getContext () {
+  if (als === null) return undefined
+  const store = als.getStore()
+  if (store === undefined) return undefined
+  // Return a shallow copy so callers cannot mutate the live store in
+  // surprising ways; use setContext() to update fields.
+  return Object.assign({}, store)
+}
+
+/**
+ * Merges `fields` into the current context scope. Throws if no scope is
+ * active. Does not affect parent scopes.
+ *
+ * @param {object} fields
+ */
+function setContext (fields) {
+  assertFields(fields, 'pino.setContext')
+  if (als === null || als.getStore() === undefined) {
+    throw new Error('pino.setContext called without an active context scope')
+  }
+  Object.assign(als.getStore(), fields)
+}
+
+/**
+ * Enters a context scope for the remainder of the current synchronous
+ * execution and persists it through subsequent async work. This mirrors
+ * `AsyncLocalStorage.prototype.enterWith` and is intended as an escape
+ * hatch for integrations that cannot wrap a callback (e.g. some stream
+ * pipelines).
+ *
+ * @param {object} fields
+ */
+function enterContextWith (fields) {
+  assertFields(fields, 'pino.enterContextWith')
+  const storage = ensureAls()
+  const parent = storage.getStore()
+  const merged = parent ? Object.assign({}, parent, fields) : Object.assign({}, fields)
+  storage.enterWith(merged)
+}
+
+/**
+ * Returns a connect/Express/Fastify-compatible middleware that opens a
+ * context scope for the lifetime of the request. `fieldsOrFn` may be a
+ * static object of fields, or a function that receives `(req, res)` and
+ * returns an object of fields.
+ *
+ * @param {object|Function} [fieldsOrFn]
+ */
+function contextMiddleware (fieldsOrFn) {
+  let resolver
+  if (fieldsOrFn === undefined || fieldsOrFn === null) {
+    resolver = () => ({})
+  } else if (typeof fieldsOrFn === 'function') {
+    resolver = fieldsOrFn
+  } else if (typeof fieldsOrFn === 'object' && !Array.isArray(fieldsOrFn)) {
+    resolver = () => fieldsOrFn
+  } else {
+    throw new TypeError(
+      'pino.contextMiddleware expects an object of fields or a function returning one'
+    )
+  }
+
+  return function pinoContextMiddleware (req, res, next) {
+    const fields = resolver(req, res) || {}
+    if (typeof fields !== 'object' || Array.isArray(fields)) {
+      return next(new TypeError('pino.contextMiddleware field resolver must return a plain object'))
+    }
+    context(fields, next)
+  }
+}
+
+/**
+ * Internal accessor used by the logging fast path. Returns the active
+ * store or `undefined`. Designed to be cheap when no ALS exists.
+ */
+function getContextStore () {
+  if (als === null) return undefined
+  return als.getStore()
+}
+
+/**
+ * Test-only helper to reset the internal ALS reference. Not part of
+ * the public API.
+ */
+function _resetForTests () {
+  als = null
+}
+
+module.exports = {
+  context,
+  getContext,
+  setContext,
+  enterContextWith,
+  contextMiddleware,
+  getContextStore,
+  _resetForTests
+}
