diff --git a/test/context.test.js b/test/context.test.js
new file mode 100644
index 0000000..0e92d00
--- /dev/null
+++ b/test/context.test.js
@@ -0,0 +1,339 @@
+'use strict'
+
+const test = require('node:test')
+const assert = require('node:assert')
+const os = require('node:os')
+
+const { sink, once } = require('./helper')
+const pino = require('../')
+
+const { pid } = process
+const hostname = os.hostname()
+
+test('pino.context exposes the expected helpers', () => {
+  assert.equal(typeof pino.context, 'function')
+  assert.equal(typeof pino.getContext, 'function')
+  assert.equal(typeof pino.setContext, 'function')
+  assert.equal(typeof pino.enterContextWith, 'function')
+  assert.equal(typeof pino.contextMiddleware, 'function')
+})
+
+test('context fields are merged into every log line', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  pino.context({ reqId: 'abc-123', userId: 42 }, () => {
+    instance.info('hello')
+  })
+
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    reqId: 'abc-123',
+    userId: 42,
+    msg: 'hello'
+  })
+})
+
+test('no context scope keeps log output unchanged', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+  instance.info('hello')
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    msg: 'hello'
+  })
+})
+
+test('context fields propagate across async boundaries', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  await pino.context({ reqId: 'async-1' }, async () => {
+    await Promise.resolve()
+    await new Promise(resolve => setImmediate(resolve))
+    instance.info('deep async')
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'async-1')
+  assert.equal(result.msg, 'deep async')
+})
+
+test('nested scopes inherit from the parent and inner overrides outer', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  pino.context({ reqId: 'outer', region: 'us-east' }, () => {
+    pino.context({ reqId: 'inner', userId: 7 }, () => {
+      instance.info('nested')
+    })
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'inner')
+  assert.equal(result.region, 'us-east')
+  assert.equal(result.userId, 7)
+})
+
+test('explicit log object overrides context fields', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  pino.context({ reqId: 'ctx-id' }, () => {
+    instance.info({ reqId: 'override-id', extra: true }, 'override')
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'override-id')
+  assert.equal(result.extra, true)
+})
+
+test('context beats mixin in field precedence', async () => {
+  const stream = sink()
+  const instance = pino({
+    mixin () {
+      return { source: 'mixin', mixinOnly: true }
+    }
+  }, stream)
+
+  pino.context({ source: 'ctx', reqId: 'r1' }, () => {
+    instance.info('priority')
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.source, 'ctx')
+  assert.equal(result.mixinOnly, true)
+  assert.equal(result.reqId, 'r1')
+})
+
+test('getContext returns a copy of the current scope fields', () => {
+  pino.context({ a: 1, b: 2 }, () => {
+    const fields = pino.getContext()
+    assert.deepEqual(fields, { a: 1, b: 2 })
+    // Mutating the returned copy must not affect subsequent reads.
+    fields.a = 99
+    assert.deepEqual(pino.getContext(), { a: 1, b: 2 })
+  })
+})
+
+test('getContext returns undefined outside a scope', () => {
+  assert.equal(pino.getContext(), undefined)
+})
+
+test('setContext merges into the current scope', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  pino.context({ reqId: 'r-1' }, () => {
+    pino.setContext({ userId: 'u-1' })
+    instance.info('after set')
+    assert.deepEqual(pino.getContext(), { reqId: 'r-1', userId: 'u-1' })
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'r-1')
+  assert.equal(result.userId, 'u-1')
+})
+
+test('setContext mutation in child does not leak into parent', () => {
+  pino.context({ reqId: 'parent' }, () => {
+    pino.context({ span: 's1' }, () => {
+      pino.setContext({ span: 's2', extra: 1 })
+      assert.deepEqual(pino.getContext(), { reqId: 'parent', span: 's2', extra: 1 })
+    })
+    assert.deepEqual(pino.getContext(), { reqId: 'parent' })
+  })
+})
+
+test('setContext throws when called outside of a scope', () => {
+  assert.throws(
+    () => pino.setContext({ foo: 'bar' }),
+    /pino\.setContext called without an active context scope/
+  )
+})
+
+test('context validates its inputs', () => {
+  assert.throws(() => pino.context(null, () => {}), /pino\.context requires a plain object/)
+  assert.throws(() => pino.context([], () => {}), /pino\.context requires a plain object/)
+  assert.throws(() => pino.context({}, 'not-a-fn'), /pino\.context requires a callback function/)
+})
+
+test('setContext validates its input', () => {
+  pino.context({ a: 1 }, () => {
+    assert.throws(() => pino.setContext(null), /pino\.setContext requires a plain object/)
+    assert.throws(() => pino.setContext([]), /pino\.setContext requires a plain object/)
+  })
+})
+
+test('context forwards extra arguments to the callback', () => {
+  const result = pino.context({ a: 1 }, (x, y) => x + y, 2, 3)
+  assert.equal(result, 5)
+})
+
+test('enterContextWith activates a scope without a callback', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  await new Promise(resolve => {
+    setImmediate(() => {
+      pino.enterContextWith({ reqId: 'enter-with' })
+      instance.info('escape hatch')
+      resolve()
+    })
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'enter-with')
+})
+
+test('enterContextWith inherits from existing parent scope', () => {
+  pino.context({ reqId: 'outer' }, () => {
+    pino.enterContextWith({ span: 'sibling' })
+    assert.deepEqual(pino.getContext(), { reqId: 'outer', span: 'sibling' })
+  })
+})
+
+test('contextMiddleware opens a scope for the request lifetime', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+  const mw = pino.contextMiddleware(req => ({ reqId: req.id, path: req.path }))
+
+  const fakeReq = { id: 'req-9', path: '/items' }
+  const fakeRes = {}
+
+  await new Promise((resolve, reject) => {
+    mw(fakeReq, fakeRes, () => {
+      try {
+        instance.info('inside middleware')
+        assert.deepEqual(pino.getContext(), { reqId: 'req-9', path: '/items' })
+        resolve()
+      } catch (err) {
+        reject(err)
+      }
+    })
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'req-9')
+  assert.equal(result.path, '/items')
+})
+
+test('contextMiddleware accepts a static object of fields', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+  const mw = pino.contextMiddleware({ service: 'api' })
+
+  await new Promise(resolve => {
+    mw({}, {}, () => {
+      instance.info('static fields')
+      resolve()
+    })
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.service, 'api')
+})
+
+test('contextMiddleware with no args opens an empty scope', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+  const mw = pino.contextMiddleware()
+
+  await new Promise(resolve => {
+    mw({}, {}, () => {
+      assert.deepEqual(pino.getContext(), {})
+      instance.info('empty')
+      resolve()
+    })
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.msg, 'empty')
+  assert.equal(result.reqId, undefined)
+})
+
+test('contextMiddleware rejects invalid arguments', () => {
+  assert.throws(() => pino.contextMiddleware('bad'), /pino\.contextMiddleware/)
+  assert.throws(() => pino.contextMiddleware(42), /pino\.contextMiddleware/)
+  assert.throws(() => pino.contextMiddleware([]), /pino\.contextMiddleware/)
+})
+
+test('contextMiddleware forwards error when resolver returns a non-object', () => {
+  const mw = pino.contextMiddleware(() => 'not-an-object')
+  let forwarded
+  mw({}, {}, (err) => {
+    forwarded = err
+  })
+  assert.ok(forwarded instanceof TypeError)
+})
+
+test('context fields interact correctly with child loggers', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+  const child = instance.child({ module: 'payments' })
+
+  pino.context({ reqId: 'req-c1' }, () => {
+    child.info('child log')
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.module, 'payments')
+  assert.equal(result.reqId, 'req-c1')
+  assert.equal(result.msg, 'child log')
+})
+
+test('clear error when AsyncLocalStorage is unavailable', () => {
+  // Simulate async_hooks being unavailable by reloading the context
+  // module with a stubbed require cache entry. We validate the error
+  // message rather than the full behaviour because ALS is always
+  // available in supported Node versions.
+  const Module = require('module')
+  const originalLoad = Module._load
+  const contextPath = require.resolve('../lib/context')
+  delete require.cache[contextPath]
+  Module._load = function (request, ...rest) {
+    if (request === 'node:async_hooks') {
+      throw new Error('simulated missing module')
+    }
+    return originalLoad.call(this, request, ...rest)
+  }
+  try {
+    const ctx = require('../lib/context')
+    assert.throws(
+      () => ctx.context({ a: 1 }, () => {}),
+      /AsyncLocalStorage, which is not available/
+    )
+    assert.throws(
+      () => ctx.enterContextWith({ a: 1 }),
+      /AsyncLocalStorage, which is not available/
+    )
+  } finally {
+    Module._load = originalLoad
+    delete require.cache[contextPath]
+    // Force the real module back into cache for subsequent tests in
+    // other files that may run in the same process.
+    require('../lib/context')
+  }
+})
+
+test('context passes Error objects as the log object', async () => {
+  const stream = sink()
+  const instance = pino(stream)
+
+  pino.context({ reqId: 'err-1' }, () => {
+    instance.error(new Error('boom'))
+  })
+
+  const result = await once(stream, 'data')
+  assert.equal(result.reqId, 'err-1')
+  assert.equal(result.msg, 'boom')
+  assert.equal(result.err.message, 'boom')
+})
