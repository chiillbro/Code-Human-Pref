index 434dddd..cf0f006 100644
--- a/pino.d.ts
+++ b/pino.d.ts
@@ -854,6 +854,80 @@ declare namespace pino {
       opts?: MultiStreamOptions
     ): MultiStreamRes<TLevel>
 
+    /**
+     * A plain object of key/value pairs bound to an async context scope.
+     * These fields are automatically merged into every log line produced
+     * inside the scope.
+     */
+    export type ContextFields = Record<string, unknown>
+
+    /**
+     * A resolver used by {@link contextMiddleware}. Receives the current
+     * request/response pair and must return the fields to bind for the
+     * duration of the request.
+     */
+    export type ContextFieldsResolver<Req = unknown, Res = unknown> = (
+      req: Req,
+      res: Res
+    ) => ContextFields
+
+    /**
+     * Connect/Express-style middleware signature produced by
+     * {@link contextMiddleware}.
+     */
+    export type ContextMiddleware<Req = unknown, Res = unknown> = (
+      req: Req,
+      res: Res,
+      next: (err?: unknown) => void
+    ) => void
+
+    /**
+     * Runs `fn` inside a new request-scoped context. Any fields bound
+     * here will be included in every log line emitted (directly or via
+     * async continuations) until `fn` returns. Nested calls inherit
+     * from their parent scope; inner fields override outer fields of
+     * the same name.
+     *
+     * Throws if `AsyncLocalStorage` is not available in the current
+     * runtime.
+     */
+    export function context<T> (fields: ContextFields, fn: () => T): T
+    export function context<T, A extends unknown[]> (
+      fields: ContextFields,
+      fn: (...args: A) => T,
+      ...args: A
+    ): T
+
+    /**
+     * Returns a shallow copy of the fields bound to the current context
+     * scope, or `undefined` if no scope is active.
+     */
+    export function getContext (): ContextFields | undefined
+
+    /**
+     * Merges `fields` into the current context scope. Throws if called
+     * outside of an active scope. Does not affect parent scopes.
+     */
+    export function setContext (fields: ContextFields): void
+
+    /**
+     * Enters a context scope for the remainder of the current
+     * synchronous execution and persists it through subsequent async
+     * work. Mirrors `AsyncLocalStorage.prototype.enterWith` and is
+     * intended as an escape hatch for integrations that cannot wrap a
+     * callback. Prefer {@link context} where possible.
+     */
+    export function enterContextWith (fields: ContextFields): void
+
+    /**
+     * Creates a connect/Express/Fastify-compatible middleware that
+     * opens a context scope for the lifetime of the request. Accepts
+     * either a static object of fields or a resolver function.
+     */
+    export function contextMiddleware<Req = unknown, Res = unknown> (
+      fieldsOrFn?: ContextFields | ContextFieldsResolver<Req, Res>
+    ): ContextMiddleware<Req, Res>
+
     export { pino as default, pino }
 }
 
