diff --git a/test/context.test.js b/test/context.test.js
new file mode 100644
index 0000000..dfcec63
--- /dev/null
+++ b/test/context.test.js
@@ -0,0 +1,460 @@
+'use strict'
+
+const test = require('node:test')
+const assert = require('node:assert')
+const os = require('node:os')
+const tspl = require('@matteo.collina/tspl')
+
+const { sink, once } = require('./helper')
+const pino = require('../')
+
+const { pid } = process
+const hostname = os.hostname()
+
+test('context fields are included in log output', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ requestId: 'abc-123' }, () => {
+    instance.info('test')
+  })
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    requestId: 'abc-123',
+    msg: 'test'
+  })
+})
+
+test('no extra fields when no context scope is active', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.info('test')
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    msg: 'test'
+  })
+})
+
+test('nested scopes - inner fields override outer', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ userId: 1 }, () => {
+    instance.context.run({ userId: 2 }, () => {
+      instance.info('inner')
+    })
+  })
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    userId: 2,
+    msg: 'inner'
+  })
+})
+
+test('nested scopes - fields accumulate', async (t) => {
+  const plan = tspl(t, { plan: 2 })
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ requestId: 'abc' }, () => {
+    instance.context.run({ userId: 42 }, () => {
+      instance.info('nested')
+    })
+  })
+  const result = await once(stream, 'data')
+  plan.equal(result.requestId, 'abc')
+  plan.equal(result.userId, 42)
+  await plan
+})
+
+test('context.get() returns flattened fields inside scope', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ requestId: 'abc', userId: 1 }, () => {
+    const fields = instance.context.get()
+    assert.deepEqual(fields, { requestId: 'abc', userId: 1 })
+  })
+})
+
+test('context.get() returns undefined outside scope', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const result = instance.context.get()
+  assert.equal(result, undefined)
+})
+
+test('context.get(key) returns single field', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ requestId: 'abc', userId: 42 }, () => {
+    assert.equal(instance.context.get('requestId'), 'abc')
+    assert.equal(instance.context.get('userId'), 42)
+    assert.equal(instance.context.get('nonexistent'), undefined)
+  })
+})
+
+test('context.set() mutates current scope', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ requestId: 'abc' }, () => {
+    instance.context.set({ traceId: 'xyz' })
+    instance.info('test')
+  })
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    requestId: 'abc',
+    traceId: 'xyz',
+    msg: 'test'
+  })
+})
+
+test('context.set() throws outside scope', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  assert.throws(() => {
+    instance.context.set({ foo: 'bar' })
+  }, /context.set\(\) called outside of a context scope/)
+})
+
+test('context.enterWith() sets context without callback wrapper', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.enterWith({ background: true })
+  instance.info('test')
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    background: true,
+    msg: 'test'
+  })
+})
+
+test('child loggers inherit context', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const child = instance.child({ module: 'auth' })
+  instance.context.run({ requestId: 'abc' }, () => {
+    child.info('child log')
+  })
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    module: 'auth',
+    requestId: 'abc',
+    msg: 'child log'
+  })
+})
+
+test('works with user mixin - both fields appear', async () => {
+  const stream = sink()
+  const instance = pino({
+    context: true,
+    mixin () {
+      return { service: 'api' }
+    }
+  }, stream)
+  instance.context.run({ requestId: 'abc' }, () => {
+    instance.info('test')
+  })
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    requestId: 'abc',
+    service: 'api',
+    msg: 'test'
+  })
+})
+
+test('user mixin overrides context fields on conflict', async () => {
+  const stream = sink()
+  const instance = pino({
+    context: true,
+    mixin () {
+      return { source: 'mixin' }
+    }
+  }, stream)
+  instance.context.run({ source: 'context' }, () => {
+    instance.info('test')
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.source, 'mixin')
+})
+
+test('logged object overrides context and mixin fields', async () => {
+  const stream = sink()
+  const instance = pino({
+    context: true,
+    mixin () {
+      return { source: 'mixin' }
+    }
+  }, stream)
+  instance.context.run({ source: 'context', requestId: 'abc' }, () => {
+    instance.info({ source: 'logged' }, 'test')
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.source, 'logged')
+  assert.equal(result.requestId, 'abc')
+})
+
+test('custom mixinMergeStrategy is respected with context', async () => {
+  const stream = sink()
+  const instance = pino({
+    context: true,
+    mixin () {
+      return { fromMixin: true }
+    },
+    mixinMergeStrategy (mergeObject, mixinObject) {
+      // Custom strategy: mixin wins over logged object
+      return Object.assign(mergeObject, mixinObject)
+    }
+  }, stream)
+  instance.context.run({ requestId: 'abc' }, () => {
+    instance.info({ fromMixin: false }, 'test')
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.fromMixin, true)
+  assert.equal(result.requestId, 'abc')
+})
+
+test('context disabled by default', async () => {
+  const stream = sink()
+  const instance = pino({}, stream)
+  assert.equal(instance.context, undefined)
+})
+
+test('context: true without mixin works', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ foo: 'bar' }, () => {
+    instance.info('test')
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.foo, 'bar')
+})
+
+test('context invalid option type throws', async () => {
+  const stream = sink()
+  assert.throws(() => {
+    pino({ context: 'yes' }, stream)
+  }, /Unknown context option type/)
+})
+
+test('async context propagates through promises', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  await instance.context.run({ requestId: 'async-123' }, async () => {
+    await new Promise(resolve => setTimeout(resolve, 10))
+    instance.info('after await')
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.requestId, 'async-123')
+})
+
+test('async context propagates through setTimeout', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  await new Promise((resolve) => {
+    instance.context.run({ requestId: 'timeout-123' }, () => {
+      setTimeout(() => {
+        instance.info('in timeout')
+        resolve()
+      }, 10)
+    })
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.requestId, 'timeout-123')
+})
+
+test('context.middleware() returns a function', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const mw = instance.context.middleware()
+  assert.equal(typeof mw, 'function')
+  assert.equal(mw.length, 3)
+})
+
+test('context.middleware() creates scope with default extractor', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const mw = instance.context.middleware()
+  const fakeReq = { id: 'req-001' }
+  const fakeRes = {}
+  await new Promise((resolve) => {
+    mw(fakeReq, fakeRes, () => {
+      instance.info('middleware test')
+      resolve()
+    })
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.requestId, 'req-001')
+})
+
+test('context.middleware() with custom extractor', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const mw = instance.context.middleware((req) => ({
+    method: req.method,
+    path: req.url
+  }))
+  const fakeReq = { method: 'GET', url: '/api/users' }
+  const fakeRes = {}
+  await new Promise((resolve) => {
+    mw(fakeReq, fakeRes, () => {
+      instance.info('custom extractor test')
+      resolve()
+    })
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.method, 'GET')
+  assert.equal(result.path, '/api/users')
+})
+
+test('context.run() returns the value of the callback', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const result = instance.context.run({ a: 1 }, () => {
+    return 42
+  })
+  assert.equal(result, 42)
+})
+
+test('context.run() returns the value of an async callback', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const result = await instance.context.run({ a: 1 }, async () => {
+    return 'hello'
+  })
+  assert.equal(result, 'hello')
+})
+
+test('user mixin receives correct arguments when composed with context', async (t) => {
+  const plan = tspl(t, { plan: 3 })
+  const stream = sink()
+  const instance = pino({
+    context: true,
+    mixin (obj, num, logger) {
+      plan.deepEqual(obj, { custom: 'data' })
+      plan.equal(num, 30)
+      plan.ok(logger !== undefined)
+      return { fromMixin: true }
+    }
+  }, stream)
+  instance.context.run({ requestId: 'abc' }, () => {
+    instance.info({ custom: 'data' }, 'test')
+  })
+  await plan
+})
+
+test('nested context.set() only affects current scope', async (t) => {
+  const plan = tspl(t, { plan: 2 })
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({ requestId: 'abc' }, () => {
+    instance.context.run({ userId: 1 }, () => {
+      instance.context.set({ extra: 'inner' })
+      const innerFields = instance.context.get()
+      plan.deepEqual(innerFields, { requestId: 'abc', userId: 1, extra: 'inner' })
+    })
+    // After inner scope exits, extra should not be present
+    const outerFields = instance.context.get()
+    plan.deepEqual(outerFields, { requestId: 'abc' })
+  })
+  await plan
+})
+
+test('multiple context fields in single run', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  instance.context.run({
+    requestId: 'abc',
+    userId: 42,
+    tenantId: 'org-1',
+    traceId: 'trace-xyz'
+  }, () => {
+    instance.info('test')
+  })
+  const result = await once(stream, 'data')
+  assert.equal(result.requestId, 'abc')
+  assert.equal(result.userId, 42)
+  assert.equal(result.tenantId, 'org-1')
+  assert.equal(result.traceId, 'trace-xyz')
+})
+
+test('context is not shared across independent async chains', async (t) => {
+  const plan = tspl(t, { plan: 1 })
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const results = []
+
+  stream.on('data', (data) => {
+    results.push(data)
+  })
+
+  const p1 = new Promise((resolve) => {
+    instance.context.run({ requestId: 'req-1' }, () => {
+      setTimeout(() => {
+        instance.info('from chain 1')
+        resolve()
+      }, 10)
+    })
+  })
+
+  const p2 = new Promise((resolve) => {
+    instance.context.run({ requestId: 'req-2' }, () => {
+      setTimeout(() => {
+        instance.info('from chain 2')
+        resolve()
+      }, 10)
+    })
+  })
+
+  await Promise.all([p1, p2])
+  // Allow stream to flush
+  await new Promise(resolve => setTimeout(resolve, 50))
+
+  const ids = results.map(r => r.requestId).sort()
+  plan.deepEqual(ids, ['req-1', 'req-2'])
+  await plan
+})
+
+test('context with child that has own bindings', async () => {
+  const stream = sink()
+  const instance = pino({ context: true }, stream)
+  const child = instance.child({ component: 'db' })
+  instance.context.run({ requestId: 'abc', traceId: 'trace-1' }, () => {
+    child.info('query executed')
+  })
+  const result = await once(stream, 'data')
+  delete result.time
+  assert.deepEqual(result, {
+    pid,
+    hostname,
+    level: 30,
+    component: 'db',
+    requestId: 'abc',
+    traceId: 'trace-1',
+    msg: 'query executed'
+  })
+})
