@@ -0,0 +1,98 @@
+'use strict'
+
+let AsyncLocalStorage
+try {
+  AsyncLocalStorage = require('node:async_hooks').AsyncLocalStorage
+} catch {}
+
+function flattenStore (store) {
+  const chain = []
+  let current = store
+  while (current) {
+    chain.push(current.fields)
+    current = current.parent
+  }
+  // Apply outermost first so innermost wins
+  const result = {}
+  for (let i = chain.length - 1; i >= 0; i--) {
+    Object.assign(result, chain[i])
+  }
+  return result
+}
+
+function createContext (userMixin) {
+  if (!AsyncLocalStorage) {
+    throw new Error(
+      'pino context requires AsyncLocalStorage, available in Node.js >= 12.17.0. ' +
+      'Set { context: false } or omit the option to disable this feature.'
+    )
+  }
+
+  const als = new AsyncLocalStorage()
+
+  function composedMixin (obj, num, logger) {
+    const store = als.getStore()
+    let contextFields
+    if (store !== undefined) {
+      contextFields = flattenStore(store)
+    }
+
+    let userFields
+    if (userMixin) {
+      userFields = userMixin(obj, num, logger)
+    }
+
+    if (!contextFields && !userFields) return {}
+    if (!contextFields) return userFields
+    if (!userFields) return contextFields
+
+    // User mixin fields override context fields
+    return Object.assign({}, contextFields, userFields)
+  }
+
+  const controller = {
+    run (fields, fn) {
+      const parent = als.getStore()
+      return als.run({ fields, parent }, fn)
+    },
+
+    get (key) {
+      const store = als.getStore()
+      if (store === undefined) return undefined
+      const flattened = flattenStore(store)
+      if (key !== undefined) return flattened[key]
+      return flattened
+    },
+
+    set (fields) {
+      const store = als.getStore()
+      if (store === undefined) {
+        throw new Error('pino.context.set() called outside of a context scope. Use context.run() first.')
+      }
+      Object.assign(store.fields, fields)
+    },
+
+    enterWith (fields) {
+      const parent = als.getStore()
+      als.enterWith({ fields, parent })
+    },
+
+    middleware (extractor) {
+      const extract = extractor || function defaultExtractor (req) {
+        const fields = {}
+        if (req.id) fields.requestId = req.id
+        return fields
+      }
+
+      return function contextMiddleware (req, res, next) {
+        const fields = extract(req, res)
+        const parent = als.getStore()
+        als.run({ fields, parent }, next)
+      }
+    }
+  }
+
+  return { controller, composedMixin }
+}
+
+module.exports = { createContext }
