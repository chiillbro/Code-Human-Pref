+
+describe('context with multistream', () => {
+  test('context fields appear in all streams', () => {
+    let count = 0
+    const collected = []
+    const stream = writeStream(function (data, enc, cb) {
+      count += 1
+      collected.push(JSON.parse(data))
+      cb()
+    })
+    const streams = [
+      { stream },
+      { stream }
+    ]
+    const logger = pino({}, pino.multistream(streams))
+    const ctx = pino.context(logger)
+
+    ctx.run({ reqId: 'multi' }, () => {
+      logger.info('multistream test')
+    })
+
+    assert.equal(count, 2)
+    assert.equal(collected[0].reqId, 'multi')
+    assert.equal(collected[0].msg, 'multistream test')
+    assert.equal(collected[1].reqId, 'multi')
+    assert.equal(collected[1].msg, 'multistream test')
+  })
+})
