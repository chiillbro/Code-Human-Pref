+
+describe('context with user mixin', () => {
+  test('composes with existing mixin function', async () => {
+    const stream = sink()
+    const logger = pino({
+      mixin: () => ({ fromMixin: true, counter: 42 })
+    }, stream)
+    const ctx = pino.context(logger)
+
+    ctx.run({ reqId: 'abc' }, () => {
+      logger.info('composed')
+    })
+
+    const data = await once(stream, 'data')
+    assert.equal(data.fromMixin, true)
+    assert.equal(data.counter, 42)
+    assert.equal(data.reqId, 'abc')
+  })
+
+  test('context fields override mixin fields on conflict', async () => {
+    const stream = sink()
+    const logger = pino({
+      mixin: () => ({ source: 'mixin', shared: 'from-mixin' })
+    }, stream)
+    const ctx = pino.context(logger)
+
+    ctx.run({ shared: 'from-context' }, () => {
+      logger.info('conflict test')
+    })
+
+    const data = await once(stream, 'data')
+    assert.equal(data.source, 'mixin')
+    assert.equal(data.shared, 'from-context') // context wins over mixin
+  })
+
+  test('explicit log fields override both mixin and context', async () => {
+    const stream = sink()
+    const logger = pino({
+      mixin: () => ({ a: 'mixin', b: 'mixin' })
+    }, stream)
+    const ctx = pino.context(logger)
+
+    ctx.run({ b: 'context', c: 'context' }, () => {
+      logger.info({ c: 'explicit' }, 'all three')
+    })
+
+    const data = await once(stream, 'data')
+    assert.equal(data.a, 'mixin')
+    assert.equal(data.b, 'context')   // context overrides mixin
+    assert.equal(data.c, 'explicit')  // explicit overrides context
+  })
+})
