index 00000000..35422cc3
--- /dev/null
+++ b/lib/context.js
@@ -0,0 +1,211 @@
+'use strict'
+
+const { AsyncLocalStorage } = require('node:async_hooks')
+const { contextSym } = require('./symbols')
+
+let enterWithWarned = false
+
+/**
+ * ContextManager wraps AsyncLocalStorage to provide automatic
+ * request-scoped logging context for pino loggers.
+ *
+ * @param {object} logger A pino logger instance
+ * @param {object} [opts] Options
+ * @param {string} [opts.mixinMergeStrategy] How to merge context with mixin
+ */
+class ContextManager {
+  constructor (logger, opts) {
+    if (!AsyncLocalStorage) {
+      throw Error('pino.context requires AsyncLocalStorage (Node.js >= 16.4.0)')
+    }
+    if (!logger || typeof logger.info !== 'function') {
+      throw Error('pino.context requires a pino logger instance')
+    }
+
+    this._als = new AsyncLocalStorage()
+    this._logger = logger
+    this._opts = opts || {}
+
+    // Attach context injection to the logger via mixin composition
+    this._attachMixin(logger)
+  }
+
+  /**
+   * The context-aware logger instance.
+   */
+  get logger () {
+    return this._logger
+  }
+
+  /**
+   * Run `fn` within a new async context scope. All log calls within `fn`
+   * and its async descendants will include `store` fields.
+   *
+   * Nested `run()` calls merge their store with the outer store
+   * (inner wins on conflict).
+   *
+   * @param {object} store Key-value pairs to add to log context
+   * @param {function} fn The function to run within the scope
+   * @returns {*} Whatever `fn` returns (Promise-transparent)
+   */
+  run (store, fn) {
+    if (store === null || store === undefined || typeof store !== 'object' || Array.isArray(store)) {
+      throw Error('pino.context: store must be a plain object')
+    }
+    if (typeof fn !== 'function') {
+      throw Error('pino.context: fn must be a function')
+    }
+
+    // Merge with outer scope if nested
+    const outerStore = this._als.getStore()
+    const mergedStore = outerStore
+      ? Object.assign({}, outerStore, store)
+      : Object.assign({}, store)
+
+    return this._als.run(mergedStore, fn)
+  }
+
+  /**
+   * Add or update a field in the current context scope.
+   * Uses copy-on-write semantics so parallel async branches
+   * sharing the same scope do not see each other's mutations.
+   *
+   * @param {string} key The field name
+   * @param {*} value The field value
+   */
+  set (key, value) {
+    const store = this._als.getStore()
+    if (store === undefined) {
+      throw Error('pino.context: set() called outside of a run() scope')
+    }
+    // Copy-on-write: clone the store before mutating so parallel
+    // async continuations sharing the parent scope are not affected
+    const newStore = Object.assign({}, store)
+    newStore[key] = value
+    this._als.enterWith(newStore)
+  }
+
+  /**
+   * Read a field from the current context scope.
+   *
+   * @param {string} key The field name
+   * @returns {*} The value, or undefined if not in scope
+   */
+  get (key) {
+    const store = this._als.getStore()
+    if (store === undefined) return undefined
+    return store[key]
+  }
+
+  /**
+   * Returns a function that wraps `fn` in a `run()` scope with the
+   * given `fields`. Useful as Express/Fastify middleware.
+   *
+   * Usage: `app.use(ctx.bind({ reqId: req.id })(handler))`
+   *
+   * @param {object} fields Context fields to bind
+   * @returns {function} A wrapper: (fn) => (...args) => ctx.run(fields, () => fn(...args))
+   */
+  bind (fields) {
+    const self = this
+    return function boundContextFactory (fn) {
+      return function boundContextRunner (...args) {
+        return self.run(fields, () => fn(...args))
+      }
+    }
+  }
+
+  /**
+   * Escape hatch that sets context for the remainder of the current
+   * async execution without creating a new scope. Mirrors
+   * AsyncLocalStorage.enterWith().
+   *
+   * WARNING: This can cause context leaks if used carelessly.
+   * Prefer `run()` for most use cases.
+   *
+   * @param {object} store The context store to enter with
+   */
+  enterWith (store) {
+    if (!enterWithWarned) {
+      enterWithWarned = true
+      process.emitWarning(
+        'pino.context enterWith() can cause context leaks; prefer run()',
+        'PinoContextWarning'
+      )
+    }
+    if (store === null || store === undefined || typeof store !== 'object' || Array.isArray(store)) {
+      throw Error('pino.context: store must be a plain object')
+    }
+
+    // Merge with outer scope
+    const outerStore = this._als.getStore()
+    const mergedStore = outerStore
+      ? Object.assign({}, outerStore, store)
+      : Object.assign({}, store)
+
+    this._als.enterWith(mergedStore)
+  }
+
+  /**
+   * Get the full current context store, or undefined if outside a scope.
+   *
+   * @returns {object|undefined}
+   */
+  getStore () {
+    return this._als.getStore()
+  }
+
+  /**
+   * Attach context injection to the logger's mixin mechanism.
+   * Composes with any existing user-supplied mixin function.
+   *
+   * @param {object} logger
+   * @private
+   */
+  _attachMixin (logger) {
+    const als = this._als
+    const existingMixin = logger[contextSym]
+      ? logger[contextSym]._prevMixin
+      : logger[require('./symbols').mixinSym]
+
+    const contextMixin = function contextMixin (mergeObj, level, logger) {
+      const store = als.getStore()
+      let result = store ? Object.assign({}, store) : {}
+
+      if (existingMixin) {
+        const mixinResult = existingMixin(mergeObj, level, logger)
+        // Merge: mixin result fields come first (lower priority),
+        // context fields override them, matching the spec that
+        // context fields appear after base bindings but can be
+        // overridden by explicitly logged fields
+        result = Object.assign({}, mixinResult, result)
+      }
+
+      return result
+    }
+
+    // Store reference to previous mixin for composition chains
+    logger[contextSym] = this
+    this._prevMixin = existingMixin || null
+
+    // Replace the mixin on the instance
+    const mixinSym = require('./symbols').mixinSym
+    logger[mixinSym] = contextMixin
+  }
+}
+
+/**
+ * Create a context manager for a pino logger.
+ *
+ * @param {object} logger A pino logger instance
+ * @param {object} [opts] Options
+ * @returns {ContextManager}
+ */
+function createContext (logger, opts) {
+  return new ContextManager(logger, opts)
+}
+
+module.exports = {
+  createContext,
+  ContextManager
+}
