+    const logger = pino(stream)
+    const ctx = pino.context(logger)
+
+    await ctx.run({ reqId: 'then-test' }, () => {
+      return new Promise((resolve) => {
+        Promise.resolve().then(() => {
+          logger.info('in then')
+          resolve()
+        })
+      })
+    })
+
+    const data = await once(stream, 'data')
+    assert.equal(data.reqId, 'then-test')
+  })
+
+  test('propagates across setTimeout', async () => {
+    const stream = sink()
+    const logger = pino(stream)
+    const ctx = pino.context(logger)
+
+    await ctx.run({ reqId: 'timeout-test' }, () => {
+      return new Promise((resolve) => {
+        setTimeout(() => {
+          logger.info('in timeout')
+          resolve()
+        }, 10)
+      })
+    })
+
+    const data = await once(stream, 'data')
+    assert.equal(data.reqId, 'timeout-test')
+  })
+
+  test('propagates across setImmediate', async () => {
+    const stream = sink()
+    const logger = pino(stream)
+    const ctx = pino.context(logger)
+
+    await ctx.run({ reqId: 'immediate-test' }, () => {
+      return new Promise((resolve) => {
+        setImmediate(() => {
+          logger.info('in immediate')
+          resolve()
+        })
+      })
+    })
+
+    const data = await once(stream, 'data')
+    assert.equal(data.reqId, 'immediate-test')
+  })
+
+  test('concurrent run() scopes are isolated', async () => {
+    const stream = sink()
+    const logger = pino(stream)
+    const ctx = pino.context(logger)
+
+    const results = []
+    stream.on('data', (d) => results.push(d))
+
+    // Simulate two parallel "requests"
+    const req1 = ctx.run({ reqId: 'req-1' }, async () => {
+      await sleep(20)
+      logger.info('from req 1')
+    })
+
+    const req2 = ctx.run({ reqId: 'req-2' }, async () => {
+      await sleep(10)
+      logger.info('from req 2')
+    })
+
+    await Promise.all([req1, req2])
+    await sleep(50)
+
+    const r1 = results.find(d => d.msg === 'from req 1')
+    const r2 = results.find(d => d.msg === 'from req 2')
+    assert.equal(r1.reqId, 'req-1')
+    assert.equal(r2.reqId, 'req-2')
+  })
+})
