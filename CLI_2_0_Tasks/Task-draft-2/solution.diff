+// ---------------------------------------------------------------------------
+// Memory safety
+// ---------------------------------------------------------------------------
+
+describe('context memory safety', () => {
+  test('stores are garbage-collectible after run() completes', async () => {
+    const stream = sink()
+    const logger = pino(stream)
+    const ctx = pino.context(logger)
+
+    // Run a loop of many contexts and verify heap doesn't grow unbounded
+    const baseline = process.memoryUsage().heapUsed
+
+    for (let i = 0; i < 10000; i++) {
+      ctx.run({ iteration: i, data: 'x'.repeat(100) }, () => {
+        // no-op
+      })
+    }
+
+    // Force GC if available
+    if (global.gc) {
+      global.gc()
+    }
+
+    const after = process.memoryUsage().heapUsed
+    // Heap growth should be modest (less than 50MB for 10K iterations)
+    const growth = after - baseline
+    assert.ok(growth < 50 * 1024 * 1024, `Heap grew by ${(growth / 1024 / 1024).toFixed(1)}MB`)
+  })
+})
