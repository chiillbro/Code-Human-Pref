index 0000000..c200058
--- /dev/null
+++ b/src/flowctl/executor.py
@@ -0,0 +1,394 @@
+"""Concurrent workflow executor with retry, timeout, conditions, and SIGINT handling."""
+
+from __future__ import annotations
+
+import os
+import signal
+import subprocess
+import sys
+import threading
+import time
+from datetime import datetime, timezone
+
+from flowctl.dag import (
+    get_ready_steps,
+    get_steps_to_cancel,
+    resolve_skips,
+    topological_sort,
+)
+from flowctl.models import (
+    AttemptResult,
+    ExecutionReport,
+    StepDefinition,
+    StepResult,
+    StepStatus,
+    WorkflowDefinition,
+    WorkflowStatus,
+)
+
+
+class ExecutionState:
+    """Thread-safe container for shared execution state."""
+
+    def __init__(self, workflow: WorkflowDefinition) -> None:
+        self._lock = threading.Lock()
+        self.workflow = workflow
+        self.results: dict[str, StepResult] = {
+            name: StepResult(name=name) for name in workflow.steps
+        }
+        self.completed: set[str] = set()
+        self.failed: set[str] = set()
+        self.running: set[str] = set()
+        self.cancelled: set[str] = set()
+        self.skipped: set[str] = set()
+        self.interrupted = False
+        self._running_processes: dict[str, subprocess.Popen] = {}
+
+    @property
+    def lock(self) -> threading.Lock:
+        return self._lock
+
+    def mark_running(self, name: str) -> None:
+        with self._lock:
+            self.results[name].status = StepStatus.RUNNING
+            self.running.add(name)
+
+    def mark_completed(self, name: str, status: StepStatus) -> None:
+        with self._lock:
+            self.results[name].status = status
+            self.running.discard(name)
+            if status == StepStatus.SUCCEEDED:
+                self.completed.add(name)
+            elif status in (StepStatus.FAILED, StepStatus.TIMED_OUT):
+                self.failed.add(name)
+
+    def mark_cancelled(self, names: set[str]) -> None:
+        with self._lock:
+            for name in names:
+                self.results[name].status = StepStatus.CANCELLED
+                self.cancelled.add(name)
+
+    def mark_skipped(self, names: set[str]) -> None:
+        with self._lock:
+            for name in names:
+                self.results[name].status = StepStatus.SKIPPED
+                self.skipped.add(name)
+
+    def add_attempt(self, name: str, attempt: AttemptResult) -> None:
+        with self._lock:
+            self.results[name].attempts.append(attempt)
+
+    def register_process(self, name: str, proc: subprocess.Popen) -> None:
+        with self._lock:
+            self._running_processes[name] = proc
+
+    def unregister_process(self, name: str) -> None:
+        with self._lock:
+            self._running_processes.pop(name, None)
+
+    def kill_all_running(self) -> None:
+        with self._lock:
+            for name, proc in list(self._running_processes.items()):
+                try:
+                    proc.terminate()
+                except OSError:
+                    pass
+            self.interrupted = True
+
+    def get_ready(self) -> list[str]:
+        with self._lock:
+            return get_ready_steps(
+                self.workflow.steps,
+                self.completed,
+                self.running,
+                self.cancelled,
+                self.skipped,
+                self.failed,
+            )
+
+    def is_done(self) -> bool:
+        with self._lock:
+            total = len(self.workflow.steps)
+            done = len(self.completed) + len(self.failed) + len(self.cancelled) + len(self.skipped)
+            return done >= total
+
+
+def _run_step_attempt(
+    step: StepDefinition,
+    attempt_num: int,
+    state: ExecutionState,
+) -> AttemptResult:
+    """Execute a single attempt of a step command as a subprocess."""
+    env = {**os.environ, **step.env}
+    start = time.monotonic()
+
+    try:
+        proc = subprocess.Popen(
+            step.command,
+            shell=True,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            env=env,
+            # Use process group so we can kill the group on timeout
+            preexec_fn=os.setsid if sys.platform != "win32" else None,
+        )
+        state.register_process(step.name, proc)
+
+        try:
+            stdout_bytes, stderr_bytes = proc.communicate(timeout=step.timeout_seconds)
+            duration = time.monotonic() - start
+            state.unregister_process(step.name)
+
+            return AttemptResult(
+                attempt_number=attempt_num,
+                duration_seconds=duration,
+                exit_code=proc.returncode,
+                stdout=stdout_bytes.decode("utf-8", errors="replace"),
+                stderr=stderr_bytes.decode("utf-8", errors="replace"),
+                timed_out=False,
+            )
+        except subprocess.TimeoutExpired:
+            duration = time.monotonic() - start
+            # Kill the whole process group
+            try:
+                if sys.platform != "win32":
+                    os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
+                else:
+                    proc.kill()
+            except OSError:
+                pass
+
+            stdout_bytes, stderr_bytes = proc.communicate()
+            state.unregister_process(step.name)
+
+            return AttemptResult(
+                attempt_number=attempt_num,
+                duration_seconds=duration,
+                exit_code=None,
+                stdout=stdout_bytes.decode("utf-8", errors="replace") if stdout_bytes else "",
+                stderr=stderr_bytes.decode("utf-8", errors="replace") if stderr_bytes else "",
+                timed_out=True,
+            )
+    except OSError as exc:
+        duration = time.monotonic() - start
+        state.unregister_process(step.name)
+        return AttemptResult(
+            attempt_number=attempt_num,
+            duration_seconds=duration,
+            exit_code=-1,
+            stdout="",
+            stderr=str(exc),
+            timed_out=False,
+        )
+
+
+def _run_step(step: StepDefinition, state: ExecutionState, log) -> None:
+    """Run a step with retries, then update shared state."""
+    log(f"[START]  {step.name}")
+    state.mark_running(step.name)
+
+    final_status = StepStatus.FAILED
+
+    for attempt_num in range(1, step.retry.max_attempts + 1):
+        if state.interrupted:
+            state.mark_completed(step.name, StepStatus.CANCELLED)
+            log(f"[CANCEL] {step.name} (interrupted)")
+            return
+
+        if attempt_num > 1:
+            log(f"[RETRY]  {step.name} (attempt {attempt_num}/{step.retry.max_attempts})")
+            time.sleep(step.retry.backoff_seconds)
+
+        result = _run_step_attempt(step, attempt_num, state)
+        state.add_attempt(step.name, result)
+
+        if result.timed_out:
+            log(f"[TIMEOUT] {step.name} (attempt {attempt_num})")
+            final_status = StepStatus.TIMED_OUT
+            continue
+
+        if result.exit_code == 0:
+            state.mark_completed(step.name, StepStatus.SUCCEEDED)
+            log(f"[DONE]   {step.name} (exit 0)")
+            return
+        else:
+            log(f"[FAIL]   {step.name} (exit {result.exit_code}, attempt {attempt_num})")
+            final_status = StepStatus.FAILED
+
+    # All attempts exhausted
+    state.mark_completed(step.name, final_status)
+
+    if final_status == StepStatus.TIMED_OUT:
+        log(f"[TIMED_OUT] {step.name} (all attempts exhausted)")
+    else:
+        log(f"[FAILED] {step.name} (all attempts exhausted)")
+
+
+def execute_workflow(
+    workflow: WorkflowDefinition,
+    dry_run: bool = False,
+) -> ExecutionReport:
+    """Execute all steps in the workflow respecting dependencies, concurrency, retries."""
+    # Validate DAG first (topological_sort will raise CycleError if cycles exist)
+    topological_sort(workflow.steps)
+
+    state = ExecutionState(workflow)
+    start_time = datetime.now(timezone.utc)
+    log_lock = threading.Lock()
+
+    def log(msg: str) -> None:
+        with log_lock:
+            print(msg, file=sys.stderr, flush=True)
+
+    if dry_run:
+        topo = topological_sort(workflow.steps)
+        log("Dry run — execution order:")
+        for name in topo:
+            step = workflow.steps[name]
+            deps = f" (after: {', '.join(step.depends_on)})" if step.depends_on else ""
+            log(f"  {name}: {step.command}{deps}")
+            state.results[name].status = StepStatus.SUCCEEDED
+            state.completed.add(name)
+
+        end_time = datetime.now(timezone.utc)
+        return ExecutionReport(
+            workflow_name=workflow.name,
+            start_time=start_time.isoformat(),
+            end_time=end_time.isoformat(),
+            status=WorkflowStatus.SUCCEEDED,
+            steps=state.results,
+        )
+
+    # Install SIGINT handler
+    original_handler = signal.getsignal(signal.SIGINT)
+
+    def _sigint_handler(signum, frame):
+        log("\n[INTERRUPT] Caught SIGINT — shutting down running steps...")
+        state.kill_all_running()
+
+    signal.signal(signal.SIGINT, _sigint_handler)
+
+    try:
+        _execute_loop(workflow, state, log)
+    finally:
+        signal.signal(signal.SIGINT, original_handler)
+
+    end_time = datetime.now(timezone.utc)
+    status = _determine_overall_status(state)
+
+    return ExecutionReport(
+        workflow_name=workflow.name,
+        start_time=start_time.isoformat(),
+        end_time=end_time.isoformat(),
+        status=status,
+        steps=state.results,
+    )
+
+
+def _execute_loop(
+    workflow: WorkflowDefinition,
+    state: ExecutionState,
+    log,
+) -> None:
+    """Main execution loop: schedule ready steps, wait for completions."""
+    threads: dict[str, threading.Thread] = {}
+
+    while not state.is_done():
+        if state.interrupted:
+            # Mark all remaining pending steps as cancelled
+            with state.lock:
+                for name in workflow.steps:
+                    if state.results[name].status == StepStatus.PENDING:
+                        state.results[name].status = StepStatus.CANCELLED
+                        state.cancelled.add(name)
+            break
+
+        ready = state.get_ready()
+
+        # Check for steps that should be cancelled (all deps resolved, none live)
+        with state.lock:
+            to_cancel = get_steps_to_cancel(
+                state.workflow.steps,
+                state.completed,
+                state.running,
+                state.cancelled,
+                state.skipped,
+                state.failed,
+            )
+        if to_cancel:
+            state.mark_cancelled(to_cancel)
+            for c in sorted(to_cancel):
+                log(f"[CANCEL] {c} (all upstream dependencies failed)")
+
+        for step_name in ready:
+            step = workflow.steps[step_name]
+
+            # Evaluate condition
+            if step.condition is not None:
+                with state.lock:
+                    cond_met = step.condition.evaluate(state.results)
+
+                if not cond_met:
+                    log(f"[SKIP]   {step_name} (condition not met)")
+                    state.mark_skipped({step_name})
+
+                    # Propagate skips downstream
+                    with state.lock:
+                        new_skips = resolve_skips(
+                            step_name, workflow.steps, state.completed, state.skipped
+                        )
+                        new_skips -= state.completed | state.running | state.cancelled
+                    if new_skips:
+                        state.mark_skipped(new_skips)
+                        for s in sorted(new_skips):
+                            log(f"[SKIP]   {s} (all dependencies skipped)")
+                    continue
+
+            t = threading.Thread(target=_run_step, args=(step, state, log), daemon=True)
+            threads[step_name] = t
+            t.start()
+
+        # Wait a bit for something to change
+        # Join any completed threads
+        for name in list(threads):
+            t = threads[name]
+            t.join(timeout=0.05)
+            if not t.is_alive():
+                del threads[name]
+
+        if not ready and threads:
+            # Nothing new to schedule, wait for any running thread
+            for t in list(threads.values()):
+                t.join(timeout=0.1)
+                break
+
+        if not ready and not threads and not state.is_done():
+            # Deadlock guard — all remaining steps have unsatisfied deps
+            time.sleep(0.05)
+            if not state.get_ready() and not threads:
+                break
+
+    # Wait for all threads to finish
+    for t in threads.values():
+        t.join(timeout=5.0)
+
+
+def _determine_overall_status(state: ExecutionState) -> WorkflowStatus:
+    has_failed = False
+    has_succeeded = False
+
+    for result in state.results.values():
+        if result.status in (StepStatus.FAILED, StepStatus.TIMED_OUT, StepStatus.CANCELLED):
+            has_failed = True
+        elif result.status == StepStatus.SUCCEEDED:
+            has_succeeded = True
+
+    if state.interrupted:
+        return WorkflowStatus.FAILED
+
+    if has_failed and has_succeeded:
+        return WorkflowStatus.PARTIAL
+    elif has_failed:
+        return WorkflowStatus.FAILED
+    else:
+        return WorkflowStatus.SUCCEEDED
