+"""Tests for flowctl.parser — YAML loading and schema validation."""
+
+import textwrap
+
+import pytest
+import yaml
+
+from flowctl.parser import ValidationError, parse_workflow_file
+
+
+def _write_workflow(tmp_path, content: str):
+    p = tmp_path / "workflow.yaml"
+    p.write_text(textwrap.dedent(content), encoding="utf-8")
+    return p
+
+
+class TestParseWorkflowFile:
+    def test_minimal_valid(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              greet:
+                command: echo hello
+        """)
+        wf = parse_workflow_file(p)
+        assert wf.name == "test"
+        assert "greet" in wf.steps
+        assert wf.steps["greet"].command == "echo hello"
+
+    def test_full_step_features(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: full
+            description: A full workflow
+            steps:
+              build:
+                command: make build
+                retry:
+                  max_attempts: 3
+                  backoff_seconds: 1.5
+                timeout_seconds: 30
+                env:
+                  CC: gcc
+              test:
+                command: make test
+                depends_on:
+                  - build
+                condition:
+                  step: build
+                  status: succeeded
+        """)
+        wf = parse_workflow_file(p)
+        assert wf.description == "A full workflow"
+        build = wf.steps["build"]
+        assert build.retry.max_attempts == 3
+        assert build.retry.backoff_seconds == 1.5
+        assert build.timeout_seconds == 30.0
+        assert build.env == {"CC": "gcc"}
+
+        test = wf.steps["test"]
+        assert test.depends_on == ["build"]
+        assert test.condition is not None
+        assert test.condition.step == "build"
+        assert test.condition.status == "succeeded"
+
+    def test_missing_name(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            steps:
+              a:
+                command: echo a
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("'name' is required" in e for e in exc_info.value.errors)
+
+    def test_missing_steps(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: empty
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("'steps' is required" in e for e in exc_info.value.errors)
+
+    def test_missing_command(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                depends_on: []
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("'command' is required" in e for e in exc_info.value.errors)
+
+    def test_unknown_dependency(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+                depends_on:
+                  - nonexistent
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("unknown step 'nonexistent'" in e for e in exc_info.value.errors)
+
+    def test_self_dependency(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+                depends_on:
+                  - a
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("cannot depend on itself" in e for e in exc_info.value.errors)
+
+    def test_invalid_step_name(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              "bad name!":
+                command: echo hello
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("alphanumeric" in e for e in exc_info.value.errors)
+
+    def test_negative_timeout(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+                timeout_seconds: -5
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("non-negative" in e for e in exc_info.value.errors)
+
+    def test_negative_retry_backoff(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+                retry:
+                  max_attempts: 2
+                  backoff_seconds: -1
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("non-negative" in e for e in exc_info.value.errors)
+
+    def test_invalid_yaml(self, tmp_path):
+        p = tmp_path / "bad.yaml"
+        p.write_text("{{{{not yaml", encoding="utf-8")
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("Invalid YAML" in e for e in exc_info.value.errors)
+
+    def test_condition_unknown_step(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+              b:
+                command: echo b
+                depends_on:
+                  - a
+                condition:
+                  step: nonexistent
+                  status: succeeded
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("unknown step 'nonexistent'" in e for e in exc_info.value.errors)
+
+    def test_condition_not_in_depends(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+              b:
+                command: echo b
+                condition:
+                  step: a
+                  status: succeeded
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("not in depends_on" in e for e in exc_info.value.errors)
+
+    def test_condition_both_status_and_output(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+              b:
+                command: echo b
+                depends_on:
+                  - a
+                condition:
+                  step: a
+                  status: succeeded
+                  output_contains: hello
+        """)
+        with pytest.raises(ValidationError) as exc_info:
+            parse_workflow_file(p)
+        assert any("cannot specify both" in e for e in exc_info.value.errors)
+
+    def test_depends_on_string_shorthand(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo a
+              b:
+                command: echo b
+                depends_on: a
+        """)
+        wf = parse_workflow_file(p)
+        assert wf.steps["b"].depends_on == ["a"]
+
+    def test_output_contains_condition(self, tmp_path):
+        p = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo hello
+              b:
+                command: echo world
+                depends_on:
+                  - a
+                condition:
+                  step: a
+                  output_contains: hello
+        """)
+        wf = parse_workflow_file(p)
+        assert wf.steps["b"].condition.output_contains == "hello"
