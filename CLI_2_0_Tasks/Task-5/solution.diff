+"""Integration tests — full CLI workflow end-to-end."""
+
+import json
+import os
+import textwrap
+
+import pytest
+
+from flowctl.cli import main
+
+
+@pytest.fixture
+def project_dir(tmp_path, monkeypatch):
+    monkeypatch.chdir(tmp_path)
+    return tmp_path
+
+
+class TestCLICommands:
+    def test_version(self, capsys):
+        rc = main(["version"])
+        assert rc == 0
+        assert "flowctl" in capsys.readouterr().out
+
+    def test_no_command_shows_help(self, capsys):
+        rc = main([])
+        assert rc == 1
+
+    def test_validate_valid(self, project_dir):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              a:
+                command: echo hello
+        """), encoding="utf-8")
+        rc = main(["validate", str(wf)])
+        assert rc == 0
+
+    def test_validate_cycle(self, project_dir, capsys):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              a:
+                command: echo a
+                depends_on:
+                  - b
+              b:
+                command: echo b
+                depends_on:
+                  - a
+        """), encoding="utf-8")
+        rc = main(["validate", str(wf)])
+        assert rc == 1
+        assert "Cycle" in capsys.readouterr().err
+
+    def test_validate_missing_file(self, project_dir, capsys):
+        rc = main(["validate", "nonexistent.yaml"])
+        assert rc == 1
+        assert "not found" in capsys.readouterr().err
+
+    def test_run_simple(self, project_dir):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              greet:
+                command: echo hello
+        """), encoding="utf-8")
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}"])
+        assert rc == 0
+        assert report_path.exists()
+
+        data = json.loads(report_path.read_text())
+        assert data["status"] == "succeeded"
+        assert data["steps"]["greet"]["status"] == "succeeded"
+
+    def test_run_failure_exit_code(self, project_dir):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              fail:
+                command: exit 1
+        """), encoding="utf-8")
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}"])
+        assert rc == 2
+
+    def test_run_dry_run(self, project_dir):
+        marker = project_dir / "marker"
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent(f"""\
+            name: test
+            steps:
+              touch:
+                command: touch {marker}
+        """), encoding="utf-8")
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}", "--dry-run"])
+        assert rc == 0
+        assert not marker.exists()
+
+    def test_report_command(self, project_dir, capsys):
+        # Create a report file first
+        report_path = project_dir / "report.json"
+        report_path.write_text(json.dumps({
+            "workflow_name": "demo",
+            "status": "succeeded",
+            "start_time": "T0",
+            "end_time": "T1",
+            "steps": {
+                "a": {
+                    "status": "succeeded",
+                    "attempts": 1,
+                    "final_exit_code": 0,
+                    "total_duration_seconds": 0.5,
+                    "attempt_details": [],
+                },
+            },
+            "summary": {
+                "total": 1,
+                "succeeded": 1,
+                "failed": 0,
+                "timed_out": 0,
+                "cancelled": 0,
+                "skipped": 0,
+            },
+        }), encoding="utf-8")
+
+        rc = main(["report", str(report_path)])
+        assert rc == 0
+        out = capsys.readouterr().out
+        assert "demo" in out
+        assert "succeeded" in out
+
+
+class TestFullWorkflow:
+    def test_multistep_lifecycle(self, project_dir):
+        """Full lifecycle: multi-step with deps, run, verify report."""
+        wf = project_dir / "wf.yaml"
+        out_file = project_dir / "output.txt"
+        wf.write_text(textwrap.dedent(f"""\
+            name: build-and-test
+            description: CI pipeline
+            steps:
+              setup:
+                command: echo setup >> {out_file}
+              build:
+                command: echo build >> {out_file}
+                depends_on:
+                  - setup
+              test-unit:
+                command: echo unit >> {out_file}
+                depends_on:
+                  - build
+              test-integration:
+                command: echo integration >> {out_file}
+                depends_on:
+                  - build
+              deploy:
+                command: echo deploy >> {out_file}
+                depends_on:
+                  - test-unit
+                  - test-integration
+        """), encoding="utf-8")
+
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}"])
+        assert rc == 0
+
+        data = json.loads(report_path.read_text())
+        assert data["status"] == "succeeded"
+        assert data["summary"]["total"] == 5
+        assert data["summary"]["succeeded"] == 5
+
+        # Verify ordering: setup before build, build before tests, tests before deploy
+        lines = out_file.read_text().strip().split("\n")
+        assert lines.index("setup") < lines.index("build")
+        assert lines.index("build") < lines.index("unit")
+        assert lines.index("build") < lines.index("integration")
+
+    def test_failure_cancels_downstream(self, project_dir):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              build:
+                command: exit 1
+              test:
+                command: echo test
+                depends_on:
+                  - build
+              deploy:
+                command: echo deploy
+                depends_on:
+                  - test
+        """), encoding="utf-8")
+
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}"])
+        assert rc == 2
+
+        data = json.loads(report_path.read_text())
+        assert data["steps"]["build"]["status"] == "failed"
+        assert data["steps"]["test"]["status"] == "cancelled"
+        assert data["steps"]["deploy"]["status"] == "cancelled"
+        assert data["summary"]["failed"] == 1
+        assert data["summary"]["cancelled"] == 2
+
+    def test_conditional_skip_workflow(self, project_dir):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              check:
+                command: echo ok
+              deploy:
+                command: echo deploying
+                depends_on:
+                  - check
+                condition:
+                  step: check
+                  status: failed
+              notify:
+                command: echo notified
+                depends_on:
+                  - deploy
+        """), encoding="utf-8")
+
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}"])
+        assert rc == 0
+
+        data = json.loads(report_path.read_text())
+        assert data["steps"]["check"]["status"] == "succeeded"
+        assert data["steps"]["deploy"]["status"] == "skipped"
+        assert data["steps"]["notify"]["status"] == "skipped"
+
+    def test_retry_and_timeout_combined(self, project_dir):
+        wf = project_dir / "wf.yaml"
+        wf.write_text(textwrap.dedent("""\
+            name: test
+            steps:
+              slow:
+                command: "python3 -c \\"import time; time.sleep(10)\\""
+                timeout_seconds: 0.2
+                retry:
+                  max_attempts: 2
+                  backoff_seconds: 0
+        """), encoding="utf-8")
+
+        report_path = project_dir / "report.json"
+        rc = main(["run", str(wf), f"--report={report_path}"])
+        assert rc == 2
+
+        data = json.loads(report_path.read_text())
+        assert data["steps"]["slow"]["status"] == "timed_out"
+        assert data["steps"]["slow"]["attempts"] == 2
