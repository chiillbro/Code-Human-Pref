+"""Execution report serialization and human-readable formatting."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+from flowctl.models import ExecutionReport
+
+
+def write_report(report: ExecutionReport, path: Path) -> None:
+    """Write execution report as JSON to the given path."""
+    path.write_text(
+        json.dumps(report.to_dict(), indent=2, ensure_ascii=False) + "\n",
+        encoding="utf-8",
+    )
+
+
+def load_report(path: Path) -> dict:
+    """Load a JSON execution report from disk."""
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def format_report(data: dict) -> str:
+    """Format a JSON report dict into a human-readable table string."""
+    lines: list[str] = []
+
+    lines.append(f"Workflow: {data.get('workflow_name', '?')}")
+    lines.append(f"Status:   {data.get('status', '?')}")
+    lines.append(f"Started:  {data.get('start_time', '?')}")
+    lines.append(f"Ended:    {data.get('end_time', '?')}")
+    lines.append("")
+
+    # Table header
+    name_w = 20
+    status_w = 12
+    attempts_w = 8
+    duration_w = 12
+    exit_w = 6
+
+    steps = data.get("steps", {})
+    if steps:
+        # Calculate column widths dynamically
+        name_w = max(name_w, max(len(n) for n in steps) + 2)
+
+    header = (
+        f"{'Step':<{name_w}} "
+        f"{'Status':<{status_w}} "
+        f"{'Attempts':>{attempts_w}} "
+        f"{'Duration':>{duration_w}} "
+        f"{'Exit':>{exit_w}}"
+    )
+    lines.append(header)
+    lines.append("-" * len(header))
+
+    for step_name, step_data in steps.items():
+        status = step_data.get("status", "?")
+        attempts = step_data.get("attempts", 0)
+        duration = step_data.get("total_duration_seconds", 0)
+        exit_code = step_data.get("final_exit_code")
+        exit_str = str(exit_code) if exit_code is not None else "-"
+
+        lines.append(
+            f"{step_name:<{name_w}} "
+            f"{status:<{status_w}} "
+            f"{attempts:>{attempts_w}} "
+            f"{duration:>{duration_w}.3f}s "
+            f"{exit_str:>{exit_w}}"
+        )
+
+    lines.append("")
+
+    # Summary
+    summary = data.get("summary", {})
+    if summary:
+        lines.append("Summary:")
+        lines.append(f"  Total: {summary.get('total', 0)}")
+        lines.append(f"  Succeeded: {summary.get('succeeded', 0)}")
+        lines.append(f"  Failed: {summary.get('failed', 0)}")
+        lines.append(f"  Timed Out: {summary.get('timed_out', 0)}")
+        lines.append(f"  Cancelled: {summary.get('cancelled', 0)}")
+        lines.append(f"  Skipped: {summary.get('skipped', 0)}")
+
+    return "\n".join(lines)
