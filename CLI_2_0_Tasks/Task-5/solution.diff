+"""Tests for flowctl.executor — step execution, retries, timeouts, conditions."""
+
+import textwrap
+import time
+
+import pytest
+import yaml
+
+from flowctl.executor import execute_workflow
+from flowctl.models import StepStatus, WorkflowStatus
+from flowctl.parser import parse_workflow_file
+
+
+def _write_workflow(tmp_path, content: str):
+    p = tmp_path / "workflow.yaml"
+    p.write_text(textwrap.dedent(content), encoding="utf-8")
+    return parse_workflow_file(p)
+
+
+class TestBasicExecution:
+    def test_single_step_success(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              hello:
+                command: echo hello
+        """)
+        report = execute_workflow(wf)
+        assert report.status == WorkflowStatus.SUCCEEDED
+        assert report.steps["hello"].status == StepStatus.SUCCEEDED
+        assert report.steps["hello"].attempts[0].stdout.strip() == "hello"
+
+    def test_single_step_failure(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              fail:
+                command: exit 1
+        """)
+        report = execute_workflow(wf)
+        assert report.status == WorkflowStatus.FAILED
+        assert report.steps["fail"].status == StepStatus.FAILED
+        assert report.steps["fail"].final_exit_code == 1
+
+    def test_dependency_ordering(self, tmp_path):
+        """Step B depends on A — B must run after A."""
+        out = tmp_path / "order.txt"
+        wf = _write_workflow(tmp_path, f"""\
+            name: test
+            steps:
+              a:
+                command: echo a >> {out}
+              b:
+                command: echo b >> {out}
+                depends_on:
+                  - a
+        """)
+        report = execute_workflow(wf)
+        assert report.status == WorkflowStatus.SUCCEEDED
+        lines = out.read_text().strip().split("\n")
+        assert lines == ["a", "b"]
+
+    def test_concurrent_independent_steps(self, tmp_path):
+        """Two independent steps should run concurrently."""
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: "python3 -c \\"import time; time.sleep(0.2); print('a')\\""
+              b:
+                command: "python3 -c \\"import time; time.sleep(0.2); print('b')\\""
+        """)
+        start = time.monotonic()
+        report = execute_workflow(wf)
+        elapsed = time.monotonic() - start
+
+        assert report.status == WorkflowStatus.SUCCEEDED
+        # If run concurrently, should take ~0.2s, not ~0.4s
+        assert elapsed < 0.6  # generous margin
+
+
+class TestRetry:
+    def test_retry_succeeds_on_second_attempt(self, tmp_path):
+        # Use a file to track attempts — first fails, second succeeds
+        marker = tmp_path / "attempt"
+        wf = _write_workflow(tmp_path, f"""\
+            name: test
+            steps:
+              flaky:
+                command: "if [ -f {marker} ]; then echo ok; else touch {marker} && exit 1; fi"
+                retry:
+                  max_attempts: 3
+                  backoff_seconds: 0
+        """)
+        report = execute_workflow(wf)
+        assert report.status == WorkflowStatus.SUCCEEDED
+        assert report.steps["flaky"].status == StepStatus.SUCCEEDED
+        assert len(report.steps["flaky"].attempts) == 2
+
+    def test_retry_exhausted(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              always_fail:
+                command: exit 1
+                retry:
+                  max_attempts: 3
+                  backoff_seconds: 0
+        """)
+        report = execute_workflow(wf)
+        assert report.status == WorkflowStatus.FAILED
+        assert report.steps["always_fail"].status == StepStatus.FAILED
+        assert len(report.steps["always_fail"].attempts) == 3
+
+
+class TestTimeout:
+    def test_timeout_kills_step(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              slow:
+                command: "python3 -c \\"import time; time.sleep(10)\\""
+                timeout_seconds: 0.3
+        """)
+        start = time.monotonic()
+        report = execute_workflow(wf)
+        elapsed = time.monotonic() - start
+
+        assert report.steps["slow"].status == StepStatus.TIMED_OUT
+        assert report.steps["slow"].attempts[0].timed_out is True
+        assert elapsed < 3.0  # should not wait 10s
+
+    def test_timeout_with_retry(self, tmp_path):
+        """Each retry attempt gets its own fresh timeout."""
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              slow:
+                command: "python3 -c \\"import time; time.sleep(10)\\""
+                timeout_seconds: 0.2
+                retry:
+                  max_attempts: 2
+                  backoff_seconds: 0
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["slow"].status == StepStatus.TIMED_OUT
+        assert len(report.steps["slow"].attempts) == 2
+        for attempt in report.steps["slow"].attempts:
+            assert attempt.timed_out is True
+
+
+class TestCancellation:
+    def test_downstream_cancelled_on_failure(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: exit 1
+              b:
+                command: echo b
+                depends_on:
+                  - a
+              c:
+                command: echo c
+                depends_on:
+                  - b
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["a"].status == StepStatus.FAILED
+        assert report.steps["b"].status == StepStatus.CANCELLED
+        assert report.steps["c"].status == StepStatus.CANCELLED
+
+    def test_partial_cancel_diamond(self, tmp_path):
+        """In a diamond, if one branch fails but the other succeeds,
+        the merge step should still run (it has a live dependency)."""
+        wf = _write_workflow(tmp_path, f"""\
+            name: test
+            steps:
+              root:
+                command: echo root
+              left:
+                command: exit 1
+                depends_on:
+                  - root
+              right:
+                command: echo right
+                depends_on:
+                  - root
+              merge:
+                command: echo merge
+                depends_on:
+                  - left
+                  - right
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["root"].status == StepStatus.SUCCEEDED
+        assert report.steps["left"].status == StepStatus.FAILED
+        assert report.steps["right"].status == StepStatus.SUCCEEDED
+        # merge should NOT be cancelled — right is a live dependency
+        assert report.steps["merge"].status != StepStatus.CANCELLED
+
+
+class TestConditions:
+    def test_condition_met(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo hello
+              b:
+                command: echo world
+                depends_on:
+                  - a
+                condition:
+                  step: a
+                  status: succeeded
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["b"].status == StepStatus.SUCCEEDED
+
+    def test_condition_not_met_skips(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo hello
+              b:
+                command: echo world
+                depends_on:
+                  - a
+                condition:
+                  step: a
+                  status: failed
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["a"].status == StepStatus.SUCCEEDED
+        assert report.steps["b"].status == StepStatus.SKIPPED
+
+    def test_skip_propagation(self, tmp_path):
+        """When B is skipped, C (which depends only on B) should also be skipped."""
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo hello
+              b:
+                command: echo world
+                depends_on:
+                  - a
+                condition:
+                  step: a
+                  status: failed
+              c:
+                command: echo end
+                depends_on:
+                  - b
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["b"].status == StepStatus.SKIPPED
+        assert report.steps["c"].status == StepStatus.SKIPPED
+
+    def test_output_contains_condition(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: echo "DEPLOY_READY"
+              b:
+                command: echo deploying
+                depends_on:
+                  - a
+                condition:
+                  step: a
+                  output_contains: DEPLOY_READY
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["b"].status == StepStatus.SUCCEEDED
+
+
+class TestDryRun:
+    def test_dry_run_no_execution(self, tmp_path):
+        marker = tmp_path / "executed"
+        wf = _write_workflow(tmp_path, f"""\
+            name: test
+            steps:
+              a:
+                command: touch {marker}
+        """)
+        report = execute_workflow(wf, dry_run=True)
+        assert report.status == WorkflowStatus.SUCCEEDED
+        assert not marker.exists()
+
+
+class TestEnvVars:
+    def test_env_injected(self, tmp_path):
+        wf = _write_workflow(tmp_path, """\
+            name: test
+            steps:
+              a:
+                command: "python3 -c \\"import os; print(os.environ['MY_VAR'])\\""
+                env:
+                  MY_VAR: hello_flowctl
+        """)
+        report = execute_workflow(wf)
+        assert report.steps["a"].status == StepStatus.SUCCEEDED
+        assert "hello_flowctl" in report.steps["a"].attempts[0].stdout
