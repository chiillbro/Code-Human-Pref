--- /dev/null
+++ b/src/flowctl/models.py
@@ -0,0 +1,160 @@
+"""Data models for flowctl workflows, steps, and execution reports."""
+
+from __future__ import annotations
+
+import enum
+from dataclasses import dataclass, field
+from typing import Any
+
+
+class StepStatus(enum.Enum):
+    PENDING = "pending"
+    RUNNING = "running"
+    SUCCEEDED = "succeeded"
+    FAILED = "failed"
+    TIMED_OUT = "timed_out"
+    CANCELLED = "cancelled"
+    SKIPPED = "skipped"
+
+
+class WorkflowStatus(enum.Enum):
+    SUCCEEDED = "succeeded"
+    FAILED = "failed"
+    PARTIAL = "partial"
+
+
+@dataclass
+class RetryConfig:
+    max_attempts: int = 1
+    backoff_seconds: float = 0.0
+
+
+@dataclass
+class Condition:
+    """Condition that gates a step based on an upstream dependency's status or output.
+
+    Supported forms:
+      - step: <name>, status: succeeded|failed|skipped
+      - step: <name>, output_contains: <substring>
+    """
+
+    step: str
+    status: str | None = None
+    output_contains: str | None = None
+
+    def evaluate(self, step_results: dict[str, StepResult]) -> bool:
+        result = step_results.get(self.step)
+        if result is None:
+            return False
+
+        if self.status is not None:
+            return result.status.value == self.status
+
+        if self.output_contains is not None:
+            last_attempt = result.attempts[-1] if result.attempts else None
+            if last_attempt is None:
+                return False
+            return self.output_contains in last_attempt.stdout
+
+        # No condition criteria -> always true
+        return True
+
+
+@dataclass
+class StepDefinition:
+    name: str
+    command: str
+    depends_on: list[str] = field(default_factory=list)
+    retry: RetryConfig = field(default_factory=RetryConfig)
+    timeout_seconds: float | None = None
+    condition: Condition | None = None
+    env: dict[str, str] = field(default_factory=dict)
+
+
+@dataclass
+class WorkflowDefinition:
+    name: str
+    description: str
+    steps: dict[str, StepDefinition] = field(default_factory=dict)
+
+
+@dataclass
+class AttemptResult:
+    attempt_number: int
+    duration_seconds: float
+    exit_code: int | None
+    stdout: str
+    stderr: str
+    timed_out: bool = False
+
+
+@dataclass
+class StepResult:
+    name: str
+    status: StepStatus = StepStatus.PENDING
+    attempts: list[AttemptResult] = field(default_factory=list)
+
+    @property
+    def final_exit_code(self) -> int | None:
+        if self.attempts:
+            return self.attempts[-1].exit_code
+        return None
+
+    @property
+    def total_duration(self) -> float:
+        return sum(a.duration_seconds for a in self.attempts)
+
+
+@dataclass
+class ExecutionReport:
+    workflow_name: str
+    start_time: str
+    end_time: str
+    status: WorkflowStatus
+    steps: dict[str, StepResult] = field(default_factory=dict)
+
+    @property
+    def summary(self) -> dict[str, Any]:
+        counts: dict[str, int] = {
+            "total": len(self.steps),
+            "succeeded": 0,
+            "failed": 0,
+            "timed_out": 0,
+            "cancelled": 0,
+            "skipped": 0,
+        }
+        for result in self.steps.values():
+            key = result.status.value
+            if key in counts:
+                counts[key] += 1
+        return counts
+
+    def to_dict(self) -> dict[str, Any]:
+        steps_dict: dict[str, Any] = {}
+        for name, result in self.steps.items():
+            steps_dict[name] = {
+                "status": result.status.value,
+                "attempts": len(result.attempts),
+                "final_exit_code": result.final_exit_code,
+                "total_duration_seconds": round(result.total_duration, 3),
+                "attempt_details": [
+                    {
+                        "attempt": a.attempt_number,
+                        "duration_seconds": round(a.duration_seconds, 3),
+                        "exit_code": a.exit_code,
+                        "stdout": a.stdout,
+                        "stderr": a.stderr,
+                        "timed_out": a.timed_out,
+                    }
+                    for a in result.attempts
+                ],
+            }
+
+        return {
+            "workflow_name": self.workflow_name,
+            "start_time": self.start_time,
+            "end_time": self.end_time,
+            "status": self.status.value,
+            "steps": steps_dict,
+            "summary": self.summary,
+        }
