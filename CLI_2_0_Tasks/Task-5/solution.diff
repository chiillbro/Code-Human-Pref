+"""Tests for flowctl.models — data model behavior."""
+
+from flowctl.models import (
+    AttemptResult,
+    Condition,
+    ExecutionReport,
+    StepResult,
+    StepStatus,
+    WorkflowStatus,
+)
+
+
+class TestConditionEvaluate:
+    def test_status_match(self):
+        results = {
+            "a": StepResult(name="a", status=StepStatus.SUCCEEDED),
+        }
+        cond = Condition(step="a", status="succeeded")
+        assert cond.evaluate(results) is True
+
+    def test_status_mismatch(self):
+        results = {
+            "a": StepResult(name="a", status=StepStatus.FAILED),
+        }
+        cond = Condition(step="a", status="succeeded")
+        assert cond.evaluate(results) is False
+
+    def test_output_contains_match(self):
+        results = {
+            "a": StepResult(
+                name="a",
+                status=StepStatus.SUCCEEDED,
+                attempts=[
+                    AttemptResult(
+                        attempt_number=1,
+                        duration_seconds=0.1,
+                        exit_code=0,
+                        stdout="DEPLOY_READY flag set",
+                        stderr="",
+                    )
+                ],
+            ),
+        }
+        cond = Condition(step="a", output_contains="DEPLOY_READY")
+        assert cond.evaluate(results) is True
+
+    def test_output_contains_no_match(self):
+        results = {
+            "a": StepResult(
+                name="a",
+                status=StepStatus.SUCCEEDED,
+                attempts=[
+                    AttemptResult(
+                        attempt_number=1,
+                        duration_seconds=0.1,
+                        exit_code=0,
+                        stdout="nothing here",
+                        stderr="",
+                    )
+                ],
+            ),
+        }
+        cond = Condition(step="a", output_contains="DEPLOY_READY")
+        assert cond.evaluate(results) is False
+
+    def test_missing_step(self):
+        cond = Condition(step="nonexistent", status="succeeded")
+        assert cond.evaluate({}) is False
+
+    def test_no_attempts(self):
+        results = {
+            "a": StepResult(name="a", status=StepStatus.SUCCEEDED),
+        }
+        cond = Condition(step="a", output_contains="hello")
+        assert cond.evaluate(results) is False
+
+
+class TestStepResult:
+    def test_final_exit_code(self):
+        r = StepResult(
+            name="x",
+            attempts=[
+                AttemptResult(1, 0.1, 1, "", ""),
+                AttemptResult(2, 0.1, 0, "", ""),
+            ],
+        )
+        assert r.final_exit_code == 0
+
+    def test_final_exit_code_no_attempts(self):
+        r = StepResult(name="x")
+        assert r.final_exit_code is None
+
+    def test_total_duration(self):
+        r = StepResult(
+            name="x",
+            attempts=[
+                AttemptResult(1, 1.5, 0, "", ""),
+                AttemptResult(2, 2.5, 0, "", ""),
+            ],
+        )
+        assert r.total_duration == 4.0
+
+
+class TestExecutionReport:
+    def test_summary_counts(self):
+        report = ExecutionReport(
+            workflow_name="test",
+            start_time="T0",
+            end_time="T1",
+            status=WorkflowStatus.PARTIAL,
+            steps={
+                "a": StepResult(name="a", status=StepStatus.SUCCEEDED),
+                "b": StepResult(name="b", status=StepStatus.FAILED),
+                "c": StepResult(name="c", status=StepStatus.SKIPPED),
+                "d": StepResult(name="d", status=StepStatus.CANCELLED),
+            },
+        )
+        s = report.summary
+        assert s["total"] == 4
+        assert s["succeeded"] == 1
+        assert s["failed"] == 1
+        assert s["skipped"] == 1
+        assert s["cancelled"] == 1
+
+    def test_to_dict_structure(self):
+        report = ExecutionReport(
+            workflow_name="test",
+            start_time="T0",
+            end_time="T1",
+            status=WorkflowStatus.SUCCEEDED,
+            steps={"a": StepResult(name="a", status=StepStatus.SUCCEEDED)},
+        )
+        d = report.to_dict()
+        assert d["workflow_name"] == "test"
+        assert "steps" in d
+        assert "summary" in d
+        assert d["steps"]["a"]["status"] == "succeeded"
