+++ b/src/flowctl/parser.py
@@ -0,0 +1,213 @@
+"""YAML workflow parser with schema validation."""
+
+from __future__ import annotations
+
+import re
+import yaml
+from pathlib import Path
+
+from flowctl.models import (
+    Condition,
+    RetryConfig,
+    StepDefinition,
+    WorkflowDefinition,
+)
+
+_STEP_NAME_RE = re.compile(r"^[a-zA-Z0-9_-]+$")
+
+_VALID_CONDITION_STATUSES = {"succeeded", "failed", "skipped"}
+
+
+class ValidationError(Exception):
+    def __init__(self, errors: list[str]) -> None:
+        self.errors = errors
+        super().__init__(f"Validation failed with {len(errors)} error(s)")
+
+
+def parse_workflow_file(path: Path) -> WorkflowDefinition:
+    """Load a YAML workflow file and return a validated WorkflowDefinition."""
+    try:
+        raw = yaml.safe_load(path.read_text(encoding="utf-8"))
+    except yaml.YAMLError as exc:
+        raise ValidationError([f"Invalid YAML in {path}: {exc}"])
+
+    if not isinstance(raw, dict):
+        raise ValidationError([f"{path}: Expected a YAML mapping at top level"])
+
+    return _parse_workflow(raw, str(path))
+
+
+def _parse_workflow(raw: dict, source: str) -> WorkflowDefinition:
+    errors: list[str] = []
+
+    # --- workflow-level fields ---
+    name = raw.get("name")
+    if not name or not isinstance(name, str):
+        errors.append(f"{source}: 'name' is required and must be a string")
+        name = "<unknown>"
+
+    description = raw.get("description", "")
+    if not isinstance(description, str):
+        errors.append(f"{source}: 'description' must be a string")
+        description = ""
+
+    raw_steps = raw.get("steps")
+    if not isinstance(raw_steps, dict) or len(raw_steps) == 0:
+        errors.append(f"{source}: 'steps' is required and must be a non-empty mapping")
+        if errors:
+            raise ValidationError(errors)
+
+    # --- parse individual steps ---
+    steps: dict[str, StepDefinition] = {}
+    step_names: set[str] = set(raw_steps.keys())
+
+    for step_name, step_raw in raw_steps.items():
+        step_errors = _parse_step(step_name, step_raw, step_names, source)
+        if isinstance(step_errors, list):
+            errors.extend(step_errors)
+        else:
+            steps[step_name] = step_errors
+
+    if errors:
+        raise ValidationError(errors)
+
+    return WorkflowDefinition(name=name, description=description, steps=steps)
+
+
+def _parse_step(
+    name: str,
+    raw: dict | None,
+    all_step_names: set[str],
+    source: str,
+) -> StepDefinition | list[str]:
+    """Parse a single step. Returns StepDefinition on success or list of error strings."""
+    errors: list[str] = []
+    prefix = f"{source}: step '{name}'"
+
+    if not _STEP_NAME_RE.match(name):
+        errors.append(
+            f"{prefix}: Step name must contain only alphanumeric characters, "
+            "hyphens, and underscores"
+        )
+
+    if not isinstance(raw, dict):
+        errors.append(f"{prefix}: Step must be a mapping")
+        return errors
+
+    # command
+    command = raw.get("command")
+    if not command or not isinstance(command, str):
+        errors.append(f"{prefix}: 'command' is required and must be a string")
+        command = ""
+
+    # depends_on
+    depends_on: list[str] = []
+    raw_deps = raw.get("depends_on")
+    if raw_deps is not None:
+        if isinstance(raw_deps, str):
+            raw_deps = [raw_deps]
+        if not isinstance(raw_deps, list):
+            errors.append(f"{prefix}: 'depends_on' must be a list of step names")
+        else:
+            for dep in raw_deps:
+                if not isinstance(dep, str):
+                    errors.append(f"{prefix}: dependency must be a string, got {type(dep).__name__}")
+                elif dep not in all_step_names:
+                    errors.append(f"{prefix}: depends on unknown step '{dep}'")
+                elif dep == name:
+                    errors.append(f"{prefix}: step cannot depend on itself")
+                else:
+                    depends_on.append(dep)
+
+    # retry
+    retry = RetryConfig()
+    raw_retry = raw.get("retry")
+    if raw_retry is not None:
+        if not isinstance(raw_retry, dict):
+            errors.append(f"{prefix}: 'retry' must be a mapping")
+        else:
+            ma = raw_retry.get("max_attempts", 1)
+            if not isinstance(ma, int) or ma < 1:
+                errors.append(f"{prefix}: retry.max_attempts must be a positive integer")
+            else:
+                retry.max_attempts = ma
+
+            bs = raw_retry.get("backoff_seconds", 0)
+            if not isinstance(bs, (int, float)) or bs < 0:
+                errors.append(f"{prefix}: retry.backoff_seconds must be a non-negative number")
+            else:
+                retry.backoff_seconds = float(bs)
+
+    # timeout_seconds
+    timeout: float | None = None
+    raw_timeout = raw.get("timeout_seconds")
+    if raw_timeout is not None:
+        if not isinstance(raw_timeout, (int, float)) or raw_timeout < 0:
+            errors.append(f"{prefix}: 'timeout_seconds' must be a non-negative number")
+        else:
+            timeout = float(raw_timeout)
+
+    # condition
+    condition: Condition | None = None
+    raw_cond = raw.get("condition")
+    if raw_cond is not None:
+        if not isinstance(raw_cond, dict):
+            errors.append(f"{prefix}: 'condition' must be a mapping")
+        else:
+            cond_step = raw_cond.get("step")
+            if not cond_step or not isinstance(cond_step, str):
+                errors.append(f"{prefix}: condition.step is required")
+            elif cond_step not in all_step_names:
+                errors.append(f"{prefix}: condition references unknown step '{cond_step}'")
+            elif cond_step not in depends_on:
+                errors.append(
+                    f"{prefix}: condition references step '{cond_step}' which is not in depends_on"
+                )
+
+            cond_status = raw_cond.get("status")
+            cond_output = raw_cond.get("output_contains")
+
+            if cond_status is not None and cond_output is not None:
+                errors.append(f"{prefix}: condition cannot specify both 'status' and 'output_contains'")
+            elif cond_status is None and cond_output is None:
+                errors.append(f"{prefix}: condition must specify 'status' or 'output_contains'")
+
+            if cond_status is not None:
+                if cond_status not in _VALID_CONDITION_STATUSES:
+                    errors.append(
+                        f"{prefix}: condition.status must be one of "
+                        f"{sorted(_VALID_CONDITION_STATUSES)}"
+                    )
+
+            if cond_output is not None and not isinstance(cond_output, str):
+                errors.append(f"{prefix}: condition.output_contains must be a string")
+
+            if not errors or cond_step:
+                condition = Condition(
+                    step=cond_step if isinstance(cond_step, str) else "",
+                    status=cond_status,
+                    output_contains=cond_output if isinstance(cond_output, str) else None,
+                )
+
+    # env
+    env: dict[str, str] = {}
+    raw_env = raw.get("env")
+    if raw_env is not None:
+        if not isinstance(raw_env, dict):
+            errors.append(f"{prefix}: 'env' must be a mapping")
+        else:
+            for k, v in raw_env.items():
+                env[str(k)] = str(v)
+
+    if errors:
+        return errors
+
+    return StepDefinition(
+        name=name,
+        command=command,
+        depends_on=depends_on,
+        retry=retry,
+        timeout_seconds=timeout,
+        condition=condition,
+        env=env,
+    )
