index 0000000..816d55b
--- /dev/null
+++ b/tests/test_dag.py
@@ -0,0 +1,296 @@
+"""Tests for flowctl.dag — cycle detection, topological sort, subgraph resolution."""
+
+import pytest
+
+from flowctl.dag import (
+    CycleError,
+    build_graph,
+    get_downstream,
+    get_ready_steps,
+    get_steps_to_cancel,
+    resolve_cancellations,
+    resolve_skips,
+    topological_sort,
+)
+from flowctl.models import RetryConfig, StepDefinition
+
+
+def _step(name: str, deps: list[str] | None = None) -> StepDefinition:
+    return StepDefinition(name=name, command=f"echo {name}", depends_on=deps or [])
+
+
+class TestTopologicalSort:
+    def test_linear_chain(self):
+        steps = {
+            "a": _step("a"),
+            "b": _step("b", ["a"]),
+            "c": _step("c", ["b"]),
+        }
+        order = topological_sort(steps)
+        assert order.index("a") < order.index("b") < order.index("c")
+
+    def test_diamond(self):
+        steps = {
+            "a": _step("a"),
+            "b": _step("b", ["a"]),
+            "c": _step("c", ["a"]),
+            "d": _step("d", ["b", "c"]),
+        }
+        order = topological_sort(steps)
+        assert order.index("a") < order.index("b")
+        assert order.index("a") < order.index("c")
+        assert order.index("b") < order.index("d")
+        assert order.index("c") < order.index("d")
+
+    def test_independent_steps(self):
+        steps = {
+            "a": _step("a"),
+            "b": _step("b"),
+            "c": _step("c"),
+        }
+        order = topological_sort(steps)
+        assert set(order) == {"a", "b", "c"}
+
+    def test_simple_cycle(self):
+        steps = {
+            "a": _step("a", ["b"]),
+            "b": _step("b", ["a"]),
+        }
+        with pytest.raises(CycleError) as exc_info:
+            topological_sort(steps)
+        assert set(exc_info.value.cycle_members) == {"a", "b"}
+
+    def test_long_chain_cycle(self):
+        steps = {
+            "a": _step("a", ["c"]),
+            "b": _step("b", ["a"]),
+            "c": _step("c", ["b"]),
+        }
+        with pytest.raises(CycleError) as exc_info:
+            topological_sort(steps)
+        assert set(exc_info.value.cycle_members) == {"a", "b", "c"}
+
+    def test_multiple_disjoint_cycles(self):
+        steps = {
+            "a": _step("a", ["b"]),
+            "b": _step("b", ["a"]),
+            "c": _step("c", ["d"]),
+            "d": _step("d", ["c"]),
+        }
+        with pytest.raises(CycleError) as exc_info:
+            topological_sort(steps)
+        assert set(exc_info.value.cycle_members) == {"a", "b", "c", "d"}
+
+    def test_self_reference_cycle(self):
+        steps = {
+            "a": _step("a", ["a"]),
+        }
+        with pytest.raises(CycleError) as exc_info:
+            topological_sort(steps)
+        assert "a" in exc_info.value.cycle_members
+
+    def test_partial_cycle(self):
+        """A→B→C→B cycle, D depends on A (D is not in the cycle)."""
+        steps = {
+            "a": _step("a"),
+            "b": _step("b", ["a", "c"]),
+            "c": _step("c", ["b"]),
+            "d": _step("d", ["a"]),
+        }
+        with pytest.raises(CycleError) as exc_info:
+            topological_sort(steps)
+        assert "b" in exc_info.value.cycle_members
+        assert "c" in exc_info.value.cycle_members
+        # d and a are not part of the cycle
+        assert "a" not in exc_info.value.cycle_members
+
+
+class TestGetDownstream:
+    def test_no_downstream(self):
+        steps = {"a": _step("a")}
+        assert get_downstream("a", steps) == set()
+
+    def test_linear(self):
+        steps = {
+            "a": _step("a"),
+            "b": _step("b", ["a"]),
+            "c": _step("c", ["b"]),
+        }
+        assert get_downstream("a", steps) == {"b", "c"}
+        assert get_downstream("b", steps) == {"c"}
+
+    def test_diamond(self):
+        steps = {
+            "a": _step("a"),
+            "b": _step("b", ["a"]),
+            "c": _step("c", ["a"]),
+            "d": _step("d", ["b", "c"]),
+        }
+        assert get_downstream("a", steps) == {"b", "c", "d"}
+        assert get_downstream("b", steps) == {"d"}
