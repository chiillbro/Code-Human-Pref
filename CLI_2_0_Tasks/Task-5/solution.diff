+        }
+        # Cancelled dep with no completed dep means step is not ready
+        ready = get_ready_steps(steps, set(), set(), {"a"}, set(), set())
+        assert "b" not in ready
+
+    def test_skipped_dep_satisfies(self):
+        steps = {
+            "a": _step("a"),
+            "b": _step("b", ["a"]),
+        }
+        ready = get_ready_steps(steps, set(), set(), set(), {"a"})
+        assert "b" in ready
+
+    def test_failed_dep_with_live_sibling(self):
+        """If one dep failed but another completed, step is ready."""
+        steps = {
+            "a": _step("a"),
+            "c": _step("c"),
+            "b": _step("b", ["a", "c"]),
+        }
+        ready = get_ready_steps(steps, {"c"}, set(), set(), set(), {"a"})
+        assert "b" in ready
+
+    def test_all_deps_failed_not_ready(self):
+        """If all deps failed, step is not ready (should be cancelled instead)."""
