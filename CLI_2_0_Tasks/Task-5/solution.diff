index 0000000..085f51a
--- /dev/null
+++ b/src/flowctl/dag.py
@@ -0,0 +1,232 @@
+"""DAG construction, cycle detection, topological sort, and subgraph resolution."""
+
+from __future__ import annotations
+
+from collections import deque
+
+from flowctl.models import StepDefinition
+
+
+class CycleError(Exception):
+    """Raised when the dependency graph contains a cycle."""
+
+    def __init__(self, cycle_members: list[str]) -> None:
+        self.cycle_members = cycle_members
+        super().__init__(
+            f"Dependency cycle detected among steps: {', '.join(cycle_members)}"
+        )
+
+
+def build_graph(steps: dict[str, StepDefinition]) -> tuple[dict[str, list[str]], dict[str, int]]:
+    """Build adjacency list and in-degree map from step definitions.
+
+    Returns (adjacency, in_degree) where adjacency[parent] = [children that depend on parent].
+    """
+    adjacency: dict[str, list[str]] = {name: [] for name in steps}
+    in_degree: dict[str, int] = {name: 0 for name in steps}
+
+    for name, step in steps.items():
+        for dep in step.depends_on:
+            adjacency[dep].append(name)
+            in_degree[name] += 1
+
+    return adjacency, in_degree
+
+
+def topological_sort(steps: dict[str, StepDefinition]) -> list[str]:
+    """Return steps in topological order using Kahn's algorithm.
+
+    Raises CycleError with the participating step names if a cycle exists.
+    """
+    adjacency, in_degree = build_graph(steps)
+
+    queue: deque[str] = deque()
+    for name, deg in in_degree.items():
+        if deg == 0:
+            queue.append(name)
+
+    order: list[str] = []
+    while queue:
+        current = queue.popleft()
+        order.append(current)
+        for child in adjacency[current]:
+            in_degree[child] -= 1
+            if in_degree[child] == 0:
+                queue.append(child)
+
+    if len(order) != len(steps):
+        # Find which steps are in the cycle(s)
+        cycle_members = sorted(name for name, deg in in_degree.items() if deg > 0)
+        raise CycleError(cycle_members)
+
+    return order
+
+
+def get_downstream(step_name: str, steps: dict[str, StepDefinition]) -> set[str]:
+    """Return all steps that transitively depend on `step_name`."""
+    adjacency, _ = build_graph(steps)
+    visited: set[str] = set()
+    queue: deque[str] = deque([step_name])
+
+    while queue:
+        current = queue.popleft()
+        for child in adjacency[current]:
+            if child not in visited:
+                visited.add(child)
+                queue.append(child)
+
+    return visited
+
+
+def get_ready_steps(
+    steps: dict[str, StepDefinition],
+    completed: set[str],
+    running: set[str],
+    cancelled: set[str],
+    skipped: set[str],
+    failed: set[str] | None = None,
+) -> list[str]:
+    """Return step names whose dependencies are all satisfied and at least one succeeded/skipped.
+
+    A step is ready when:
+    - It's not already completed, running, cancelled, skipped, or failed
+    - All its depends_on entries are resolved (completed, skipped, or failed)
+    - At least one depends_on entry succeeded (completed) or was skipped
+    """
+    if failed is None:
+        failed = set()
+    ready: list[str] = []
+    resolved = completed | cancelled | skipped | failed
+
+    for name, step in steps.items():
+        if name in completed or name in running or name in cancelled or name in skipped or name in failed:
+            continue
+
+        if not step.depends_on:
+            ready.append(name)
+            continue
+
+        all_resolved = all(dep in resolved for dep in step.depends_on)
+        if not all_resolved:
+            continue
+
+        # At least one dep must have succeeded or been skipped (not all failed/cancelled)
+        has_live = any(dep in completed or dep in skipped for dep in step.depends_on)
+        if has_live:
+            ready.append(name)
+
+    return ready
+
+
+def get_steps_to_cancel(
+    steps: dict[str, StepDefinition],
+    completed: set[str],
+    running: set[str],
+    cancelled: set[str],
+    skipped: set[str],
+    failed: set[str],
+) -> set[str]:
+    """Return steps that should be cancelled because all deps are resolved and none succeeded/skipped.
+
+    Iterates until stable to handle cascading cancellations (e.g., A fails, B cancelled, C cancelled).
+    """
+    all_cancelled = set(cancelled)
+    new_cancels: set[str] = set()
+
+    while True:
+        resolved = completed | all_cancelled | skipped | failed
+        found: set[str] = set()
+
+        for name, step in steps.items():
+            if name in completed or name in running or name in all_cancelled or name in skipped or name in failed:
+                continue
+
+            if not step.depends_on:
+                continue
+
+            all_resolved = all(dep in resolved for dep in step.depends_on)
+            if not all_resolved:
+                continue
+
+            has_live = any(dep in completed or dep in skipped for dep in step.depends_on)
+            if not has_live:
+                found.add(name)
+
+        if not found:
+            break
+
+        new_cancels |= found
+        all_cancelled |= found
+
+    return new_cancels
+
+
+def resolve_cancellations(
+    failed_step: str,
+    steps: dict[str, StepDefinition],
+    completed: set[str],
+    skipped: set[str],
+    running: set[str] | None = None,
+) -> set[str]:
+    """Determine which steps should be cancelled due to a step failure.
+
+    A downstream step is cancelled if ALL paths from roots to it pass through
+    the failed step (i.e., it has no alternative satisfied or potentially-live
+    dependency path). Running deps are treated as potentially live.
+    """
+    if running is None:
+        running = set()
+
+    downstream = get_downstream(failed_step, steps)
+    to_cancel: set[str] = set()
+
+    for candidate in downstream:
+        step = steps[candidate]
+        # If every dependency is either the failed step, already cancelled,
+        # or itself downstream of the failed step, cancel this step.
+        # Running deps are potentially live — don't cancel yet.
+        has_live_dep = False
+        for dep in step.depends_on:
+            if dep == failed_step or dep in to_cancel:
+                continue
+            if dep in completed or dep in skipped or dep in running:
+                has_live_dep = True
+                break
+
+        if not has_live_dep:
+            to_cancel.add(candidate)
+
+    return to_cancel
+
+
+def resolve_skips(
+    skipped_step: str,
+    steps: dict[str, StepDefinition],
+    completed: set[str],
+    already_skipped: set[str],
+) -> set[str]:
+    """Determine which downstream steps should be skipped.
+
+    A downstream step is skipped only if ALL its dependencies are skipped
+    (no live/completed dependency exists).
+    """
+    downstream = get_downstream(skipped_step, steps)
+    new_skips: set[str] = set()
+    all_skipped = already_skipped | {skipped_step}
+
+    # Iterate in topological order to propagate correctly
+    topo = topological_sort(steps)
+    for name in topo:
+        if name not in downstream:
+            continue
+
+        step = steps[name]
+        all_deps_skipped = all(
+            dep in all_skipped or dep in new_skips for dep in step.depends_on
+        )
+
+        if all_deps_skipped:
+            new_skips.add(name)
+            all_skipped.add(name)
+
+    return new_skips
diff --git a/src/flowctl/executor.py b/src/flowctl/executor.py
