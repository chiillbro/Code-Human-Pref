@@ -0,0 +1,105 @@
+"""Tests for flowctl.reporter — JSON report writing and formatting."""
+
+import json
+
+from flowctl.models import (
+    AttemptResult,
+    ExecutionReport,
+    StepResult,
+    StepStatus,
+    WorkflowStatus,
+)
+from flowctl.reporter import format_report, load_report, write_report
+
+
+def _make_report() -> ExecutionReport:
+    steps = {
+        "build": StepResult(
+            name="build",
+            status=StepStatus.SUCCEEDED,
+            attempts=[
+                AttemptResult(
+                    attempt_number=1,
+                    duration_seconds=1.234,
+                    exit_code=0,
+                    stdout="compiled",
+                    stderr="",
+                )
+            ],
+        ),
+        "test": StepResult(
+            name="test",
+            status=StepStatus.FAILED,
+            attempts=[
+                AttemptResult(
+                    attempt_number=1,
+                    duration_seconds=0.5,
+                    exit_code=1,
+                    stdout="FAIL",
+                    stderr="assertion error",
+                )
+            ],
+        ),
+    }
+    return ExecutionReport(
+        workflow_name="ci",
+        start_time="2026-04-19T10:00:00+00:00",
+        end_time="2026-04-19T10:00:02+00:00",
+        status=WorkflowStatus.PARTIAL,
+        steps=steps,
+    )
+
+
+class TestWriteReport:
+    def test_roundtrip(self, tmp_path):
+        report = _make_report()
+        path = tmp_path / "report.json"
+        write_report(report, path)
+
+        data = load_report(path)
+        assert data["workflow_name"] == "ci"
+        assert data["status"] == "partial"
+        assert data["steps"]["build"]["status"] == "succeeded"
+        assert data["steps"]["test"]["status"] == "failed"
+        assert data["summary"]["total"] == 2
+        assert data["summary"]["succeeded"] == 1
+        assert data["summary"]["failed"] == 1
+
+    def test_json_structure(self, tmp_path):
+        report = _make_report()
+        path = tmp_path / "report.json"
+        write_report(report, path)
+
+        raw = json.loads(path.read_text())
+        build_details = raw["steps"]["build"]["attempt_details"]
+        assert len(build_details) == 1
+        assert build_details[0]["stdout"] == "compiled"
+        assert build_details[0]["exit_code"] == 0
+
+
+class TestFormatReport:
+    def test_contains_key_info(self):
+        report = _make_report()
+        data = report.to_dict()
+        text = format_report(data)
+
+        assert "ci" in text
+        assert "partial" in text
+        assert "build" in text
+        assert "test" in text
+        assert "succeeded" in text
+        assert "failed" in text
+        assert "Summary:" in text
+
+    def test_empty_steps(self):
+        data = {
+            "workflow_name": "empty",
+            "status": "succeeded",
+            "start_time": "T0",
+            "end_time": "T1",
+            "steps": {},
+            "summary": {"total": 0, "succeeded": 0, "failed": 0, "timed_out": 0, "cancelled": 0, "skipped": 0},
+        }
+        text = format_report(data)
+        assert "empty" in text
+        assert "Total: 0" in text
