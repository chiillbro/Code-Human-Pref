@@ -0,0 +1,162 @@
+"""CLI entry point for flowctl."""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from pathlib import Path
+
+from flowctl import __version__
+from flowctl.dag import CycleError
+from flowctl.executor import execute_workflow
+from flowctl.parser import ValidationError, parse_workflow_file
+from flowctl.reporter import format_report, load_report, write_report
+
+EXIT_SUCCESS = 0
+EXIT_VALIDATION = 1
+EXIT_FAILURE = 2
+EXIT_INTERRUPTED = 130
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="flowctl",
+        description="Event-driven workflow orchestration engine",
+    )
+    sub = parser.add_subparsers(dest="command")
+
+    # validate
+    p_val = sub.add_parser("validate", help="Validate a workflow YAML file")
+    p_val.add_argument("workflow", type=Path, help="Path to workflow YAML file")
+
+    # run
+    p_run = sub.add_parser("run", help="Execute a workflow")
+    p_run.add_argument("workflow", type=Path, help="Path to workflow YAML file")
+    p_run.add_argument(
+        "--report",
+        type=Path,
+        default=Path("flowctl-report.json"),
+        help="Output path for the JSON execution report (default: ./flowctl-report.json)",
+    )
+    p_run.add_argument(
+        "--dry-run",
+        action="store_true",
+        help="Show execution plan without running commands",
+    )
+
+    # report
+    p_rep = sub.add_parser("report", help="Pretty-print an execution report")
+    p_rep.add_argument("report_file", type=Path, help="Path to a JSON report file")
+
+    # version
+    sub.add_parser("version", help="Show flowctl version")
+
+    return parser
+
+
+def cmd_validate(args: argparse.Namespace) -> int:
+    path: Path = args.workflow
+    if not path.exists():
+        print(f"Error: file not found: {path}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    try:
+        workflow = parse_workflow_file(path)
+    except ValidationError as exc:
+        for err in exc.errors:
+            print(f"  {err}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    # Also check for cycles
+    from flowctl.dag import topological_sort
+
+    try:
+        topological_sort(workflow.steps)
+    except CycleError as exc:
+        print(f"Cycle detected: {', '.join(exc.cycle_members)}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    step_count = len(workflow.steps)
+    print(f"Validation passed: {step_count} step(s) in workflow '{workflow.name}'")
+    return EXIT_SUCCESS
+
+
+def cmd_run(args: argparse.Namespace) -> int:
+    path: Path = args.workflow
+    if not path.exists():
+        print(f"Error: file not found: {path}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    try:
+        workflow = parse_workflow_file(path)
+    except ValidationError as exc:
+        for err in exc.errors:
+            print(f"  {err}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    try:
+        report = execute_workflow(workflow, dry_run=args.dry_run)
+    except CycleError as exc:
+        print(f"Cycle detected: {', '.join(exc.cycle_members)}", file=sys.stderr)
+        return EXIT_VALIDATION
+    except KeyboardInterrupt:
+        return EXIT_INTERRUPTED
+
+    write_report(report, args.report)
+    print(f"Report written to {args.report}")
+
+    # Determine exit code from report status
+    from flowctl.models import WorkflowStatus
+
+    if report.status == WorkflowStatus.SUCCEEDED:
+        return EXIT_SUCCESS
+    else:
+        return EXIT_FAILURE
+
+
+def cmd_report(args: argparse.Namespace) -> int:
+    path: Path = args.report_file
+    if not path.exists():
+        print(f"Error: file not found: {path}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    try:
+        data = load_report(path)
+    except Exception as exc:
+        print(f"Error reading report: {exc}", file=sys.stderr)
+        return EXIT_VALIDATION
+
+    print(format_report(data))
+    return EXIT_SUCCESS
+
+
+def cmd_version(_args: argparse.Namespace) -> int:
+    print(f"flowctl {__version__}")
+    return EXIT_SUCCESS
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = _build_parser()
+    args = parser.parse_args(argv)
+
+    if args.command is None:
+        parser.print_help()
+        return EXIT_VALIDATION
+
+    handlers = {
+        "validate": cmd_validate,
+        "run": cmd_run,
+        "report": cmd_report,
+        "version": cmd_version,
+    }
+
+    handler = handlers.get(args.command)
+    if handler is None:
+        parser.print_help()
+        return EXIT_VALIDATION
+
+    return handler(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
diff --git a/src/flowctl/dag.py b/src/flowctl/dag.py
