+    def test_overall_status_partial(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: good\n    run: 'true'\n"
+            "  - id: bad\n    run: 'exit 1'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.status, PARTIAL)
+
+    def test_overall_status_failed_when_nothing_succeeded(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n    run: 'exit 1'\n"
+            "  - id: b\n    depends_on:\n      - a\n    run: 'true'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        # a=failed, b=cancelled -> no successes -> failed
+        self.assertEqual(rep.status, FAILED)
+
+    def test_partial_with_skip_and_failure(self):
+        # The exact scenario the user described: build fails, deploy skipped,
+        # cleanup runs and succeeds -> partial (not failed).
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: build\n    run: 'exit 1'\n"
+            "  - id: deploy\n    depends_on:\n      - build\n"
+            "    condition: \"succeeded('build')\"\n    run: 'true'\n"
+            "  - id: cleanup\n    depends_on:\n      - build\n"
+            "    condition: \"failed('build')\"\n    run: 'true'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.status, PARTIAL)
+
+    def test_total_retry_delay(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n    retries: 2\n    retry_backoff: 0.1\n    run: 'exit 1'\n"
+            "  - id: b\n    retries: 1\n    retry_backoff: 0.15\n    run: 'exit 1'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        d = rep.to_dict()
+        # a: 0.1 + 0.2 = 0.3; b: 0.15; total ~= 0.45
+        self.assertAlmostEqual(d["summary"]["total_retry_delay"], 0.45, delta=0.1)
+        by = {s["id"]: s for s in d["steps"]}
+        self.assertAlmostEqual(by["a"]["retry_delay"], 0.30, delta=0.06)
+        self.assertAlmostEqual(by["b"]["retry_delay"], 0.15, delta=0.05)
+
+    def test_zero_retry_delay_when_no_retries(self):
+        wf = _wf("name: t\nsteps:\n  - id: a\n    run: 'true'\n")
+        rep = Engine(wf, logger=SILENT).run()
+        d = rep.to_dict()
+        self.assertEqual(d["summary"]["total_retry_delay"], 0.0)
+        self.assertEqual(d["steps"][0]["retry_delay"], 0.0)
+
 
