+def _overall_status(steps: list[StepResult]) -> str:
+    """Classify the workflow by the steps that actually executed.
+
+    skipped/cancelled steps are ignored (they never ran). Of the steps that ran:
+      * all succeeded (or none ran)  -> SUCCEEDED
+      * all failed/timed_out         -> FAILED
+      * mix                          -> PARTIAL
+    """
+    ran = [s.status for s in steps if s.status in _RAN]
+    if all(s == SUCCEEDED for s in ran):
+        return SUCCEEDED
+    if all(s != SUCCEEDED for s in ran):
+        return FAILED
+    return PARTIAL
+
