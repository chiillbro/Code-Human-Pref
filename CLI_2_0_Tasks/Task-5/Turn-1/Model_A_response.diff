+"""Command-line interface for bujjictl."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+
+from . import __version__
+from .engine import Engine
+from .model import ValidationError, load_workflow
+from .report import load_report, render
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(
+        prog="bujjictl",
+        description="A lightweight, local-first workflow orchestration engine.",
+    )
+    p.add_argument("--version", action="version", version=f"bujjictl {__version__}")
+    sub = p.add_subparsers(dest="command", required=True, metavar="<command>")
+
+    pv = sub.add_parser("validate", help="Validate a workflow YAML file without running it.")
+    pv.add_argument("file", help="Path to the workflow YAML file.")
+
+    pr = sub.add_parser("run", help="Validate and execute a workflow YAML file.")
+    pr.add_argument("file", help="Path to the workflow YAML file.")
+    pr.add_argument("-o", "--report", metavar="PATH",
+                    help="Write the JSON run report to PATH (default: <workflow>.report.json).")
+    pr.add_argument("-j", "--max-workers", type=int, default=None,
+                    help="Maximum number of steps to run concurrently.")
+    pr.add_argument("-q", "--quiet", action="store_true",
+                    help="Suppress progress logging to stderr.")
+    pr.add_argument("--no-pretty", action="store_true",
+                    help="Do not pretty-print the report after the run.")
+
+    pp = sub.add_parser("report", help="Pretty-print a previously generated JSON report.")
+    pp.add_argument("file", help="Path to the JSON report file.")
+    pp.add_argument("--no-output", action="store_true",
+                    help="Hide captured stdout/stderr in the per-step detail.")
+
+    return p
+
+
+def _cmd_validate(args: argparse.Namespace) -> int:
+    try:
+        wf = load_workflow(args.file)
+    except ValidationError as e:
+        print("✘ invalid workflow:", file=sys.stderr)
+        for err in e.errors:
+            print(f"  - {err}", file=sys.stderr)
+        return 1
+    print(f"✔ workflow '{wf.name}' is valid ({len(wf.steps)} steps).")
+    return 0
+
+
+def _cmd_run(args: argparse.Namespace) -> int:
+    try:
+        wf = load_workflow(args.file)
+    except ValidationError as e:
+        print("✘ invalid workflow:", file=sys.stderr)
+        for err in e.errors:
+            print(f"  - {err}", file=sys.stderr)
+        return 1
+
+    logger = (lambda msg: None) if args.quiet else None
+    engine = Engine(wf, max_workers=args.max_workers, logger=logger)
+    result = engine.run()
+    report_dict = result.to_dict()
+
+    out_path = args.report or f"{wf.name}.report.json"
+    try:
+        with open(out_path, "w", encoding="utf-8") as f:
+            json.dump(report_dict, f, indent=2)
+            f.write("\n")
+        print(f"\n→ report written to {out_path}", file=sys.stderr)
+    except OSError as e:
+        print(f"✘ failed to write report to {out_path}: {e}", file=sys.stderr)
+        return 1
+
+    if not args.no_pretty:
+        print(file=sys.stderr)
+        render(report_dict, stream=sys.stdout)
+
+    return 0 if result.status == "succeeded" else 2
+
+
+def _cmd_report(args: argparse.Namespace) -> int:
+    try:
+        data = load_report(args.file)
+    except FileNotFoundError:
+        print(f"✘ report file not found: {args.file}", file=sys.stderr)
+        return 1
+    except json.JSONDecodeError as e:
+        print(f"✘ invalid JSON in {args.file}: {e}", file=sys.stderr)
+        return 1
+    render(data, stream=sys.stdout, show_output=not args.no_output)
+    return 0
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = _build_parser()
+    args = parser.parse_args(argv)
+    if args.command == "validate":
+        return _cmd_validate(args)
+    if args.command == "run":
+        return _cmd_run(args)
+    if args.command == "report":
+        return _cmd_report(args)
+    parser.error(f"unknown command: {args.command}")
+    return 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
