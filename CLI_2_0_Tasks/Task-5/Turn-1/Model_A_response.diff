@@ -0,0 +1,93 @@
+import os
+import tempfile
+import unittest
+
+from bujjictl.model import ValidationError, load_workflow
+
+
+def _write(content: str) -> str:
+    fd, path = tempfile.mkstemp(suffix=".yaml")
+    with os.fdopen(fd, "w") as f:
+        f.write(content)
+    return path
+
+
+class TestValidation(unittest.TestCase):
+    def test_valid(self):
+        p = _write(
+            "name: wf\n"
+            "steps:\n"
+            "  - id: a\n"
+            "    run: echo hi\n"
+            "  - id: b\n"
+            "    run: echo bye\n"
+            "    depends_on:\n"
+            "      - a\n"
+        )
+        wf = load_workflow(p)
+        self.assertEqual(wf.name, "wf")
+        self.assertEqual([s.id for s in wf.steps], ["a", "b"])
+        self.assertEqual(wf.dependents["a"], {"b"})
+
+    def test_missing_name(self):
+        p = _write("steps:\n  - id: a\n    run: x\n")
+        with self.assertRaises(ValidationError) as ctx:
+            load_workflow(p)
+        self.assertTrue(any("'name'" in e for e in ctx.exception.errors))
+
+    def test_unknown_dep(self):
+        p = _write(
+            "name: wf\nsteps:\n"
+            "  - id: a\n    run: x\n    depends_on:\n      - ghost\n"
+        )
+        with self.assertRaises(ValidationError) as ctx:
+            load_workflow(p)
+        self.assertTrue(any("ghost" in e for e in ctx.exception.errors))
+
+    def test_duplicate_id(self):
+        p = _write(
+            "name: wf\nsteps:\n"
+            "  - id: a\n    run: x\n"
+            "  - id: a\n    run: y\n"
+        )
+        with self.assertRaises(ValidationError):
+            load_workflow(p)
+
+    def test_cycle(self):
+        p = _write(
+            "name: wf\nsteps:\n"
+            "  - id: a\n    run: x\n    depends_on:\n      - b\n"
+            "  - id: b\n    run: y\n    depends_on:\n      - a\n"
+        )
+        with self.assertRaises(ValidationError) as ctx:
+            load_workflow(p)
+        self.assertTrue(any("cycle" in e for e in ctx.exception.errors))
+
+    def test_self_dep(self):
+        p = _write(
+            "name: wf\nsteps:\n"
+            "  - id: a\n    run: x\n    depends_on:\n      - a\n"
+        )
+        with self.assertRaises(ValidationError):
+            load_workflow(p)
+
+    def test_unknown_key(self):
+        p = _write("name: wf\nfoo: bar\nsteps:\n  - id: a\n    run: x\n")
+        with self.assertRaises(ValidationError) as ctx:
+            load_workflow(p)
+        self.assertTrue(any("unknown key 'foo'" in e for e in ctx.exception.errors))
+
+    def test_bad_types(self):
+        p = _write(
+            "name: wf\nsteps:\n"
+            "  - id: a\n    run: x\n    retries: nope\n    timeout: -1\n"
+        )
+        with self.assertRaises(ValidationError) as ctx:
+            load_workflow(p)
+        msgs = " ".join(ctx.exception.errors)
+        self.assertIn("retries", msgs)
+        self.assertIn("timeout", msgs)
+
+
+if __name__ == "__main__":
+    unittest.main()
diff --git a/tests/test_yaml_parser.py b/tests/test_yaml_parser.py
new file mode 100644
index 0000000..536c4db
--- /dev/null
+++ b/tests/test_yaml_parser.py
@@ -0,0 +1,76 @@
+import unittest
+
+from bujjictl.yaml_parser import load, YamlError
+
+
+class TestYamlParser(unittest.TestCase):
+    def test_scalars(self):
+        self.assertEqual(load("a: 1"), {"a": 1})
+        self.assertEqual(load("a: 1.5"), {"a": 1.5})
+        self.assertEqual(load("a: true"), {"a": True})
+        self.assertEqual(load("a: false"), {"a": False})
+        self.assertEqual(load("a: null"), {"a": None})
+        self.assertEqual(load("a: ~"), {"a": None})
+        self.assertEqual(load("a: hello world"), {"a": "hello world"})
+        self.assertEqual(load("a:"), {"a": None})
+
+    def test_quoted(self):
+        self.assertEqual(load('a: "hi: there"'), {"a": "hi: there"})
+        self.assertEqual(load("a: 'hi: there'"), {"a": "hi: there"})
+        self.assertEqual(load('a: "line\\nbreak"'), {"a": "line\nbreak"})
+        self.assertEqual(load('a: "true"'), {"a": "true"})
+
+    def test_nested_mapping(self):
+        src = "a:\n  b: 1\n  c: 2\n"
+        self.assertEqual(load(src), {"a": {"b": 1, "c": 2}})
+
+    def test_sequence(self):
+        src = "a:\n  - x\n  - y\n"
+        self.assertEqual(load(src), {"a": ["x", "y"]})
+
+    def test_sequence_of_mappings(self):
+        src = (
+            "steps:\n"
+            "  - id: one\n"
+            "    run: echo hi\n"
+            "  - id: two\n"
+            "    run: echo bye\n"
+        )
+        self.assertEqual(load(src), {"steps": [
+            {"id": "one", "run": "echo hi"},
+            {"id": "two", "run": "echo bye"},
+        ]})
+
+    def test_block_scalar_literal(self):
+        src = "run: |\n  line1\n  line2\n"
+        self.assertEqual(load(src), {"run": "line1\nline2\n"})
+
+    def test_block_scalar_strip(self):
+        src = "run: |-\n  line1\n  line2\n"
+        self.assertEqual(load(src), {"run": "line1\nline2"})
+
+    def test_comments_and_blank_lines(self):
+        src = "# top\na: 1  # trailing\n\nb: 2\n"
+        self.assertEqual(load(src), {"a": 1, "b": 2})
+
+    def test_nested_list_under_dash(self):
+        src = (
+            "steps:\n"
+            "  - id: a\n"
+            "    depends_on:\n"
+            "      - x\n"
+            "      - y\n"
+        )
+        self.assertEqual(load(src), {"steps": [{"id": "a", "depends_on": ["x", "y"]}]})
+
+    def test_duplicate_key(self):
+        with self.assertRaises(YamlError):
+            load("a: 1\na: 2\n")
+
+    def test_colon_in_unquoted_value(self):
+        # colon not followed by space should not split
+        self.assertEqual(load("a: http://x"), {"a": "http://x"})
+
+
+if __name__ == "__main__":
+    unittest.main()
