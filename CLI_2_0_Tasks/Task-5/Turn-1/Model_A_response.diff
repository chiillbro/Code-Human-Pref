+"""Concurrent DAG execution engine."""
+
+from __future__ import annotations
+
+import os
+import signal
+import subprocess
+import sys
+import threading
+import time
+from concurrent.futures import ThreadPoolExecutor
+from dataclasses import dataclass, field
+from datetime import datetime, timezone
+from typing import Callable
+
+from .model import Step, Workflow
+
+
+# ----------------------------------------------------------------------------
+# Result types
+# ----------------------------------------------------------------------------
+
+PENDING = "pending"
+RUNNING = "running"
+SUCCEEDED = "succeeded"
+FAILED = "failed"
+TIMED_OUT = "timed_out"
+CANCELLED = "cancelled"
+
+_TERMINAL = {SUCCEEDED, FAILED, TIMED_OUT, CANCELLED}
+
+
+@dataclass
+class Attempt:
+    number: int
+    started_at: str
+    finished_at: str
+    duration: float
+    exit_code: int | None
+    stdout: str
+    stderr: str
+    timed_out: bool
+    error: str | None = None
+
+    def to_dict(self) -> dict:
+        return {
+            "number": self.number,
+            "started_at": self.started_at,
+            "finished_at": self.finished_at,
+            "duration": round(self.duration, 6),
+            "exit_code": self.exit_code,
+            "timed_out": self.timed_out,
+            "stdout": self.stdout,
+            "stderr": self.stderr,
+            "error": self.error,
+        }
+
+
+@dataclass
+class StepResult:
+    step: Step
+    status: str = PENDING
+    attempts: list[Attempt] = field(default_factory=list)
+    started_at: str | None = None
+    finished_at: str | None = None
+    duration: float = 0.0
+    cancel_reason: str | None = None
+
+    def to_dict(self) -> dict:
+        return {
+            "id": self.step.id,
+            "name": self.step.name,
+            "status": self.status,
+            "depends_on": list(self.step.depends_on),
+            "started_at": self.started_at,
+            "finished_at": self.finished_at,
+            "duration": round(self.duration, 6),
+            "attempt_count": len(self.attempts),
+            "cancel_reason": self.cancel_reason,
+            "attempts": [a.to_dict() for a in self.attempts],
+        }
+
+
+@dataclass
+class RunReport:
+    workflow: Workflow
+    status: str
+    started_at: str
+    finished_at: str
+    duration: float
+    steps: list[StepResult]
+
+    def to_dict(self) -> dict:
+        return {
+            "workflow": {
+                "name": self.workflow.name,
+                "description": self.workflow.description,
+            },
+            "status": self.status,
+            "started_at": self.started_at,
+            "finished_at": self.finished_at,
+            "duration": round(self.duration, 6),
+            "summary": _summarize(self.steps),
+            "steps": [s.to_dict() for s in self.steps],
+        }
+
+
+def _summarize(steps: list[StepResult]) -> dict:
+    counts = {SUCCEEDED: 0, FAILED: 0, TIMED_OUT: 0, CANCELLED: 0}
+    for s in steps:
+        if s.status in counts:
+            counts[s.status] += 1
+    counts["total"] = len(steps)
+    return counts
+
+
+def _now_iso() -> str:
+    return datetime.now(timezone.utc).isoformat(timespec="microseconds")
+
+
+# ----------------------------------------------------------------------------
+# Engine
+# ----------------------------------------------------------------------------
+
+Logger = Callable[[str], None]
+
+
+class Engine:
+    def __init__(self, workflow: Workflow, *, max_workers: int | None = None, logger: Logger | None = None):
+        self.wf = workflow
+        self.max_workers = max_workers or min(32, (os.cpu_count() or 4))
+        self.log = logger or (lambda msg: print(msg, file=sys.stderr, flush=True))
+
+        self._lock = threading.Lock()
+        self._cond = threading.Condition(self._lock)
+        self._results: dict[str, StepResult] = {s.id: StepResult(step=s) for s in workflow.steps}
+        self._remaining_deps: dict[str, set[str]] = {
+            s.id: set(s.depends_on) for s in workflow.steps
+        }
+        self._scheduled: set[str] = set()
+
+    # -- public ------------------------------------------------------------
+
+    def run(self) -> RunReport:
+        t0 = time.monotonic()
+        started_at = _now_iso()
+        self.log(f"▶ workflow '{self.wf.name}' starting ({len(self.wf.steps)} steps, max_workers={self.max_workers})")
+
+        with ThreadPoolExecutor(max_workers=self.max_workers, thread_name_prefix="bujji") as pool:
+            with self._cond:
+                self._schedule_ready(pool)
+                while not self._all_terminal():
+                    self._cond.wait()
+                    self._schedule_ready(pool)
+
+        finished_at = _now_iso()
+        duration = time.monotonic() - t0
+        status = SUCCEEDED if all(r.status == SUCCEEDED for r in self._results.values()) else FAILED
+        self.log(f"■ workflow '{self.wf.name}' finished: {status} in {duration:.3f}s")
+
+        ordered = [self._results[s.id] for s in self.wf.steps]
+        return RunReport(
+            workflow=self.wf, status=status,
+            started_at=started_at, finished_at=finished_at,
+            duration=duration, steps=ordered,
+        )
+
+    # -- scheduling --------------------------------------------------------
+
+    def _all_terminal(self) -> bool:
+        return all(r.status in _TERMINAL for r in self._results.values())
+
+    def _schedule_ready(self, pool: ThreadPoolExecutor) -> None:
+        for sid, deps in self._remaining_deps.items():
+            if sid in self._scheduled:
+                continue
+            if self._results[sid].status != PENDING:
+                continue
+            if deps:
+                continue
+            self._scheduled.add(sid)
+            self._results[sid].status = RUNNING
+            pool.submit(self._run_step, sid)
+
+    def _on_step_finished(self, sid: str, status: str) -> None:
+        with self._cond:
+            res = self._results[sid]
+            res.status = status
+            if status == SUCCEEDED:
+                for child in self.wf.dependents.get(sid, ()):
+                    self._remaining_deps[child].discard(sid)
+            else:
+                self._cancel_downstream(sid, reason=f"upstream step '{sid}' {status}")
+            self._cond.notify_all()
+
+    def _cancel_downstream(self, root: str, *, reason: str) -> None:
+        # BFS over dependents; mark anything still pending as cancelled.
+        queue = list(self.wf.dependents.get(root, ()))
+        seen: set[str] = set()
+        while queue:
+            cur = queue.pop()
+            if cur in seen:
+                continue
+            seen.add(cur)
+            res = self._results[cur]
+            if res.status == PENDING:
+                res.status = CANCELLED
+                res.cancel_reason = reason
+                res.finished_at = _now_iso()
+                self.log(f"  ⊘ step '{cur}' cancelled ({reason})")
+            queue.extend(self.wf.dependents.get(cur, ()))
+
+    # -- execution ---------------------------------------------------------
+
+    def _run_step(self, sid: str) -> None:
+        step = self.wf.steps_by_id[sid]
+        res = self._results[sid]
+        res.started_at = _now_iso()
+        t0 = time.monotonic()
+        self.log(f"  ▷ step '{sid}' started")
+
+        env = dict(os.environ)
+        env.update(self.wf.env)
+        env.update(step.env)
+        env["BUJJI_STEP_ID"] = sid
+        env["BUJJI_WORKFLOW"] = self.wf.name
+
+        final_status = FAILED
+        max_attempts = step.retries + 1
+        for n in range(1, max_attempts + 1):
+            env["BUJJI_ATTEMPT"] = str(n)
+            attempt = self._exec_once(step, n, env)
+            res.attempts.append(attempt)
+            if attempt.exit_code == 0 and not attempt.timed_out and attempt.error is None:
+                final_status = SUCCEEDED
+                break
+            if attempt.timed_out:
+                final_status = TIMED_OUT
+            else:
+                final_status = FAILED
+            if n < max_attempts:
+                delay = step.retry_backoff * (2 ** (n - 1))
+                self.log(f"    ↻ step '{sid}' attempt {n} failed; retrying in {delay:.2f}s")
+                time.sleep(delay)
+
+        res.finished_at = _now_iso()
+        res.duration = time.monotonic() - t0
+        glyph = "✔" if final_status == SUCCEEDED else "✘"
+        self.log(f"  {glyph} step '{sid}' {final_status} "
+                 f"({len(res.attempts)} attempt{'s' if len(res.attempts) != 1 else ''}, {res.duration:.3f}s)")
+        self._on_step_finished(sid, final_status)
+
+    def _exec_once(self, step: Step, number: int, env: dict[str, str]) -> Attempt:
+        a_t0 = time.monotonic()
+        a_start = _now_iso()
+        exit_code: int | None = None
+        stdout = ""
+        stderr = ""
+        timed_out = False
+        error: str | None = None
+
+        popen_kwargs: dict = dict(
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            env=env,
+            text=True,
+        )
+        if os.name == "posix":
+            popen_kwargs["start_new_session"] = True  # own process group for clean kill
+
+        try:
+            proc = subprocess.Popen([step.shell, "-c", step.run], **popen_kwargs)
+            try:
+                stdout, stderr = proc.communicate(timeout=step.timeout)
+                exit_code = proc.returncode
+            except subprocess.TimeoutExpired:
+                timed_out = True
+                _kill_process(proc)
+                try:
+                    stdout, stderr = proc.communicate(timeout=5)
+                except subprocess.TimeoutExpired:
+                    proc.kill()
+                    stdout, stderr = proc.communicate()
+                exit_code = proc.returncode
+        except FileNotFoundError as e:
+            error = f"shell not found: {e}"
+        except Exception as e:  # defensive: surface in report rather than crashing the run
+            error = f"{type(e).__name__}: {e}"
+
+        return Attempt(
+            number=number,
+            started_at=a_start,
+            finished_at=_now_iso(),
+            duration=time.monotonic() - a_t0,
+            exit_code=exit_code,
+            stdout=stdout,
+            stderr=stderr,
+            timed_out=timed_out,
+            error=error,
+        )
+
+
+def _kill_process(proc: subprocess.Popen) -> None:
+    try:
+        if os.name == "posix":
+            os.killpg(proc.pid, signal.SIGTERM)
+            time.sleep(0.2)
+            if proc.poll() is None:
+                os.killpg(proc.pid, signal.SIGKILL)
+        else:
+            proc.terminate()
+            time.sleep(0.2)
+            if proc.poll() is None:
+                proc.kill()
+    except ProcessLookupError:
+        pass
