@@ -0,0 +1,311 @@
+"""Workflow and step data model + validation."""
+
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass, field
+from typing import Any
+
+from .yaml_parser import load_file, YamlError
+
+
+class ValidationError(Exception):
+    """Raised when a workflow definition is invalid. Carries a list of messages."""
+
+    def __init__(self, errors: list[str]):
+        self.errors = errors
+        super().__init__("workflow validation failed:\n  - " + "\n  - ".join(errors))
+
+
+_ID_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_\-]*$")
+
+_TOP_KEYS = {"name", "description", "env", "defaults", "steps"}
+_DEFAULT_KEYS = {"timeout", "retries", "retry_backoff", "shell"}
+_STEP_KEYS = {
+    "id", "name", "run", "depends_on", "env",
+    "timeout", "retries", "retry_backoff", "shell",
+}
+
+
+@dataclass
+class Step:
+    id: str
+    run: str
+    name: str | None = None
+    depends_on: list[str] = field(default_factory=list)
+    env: dict[str, str] = field(default_factory=dict)
+    timeout: float | None = None
+    retries: int = 0
+    retry_backoff: float = 1.0
+    shell: str = "/bin/sh"
+
+
+@dataclass
+class Workflow:
+    name: str
+    description: str | None
+    env: dict[str, str]
+    steps: list[Step]
+    steps_by_id: dict[str, Step] = field(default_factory=dict)
+    dependents: dict[str, set[str]] = field(default_factory=dict)  # id -> downstream ids
+
+    def __post_init__(self) -> None:
+        self.steps_by_id = {s.id: s for s in self.steps}
+        self.dependents = {s.id: set() for s in self.steps}
+        for s in self.steps:
+            for dep in s.depends_on:
+                self.dependents[dep].add(s.id)
+
+
+# ----------------------------------------------------------------------------
+# Loading & validation
+# ----------------------------------------------------------------------------
+
+def load_workflow(path: str) -> Workflow:
+    """Load and fully validate a workflow file. Raises ValidationError on any problem."""
+    try:
+        doc = load_file(path)
+    except FileNotFoundError:
+        raise ValidationError([f"file not found: {path}"])
+    except YamlError as e:
+        raise ValidationError([f"YAML parse error: {e}"])
+
+    errors: list[str] = []
+    wf = _validate(doc, errors)
+    if errors:
+        raise ValidationError(errors)
+    assert wf is not None
+    return wf
+
+
+def _validate(doc: Any, errors: list[str]) -> Workflow | None:
+    if not isinstance(doc, dict):
+        errors.append("top-level document must be a mapping")
+        return None
+
+    _check_unknown_keys(doc, _TOP_KEYS, "top-level", errors)
+
+    name = doc.get("name")
+    if not isinstance(name, str) or not name.strip():
+        errors.append("'name' is required and must be a non-empty string")
+        name = "<invalid>"
+
+    description = doc.get("description")
+    if description is not None and not isinstance(description, str):
+        errors.append("'description' must be a string")
+        description = None
+
+    global_env = _validate_env(doc.get("env"), "env", errors)
+
+    defaults = doc.get("defaults") or {}
+    if not isinstance(defaults, dict):
+        errors.append("'defaults' must be a mapping")
+        defaults = {}
+    else:
+        _check_unknown_keys(defaults, _DEFAULT_KEYS, "defaults", errors)
+
+    d_timeout = _validate_number(defaults.get("timeout"), "defaults.timeout", errors, allow_none=True, minimum=0.001)
+    d_retries = _validate_int(defaults.get("retries", 0), "defaults.retries", errors, minimum=0)
+    d_backoff = _validate_number(defaults.get("retry_backoff", 1.0), "defaults.retry_backoff", errors, minimum=0.0)
+    d_shell = defaults.get("shell", "/bin/sh")
+    if not isinstance(d_shell, str) or not d_shell:
+        errors.append("'defaults.shell' must be a non-empty string")
+        d_shell = "/bin/sh"
+
+    raw_steps = doc.get("steps")
+    if not isinstance(raw_steps, list) or not raw_steps:
+        errors.append("'steps' is required and must be a non-empty list")
+        return None
+
+    steps: list[Step] = []
+    seen_ids: set[str] = set()
+    for i, raw in enumerate(raw_steps):
+        loc = f"steps[{i}]"
+        if not isinstance(raw, dict):
+            errors.append(f"{loc}: must be a mapping")
+            continue
+        _check_unknown_keys(raw, _STEP_KEYS, loc, errors)
+
+        sid = raw.get("id")
+        if not isinstance(sid, str) or not sid:
+            errors.append(f"{loc}: 'id' is required and must be a non-empty string")
+            continue
+        if not _ID_RE.match(sid):
+            errors.append(f"{loc}: 'id' '{sid}' must match {_ID_RE.pattern}")
+        if sid in seen_ids:
+            errors.append(f"{loc}: duplicate step id '{sid}'")
+            continue
+        seen_ids.add(sid)
+        loc = f"steps[{i}] (id='{sid}')"
+
+        run = raw.get("run")
+        if not isinstance(run, str) or not run.strip():
+            errors.append(f"{loc}: 'run' is required and must be a non-empty string")
+            run = "false"
+
+        sname = raw.get("name")
+        if sname is not None and not isinstance(sname, str):
+            errors.append(f"{loc}: 'name' must be a string")
+            sname = None
+
+        deps = _validate_depends_on(raw.get("depends_on"), loc, errors)
+        if sid in deps:
+            errors.append(f"{loc}: step cannot depend on itself")
+            deps = [d for d in deps if d != sid]
+
+        senv = _validate_env(raw.get("env"), f"{loc}.env", errors)
+
+        timeout = _validate_number(
+            raw.get("timeout", d_timeout), f"{loc}.timeout", errors,
+            allow_none=True, minimum=0.001,
+        )
+        retries = _validate_int(raw.get("retries", d_retries), f"{loc}.retries", errors, minimum=0)
+        backoff = _validate_number(
+            raw.get("retry_backoff", d_backoff), f"{loc}.retry_backoff", errors, minimum=0.0,
+        )
+        shell = raw.get("shell", d_shell)
+        if not isinstance(shell, str) or not shell:
+            errors.append(f"{loc}: 'shell' must be a non-empty string")
+            shell = d_shell
+
+        steps.append(Step(
+            id=sid, run=run, name=sname, depends_on=deps, env=senv,
+            timeout=timeout, retries=retries or 0, retry_backoff=backoff or 1.0, shell=shell,
+        ))
+
+    # Reference + cycle checks (only meaningful once we have ids).
+    ids = {s.id for s in steps}
+    for s in steps:
+        for dep in s.depends_on:
+            if dep not in ids:
+                errors.append(f"step '{s.id}': depends_on references unknown step '{dep}'")
+
+    cycle = _find_cycle(steps)
+    if cycle:
+        errors.append("dependency cycle detected: " + " -> ".join(cycle))
+
+    if errors:
+        return None
+    return Workflow(name=name, description=description, env=global_env, steps=steps)
+
+
+# ----------------------------------------------------------------------------
+# Field validators
+# ----------------------------------------------------------------------------
+
+def _check_unknown_keys(d: dict, allowed: set[str], loc: str, errors: list[str]) -> None:
+    for k in d:
+        if k not in allowed:
+            errors.append(f"{loc}: unknown key '{k}'")
+
+
+def _validate_env(value: Any, loc: str, errors: list[str]) -> dict[str, str]:
+    if value is None:
+        return {}
+    if not isinstance(value, dict):
+        errors.append(f"'{loc}' must be a mapping of string -> string")
+        return {}
+    out: dict[str, str] = {}
+    for k, v in value.items():
+        if not isinstance(k, str) or not k:
+            errors.append(f"'{loc}': environment variable names must be non-empty strings")
+            continue
+        if v is None:
+            v = ""
+        if isinstance(v, bool):
+            v = "true" if v else "false"
+        if isinstance(v, (int, float)):
+            v = str(v)
+        if not isinstance(v, str):
+            errors.append(f"'{loc}.{k}': value must be a string/number/bool")
+            continue
+        out[k] = v
+    return out
+
+
+def _validate_depends_on(value: Any, loc: str, errors: list[str]) -> list[str]:
+    if value is None:
+        return []
+    if not isinstance(value, list):
+        errors.append(f"{loc}: 'depends_on' must be a list of step ids")
+        return []
+    out: list[str] = []
+    for i, item in enumerate(value):
+        if not isinstance(item, str) or not item:
+            errors.append(f"{loc}.depends_on[{i}]: must be a non-empty string")
+            continue
+        if item in out:
+            errors.append(f"{loc}.depends_on: duplicate dependency '{item}'")
+            continue
+        out.append(item)
+    return out
+
+
+def _validate_number(value: Any, loc: str, errors: list[str], *, allow_none: bool = False, minimum: float | None = None) -> float | None:
+    if value is None:
+        if allow_none:
+            return None
+        errors.append(f"'{loc}' must be a number")
+        return None
+    if isinstance(value, bool) or not isinstance(value, (int, float)):
+        errors.append(f"'{loc}' must be a number")
+        return None
+    f = float(value)
+    if minimum is not None and f < minimum:
+        errors.append(f"'{loc}' must be >= {minimum}")
+        return None
+    return f
+
+
+def _validate_int(value: Any, loc: str, errors: list[str], *, minimum: int | None = None) -> int | None:
+    if isinstance(value, bool) or not isinstance(value, int):
+        errors.append(f"'{loc}' must be an integer")
+        return None
+    if minimum is not None and value < minimum:
+        errors.append(f"'{loc}' must be >= {minimum}")
+        return None
+    return value
+
+
+# ----------------------------------------------------------------------------
+# Cycle detection (iterative DFS so deep graphs don't blow the stack)
+# ----------------------------------------------------------------------------
+
+def _find_cycle(steps: list[Step]) -> list[str] | None:
+    graph = {s.id: [d for d in s.depends_on] for s in steps}
+    WHITE, GRAY, BLACK = 0, 1, 2
+    color = {n: WHITE for n in graph}
+    parent: dict[str, str | None] = {}
+
+    for start in graph:
+        if color[start] != WHITE:
+            continue
+        stack: list[tuple[str, int]] = [(start, 0)]
+        parent[start] = None
+        while stack:
+            node, idx = stack[-1]
+            if idx == 0:
+                color[node] = GRAY
+            children = graph.get(node, [])
+            if idx < len(children):
+                stack[-1] = (node, idx + 1)
+                child = children[idx]
+                if child not in graph:
+                    continue  # unknown ref; reported elsewhere
+                if color[child] == WHITE:
+                    parent[child] = node
+                    stack.append((child, 0))
+                elif color[child] == GRAY:
+                    # reconstruct cycle
+                    cyc = [child]
+                    cur = node
+                    while cur is not None and cur != child:
+                        cyc.append(cur)
+                        cur = parent.get(cur)
+                    cyc.append(child)
+                    cyc.reverse()
+                    return cyc
+            else:
+                color[node] = BLACK
+                stack.pop()
+    return None
diff --git a/bujjictl/report.py b/bujjictl/report.py
new file mode 100644
index 0000000..aa8aef4
--- /dev/null
+++ b/bujjictl/report.py
@@ -0,0 +1,129 @@
+"""Pretty-print a JSON run report to the terminal."""
+
+from __future__ import annotations
+
+import json
+import os
+import sys
+import textwrap
+
+
+_STATUS_STYLE = {
+    "succeeded": ("✔", "32"),   # green
+    "failed":    ("✘", "31"),   # red
+    "timed_out": ("⏱", "33"),   # yellow
+    "cancelled": ("⊘", "90"),   # grey
+    "running":   ("▷", "36"),
+    "pending":   ("·", "90"),
+}
+
+
+def _color_enabled(stream) -> bool:
+    if os.environ.get("NO_COLOR"):
+        return False
+    return stream.isatty()
+
+
+def _c(text: str, code: str, *, enabled: bool) -> str:
+    if not enabled:
+        return text
+    return f"\033[{code}m{text}\033[0m"
+
+
+def _fmt_duration(d: float | None) -> str:
+    if d is None:
+        return "-"
+    if d < 1:
+        return f"{d * 1000:.0f}ms"
+    if d < 60:
+        return f"{d:.2f}s"
+    m, s = divmod(d, 60)
+    return f"{int(m)}m{s:04.1f}s"
+
+
+def render(report: dict, *, stream=sys.stdout, show_output: bool = True) -> None:
+    color = _color_enabled(stream)
+
+    def out(s: str = "") -> None:
+        print(s, file=stream)
+
+    wf = report.get("workflow", {})
+    status = report.get("status", "?")
+    glyph, code = _STATUS_STYLE.get(status, ("?", "0"))
+
+    out(_c(f"Workflow: {wf.get('name', '<unnamed>')}", "1", enabled=color))
+    if wf.get("description"):
+        out(f"  {wf['description']}")
+    out(f"  Status:   {_c(glyph + ' ' + status, code, enabled=color)}")
+    out(f"  Started:  {report.get('started_at', '-')}")
+    out(f"  Finished: {report.get('finished_at', '-')}")
+    out(f"  Duration: {_fmt_duration(report.get('duration'))}")
+
+    summary = report.get("summary", {})
+    if summary:
+        parts = []
+        for k in ("succeeded", "failed", "timed_out", "cancelled"):
+            v = summary.get(k, 0)
+            g, cde = _STATUS_STYLE[k]
+            parts.append(_c(f"{g} {v} {k}", cde, enabled=color))
+        out("  Summary:  " + "   ".join(parts) + f"   (total {summary.get('total', 0)})")
+    out()
+
+    steps = report.get("steps", [])
+    if not steps:
+        out("  (no steps)")
+        return
+
+    id_w = max(len(s.get("id", "")) for s in steps)
+    id_w = max(id_w, len("STEP"))
+
+    out(_c(f"  {'STEP':<{id_w}}  {'STATUS':<10}  {'ATTEMPTS':>8}  {'DURATION':>10}  DEPENDS ON",
+           "1", enabled=color))
+    out("  " + "-" * (id_w + 2 + 10 + 2 + 8 + 2 + 10 + 2 + 20))
+    for s in steps:
+        st = s.get("status", "?")
+        g, cde = _STATUS_STYLE.get(st, ("?", "0"))
+        deps = ", ".join(s.get("depends_on") or []) or "-"
+        out("  "
+            + f"{s.get('id', ''):<{id_w}}  "
+            + _c(f"{g} {st:<8}", cde, enabled=color) + "  "
+            + f"{s.get('attempt_count', 0):>8}  "
+            + f"{_fmt_duration(s.get('duration')):>10}  "
+            + deps)
+    out()
+
+    # Per-step detail
+    for s in steps:
+        st = s.get("status", "?")
+        g, cde = _STATUS_STYLE.get(st, ("?", "0"))
+        title = s.get("name") or s.get("id")
+        out(_c(f"• {s.get('id')}", "1", enabled=color)
+            + (f"  —  {title}" if s.get("name") else "")
+            + "   [" + _c(f"{g} {st}", cde, enabled=color) + "]")
+        if s.get("cancel_reason"):
+            out(f"    reason: {s['cancel_reason']}")
+        for a in s.get("attempts", []):
+            ec = a.get("exit_code")
+            tag = "TIMEOUT" if a.get("timed_out") else (f"exit={ec}" if ec is not None else "error")
+            out(f"    attempt #{a.get('number')}  {tag}  "
+                f"({_fmt_duration(a.get('duration'))})  "
+                f"{a.get('started_at', '')} → {a.get('finished_at', '')}")
+            if a.get("error"):
+                out(f"      error: {a['error']}")
+            if show_output:
+                _dump_stream("stdout", a.get("stdout", ""), out)
+                _dump_stream("stderr", a.get("stderr", ""), out)
+        out()
+
+
+def _dump_stream(label: str, content: str, out) -> None:
+    if not content:
+        return
+    out(f"      {label}:")
+    for line in content.rstrip("\n").splitlines() or [""]:
+        out(textwrap.indent(line, "        "))
+
+
+def load_report(path: str) -> dict:
+    with open(path, "r", encoding="utf-8") as f:
+        return json.load(f)
diff --git a/bujjictl/yaml_parser.py b/bujjictl/yaml_parser.py
new file mode 100644
index 0000000..e64157a
--- /dev/null
+++ b/bujjictl/yaml_parser.py
@@ -0,0 +1,379 @@
+"""
+A minimal, dependency-free YAML parser.
+
+Supports the subset of YAML needed for workflow definitions:
+  * mappings (key: value)
+  * sequences (- item)
+  * nested structures via indentation
+  * inline scalars: strings, ints, floats, bools, null
+  * single- and double-quoted strings
+  * block scalars: | (literal) and > (folded)
+  * full-line and trailing comments (outside quotes)
+  * blank lines
+
+It deliberately does NOT support anchors/aliases, flow collections,
+multi-document streams, tags, or other advanced YAML features.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Any
+
+
+class YamlError(Exception):
+    def __init__(self, message: str, line: int | None = None):
+        if line is not None:
+            super().__init__(f"line {line}: {message}")
+        else:
+            super().__init__(message)
+        self.line = line
+
+
+@dataclass
+class _Line:
+    num: int          # 1-based original line number
+    indent: int       # number of leading spaces
+    text: str         # content after indentation (may be empty)
+
+
+# ----------------------------------------------------------------------------
+# Pre-processing
+# ----------------------------------------------------------------------------
+
+def _strip_comment(s: str) -> str:
+    """Remove a trailing comment that is not inside a quoted string."""
+    out = []
+    i = 0
+    n = len(s)
+    in_single = False
+    in_double = False
+    while i < n:
+        ch = s[i]
+        if in_single:
+            out.append(ch)
+            if ch == "'":
+                in_single = False
+            i += 1
+            continue
+        if in_double:
+            out.append(ch)
+            if ch == "\\" and i + 1 < n:
+                out.append(s[i + 1])
+                i += 2
+                continue
+            if ch == '"':
+                in_double = False
+            i += 1
+            continue
+        if ch == "'":
+            in_single = True
+            out.append(ch)
+            i += 1
+            continue
+        if ch == '"':
+            in_double = True
+            out.append(ch)
+            i += 1
+            continue
+        if ch == "#" and (i == 0 or s[i - 1] in (" ", "\t")):
+            break
+        out.append(ch)
+        i += 1
+    return "".join(out).rstrip()
+
+
+def _preprocess(source: str) -> list[_Line]:
+    lines: list[_Line] = []
+    for num, raw in enumerate(source.splitlines(), start=1):
+        if "\t" in raw[: len(raw) - len(raw.lstrip("\t "))]:
+            raise YamlError("tabs are not allowed for indentation", num)
+        stripped_full = raw.rstrip()
+        # Preserve genuinely blank lines for block-scalar handling.
+        if stripped_full == "":
+            lines.append(_Line(num, 0, ""))
+            continue
+        indent = len(raw) - len(raw.lstrip(" "))
+        body = _strip_comment(raw[indent:])
+        if body == "":
+            # whole line was a comment -> treat as blank
+            lines.append(_Line(num, 0, ""))
+            continue
+        lines.append(_Line(num, indent, body))
+    return lines
+
+
+# ----------------------------------------------------------------------------
+# Scalar parsing
+# ----------------------------------------------------------------------------
+
+def _parse_scalar(token: str, line_num: int) -> Any:
+    s = token.strip()
+    if s == "":
+        return None
+    if s[0] == '"' and s[-1] == '"' and len(s) >= 2:
+        return _unescape_double(s[1:-1], line_num)
+    if s[0] == "'" and s[-1] == "'" and len(s) >= 2:
+        return s[1:-1].replace("''", "'")
+    low = s.lower()
+    if low in ("null", "~"):
+        return None
+    if low in ("true", "yes", "on"):
+        return True
+    if low in ("false", "no", "off"):
+        return False
+    # int
+    try:
+        if s.startswith(("0x", "0X")):
+            return int(s, 16)
+        if s.startswith(("0o", "0O")):
+            return int(s, 8)
+        return int(s)
+    except ValueError:
+        pass
+    # float
+    try:
+        return float(s)
+    except ValueError:
+        pass
+    return s
+
+
+def _unescape_double(s: str, line_num: int) -> str:
+    out = []
+    i = 0
+    escapes = {"n": "\n", "t": "\t", "r": "\r", '"': '"', "\\": "\\", "0": "\0"}
+    while i < len(s):
+        ch = s[i]
+        if ch == "\\":
+            i += 1
+            if i >= len(s):
+                raise YamlError("unterminated escape sequence", line_num)
+            e = s[i]
+            if e in escapes:
+                out.append(escapes[e])
+            else:
+                out.append(e)
+        else:
+            out.append(ch)
+        i += 1
+    return "".join(out)
+
+
+# ----------------------------------------------------------------------------
+# Core recursive parser
+# ----------------------------------------------------------------------------
+
+class _Parser:
+    def __init__(self, lines: list[_Line]):
+        self.lines = lines
+        self.pos = 0
+
+    # -- helpers ------------------------------------------------------------
+
+    def _peek(self) -> _Line | None:
+        while self.pos < len(self.lines) and self.lines[self.pos].text == "":
+            self.pos += 1
+        if self.pos < len(self.lines):
+            return self.lines[self.pos]
+        return None
+
+    def _split_key(self, text: str) -> tuple[str, str] | None:
+        """Split 'key: rest' respecting quotes. Returns (key, rest) or None."""
+        i = 0
+        n = len(text)
+        in_single = False
+        in_double = False
+        while i < n:
+            ch = text[i]
+            if in_single:
+                if ch == "'":
+                    in_single = False
+            elif in_double:
+                if ch == "\\":
+                    i += 1
+                elif ch == '"':
+                    in_double = False
+            elif ch == "'":
+                in_single = True
+            elif ch == '"':
+                in_double = True
+            elif ch == ":" and (i + 1 == n or text[i + 1] in (" ", "\t")):
+                key = text[:i].strip()
+                rest = text[i + 1:].strip()
+                return key, rest
+            i += 1
+        return None
+
+    # -- block scalar -------------------------------------------------------
+
+    def _parse_block_scalar(self, style: str, base_indent: int, line_num: int) -> str:
+        # style is '|' or '>' optionally followed by '-' or '+'
+        chomp = ""
+        if len(style) > 1:
+            chomp = style[1]
+        raw_lines: list[str] = []
+        content_indent: int | None = None
+        # Consume raw lines (do NOT use _peek; blank lines matter here).
+        while self.pos < len(self.lines):
+            ln = self.lines[self.pos]
+            if ln.text == "":
+                raw_lines.append("")
+                self.pos += 1
+                continue
+            if ln.indent <= base_indent:
+                break
+            if content_indent is None:
+                content_indent = ln.indent
+            if ln.indent < content_indent:
+                break
+            raw_lines.append(" " * (ln.indent - content_indent) + ln.text)
+            self.pos += 1
+        # Drop trailing blank entries we speculatively consumed past the block.
+        while raw_lines and raw_lines[-1] == "":
+            raw_lines.pop()
+        if style[0] == "|":
+            body = "\n".join(raw_lines)
+        else:  # '>' folded
+            out: list[str] = []
+            prev_blank = True
+            for r in raw_lines:
+                if r == "":
+                    out.append("\n")
+                    prev_blank = True
+                elif r.startswith(" "):
+                    if out and not out[-1].endswith("\n"):
+                        out.append("\n")
+                    out.append(r)
+                    out.append("\n")
+                    prev_blank = True
+                else:
+                    if not prev_blank:
+                        out.append(" ")
+                    out.append(r)
+                    prev_blank = False
+            body = "".join(out).rstrip("\n")
+        if chomp == "-":
+            return body
+        return body + ("\n" if body else "")
+
+    # -- value / mapping / sequence ----------------------------------------
+
+    def parse_block(self, indent: int) -> Any:
+        ln = self._peek()
+        if ln is None or ln.indent < indent:
+            return None
+        if ln.text.startswith("- ") or ln.text == "-":
+            return self._parse_sequence(ln.indent)
+        if self._split_key(ln.text) is not None:
+            return self._parse_mapping(ln.indent)
+        # bare scalar on its own line
+        self.pos += 1
+        return _parse_scalar(ln.text, ln.num)
+
+    def _parse_sequence(self, indent: int) -> list[Any]:
+        items: list[Any] = []
+        while True:
+            ln = self._peek()
+            if ln is None or ln.indent != indent:
+                break
+            if not (ln.text.startswith("- ") or ln.text == "-"):
+                break
+            self.pos += 1
+            after = ln.text[1:].lstrip(" ")
+            item_indent = indent + (len(ln.text) - len(ln.text[1:].lstrip(" ")))  # indent of content after '-'
+            if not after:
+                # '-' alone: nested block follows
+                items.append(self.parse_block(indent + 1))
+                continue
+            kv = self._split_key(after)
+            if kv is not None:
+                # '- key: value' starts an inline mapping; subsequent keys at item_indent.
+                items.append(self._parse_inline_seq_mapping(kv, item_indent, ln.num))
+            elif after in ("|", ">", "|-", "|+", ">-", ">+"):
+                items.append(self._parse_block_scalar(after, indent, ln.num))
+            else:
+                items.append(_parse_scalar(after, ln.num))
+        return items
+
+    def _parse_inline_seq_mapping(self, first_kv: tuple[str, str], indent: int, line_num: int) -> dict[str, Any]:
+        result: dict[str, Any] = {}
+        key, rest = first_kv
+        key = self._unquote_key(key, line_num)
+        result[key] = self._value_for_key(rest, indent, line_num)
+        # Continue reading sibling keys at `indent`.
+        while True:
+            ln = self._peek()
+            if ln is None or ln.indent != indent:
+                break
+            kv = self._split_key(ln.text)
+            if kv is None or ln.text.startswith("- ") or ln.text == "-":
+                break
+            self.pos += 1
+            k, r = kv
+            k = self._unquote_key(k, ln.num)
+            if k in result:
+                raise YamlError(f"duplicate mapping key '{k}'", ln.num)
+            result[k] = self._value_for_key(r, indent, ln.num)
+        return result
+
+    def _parse_mapping(self, indent: int) -> dict[str, Any]:
+        result: dict[str, Any] = {}
+        while True:
+            ln = self._peek()
+            if ln is None or ln.indent != indent:
+                break
+            if ln.text.startswith("- ") or ln.text == "-":
+                break
+            kv = self._split_key(ln.text)
+            if kv is None:
+                raise YamlError(f"expected 'key: value', got '{ln.text}'", ln.num)
+            self.pos += 1
+            key, rest = kv
+            key = self._unquote_key(key, ln.num)
+            if key in result:
+                raise YamlError(f"duplicate mapping key '{key}'", ln.num)
+            result[key] = self._value_for_key(rest, indent, ln.num)
+        return result
+
+    def _value_for_key(self, rest: str, key_indent: int, line_num: int) -> Any:
+        if rest in ("|", ">", "|-", "|+", ">-", ">+"):
+            return self._parse_block_scalar(rest, key_indent, line_num)
+        if rest:
+            return _parse_scalar(rest, line_num)
+        # No inline value: look at next non-blank line.
+        nxt = self._peek()
+        if nxt is None or nxt.indent <= key_indent:
+            return None
+        return self.parse_block(nxt.indent)
+
+    @staticmethod
+    def _unquote_key(key: str, line_num: int) -> str:
+        if len(key) >= 2 and key[0] == key[-1] and key[0] in ("'", '"'):
+            return str(_parse_scalar(key, line_num))
+        return key
+
+
+# ----------------------------------------------------------------------------
+# Public API
+# ----------------------------------------------------------------------------
+
+def load(source: str) -> Any:
+    """Parse a YAML document from a string."""
+    lines = _preprocess(source)
+    parser = _Parser(lines)
+    first = parser._peek()
+    if first is None:
+        return None
+    if first.indent != 0:
+        raise YamlError("top-level content must not be indented", first.num)
+    value = parser.parse_block(0)
+    trailing = parser._peek()
+    if trailing is not None:
+        raise YamlError(f"unexpected content '{trailing.text}'", trailing.num)
+    return value
+
+
+def load_file(path: str) -> Any:
+    with open(path, "r", encoding="utf-8") as f:
+        return load(f.read())
