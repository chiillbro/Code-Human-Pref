new file mode 100644
index 0000000..cbc2be2
--- /dev/null
+++ b/tests/test_engine.py
@@ -0,0 +1,106 @@
+import os
+import tempfile
+import time
+import unittest
+
+from bujjictl.engine import Engine, SUCCEEDED, FAILED, CANCELLED, TIMED_OUT
+from bujjictl.model import load_workflow
+
+
+def _wf(content: str):
+    fd, path = tempfile.mkstemp(suffix=".yaml")
+    with os.fdopen(fd, "w") as f:
+        f.write(content)
+    return load_workflow(path)
+
+
+SILENT = lambda msg: None
+
+
+class TestEngine(unittest.TestCase):
+    def test_simple_success(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n    run: 'echo hello'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.status, SUCCEEDED)
+        self.assertEqual(rep.steps[0].attempts[0].exit_code, 0)
+        self.assertIn("hello", rep.steps[0].attempts[0].stdout)
+
+    def test_dependency_order(self):
+        d = tempfile.mkdtemp()
+        marker = os.path.join(d, "m")
+        wf = _wf(
+            "name: t\nsteps:\n"
+            f"  - id: a\n    run: 'sleep 0.3 && touch {marker}'\n"
+            f"  - id: b\n    depends_on:\n      - a\n    run: 'test -f {marker}'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.status, SUCCEEDED)
+
+    def test_concurrency(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n    run: 'sleep 0.5'\n"
+            "  - id: b\n    run: 'sleep 0.5'\n"
+            "  - id: c\n    run: 'sleep 0.5'\n"
+        )
+        t0 = time.monotonic()
+        rep = Engine(wf, max_workers=4, logger=SILENT).run()
+        elapsed = time.monotonic() - t0
+        self.assertEqual(rep.status, SUCCEEDED)
+        self.assertLess(elapsed, 1.2, f"expected concurrent execution, took {elapsed:.2f}s")
+
+    def test_failure_cancels_downstream(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n    run: 'exit 1'\n"
+            "  - id: b\n    depends_on:\n      - a\n    run: 'echo nope'\n"
+            "  - id: c\n    depends_on:\n      - b\n    run: 'echo nope'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.status, FAILED)
+        by = {s.step.id: s for s in rep.steps}
+        self.assertEqual(by["a"].status, FAILED)
+        self.assertEqual(by["b"].status, CANCELLED)
+        self.assertEqual(by["c"].status, CANCELLED)
+        self.assertEqual(by["b"].attempts, [])
+
+    def test_retries(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n"
+            "    retries: 3\n"
+            "    retry_backoff: 0.05\n"
+            "    run: 'test \"$BUJJI_ATTEMPT\" -ge 3'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.status, SUCCEEDED)
+        self.assertEqual(len(rep.steps[0].attempts), 3)
+
+    def test_timeout(self):
+        wf = _wf(
+            "name: t\nsteps:\n"
+            "  - id: a\n    timeout: 0.4\n    run: 'sleep 5'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        self.assertEqual(rep.steps[0].status, TIMED_OUT)
+        self.assertTrue(rep.steps[0].attempts[0].timed_out)
+
+    def test_env_injection(self):
+        wf = _wf(
+            "name: t\n"
+            "env:\n  G: gee\n"
+            "steps:\n"
+            "  - id: a\n"
+            "    env:\n      L: ell\n"
+            "    run: 'echo \"$G-$L-$BUJJI_STEP_ID-$BUJJI_WORKFLOW\"'\n"
+        )
+        rep = Engine(wf, logger=SILENT).run()
+        out = rep.steps[0].attempts[0].stdout.strip()
+        self.assertEqual(out, "gee-ell-a-t")
+
+
+if __name__ == "__main__":
+    unittest.main()
