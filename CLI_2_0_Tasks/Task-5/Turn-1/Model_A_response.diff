@@ -0,0 +1,30 @@
+name: failure-demo
+description: Shows failure propagation, downstream cancellation, and timeouts.
+
+steps:
+  - id: ok
+    run: 'echo "this one is fine"'
+
+  - id: boom
+    depends_on: 
+      - ok
+    retries: 1
+    retry_backoff: 0.1
+    run: |
+      echo "about to fail" >&2
+      exit 1
+
+  - id: slow
+    depends_on:
+      - ok
+    timeout: 1
+    run: |
+      echo "sleeping..."
+      sleep 5
+      echo "you will never see this"
+
+  - id: downstream
+    depends_on:
+      - boom
+      - slow
+    run: 'echo "should be cancelled"'
