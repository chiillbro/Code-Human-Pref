--- /dev/null
+++ b/examples/hello.yaml
@@ -0,0 +1,57 @@
+# A small demo workflow showing dependencies, concurrency, env vars,
+# retries, and timeouts.
+
+name: hello
+description: Demo workflow for bujjictl
+
+env:
+  GREETING: "hello from bujjictl"
+
+defaults:
+  timeout: 30
+  retries: 0
+  retry_backoff: 0.5
+
+steps:
+  - id: prepare
+    name: Prepare workspace
+    run: |
+      echo "[prepare] $GREETING"
+      sleep 0.2
+
+  - id: lint
+    name: Lint
+    depends_on:
+      - prepare
+    run: |
+      echo "[lint] linting on attempt $BUJJI_ATTEMPT" >&2
+      sleep 0.3
+
+  - id: test
+    name: Test
+    depends_on:
+      - prepare
+    env:
+      TARGET: unit
+    run: |
+      echo "[test] running $TARGET tests"
+      sleep 0.3
+
+  - id: flaky
+    name: Flaky step (succeeds on 2nd try)
+    depends_on:
+      - prepare
+    retries: 2
+    retry_backoff: 0.2
+    run: |
+      echo "[flaky] attempt=$BUJJI_ATTEMPT"
+      test "$BUJJI_ATTEMPT" -ge 2
+
+  - id: package
+    name: Package
+    depends_on:
+      - lint
+      - test
+      - flaky
+    run: |
+      echo "[package] building artifact"
