+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+
+from . import miniyaml
+from .workflow import load_workflow, ValidationError
+from .engine import Engine
+from .report import render, load_report
+
+
+def _read_workflow(path: str):
+    try:
+        with open(path, "r", encoding="utf-8") as fh:
+            text = fh.read()
+    except OSError as exc:
+        print(f"error: cannot read {path!r}: {exc}", file=sys.stderr)
+        sys.exit(2)
+    try:
+        doc = miniyaml.load(text)
+    except miniyaml.YamlError as exc:
+        print(f"error: YAML parse error in {path}: {exc}", file=sys.stderr)
+        sys.exit(2)
+    stem = os.path.splitext(os.path.basename(path))[0]
+    return load_workflow(doc, source_name=stem)
+
+
+def cmd_validate(args: argparse.Namespace) -> int:
+    try:
+        wf = _read_workflow(args.file)
+    except ValidationError as exc:
+        print(f"✘ {args.file} is invalid:\n", file=sys.stderr)
+        for e in exc.errors:
+            print(f"  - {e}", file=sys.stderr)
+        return 1
+    print(f"✔ {args.file} is valid "
+          f"({len(wf.steps)} steps, max_parallel={wf.max_parallel})")
+    print("execution order: " + " -> ".join(wf.order))
+    return 0
+
+
+def cmd_run(args: argparse.Namespace) -> int:
+    try:
+        wf = _read_workflow(args.file)
+    except ValidationError as exc:
+        print(f"✘ validation failed:\n", file=sys.stderr)
+        for e in exc.errors:
+            print(f"  - {e}", file=sys.stderr)
+        return 2
+
+    engine = Engine(wf, verbose=not args.quiet)
+    result = engine.run()
+
+    out_path = args.output or f"{wf.name}.report.json"
+    with open(out_path, "w", encoding="utf-8") as fh:
+        json.dump(result, fh, indent=2)
+    print(f"\nreport written to {out_path}", file=sys.stderr)
+
+    if not args.no_summary:
+        print()
+        print(render(result, max_output_lines=args.lines))
+
+    return 0 if result["status"] == "success" else 1
+
+
+def cmd_report(args: argparse.Namespace) -> int:
+    try:
+        rep = load_report(args.file)
+    except (OSError, json.JSONDecodeError) as exc:
+        print(f"error: cannot load report {args.file!r}: {exc}",
+              file=sys.stderr)
+        return 2
+    color = None
+    if args.color == "always":
+        color = True
+    elif args.color == "never":
+        color = False
+    print(render(rep, color=color, max_output_lines=args.lines))
+    return 0
+
+
+def build_parser() -> argparse.ArgumentParser:
+    p = argparse.ArgumentParser(
+        prog="bujjictl",
+        description="Lightweight local-first workflow orchestration engine.",
+    )
+    sub = p.add_subparsers(dest="cmd", required=True)
+
+    v = sub.add_parser("validate", help="validate a workflow YAML file")
+    v.add_argument("file", help="path to workflow .yaml file")
+    v.set_defaults(func=cmd_validate)
+
+    r = sub.add_parser("run", help="validate and execute a workflow")
+    r.add_argument("file", help="path to workflow .yaml file")
+    r.add_argument("-o", "--output", help="path to write JSON report "
+                   "(default: <name>.report.json)")
+    r.add_argument("-q", "--quiet", action="store_true",
+                   help="suppress live progress output")
+    r.add_argument("--no-summary", action="store_true",
+                   help="do not print the pretty report after the run")
+    r.add_argument("--lines", type=int, default=10,
+                   help="max stdout/stderr lines per attempt in summary")
+    r.set_defaults(func=cmd_run)
+
+    rp = sub.add_parser("report", help="pretty-print a JSON run report")
+    rp.add_argument("file", help="path to .report.json file")
+    rp.add_argument("--color", choices=("auto", "always", "never"),
+                    default="auto")
+    rp.add_argument("--lines", type=int, default=20,
+                    help="max stdout/stderr lines per attempt")
+    rp.set_defaults(func=cmd_report)
+
+    return p
+
+
+def main(argv=None) -> int:
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
