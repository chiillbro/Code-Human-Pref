@@ -0,0 +1,54 @@
+name: demo-pipeline
+max_parallel: 3
+
+env:
+  GREETING: "hello from bujjictl"
+
+defaults:
+  timeout: 30
+  retries: 0
+  retry_backoff: 0.5
+
+steps:
+  - id: setup
+    run: |
+      echo "$GREETING"
+      echo "setting things up..."
+      sleep 0.2
+
+  - id: lint
+    needs: [setup]
+    run: |
+      echo "linting source (step=$BUJJI_STEP_ID)"
+      sleep 0.3
+
+  - id: test
+    needs: [setup]
+    env:
+      TEST_TARGET: unit
+    retries: 2
+    retry_backoff: 0.2
+    run: |
+      echo "running $TEST_TARGET tests"
+      sleep 0.3
+
+  - id: flaky
+    needs: [setup]
+    retries: 3
+    retry_backoff: 0.1
+    run: |
+      # succeed only on the 2nd attempt using a marker file
+      F="/tmp/bujji_flaky_$BUJJI_WORKFLOW"
+      if [ -f "$F" ]; then rm -f "$F"; echo "recovered"; exit 0; fi
+      touch "$F"; echo "transient failure" >&2; exit 1
+
+  - id: package
+    needs: [lint, test, flaky]
+    timeout: 10
+    run: |
+      echo "packaging artifact"
+      sleep 0.2
+
+  - id: deploy
+    needs: [package]
+    run: echo "deploying to staging"
