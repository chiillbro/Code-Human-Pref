index 0000000..1a6f0e2
--- /dev/null
+++ b/build/lib/bujjictl/workflow.py
@@ -0,0 +1,314 @@
+"""
+Workflow model and validation.
+
+Schema (YAML):
+
+    name: <string>                # optional, defaults to file stem
+    max_parallel: <int>           # optional, default = cpu_count
+    env:                          # optional, global env vars
+      KEY: value
+    defaults:                     # optional, applied to every step
+      timeout: <seconds>
+      retries: <int>
+      retry_backoff: <seconds>
+      shell: <string>             # default "/bin/sh"
+    steps:
+      - id: <identifier>          # required, [A-Za-z0-9_-]+, unique
+        run: <shell command>      # required (string, may be multi-line via |)
+        needs: [<id>, ...]        # optional
+        env: {KEY: value, ...}    # optional, merged over global env
+        timeout: <seconds>        # optional
+        retries: <int>            # optional, number of *additional* attempts
+        retry_backoff: <seconds>  # optional, base delay; attempt N waits base * 2**(N-1)
+        shell: <string>           # optional
+        cwd: <path>               # optional
+"""
+from __future__ import annotations
+
+import os
+import re
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Set
+
+_ID_RE = re.compile(r"^[A-Za-z0-9_-]+$")
+
+_STEP_KEYS = {
+    "id", "run", "needs", "env", "timeout", "retries",
+    "retry_backoff", "shell", "cwd",
+}
+_TOP_KEYS = {"name", "max_parallel", "env", "defaults", "steps"}
+_DEFAULT_KEYS = {"timeout", "retries", "retry_backoff", "shell"}
+
+
+class ValidationError(Exception):
+    def __init__(self, errors: List[str]):
+        self.errors = errors
+        super().__init__("\n".join(errors))
+
+
+@dataclass
+class Step:
+    id: str
+    run: str
+    needs: List[str] = field(default_factory=list)
+    env: Dict[str, str] = field(default_factory=dict)
+    timeout: float | None = None
+    retries: int = 0
+    retry_backoff: float = 1.0
+    shell: str = "/bin/sh"
+    cwd: str | None = None
+
+
+@dataclass
+class Workflow:
+    name: str
+    steps: Dict[str, Step]
+    order: List[str]          # topological order
+    max_parallel: int
+    global_env: Dict[str, str]
+
+    def downstream_of(self, step_id: str) -> Set[str]:
+        """All transitive dependents of ``step_id``."""
+        rev: Dict[str, List[str]] = {sid: [] for sid in self.steps}
+        for s in self.steps.values():
+            for dep in s.needs:
+                rev[dep].append(s.id)
+        out: Set[str] = set()
+        stack = [step_id]
+        while stack:
+            cur = stack.pop()
+            for child in rev[cur]:
+                if child not in out:
+                    out.add(child)
+                    stack.append(child)
+        return out
+
+
+# ---------------------------------------------------------------------------
+
+def _err(errors: List[str], path: str, msg: str) -> None:
+    errors.append(f"{path}: {msg}")
+
+
+def _coerce_env(raw: Any, path: str, errors: List[str]) -> Dict[str, str]:
+    if raw is None:
+        return {}
+    if not isinstance(raw, dict):
+        _err(errors, path, "must be a mapping of KEY: value")
+        return {}
+    out = {}
+    for k, v in raw.items():
+        if v is None:
+            v = ""
+        out[str(k)] = str(v)
+    return out
+
+
+def _coerce_num(raw: Any, path: str, errors: List[str], *, integer=False,
+                min_val=None) -> Any:
+    if raw is None:
+        return None
+    if integer:
+        if isinstance(raw, bool) or not isinstance(raw, int):
+            _err(errors, path, "must be an integer")
+            return None
+        val = raw
+    else:
+        if isinstance(raw, bool) or not isinstance(raw, (int, float)):
+            _err(errors, path, "must be a number")
+            return None
+        val = float(raw)
+    if min_val is not None and val < min_val:
+        _err(errors, path, f"must be >= {min_val}")
+    return val
+
+
+def load_workflow(doc: Any, *, source_name: str = "workflow") -> Workflow:
+    """Validate a parsed YAML document and return a Workflow.
+
+    Raises ValidationError listing *all* problems found.
+    """
+    errors: List[str] = []
+
+    if not isinstance(doc, dict):
+        raise ValidationError(["<root>: workflow file must be a mapping"])
+
+    for k in doc:
+        if k not in _TOP_KEYS:
+            _err(errors, f"<root>.{k}", f"unknown key (allowed: {sorted(_TOP_KEYS)})")
+
+    name = doc.get("name") or source_name
+    if not isinstance(name, str):
+        _err(errors, "name", "must be a string")
+        name = source_name
+
+    max_par = doc.get("max_parallel")
+    if max_par is None:
+        max_par = os.cpu_count() or 4
+    else:
+        mp = _coerce_num(max_par, "max_parallel", errors, integer=True, min_val=1)
+        max_par = mp or (os.cpu_count() or 4)
+
+    global_env = _coerce_env(doc.get("env"), "env", errors)
+
+    defaults = doc.get("defaults") or {}
+    if not isinstance(defaults, dict):
+        _err(errors, "defaults", "must be a mapping")
+        defaults = {}
+    for k in defaults:
+        if k not in _DEFAULT_KEYS:
+            _err(errors, f"defaults.{k}",
+                 f"unknown key (allowed: {sorted(_DEFAULT_KEYS)})")
+
+    d_timeout = _coerce_num(defaults.get("timeout"), "defaults.timeout", errors,
+                            min_val=0)
+    d_retries = _coerce_num(defaults.get("retries"), "defaults.retries", errors,
+                            integer=True, min_val=0)
+    d_backoff = _coerce_num(defaults.get("retry_backoff"),
+                            "defaults.retry_backoff", errors, min_val=0)
+    d_shell = defaults.get("shell")
+    if d_shell is not None and not isinstance(d_shell, str):
+        _err(errors, "defaults.shell", "must be a string")
+        d_shell = None
+
+    raw_steps = doc.get("steps")
+    if not isinstance(raw_steps, list) or not raw_steps:
+        _err(errors, "steps", "must be a non-empty list")
+        raw_steps = []
+
+    steps: Dict[str, Step] = {}
+    for i, raw in enumerate(raw_steps):
+        path = f"steps[{i}]"
+        if not isinstance(raw, dict):
+            _err(errors, path, "must be a mapping")
+            continue
+        for k in raw:
+            if k not in _STEP_KEYS:
+                _err(errors, f"{path}.{k}",
+                     f"unknown key (allowed: {sorted(_STEP_KEYS)})")
+
+        sid = raw.get("id")
+        if not isinstance(sid, str) or not _ID_RE.match(sid):
+            _err(errors, f"{path}.id",
+                 "required, must match [A-Za-z0-9_-]+")
+            continue
+        if sid in steps:
+            _err(errors, f"{path}.id", f"duplicate step id {sid!r}")
+            continue
+
+        run = raw.get("run")
+        if not isinstance(run, str) or not run.strip():
+            _err(errors, f"{path}.run", "required, must be a non-empty string")
+            run = "false"
+
+        needs_raw = raw.get("needs") or []
+        if isinstance(needs_raw, str):
+            needs_raw = [needs_raw]
+        if not isinstance(needs_raw, list):
+            _err(errors, f"{path}.needs", "must be a list of step ids")
+            needs_raw = []
+        needs: List[str] = []
+        for j, dep in enumerate(needs_raw):
+            if not isinstance(dep, str):
+                _err(errors, f"{path}.needs[{j}]", "must be a string")
+            elif dep == sid:
+                _err(errors, f"{path}.needs[{j}]",
+                     f"step {sid!r} cannot depend on itself")
+            elif dep in needs:
+                _err(errors, f"{path}.needs[{j}]", f"duplicate dependency {dep!r}")
+            else:
+                needs.append(dep)
+
+        timeout = _coerce_num(raw.get("timeout"), f"{path}.timeout", errors,
+                              min_val=0)
+        retries = _coerce_num(raw.get("retries"), f"{path}.retries", errors,
+                              integer=True, min_val=0)
+        backoff = _coerce_num(raw.get("retry_backoff"),
+                              f"{path}.retry_backoff", errors, min_val=0)
+        shell = raw.get("shell")
+        if shell is not None and not isinstance(shell, str):
+            _err(errors, f"{path}.shell", "must be a string")
+            shell = None
+        cwd = raw.get("cwd")
+        if cwd is not None and not isinstance(cwd, str):
+            _err(errors, f"{path}.cwd", "must be a string")
+            cwd = None
+
+        steps[sid] = Step(
+            id=sid,
+            run=run,
+            needs=needs,
+            env=_coerce_env(raw.get("env"), f"{path}.env", errors),
+            timeout=timeout if timeout is not None else d_timeout,
+            retries=retries if retries is not None else (d_retries or 0),
+            retry_backoff=backoff if backoff is not None else
+                          (d_backoff if d_backoff is not None else 1.0),
+            shell=shell or d_shell or "/bin/sh",
+            cwd=cwd,
+        )
+
+    # cross-step reference + cycle checks
+    for s in steps.values():
+        for dep in s.needs:
+            if dep not in steps:
+                _err(errors, f"steps[{s.id}].needs",
+                     f"references unknown step {dep!r}")
+
+    order: List[str] = []
+    if not errors:
+        order = _topo_sort(steps, errors)
+
+    if errors:
+        raise ValidationError(errors)
+
+    return Workflow(
+        name=str(name),
+        steps=steps,
+        order=order,
+        max_parallel=int(max_par),
+        global_env=global_env,
+    )
+
+
+def _topo_sort(steps: Dict[str, Step], errors: List[str]) -> List[str]:
+    indeg = {sid: 0 for sid in steps}
+    children: Dict[str, List[str]] = {sid: [] for sid in steps}
+    for s in steps.values():
+        for dep in s.needs:
+            indeg[s.id] += 1
+            children[dep].append(s.id)
+
+    ready = sorted(sid for sid, d in indeg.items() if d == 0)
+    order: List[str] = []
+    while ready:
+        cur = ready.pop(0)
+        order.append(cur)
+        for ch in children[cur]:
+            indeg[ch] -= 1
+            if indeg[ch] == 0:
+                ready.append(ch)
+        ready.sort()
+
+    if len(order) != len(steps):
+        remaining = set(steps) - set(order)
+        cycle = _find_cycle(steps, remaining)
+        _err(errors, "steps",
+             "dependency cycle detected: " + " -> ".join(cycle))
+    return order
+
+
+def _find_cycle(steps: Dict[str, Step], remaining: Set[str]) -> List[str]:
+    # walk from any remaining node following deps until we revisit one
+    start = next(iter(remaining))
+    seen: List[str] = []
+    cur = start
+    while cur not in seen:
+        seen.append(cur)
+        nxt = next((d for d in steps[cur].needs if d in remaining), None)
+        if nxt is None:
+            break
+        cur = nxt
+    if cur in seen:
+        i = seen.index(cur)
+        return seen[i:] + [cur]
+    return seen
