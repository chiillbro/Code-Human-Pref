--- /dev/null
+++ b/src/bujjictl/engine.py
@@ -0,0 +1,325 @@
+"""
+Execution engine.
+
+Runs workflow steps with:
+  * concurrency bounded by ``max_parallel`` (independent steps run together)
+  * dependency gating (a step starts only after all ``needs`` succeed)
+  * per-step timeout (process group killed on expiry)
+  * retries with exponential backoff
+  * env injection (process env <- global env <- step env <- BUJJI_* vars)
+  * graceful downstream cancellation when a step fails / times out
+  * Ctrl-C handling: running steps are terminated, pending steps cancelled
+"""
+from __future__ import annotations
+
+import datetime as _dt
+import os
+import signal
+import subprocess
+import sys
+import threading
+import time
+from dataclasses import dataclass, field, asdict
+from typing import Dict, List, Optional
+
+from .workflow import Step, Workflow
+
+
+# ---------------------------------------------------------------------------
+# Result records
+# ---------------------------------------------------------------------------
+
+@dataclass
+class Attempt:
+    index: int
+    started_at: str
+    ended_at: str
+    duration_sec: float
+    exit_code: Optional[int]
+    timed_out: bool
+    stdout: str
+    stderr: str
+    error: Optional[str] = None
+
+
+@dataclass
+class StepResult:
+    id: str
+    status: str                   # success | failed | timeout | cancelled | skipped
+    started_at: Optional[str] = None
+    ended_at: Optional[str] = None
+    duration_sec: float = 0.0
+    attempts: List[Attempt] = field(default_factory=list)
+    reason: Optional[str] = None  # for cancelled/skipped
+
+
+def _now_iso() -> str:
+    return _dt.datetime.now().isoformat(timespec="milliseconds")
+
+
+# ---------------------------------------------------------------------------
+# Single attempt execution
+# ---------------------------------------------------------------------------
+
+def _run_attempt(step: Step, env: Dict[str, str], idx: int,
+                 cancel_event: threading.Event) -> Attempt:
+    t0 = time.monotonic()
+    started = _now_iso()
+    timed_out = False
+    error: Optional[str] = None
+    exit_code: Optional[int] = None
+    stdout = stderr = ""
+
+    posix = os.name == "posix"
+    try:
+        proc = subprocess.Popen(
+            [step.shell, "-c", step.run],
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            cwd=step.cwd,
+            env=env,
+            start_new_session=posix,
+        )
+    except Exception as exc:  # e.g. shell not found, cwd missing
+        return Attempt(
+            index=idx, started_at=started, ended_at=_now_iso(),
+            duration_sec=time.monotonic() - t0, exit_code=None,
+            timed_out=False, stdout="", stderr="", error=f"{type(exc).__name__}: {exc}",
+        )
+
+    deadline = (time.monotonic() + step.timeout) if step.timeout else None
+
+    def _kill(sig):
+        try:
+            if posix:
+                os.killpg(proc.pid, sig)
+            else:
+                proc.send_signal(sig)
+        except Exception:
+            pass
+
+    # poll loop so we can react to cancel_event
+    while True:
+        try:
+            out, err_b = proc.communicate(timeout=0.1)
+            stdout = out.decode("utf-8", "replace")
+            stderr = err_b.decode("utf-8", "replace")
+            exit_code = proc.returncode
+            break
+        except subprocess.TimeoutExpired:
+            if cancel_event.is_set():
+                _kill(signal.SIGTERM)
+                try:
+                    out, err_b = proc.communicate(timeout=5)
+                except subprocess.TimeoutExpired:
+                    _kill(signal.SIGKILL)
+                    out, err_b = proc.communicate()
+                stdout = out.decode("utf-8", "replace")
+                stderr = err_b.decode("utf-8", "replace")
+                exit_code = proc.returncode
+                error = "cancelled"
+                break
+            if deadline and time.monotonic() > deadline:
+                timed_out = True
+                _kill(signal.SIGTERM)
+                try:
+                    out, err_b = proc.communicate(timeout=5)
+                except subprocess.TimeoutExpired:
+                    _kill(signal.SIGKILL)
+                    out, err_b = proc.communicate()
+                stdout = out.decode("utf-8", "replace")
+                stderr = err_b.decode("utf-8", "replace")
+                exit_code = proc.returncode
+                break
+
+    return Attempt(
+        index=idx, started_at=started, ended_at=_now_iso(),
+        duration_sec=round(time.monotonic() - t0, 4),
+        exit_code=exit_code, timed_out=timed_out,
+        stdout=stdout, stderr=stderr, error=error,
+    )
+
+
+def _run_step(step: Step, wf: Workflow, cancel_event: threading.Event,
+              log) -> StepResult:
+    res = StepResult(id=step.id, status="failed")
+    res.started_at = _now_iso()
+    t0 = time.monotonic()
+
+    base_env = dict(os.environ)
+    base_env.update(wf.global_env)
+    base_env.update(step.env)
+    base_env["BUJJI_STEP_ID"] = step.id
+    base_env["BUJJI_WORKFLOW"] = wf.name
+
+    max_attempts = 1 + max(0, step.retries)
+    for i in range(1, max_attempts + 1):
+        if cancel_event.is_set():
+            res.status = "cancelled"
+            res.reason = "run aborted"
+            break
+
+        log(f"▶ {step.id} (attempt {i}/{max_attempts})")
+        att = _run_attempt(step, base_env, i, cancel_event)
+        res.attempts.append(att)
+
+        if att.error == "cancelled":
+            res.status = "cancelled"
+            res.reason = "run aborted"
+            break
+        if att.timed_out:
+            res.status = "timeout"
+            log(f"⏱  {step.id} timed out after {step.timeout}s "
+                f"(attempt {i}/{max_attempts})")
+        elif att.exit_code == 0:
+            res.status = "success"
+            log(f"✔ {step.id} ({att.duration_sec:.2f}s)")
+            break
+        else:
+            res.status = "failed"
+            log(f"✘ {step.id} exit={att.exit_code} "
+                f"(attempt {i}/{max_attempts})")
+
+        if i < max_attempts and not cancel_event.is_set():
+            delay = step.retry_backoff * (2 ** (i - 1))
+            log(f"… {step.id} retrying in {delay:.1f}s")
+            # interruptible sleep
+            end = time.monotonic() + delay
+            while time.monotonic() < end and not cancel_event.is_set():
+                time.sleep(min(0.1, end - time.monotonic()))
+
+    res.ended_at = _now_iso()
+    res.duration_sec = round(time.monotonic() - t0, 4)
+    return res
+
+
+# ---------------------------------------------------------------------------
+# Scheduler
+# ---------------------------------------------------------------------------
+
+class Engine:
+    def __init__(self, wf: Workflow, *, verbose: bool = True):
+        self.wf = wf
+        self.verbose = verbose
+        self._lock = threading.Lock()
+        self._cv = threading.Condition(self._lock)
+        self._cancel = threading.Event()
+        self._results: Dict[str, StepResult] = {}
+        self._pending = set(wf.steps)
+        self._running: set[str] = set()
+        self._log_lock = threading.Lock()
+
+    def _log(self, msg: str) -> None:
+        if not self.verbose:
+            return
+        with self._log_lock:
+            ts = _dt.datetime.now().strftime("%H:%M:%S")
+            print(f"[{ts}] {msg}", file=sys.stderr, flush=True)
+
+    def _ready(self, sid: str) -> bool:
+        step = self.wf.steps[sid]
+        return all(
+            dep in self._results and self._results[dep].status == "success"
+            for dep in step.needs
+        )
+
+    def _skip_downstream(self, failed_sid: str, status_reason: str) -> None:
+        for sid in self.wf.downstream_of(failed_sid):
+            if sid in self._pending:
+                self._pending.discard(sid)
+                self._results[sid] = StepResult(
+                    id=sid, status="skipped",
+                    reason=f"upstream '{failed_sid}' {status_reason}",
+                )
+                self._log(f"⊘ {sid} skipped (upstream '{failed_sid}' "
+                          f"{status_reason})")
+
+    def run(self) -> dict:
+        run_started = _now_iso()
+        t0 = time.monotonic()
+
+        prev_handler = None
+        if threading.current_thread() is threading.main_thread():
+            def _sigint(_sig, _frm):
+                self._log("! received interrupt, cancelling…")
+                self._cancel.set()
+                with self._cv:
+                    self._cv.notify_all()
+            prev_handler = signal.signal(signal.SIGINT, _sigint)
+
+        try:
+            self._schedule_loop()
+        finally:
+            if prev_handler is not None:
+                signal.signal(signal.SIGINT, prev_handler)
+
+        # anything still pending after cancel
+        for sid in list(self._pending):
+            self._results[sid] = StepResult(
+                id=sid, status="cancelled", reason="run aborted",
+            )
+            self._pending.discard(sid)
+
+        run_ended = _now_iso()
+        statuses = [r.status for r in self._results.values()]
+        overall = "success" if all(s == "success" for s in statuses) else (
+            "cancelled" if self._cancel.is_set() else "failed"
+        )
+
+        return {
+            "workflow": self.wf.name,
+            "status": overall,
+            "started_at": run_started,
+            "ended_at": run_ended,
+            "duration_sec": round(time.monotonic() - t0, 4),
+            "max_parallel": self.wf.max_parallel,
+            "summary": {
+                s: statuses.count(s)
+                for s in ("success", "failed", "timeout", "skipped", "cancelled")
+                if statuses.count(s)
+            },
+            "steps": [asdict(self._results[sid]) for sid in self.wf.order],
+        }
+
+    def _schedule_loop(self) -> None:
+        threads: List[threading.Thread] = []
+        with self._cv:
+            while (self._pending or self._running) and not (
+                self._cancel.is_set() and not self._running
+            ):
+                # launch as many ready steps as parallelism allows
+                launched = True
+                while launched:
+                    launched = False
+                    if self._cancel.is_set():
+                        break
+                    if len(self._running) >= self.wf.max_parallel:
+                        break
+                    for sid in list(self._pending):
+                        if self._ready(sid):
+                            self._pending.discard(sid)
+                            self._running.add(sid)
+                            t = threading.Thread(
+                                target=self._worker, args=(sid,), daemon=True,
+                            )
+                            t.start()
+                            threads.append(t)
+                            launched = True
+                            if len(self._running) >= self.wf.max_parallel:
+                                break
+                if not self._pending and not self._running:
+                    break
+                self._cv.wait(timeout=0.2)
+
+        for t in threads:
+            t.join()
+
+    def _worker(self, sid: str) -> None:
+        step = self.wf.steps[sid]
+        res = _run_step(step, self.wf, self._cancel, self._log)
+        with self._cv:
+            self._running.discard(sid)
+            self._results[sid] = res
+            if res.status != "success":
+                self._skip_downstream(sid, res.status)
+            self._cv.notify_all()
diff --git a/src/bujjictl/miniyaml.py b/src/bujjictl/miniyaml.py
new file mode 100644
index 0000000..0936bd6
--- /dev/null
+++ b/src/bujjictl/miniyaml.py
@@ -0,0 +1,226 @@
+"""
+A small, dependency-free YAML loader supporting the subset needed for
+bujjictl workflow files.
+
+Supported features:
+  * Block mappings (``key: value``) with 2+ space indentation.
+  * Block sequences (``- item``), including sequences of mappings.
+  * Inline flow sequences (``[a, b, c]``) of scalars.
+  * Scalars: unquoted, single-quoted, double-quoted, int, float, bool, null.
+  * Block literal scalars (``key: |``) for multi-line shell commands.
+  * Full-line and trailing ``#`` comments (outside quotes).
+
+Not supported: anchors/aliases, flow mappings, multi-document streams,
+``>`` folded scalars, complex keys. These raise ``YamlError`` with a
+line number so validation fails fast rather than mis-parsing.
+"""
+from __future__ import annotations
+
+import re
+from typing import Any, List, Tuple
+
+
+class YamlError(Exception):
+    def __init__(self, msg: str, line: int | None = None):
+        super().__init__(f"line {line}: {msg}" if line else msg)
+        self.line = line
+
+
+_INT_RE = re.compile(r"^-?\d+$")
+_FLOAT_RE = re.compile(r"^-?\d+\.\d+$")
+
+
+def _scalar(tok: str) -> Any:
+    s = tok.strip()
+    if s == "" or s == "~" or s.lower() == "null":
+        return None
+    if s.lower() == "true":
+        return True
+    if s.lower() == "false":
+        return False
+    if len(s) >= 2 and s[0] == s[-1] and s[0] in ("'", '"'):
+        inner = s[1:-1]
+        if s[0] == '"':
+            inner = inner.encode("utf-8").decode("unicode_escape")
+        return inner
+    if _INT_RE.match(s):
+        return int(s)
+    if _FLOAT_RE.match(s):
+        return float(s)
+    return s
+
+
+def _strip_comment(s: str) -> str:
+    out = []
+    quote = None
+    for i, ch in enumerate(s):
+        if quote:
+            out.append(ch)
+            if ch == quote:
+                quote = None
+        elif ch in ("'", '"'):
+            quote = ch
+            out.append(ch)
+        elif ch == "#":
+            break
+        else:
+            out.append(ch)
+    return "".join(out)
+
+
+def _flow_seq(s: str, lineno: int) -> list:
+    body = s.strip()[1:-1].strip()
+    if not body:
+        return []
+    # naive split on commas not inside quotes
+    parts, cur, quote = [], [], None
+    for ch in body:
+        if quote:
+            cur.append(ch)
+            if ch == quote:
+                quote = None
+        elif ch in ("'", '"'):
+            quote = ch
+            cur.append(ch)
+        elif ch == ",":
+            parts.append("".join(cur))
+            cur = []
+        else:
+            cur.append(ch)
+    parts.append("".join(cur))
+    return [_scalar(p) for p in parts]
+
+
+# ---------------------------------------------------------------------------
+# Tokenizer: raw text -> list of (lineno, indent, content) with comments and
+# blank lines removed. Block-literal bodies are left in place for the parser.
+# ---------------------------------------------------------------------------
+
+def _tokenize(text: str) -> List[Tuple[int, int, str]]:
+    lines = text.replace("\t", "  ").split("\n")
+    out: List[Tuple[int, int, str]] = []
+    for i, raw in enumerate(lines, 1):
+        out.append((i, len(raw) - len(raw.lstrip(" ")), raw))
+    return out
+
+
+class _Parser:
+    def __init__(self, text: str):
+        self.lines = _tokenize(text)
+        self.pos = 0
+
+    def peek(self):
+        while self.pos < len(self.lines):
+            ln, ind, raw = self.lines[self.pos]
+            stripped = _strip_comment(raw).rstrip()
+            if stripped.strip() == "":
+                self.pos += 1
+                continue
+            return ln, ind, stripped.lstrip(" ")
+        return None
+
+    def advance(self):
+        self.pos += 1
+
+    # ---- block literal -------------------------------------------------
+    def read_block_literal(self, base_indent: int) -> str:
+        body = []
+        min_ind = None
+        while self.pos < len(self.lines):
+            ln, ind, raw = self.lines[self.pos]
+            if raw.strip() == "":
+                body.append("")
+                self.pos += 1
+                continue
+            if ind <= base_indent:
+                break
+            if min_ind is None:
+                min_ind = ind
+            body.append(raw[min_ind:])
+            self.pos += 1
+        # trim trailing blank lines
+        while body and body[-1] == "":
+            body.pop()
+        return "\n".join(body) + ("\n" if body else "")
+
+    # ---- value dispatch ------------------------------------------------
+    def parse_value(self, indent: int, lineno: int, inline: str) -> Any:
+        inline = inline.strip()
+        if inline == "|":
+            return self.read_block_literal(indent)
+        if inline.startswith("[") and inline.endswith("]"):
+            return _flow_seq(inline, lineno)
+        if inline != "":
+            return _scalar(inline)
+        # value is on following lines: nested mapping or sequence
+        nxt = self.peek()
+        if nxt is None or nxt[1] <= indent:
+            return None
+        child_indent = nxt[1]
+        if nxt[2].startswith("- "):  # sequence
+            return self.parse_sequence(child_indent)
+        return self.parse_mapping(child_indent)
+
+    def parse_sequence(self, indent: int) -> list:
+        items: list = []
+        while True:
+            nxt = self.peek()
+            if nxt is None or nxt[1] != indent or not nxt[2].startswith("-"):
+                break
+            ln, ind, content = nxt
+            self.advance()
+            after = content[1:].lstrip(" ")
+            if after == "" or after == "|":
+                # nested block under this dash
+                if after == "|":
+                    items.append(self.read_block_literal(indent))
+                else:
+                    sub = self.peek()
+                    if sub is None or sub[1] <= indent:
+                        items.append(None)
+                    elif sub[2].startswith("- "):
+                        items.append(self.parse_sequence(sub[1]))
+                    else:
+                        items.append(self.parse_mapping(sub[1]))
+            elif ":" in after and not after.lstrip().startswith(("'", '"', "[")):
+                # mapping starting on same line as dash, e.g. ``- id: foo``
+                key_indent = indent + (len(content) - len(after))
+                # rewind so parse_mapping sees this line
+                self.pos -= 1
+                # temporarily replace current line content without leading "- "
+                ln2, ind2, raw2 = self.lines[self.pos]
+                self.lines[self.pos] = (ln2, key_indent, " " * key_indent + after)
+                items.append(self.parse_mapping(key_indent))
+                self.lines[self.pos - 1] = (ln2, ind2, raw2)  # restore (cosmetic)
+            else:
+                items.append(_scalar(after))
+        return items
+
+    def parse_mapping(self, indent: int) -> dict:
+        result: dict = {}
+        while True:
+            nxt = self.peek()
+            if nxt is None or nxt[1] != indent:
+                break
+            ln, ind, content = nxt
+            if content.startswith("- "):
+                break
+            m = re.match(r"^([^:\s][^:]*?)\s*:\s?(.*)$", content)
+            if not m:
+                raise YamlError(f"expected 'key: value', got {content!r}", ln)
+            key, rest = m.group(1), m.group(2)
+            self.advance()
+            result[key] = self.parse_value(indent, ln, rest)
+        return result
+
+    def parse(self) -> Any:
+        nxt = self.peek()
+        if nxt is None:
+            return None
+        if nxt[2].startswith("- "):
+            return self.parse_sequence(nxt[1])
+        return self.parse_mapping(nxt[1])
+
+
+def load(text: str) -> Any:
+    return _Parser(text).parse()
diff --git a/src/bujjictl/report.py b/src/bujjictl/report.py
new file mode 100644
index 0000000..2ab95a1
--- /dev/null
+++ b/src/bujjictl/report.py
@@ -0,0 +1,101 @@
+"""Pretty-print a JSON run report to the terminal."""
+from __future__ import annotations
+
+import json
+import sys
+import textwrap
+from typing import Any, Dict
+
+_STATUS_STYLE = {
+    "success":   ("✔", "32"),
+    "failed":    ("✘", "31"),
+    "timeout":   ("⏱", "33"),
+    "skipped":   ("⊘", "90"),
+    "cancelled": ("✖", "35"),
+}
+
+
+def _c(s: str, code: str, enable: bool) -> str:
+    return f"\033[{code}m{s}\033[0m" if enable else s
+
+
+def _trunc_block(text: str, label: str, color: bool, max_lines: int) -> str:
+    if not text:
+        return ""
+    lines = text.rstrip("\n").split("\n")
+    shown = lines[:max_lines]
+    out = [_c(f"      {label}:", "36", color)]
+    out += [f"        {ln}" for ln in shown]
+    if len(lines) > max_lines:
+        out.append(_c(f"        … ({len(lines) - max_lines} more lines)",
+                      "90", color))
+    return "\n".join(out) + "\n"
+
+
+def render(report: Dict[str, Any], *, color: bool | None = None,
+           max_output_lines: int = 20) -> str:
+    if color is None:
+        color = sys.stdout.isatty()
+
+    buf: list[str] = []
+    title = f"Workflow: {report.get('workflow', '?')}"
+    status = report.get("status", "?")
+    sym, code = _STATUS_STYLE.get(status, ("?", "0"))
+    buf.append(_c("═" * max(60, len(title) + 4), "90", color))
+    buf.append(_c(title, "1", color))
+    buf.append(f"Status:     {_c(sym + ' ' + status.upper(), code, color)}")
+    buf.append(f"Started:    {report.get('started_at', '-')}")
+    buf.append(f"Ended:      {report.get('ended_at', '-')}")
+    buf.append(f"Duration:   {report.get('duration_sec', 0):.2f}s")
+    summary = report.get("summary", {})
+    if summary:
+        parts = [f"{v} {k}" for k, v in summary.items()]
+        buf.append(f"Summary:    {', '.join(parts)}")
+    buf.append(_c("─" * 60, "90", color))
+
+    steps = report.get("steps", [])
+    idw = max((len(s["id"]) for s in steps), default=4)
+
+    for s in steps:
+        st = s.get("status", "?")
+        sym, code = _STATUS_STYLE.get(st, ("?", "0"))
+        dur = s.get("duration_sec") or 0
+        attempts = s.get("attempts") or []
+        natt = len(attempts)
+        head = (
+            f"  {_c(sym, code, color)} "
+            f"{_c(s['id'].ljust(idw), '1', color)}  "
+            f"{_c(st.ljust(9), code, color)}  "
+            f"{dur:7.2f}s"
+        )
+        if natt:
+            head += f"  attempts={natt}"
+        if s.get("reason"):
+            head += f"  ({s['reason']})"
+        buf.append(head)
+
+        for att in attempts:
+            line = (f"    attempt {att['index']}: "
+                    f"exit={att.get('exit_code')}  "
+                    f"{att.get('duration_sec', 0):.2f}s")
+            if att.get("timed_out"):
+                line += "  " + _c("[timed out]", "33", color)
+            if att.get("error"):
+                line += f"  error={att['error']}"
+            buf.append(line)
+            buf_str = _trunc_block(att.get("stdout", ""), "stdout",
+                                   color, max_output_lines)
+            if buf_str:
+                buf.append(buf_str.rstrip("\n"))
+            buf_str = _trunc_block(att.get("stderr", ""), "stderr",
+                                   color, max_output_lines)
+            if buf_str:
+                buf.append(buf_str.rstrip("\n"))
+
+    buf.append(_c("═" * 60, "90", color))
+    return "\n".join(buf)
+
+
+def load_report(path: str) -> Dict[str, Any]:
+    with open(path, "r", encoding="utf-8") as fh:
+        return json.load(fh)
