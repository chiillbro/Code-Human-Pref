+++ b/bujjictl/condition.py
@@ -0,0 +1,281 @@
+"""
+Tiny condition-expression language for step `condition:` fields.
+
+Grammar (informal):
+
+    expr      := or_expr
+    or_expr   := and_expr ( "or" and_expr )*
+    and_expr  := unary ( "and" unary )*
+    unary     := "not" unary | primary
+    primary   := "(" expr ")" | comparison
+    comparison:=
+          REF.status   ("==" | "!=") STATUS
+        | REF.exit_code("==" | "!=") INT
+        | REF.stdout   "contains"    STRING
+        | REF.stderr   "contains"    STRING
+
+    REF    := <step id>
+    STATUS := succeeded | failed | timed_out | skipped | cancelled
+    STRING := "double-quoted" or 'single-quoted'
+
+The compiled Condition exposes:
+    .references  -> set[str] of step ids referenced
+    .evaluate(lookup) -> bool
+        where lookup(step_id) -> {"status": str, "exit_code": int|None,
+                                  "stdout": str, "stderr": str}
+"""
+
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass
+from typing import Any, Callable
+
+
+class ConditionError(Exception):
+    pass
+
+
+_STATUSES = {"succeeded", "failed", "timed_out", "skipped", "cancelled"}
+_FIELDS = {"status", "exit_code", "stdout", "stderr"}
+
+_TOKEN_RE = re.compile(
+    r"""
+    \s*(?:
+        (?P<lparen>\()
+      | (?P<rparen>\))
+      | (?P<op>==|!=)
+      | (?P<dot>\.)
+      | (?P<string>"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')
+      | (?P<int>-?\d+)
+      | (?P<ident>[A-Za-z_][A-Za-z0-9_\-]*)
+    )
+    """,
+    re.VERBOSE,
+)
+
+
+@dataclass
+class _Tok:
+    kind: str
+    value: Any
+
+
+def _tokenize(src: str) -> list[_Tok]:
+    pos = 0
+    toks: list[_Tok] = []
+    while pos < len(src):
+        m = _TOKEN_RE.match(src, pos)
+        if not m or m.end() == pos:
+            snippet = src[pos:pos + 12]
+            raise ConditionError(f"unexpected character near '{snippet}'")
+        pos = m.end()
+        for kind in ("lparen", "rparen", "op", "dot", "string", "int", "ident"):
+            v = m.group(kind)
+            if v is None:
+                continue
+            if kind == "string":
+                v = _unquote(v)
+            elif kind == "int":
+                v = int(v)
+            toks.append(_Tok(kind, v))
+            break
+    # trailing whitespace
+    return toks
+
+
+def _unquote(s: str) -> str:
+    q = s[0]
+    body = s[1:-1]
+    if q == '"':
+        return body.encode("utf-8").decode("unicode_escape")
+    return body.replace("\\'", "'")
+
+
+# --- AST ---------------------------------------------------------------------
+
+Lookup = Callable[[str], dict[str, Any]]
+
+
+class _Node:
+    def references(self) -> set[str]:
+        raise NotImplementedError
+
+    def evaluate(self, lookup: Lookup) -> bool:
+        raise NotImplementedError
+
+
+@dataclass
+class _BoolOp(_Node):
+    op: str  # 'and' | 'or'
+    parts: list[_Node]
+
+    def references(self) -> set[str]:
+        out: set[str] = set()
+        for p in self.parts:
+            out |= p.references()
+        return out
+
+    def evaluate(self, lookup: Lookup) -> bool:
+        if self.op == "and":
+            return all(p.evaluate(lookup) for p in self.parts)
+        return any(p.evaluate(lookup) for p in self.parts)
+
+
+@dataclass
+class _Not(_Node):
+    inner: _Node
+
+    def references(self) -> set[str]:
+        return self.inner.references()
+
+    def evaluate(self, lookup: Lookup) -> bool:
+        return not self.inner.evaluate(lookup)
+
+
+@dataclass
+class _Cmp(_Node):
+    step: str
+    field: str
+    op: str       # '==', '!=', 'contains'
+    rhs: Any
+
+    def references(self) -> set[str]:
+        return {self.step}
+
+    def evaluate(self, lookup: Lookup) -> bool:
+        info = lookup(self.step)
+        lhs = info.get(self.field)
+        if self.op == "contains":
+            return isinstance(lhs, str) and str(self.rhs) in lhs
+        if self.op == "==":
+            return lhs == self.rhs
+        if self.op == "!=":
+            return lhs != self.rhs
+        raise ConditionError(f"unknown operator '{self.op}'")
+
+
+# --- Parser ------------------------------------------------------------------
+
+class _Parser:
+    def __init__(self, toks: list[_Tok]):
+        self.toks = toks
+        self.i = 0
+
+    def _peek(self) -> _Tok | None:
+        return self.toks[self.i] if self.i < len(self.toks) else None
+
+    def _eat(self, kind: str, value: Any = None) -> _Tok:
+        t = self._peek()
+        if t is None or t.kind != kind or (value is not None and t.value != value):
+            exp = value if value is not None else kind
+            got = "end of input" if t is None else repr(t.value)
+            raise ConditionError(f"expected {exp}, got {got}")
+        self.i += 1
+        return t
+
+    def _accept_kw(self, word: str) -> bool:
+        t = self._peek()
+        if t and t.kind == "ident" and t.value == word:
+            self.i += 1
+            return True
+        return False
+
+    def parse(self) -> _Node:
+        node = self._or()
+        if self._peek() is not None:
+            raise ConditionError(f"unexpected trailing token {self._peek().value!r}")
+        return node
+
+    def _or(self) -> _Node:
+        parts = [self._and()]
+        while self._accept_kw("or"):
+            parts.append(self._and())
+        return parts[0] if len(parts) == 1 else _BoolOp("or", parts)
+
+    def _and(self) -> _Node:
+        parts = [self._unary()]
+        while self._accept_kw("and"):
+            parts.append(self._unary())
+        return parts[0] if len(parts) == 1 else _BoolOp("and", parts)
+
+    def _unary(self) -> _Node:
+        if self._accept_kw("not"):
+            return _Not(self._unary())
+        return self._primary()
+
+    def _primary(self) -> _Node:
+        t = self._peek()
+        if t and t.kind == "lparen":
+            self.i += 1
+            node = self._or()
+            self._eat("rparen")
+            return node
+        return self._comparison()
+
+    def _comparison(self) -> _Node:
+        step = self._eat("ident").value
+        if step in ("and", "or", "not", "contains"):
+            raise ConditionError(f"expected step id, got keyword '{step}'")
+        self._eat("dot")
+        field = self._eat("ident").value
+        if field not in _FIELDS:
+            raise ConditionError(
+                f"unknown field '{field}' (expected one of: {', '.join(sorted(_FIELDS))})"
+            )
+
+        t = self._peek()
+        if t and t.kind == "op":
+            op = t.value
+            self.i += 1
+            rhs = self._rhs_for(field, op)
+            return _Cmp(step, field, op, rhs)
+        if self._accept_kw("contains"):
+            if field not in ("stdout", "stderr"):
+                raise ConditionError(f"'contains' only valid for stdout/stderr, not '{field}'")
+            rhs = self._eat("string").value
+            return _Cmp(step, field, "contains", rhs)
+        raise ConditionError("expected '==', '!=' or 'contains'")
+
+    def _rhs_for(self, field: str, op: str) -> Any:
+        t = self._peek()
+        if t is None:
+            raise ConditionError(f"expected value after '{op}'")
+        self.i += 1
+        if field == "status":
+            if t.kind != "ident" or t.value not in _STATUSES:
+                raise ConditionError(
+                    f"status must be compared to one of: {', '.join(sorted(_STATUSES))}"
+                )
+            return t.value
+        if field == "exit_code":
+            if t.kind != "int":
+                raise ConditionError("exit_code must be compared to an integer")
+            return t.value
+        # stdout / stderr with == / !=
+        if t.kind != "string":
+            raise ConditionError(f"'{field}' must be compared to a quoted string")
+        return t.value
+
+
+# --- Public ------------------------------------------------------------------
+
+class Condition:
+    def __init__(self, source: str, node: _Node):
+        self.source = source
+        self._node = node
+        self.references = node.references()
+
+    def evaluate(self, lookup: Lookup) -> bool:
+        return self._node.evaluate(lookup)
+
+    def __repr__(self) -> str:
+        return f"Condition({self.source!r})"
+
+
+def compile_condition(source: str) -> Condition:
+    toks = _tokenize(source)
+    if not toks:
+        raise ConditionError("condition is empty")
+    node = _Parser(toks).parse()
+    return Condition(source, node)


diff --git a/examples/conditional.yaml b/examples/conditional.yaml
new file mode 100644
index 0000000..8908d3e
--- /dev/null
+++ b/examples/conditional.yaml
@@ -0,0 +1,38 @@
+name: conditional
+description: Deploy on success, run cleanup on failure; gate a step on stdout.
+
+steps:
+  - id: build
+    run: |
+      echo "building..."
+      # flip to `exit 1` to see the cleanup branch run instead
+      exit 0
+
+  - id: deploy
+    depends_on:
+      - build
+    condition: 'build.status == succeeded'
+    run: 'echo "deploying"'
+
+  - id: cleanup
+    depends_on:
+      - build
+    condition: 'build.status == failed or build.status == timed_out'
+    run: 'echo "cleaning up after failed build"'
+
+  - id: probe
+    run: 'echo "MODE=prod"'
+
+  - id: prod-only
+    depends_on:
+      - probe
+    condition: 'probe.stdout contains "MODE=prod"'
+    run: 'echo "running prod-only step"'
+
+  - id: notify
+    # depends on deploy + cleanup; one of them is always skipped, the other runs.
+    # default rule: at least one non-skipped dep succeeded -> notify still runs.
+    depends_on:
+      - deploy
+      - cleanup
+    run: 'echo "notify: done"'



diff --git a/tests/test_condition.py b/tests/test_condition.py
new file mode 100644
index 0000000..78f05b0
--- /dev/null
+++ b/tests/test_condition.py
@@ -0,0 +1,59 @@
+import unittest
+
+from bujjictl.condition import compile_condition, ConditionError
+
+
+def view(**kw):
+    base = {"status": "succeeded", "exit_code": 0, "stdout": "", "stderr": ""}
+    base.update(kw)
+    return base
+
+
+class TestCondition(unittest.TestCase):
+    def test_status_eq(self):
+        c = compile_condition("build.status == succeeded")
+        self.assertEqual(c.references, {"build"})
+        self.assertTrue(c.evaluate(lambda r: view(status="succeeded")))
+        self.assertFalse(c.evaluate(lambda r: view(status="failed")))
+
+    def test_status_ne(self):
+        c = compile_condition("build.status != failed")
+        self.assertTrue(c.evaluate(lambda r: view(status="succeeded")))
+
+    def test_contains(self):
+        c = compile_condition('build.stdout contains "MARK"')
+        self.assertTrue(c.evaluate(lambda r: view(stdout="xxMARKyy")))
+        self.assertFalse(c.evaluate(lambda r: view(stdout="nope")))
+
+    def test_exit_code(self):
+        c = compile_condition("a.exit_code == 7")
+        self.assertTrue(c.evaluate(lambda r: view(exit_code=7)))
+        self.assertFalse(c.evaluate(lambda r: view(exit_code=0)))
+
+    def test_and_or_not_paren(self):
+        c = compile_condition("(a.status == failed or a.status == timed_out) and not b.status == skipped")
+        self.assertEqual(c.references, {"a", "b"})
+        lk = {"a": view(status="failed"), "b": view(status="succeeded")}
+        self.assertTrue(c.evaluate(lambda r: lk[r]))
+        lk["b"] = view(status="skipped")
+        self.assertFalse(c.evaluate(lambda r: lk[r]))
+
+    def test_bad_status_value(self):
+        with self.assertRaises(ConditionError):
+            compile_condition("a.status == winning")
+
+    def test_bad_field(self):
+        with self.assertRaises(ConditionError):
+            compile_condition("a.nope == 1")
+
+    def test_contains_on_status(self):
+        with self.assertRaises(ConditionError):
+            compile_condition('a.status contains "x"')
+
+    def test_trailing(self):
+        with self.assertRaises(ConditionError):
+            compile_condition("a.status == failed junk")
+
+
+if __name__ == "__main__":
+    unittest.main()



diff --git a/README.md b/README.md
index a31861d..af53625 100644
--- a/README.md
+++ b/README.md
@@ -56,6 +56,7 @@ steps:                       # required, non-empty list
     retries: 2
     retry_backoff: 0.5
     shell: /bin/bash
+    condition: 'fetch.status == succeeded'   # optional, see below
 ```
 
 ### Injected environment variables
@@ -70,13 +71,50 @@ Every step receives, in addition to the process environment + `env:` blocks:
 
 ### Execution semantics
 
-* The steps form a DAG via `depends_on`. Steps with no unmet dependencies are
-  scheduled immediately and run **concurrently** (bounded by `--max-workers`).
-* If a step **fails** or **times out** (after exhausting retries), every
-  transitive downstream step is marked `cancelled` and never runs.
+* The steps form a DAG via `depends_on`. A step becomes **ready** once *all*
+  its dependencies have reached a terminal state. Ready, independent steps run
+  **concurrently** (bounded by `--max-workers`).
+* When a step is ready, it is resolved as follows:
+  * **With an explicit `condition:`** — the expression is evaluated; *true* →
+    run, *false* → step is marked `skipped`.
+  * **Without a condition (default)** — if any dependency is
+    `failed`/`timed_out`/`cancelled` the step is `cancelled`; else if it has
+    dependencies and *all* of them are `skipped` the step is `skipped`;
+    otherwise it runs (so a mix of `succeeded` + `skipped` deps still runs).
+* `skipped` steps do **not** fail the workflow; the run is `succeeded` if every
+  step is `succeeded` or `skipped`.
 * Retries use exponential backoff: `retry_backoff * 2^(attempt-1)` seconds.
 * On timeout the step's process group is sent `SIGTERM`, then `SIGKILL`.
 
+### Conditions
+
+`condition:` is a small boolean expression over the step's **dependencies**
+(referencing any other step is a validation error):
+
+```text
+<dep>.status    == | !=  succeeded | failed | timed_out | skipped | cancelled
+<dep>.exit_code == | !=  <int>
+<dep>.stdout    contains "<string>"
+<dep>.stderr    contains "<string>"
+```
+
+Combine with `and`, `or`, `not`, and parentheses. Examples:
+
+```yaml
+condition: 'build.status == failed or build.status == timed_out'
+condition: 'probe.stdout contains "MODE=prod" and not build.status == skipped'
+```
+
+`stdout`/`stderr`/`exit_code` refer to the dependency's **last attempt**.
+
+### Interrupts (Ctrl-C / SIGTERM)
+
+On `SIGINT`/`SIGTERM` the engine performs a graceful shutdown: every running
+step's process group is sent `SIGTERM` (then `SIGKILL` if it doesn't exit), all
+running and pending steps are marked `cancelled` with reason `run interrupted`,
+and a complete JSON report is still written. `bujjictl run` then exits with
+code **130**.
+
 ### Validation
 
 `bujjictl validate` (and the start of every `run`) checks, **before executing
@@ -88,6 +126,8 @@ anything**:
 * Step ids are unique and well-formed.
 * Every `depends_on` references an existing step; no self-dependencies.
 * **No cycles** in the dependency graph.
+* `condition:` expressions parse, use valid fields/status names, and only
+  reference steps listed in `depends_on`.
 
 All problems are collected and reported together — not just the first one.
 
@@ -103,8 +143,8 @@ bujjictl report   <report.json> [--no-output]
 
 * `validate` — parse + validate only. Exit 0 on success, 1 on error.
 * `run` — validate, execute, write a JSON report (default
-  `<name>.report.json`), then pretty-print it. Exit 0 on success, 1 on
-  validation error, 2 if any step did not succeed.
+  `<name>.report.json`), then pretty-print it. Exit **0** on success, **1** on
+  validation error, **2** if any step failed/timed-out, **130** if interrupted.
 * `report` — pretty-print a previously written JSON report.
 
 ---
