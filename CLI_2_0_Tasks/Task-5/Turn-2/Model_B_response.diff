+class TestInterrupt(unittest.TestCase):
+    def test_interrupt_kills_and_reports(self):
+        import threading
+        import tempfile
+
+        # Use a sentinel that the child writes after sleeping; it must NOT exist.
+        d = tempfile.mkdtemp()
+        sentinel = os.path.join(d, "done")
+        wf = _wf(
+            "name: t\nsteps:\n"
+            f"  - id: slow\n    run: 'sleep 5 && touch {sentinel}'\n"
+            "  - id: after\n    depends_on:\n      - slow\n    run: 'echo nope'\n"
+        )
+        eng = Engine(wf, logger=SILENT)
+        threading.Timer(0.4, eng.interrupt).start()
+        t0 = time.monotonic()
+        rep = eng.run()
+        elapsed = time.monotonic() - t0
+
+        self.assertLess(elapsed, 3.0, "interrupt should stop the run promptly")
+        self.assertEqual(rep.status, "interrupted")
+        by = {s.step.id: s for s in rep.steps}
+        self.assertEqual(by["slow"].status, "cancelled")
+        self.assertEqual(by["slow"].cancel_reason, "run interrupted")
+        self.assertEqual(by["after"].status, "cancelled")
+        # Child process group must have been killed (sentinel never created).
+        time.sleep(0.3)
+        self.assertFalse(os.path.exists(sentinel))
+        # Report still serializable.
+        import json as _json
+        _json.dumps(rep.to_dict())
