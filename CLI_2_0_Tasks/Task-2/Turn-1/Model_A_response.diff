+describe('sampling - composition', () => {
+  test('multiple checks short-circuit', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { every: 2, limit: 2, window: 60000 } } }, stream)
+
+    // every:2 keeps calls 0,2,4,6,8 -> limit:2 keeps first 2 of those
+    for (let i = 0; i < 10; i++) logger.info('x')
+    plan.equal(stream.lines.length, 2)
+  })
+})
