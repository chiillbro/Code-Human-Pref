diff --git a/test/sampling.test.js b/test/sampling.test.js
new file mode 100644
index 0000000..cc07e63
--- /dev/null
+++ b/test/sampling.test.js
@@ -0,0 +1,368 @@
+'use strict'
+
+const { describe, test } = require('node:test')
+const tspl = require('@matteo.collina/tspl')
+
+const { sink, once, sleep } = require('./helper')
+const pino = require('../')
+
+function captureStream () {
+  const lines = []
+  return {
+    lines,
+    write (s) { lines.push(JSON.parse(s)) }
+  }
+}
+
+describe('sampling', () => {
+  test('no sampling configured leaves hot path untouched (LOG function)', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const logger = pino(sink())
+    plan.equal(logger.info.name, 'LOG')
+    plan.equal(logger.error.name, 'LOG')
+  })
+
+  test('every: emits 1st, N+1th, ... and only for the configured level', async t => {
+    const plan = tspl(t, { plan: 4 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { every: 3 } } }, stream)
+
+    for (let i = 0; i < 10; i++) logger.info('m%d', i)
+    for (let i = 0; i < 5; i++) logger.warn('w%d', i)
+
+    const infos = stream.lines.filter(l => l.level === 30)
+    const warns = stream.lines.filter(l => l.level === 40)
+    plan.equal(infos.length, 4)
+    plan.deepEqual(infos.map(l => l.msg), ['m0', 'm3', 'm6', 'm9'])
+    plan.equal(warns.length, 5)
+    plan.equal(logger.warn.name, 'LOG')
+  })
+
+  test('rate: 0 drops everything, 1 keeps everything', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { rate: 0 }, warn: { rate: 1 } } }, stream)
+
+    for (let i = 0; i < 50; i++) { logger.info('x'); logger.warn('y') }
+    plan.equal(stream.lines.filter(l => l.level === 30).length, 0)
+    plan.equal(stream.lines.filter(l => l.level === 40).length, 50)
+  })
+
+  test('rate: number shorthand and approximate distribution', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: 0.3 } }, stream)
+
+    for (let i = 0; i < 4000; i++) logger.info('x')
+    const ratio = stream.lines.length / 4000
+    plan.ok(ratio > 0.2 && ratio < 0.4, `ratio ${ratio} should be ~0.3`)
+  })
+
+  test('limit + window: caps emissions per fixed window', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { limit: 3, window: 60000 } } }, stream)
+
+    for (let i = 0; i < 20; i++) logger.info('x')
+    plan.equal(stream.lines.length, 3)
+
+    // simulate window rollover by waiting on a tiny window
+    const stream2 = captureStream()
+    const logger2 = pino({ sampling: { info: { limit: 2, window: 30 } } }, stream2)
+    for (let i = 0; i < 10; i++) logger2.info('x')
+    await sleep(40)
+    for (let i = 0; i < 10; i++) logger2.info('x')
+    plan.equal(stream2.lines.length, 4)
+  })
+
+  test('test: custom predicate receives raw args and level', async t => {
+    const plan = tspl(t, { plan: 3 })
+    const stream = captureStream()
+    let seenLevel
+    const logger = pino({
+      sampling: {
+        info: {
+          test (args, level) {
+            seenLevel = level
+            return args[0] !== 'drop'
+          }
+        }
+      }
+    }, stream)
+
+    logger.info('drop')
+    logger.info('keep')
+    plan.equal(seenLevel, 30)
+    plan.equal(stream.lines.length, 1)
+    plan.equal(stream.lines[0].msg, 'keep')
+  })
+
+  test('function shorthand is treated as test', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: (args) => args[0] === 'ok' } }, stream)
+    logger.info('no')
+    logger.info('ok')
+    plan.deepEqual(stream.lines.map(l => l.msg), ['ok'])
+  })
+
+  test('wildcard rule applies to unconfigured levels', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { '*': { every: 2 }, error: false } }, stream)
+
+    for (let i = 0; i < 4; i++) logger.info('i')
+    for (let i = 0; i < 4; i++) logger.error('e')
+    plan.equal(stream.lines.filter(l => l.level === 30).length, 2)
+    plan.equal(stream.lines.filter(l => l.level === 50).length, 4)
+  })
+
+  test('dropped logs do not pay serialization cost', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    let serialized = 0
+    const logger = pino({
+      sampling: { info: { rate: 0 } },
+      serializers: { foo () { serialized++; return 'x' } }
+    }, stream)
+
+    for (let i = 0; i < 10; i++) logger.info({ foo: {} }, 'x')
+    plan.equal(stream.lines.length, 0)
+    plan.equal(serialized, 0)
+  })
+
+  test('dropped logs do not invoke logMethod hook', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    let hooked = 0
+    const logger = pino({
+      sampling: { info: { every: 5 } },
+      hooks: { logMethod (args, method) { hooked++; method.apply(this, args) } }
+    }, stream)
+
+    for (let i = 0; i < 10; i++) logger.info('x')
+    plan.equal(stream.lines.length, 2)
+    plan.equal(hooked, 2)
+  })
+
+  test('works with custom levels', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({
+      customLevels: { verbose: 11 },
+      level: 'verbose',
+      sampling: { verbose: { every: 4 } }
+    }, stream)
+
+    for (let i = 0; i < 8; i++) logger.verbose('v')
+    plan.equal(stream.lines.filter(l => l.level === 11).length, 2)
+  })
