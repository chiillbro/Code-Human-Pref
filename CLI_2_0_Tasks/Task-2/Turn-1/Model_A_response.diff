+describe('sampling - dedupe', () => {
+  test('emits first occurrence, suppresses duplicates, then emits summary', async t => {
+    const plan = tspl(t, { plan: 6 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { error: { dedupe: { window: 30 } } } }, stream)
+
+    logger.error('boom')
+    logger.error('boom')
+    logger.error('boom')
+    logger.error('other')
+
+    plan.equal(stream.lines.length, 2)
+    plan.deepEqual(stream.lines.map(l => l.msg), ['boom', 'other'])
+
+    await sleep(60)
+
+    const summaries = stream.lines.filter(l => l.sampling)
+    plan.equal(summaries.length, 1)
+    plan.equal(summaries[0].level, 50)
+    plan.equal(summaries[0].sampling.suppressed, 2)
+    plan.equal(summaries[0].sampling.key, 'boom')
+  })
+
+  test('dedupe keys Error arguments by message', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { error: { dedupe: { window: 30 } } } }, stream)
+
+    logger.error(new Error('db down'))
+    logger.error(new Error('db down'))
+    logger.error(new Error('db down'))
+
+    plan.equal(stream.lines.length, 1)
+    await sleep(60)
+    const summary = stream.lines.find(l => l.sampling)
+    plan.equal(summary.sampling.suppressed, 2)
+  })
+
+  test('dedupe with merging object keys on the message argument', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { dedupe: { window: 30 } } } }, stream)
+
+    logger.info({ a: 1 }, 'same')
+    logger.info({ a: 2 }, 'same')
+    logger.info({ a: 3 }, 'diff')
+
+    plan.deepEqual(stream.lines.map(l => l.msg), ['same', 'diff'])
+    await sleep(60)
+  })
+
+  test('dedupe custom key function', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({
+      sampling: {
+        info: { dedupe: { window: 30, key: (args) => args[0] && args[0].code } }
+      }
+    }, stream)
+
+    logger.info({ code: 'E1' }, 'a')
+    logger.info({ code: 'E1' }, 'b')
+    logger.info({ code: 'E2' }, 'c')
+
+    plan.deepEqual(stream.lines.map(l => l.msg), ['a', 'c'])
+    await sleep(60)
+  })
+
+  test('no summary when nothing was suppressed', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { dedupe: { window: 20 } } } }, stream)
+
+    logger.info('once')
+    await sleep(40)
+    plan.equal(stream.lines.filter(l => l.sampling).length, 0)
+  })
+
+  test('dedupe window resets after expiry', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const logger = pino({ sampling: { info: { dedupe: { window: 20 } } } }, stream)
+
+    logger.info('x')
+    logger.info('x')
+    await sleep(40)
+    logger.info('x')
+    await sleep(40)
+    plan.deepEqual(
+      stream.lines.filter(l => !l.sampling).map(l => l.msg),
+      ['x', 'x']
+    )
+  })
+})
+
+describe('sampling - child loggers', () => {
+  test('children inherit and share parent sampler state by default', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const parent = pino({ sampling: { info: { every: 3 } } }, stream)
+    const child = parent.child({ component: 'c' })
+
+    parent.info('p0') // emitted
+    child.info('c1')  // dropped
+    parent.info('p2') // dropped
+    child.info('c3')  // emitted
+    plan.deepEqual(stream.lines.map(l => l.msg), ['p0', 'c3'])
+  })
+
+  test('child can override a single level rule', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const parent = pino({ sampling: { info: { rate: 0 }, warn: { every: 2 } } }, stream)
+    const child = parent.child({}, { sampling: { info: { every: 1 } } })
+
+    for (let i = 0; i < 4; i++) child.info('i')
+    for (let i = 0; i < 4; i++) child.warn('w')
+    plan.equal(stream.lines.filter(l => l.level === 30).length, 4)
+    // warn rule inherited from parent (independent state on the override path)
+    plan.equal(stream.lines.filter(l => l.level === 40).length, 2)
+  })
+
+  test('child can disable a single inherited level with false', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const parent = pino({ sampling: { info: { rate: 0 } } }, stream)
+    const child = parent.child({}, { sampling: { info: false } })
+
+    for (let i = 0; i < 3; i++) child.info('i')
+    plan.equal(stream.lines.length, 3)
+  })
+
+  test('child can disable all sampling with null', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const parent = pino({ sampling: { '*': { rate: 0 } } }, stream)
+    const child = parent.child({}, { sampling: null })
+
+    child.info('i'); child.warn('w')
+    plan.equal(stream.lines.length, 2)
+    plan.equal(child.info.name, 'LOG')
+  })
+
+  test('child level change preserves inherited sampling', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const parent = pino({ sampling: { info: { every: 2 } } }, stream)
+    const child = parent.child({}, { level: 'debug' })
+
+    for (let i = 0; i < 4; i++) child.info('i')
+    plan.equal(stream.lines.length, 2)
+  })
+})
