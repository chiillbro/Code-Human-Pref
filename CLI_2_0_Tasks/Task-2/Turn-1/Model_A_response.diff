+describe('sampling - validation', () => {
+  test('rejects non-object sampling', t => {
+    const plan = tspl(t, { plan: 1 })
+    plan.throws(() => pino({ sampling: 'nope' }, sink()), /sampling option must be an object/)
+  })
+
+  test('rejects out-of-range rate', t => {
+    const plan = tspl(t, { plan: 1 })
+    plan.throws(() => pino({ sampling: { info: { rate: 2 } } }, sink()), /rate must be a number between 0 and 1/)
+  })
+
+  test('rejects non-integer every', t => {
+    const plan = tspl(t, { plan: 1 })
+    plan.throws(() => pino({ sampling: { info: { every: 1.5 } } }, sink()), /every must be a positive integer/)
+  })
+
+  test('rejects limit without window', t => {
+    const plan = tspl(t, { plan: 1 })
+    plan.throws(() => pino({ sampling: { info: { limit: 5 } } }, sink()), /requires sampling.info.window/)
+  })
+
+  test('rejects dedupe without window', t => {
+    const plan = tspl(t, { plan: 1 })
+    plan.throws(() => pino({ sampling: { info: { dedupe: {} } } }, sink()), /dedupe.window must be a positive number/)
+  })
+
+  test('rejects invalid rule type', t => {
+    const plan = tspl(t, { plan: 1 })
+    plan.throws(() => pino({ sampling: { info: 'bad' } }, sink()), /sampling rule must be an object/)
+  })
+})
