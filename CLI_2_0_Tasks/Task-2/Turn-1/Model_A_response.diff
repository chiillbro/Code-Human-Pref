index 0000000..836d279
--- /dev/null
+++ b/lib/sampling.js
@@ -0,0 +1,183 @@
+'use strict'
+
+/* eslint no-prototype-builtins: 0 */
+
+const { writeSym } = require('./symbols')
+
+function normalizeRule (rule) {
+  if (rule === false || rule === null) return false
+  if (typeof rule === 'number') return { rate: rule }
+  if (typeof rule === 'function') return { test: rule }
+  if (typeof rule !== 'object') {
+    throw Error('sampling rule must be an object, number, function, false or null')
+  }
+  return rule
+}
+
+function assertRule (label, rule) {
+  if (rule === false) return
+  if (rule.rate !== undefined && (typeof rule.rate !== 'number' || rule.rate < 0 || rule.rate > 1)) {
+    throw Error(`sampling.${label}.rate must be a number between 0 and 1`)
+  }
+  if (rule.every !== undefined && (!Number.isInteger(rule.every) || rule.every < 1)) {
+    throw Error(`sampling.${label}.every must be a positive integer`)
+  }
+  if (rule.limit !== undefined) {
+    if (!Number.isInteger(rule.limit) || rule.limit < 0) {
+      throw Error(`sampling.${label}.limit must be a non-negative integer`)
+    }
+    if (rule.window === undefined) {
+      throw Error(`sampling.${label}.limit requires sampling.${label}.window`)
+    }
+  }
+  if (rule.window !== undefined && (!Number.isFinite(rule.window) || rule.window <= 0)) {
+    throw Error(`sampling.${label}.window must be a positive number (ms)`)
+  }
+  if (rule.dedupe !== undefined) {
+    const d = rule.dedupe
+    if (d === null || typeof d !== 'object') {
+      throw Error(`sampling.${label}.dedupe must be an object`)
+    }
+    if (!Number.isFinite(d.window) || d.window <= 0) {
+      throw Error(`sampling.${label}.dedupe.window must be a positive number (ms)`)
+    }
+    if (d.key !== undefined && typeof d.key !== 'function') {
+      throw Error(`sampling.${label}.dedupe.key must be a function`)
+    }
+  }
+  if (rule.test !== undefined && typeof rule.test !== 'function') {
+    throw Error(`sampling.${label}.test must be a function`)
+  }
+}
+
+function assertSampling (sampling) {
+  if (sampling === null || typeof sampling !== 'object') {
+    throw Error('sampling option must be an object')
+  }
+  for (const label in sampling) {
+    assertRule(label, normalizeRule(sampling[label]))
+  }
+}
+
+// Extract a cheap identity key from the raw log-method arguments
+// without running format() or any serializers.
+function defaultDedupeKey (args) {
+  const o = args[0]
+  if (o === null || o === undefined) return args[1]
+  if (typeof o === 'object') {
+    return o instanceof Error ? o.message : args[1]
+  }
+  return o
+}
+
+function genSampler (rule, num) {
+  rule = normalizeRule(rule)
+  if (rule === false) return null
+
+  const checks = []
+
+  if (rule.every !== undefined && rule.every > 1) {
+    const every = rule.every
+    let n = 0
+    checks.push(function everyCheck () {
+      if (n === 0) { n = every - 1; return true }
+      n--
+      return false
+    })
+  }
+
+  if (rule.rate !== undefined && rule.rate < 1) {
+    const rate = rule.rate
+    checks.push(rate <= 0
+      ? function rateCheck () { return false }
+      : function rateCheck () { return Math.random() < rate }
+    )
+  }
+
+  if (rule.limit !== undefined) {
+    const limit = rule.limit
+    const window = rule.window
+    let start = 0
+    let count = 0
+    checks.push(function limitCheck () {
+      const now = Date.now()
+      if (now - start >= window) { start = now; count = 0 }
+      if (count < limit) { count++; return true }
+      return false
+    })
+  }
+
+  if (typeof rule.test === 'function') {
+    const test = rule.test
+    checks.push(function testCheck (args) {
+      return test.call(this, args, num) !== false
+    })
+  }
+
+  if (rule.dedupe !== undefined) {
+    const window = rule.dedupe.window
+    const keyFn = rule.dedupe.key || defaultDedupeKey
+    const seen = new Map()
+    checks.push(function dedupeCheck (args) {
+      const key = keyFn(args)
+      if (key === undefined || key === null) return true
+      const entry = seen.get(key)
+      if (entry !== undefined) { entry.count++; return false }
+      const state = { count: 0 }
+      seen.set(key, state)
+      const logger = this
+      const timer = setTimeout(function dedupeFlush () {
+        seen.delete(key)
+        if (state.count > 0) {
+          // bypass sampling by writing directly so the summary is never dropped
+          logger[writeSym]({ sampling: { suppressed: state.count, key } }, `suppressed ${state.count} duplicate log(s)`, num)
+        }
+      }, window)
+      if (typeof timer.unref === 'function') timer.unref()
+      return true
+    })
+  }
+
+  if (checks.length === 0) return null
+  if (checks.length === 1) return checks[0]
+
+  return function composedSampler (args) {
+    for (let i = 0; i < checks.length; i++) {
+      if (checks[i].call(this, args) === false) return false
+    }
+    return true
+  }
+}
+
+function buildSampling (rules, levels) {
+  if (!rules) return null
+  assertSampling(rules)
+  const samplers = {}
+  const wildcard = rules['*']
+  let count = 0
+  for (const label in levels.values) {
+    if (label === 'silent') continue
+    const rule = rules.hasOwnProperty(label) ? rules[label] : wildcard
+    if (rule === undefined) continue
+    const num = levels.values[label]
+    const sampler = genSampler(rule, num)
+    if (sampler !== null) {
+      samplers[num] = sampler
+      count++
+    }
+  }
+  if (count === 0 && wildcard === undefined) return null
+  return { rules, samplers }
+}
+
+function mergeSampling (parentRules, childRules) {
+  if (!parentRules) return childRules
+  return Object.assign({}, parentRules, childRules)
+}
+
+module.exports = {
+  assertSampling,
+  buildSampling,
+  mergeSampling,
+  genSampler
+}
