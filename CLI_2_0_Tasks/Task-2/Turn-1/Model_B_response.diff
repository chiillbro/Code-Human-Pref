diff --git a/test/sampling.test.js b/test/sampling.test.js
new file mode 100644
index 0000000..ea880a5
--- /dev/null
+++ b/test/sampling.test.js
@@ -0,0 +1,142 @@
+'use strict'
+
+const test = require('node:test')
+const assert = require('node:assert')
+
+const { sink, sleep } = require('./helper')
+const pino = require('../')
+
+test('probabilistic sampling with rate=0 drops everything', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    sampling: { rules: { info: { type: 'probabilistic', rate: 0 } } }
+  }, stream)
+  for (let i = 0; i < 50; i++) logger.info('hi %d', i)
+  assert.equal(received.length, 0)
+})
+
+test('probabilistic sampling with rate=1 emits everything', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    sampling: { rules: { info: { type: 'probabilistic', rate: 1 } } }
+  }, stream)
+  for (let i = 0; i < 25; i++) logger.info('hi')
+  assert.equal(received.length, 25)
+})
+
+test('everyN emits 1 in N logs', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    sampling: { rules: { info: { type: 'everyN', n: 5 } } }
+  }, stream)
+  for (let i = 0; i < 20; i++) logger.info('hi')
+  assert.equal(received.length, 4)
+})
+
+test('rateLimit caps emissions within a window', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    sampling: {
+      rules: { info: { type: 'rateLimit', maxPerInterval: 3, intervalMs: 10_000 } }
+    }
+  }, stream)
+  for (let i = 0; i < 100; i++) logger.info('hi')
+  assert.equal(received.length, 3)
+})
+
+test('dedupe suppresses repeated identical messages and emits a summary', async () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    sampling: { dedupe: { windowMs: 50, levels: ['error'] } }
+  }, stream)
+  for (let i = 0; i < 10; i++) logger.error('same error')
+  // only the first should go through while window is open
+  assert.equal(received.length, 1)
+  assert.equal(received[0].msg, 'same error')
+
+  // wait for window to expire and log again to trigger the summary
+  await sleep(80)
+  logger.error('same error')
+  // summary from prior window + the fresh log
+  assert.equal(received.length, 3)
+  assert.ok(received[1].msg.includes('repeated 9 times'))
+  assert.equal(received[2].msg, 'same error')
+})
+
+test('dedupe does not affect distinct messages', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    sampling: { dedupe: { windowMs: 1000 } }
+  }, stream)
+  logger.info('a')
+  logger.info('b')
+  logger.info('c')
+  assert.equal(received.length, 3)
+})
+
+test('levels without a rule keep the fast path and are unaffected', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const logger = pino({
+    level: 'trace',
+    sampling: { rules: { debug: { type: 'everyN', n: 100 } } }
+  }, stream)
+  for (let i = 0; i < 5; i++) logger.info('hi')
+  for (let i = 0; i < 5; i++) logger.debug('dbg')
+  assert.equal(received.filter(r => r.msg === 'hi').length, 5)
+  assert.equal(received.filter(r => r.msg === 'dbg').length, 0)
+})
+
+test('child inherits parent sampling rules', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const parent = pino({
+    sampling: { rules: { info: { type: 'everyN', n: 3 } } }
+  }, stream)
+  const child = parent.child({ component: 'x' })
+  // parent + child share the same counter (inherited via prototype)
+  for (let i = 0; i < 6; i++) child.info('hi')
+  assert.equal(received.length, 2)
+})
+
+test('child can override parent sampling rules', () => {
+  const stream = sink()
+  const received = []
+  stream.on('data', (d) => received.push(d))
+  const parent = pino({
+    sampling: { rules: { info: { type: 'probabilistic', rate: 0 } } }
+  }, stream)
+  const child = parent.child({}, {
+    sampling: { rules: { info: { type: 'probabilistic', rate: 1 } } }
+  })
+  child.info('child-msg')
+  parent.info('parent-msg')
+  assert.equal(received.length, 1)
+  assert.equal(received[0].msg, 'child-msg')
+})
+
+test('invalid sampling type throws', () => {
+  assert.throws(() => pino({
+    sampling: { rules: { info: { type: 'bogus' } } }
+  }), /invalid sampling rule type/)
+})
+
+test('probabilistic rate out of range throws', () => {
+  assert.throws(() => pino({
+    sampling: { rules: { info: { type: 'probabilistic', rate: 2 } } }
+  }), /probabilistic sampling rate/)
+})
