new file mode 100644
index 0000000..ae2f6ce
--- /dev/null
+++ b/lib/sampling.js
@@ -0,0 +1,173 @@
+'use strict'
+
+/**
+ * Sampling and deduplication utilities for pino.
+ *
+ * These are invoked BEFORE serialization (and before any format() call)
+ * by a per-level wrapper installed in `setLevel()`. When sampling is not
+ * configured, no wrappers are installed so the hot path is unaffected.
+ */
+
+const SAMPLING_TYPES = ['probabilistic', 'rateLimit', 'everyN']
+
+/**
+ * Builds a `shouldLog()` predicate for a single per-level rule.
+ * Returns null if the rule does not define a sampler (dedupe-only).
+ */
+function createSampler (rule) {
+  if (rule == null) return null
+  const type = rule.type
+  if (type === undefined) return null
+  if (!SAMPLING_TYPES.includes(type)) {
+    throw Error(`invalid sampling rule type "${type}" - expected one of ${SAMPLING_TYPES.join(', ')}`)
+  }
+
+  if (type === 'probabilistic') {
+    const rate = typeof rule.rate === 'number' ? rule.rate : 1
+    if (rate < 0 || rate > 1) {
+      throw Error('probabilistic sampling rate must be between 0 and 1')
+    }
+    if (rate >= 1) return () => true
+    if (rate <= 0) return () => false
+    return () => Math.random() < rate
+  }
+
+  if (type === 'everyN') {
+    const n = rule.n | 0
+    if (n <= 0) throw Error('everyN sampling requires positive integer n')
+    if (n === 1) return () => true
+    let counter = 0
+    return () => {
+      counter++
+      if (counter >= n) {
+        counter = 0
+        return true
+      }
+      return false
+    }
+  }
+
+  // rateLimit: allow at most `maxPerInterval` logs per `intervalMs`.
+  const maxPerInterval = rule.maxPerInterval | 0
+  const intervalMs = rule.intervalMs | 0
+  if (maxPerInterval <= 0) throw Error('rateLimit sampling requires positive maxPerInterval')
+  if (intervalMs <= 0) throw Error('rateLimit sampling requires positive intervalMs')
+
+  let windowStart = 0
+  let count = 0
+  return () => {
+    const now = Date.now()
+    if (now - windowStart >= intervalMs) {
+      windowStart = now
+      count = 0
+    }
+    if (count < maxPerInterval) {
+      count++
+      return true
+    }
+    return false
+  }
+}
+
+/**
+ * Extracts a dedupe key from the arguments passed to a log method.
+ * Falls back to '' when no stable key can be derived (treated as
+ * "never match" by the deduper).
+ */
+function dedupeKey (args) {
+  const a0 = args[0]
+  if (typeof a0 === 'string') return a0
+  if (a0 && typeof a0 === 'object') {
+    if (a0 instanceof Error) return 'err:' + (a0.message || a0.name || '')
+    if (typeof args[1] === 'string') return args[1]
+    if (typeof a0.msg === 'string') return a0.msg
+    if (a0.err && typeof a0.err.message === 'string') return 'err:' + a0.err.message
+  }
+  return ''
+}
+
+/**
+ * Builds a deduper that suppresses messages with an identical key within
+ * `windowMs`. Returns `{ allow, summary }` per call where `summary`, when
+ * non-null, is the text that should replace the current log describing the
+ * number of suppressed occurrences since the window opened.
+ */
+function createDeduper (opts) {
+  const windowMs = opts.windowMs | 0
+  if (windowMs <= 0) throw Error('dedupe requires positive windowMs')
+  const summaryTemplate = typeof opts.summary === 'string'
+    ? opts.summary
+    : 'message repeated {count} times in {window}ms: {msg}'
+
+  const seen = new Map() // key -> { expires, count }
+
+  function format (key, count) {
+    return summaryTemplate
+      .replace('{count}', String(count))
+      .replace('{window}', String(windowMs))
+      .replace('{msg}', key)
+  }
+
+  return function dedupe (key) {
+    if (key === '') return { allow: true, summary: null }
+    const now = Date.now()
+    const entry = seen.get(key)
+    if (entry === undefined || entry.expires <= now) {
+      // emit a summary for the prior expired window if we suppressed anything
+      let summary = null
+      if (entry !== undefined && entry.count > 1) {
+        summary = format(key, entry.count - 1)
+      }
+      seen.set(key, { expires: now + windowMs, count: 1 })
+      return { allow: true, summary }
+    }
+    entry.count++
+    return { allow: false, summary: null }
+  }
+}
+
+/**
+ * Given the user-supplied `sampling` option and the logger level map,
+ * returns an object shaped as `{ [levelLabel]: { sampler, deduper } }`
+ * plus a `hasAny` flag so `setLevel()` can skip the wrapping loop when no
+ * rule applies.
+ */
+function buildSamplingState (samplingOpts, levels) {
+  if (samplingOpts == null) return null
+
+  const rules = samplingOpts.rules || {}
+  const dedupe = samplingOpts.dedupe || null
+
+  // dedupe.levels defaults to "every non-silent level"
+  let dedupeLevels = null
+  if (dedupe) {
+    if (Array.isArray(dedupe.levels)) {
+      dedupeLevels = new Set(dedupe.levels)
+    }
+  }
+
+  const state = {}
+  let hasAny = false
+
+  for (const label in levels.values) {
+    const hasRule = Object.prototype.hasOwnProperty.call(rules, label)
+    const applyDedupe = dedupe !== null && (dedupeLevels === null || dedupeLevels.has(label))
+    if (!hasRule && !applyDedupe) continue
+
+    const sampler = hasRule ? createSampler(rules[label]) : null
+    const deduper = applyDedupe ? createDeduper(dedupe) : null
+    if (sampler === null && deduper === null) continue
+
+    state[label] = { sampler, deduper }
+    hasAny = true
+  }
+
+  return hasAny ? state : null
+}
+
+module.exports = {
+  buildSamplingState,
+  createSampler,
+  createDeduper,
+  dedupeKey
+}
