+
+describe('SamplingEngine deduplication', () => {
+  test('suppresses duplicate messages within TTL', () => {
+    const engine = new SamplingEngine({
+      dedupe: { enabled: true, ttlMs: 5000, maxKeys: 100 }
+    }, {})
+
+    const first = engine.shouldEmit(30, 'duplicate msg')
+    assert.equal(first.emit, true)
+
+    // Same message again should be suppressed
+    const second = engine.shouldEmit(30, 'duplicate msg')
+    assert.equal(second.emit, false)
+
+    // Different message should pass
+    const diff = engine.shouldEmit(30, 'different msg')
+    assert.equal(diff.emit, true)
+  })
+
+  test('dedupe allows after TTL expiry', async () => {
+    const engine = new SamplingEngine({
+      dedupe: { enabled: true, ttlMs: 100, maxKeys: 100 }
+    }, {})
+
+    engine.shouldEmit(30, 'ttl-test')
+    assert.equal(engine.shouldEmit(30, 'ttl-test').emit, false)
+
+    await sleep(150)
+
+    // After TTL, same message is allowed again
+    const result = engine.shouldEmit(30, 'ttl-test')
+    assert.equal(result.emit, true)
+    engine.destroy()
+  })
+
+  test('LRU eviction generates summary', () => {
+    const engine = new SamplingEngine({
+      dedupe: { enabled: true, ttlMs: 60000, maxKeys: 2 }
+    }, {})
+
+    engine.shouldEmit(30, 'msg-a')  // cache: [a]
+    engine.shouldEmit(30, 'msg-a')  // suppress, a.count = 1
+    engine.shouldEmit(30, 'msg-b')  // cache: [a, b]
+    engine.shouldEmit(30, 'msg-c')  // evicts 'a' → summary
+
+    const summaries = engine.drainSummaries()
+    assert.equal(summaries.length, 1)
+    assert.ok(summaries[0].msg.includes('suppressed'))
+    assert.ok(summaries[0].msg.includes('1'))
+    engine.destroy()
+  })
+
+  test('dedupe with zero suppressed count does not generate summary on eviction', () => {
+    const engine = new SamplingEngine({
+      dedupe: { enabled: true, ttlMs: 60000, maxKeys: 2 }
+    }, {})
+
+    engine.shouldEmit(30, 'msg-a')  // cache: [a], count=0
+    engine.shouldEmit(30, 'msg-b')  // cache: [a, b]
+    engine.shouldEmit(30, 'msg-c')  // evicts 'a' but count=0 → no summary
+
+    const summaries = engine.drainSummaries()
+    assert.equal(summaries.length, 0)
+    engine.destroy()
+  })
+
+  test('sweep expired entries generates summaries', async () => {
+    const engine = new SamplingEngine({
+      dedupe: { enabled: true, ttlMs: 100, maxKeys: 100 }
+    }, {})
+
+    engine.shouldEmit(30, 'sweep-test')  // first occurrence
+    engine.shouldEmit(30, 'sweep-test')  // suppressed, count=1
+    engine.shouldEmit(30, 'sweep-test')  // suppressed, count=2
+
+    // Wait for sweep interval to fire (TTL=100ms, sweep=min(100,1000)=100ms)
+    await sleep(250)
+
+    const summaries = engine.drainSummaries()
+    assert.equal(summaries.length, 1)
+    assert.ok(summaries[0].msg.includes('suppressed'))
+    assert.ok(summaries[0].msg.includes('2'))
+    engine.destroy()
+  })
+})
