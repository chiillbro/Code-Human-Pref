+describe('SamplingEngine', () => {
+  test('no rules passes everything through', () => {
+    const engine = new SamplingEngine({ rules: [] }, { info: 30 })
+    const result = engine.shouldEmit(30, 'hello')
+    assert.equal(result.emit, true)
+    assert.equal(result.meta, null) // no rule for this level => no meta
+  })
+
+  test('probability with custom randomFn', () => {
+    let callCount = 0
+    const engine = new SamplingEngine({
+      rules: [{ level: 'info', method: 'probability', value: 0.5 }],
+      randomFn: () => {
+        callCount++
+        return callCount <= 3 ? 0.1 : 0.9 // first 3 pass, rest fail
+      }
+    }, { info: 30 })
+
+    const results = []
+    for (let i = 0; i < 6; i++) {
+      results.push(engine.shouldEmit(30, 'msg').emit)
+    }
+    assert.deepEqual(results, [true, true, true, false, false, false])
+  })
+
+  test('probability metadata contains method and value', () => {
+    const engine = new SamplingEngine({
+      rules: [{ level: 'info', method: 'probability', value: 1.0 }],
+      randomFn: () => 0.5 // always passes
+    }, { info: 30 })
+
+    const result = engine.shouldEmit(30, 'msg')
+    assert.equal(result.emit, true)
+    assert.equal(result.meta.method, 'probability')
+    assert.equal(result.meta.value, 1.0)
+    assert.equal(result.meta.dropped, 0)
+  })
+
+  test('probability tracks dropped count', () => {
+    let calls = 0
+    const engine = new SamplingEngine({
+      rules: [{ level: 'info', method: 'probability', value: 0.5 }],
+      randomFn: () => {
+        calls++
+        // Drop first 3, then emit
+        return calls <= 3 ? 0.9 : 0.1
+      }
+    }, { info: 30 })
+
+    for (let i = 0; i < 3; i++) {
+      assert.equal(engine.shouldEmit(30, 'test').emit, false)
+    }
+    const result = engine.shouldEmit(30, 'test')
+    assert.equal(result.emit, true)
+    assert.equal(result.meta.dropped, 3)
+  })
+
+  test('every method emits every Nth log', () => {
+    const engine = new SamplingEngine({
+      rules: [{ level: 'debug', method: 'every', value: 3 }]
+    }, { debug: 20 })
+
+    const emitted = []
+    for (let i = 0; i < 10; i++) {
+      emitted.push(engine.shouldEmit(20, 'msg ' + i).emit)
+    }
+    // Counter starts at 0, increments to 1,2,3,...
+    // Emits when count % 3 === 0 → at counts 3, 6, 9
+    assert.deepEqual(emitted, [
+      false, false, true,  // count 1,2,3
+      false, false, true,  // count 4,5,6
+      false, false, true,  // count 7,8,9
+      false                // count 10
+    ])
+  })
+
+  test('every=1 emits every log', () => {
+    const engine = new SamplingEngine({
+      rules: [{ level: 'info', method: 'every', value: 1 }]
+    }, { info: 30 })
+
+    for (let i = 0; i < 5; i++) {
+      assert.equal(engine.shouldEmit(30, 'msg').emit, true)
+    }
+  })
+
+  test('every metadata contains method, value and dropped count', () => {
+    const engine = new SamplingEngine({
+      rules: [{ level: 'info', method: 'every', value: 3 }]
+    }, { info: 30 })
+
+    // First 2 are dropped, 3rd is emitted
+    engine.shouldEmit(30, 'a')
+    engine.shouldEmit(30, 'b')
+    const result = engine.shouldEmit(30, 'c')
+    assert.equal(result.emit, true)
+    assert.equal(result.meta.method, 'every')
+    assert.equal(result.meta.value, 3)
+    assert.equal(result.meta.dropped, 2)
+  })
+
+  test('rate method uses token bucket', () => {
+    const engine = new SamplingEngine({
+      rules: [{ level: 'warn', method: 'rate', rate: 3 }]
+    }, { warn: 40 })
+
+    // Should burst up to 3
+    assert.equal(engine.shouldEmit(40, 'a').emit, true)
+    assert.equal(engine.shouldEmit(40, 'b').emit, true)
+    assert.equal(engine.shouldEmit(40, 'c').emit, true)
+    // 4th should be dropped
+    assert.equal(engine.shouldEmit(40, 'd').emit, false)
+  })
+
+  test('rate metadata contains method, rate and dropped count', () => {
+    const engine = new SamplingEngine({
+      rules: [{ level: 'info', method: 'rate', rate: 2 }]
+    }, { info: 30 })
+
+    const result = engine.shouldEmit(30, 'msg')
+    assert.equal(result.emit, true)
+    assert.equal(result.meta.method, 'rate')
+    assert.equal(result.meta.rate, 2)
+    assert.equal(result.meta.dropped, 0)
+  })
+
+  test('levels without rules pass through', () => {
+    const engine = new SamplingEngine({
