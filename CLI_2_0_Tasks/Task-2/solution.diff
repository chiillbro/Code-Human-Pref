+// ---------------------------------------------------------------------------
+// Integration: child loggers
+// ---------------------------------------------------------------------------
+
+describe('sampling child loggers', () => {
+  test('child inherits parent sampling', async () => {
+    const stream = sink()
+    const parent = pino({
+      sampling: {
+        rules: [{ level: 'info', method: 'probability', value: 0 }]
+      }
+    }, stream)
+
+    const child = parent.child({ child: true })
+
+    let count = 0
+    stream.on('data', () => { count++ })
+
+    for (let i = 0; i < 20; i++) {
+      child.info('should be dropped')
+    }
+
+    await sleep(50)
+    assert.equal(count, 0)
+  })
+
+  test('child can override sampling with new config', async () => {
+    const stream = sink()
+    const parent = pino({
+      level: 'trace',
+      sampling: {
+        rules: [{ level: 'debug', method: 'probability', value: 0 }]
+      }
+    }, stream)
+
+    // Child overrides to emit all debug logs (sampling goes in options, 2nd arg)
+    const child = parent.child({}, {
+      sampling: {
+        rules: [{ level: 'debug', method: 'probability', value: 1.0 }]
+      }
+    })
+
+    child.debug({ test: true }, 'from child')
+    const data = await once(stream, 'data')
+    assert.equal(data.msg, 'from child')
+    assert.equal(data.test, true)
+  })
+
+  test('child can disable sampling with null', async () => {
+    const stream = sink()
+    const parent = pino({
+      sampling: {
+        rules: [{ level: 'info', method: 'probability', value: 0 }]
+      }
+    }, stream)
+
+    // Disable sampling on child (sampling goes in options, 2nd arg)
+    const child = parent.child({}, { sampling: null })
+
+    child.info('should pass')
+    const data = await once(stream, 'data')
+    assert.equal(data.msg, 'should pass')
+  })
+
+  test('child can disable sampling with false', async () => {
+    const stream = sink()
+    const parent = pino({
+      sampling: {
+        rules: [{ level: 'info', method: 'probability', value: 0 }]
+      }
+    }, stream)
+
+    const child = parent.child({}, { sampling: false })
+
+    child.info('should pass')
+    const data = await once(stream, 'data')
+    assert.equal(data.msg, 'should pass')
+  })
+})
+
+// ---------------------------------------------------------------------------
+// Integration: pino constructor validation
+// ---------------------------------------------------------------------------
+
+describe('sampling pino constructor validation', () => {
+  test('invalid sampling config throws at construction', () => {
+    assert.throws(
+      () => pino({
+        sampling: { rules: [{ level: 'info', method: 'bad' }] }
+      }),
+      /method must be "probability", "rate", or "every"/
+    )
+  })
+
+  test('invalid probability throws at construction', () => {
+    assert.throws(
+      () => pino({
+        sampling: { rules: [{ level: 'info', method: 'probability', value: -1 }] }
+      }),
+      /value for probability must be a number between 0 and 1/
+    )
+  })
+
+  test('invalid level name throws at construction', () => {
+    assert.throws(
+      () => pino({
+        sampling: { rules: [{ level: 'nonexistent', method: 'every', value: 1 }] }
+      }),
+      /not a known level/
+    )
+  })
+})
