index 00000000..b08da42c
--- /dev/null
+++ b/lib/sampling.js
@@ -0,0 +1,490 @@
+'use strict'
+
+/**
+ * Sampling and rate-limiting engine for pino.
+ *
+ * Provides three sampling methods:
+ *   - probability: emit each log with a given probability (0.0–1.0)
+ *   - rate: token-bucket rate limiting (max N logs/sec with smooth refill)
+ *   - every: deterministic downsampling (emit every Nth log)
+ *
+ * Also provides per-key deduplication with a bounded LRU cache.
+ */
+
+const { samplingSym } = require('./symbols')
+
+// ---------------------------------------------------------------------------
+// Validation
+// ---------------------------------------------------------------------------
+
+function validateSamplingConfig (sampling, levels) {
+  if (sampling == null) return null
+  if (typeof sampling !== 'object' || Array.isArray(sampling)) {
+    throw Error('pino – sampling must be a plain object')
+  }
+
+  const rules = sampling.rules
+  if (rules !== undefined && rules !== null) {
+    if (!Array.isArray(rules)) {
+      throw Error('pino – sampling.rules must be an array')
+    }
+    const seenLevels = new Set()
+    for (let i = 0; i < rules.length; i++) {
+      const rule = rules[i]
+      if (!rule || typeof rule !== 'object') {
+        throw Error('pino – sampling.rules[' + i + '] must be an object')
+      }
+      if (typeof rule.level !== 'string') {
+        throw Error('pino – sampling.rules[' + i + '].level must be a string')
+      }
+      if (levels.values[rule.level] === undefined) {
+        throw Error('pino – sampling.rules[' + i + '].level "' + rule.level + '" is not a known level')
+      }
+      if (seenLevels.has(rule.level)) {
+        throw Error('pino – sampling.rules contains duplicate level "' + rule.level + '"')
+      }
+      seenLevels.add(rule.level)
+
+      switch (rule.method) {
+        case 'probability':
+          if (typeof rule.value !== 'number' || rule.value < 0 || rule.value > 1) {
+            throw Error('pino – sampling.rules[' + i + '].value for probability must be a number between 0 and 1')
+          }
+          break
+        case 'rate':
+          if (typeof rule.rate !== 'number' || rule.rate <= 0) {
+            throw Error('pino – sampling.rules[' + i + '].rate must be a positive number')
+          }
+          break
+        case 'every':
+          if (typeof rule.value !== 'number' || rule.value < 1 || rule.value !== Math.floor(rule.value)) {
+            throw Error('pino – sampling.rules[' + i + '].value for every must be a positive integer >= 1')
+          }
+          break
+        default:
+          throw Error('pino – sampling.rules[' + i + '].method must be "probability", "rate", or "every"')
+      }
+    }
+  }
+
+  const dedupe = sampling.dedupe
+  if (dedupe !== undefined && dedupe !== null) {
+    if (typeof dedupe !== 'object' || Array.isArray(dedupe)) {
+      throw Error('pino – sampling.dedupe must be a plain object')
+    }
+    if (dedupe.enabled) {
+      if (dedupe.ttlMs !== undefined && (typeof dedupe.ttlMs !== 'number' || dedupe.ttlMs <= 0)) {
+        throw Error('pino – sampling.dedupe.ttlMs must be a positive number')
+      }
+      if (dedupe.maxKeys !== undefined && (typeof dedupe.maxKeys !== 'number' || dedupe.maxKeys < 1 || dedupe.maxKeys !== Math.floor(dedupe.maxKeys))) {
+        throw Error('pino – sampling.dedupe.maxKeys must be a positive integer')
+      }
+    }
+  }
+
+  return sampling
+}
+
+// ---------------------------------------------------------------------------
+// LRU Cache for deduplication
+// ---------------------------------------------------------------------------
+
+class LruCache {
+  constructor (maxSize) {
+    this._max = maxSize
+    this._map = new Map()
+  }
+
+  get (key) {
+    const entry = this._map.get(key)
+    if (entry === undefined) return undefined
+    // Promote to most-recently-used by delete-then-set
+    this._map.delete(key)
+    this._map.set(key, entry)
+    return entry
+  }
+
+  set (key, value) {
+    // If key exists, delete first to update insertion order
+    if (this._map.has(key)) {
+      this._map.delete(key)
+      this._map.set(key, value)
+      return null
+    }
+    let evicted = null
+    if (this._map.size >= this._max) {
+      // Evict oldest (first inserted) entry
+      const oldest = this._map.keys().next().value
+      evicted = this._map.get(oldest)
+      this._map.delete(oldest)
+    }
+    this._map.set(key, value)
+    return evicted // return evicted entry so caller can emit summary, or null
+  }
+
+  delete (key) {
+    return this._map.delete(key)
+  }
+
+  has (key) {
+    return this._map.has(key)
+  }
+
+  clear () {
+    this._map.clear()
+  }
+
+  get size () {
+    return this._map.size
+  }
+
+  // Iterate entries for TTL expiry sweep
+  entries () {
+    return this._map.entries()
+  }
+
+  // Delete and return entry without promotion
+  evict (key) {
+    const entry = this._map.get(key)
+    if (entry !== undefined) {
+      this._map.delete(key)
+    }
+    return entry
+  }
+}
+
+// ---------------------------------------------------------------------------
+// Token Bucket (smooth refill)
+// ---------------------------------------------------------------------------
+
+class TokenBucket {
+  constructor (rate) {
+    this._rate = rate          // tokens per second
+    this._tokens = rate        // start full
+    this._lastRefill = Date.now()
+  }
+
+  consume () {
+    this._refill()
+    if (this._tokens >= 1) {
+      this._tokens -= 1
+      return true
+    }
+    return false
+  }
+
+  _refill () {
+    const now = Date.now()
+    const elapsed = (now - this._lastRefill) / 1000 // seconds
+    if (elapsed > 0) {
+      this._tokens = Math.min(this._rate, this._tokens + elapsed * this._rate)
+      this._lastRefill = now
+    }
+  }
+}
+
+// ---------------------------------------------------------------------------
+// Sampling Engine
+// ---------------------------------------------------------------------------
+
+class SamplingEngine {
+  constructor (config, levelValues) {
+    this._rulesByLevelNum = new Map()
+    this._counters = new Map()
+    this._dropCounts = new Map()
+    this._buckets = new Map()
+    this._dedupe = null
+    this._dedupeKey = 'msg'
+    this._dedupeTtlMs = 5000
+    this._sweepInterval = null
+    this._randomFn = Math.random
+
+    if (config.randomFn && typeof config.randomFn === 'function') {
+      this._randomFn = config.randomFn
+    }
+
+    // Build rule index keyed by numeric level value
+    if (config.rules) {
+      for (let i = 0; i < config.rules.length; i++) {
+        const rule = config.rules[i]
+        const numLevel = levelValues[rule.level]
+        const ruleEntry = {
+          method: rule.method,
+          value: rule.value,
+          rate: rule.rate,
+          level: rule.level,
+          levelNum: numLevel
+        }
+        this._rulesByLevelNum.set(numLevel, ruleEntry)
+        this._dropCounts.set(numLevel, 0)
+
+        if (rule.method === 'every') {
+          this._counters.set(numLevel, 0)
+        } else if (rule.method === 'rate') {
+          this._buckets.set(numLevel, new TokenBucket(rule.rate))
+        }
+      }
+    }
+
+    // Set up deduplication
+    if (config.dedupe && config.dedupe.enabled) {
+      const maxKeys = config.dedupe.maxKeys || 10000
+      this._dedupe = new LruCache(maxKeys)
+      this._dedupeKey = config.dedupe.key || 'msg'
+      this._dedupeTtlMs = config.dedupe.ttlMs || 5000
+      this._dedupeMaxKeys = maxKeys
+
+      // Periodic sweep to expire TTL entries and emit summaries
+      this._pendingSummaries = []
+      this._sweepInterval = setInterval(() => {
+        this._sweepExpired()
+      }, Math.min(this._dedupeTtlMs, 1000))
+      // Unref so it doesn't keep the process alive
+      if (this._sweepInterval.unref) {
+        this._sweepInterval.unref()
+      }
+    }
+  }
+
+  /**
+   * Check whether a log at the given numeric level with the given message
+   * should be emitted. Returns an object with `{ emit, meta }` where meta
+   * contains sampling metadata to inject, or null if the log should be dropped.
+   */
+  shouldEmit (levelNum, msg) {
+    // Deduplication check (applied before method-based sampling)
+    if (this._dedupe !== null) {
+      const dedupeKey = typeof msg === 'string' ? msg : ''
+      const existing = this._dedupe.get(dedupeKey)
+      if (existing !== undefined) {
+        const now = Date.now()
+        if (now - existing.firstSeen < this._dedupeTtlMs) {
+          existing.count += 1
+          existing.levelNum = levelNum
+          return { emit: false, meta: null }
+        }
+        // TTL expired — allow this one through but emit summary for the suppressed
+        if (existing.count > 0) {
+          this._pendingSummaries.push({
+            msg: 'dedupe: suppressed ' + existing.count + ' occurrences of \'' + dedupeKey + '\'',
+            levelNum: existing.levelNum
+          })
+        }
+        this._dedupe.delete(dedupeKey)
+      }
+
+      // Insert/re-insert into cache
+      const evicted = this._dedupe.set(dedupeKey, {
+        firstSeen: Date.now(),
+        count: 0,
+        levelNum
+      })
+      if (evicted !== null && evicted.count > 0) {
+        this._pendingSummaries.push({
+          msg: 'dedupe: suppressed ' + evicted.count + ' occurrences (evicted)',
+          levelNum: evicted.levelNum
+        })
+      }
+    }
+
+    // Method-based sampling
+    const rule = this._rulesByLevelNum.get(levelNum)
+    if (rule === undefined) {
+      // No rule for this level — pass through unsampled
+      return { emit: true, meta: null }
+    }
+
+    let emit = true
+
+    switch (rule.method) {
+      case 'probability': {
+        emit = this._randomFn() < rule.value
+        break
+      }
+      case 'rate': {
+        const bucket = this._buckets.get(levelNum)
+        emit = bucket.consume()
+        break
+      }
+      case 'every': {
+        const count = this._counters.get(levelNum) + 1
+        this._counters.set(levelNum, count)
+        emit = (count % rule.value) === 0
+        break
+      }
+    }
+
+    if (!emit) {
+      this._dropCounts.set(levelNum, (this._dropCounts.get(levelNum) || 0) + 1)
+      return { emit: false, meta: null }
+    }
+
+    const dropped = this._dropCounts.get(levelNum) || 0
+    this._dropCounts.set(levelNum, 0)
+
+    const meta = {
+      method: rule.method
+    }
+    if (rule.method === 'probability') {
+      meta.value = rule.value
+    } else if (rule.method === 'rate') {
+      meta.rate = rule.rate
+    } else if (rule.method === 'every') {
+      meta.value = rule.value
+    }
+    meta.dropped = dropped
+
+    return { emit: true, meta }
+  }
+
+  /**
+   * Drain any pending dedupe summary logs. Returns an array of
+   * { msg, levelNum } objects or an empty array.
+   */
+  drainSummaries () {
+    if (this._pendingSummaries === undefined || this._pendingSummaries.length === 0) {
+      return []
+    }
+    const summaries = this._pendingSummaries
+    this._pendingSummaries = []
+    return summaries
+  }
+
+  _sweepExpired () {
+    if (this._dedupe === null) return
+    const now = Date.now()
+    const toDelete = []
+    for (const [key, entry] of this._dedupe.entries()) {
+      if (now - entry.firstSeen >= this._dedupeTtlMs) {
+        toDelete.push({ key, entry })
+      }
+    }
+    for (let i = 0; i < toDelete.length; i++) {
+      const { key, entry } = toDelete[i]
+      this._dedupe.delete(key)
+      if (entry.count > 0) {
+        this._pendingSummaries.push({
+          msg: 'dedupe: suppressed ' + entry.count + ' occurrences of \'' + key + '\'',
+          levelNum: entry.levelNum
+        })
+      }
+    }
+  }
+
+  destroy () {
+    if (this._sweepInterval !== null) {
+      clearInterval(this._sweepInterval)
+      this._sweepInterval = null
+    }
+    if (this._dedupe !== null) {
+      this._dedupe.clear()
+    }
+    this._rulesByLevelNum.clear()
+    this._counters.clear()
+    this._dropCounts.clear()
+    this._buckets.clear()
+  }
+}
+
+// ---------------------------------------------------------------------------
+// Factory for creating a sampling engine from config
+// ---------------------------------------------------------------------------
+
+function buildSamplingEngine (config, levels) {
+  if (!config || (!config.rules && !config.dedupe)) return null
+  return new SamplingEngine(config, levels.values)
+}
+
+// ---------------------------------------------------------------------------
+// Generate a sampling-aware LOG variant for genLog
+//
+// This returns a wrapper function that checks sampling before calling
+// the original LOG function. It is ONLY created when sampling is active;
+// when sampling is null the original genLog path is untouched (zero cost).
+// ---------------------------------------------------------------------------
+
+function genSampledLog (level, hook, samplingEngine, samplingMetaKey) {
+  if (!hook) return SAMPLED_LOG
+
+  return function hookWrappedSampledLog (...args) {
+    hook.call(this, args, SAMPLED_LOG, level)
+  }
+
+  function SAMPLED_LOG (o, ...n) {
+    const engine = this[samplingSym]
+    if (!engine) {
+      // Fallback: no engine on this instance, should not happen but be safe
+      return
+    }
+
+    // Determine the message string for dedupe purposes
+    let msgForDedupe
+    if (typeof o === 'object') {
+      msgForDedupe = (o === null && n.length === 0) ? '' : (typeof n[0] === 'string' ? n[0] : '')
+    } else {
+      msgForDedupe = o === undefined ? (typeof n[0] === 'string' ? n[0] : '') : (typeof o === 'string' ? o : '')
+    }
+
+    const result = engine.shouldEmit(level, msgForDedupe)
+    if (!result.emit) return
+
+    // Inject sampling metadata into the merge object
+    if (result.meta !== null) {
+      if (typeof o === 'object' && o !== null) {
+        o[samplingMetaKey] = result.meta
+      } else if (typeof o !== 'object') {
+        // For non-object first arg, we cannot inject metadata into the obj
+        // so we just log without metadata injection (msg-only logs)
+      }
+    }
+
+    // Delegate to the write path
+    const { mapHttpRequest, mapHttpResponse } = require('pino-std-serializers')
+    const format = require('quick-format-unescaped')
+    const { writeSym, msgPrefixSym, formatOptsSym } = require('./symbols')
+
+    if (typeof o === 'object') {
+      let msg = o
+      if (o !== null) {
+        if (o.method && o.headers && o.socket) {
+          o = mapHttpRequest(o)
+        } else if (typeof o.setHeader === 'function') {
+          o = mapHttpResponse(o)
+        }
+      }
+      let formatParams
+      if (msg === null && n.length === 0) {
+        formatParams = [null]
+      } else {
+        msg = n.shift()
+        formatParams = n
+      }
+      if (typeof this[msgPrefixSym] === 'string' && msg !== undefined && msg !== null) {
+        msg = this[msgPrefixSym] + msg
+      }
+      this[writeSym](o, format(msg, formatParams, this[formatOptsSym]), level)
+    } else {
+      let msg = o === undefined ? n.shift() : o
+      if (typeof this[msgPrefixSym] === 'string' && msg !== undefined && msg !== null) {
+        msg = this[msgPrefixSym] + msg
+      }
+      this[writeSym](null, format(msg, n, this[formatOptsSym]), level)
+    }
+
+    // Emit any pending dedupe summaries
+    const summaries = engine.drainSummaries()
+    for (let i = 0; i < summaries.length; i++) {
+      const summary = summaries[i]
+      this[writeSym]({ [samplingMetaKey]: { method: 'dedupe', dedupe: true } }, summary.msg, summary.levelNum)
+    }
+  }
+}
+
+module.exports = {
+  validateSamplingConfig,
+  buildSamplingEngine,
+  genSampledLog,
+  SamplingEngine,
+  LruCache,
+  TokenBucket
+}
