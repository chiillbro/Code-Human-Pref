+describe('LruCache', () => {
+  test('basic set and get', () => {
+    const cache = new LruCache(3)
+    cache.set('a', 1)
+    cache.set('b', 2)
+    assert.equal(cache.get('a'), 1)
+    assert.equal(cache.get('b'), 2)
+    assert.equal(cache.size, 2)
+  })
+
+  test('eviction when limit reached', () => {
+    const cache = new LruCache(2)
+    cache.set('a', { v: 1 })
+    cache.set('b', { v: 2 })
+    const evicted = cache.set('c', { v: 3 })
+    // 'a' was the oldest, should be evicted
+    assert.ok(evicted !== null)
+    assert.equal(evicted.v, 1)
+    assert.equal(cache.get('a'), undefined)
+    assert.equal(cache.size, 2)
+  })
+
+  test('get promotes to most recently used', () => {
+    const cache = new LruCache(2)
+    cache.set('a', 1)
+    cache.set('b', 2)
+    // Access 'a' to promote it
+    cache.get('a')
+    // Now 'b' is oldest
+    const evicted = cache.set('c', 3)
+    assert.equal(evicted, 2) // b was evicted and returned
+    assert.equal(cache.get('b'), undefined) // b was evicted
+    assert.equal(cache.get('a'), 1) // a was promoted
+    assert.equal(cache.get('c'), 3)
+  })
+
+  test('overwriting existing key does not evict', () => {
+    const cache = new LruCache(2)
+    cache.set('a', 1)
+    cache.set('b', 2)
+    const evicted = cache.set('a', 10)
+    assert.equal(evicted, null)
+    assert.equal(cache.get('a'), 10)
+    assert.equal(cache.size, 2)
+  })
+
+  test('has returns correct values', () => {
+    const cache = new LruCache(3)
+    cache.set('x', 42)
+    assert.equal(cache.has('x'), true)
+    assert.equal(cache.has('y'), false)
+  })
+
+  test('delete removes entry', () => {
+    const cache = new LruCache(3)
+    cache.set('x', 42)
+    cache.delete('x')
+    assert.equal(cache.get('x'), undefined)
+    assert.equal(cache.size, 0)
+  })
+
+  test('clear empties cache', () => {
+    const cache = new LruCache(3)
+    cache.set('a', 1)
+    cache.set('b', 2)
+    cache.clear()
+    assert.equal(cache.size, 0)
+  })
+
+  test('evict removes without promotion', () => {
+    const cache = new LruCache(3)
+    cache.set('a', 1)
+    cache.set('b', 2)
+    const entry = cache.evict('a')
+    assert.equal(entry, 1)
+    assert.equal(cache.get('a'), undefined)
+    assert.equal(cache.size, 1)
+  })
+})
