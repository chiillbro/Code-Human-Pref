+describe('TokenBucket', () => {
+  test('starts full and allows burst', () => {
+    const bucket = new TokenBucket(5)
+    for (let i = 0; i < 5; i++) {
+      assert.equal(bucket.consume(), true)
+    }
+    // Should be empty now
+    assert.equal(bucket.consume(), false)
+  })
+
+  test('refills over time', async () => {
+    const bucket = new TokenBucket(10)
+    // Drain the bucket
+    for (let i = 0; i < 10; i++) {
+      bucket.consume()
+    }
+    assert.equal(bucket.consume(), false)
+    // Wait for tokens to refill
+    await sleep(200)
+    // Should have ~2 tokens after 200ms at 10/s
+    assert.equal(bucket.consume(), true)
+  })
+
+  test('tokens capped at rate', async () => {
+    const bucket = new TokenBucket(3)
+    // Wait long enough to theoretically over-fill
+    await sleep(500)
+    // Should still only have 3 tokens max
+    let consumed = 0
+    while (bucket.consume()) consumed++
+    assert.equal(consumed, 3)
+  })
+})
