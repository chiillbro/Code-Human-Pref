+  test('sampling metadata is injected via merge object', async () => {
+    const stream = sink()
+    const logger = pino({
+      sampling: {
+        rules: [{ level: 'info', method: 'every', value: 2 }]
+      }
+    }, stream)
+
+    // First log is dropped (1 % 2 !== 0), second is emitted (2 % 2 === 0)
+    logger.info({ foo: 'bar' }, 'first')
+    logger.info({ foo: 'baz' }, 'second')
+
+    const data = await once(stream, 'data')
+    assert.equal(data.msg, 'second')
+    assert.equal(data.foo, 'baz')
+    assert.ok(data._sampling, 'should have _sampling metadata')
+    assert.equal(data._sampling.method, 'every')
+    assert.equal(data._sampling.value, 2)
+    assert.equal(data._sampling.dropped, 1)
+  })
+
+  test('custom metaKey changes metadata property name', async () => {
+    const stream = sink()
+    const logger = pino({
