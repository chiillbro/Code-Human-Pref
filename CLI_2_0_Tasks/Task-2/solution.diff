+describe('sampling integration', () => {
+  test('no sampling option works normally', async () => {
+    const stream = sink()
+    const logger = pino(stream)
+    logger.info('hello')
+    const result = await once(stream, 'data')
+    assert.equal(result.msg, 'hello')
+    assert.equal(result.level, 30)
+  })
+
+  test('probability=1 emits all logs', async () => {
+    const stream = sink()
+    const logger = pino({
+      sampling: {
+        rules: [{ level: 'info', method: 'probability', value: 1.0 }]
+      }
+    }, stream)
+
+    const expected = 10
+    let count = 0
+    const done = new Promise((resolve) => {
+      stream.on('data', () => {
+        count++
+        if (count === expected) resolve()
+      })
+    })
+
+    for (let i = 0; i < expected; i++) {
+      logger.info('test')
+    }
+
+    await done
+    assert.equal(count, expected)
+  })
+
+  test('probability=0 emits no logs', async () => {
+    const stream = sink()
+    const logger = pino({
+      sampling: {
+        rules: [{ level: 'info', method: 'probability', value: 0 }]
+      }
+    }, stream)
+
+    let count = 0
+    stream.on('data', () => { count++ })
+
+    for (let i = 0; i < 50; i++) {
+      logger.info('should be dropped')
+    }
+
+    await sleep(50)
+    assert.equal(count, 0)
