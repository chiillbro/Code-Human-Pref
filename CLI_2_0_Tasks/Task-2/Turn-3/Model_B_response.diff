+describe('sampling - integration with other features', () => {
+  test('redaction is applied to logs that pass sampling', async t => {
+    const plan = tspl(t, { plan: 3 })
+    const stream = captureStream()
+    const logger = pino({
+      redact: ['secret'],
+      sampling: { info: { every: 2 } }
+    }, stream)
+
+    logger.info({ secret: 'hunter2', keep: 1 }, 'a') // emitted
+    logger.info({ secret: 'hunter2', keep: 2 }, 'b') // dropped
+    logger.info({ secret: 'hunter2', keep: 3 }, 'c') // emitted
+
+    plan.equal(stream.lines.length, 2)
+    plan.equal(stream.lines[0].secret, '[Redacted]')
+    plan.deepEqual(stream.lines.map(l => l.keep), [1, 3])
+  })
+
+  test('serializers run only for logs that pass sampling', async t => {
+    const plan = tspl(t, { plan: 3 })
+    const stream = captureStream()
+    let calls = 0
+    const logger = pino({
+      sampling: { info: { every: 2 } },
+      serializers: { foo (v) { calls++; return v.id } }
+    }, stream)
+
+    for (let i = 0; i < 6; i++) logger.info({ foo: { id: i } }, 'x')
+
+    plan.equal(stream.lines.length, 3)
+    // serializer ran only for the 3 emitted lines, not the 3 dropped ones
+    plan.equal(calls, 3)
+    plan.deepEqual(stream.lines.map(l => l.foo), [0, 2, 4])
+  })
+
+  test('msgPrefix is applied to logs that pass sampling', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const logger = pino({
+      msgPrefix: '[S] ',
+      sampling: { info: { every: 2 } }
+    }, stream)
+
+    logger.info('one')
+    logger.info('two')
+    logger.info('three')
+
+    plan.equal(stream.lines.length, 2)
+    plan.deepEqual(stream.lines.map(l => l.msg), ['[S] one', '[S] three'])
+  })
+
+  test('child msgPrefix + inherited sampling', async t => {
+    const plan = tspl(t, { plan: 1 })
+    const stream = captureStream()
+    const parent = pino({ msgPrefix: '[P] ', sampling: { info: { every: 2 } } }, stream)
+    const child = parent.child({}, { msgPrefix: '[C] ' })
+
+    child.info('a'); child.info('b'); child.info('c')
+    plan.deepEqual(stream.lines.map(l => l.msg), ['[P] [C] a', '[P] [C] c'])
+  })
+})
