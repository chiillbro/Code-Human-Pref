+    const stream = captureStream()
+    const logger = pino({
+      sampling: { info: { dedupe: { window: 30, maxKeys: 1 } } }
+    }, stream)
+
+    logger.info('a') // arms timer for 'a'
+    logger.info('a') // suppressed, a.count = 1
+    logger.info('b') // evicts 'a' -> should clearTimeout + emit 'a' summary now
+
+    // Wait past the original timer's firing time. If the timer were not
+    // cleared (or the guard were missing) we would see a duplicate summary.
+    await sleep(60)
