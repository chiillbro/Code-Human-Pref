+    plan.equal(summaries[0].sampling.suppressed, 1)
+    // 'b' was only seen once and never suppressed -> no summary for it
+    plan.equal(stream.lines.filter(l => l.sampling && l.sampling.key === 'b').length, 0)
+  })
