+
+describe('sampling - integration with other features', () => {
+  test('sampling + redact: redaction still applies to emitted logs', async t => {
+    const plan = tspl(t, { plan: 4 })
+    const stream = captureStream()
+    const logger = pino({
+      redact: ['secret', 'nested.token'],
+      sampling: { info: { every: 2 } }
+    }, stream)
+
+    // every:2 -> emits calls 0, 2
+    logger.info({ secret: 'hunter2', nested: { token: 'abc' }, keep: 'yes' }, 'l0')
+    logger.info({ secret: 'hunter2' }, 'l1') // dropped
+    logger.info({ secret: 'hunter3', nested: { token: 'xyz' }, keep: 'also' }, 'l2')
+
+    plan.equal(stream.lines.length, 2)
+    // both emitted lines must have secret redacted but non-secret fields intact
+    plan.equal(stream.lines[0].secret, '[Redacted]')
+    plan.equal(stream.lines[0].nested.token, '[Redacted]')
+    plan.equal(stream.lines[1].secret, '[Redacted]')
+  })
+
+  test('sampling + serializers: serializer only runs for passed logs', async t => {
+    const plan = tspl(t, { plan: 3 })
+    const stream = captureStream()
+    let serializerCalls = 0
+    const logger = pino({
+      serializers: {
+        user (u) { serializerCalls++; return { id: u.id } }
+      },
+      sampling: { info: { every: 3 } }
+    }, stream)
+
+    // every:3 -> emits calls 0, 3, 6, 9 out of 10
+    for (let i = 0; i < 10; i++) {
+      logger.info({ user: { id: i, password: 'p' + i } }, 'm')
+    }
+
+    plan.equal(stream.lines.length, 4)
+    plan.equal(serializerCalls, 4) // exactly once per emitted log
+    plan.deepEqual(stream.lines.map(l => l.user), [
+      { id: 0 }, { id: 3 }, { id: 6 }, { id: 9 }
+    ])
+  })
+
+  test('sampling + msgPrefix: prefix applied to emitted logs only', async t => {
+    const plan = tspl(t, { plan: 3 })
+    const stream = captureStream()
+    const logger = pino({
+      msgPrefix: '[HTTP] ',
+      sampling: { info: { every: 2 } }
+    }, stream)
+
+    logger.info('a') // emitted
+    logger.info('b') // dropped
+    logger.info('c') // emitted
+
+    plan.equal(stream.lines.length, 2)
+    plan.equal(stream.lines[0].msg, '[HTTP] a')
+    plan.equal(stream.lines[1].msg, '[HTTP] c')
+  })
+
+  test('sampling + msgPrefix: child prefix concatenates on sampled logs', async t => {
+    const plan = tspl(t, { plan: 2 })
+    const stream = captureStream()
+    const parent = pino({
+      msgPrefix: '[HTTP] ',
+      sampling: { info: { every: 2 } }
+    }, stream)
+    const child = parent.child({}, { msgPrefix: '[req] ' })
+
+    child.info('a') // emitted (shares parent sampler state)
+    child.info('b') // dropped
+    child.info('c') // emitted
+
+    plan.equal(stream.lines.length, 2)
+    plan.equal(stream.lines[0].msg, '[HTTP] [req] a')
+  })
+
+  test('sampling + dedupe summary: redaction still applies to the summary line', async t => {
+    const plan = tspl(t, { plan: 4 })
+    const stream = captureStream()
+    const logger = pino({
+      msgPrefix: '[svc] ',
+      redact: ['secret'],
+      sampling: { info: { dedupe: { window: 30 } } }
+    }, stream)
+
+    logger.info({ secret: 's1' }, 'boom')
+    logger.info({ secret: 's2' }, 'boom')
+    logger.info({ secret: 's3' }, 'boom')
+    await sleep(60)
+
+    const emitted = stream.lines.filter(l => !l.sampling)
+    const summaries = stream.lines.filter(l => l.sampling)
+    plan.equal(emitted.length, 1)
+    plan.equal(emitted[0].msg, '[svc] boom') // msgPrefix applies to user logs
+    // Redaction runs in asJson (downstream of writeSym) so it still applies
+    // to the sampling summary – the key 'boom' isn't a redacted path but
+    // emitted logs confirm redaction is active on this logger.
+    plan.equal(emitted[0].secret, '[Redacted]')
+    // Dedupe summary is emitted via writeSym directly (bypassing LOG / format
+    // / msgPrefix) so it can't recurse into the sampler. This is intentional:
+    // the summary carries a structured `sampling` field for filtering.
+    plan.equal(summaries.length, 1)
+  })
+})
