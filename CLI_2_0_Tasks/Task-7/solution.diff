index 0000000..f1ec187
--- /dev/null
+++ b/src/logpipe/parsers/syslog_parser.py
@@ -0,0 +1,59 @@
+from __future__ import annotations
+
+import re
+from datetime import timezone
+
+from logpipe.models import LogEntry, Severity
+from logpipe.normalizer import SYSLOG_SEVERITY_MAP, parse_timestamp
+
+SYSLOG_RE = re.compile(
+    r"<(\d{1,3})>"
+    r"(\w{3}\s+\d{1,2}\s+\d{2}:\d{2}:\d{2})\s+"
+    r"(\S+)\s+"  # hostname
+    r"(.*)"  # rest
+)
+
+MSG_RE = re.compile(r"(\S+?)(?:\[(\d+)\])?:\s*(.*)", re.DOTALL)
+
+
+def parse_syslog_line(
+    line: str,
+    source: str,
+    default_tz: timezone = timezone.utc,
+    reference_year: int | None = None,
+) -> LogEntry:
+    m = SYSLOG_RE.match(line)
+    if not m:
+        raise ValueError("Does not match syslog format")
+
+    priority = int(m.group(1))
+    ts_raw = m.group(2)
+    hostname = m.group(3)
+    rest = m.group(4)
+
+    facility = priority >> 3
+    severity_num = priority & 0x07
+    severity = SYSLOG_SEVERITY_MAP.get(severity_num, Severity.INFO)
+
+    timestamp = parse_timestamp(ts_raw, default_tz=default_tz, reference_year=reference_year)
+
+    metadata: dict = {"hostname": hostname, "facility": facility, "priority": priority}
+
+    msg_match = MSG_RE.match(rest)
+    if msg_match:
+        process = msg_match.group(1)
+        pid = msg_match.group(2)
+        message = msg_match.group(3)
+        metadata["process"] = process
+        if pid:
+            metadata["pid"] = int(pid)
+    else:
+        message = rest
+
+    return LogEntry(
+        timestamp=timestamp,
+        severity=severity,
+        source=hostname,
+        message=message,
+        metadata=metadata,
+    )
