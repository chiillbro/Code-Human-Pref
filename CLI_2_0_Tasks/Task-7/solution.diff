@@ -0,0 +1,44 @@
+from __future__ import annotations
+
+import re
+from datetime import timezone
+
+from logpipe.models import LogEntry, Severity, SEVERITY_NAMES
+from logpipe.normalizer import parse_timestamp
+
+
+def parse_pattern_line(
+    line: str,
+    pattern: str,
+    ts_format: str,
+    source: str,
+    default_tz: timezone = timezone.utc,
+) -> LogEntry:
+    m = re.match(pattern, line)
+    if not m:
+        raise ValueError(f"Does not match custom pattern")
+
+    groups = m.groupdict()
+
+    ts_raw = groups.pop("timestamp", None)
+    if not ts_raw:
+        raise ValueError("Custom pattern must capture a 'timestamp' group")
+
+    timestamp = parse_timestamp(ts_raw, fmt=ts_format, default_tz=default_tz)
+    message = groups.pop("message", "")
+
+    severity_raw = groups.pop("severity", None)
+    if severity_raw:
+        severity = SEVERITY_NAMES.get(severity_raw.upper(), Severity.INFO)
+    else:
+        severity = Severity.INFO
+
+    src = groups.pop("source", source)
+
+    return LogEntry(
+        timestamp=timestamp,
+        severity=severity,
+        source=src,
+        message=message,
+        metadata=groups,
+    )
