+++ b/src/logpipe/rules_engine.py
@@ -0,0 +1,60 @@
+from __future__ import annotations
+
+import fnmatch
+import re
+
+from logpipe.models import FilterConfig, LogEntry, TransformRule
+
+
+def apply_filter(entry: LogEntry, config: FilterConfig) -> tuple[bool, str | None]:
+    """Check whether an entry passes all filters. Returns (passes, rejected_by_name)."""
+    if config.severity_min is not None and entry.severity < config.severity_min:
+        return False, "severity_min"
+
+    if config.source_exclude:
+        for pattern in config.source_exclude:
+            if fnmatch.fnmatch(entry.source, pattern):
+                return False, "source_exclude"
+
+    if config.source_include:
+        if not any(fnmatch.fnmatch(entry.source, p) for p in config.source_include):
+            return False, "source_include"
+
+    if config.keyword_exclude:
+        msg_lower = entry.message.lower()
+        for kw in config.keyword_exclude:
+            if kw.lower() in msg_lower:
+                return False, "keyword_exclude"
+
+    if config.keyword_match:
+        msg_lower = entry.message.lower()
+        if not any(kw.lower() in msg_lower for kw in config.keyword_match):
+            return False, "keyword_match"
+
+    if config.time_range_start and entry.timestamp < config.time_range_start:
+        return False, "time_range"
+
+    if config.time_range_end and entry.timestamp >= config.time_range_end:
+        return False, "time_range"
+
+    return True, None
+
+
+def apply_transforms(entry: LogEntry, transforms: list[TransformRule]) -> LogEntry:
+    """Apply transform rules in order. Mutates and returns the entry."""
+    for rule in transforms:
+        if rule.type == "extract_fields":
+            m = re.search(rule.params["pattern"], entry.message)
+            if m:
+                entry.metadata.update(m.groupdict())
+        elif rule.type == "rename_field":
+            old = rule.params["from"]
+            new = rule.params["to"]
+            if old in entry.metadata:
+                entry.metadata[new] = entry.metadata.pop(old)
+        elif rule.type == "add_static_field":
+            entry.metadata[rule.params["key"]] = rule.params["value"]
+        elif rule.type == "drop_fields":
+            for f in rule.params["fields"]:
+                entry.metadata.pop(f, None)
+    return entry
diff --git a/src/logpipe/tail.py b/src/logpipe/tail.py
new file mode 100644
index 0000000..17941ff
--- /dev/null
+++ b/src/logpipe/tail.py
@@ -0,0 +1,151 @@
+from __future__ import annotations
+
+import json
+import os
+import sys
+import time
+from datetime import timezone
+
+from logpipe.models import PipelineConfig
+from logpipe.normalizer import resolve_default_tz
+from logpipe.parsers.detector import detect_format
+from logpipe.parsers.json_parser import parse_json_line
+from logpipe.parsers.pattern_parser import parse_pattern_line
+from logpipe.parsers.syslog_parser import parse_syslog_line
+from logpipe.rules_engine import apply_filter, apply_transforms
+
+
+class FileMonitor:
+    """Monitor a single file for new content with rotation detection via inode check."""
+
+    def __init__(self, filepath: str, format_name: str, config: PipelineConfig):
+        self.filepath = filepath
+        self.format_name = format_name
+        self.config = config
+        self.file = None
+        self.inode: int | None = None
+        self._open(seek_end=True)
+
+    def _open(self, seek_end: bool = False) -> None:
+        self.file = open(self.filepath, errors="replace")
+        stat = os.stat(self.filepath)
+        self.inode = stat.st_ino
+        if seek_end:
+            self.file.seek(0, 2)
+
+    def check_rotation(self) -> bool:
+        try:
+            stat = os.stat(self.filepath)
+            if stat.st_ino != self.inode:
+                self.file.close()
+                self._open(seek_end=False)
+                return True
+        except FileNotFoundError:
+            pass
+        return False
+
+    def read_new_lines(self) -> list[str]:
+        lines: list[str] = []
+        while True:
+            line = self.file.readline()
+            if not line:
+                break
+            lines.append(line.rstrip("\n\r"))
+        return lines
+
+    def close(self) -> None:
+        if self.file and not self.file.closed:
+            self.file.close()
+
+
+def tail_files(
+    paths: list[str],
+    config: PipelineConfig,
+    format_name: str | None = None,
+    refresh_seconds: float = 5.0,
+    output_format: str = "raw",
+) -> None:
+    default_tz = resolve_default_tz(config.default_timezone)
+    monitors: list[FileMonitor] = []
+
+    for p in paths:
+        try:
+            fmt = format_name or detect_format(p, config.custom_patterns or None)
+            monitors.append(FileMonitor(p, fmt, config))
+        except (OSError, ValueError) as e:
+            print(f"Warning: {p}: {e}", file=sys.stderr)
+
+    if not monitors:
+        print("Error: No files could be opened for monitoring.", file=sys.stderr)
+        return
+
+    entry_count = 0
+    last_refresh = time.monotonic()
+
+    try:
+        while True:
+            for mon in monitors:
+                mon.check_rotation()
+                lines = mon.read_new_lines()
+
+                for line in lines:
+                    if not line.strip():
+                        continue
+                    entry = _parse_line(line, mon, default_tz)
+                    if entry is None:
+                        continue
+
+                    passes, _ = apply_filter(entry, config.filters)
+                    if not passes:
+                        continue
+
+                    entry = apply_transforms(entry, config.transforms)
+                    entry_count += 1
+
+                    if output_format == "json":
+                        print(
+                            json.dumps(
+                                {
+                                    "timestamp": entry.timestamp.isoformat(),
+                                    "severity": entry.severity.name,
+                                    "source": entry.source,
+                                    "message": entry.message,
+                                    "metadata": entry.metadata,
+                                }
+                            )
+                        )
+                    else:
+                        print(
+                            f"{entry.timestamp.isoformat()} [{entry.severity.name}] "
+                            f"{entry.source}: {entry.message}"
+                        )
+
+            now = time.monotonic()
+            if now - last_refresh >= refresh_seconds:
+                print(f"\n--- {entry_count} entries processed ---", file=sys.stderr)
+                last_refresh = now
+
+            time.sleep(0.25)
+
+    except KeyboardInterrupt:
+        pass
+    finally:
+        for mon in monitors:
+            mon.close()
+
+
+def _parse_line(line, mon, default_tz):
+    try:
+        if mon.format_name == "json":
+            return parse_json_line(line, mon.filepath, default_tz)
+        elif mon.format_name == "syslog":
+            return parse_syslog_line(line, mon.filepath, default_tz)
+        elif mon.format_name.startswith("custom:"):
+            pname = mon.format_name.split(":", 1)[1]
+            cp = next((c for c in mon.config.custom_patterns if c.name == pname), None)
+            if not cp:
+                return None
+            return parse_pattern_line(line, cp.pattern, cp.timestamp_format, mon.filepath, default_tz)
+    except (ValueError, KeyError):
+        return None
+    return None
