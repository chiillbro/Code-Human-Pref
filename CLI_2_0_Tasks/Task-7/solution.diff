+import json
+import os
+import tempfile
+from datetime import datetime, timezone
+
+import pytest
+
+from logpipe.models import Severity, CustomPattern, PipelineConfig
+from logpipe.parsers.json_parser import parse_json_line
+from logpipe.parsers.syslog_parser import parse_syslog_line
+from logpipe.parsers.pattern_parser import parse_pattern_line
+from logpipe.parsers.detector import detect_format
+from logpipe.parsers import parse_file
+
+
+class TestJsonParser:
+    def test_basic(self):
+        line = json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "hello"})
+        entry = parse_json_line(line, "/test.log")
+        assert entry.message == "hello"
+        assert entry.severity == Severity.INFO
+        assert entry.source == "/test.log"
+        assert entry.timestamp.tzinfo is not None
+
+    def test_with_severity(self):
+        line = json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "err", "severity": "ERROR"})
+        entry = parse_json_line(line, "/test.log")
+        assert entry.severity == Severity.ERROR
+
+    def test_with_level_field(self):
+        line = json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "warn", "level": "WARNING"})
+        entry = parse_json_line(line, "/test.log")
+        assert entry.severity == Severity.WARNING
+
+    def test_extra_fields_in_metadata(self):
+        line = json.dumps({
+            "timestamp": "2024-01-15T10:00:00Z", "message": "hi",
+            "user": "alice", "request_id": "abc123"
+        })
+        entry = parse_json_line(line, "/test.log")
+        assert entry.metadata["user"] == "alice"
+        assert entry.metadata["request_id"] == "abc123"
+        assert "timestamp" not in entry.metadata
+        assert "message" not in entry.metadata
+
+    def test_missing_timestamp_raises(self):
+        line = json.dumps({"message": "no ts"})
+        with pytest.raises(ValueError, match="timestamp"):
+            parse_json_line(line, "/test.log")
+
+    def test_invalid_json_raises(self):
+        with pytest.raises(json.JSONDecodeError):
+            parse_json_line("not json", "/test.log")
+
+    def test_unknown_severity_defaults_to_info(self):
+        line = json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "x", "severity": "UNKNOWN"})
+        entry = parse_json_line(line, "/test.log")
+        assert entry.severity == Severity.INFO
+
+
+class TestSyslogParser:
+    def test_basic_with_pid(self):
+        line = "<34>Jan 15 10:30:00 myhost sshd[1234]: Accepted password for user"
+        entry = parse_syslog_line(line, "/var/log/syslog", reference_year=2024)
+        assert entry.source == "myhost"
+        assert entry.message == "Accepted password for user"
+        assert entry.metadata["process"] == "sshd"
+        assert entry.metadata["pid"] == 1234
+        assert entry.metadata["hostname"] == "myhost"
+        # priority 34 = facility 4, severity 2 (Critical)
+        assert entry.metadata["facility"] == 4
+        assert entry.severity == Severity.CRITICAL
+
+    def test_without_pid(self):
+        line = "<13>Jan 15 10:30:00 myhost kernel: some kernel message"
+        entry = parse_syslog_line(line, "/var/log/syslog", reference_year=2024)
+        assert entry.metadata["process"] == "kernel"
+        assert "pid" not in entry.metadata
+
+    def test_severity_mapping(self):
+        # priority = facility * 8 + severity
+        # <11> = facility 1, severity 3 (Error)
+        line = "<11>Jan 15 10:00:00 host proc[1]: msg"
+        entry = parse_syslog_line(line, "x", reference_year=2024)
+        assert entry.severity == Severity.ERROR
+
+    def test_warning_severity(self):
+        # <12> = facility 1, severity 4 (Warning)
+        line = "<12>Jan 15 10:00:00 host proc: msg"
+        entry = parse_syslog_line(line, "x", reference_year=2024)
+        assert entry.severity == Severity.WARNING
+
+    def test_info_severity(self):
+        # <14> = facility 1, severity 6 (Informational)
+        line = "<14>Jan 15 10:00:00 host proc: msg"
+        entry = parse_syslog_line(line, "x", reference_year=2024)
+        assert entry.severity == Severity.INFO
+
+    def test_invalid_format_raises(self):
+        with pytest.raises(ValueError, match="syslog"):
+            parse_syslog_line("not a syslog line", "x")
+
+    def test_single_digit_day(self):
+        line = "<13>Jan  5 08:00:00 host proc: msg"
+        entry = parse_syslog_line(line, "x", reference_year=2024)
+        assert entry.timestamp.day == 5
+
+
+class TestPatternParser:
+    PATTERN = r"(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) \[(?P<severity>\w+)\] (?P<message>.*)"
+    TS_FMT = "%Y-%m-%d %H:%M:%S"
+
+    def test_basic(self):
+        line = "2024-01-15 10:30:00 [ERROR] something broke"
+        entry = parse_pattern_line(line, self.PATTERN, self.TS_FMT, "/app.log")
+        assert entry.severity == Severity.ERROR
+        assert entry.message == "something broke"
+        assert entry.source == "/app.log"
+
+    def test_no_match_raises(self):
+        with pytest.raises(ValueError, match="pattern"):
+            parse_pattern_line("nope", self.PATTERN, self.TS_FMT, "/app.log")
+
+    def test_missing_timestamp_group_raises(self):
+        pattern = r"(?P<message>.*)"
+        with pytest.raises(ValueError, match="timestamp"):
+            parse_pattern_line("hello", pattern, "%Y", "/app.log")
+
+    def test_extra_groups_in_metadata(self):
+        pattern = r"(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) (?P<user>\w+) (?P<message>.*)"
+        line = "2024-01-15 10:30:00 alice did stuff"
+        entry = parse_pattern_line(line, pattern, self.TS_FMT, "/app.log")
+        assert entry.metadata["user"] == "alice"
+
+    def test_source_from_pattern(self):
+        pattern = r"(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) (?P<source>\S+) (?P<message>.*)"
+        line = "2024-01-15 10:30:00 web-01 request handled"
+        entry = parse_pattern_line(line, pattern, self.TS_FMT, "/app.log")
+        assert entry.source == "web-01"
+
+    def test_default_severity_is_info(self):
+        pattern = r"(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) (?P<message>.*)"
+        line = "2024-01-15 10:30:00 no severity"
+        entry = parse_pattern_line(line, pattern, self.TS_FMT, "/app.log")
+        assert entry.severity == Severity.INFO
+
+
+class TestDetectFormat:
+    def _write_temp(self, lines):
+        f = tempfile.NamedTemporaryFile(mode="w", suffix=".log", delete=False)
+        f.write("\n".join(lines) + "\n")
+        f.close()
+        return f.name
+
+    def test_detect_json(self):
+        lines = [json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": f"msg{i}"}) for i in range(10)]
+        path = self._write_temp(lines)
+        try:
+            assert detect_format(path) == "json"
+        finally:
+            os.unlink(path)
+
+    def test_detect_syslog(self):
+        lines = [f"<13>Jan 15 10:0{i}:00 host proc: msg{i}" for i in range(10)]
+        path = self._write_temp(lines)
+        try:
+            assert detect_format(path) == "syslog"
+        finally:
+            os.unlink(path)
+
+    def test_mixed_format_below_threshold_raises(self):
+        lines = [
+            json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "json"}),
+            "<13>Jan 15 10:00:00 host proc: syslog",
+            "plain text line",
+            json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "json2"}),
+            "<13>Jan 15 10:01:00 host proc: syslog2",
+            "another plain line",
+            json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "json3"}),
+            "<13>Jan 15 10:02:00 host proc: syslog3",
+            "plain again",
+            "more plain",
+        ]
+        path = self._write_temp(lines)
+        try:
+            with pytest.raises(ValueError, match="auto-detect"):
+                detect_format(path)
+        finally:
+            os.unlink(path)
+
+    def test_empty_file_raises(self):
+        path = self._write_temp(["", "   ", ""])
+        try:
+            with pytest.raises(ValueError, match="empty"):
+                detect_format(path)
+        finally:
+            os.unlink(path)
+
+    def test_custom_pattern_detection(self):
+        lines = [f"2024-01-15 10:0{i}:00 [INFO] message {i}" for i in range(10)]
+        path = self._write_temp(lines)
+        cp = CustomPattern(
+            name="myformat",
+            pattern=r"(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) \[(?P<severity>\w+)\] (?P<message>.*)",
+            timestamp_format="%Y-%m-%d %H:%M:%S",
+        )
+        try:
+            assert detect_format(path, [cp]) == "custom:myformat"
+        finally:
+            os.unlink(path)
+
+    def test_few_lines_json(self):
+        lines = [json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": f"m{i}"}) for i in range(3)]
+        path = self._write_temp(lines)
+        try:
+            assert detect_format(path) == "json"
+        finally:
+            os.unlink(path)
+
+
+class TestParseFile:
+    def _write_temp(self, lines):
+        f = tempfile.NamedTemporaryFile(mode="w", suffix=".log", delete=False)
+        f.write("\n".join(lines) + "\n")
+        f.close()
+        return f.name
+
+    def test_parse_json_file(self):
+        lines = [
+            json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "a"}),
+            json.dumps({"timestamp": "2024-01-15T10:01:00Z", "message": "b"}),
+        ]
+        path = self._write_temp(lines)
+        try:
+            results = list(parse_file(path, format_name="json"))
+            entries = [e for e, err in results if e is not None]
+            assert len(entries) == 2
+            assert entries[0].message == "a"
+        finally:
+            os.unlink(path)
+
+    def test_malformed_lines_reported(self):
