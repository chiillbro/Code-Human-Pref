+import json
+import os
+import subprocess
+import sys
+import tempfile
+
+import pytest
+import yaml
+
+
+def _write_temp(content, suffix=".log"):
+    f = tempfile.NamedTemporaryFile(mode="w", suffix=suffix, delete=False)
+    f.write(content)
+    f.close()
+    return f.name
+
+
+def _run_logpipe(*args, input_text=None):
+    cmd = [sys.executable, "-m", "logpipe"] + list(args)
+    result = subprocess.run(
+        cmd,
+        capture_output=True,
+        text=True,
+        timeout=30,
+        input=input_text,
+    )
+    return result
+
+
+class TestAnalyzeCommand:
+    def test_json_file(self):
+        lines = "\n".join(
+            json.dumps({"timestamp": f"2024-01-15T10:{i:02d}:00Z", "message": f"msg{i}"})
+            for i in range(20)
+        )
+        log_path = _write_temp(lines)
+        report_path = _write_temp("", suffix=".json")
+        try:
+            r = _run_logpipe("analyze", log_path, "--report", report_path)
+            assert r.returncode == 0
+            with open(report_path) as f:
+                data = json.load(f)
+            assert data["ingestion"]["total_entries"] == 20
+            assert data["ingestion"]["files_processed"] == 1
+        finally:
+            os.unlink(log_path)
+            os.unlink(report_path)
+
+    def test_syslog_file(self):
+        lines = "\n".join(
+            f"<14>Jan 15 10:{i:02d}:00 myhost app[100]: log entry {i}"
+            for i in range(10)
+        )
+        log_path = _write_temp(lines)
+        report_path = _write_temp("", suffix=".json")
+        try:
+            r = _run_logpipe("analyze", log_path, "--format", "syslog", "--report", report_path)
+            assert r.returncode == 0
+            with open(report_path) as f:
+                data = json.load(f)
+            assert data["ingestion"]["total_entries"] == 10
+        finally:
+            os.unlink(log_path)
+            os.unlink(report_path)
+
+    def test_with_config(self):
+        lines = "\n".join(
+            json.dumps({
+                "timestamp": f"2024-01-15T10:{i:02d}:00Z",
+                "message": "error occurred" if i % 3 == 0 else "info msg",
+                "severity": "ERROR" if i % 3 == 0 else "INFO",
+            })
+            for i in range(15)
+        )
+        log_path = _write_temp(lines)
+        config = {
+            "filters": {"severity_min": "ERROR"},
+            "aggregation": {"window_seconds": 300, "slide_seconds": 300},
+        }
+        config_path = _write_temp(yaml.dump(config), suffix=".yaml")
+        report_path = _write_temp("", suffix=".json")
+        try:
+            r = _run_logpipe("analyze", log_path, "--config", config_path, "--report", report_path)
+            assert r.returncode == 0
+            with open(report_path) as f:
+                data = json.load(f)
+            # Only ERROR entries should pass (every 3rd entry: 0,3,6,9,12 = 5)
+            assert data["filter_summary"]["entries_after"] == 5
+        finally:
+            os.unlink(log_path)
+            os.unlink(config_path)
+            os.unlink(report_path)
+
+    def test_missing_file(self):
+        r = _run_logpipe("analyze", "/tmp/nonexistent_12345.log")
+        assert r.returncode == 2
+
+    def test_bad_config(self):
+        log_path = _write_temp(json.dumps({"timestamp": "2024-01-15T10:00:00Z", "message": "x"}))
+        try:
+            r = _run_logpipe("analyze", log_path, "--config", "/tmp/nonexistent_config_12345.yaml")
+            assert r.returncode == 1
+        finally:
+            os.unlink(log_path)
+
+    def test_anomaly_exit_code(self):
+        # Create data with a big spike after steady baseline
+        lines = []
+        for i in range(25):
+            count = 2 if i < 22 else 50
+            day = 15 + i // 14
+            hour = i % 14
+            for j in range(count):
+                lines.append(json.dumps({
+                    "timestamp": f"2024-01-{day:02d}T{hour:02d}:{j:02d}:00Z",
+                    "message": f"msg",
+                }))
+        log_path = _write_temp("\n".join(lines))
+        config = {
+            "aggregation": {"window_seconds": 3600, "slide_seconds": 3600},
+            "anomaly": {"baseline_windows": 5, "sensitivity": 1.5},
