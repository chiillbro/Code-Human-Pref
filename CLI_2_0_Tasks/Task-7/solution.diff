+from datetime import datetime, timezone
+
+import pytest
+
+from logpipe.models import FilterConfig, LogEntry, Severity, TransformRule
+from logpipe.rules_engine import apply_filter, apply_transforms
+
+
+def _entry(
+    message="test message",
+    severity=Severity.INFO,
+    source="/app.log",
+    ts="2024-06-15T12:00:00Z",
+    metadata=None,
+):
+    return LogEntry(
+        timestamp=datetime.fromisoformat(ts),
+        severity=severity,
+        source=source,
+        message=message,
+        metadata=metadata or {},
+    )
+
+
+class TestSeverityMinFilter:
+    def test_passes_above(self):
+        config = FilterConfig(severity_min=Severity.WARNING)
+        ok, _ = apply_filter(_entry(severity=Severity.ERROR), config)
+        assert ok
+
+    def test_passes_equal(self):
+        config = FilterConfig(severity_min=Severity.WARNING)
+        ok, _ = apply_filter(_entry(severity=Severity.WARNING), config)
+        assert ok
+
+    def test_rejects_below(self):
+        config = FilterConfig(severity_min=Severity.WARNING)
+        ok, name = apply_filter(_entry(severity=Severity.INFO), config)
+        assert not ok
+        assert name == "severity_min"
+
+
+class TestSourceFilters:
+    def test_include_match(self):
+        config = FilterConfig(source_include=["*.log"])
+        ok, _ = apply_filter(_entry(source="/app.log"), config)
+        assert ok
+
+    def test_include_no_match(self):
+        config = FilterConfig(source_include=["*.log"])
+        ok, name = apply_filter(_entry(source="/app.txt"), config)
+        assert not ok
+        assert name == "source_include"
+
+    def test_exclude_match(self):
+        config = FilterConfig(source_exclude=["debug*"])
+        ok, name = apply_filter(_entry(source="debug.log"), config)
+        assert not ok
+        assert name == "source_exclude"
+
+    def test_exclude_takes_priority(self):
+        config = FilterConfig(source_include=["*.log"], source_exclude=["debug*"])
+        ok, name = apply_filter(_entry(source="debug.log"), config)
+        assert not ok
+        assert name == "source_exclude"
+
+
+class TestKeywordFilters:
+    def test_keyword_match_present(self):
+        config = FilterConfig(keyword_match=["error", "fail"])
+        ok, _ = apply_filter(_entry(message="an error occurred"), config)
+        assert ok
+
+    def test_keyword_match_absent(self):
+        config = FilterConfig(keyword_match=["error", "fail"])
+        ok, name = apply_filter(_entry(message="all good"), config)
+        assert not ok
+        assert name == "keyword_match"
+
+    def test_keyword_match_case_insensitive(self):
+        config = FilterConfig(keyword_match=["ERROR"])
+        ok, _ = apply_filter(_entry(message="an error occurred"), config)
+        assert ok
+
+    def test_keyword_exclude_present(self):
+        config = FilterConfig(keyword_exclude=["test"])
+        ok, name = apply_filter(_entry(message="this is a test"), config)
+        assert not ok
+        assert name == "keyword_exclude"
+
+    def test_keyword_exclude_absent(self):
+        config = FilterConfig(keyword_exclude=["test"])
+        ok, _ = apply_filter(_entry(message="production"), config)
+        assert ok
+
+
+class TestTimeRangeFilter:
+    def test_within_range(self):
+        config = FilterConfig(
+            time_range_start=datetime(2024, 1, 1, tzinfo=timezone.utc),
+            time_range_end=datetime(2024, 12, 31, tzinfo=timezone.utc),
+        )
+        ok, _ = apply_filter(_entry(ts="2024-06-15T12:00:00Z"), config)
+        assert ok
+
+    def test_before_start(self):
+        config = FilterConfig(
+            time_range_start=datetime(2024, 6, 1, tzinfo=timezone.utc),
+        )
+        ok, name = apply_filter(_entry(ts="2024-01-01T00:00:00Z"), config)
+        assert not ok
+        assert name == "time_range"
+
+    def test_at_end_boundary_excluded(self):
+        config = FilterConfig(
+            time_range_end=datetime(2024, 6, 15, 12, 0, 0, tzinfo=timezone.utc),
+        )
+        ok, name = apply_filter(_entry(ts="2024-06-15T12:00:00Z"), config)
+        assert not ok
+        assert name == "time_range"
+
+
+class TestCombinedFilters:
+    def test_and_logic(self):
+        config = FilterConfig(
+            severity_min=Severity.WARNING,
+            keyword_match=["critical"],
+        )
+        # Passes severity but not keyword
+        ok, name = apply_filter(_entry(severity=Severity.ERROR, message="other"), config)
+        assert not ok
+        assert name == "keyword_match"
+
+    def test_all_pass(self):
+        config = FilterConfig(
+            severity_min=Severity.WARNING,
+            keyword_match=["critical"],
+        )
+        ok, _ = apply_filter(_entry(severity=Severity.ERROR, message="critical issue"), config)
+        assert ok
+
+    def test_no_filters(self):
+        config = FilterConfig()
+        ok, _ = apply_filter(_entry(), config)
+        assert ok
+
+
+class TestTransforms:
+    def test_extract_fields(self):
+        rule = TransformRule(type="extract_fields", params={"pattern": r"user=(?P<user>\w+)"})
+        entry = _entry(message="login user=alice from 10.0.0.1")
+        result = apply_transforms(entry, [rule])
+        assert result.metadata["user"] == "alice"
+
+    def test_extract_fields_no_match(self):
+        rule = TransformRule(type="extract_fields", params={"pattern": r"user=(?P<user>\w+)"})
+        entry = _entry(message="no user info")
+        result = apply_transforms(entry, [rule])
+        assert "user" not in result.metadata
+
+    def test_rename_field(self):
+        rule = TransformRule(type="rename_field", params={"from": "old", "to": "new"})
+        entry = _entry(metadata={"old": "value"})
+        result = apply_transforms(entry, [rule])
+        assert "new" in result.metadata
+        assert "old" not in result.metadata
+
+    def test_rename_missing_field(self):
+        rule = TransformRule(type="rename_field", params={"from": "nope", "to": "new"})
+        entry = _entry()
+        result = apply_transforms(entry, [rule])
+        assert "new" not in result.metadata
+
+    def test_add_static_field(self):
