+from __future__ import annotations
+
+import os
+from datetime import datetime, timezone
+from typing import Generator
+
+from logpipe.models import CustomPattern, LogEntry, PipelineConfig
+from logpipe.normalizer import resolve_default_tz
+from logpipe.parsers.detector import detect_format
+from logpipe.parsers.json_parser import parse_json_line
+from logpipe.parsers.pattern_parser import parse_pattern_line
+from logpipe.parsers.syslog_parser import parse_syslog_line
+
+
+def parse_file(
+    filepath: str,
+    format_name: str | None = None,
+    config: PipelineConfig | None = None,
+) -> Generator[tuple[LogEntry | None, str | None], None, None]:
+    """Stream log entries from a file. Yields (entry, None) or (None, error_string)."""
+    default_tz = resolve_default_tz(config.default_timezone if config else "UTC")
+    custom_patterns = config.custom_patterns if config else []
+
+    if format_name is None:
+        format_name = detect_format(filepath, custom_patterns or None)
+
+    reference_year = None
+    if format_name == "syslog":
+        try:
+            stat = os.stat(filepath)
+            reference_year = datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc).year
+        except OSError:
+            reference_year = datetime.now(timezone.utc).year
+
+    custom_pattern = None
+    custom_ts_fmt = None
+    if format_name.startswith("custom:"):
+        pname = format_name.split(":", 1)[1]
+        for cp in custom_patterns:
+            if cp.name == pname:
+                custom_pattern = cp.pattern
+                custom_ts_fmt = cp.timestamp_format
+                break
+        if custom_pattern is None:
+            yield None, f"Custom pattern '{pname}' not found in config"
+            return
+
+    with open(filepath, errors="replace") as f:
+        for lineno, raw_line in enumerate(f, 1):
+            line = raw_line.rstrip("\n\r")
+            if not line.strip():
+                continue
+            try:
+                if format_name == "json":
+                    entry = parse_json_line(line, filepath, default_tz)
+                elif format_name == "syslog":
+                    entry = parse_syslog_line(line, filepath, default_tz, reference_year)
+                elif custom_pattern:
+                    entry = parse_pattern_line(
+                        line, custom_pattern, custom_ts_fmt, filepath, default_tz
+                    )
+                else:
+                    yield None, f"{filepath}:{lineno}: unknown format '{format_name}'"
+                    continue
+                yield entry, None
+            except (ValueError, KeyError) as e:
+                yield None, f"{filepath}:{lineno}: {e}"
