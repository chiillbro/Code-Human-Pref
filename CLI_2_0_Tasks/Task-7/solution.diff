+
+class TestBuildWindows:
+    def test_empty(self):
+        assert build_windows([], 300, 60) == []
+
+    def test_single_entry(self):
+        entries = [_entry("2024-01-15T10:00:30Z")]
+        windows = build_windows(entries, 300, 60)
+        assert len(windows) >= 1
+        assert any(w.total_count == 1 for w in windows)
+
+    def test_boundary_inclusive_start(self):
+        """Event exactly at window start should be included in that window."""
+        # Window [10:00:00, 10:05:00)
+        entries = [
+            _entry("2024-01-15T10:00:00Z"),
+            _entry("2024-01-15T10:04:59Z"),
+        ]
+        windows = build_windows(entries, 300, 300)
+        assert len(windows) == 1
+        assert windows[0].total_count == 2
+
+    def test_boundary_exclusive_end(self):
+        """Event exactly at window end should NOT be in that window [start, end)."""
+        entries = [
+            _entry("2024-01-15T10:00:00Z"),
+            _entry("2024-01-15T10:05:00Z"),  # exactly at end of first window
+        ]
+        windows = build_windows(entries, 300, 300)
+        # First window: [10:00:00, 10:05:00) → 1 entry
+        # Second window: [10:05:00, 10:10:00) → 1 entry
+        assert len(windows) == 2
+        assert windows[0].total_count == 1
+        assert windows[1].total_count == 1
+
+    def test_sliding_overlap(self):
+        """With slide < window, entries can appear in multiple windows."""
+        entries = [
+            _entry("2024-01-15T10:00:30Z"),
+            _entry("2024-01-15T10:04:30Z"),
+        ]
+        # 300s window, 60s slide → entries should appear in multiple windows
+        windows = build_windows(entries, 300, 60)
+        total_hits = sum(w.total_count for w in windows)
+        # With overlapping windows, total hits across all windows > number of entries
+        assert total_hits > 2
+
+    def test_no_gaps_with_slide(self):
+        """Windows should cover the full range without gaps."""
+        entries = [
+            _entry("2024-01-15T10:00:00Z"),
+            _entry("2024-01-15T10:10:00Z"),
+        ]
+        windows = build_windows(entries, 300, 60)
+        # Check windows are contiguous in terms of slide
+        for i in range(1, len(windows)):
+            prev_start = windows[i - 1].start.timestamp()
+            curr_start = windows[i].start.timestamp()
+            assert curr_start - prev_start == 60
+
+    def test_top_n_sources(self):
+        entries = [
+            _entry("2024-01-15T10:00:00Z", source="a"),
+            _entry("2024-01-15T10:00:01Z", source="a"),
+            _entry("2024-01-15T10:00:02Z", source="b"),
+        ]
+        windows = build_windows(entries, 300, 300, top_n=1)
+        assert len(windows) == 1
+        # top_n=1 should only report top source
+        assert len(windows[0].top_sources) == 1
+        assert windows[0].top_sources[0][0] == "a"
+
+    def test_error_rate(self):
+        entries = [
+            _entry("2024-01-15T10:00:00Z", severity=Severity.INFO),
+            _entry("2024-01-15T10:00:01Z", severity=Severity.ERROR),
+            _entry("2024-01-15T10:00:02Z", severity=Severity.CRITICAL),
+            _entry("2024-01-15T10:00:03Z", severity=Severity.INFO),
+        ]
+        windows = build_windows(entries, 300, 300)
+        assert len(windows) == 1
+        # 2 out of 4 are ERROR or CRITICAL = 50%
+        assert windows[0].error_rate == 50.0
+
+    def test_eps(self):
+        entries = [_entry(f"2024-01-15T10:00:0{i}Z") for i in range(5)]
+        windows = build_windows(entries, 300, 300)
+        assert len(windows) == 1
+        # 5 events / 300 seconds
+        assert abs(windows[0].eps - 5 / 300) < 0.001
+
+    def test_severity_counts(self):
+        entries = [
+            _entry("2024-01-15T10:00:00Z", severity=Severity.INFO),
+            _entry("2024-01-15T10:00:01Z", severity=Severity.INFO),
+            _entry("2024-01-15T10:00:02Z", severity=Severity.ERROR),
+        ]
+        windows = build_windows(entries, 300, 300)
+        assert windows[0].counts_by_severity["INFO"] == 2
+        assert windows[0].counts_by_severity["ERROR"] == 1
+
+
+class TestComputeMetrics:
+    def test_empty_window(self):
+        start = datetime(2024, 1, 15, 10, 0, 0, tzinfo=timezone.utc)
+        end = datetime(2024, 1, 15, 10, 5, 0, tzinfo=timezone.utc)
+        m = _compute_metrics([], start, end, 300, 10)
+        assert m.total_count == 0
+        assert m.error_rate == 0.0
+        assert m.eps == 0.0
+        assert m.counts_by_severity == {}
+        assert m.top_sources == []
