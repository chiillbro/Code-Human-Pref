@@ -0,0 +1,193 @@
+from __future__ import annotations
+
+import argparse
+import sys
+
+import logpipe
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(
+        prog="logpipe",
+        description="Multi-format log aggregation & anomaly detection pipeline",
+    )
+    sub = parser.add_subparsers(dest="command")
+
+    # analyze
+    analyze_p = sub.add_parser("analyze", help="Batch analysis mode")
+    analyze_p.add_argument("files", nargs="+", help="Log files to process")
+    analyze_p.add_argument("--config", "-c", help="Path to config YAML")
+    analyze_p.add_argument("--report", "-r", help="Path to write JSON report")
+    analyze_p.add_argument(
+        "--format", "-f", dest="fmt", help="Force log format (json, syslog, custom:<name>)"
+    )
+
+    # tail
+    tail_p = sub.add_parser("tail", help="Streaming monitor mode")
+    tail_p.add_argument("files", nargs="+", help="Log files to monitor")
+    tail_p.add_argument("--config", "-c", help="Path to config YAML")
+    tail_p.add_argument("--refresh", type=float, default=5.0, help="Refresh interval (seconds)")
+    tail_p.add_argument("--format", "-f", dest="fmt", help="Force log format")
+    tail_p.add_argument("--output", "-o", choices=["raw", "json"], default="raw")
+
+    # config
+    config_p = sub.add_parser("config", help="Config management")
+    config_sub = config_p.add_subparsers(dest="config_command")
+    config_sub.add_parser("init", help="Generate starter config file")
+
+    # version
+    sub.add_parser("version", help="Print version")
+
+    args = parser.parse_args()
+
+    if args.command == "analyze":
+        sys.exit(_analyze(args))
+    elif args.command == "tail":
+        sys.exit(_tail(args))
+    elif args.command == "config":
+        if args.config_command == "init":
+            sys.exit(_config_init())
+        else:
+            config_p.print_help()
+            sys.exit(1)
+    elif args.command == "version":
+        print(f"logpipe {logpipe.__version__}")
+        sys.exit(0)
+    else:
+        parser.print_help()
+        sys.exit(1)
+
+
+def _analyze(args) -> int:
+    from logpipe.aggregator import build_windows
+    from logpipe.anomaly_detector import detect_anomalies
+    from logpipe.config import load_config
+    from logpipe.models import AnalysisReport, FilterSummary, IngestionSummary, PipelineConfig
+    from logpipe.parsers import parse_file
+    from logpipe.parsers.detector import detect_format
+    from logpipe.reporter import format_report, write_report
+    from logpipe.rules_engine import apply_filter, apply_transforms
+
+    config = PipelineConfig()
+    if args.config:
+        try:
+            config = load_config(args.config)
+        except Exception as e:
+            print(f"Config error: {e}", file=sys.stderr)
+            return 1
+
+    ingestion = IngestionSummary()
+    filter_summary = FilterSummary()
+    entries = []
+    severity_counts: dict[str, int] = {}
+
+    files_ok = 0
+    for filepath in args.files:
+        try:
+            fmt = args.fmt
+            if fmt is None:
+                fmt = detect_format(filepath, config.custom_patterns or None)
+        except (OSError, ValueError) as e:
+            print(f"Warning: {filepath}: {e}", file=sys.stderr)
+            continue
+
+        file_entries = 0
+        try:
+            for entry, error in parse_file(filepath, format_name=fmt, config=config):
+                if error:
+                    ingestion.malformed_lines += 1
+                    print(f"Warning: {error}", file=sys.stderr)
+                    continue
+
+                ingestion.total_entries += 1
+                filter_summary.entries_before += 1
+                file_entries += 1
+
+                passes, rejected_by = apply_filter(entry, config.filters)
+                if not passes:
+                    filter_summary.dropped_per_filter[rejected_by] = (
+                        filter_summary.dropped_per_filter.get(rejected_by, 0) + 1
+                    )
+                    continue
+
+                entry = apply_transforms(entry, config.transforms)
+                filter_summary.entries_after += 1
+                entries.append(entry)
+
+                sev_name = entry.severity.name
+                severity_counts[sev_name] = severity_counts.get(sev_name, 0) + 1
+
+        except OSError as e:
+            print(f"Error: Cannot read {filepath}: {e}", file=sys.stderr)
+            continue
+
+        if file_entries > 0:
+            files_ok += 1
+            ingestion.entries_per_format[fmt] = (
+                ingestion.entries_per_format.get(fmt, 0) + file_entries
+            )
+
+    ingestion.files_processed = files_ok
+
+    if files_ok == 0:
+        print("Error: No files could be processed.", file=sys.stderr)
+        return 2
+
+    windows = build_windows(
+        entries,
+        config.aggregation.window_seconds,
+        config.aggregation.slide_seconds,
+        config.aggregation.top_n,
+    )
+
+    anomalies = detect_anomalies(
+        windows,
+        config.anomaly.baseline_windows,
+        config.anomaly.sensitivity,
+    )
+
+    report = AnalysisReport(
+        ingestion=ingestion,
+        filter_summary=filter_summary,
+        windows=windows,
+        anomalies=anomalies,
+        severity_breakdown=severity_counts,
+    )
+
+    print(format_report(report))
+
+    if args.report:
+        write_report(report, args.report)
+        print(f"\nReport written to {args.report}")
+
+    return 3 if anomalies else 0
+
+
+def _tail(args) -> int:
+    from logpipe.config import load_config
+    from logpipe.models import PipelineConfig
+    from logpipe.tail import tail_files
+
+    config = PipelineConfig()
+    if args.config:
+        try:
+            config = load_config(args.config)
+        except Exception as e:
+            print(f"Config error: {e}", file=sys.stderr)
+            return 1
+
+    tail_files(
+        args.files,
+        config,
+        format_name=args.fmt,
+        refresh_seconds=args.refresh,
+        output_format=args.output,
+    )
+    return 0
+
+
+def _config_init() -> int:
+    from logpipe.config import CONFIG_TEMPLATE
+
+    print(CONFIG_TEMPLATE)
+    return 0
diff --git a/src/logpipe/config.py b/src/logpipe/config.py
new file mode 100644
index 0000000..a8be0ad
--- /dev/null
+++ b/src/logpipe/config.py
@@ -0,0 +1,150 @@
+from __future__ import annotations
+
+import yaml
+
+from logpipe.models import (
+    AggregationConfig,
+    AnomalyConfig,
+    CustomPattern,
+    FilterConfig,
+    PipelineConfig,
+    Severity,
+    TransformRule,
+)
+from logpipe.normalizer import parse_timestamp
+
+
+def load_config(path: str) -> PipelineConfig:
+    with open(path) as f:
+        raw = yaml.safe_load(f)
+
+    if not raw:
+        return PipelineConfig()
+
+    config = PipelineConfig()
+    config.default_timezone = raw.get("default_timezone", "UTC")
+
+    if "filters" in raw:
+        f = raw["filters"]
+        sev_min = None
+        if "severity_min" in f:
+            sev_min = Severity[f["severity_min"].upper()]
+
+        tr_start = None
+        tr_end = None
+        if "time_range" in f and isinstance(f["time_range"], dict):
+            tr = f["time_range"]
+            if "start" in tr:
+                tr_start = parse_timestamp(str(tr["start"]))
+            if "end" in tr:
+                tr_end = parse_timestamp(str(tr["end"]))
+
+        config.filters = FilterConfig(
+            severity_min=sev_min,
+            source_include=f.get("source_include", []),
+            source_exclude=f.get("source_exclude", []),
+            keyword_match=f.get("keyword_match", []),
+            keyword_exclude=f.get("keyword_exclude", []),
+            time_range_start=tr_start,
+            time_range_end=tr_end,
+        )
+
+    if "transforms" in raw:
+        for t in raw["transforms"]:
+            ttype = t["type"]
+            params = {k: v for k, v in t.items() if k != "type"}
+            config.transforms.append(TransformRule(type=ttype, params=params))
+
+    if "aggregation" in raw:
+        a = raw["aggregation"]
+        config.aggregation = AggregationConfig(
+            window_seconds=a.get("window_seconds", 300),
+            slide_seconds=a.get("slide_seconds", 60),
+            top_n=a.get("top_n", 10),
+        )
+
+    if "anomaly" in raw:
+        an = raw["anomaly"]
+        config.anomaly = AnomalyConfig(
+            baseline_windows=an.get("baseline_windows", 20),
+            sensitivity=an.get("sensitivity", 2.0),
+        )
+
+    if "custom_patterns" in raw:
+        for cp in raw["custom_patterns"]:
+            config.custom_patterns.append(
+                CustomPattern(
+                    name=cp["name"],
+                    pattern=cp["pattern"],
+                    timestamp_format=cp["timestamp_format"],
+                )
+            )
+
+    return config
+
+
+CONFIG_TEMPLATE = """\
+# logpipe configuration file
+# All sections are optional — defaults are used for missing values.
+
+# Default timezone for timestamps without timezone info
+default_timezone: UTC
+
+# Filter rules — entries must pass ALL active filters
+filters:
+  # Minimum severity: DEBUG, INFO, WARNING, ERROR, CRITICAL
+  # severity_min: INFO
+
+  # Only include entries from sources matching these globs
+  # source_include:
+  #   - "*.log"
+
+  # Exclude entries from sources matching these globs (takes priority over include)
+  # source_exclude:
+  #   - "debug*"
+
+  # Entries must contain at least one of these keywords
+  # keyword_match:
+  #   - "error"
+  #   - "failed"
+
+  # Drop entries containing any of these keywords
+  # keyword_exclude:
+  #   - "test"
+
+  # Only include entries within this time range
+  # time_range:
+  #   start: "2024-01-01T00:00:00Z"
+  #   end: "2024-12-31T23:59:59Z"
+
+# Transform rules — applied in order after filtering
+transforms: []
+  # - type: extract_fields
+  #   pattern: "user=(?P<user>\\\\w+)"
+  # - type: rename_field
+  #   from: old_name
+  #   to: new_name
+  # - type: add_static_field
+  #   key: environment
+  #   value: production
+  # - type: drop_fields
+  #   fields:
+  #     - internal_id
+
+# Aggregation settings
+aggregation:
+  window_seconds: 300    # 5-minute windows
+  slide_seconds: 60      # slide every 1 minute
+  top_n: 10              # top N sources per window
+
+# Anomaly detection settings
+anomaly:
+  baseline_windows: 20   # number of windows for baseline
+  sensitivity: 2.0       # IQR multiplier for anomaly threshold
+
+# Custom log format patterns
+# custom_patterns:
+#   - name: apache
+#     pattern: '(?P<source>\\\\S+) - - \\\\[(?P<timestamp>[^\\\\]]+)\\\\] "(?P<message>[^"]+)"'
+#     timestamp_format: "%d/%b/%Y:%H:%M:%S %z"
+"""
