@@ -0,0 +1,79 @@
+from __future__ import annotations
+
+import json
+import math
+import re
+
+from logpipe.models import CustomPattern
+
+
+def _classify_line(line: str) -> str | None:
+    stripped = line.strip()
+    if not stripped:
+        return None
+    if stripped.startswith("{"):
+        try:
+            json.loads(stripped)
+            return "json"
+        except json.JSONDecodeError:
+            return None
+    if re.match(r"<\d{1,3}>", stripped):
+        return "syslog"
+    return None
+
+
+def detect_format(
+    filepath: str, custom_patterns: list[CustomPattern] | None = None
+) -> str:
+    """Auto-detect log format by examining first 10 non-empty lines.
+
+    Requires >= 70% of sampled lines to match a single format.
+    """
+    votes: dict[str, int] = {}
+    lines_checked = 0
+
+    with open(filepath, errors="replace") as f:
+        for raw_line in f:
+            line = raw_line.strip()
+            if not line:
+                continue
+            fmt = _classify_line(line)
+            if fmt:
+                votes[fmt] = votes.get(fmt, 0) + 1
+            lines_checked += 1
+            if lines_checked >= 10:
+                break
+
+    if lines_checked == 0:
+        raise ValueError(f"File is empty or contains only blank lines: {filepath}")
+
+    threshold = math.ceil(lines_checked * 0.7)
+
+    for fmt, count in sorted(votes.items(), key=lambda x: -x[1]):
+        if count >= threshold:
+            return fmt
+
+    if custom_patterns:
+        for cp in custom_patterns:
+            pattern = re.compile(cp.pattern)
+            matches = 0
+            checked = 0
+            with open(filepath, errors="replace") as f:
+                for raw_line in f:
+                    line = raw_line.strip()
+                    if not line:
+                        continue
+                    if pattern.match(line):
+                        matches += 1
+                    checked += 1
+                    if checked >= 10:
+                        break
+            cp_threshold = math.ceil(checked * 0.7)
+            if matches >= cp_threshold:
+                return f"custom:{cp.name}"
+
+    raise ValueError(
+        f"Could not auto-detect format for {filepath}. "
+        f"Checked {lines_checked} lines, results: {votes}. "
+        f"Use --format to specify explicitly."
+    )
