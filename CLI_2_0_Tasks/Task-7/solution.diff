+from datetime import datetime, timezone
+
+import pytest
+
+from logpipe.anomaly_detector import detect_anomalies, _compute_median_iqr
+from logpipe.models import WindowMetrics
+
+
+def _window(start_minute, count):
+    start = datetime(2024, 1, 15, 10, start_minute, 0, tzinfo=timezone.utc)
+    end = datetime(2024, 1, 15, 10, start_minute + 5, 0, tzinfo=timezone.utc)
+    return WindowMetrics(
+        start=start,
+        end=end,
+        total_count=count,
+        counts_by_severity={},
+        top_sources=[],
+        error_rate=0.0,
+        eps=0.0,
+    )
+
+
+class TestComputeMedianIqr:
+    def test_empty(self):
+        median, iqr = _compute_median_iqr([])
+        assert median == 0.0
+        assert iqr == 0.0
+
+    def test_single(self):
+        median, iqr = _compute_median_iqr([10])
+        assert median == 10
+        assert iqr == 0.0
+
+    def test_two_values(self):
+        median, iqr = _compute_median_iqr([10, 20])
+        assert median == 15.0
+        assert iqr == 0.0  # n < 4
+
+    def test_four_values(self):
+        median, iqr = _compute_median_iqr([1, 2, 3, 4])
+        # sorted: [1, 2, 3, 4]
+        # lower: [1, 2] → Q1 = 1.5
+        # upper: [3, 4] → Q3 = 3.5
+        assert median == 2.5
+        assert iqr == 2.0
+
+    def test_odd_values(self):
+        median, iqr = _compute_median_iqr([1, 2, 3, 4, 5])
+        # sorted: [1, 2, 3, 4, 5]
+        # median = 3
+        # lower: [1, 2] → Q1 = 1.5
+        # upper: [4, 5] → Q3 = 4.5
+        assert median == 3
+        assert iqr == 3.0
+
+    def test_uniform(self):
+        median, iqr = _compute_median_iqr([5, 5, 5, 5, 5])
+        assert median == 5
+        assert iqr == 0.0
+
+
+class TestDetectAnomalies:
+    def test_first_k_windows_not_flagged(self):
+        windows = [_window(i, 10) for i in range(25)]
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        # All have count=10, no anomalies
+        assert len(anomalies) == 0
+
+    def test_spike_detected(self):
+        # 20 baseline windows with count=10, then one with count=100
+        windows = [_window(i, 10) for i in range(20)]
+        windows.append(_window(20, 100))
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 1
+        assert anomalies[0].direction == "spike"
+        assert anomalies[0].event_count == 100
+        assert anomalies[0].baseline_median == 10
+
+    def test_drop_detected(self):
+        # 20 baseline windows with count=100, then one with count=0
+        windows = [_window(i, 100) for i in range(20)]
+        windows.append(_window(20, 0))
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 1
+        assert anomalies[0].direction == "drop"
+
+    def test_no_anomaly_within_bounds(self):
+        # Varying counts within normal range
+        counts = [10, 12, 11, 13, 10, 14, 11, 12, 10, 13,
+                  11, 12, 10, 14, 13, 11, 12, 10, 13, 11, 12]
+        windows = [_window(i, c) for i, c in enumerate(counts)]
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 0
+
+    def test_iqr_zero_spike(self):
+        # All baseline=10, current=15 → IQR is 0, 15 != 10 → spike
+        windows = [_window(i, 10) for i in range(20)]
+        windows.append(_window(20, 15))
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 1
+        assert anomalies[0].direction == "spike"
+        assert anomalies[0].magnitude == 5  # abs(15 - 10)
+
+    def test_iqr_zero_drop(self):
+        windows = [_window(i, 10) for i in range(20)]
+        windows.append(_window(20, 5))
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 1
+        assert anomalies[0].direction == "drop"
+        assert anomalies[0].magnitude == 5
+
+    def test_iqr_zero_no_anomaly(self):
+        windows = [_window(i, 10) for i in range(21)]
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 0
+
+    def test_exactly_at_boundary_not_flagged(self):
+        # baseline: mix of 8 and 12 → median=10, IQR=4
+        # upper = 10 + 2*4 = 18, lower = 10 - 2*4 = 2
+        counts = [8, 12] * 10  # 20 values
+        windows = [_window(i, c) for i, c in enumerate(counts)]
+        # Add one at exactly upper=18
+        windows.append(_window(20, 18))
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        assert len(anomalies) == 0  # exactly at boundary → not anomalous
+
+    def test_sensitivity_parameter(self):
+        # Low sensitivity should flag more
+        counts = [10, 12] * 10
+        windows = [_window(i, c) for i, c in enumerate(counts)]
+        windows.append(_window(20, 14))  # slight increase
+        # With sensitivity=0.5: upper = 11 + 0.5*2 = 12, 14 > 12 → spike
+        anomalies_low = detect_anomalies(windows, baseline_k=20, sensitivity=0.5)
+        # With sensitivity=5: upper = 11 + 5*2 = 21, 14 < 21 → no anomaly
+        anomalies_high = detect_anomalies(windows, baseline_k=20, sensitivity=5.0)
+        assert len(anomalies_low) >= 1
+        assert len(anomalies_high) == 0
+
+    def test_rolling_baseline(self):
+        # First 20 windows: count=10. Then 5 windows with count=50.
+        # By window 25, the baseline is windows 5-24 which includes some 50s.
+        windows = [_window(i, 10) for i in range(20)]
+        for i in range(20, 26):
+            windows.append(_window(i, 50))
+        anomalies = detect_anomalies(windows, baseline_k=20, sensitivity=2.0)
+        # Window 20 (count=50) uses baseline from windows 0-19 (all count=10)
+        # This should be flagged as spike
+        assert any(a.event_count == 50 and a.direction == "spike" for a in anomalies)
