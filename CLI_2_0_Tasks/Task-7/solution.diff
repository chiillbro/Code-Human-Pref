+from __future__ import annotations
+
+import json
+
+from logpipe.models import AnalysisReport
+
+
+def write_report(report: AnalysisReport, path: str) -> None:
+    with open(path, "w") as f:
+        json.dump(report.to_dict(), f, indent=2)
+
+
+def load_report(path: str) -> dict:
+    with open(path) as f:
+        return json.load(f)
+
+
+def format_report(report: AnalysisReport) -> str:
+    lines: list[str] = []
+    lines.append("=== Log Analysis Report ===")
+    lines.append("")
+
+    ing = report.ingestion
+    lines.append("Ingestion:")
+    lines.append(f"  Files processed:   {ing.files_processed}")
+    lines.append(f"  Total entries:     {ing.total_entries}")
+    lines.append(f"  Malformed lines:   {ing.malformed_lines}")
+    if ing.entries_per_format:
+        fmt_str = ", ".join(f"{k}={v}" for k, v in sorted(ing.entries_per_format.items()))
+        lines.append(f"  By format:         {fmt_str}")
+    lines.append("")
+
+    fs = report.filter_summary
+    lines.append("Filtering:")
+    lines.append(f"  Before: {fs.entries_before}")
+    lines.append(f"  After:  {fs.entries_after}")
+    if fs.dropped_per_filter:
+        for name, count in sorted(fs.dropped_per_filter.items()):
+            lines.append(f"    {name}: -{count}")
+    lines.append("")
+
+    if report.severity_breakdown:
+        lines.append("Severity Breakdown:")
+        for sev in ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]:
+            if sev in report.severity_breakdown:
+                lines.append(f"  {sev:<10} {report.severity_breakdown[sev]}")
+        lines.append("")
+
+    lines.append(f"Windows: {len(report.windows)}")
+    lines.append(f"Anomalies: {len(report.anomalies)}")
+
+    if report.anomalies:
+        lines.append("")
+        top = sorted(report.anomalies, key=lambda a: a.magnitude, reverse=True)[:5]
+        lines.append("Top Anomalies:")
+        for a in top:
+            lines.append(
+                f"  {a.window_start.strftime('%Y-%m-%d %H:%M')} - "
+                f"{a.window_end.strftime('%H:%M')}  "
+                f"{a.direction:<5}  count={a.event_count}  "
+                f"baseline={a.baseline_median:.0f}  "
+                f"magnitude={a.magnitude:.2f}"
+            )
+
+    return "\n".join(lines)
