+++ b/src/logpipe/normalizer.py
@@ -0,0 +1,73 @@
+from __future__ import annotations
+
+import re
+from datetime import datetime, timedelta, timezone
+from zoneinfo import ZoneInfo
+
+from logpipe.models import Severity
+
+_SYSLOG_TS_RE = re.compile(r"^(\w{3})\s+(\d{1,2})\s+(\d{2}:\d{2}:\d{2})$")
+
+SYSLOG_SEVERITY_MAP: dict[int, Severity] = {
+    0: Severity.CRITICAL,   # Emergency
+    1: Severity.CRITICAL,   # Alert
+    2: Severity.CRITICAL,   # Critical
+    3: Severity.ERROR,      # Error
+    4: Severity.WARNING,    # Warning
+    5: Severity.INFO,       # Notice
+    6: Severity.INFO,       # Informational
+    7: Severity.DEBUG,      # Debug
+}
+
+
+def resolve_default_tz(tz_name: str) -> timezone | ZoneInfo:
+    if tz_name == "UTC":
+        return timezone.utc
+    try:
+        return ZoneInfo(tz_name)
+    except (KeyError, ImportError):
+        return timezone.utc
+
+
+def parse_timestamp(
+    raw: str,
+    fmt: str | None = None,
+    default_tz: timezone | ZoneInfo = timezone.utc,
+    reference_year: int | None = None,
+) -> datetime:
+    """Parse a timestamp string into a timezone-aware UTC datetime.
+
+    Handles ISO 8601 variants (Z, numeric offsets, fractional seconds, T or space separator),
+    syslog format (Mon DD HH:MM:SS with year inference), and custom strptime formats.
+    """
+    raw = raw.strip()
+
+    if fmt:
+        dt = datetime.strptime(raw, fmt)
+        if dt.tzinfo is None:
+            dt = dt.replace(tzinfo=default_tz)
+        return dt.astimezone(timezone.utc)
+
+    # ISO 8601 via fromisoformat (Python 3.11+ handles Z and numeric offsets)
+    try:
+        dt = datetime.fromisoformat(raw)
+        if dt.tzinfo is None:
+            dt = dt.replace(tzinfo=default_tz)
+        return dt.astimezone(timezone.utc)
+    except ValueError:
+        pass
+
+    # Syslog timestamp: "Mon DD HH:MM:SS" (no year)
+    m = _SYSLOG_TS_RE.match(raw)
+    if m:
+        month_str, day_str, time_str = m.group(1), m.group(2), m.group(3)
+        year = reference_year or datetime.now(timezone.utc).year
+        dt_str = f"{month_str} {int(day_str)} {time_str} {year}"
+        dt = datetime.strptime(dt_str, "%b %d %H:%M:%S %Y")
+        dt = dt.replace(tzinfo=default_tz)
+        # If >1 day in the future, assume previous year (Dec→Jan boundary)
+        if dt.astimezone(timezone.utc) > datetime.now(timezone.utc) + timedelta(days=1):
+            dt = dt.replace(year=year - 1)
+        return dt.astimezone(timezone.utc)
+
+    raise ValueError(f"Unable to parse timestamp: {raw!r}")
