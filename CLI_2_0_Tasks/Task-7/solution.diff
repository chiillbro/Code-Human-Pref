+from __future__ import annotations
+
+import bisect
+from collections import Counter
+from datetime import datetime, timezone
+
+from logpipe.models import LogEntry, Severity, WindowMetrics
+
+
+def build_windows(
+    entries: list[LogEntry],
+    window_seconds: int,
+    slide_seconds: int,
+    top_n: int = 10,
+) -> list[WindowMetrics]:
+    """Build sliding time windows over entries. Windows use [start, end) boundary semantics.
+
+    An event whose timestamp equals the window start is included; an event whose
+    timestamp equals the window end belongs to the *next* window.
+    """
+    if not entries:
+        return []
+
+    entries.sort(key=lambda e: e.timestamp)
+    timestamps = [e.timestamp for e in entries]
+
+    first_epoch = entries[0].timestamp.timestamp()
+    last_epoch = entries[-1].timestamp.timestamp()
+
+    aligned_start = first_epoch - (first_epoch % slide_seconds)
+
+    windows: list[WindowMetrics] = []
+    current = aligned_start
+
+    while current <= last_epoch:
+        w_start = datetime.fromtimestamp(current, tz=timezone.utc)
+        w_end = datetime.fromtimestamp(current + window_seconds, tz=timezone.utc)
+
+        lo = bisect.bisect_left(timestamps, w_start)
+        hi = bisect.bisect_left(timestamps, w_end)
+        window_entries = entries[lo:hi]
+
+        metrics = _compute_metrics(window_entries, w_start, w_end, window_seconds, top_n)
+        windows.append(metrics)
+
+        current += slide_seconds
+
+    return windows
+
+
+def _compute_metrics(
+    entries: list[LogEntry],
+    start: datetime,
+    end: datetime,
+    window_seconds: int,
+    top_n: int,
+) -> WindowMetrics:
+    total = len(entries)
+
+    severity_counts = Counter(e.severity.name for e in entries)
+    source_counts = Counter(e.source for e in entries)
+    top_sources = source_counts.most_common(top_n)
+
+    error_count = sum(1 for e in entries if e.severity >= Severity.ERROR)
+    error_rate = (error_count / total * 100) if total > 0 else 0.0
+    eps = total / window_seconds if window_seconds > 0 else 0.0
+
+    return WindowMetrics(
+        start=start,
+        end=end,
+        total_count=total,
+        counts_by_severity=dict(severity_counts),
+        top_sources=top_sources,
+        error_rate=round(error_rate, 2),
+        eps=round(eps, 4),
+    )
diff --git a/src/logpipe/anomaly_detector.py b/src/logpipe/anomaly_detector.py
new file mode 100644
index 0000000..3bf239f
--- /dev/null
+++ b/src/logpipe/anomaly_detector.py
@@ -0,0 +1,97 @@
+from __future__ import annotations
+
+import statistics
+
+from logpipe.models import AnomalyResult, WindowMetrics
+
+
+def detect_anomalies(
+    windows: list[WindowMetrics],
+    baseline_k: int = 20,
+    sensitivity: float = 2.0,
+) -> list[AnomalyResult]:
+    """Detect anomalous windows using a rolling median + IQR baseline.
+
+    The first *baseline_k* windows are used to build the baseline and are never flagged.
+    """
+    anomalies: list[AnomalyResult] = []
+
+    for i, window in enumerate(windows):
+        if i < baseline_k:
+            continue
+
+        recent = [w.total_count for w in windows[i - baseline_k : i]]
+        median, iqr = _compute_median_iqr(recent)
+
+        count = window.total_count
+
+        if iqr > 0:
+            upper = median + sensitivity * iqr
+            lower = median - sensitivity * iqr
+
+            if count > upper:
+                anomalies.append(
+                    AnomalyResult(
+                        window_start=window.start,
+                        window_end=window.end,
+                        event_count=count,
+                        baseline_median=median,
+                        direction="spike",
+                        magnitude=round((count - median) / iqr, 2),
+                    )
+                )
+            elif count < lower:
+                anomalies.append(
+                    AnomalyResult(
+                        window_start=window.start,
+                        window_end=window.end,
+                        event_count=count,
+                        baseline_median=median,
+                        direction="drop",
+                        magnitude=round((median - count) / iqr, 2),
+                    )
+                )
+        else:
+            # IQR == 0: all baseline windows have the same count.
+            # Any deviation from the median is anomalous.
+            if count != median:
+                direction = "spike" if count > median else "drop"
+                anomalies.append(
+                    AnomalyResult(
+                        window_start=window.start,
+                        window_end=window.end,
+                        event_count=count,
+                        baseline_median=median,
+                        direction=direction,
+                        magnitude=abs(count - median),
+                    )
+                )
+
+    return anomalies
+
+
+def _compute_median_iqr(values: list[int | float]) -> tuple[float, float]:
+    """Compute median and interquartile range (IQR) of a list of numbers."""
+    s = sorted(values)
+    n = len(s)
+
+    if n == 0:
+        return 0.0, 0.0
+
+    median = statistics.median(s)
+
+    if n < 4:
+        return median, 0.0
+
+    mid = n // 2
+    if n % 2 == 0:
+        lower = s[:mid]
+        upper = s[mid:]
+    else:
+        lower = s[:mid]
+        upper = s[mid + 1 :]
+
+    q1 = statistics.median(lower) if lower else median
+    q3 = statistics.median(upper) if upper else median
+
+    return median, q3 - q1
