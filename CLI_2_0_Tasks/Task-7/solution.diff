+from __future__ import annotations
+
+import json
+from datetime import timezone
+
+from logpipe.models import LogEntry, Severity, SEVERITY_NAMES
+from logpipe.normalizer import parse_timestamp
+
+
+def parse_json_line(
+    line: str, source: str, default_tz: timezone = timezone.utc
+) -> LogEntry:
+    data = json.loads(line)
+
+    ts_raw = data.get("timestamp")
+    if not ts_raw:
+        raise ValueError("Missing 'timestamp' field")
+
+    timestamp = parse_timestamp(str(ts_raw), default_tz=default_tz)
+    message = str(data.get("message", ""))
+
+    severity_raw = data.get("severity", data.get("level", "INFO"))
+    severity = SEVERITY_NAMES.get(str(severity_raw).upper(), Severity.INFO)
+
+    metadata = {
+        k: v
+        for k, v in data.items()
+        if k not in ("timestamp", "message", "severity", "level")
+    }
+
+    return LogEntry(
+        timestamp=timestamp,
+        severity=severity,
+        source=source,
+        message=message,
+        metadata=metadata,
+    )
