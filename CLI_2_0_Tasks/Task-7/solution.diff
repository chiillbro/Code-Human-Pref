+from datetime import datetime, timezone, timedelta
+from zoneinfo import ZoneInfo
+
+import pytest
+
+from logpipe.normalizer import parse_timestamp, resolve_default_tz, SYSLOG_SEVERITY_MAP
+from logpipe.models import Severity
+
+
+class TestResolveDefaultTz:
+    def test_utc(self):
+        tz = resolve_default_tz("UTC")
+        assert tz == timezone.utc
+
+    def test_named_zone(self):
+        tz = resolve_default_tz("America/New_York")
+        assert isinstance(tz, ZoneInfo)
+
+    def test_unknown_zone_falls_back_to_utc(self):
+        tz = resolve_default_tz("Not/A/Zone")
+        assert tz == timezone.utc
+
+
+class TestParseTimestamp:
+    def test_iso_with_z(self):
+        dt = parse_timestamp("2024-01-15T10:30:00Z")
+        assert dt == datetime(2024, 1, 15, 10, 30, 0, tzinfo=timezone.utc)
+
+    def test_iso_with_offset(self):
+        dt = parse_timestamp("2024-01-15T10:30:00+05:30")
+        expected = datetime(2024, 1, 15, 5, 0, 0, tzinfo=timezone.utc)
+        assert dt == expected
+
+    def test_iso_space_separator(self):
+        dt = parse_timestamp("2024-01-15 10:30:00")
+        assert dt == datetime(2024, 1, 15, 10, 30, 0, tzinfo=timezone.utc)
+
+    def test_iso_fractional_seconds(self):
+        dt = parse_timestamp("2024-01-15T10:30:00.123456Z")
+        assert dt.microsecond == 123456
+        assert dt.tzinfo == timezone.utc
+
+    def test_iso_fractional_with_offset(self):
+        dt = parse_timestamp("2024-01-15T10:30:00.500+00:00")
+        assert dt.microsecond == 500000
+
+    def test_no_timezone_uses_default(self):
+        eastern = ZoneInfo("America/New_York")
+        dt = parse_timestamp("2024-07-15 12:00:00", default_tz=eastern)
+        # July in EDT = UTC-4
+        assert dt.tzinfo == timezone.utc
+        assert dt.hour == 16
+
+    def test_syslog_format(self):
+        dt = parse_timestamp("Jan 15 10:30:00", reference_year=2024)
+        assert dt.month == 1
+        assert dt.day == 15
+        assert dt.hour == 10
+        assert dt.minute == 30
+
+    def test_syslog_single_digit_day(self):
+        dt = parse_timestamp("Jan  5 08:00:00", reference_year=2024)
+        assert dt.day == 5
+
+    def test_syslog_year_inference_future_wraps(self):
+        # Use a month far in the future to trigger year rollback
+        future_month = datetime.now(timezone.utc) + timedelta(days=400)
+        month_str = future_month.strftime("%b")
+        ts = f"{month_str} 15 10:00:00"
+        dt = parse_timestamp(ts)
+        # Should not be >1 day in the future
+        assert dt <= datetime.now(timezone.utc) + timedelta(days=1)
+
+    def test_custom_format(self):
+        dt = parse_timestamp("15/Jan/2024:10:30:00 +0000", fmt="%d/%b/%Y:%H:%M:%S %z")
