+import json
+import os
+import tempfile
+from datetime import datetime, timezone
+
+from logpipe.models import (
+    AnalysisReport,
+    AnomalyResult,
+    FilterSummary,
+    IngestionSummary,
+    WindowMetrics,
+)
+from logpipe.reporter import format_report, load_report, write_report
+
+
+def _sample_report():
+    return AnalysisReport(
+        ingestion=IngestionSummary(
+            files_processed=2,
+            total_entries=100,
+            entries_per_format={"json": 60, "syslog": 40},
+            malformed_lines=3,
+        ),
+        filter_summary=FilterSummary(
+            entries_before=100,
+            entries_after=80,
+            dropped_per_filter={"severity_min": 15, "keyword_exclude": 5},
+        ),
+        windows=[
+            WindowMetrics(
+                start=datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc),
+                end=datetime(2024, 1, 15, 10, 5, tzinfo=timezone.utc),
+                total_count=50,
+                counts_by_severity={"INFO": 40, "ERROR": 10},
+                top_sources=[("host-a", 30), ("host-b", 20)],
+                error_rate=20.0,
+                eps=0.1667,
+            )
+        ],
+        anomalies=[
+            AnomalyResult(
+                window_start=datetime(2024, 1, 15, 10, 0, tzinfo=timezone.utc),
+                window_end=datetime(2024, 1, 15, 10, 5, tzinfo=timezone.utc),
+                event_count=200,
+                baseline_median=50.0,
+                direction="spike",
+                magnitude=3.5,
+            )
+        ],
+        severity_breakdown={"INFO": 60, "ERROR": 20},
+    )
+
+
+class TestWriteAndLoadReport:
+    def test_roundtrip(self):
+        report = _sample_report()
+        with tempfile.NamedTemporaryFile(suffix=".json", delete=False) as f:
+            path = f.name
+        try:
+            write_report(report, path)
+            loaded = load_report(path)
+            assert loaded["ingestion"]["files_processed"] == 2
+            assert loaded["ingestion"]["total_entries"] == 100
+            assert loaded["filter_summary"]["entries_after"] == 80
+            assert len(loaded["windows"]) == 1
+            assert len(loaded["anomalies"]) == 1
+            assert loaded["anomalies"][0]["direction"] == "spike"
+            assert loaded["severity_breakdown"]["INFO"] == 60
+        finally:
+            os.unlink(path)
+
+    def test_json_structure(self):
+        report = _sample_report()
+        with tempfile.NamedTemporaryFile(suffix=".json", delete=False) as f:
+            path = f.name
+        try:
+            write_report(report, path)
+            with open(path) as f:
+                data = json.load(f)
+            assert set(data.keys()) == {
+                "ingestion", "filter_summary", "windows", "anomalies", "severity_breakdown"
+            }
+            assert "top_sources" in data["windows"][0]
+        finally:
+            os.unlink(path)
+
+
+class TestFormatReport:
+    def test_contains_key_info(self):
+        report = _sample_report()
+        text = format_report(report)
+        assert "Files processed" in text
+        assert "100" in text  # total entries
+        assert "Anomalies: 1" in text
+        assert "spike" in text
+
+    def test_severity_breakdown(self):
+        report = _sample_report()
+        text = format_report(report)
+        assert "INFO" in text
+        assert "ERROR" in text
+
+    def test_no_anomalies(self):
+        report = _sample_report()
+        report.anomalies = []
+        text = format_report(report)
+        assert "Anomalies: 0" in text
+        assert "Top Anomalies" not in text
