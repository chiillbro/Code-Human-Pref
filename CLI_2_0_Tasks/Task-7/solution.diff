@@ -0,0 +1,163 @@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from datetime import datetime
+from enum import IntEnum
+from typing import Any
+
+
+class Severity(IntEnum):
+    DEBUG = 0
+    INFO = 1
+    WARNING = 2
+    ERROR = 3
+    CRITICAL = 4
+
+
+SEVERITY_NAMES: dict[str, Severity] = {s.name: s for s in Severity}
+
+
+@dataclass
+class LogEntry:
+    timestamp: datetime
+    severity: Severity
+    source: str
+    message: str
+    metadata: dict[str, Any] = field(default_factory=dict)
+
+
+@dataclass
+class FilterConfig:
+    severity_min: Severity | None = None
+    source_include: list[str] = field(default_factory=list)
+    source_exclude: list[str] = field(default_factory=list)
+    keyword_match: list[str] = field(default_factory=list)
+    keyword_exclude: list[str] = field(default_factory=list)
+    time_range_start: datetime | None = None
+    time_range_end: datetime | None = None
+
+
+@dataclass
+class TransformRule:
+    type: str
+    params: dict[str, Any] = field(default_factory=dict)
+
+
+@dataclass
+class AggregationConfig:
+    window_seconds: int = 300
+    slide_seconds: int = 60
+    top_n: int = 10
+
+
+@dataclass
+class AnomalyConfig:
+    baseline_windows: int = 20
+    sensitivity: float = 2.0
+
+
+@dataclass
+class CustomPattern:
+    name: str
+    pattern: str
+    timestamp_format: str
+
+
+@dataclass
+class PipelineConfig:
+    default_timezone: str = "UTC"
+    filters: FilterConfig = field(default_factory=FilterConfig)
+    transforms: list[TransformRule] = field(default_factory=list)
+    aggregation: AggregationConfig = field(default_factory=AggregationConfig)
+    anomaly: AnomalyConfig = field(default_factory=AnomalyConfig)
+    custom_patterns: list[CustomPattern] = field(default_factory=list)
+
+
+@dataclass
+class WindowMetrics:
+    start: datetime
+    end: datetime
+    total_count: int
+    counts_by_severity: dict[str, int]
+    top_sources: list[tuple[str, int]]
+    error_rate: float
+    eps: float
+
+    def to_dict(self) -> dict:
+        return {
+            "start": self.start.isoformat(),
+            "end": self.end.isoformat(),
+            "total_count": self.total_count,
+            "counts_by_severity": self.counts_by_severity,
+            "top_sources": [{"source": s, "count": c} for s, c in self.top_sources],
+            "error_rate": self.error_rate,
+            "eps": self.eps,
+        }
+
+
+@dataclass
+class AnomalyResult:
+    window_start: datetime
+    window_end: datetime
+    event_count: int
+    baseline_median: float
+    direction: str  # "spike" or "drop"
+    magnitude: float
+
+    def to_dict(self) -> dict:
+        return {
+            "window_start": self.window_start.isoformat(),
+            "window_end": self.window_end.isoformat(),
+            "event_count": self.event_count,
+            "baseline_median": self.baseline_median,
+            "direction": self.direction,
+            "magnitude": round(self.magnitude, 2),
+        }
+
+
+@dataclass
+class IngestionSummary:
+    files_processed: int = 0
+    total_entries: int = 0
+    entries_per_format: dict[str, int] = field(default_factory=dict)
+    malformed_lines: int = 0
+
+    def to_dict(self) -> dict:
+        return {
+            "files_processed": self.files_processed,
+            "total_entries": self.total_entries,
+            "entries_per_format": self.entries_per_format,
+            "malformed_lines": self.malformed_lines,
+        }
+
+
+@dataclass
+class FilterSummary:
+    entries_before: int = 0
+    entries_after: int = 0
+    dropped_per_filter: dict[str, int] = field(default_factory=dict)
+
+    def to_dict(self) -> dict:
+        return {
+            "entries_before": self.entries_before,
+            "entries_after": self.entries_after,
+            "dropped_per_filter": self.dropped_per_filter,
+        }
+
+
+@dataclass
+class AnalysisReport:
+    ingestion: IngestionSummary
+    filter_summary: FilterSummary
+    windows: list[WindowMetrics]
+    anomalies: list[AnomalyResult]
+    severity_breakdown: dict[str, int] = field(default_factory=dict)
+
+    def to_dict(self) -> dict:
+        return {
+            "ingestion": self.ingestion.to_dict(),
+            "filter_summary": self.filter_summary.to_dict(),
+            "windows": [w.to_dict() for w in self.windows],
+            "anomalies": [a.to_dict() for a in self.anomalies],
+            "severity_breakdown": self.severity_breakdown,
+        }
