-    def __init__(self, default_year: Optional[int] = None) -> None:
-        self._year = default_year or datetime.now().year
+    def __init__(
+        self,
+        default_year: Optional[int] = None,
+        reference_date: Optional[date] = None,
+    ) -> None:
+        if reference_date is not None:
+            self._year = reference_date.year
+            self._ref_month = reference_date.month
+        elif default_year is not None:
+            # Explicit year without a reference date: set ref_month=12 so the
+            # rollback logic never fires (preserves backward compatibility).
+            self._year = default_year
+            self._ref_month = 12
+        else:
+            today = date.today()
+            self._year = today.year
+            self._ref_month = today.month
+
+    def _infer_year(self, month: int) -> int:
+        if month > self._ref_month:
+            return self._year - 1
+        return self._year
 
     def parse(self, line: str, source: str) -> Optional[LogEvent]:
         m = _PAT.match(line.rstrip("\n"))
         if not m:
             return None
         try:
-            ts = datetime.strptime(f"{self._year} {m['ts']}", "%Y %b %d %H:%M:%S")
+            # Parse without year first so we can read the month.
+            preliminary = datetime.strptime(m["ts"], "%b %d %H:%M:%S")
+            year = self._infer_year(preliminary.month)
+            ts = preliminary.replace(year=year)
         except ValueError:
             ts = None
 
