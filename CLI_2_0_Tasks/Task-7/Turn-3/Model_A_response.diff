+def starter_config_yaml() -> str:
+    """A fully-commented starter config for ``logpipe config init``.
+
+    Every available filter, transform and analysis setting appears as a
+    commented example with its default; users uncomment what they need.
+    """
+    d = AnalysisConfig()
+    # Convention: lines starting with '## ' are documentation; lines starting
+    # with '# ' are disabled config a user can uncomment by removing '# '.
+    return f"""\
+## logpipe configuration. Every section is optional.
+## Generated by `logpipe config init`. Uncomment the '# ' lines you need.
+
+## -------------------------------------------------------------------------
+## Custom parsers (built-ins jsonl, syslog, clf are always auto-detected).
+## -------------------------------------------------------------------------
+# parsers:
+#   custom:
+#     - name: myapp
+#       ## Named groups recognised: timestamp, level, message, host.
+#       ## Any other named group is stored in event.extra.
+#       pattern: '^(?P<timestamp>\\S+) \\[(?P<level>\\w+)\\] (?P<message>.*)$'
+#       time_format: '%Y-%m-%dT%H:%M:%S'   ## optional; ISO-8601 assumed if omitted
+
+## -------------------------------------------------------------------------
+## Filters: applied in order; an event must pass ALL filters to be kept.
+## -------------------------------------------------------------------------
+# filters:
+#   ## Keep only events at or above this severity.
+#   - type: level
+#     min: WARNING
+#
+#   ## Keep events whose field matches a regex (default field: message).
+#   - type: match
+#     field: message
+#     pattern: 'timeout|refused'
+#
+#   ## Drop events whose field matches a regex.
+#   - type: exclude
+#     field: message
+#     pattern: 'healthcheck'
+#
+#   ## Keep events where a field exactly equals a value.
+#   - type: equals
+#     field: status
+#     value: 500
+#
+#   ## Keep events inside a time range (ISO-8601). Either bound is optional.
+#   - type: time_range
+#     after:  '2026-01-01T00:00:00'
+#     before: '2026-12-31T23:59:59'
+
+## -------------------------------------------------------------------------
+## Transforms: applied in order after filters.
+## -------------------------------------------------------------------------
+# transforms:
+#   ## Set/overwrite a field (core fields or extra).
+#   - type: set
+#     field: env
+#     value: prod
+#
+#   ## Remove a field from event.extra.
+#   - type: drop
+#     field: password
+#
+#   ## Rename an extra field; if `to` is a core field name it is promoted.
+#   - type: rename
+#     field: lvl
+#     to: level
+#
+#   ## Re-derive the canonical level from another field.
+#   - type: normalize_level
+#     field: severity
+
+## -------------------------------------------------------------------------
+## Analysis settings (defaults shown).
+## -------------------------------------------------------------------------
+# analysis:
+#   window_seconds: {d.window_seconds}        ## bucket size for event-rate series
+#   baseline_windows: {d.baseline_windows}      ## trailing windows used as the rolling anomaly baseline
+#   anomaly_sensitivity: {d.anomaly_sensitivity}  ## bounds = median +/- sensitivity * IQR
+#   top_messages: {d.top_messages}          ## how many message signatures to report
+"""
