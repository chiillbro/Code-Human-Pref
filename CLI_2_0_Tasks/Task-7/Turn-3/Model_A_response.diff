+class StarterConfigTests(unittest.TestCase):
+    def test_is_valid_yaml_as_is(self) -> None:
+        # Everything is commented out so it must parse to an empty document.
+        text = starter_config_yaml()
+        self.assertIsNone(yaml.safe_load(text))
+
+    def test_mentions_every_filter_and_transform_type(self) -> None:
+        text = starter_config_yaml()
+        for t in ("level", "match", "exclude", "equals", "time_range"):
+            self.assertIn(f"type: {t}", text)
+        for t in ("set", "drop", "rename", "normalize_level"):
+            self.assertIn(f"type: {t}", text)
+
+    def test_shows_analysis_defaults(self) -> None:
+        text = starter_config_yaml()
+        d = AnalysisConfig()
+        self.assertIn(f"window_seconds: {d.window_seconds}", text)
+        self.assertIn(f"baseline_windows: {d.baseline_windows}", text)
+        self.assertIn(f"anomaly_sensitivity: {d.anomaly_sensitivity}", text)
+        self.assertIn(f"top_messages: {d.top_messages}", text)
+
+    def test_uncommented_template_round_trips_through_loader(self) -> None:
+        # Strip the leading "# " from disabled-config lines (single-hash) and
+        # confirm Config.load accepts the result — guards against the template
+        # drifting from the real schema. '## ' prose lines stay commented.
+        text = starter_config_yaml()
+        uncommented = re.sub(r"(?m)^# ?(?!#)", "", text)
+        with TemporaryDirectory() as d:
+            p = os.path.join(d, "starter.yaml")
+            with open(p, "w") as fh:
+                fh.write(uncommented)
+            cfg = Config.load(p)
+        self.assertEqual(len(cfg.filters), 5)
+        self.assertEqual(len(cfg.transforms), 4)
+        self.assertEqual(len(cfg.custom_parsers), 1)
+        self.assertEqual(cfg.analysis.window_seconds, AnalysisConfig().window_seconds)
+
+
 if __name__ == "__main__":
     unittest.main()
