 Covers the classic ``<PRI>MMM dd HH:MM:SS host proc[pid]: message`` shape and
 the very common variant without the ``<PRI>`` prefix (what you usually see in
-``/var/log/syslog``). The year is not encoded in RFC-3164 so we default to the
-current year.
+``/var/log/syslog``).
+
+RFC-3164 timestamps carry no year, so we infer one relative to a *reference
+date* (default: now). If the log line's month is later than the reference
+month we assume it belongs to the previous year — otherwise a December entry
+read in April would be placed eight months in the future.
 """
 from __future__ import annotations
 
@@ -38,15 +42,22 @@ _PAT = re.compile(
 class SyslogParser(Parser):
     name = "syslog"
 
-    def __init__(self, default_year: Optional[int] = None) -> None:
-        self._year = default_year or datetime.now().year
+    def __init__(self, reference_date: Optional[datetime] = None) -> None:
+        self._ref = reference_date or datetime.now()
+
+    def _infer_year(self, month: int) -> int:
+        # A month later than the reference month almost certainly came from the
+        # previous calendar year (logs do not arrive from the future).
+        return self._ref.year - 1 if month > self._ref.month else self._ref.year
 
     def parse(self, line: str, source: str) -> Optional[LogEvent]:
         m = _PAT.match(line.rstrip("\n"))
         if not m:
             return None
         try:
-            ts = datetime.strptime(f"{self._year} {m['ts']}", "%Y %b %d %H:%M:%S")
+            # Parse without a year first to learn the month, then re-anchor.
+            partial = datetime.strptime(m["ts"], "%b %d %H:%M:%S")
+            ts = partial.replace(year=self._infer_year(partial.month))
         except ValueError:
             ts = None
 
