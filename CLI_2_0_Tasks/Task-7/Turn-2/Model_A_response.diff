@@ -0,0 +1,57 @@
+"""Config.load() must fail fast on a bad explicit path."""
+from __future__ import annotations
+
+import os
+import unittest
+from tempfile import TemporaryDirectory
+
+from logpipe.config import Config, ConfigError
+
+
+class ConfigLoadTests(unittest.TestCase):
+    def test_none_path_returns_defaults(self) -> None:
+        cfg = Config.load(None)
+        self.assertEqual(cfg.filters, [])
+        self.assertEqual(cfg.analysis.baseline_windows, 20)
+
+    def test_missing_file_raises(self) -> None:
+        with self.assertRaises(ConfigError):
+            Config.load("/nonexistent/path/typo.yaml")
+
+    def test_invalid_yaml_raises(self) -> None:
+        with TemporaryDirectory() as d:
+            p = os.path.join(d, "bad.yaml")
+            with open(p, "w") as fh:
+                fh.write("filters: [unclosed\n")
+            with self.assertRaises(ConfigError):
+                Config.load(p)
+
+    def test_non_mapping_top_level_raises(self) -> None:
+        with TemporaryDirectory() as d:
+            p = os.path.join(d, "list.yaml")
+            with open(p, "w") as fh:
+                fh.write("- a\n- b\n")
+            with self.assertRaises(ConfigError):
+                Config.load(p)
+
+    def test_valid_file_loads(self) -> None:
+        with TemporaryDirectory() as d:
+            p = os.path.join(d, "ok.yaml")
+            with open(p, "w") as fh:
+                fh.write(
+                    "filters:\n"
+                    "  - {type: level, min: WARNING}\n"
+                    "analysis:\n"
+                    "  window_seconds: 30\n"
+                    "  baseline_windows: 8\n"
+                    "  anomaly_sensitivity: 2.0\n"
+                )
+            cfg = Config.load(p)
+        self.assertEqual(len(cfg.filters), 1)
+        self.assertEqual(cfg.analysis.window_seconds, 30)
+        self.assertEqual(cfg.analysis.baseline_windows, 8)
+        self.assertEqual(cfg.analysis.anomaly_sensitivity, 2.0)
+
+
+if __name__ == "__main__":
+    unittest.main()
