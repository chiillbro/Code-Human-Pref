+"""Unit tests for each parser in isolation."""
+from __future__ import annotations
+
+import unittest
+from datetime import datetime, timezone
+
+from logpipe.parsers import CLFParser, JSONLinesParser, RegexParser, SyslogParser
+
+
+class JSONLinesTests(unittest.TestCase):
+    def setUp(self) -> None:
+        self.p = JSONLinesParser()
+
+    def test_full_event(self) -> None:
+        ev = self.p.parse(
+            '{"timestamp": "2026-04-19T10:00:00Z", "level": "error", '
+            '"message": "boom", "host": "web1", "request_id": "abc"}',
+            "src",
+        )
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.message, "boom")
+        self.assertEqual(ev.host, "web1")
+        self.assertEqual(ev.extra["request_id"], "abc")
+        self.assertEqual(ev.timestamp, datetime(2026, 4, 19, 10, 0, 0, tzinfo=timezone.utc))
+
+    def test_missing_fields_fall_back_gracefully(self) -> None:
+        # No level, no message, no timestamp — still produces an event.
+        ev = self.p.parse('{"foo": 1, "bar": 2}', "src")
+        assert ev is not None
+        self.assertIsNone(ev.level)
+        self.assertIsNone(ev.timestamp)
+        # message falls back to the raw line so the event is still useful
+        self.assertIn("foo", ev.message)
+        self.assertEqual(ev.extra, {"foo": 1, "bar": 2})
+
+    def test_epoch_seconds_and_milliseconds(self) -> None:
+        ev_s = self.p.parse('{"ts": 1745056800, "msg": "x"}', "src")
+        ev_ms = self.p.parse('{"ts": 1745056800000, "msg": "x"}', "src")
+        assert ev_s is not None and ev_ms is not None
+        self.assertIsNotNone(ev_s.timestamp)
+        # both should resolve to the same instant
+        self.assertEqual(ev_s.timestamp, ev_ms.timestamp)
+
+    def test_level_aliases(self) -> None:
+        ev = self.p.parse('{"severity": "WARN", "msg": "x"}', "src")
+        assert ev is not None
+        self.assertEqual(ev.level, "WARNING")
+
+    def test_non_dict_json_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("[1, 2, 3]", "src"))
+
+    def test_malformed_json_rejected(self) -> None:
+        self.assertIsNone(self.p.parse('{"broken": ', "src"))
+        self.assertIsNone(self.p.parse("plain text", "src"))
+
+
+class SyslogTests(unittest.TestCase):
+    def setUp(self) -> None:
+        self.p = SyslogParser(default_year=2026)
+
+    def test_with_pri_maps_severity(self) -> None:
+        # PRI 11 = facility 1, severity 3 (ERROR)
+        ev = self.p.parse("<11>Apr 19 10:01:02 web1 app[77]: boom", "src")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.host, "web1")
+        self.assertEqual(ev.extra["process"], "app")
+        self.assertEqual(ev.extra["pid"], 77)
+        self.assertEqual(ev.extra["facility"], 1)
+        self.assertEqual(ev.timestamp, datetime(2026, 4, 19, 10, 1, 2))
+
+    def test_without_pri(self) -> None:
+        ev = self.p.parse("Apr  5 03:04:05 db1 cron[9]: job ran", "src")
+        assert ev is not None
+        self.assertIsNone(ev.level)  # no PRI -> no derived level
+        self.assertEqual(ev.host, "db1")
+        self.assertEqual(ev.extra["pid"], 9)
+        self.assertNotIn("facility", ev.extra)
+
+    def test_without_pid(self) -> None:
+        ev = self.p.parse("Apr 19 10:00:30 web1 kernel: oom-killer invoked", "src")
+        assert ev is not None
+        self.assertEqual(ev.extra["process"], "kernel")
+        self.assertNotIn("pid", ev.extra)
+
+    def test_malformed_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("not a syslog line at all", "src"))
+
+
+class CLFTests(unittest.TestCase):
+    def setUp(self) -> None:
+        self.p = CLFParser()
+
+    def test_common_variant(self) -> None:
+        line = '127.0.0.1 - - [19/Apr/2026:10:00:00 +0000] "GET / HTTP/1.1" 200 512'
+        ev = self.p.parse(line, "src")
+        assert ev is not None
+        self.assertEqual(ev.level, "INFO")
+        self.assertEqual(ev.extra["status"], 200)
+        self.assertEqual(ev.extra["bytes"], 512)
+        self.assertNotIn("user_agent", ev.extra)
+
+    def test_combined_variant(self) -> None:
+        line = (
+            '10.0.0.5 - bob [19/Apr/2026:10:00:20 +0000] '
+            '"POST /api HTTP/1.1" 500 128 "https://ref" "curl/8"'
+        )
+        ev = self.p.parse(line, "src")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.extra["referer"], "https://ref")
+        self.assertEqual(ev.extra["user_agent"], "curl/8")
+
+    def test_status_level_mapping(self) -> None:
+        for status, want in [(200, "INFO"), (302, "INFO"), (404, "WARNING"), (503, "ERROR")]:
+            line = f'1.1.1.1 - - [19/Apr/2026:10:00:00 +0000] "GET /x HTTP/1.1" {status} -'
+            ev = self.p.parse(line, "src")
+            assert ev is not None
+            self.assertEqual(ev.level, want, f"status {status}")
+
+    def test_dash_bytes(self) -> None:
+        line = '1.1.1.1 - - [19/Apr/2026:10:00:00 +0000] "GET /x HTTP/1.1" 304 -'
+        ev = self.p.parse(line, "src")
+        assert ev is not None
+        self.assertEqual(ev.extra["bytes"], 0)
+
+    def test_malformed_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("nonsense", "src"))
+
+
+class RegexParserTests(unittest.TestCase):
+    def test_all_named_groups(self) -> None:
+        p = RegexParser(
+            "myapp",
+            r"^(?P<timestamp>\S+) \[(?P<level>\w+)\] (?P<host>\S+) (?P<message>.*)$",
+            time_format="%Y-%m-%dT%H:%M:%S",
+        )
+        ev = p.parse("2026-04-19T10:00:00 [WARN] web1 disk full", "src")
+        assert ev is not None
+        self.assertEqual(ev.level, "WARNING")
+        self.assertEqual(ev.host, "web1")
+        self.assertEqual(ev.message, "disk full")
+        self.assertEqual(ev.timestamp, datetime(2026, 4, 19, 10, 0, 0))
+
+    def test_missing_optional_groups(self) -> None:
+        # Pattern only captures message + an extra field; ts/level/host absent.
+        p = RegexParser("simple", r"^(?P<module>\w+): (?P<message>.*)$")
+        ev = p.parse("auth: login ok", "src")
+        assert ev is not None
+        self.assertIsNone(ev.timestamp)
+        self.assertIsNone(ev.level)
+        self.assertIsNone(ev.host)
+        self.assertEqual(ev.message, "login ok")
+        self.assertEqual(ev.extra["module"], "auth")
+
+    def test_unparseable_timestamp_is_non_fatal(self) -> None:
+        p = RegexParser(
+            "x",
+            r"^(?P<timestamp>\S+) (?P<message>.*)$",
+            time_format="%Y-%m-%d",
+        )
+        ev = p.parse("not-a-date hello", "src")
+        assert ev is not None
+        self.assertIsNone(ev.timestamp)
+        self.assertEqual(ev.message, "hello")
+
+    def test_no_match_returns_none(self) -> None:
+        p = RegexParser("x", r"^FIXED PREFIX (?P<message>.*)$")
+        self.assertIsNone(p.parse("other prefix oops", "src"))
+
+
+if __name__ == "__main__":
+    unittest.main()
