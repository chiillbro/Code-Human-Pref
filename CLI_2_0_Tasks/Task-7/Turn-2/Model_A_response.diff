diff --git a/tests/test_analysis.py b/tests/test_analysis.py
new file mode 100644
index 0000000..c137056
--- /dev/null
+++ b/tests/test_analysis.py
@@ -0,0 +1,115 @@
+"""Unit tests for windowed aggregation and rolling median+IQR anomaly detection."""
+from __future__ import annotations
+
+import unittest
+from datetime import datetime
+
+from logpipe.analysis import Analyzer, _floor
+from logpipe.config import AnalysisConfig
+from logpipe.event import LogEvent
+
+
+def _ev(ts: datetime, level: str = "INFO") -> LogEvent:
+    return LogEvent(timestamp=ts, level=level, message="x", source="s", raw="x")
+
+
+def _feed_series(an: Analyzer, counts: list[int], start: datetime) -> None:
+    """Feed *counts[i]* events into minute *i* starting at *start*."""
+    for minute, n in enumerate(counts):
+        ts = start.replace(minute=start.minute + minute)
+        for _ in range(n):
+            an.feed(_ev(ts))
+
+
+class WindowingTests(unittest.TestCase):
+    def test_floor_exact_boundary(self) -> None:
+        # 10:01:00 with 60s windows is exactly the start of its own bucket.
+        self.assertEqual(_floor(datetime(2026, 4, 19, 10, 1, 0), 60),
+                         datetime(2026, 4, 19, 10, 1, 0))
+        # 10:00:59 belongs to the 10:00:00 bucket.
+        self.assertEqual(_floor(datetime(2026, 4, 19, 10, 0, 59), 60),
+                         datetime(2026, 4, 19, 10, 0, 0))
+
+    def test_event_on_boundary_lands_in_own_bucket(self) -> None:
+        an = Analyzer(AnalysisConfig(window_seconds=60))
+        an.feed(_ev(datetime(2026, 4, 19, 10, 0, 59)))
+        an.feed(_ev(datetime(2026, 4, 19, 10, 1, 0)))   # boundary
+        an.feed(_ev(datetime(2026, 4, 19, 10, 1, 30)))
+        res = an.result()
+        self.assertEqual(res.windows[datetime(2026, 4, 19, 10, 0, 0)], 1)
+        self.assertEqual(res.windows[datetime(2026, 4, 19, 10, 1, 0)], 2)
+
+    def test_gap_filling_inserts_zero_windows(self) -> None:
+        an = Analyzer(AnalysisConfig(window_seconds=60))
+        an.feed(_ev(datetime(2026, 4, 19, 10, 0, 0)))
+        an.feed(_ev(datetime(2026, 4, 19, 10, 3, 0)))
+        res = an.result()
+        self.assertEqual(res.windows[datetime(2026, 4, 19, 10, 1, 0)], 0)
+        self.assertEqual(res.windows[datetime(2026, 4, 19, 10, 2, 0)], 0)
+
+
+class AnomalyTests(unittest.TestCase):
+    BASE = datetime(2026, 4, 19, 10, 0, 0)
+
+    def _analyzer(self, k: int = 5, sens: float = 1.5) -> Analyzer:
+        return Analyzer(
+            AnalysisConfig(window_seconds=60, baseline_windows=k, anomaly_sensitivity=sens)
+        )
+
+    def test_no_flags_without_enough_history(self) -> None:
+        an = self._analyzer(k=5)
+        _feed_series(an, [3, 4, 100, 2, 5], self.BASE)  # only 5 windows == K
+        self.assertEqual(an.result().anomalies, [])
+
+    def test_spike_flagged(self) -> None:
+        an = self._analyzer(k=5)
+        # baseline ~10, then a 100 spike
+        _feed_series(an, [10, 11, 9, 10, 12, 100], self.BASE)
+        res = an.result()
+        self.assertEqual(len(res.anomalies), 1)
+        a = res.anomalies[0]
+        self.assertEqual(a.kind, "spike")
+        self.assertEqual(a.count, 100)
+        self.assertEqual(a.window_start, datetime(2026, 4, 19, 10, 5, 0))
+        self.assertAlmostEqual(a.baseline, 10.0, places=3)
+
+    def test_drop_flagged(self) -> None:
+        an = self._analyzer(k=5)
+        _feed_series(an, [20, 22, 19, 21, 20, 1], self.BASE)
+        res = an.result()
+        self.assertEqual(len(res.anomalies), 1)
+        self.assertEqual(res.anomalies[0].kind, "drop")
+        self.assertEqual(res.anomalies[0].count, 1)
+
+    def test_within_bounds_not_flagged(self) -> None:
+        an = self._analyzer(k=5, sens=1.5)
+        # baseline 8-12 (median 10, IQR 2, bounds 7..13); next value 12 is inside.
+        _feed_series(an, [8, 12, 10, 9, 11, 12], self.BASE)
+        self.assertEqual(an.result().anomalies, [])
+
+    def test_constant_baseline_no_false_positive(self) -> None:
+        an = self._analyzer(k=5)
+        _feed_series(an, [7, 7, 7, 7, 7, 7, 7, 7], self.BASE)
+        self.assertEqual(an.result().anomalies, [])
+
+    def test_constant_baseline_then_change_flags(self) -> None:
+        # IQR is zero so bounds collapse to the median; any deviation is a flag.
+        an = self._analyzer(k=5)
+        _feed_series(an, [7, 7, 7, 7, 7, 8], self.BASE)
+        res = an.result()
+        self.assertEqual(len(res.anomalies), 1)
+        self.assertEqual(res.anomalies[0].kind, "spike")
+
+    def test_spike_in_history_does_not_mask_next_spike(self) -> None:
+        # This is the case mean+stdev got wrong: one earlier spike shouldn't
+        # stretch the bounds enough to hide a second spike, because median/IQR
+        # are robust to a single outlier in the trailing window.
+        an = self._analyzer(k=6, sens=1.5)
+        _feed_series(an, [10, 10, 10, 100, 10, 10, 80], self.BASE)
+        res = an.result()
+        kinds = [(a.window_start.minute, a.kind) for a in res.anomalies]
+        self.assertIn((6, "spike"), kinds)
+
+
+if __name__ == "__main__":
+    unittest.main()
