+"""Integration test: drive the real CLI entry point against temp files and
+assert on the JSON report it writes."""
+from __future__ import annotations
+
+import json
+import os
+import unittest
+from datetime import datetime, timedelta
+from tempfile import TemporaryDirectory
+
+from logpipe.cli import main
+
+
+def _write_jsonl(path: str, *, baseline: int, spike: int, k: int) -> None:
+    """K windows of *baseline* events/min, then one window of *spike* events."""
+    base = datetime(2026, 4, 19, 10, 0, 0)
+    with open(path, "w") as fh:
+        for minute in range(k):
+            for i in range(baseline):
+                ts = (base + timedelta(minutes=minute, seconds=i)).isoformat() + "Z"
+                fh.write(json.dumps({"ts": ts, "level": "info", "msg": f"req {i}"}) + "\n")
+        for i in range(spike):
+            ts = (base + timedelta(minutes=k, seconds=0)).isoformat() + "Z"
+            fh.write(json.dumps({"ts": ts, "level": "error", "msg": "db timeout"}) + "\n")
+        fh.write("CORRUPT LINE\n")
+
+
+def _write_syslog(path: str) -> None:
+    with open(path, "w") as fh:
+        fh.write("Apr 19 10:00:01 web1 sshd[42]: Accepted publickey\n")
+        fh.write("<11>Apr 19 10:00:30 web1 app[7]: connection refused\n")
+
+
+class AnalyzeCLITests(unittest.TestCase):
+    def test_analyze_writes_valid_json_report(self) -> None:
+        with TemporaryDirectory() as d:
+            jl = os.path.join(d, "app.jsonl")
+            sl = os.path.join(d, "sys.log")
+            cfg = os.path.join(d, "cfg.yaml")
+            out = os.path.join(d, "report.json")
+            _write_jsonl(jl, baseline=10, spike=80, k=6)
+            _write_syslog(sl)
+            with open(cfg, "w") as fh:
+                fh.write(
+                    "analysis:\n"
+                    "  window_seconds: 60\n"
+                    "  baseline_windows: 5\n"
+                    "  anomaly_sensitivity: 1.5\n"
+                )
+
+            rc = main(["analyze", jl, sl, "-c", cfg, "-o", out, "-f", "json"])
+            self.assertEqual(rc, 0)
+            with open(out) as fh:
+                report = json.load(fh)
+
+        ing = report["ingest"]
+        an = report["analysis"]
+
+        self.assertEqual(ing["parsers_used"][jl], "jsonl")
+        self.assertEqual(ing["parsers_used"][sl], "syslog")
+        self.assertGreaterEqual(ing["lines_malformed"], 1)
+        self.assertEqual(len(ing["files_ok"]), 2)
+
+        self.assertGreater(an["total_events"], 0)
+        self.assertIn("ERROR", an["by_level"])
+        self.assertGreaterEqual(len(an["rate_per_window"]), 7)
+
+        spikes = [a for a in an["anomalies"] if a["kind"] == "spike"]
+        self.assertEqual(len(spikes), 1)
+        self.assertEqual(spikes[0]["count"], 80)
+        self.assertIn("baseline", spikes[0])
+
+    def test_missing_config_exits_nonzero(self) -> None:
+        with TemporaryDirectory() as d:
+            jl = os.path.join(d, "app.jsonl")
+            _write_jsonl(jl, baseline=2, spike=2, k=2)
+            rc = main(["analyze", jl, "-c", os.path.join(d, "typo.yaml"), "-f", "json"])
+        self.assertEqual(rc, 2)
+
+
+if __name__ == "__main__":
+    unittest.main()
