@@ -0,0 +1,123 @@
+"""Unit tests for filter and transform builders."""
+from __future__ import annotations
+
+import unittest
+from datetime import datetime
+
+from logpipe.event import LogEvent
+from logpipe.filters import apply_pipeline, build_filters, build_transforms
+
+
+def _ev(level=None, message="hello", ts=None, **extra) -> LogEvent:
+    return LogEvent(
+        timestamp=ts,
+        level=level,
+        message=message,
+        source="test",
+        raw=message,
+        extra=dict(extra),
+    )
+
+
+class FilterTests(unittest.TestCase):
+    def test_level_floor(self) -> None:
+        [f] = build_filters([{"type": "level", "min": "WARNING"}])
+        self.assertTrue(f(_ev(level="ERROR")))
+        self.assertTrue(f(_ev(level="WARNING")))
+        self.assertFalse(f(_ev(level="INFO")))
+        # unlevelled events drop when a floor is set
+        self.assertFalse(f(_ev(level=None)))
+
+    def test_level_floor_unset_keeps_unlevelled(self) -> None:
+        [f] = build_filters([{"type": "level", "min": None}])
+        self.assertTrue(f(_ev(level=None)))
+
+    def test_match_on_default_field(self) -> None:
+        [f] = build_filters([{"type": "match", "pattern": "timeout"}])
+        self.assertTrue(f(_ev(message="db timeout after 5s")))
+        self.assertFalse(f(_ev(message="all good")))
+
+    def test_match_on_extra_field(self) -> None:
+        [f] = build_filters([{"type": "match", "field": "request", "pattern": "POST"}])
+        self.assertTrue(f(_ev(request="POST /api")))
+        self.assertFalse(f(_ev(request="GET /")))
+        self.assertFalse(f(_ev()))  # field absent
+
+    def test_exclude(self) -> None:
+        [f] = build_filters([{"type": "exclude", "pattern": "healthcheck"}])
+        self.assertFalse(f(_ev(message="GET /healthcheck")))
+        self.assertTrue(f(_ev(message="GET /api")))
+
+    def test_equals(self) -> None:
+        [f] = build_filters([{"type": "equals", "field": "status", "value": 500}])
+        self.assertTrue(f(_ev(status=500)))
+        self.assertFalse(f(_ev(status=200)))
+
+    def test_time_range(self) -> None:
+        [f] = build_filters(
+            [{"type": "time_range", "after": "2026-04-19T10:00:00", "before": "2026-04-19T11:00:00"}]
+        )
+        self.assertTrue(f(_ev(ts=datetime(2026, 4, 19, 10, 30))))
+        self.assertFalse(f(_ev(ts=datetime(2026, 4, 19, 9, 0))))
+        self.assertFalse(f(_ev(ts=datetime(2026, 4, 19, 12, 0))))
+        # timestamp-less events pass through (can't judge them)
+        self.assertTrue(f(_ev(ts=None)))
+
+    def test_unknown_filter_type_skipped(self) -> None:
+        # Should warn (to stderr) and produce no predicate, not crash.
+        out = build_filters([{"type": "nope"}])
+        self.assertEqual(out, [])
+
+    def test_combined_chain(self) -> None:
+        fs = build_filters(
+            [
+                {"type": "level", "min": "INFO"},
+                {"type": "exclude", "pattern": "noise"},
+                {"type": "match", "pattern": "db"},
+            ]
+        )
+        keep = _ev(level="ERROR", message="db down")
+        drop_level = _ev(level="DEBUG", message="db down")
+        drop_excl = _ev(level="ERROR", message="db noise")
+        drop_match = _ev(level="ERROR", message="something else")
+        self.assertIsNotNone(apply_pipeline(keep, fs, []))
+        self.assertIsNone(apply_pipeline(drop_level, fs, []))
+        self.assertIsNone(apply_pipeline(drop_excl, fs, []))
+        self.assertIsNone(apply_pipeline(drop_match, fs, []))
+
+
+class TransformTests(unittest.TestCase):
+    def test_set(self) -> None:
+        [t] = build_transforms([{"type": "set", "field": "env", "value": "prod"}])
+        ev = t(_ev())
+        self.assertEqual(ev.extra["env"], "prod")
+
+    def test_set_core_field(self) -> None:
+        [t] = build_transforms([{"type": "set", "field": "level", "value": "ERROR"}])
+        ev = t(_ev(level="INFO"))
+        self.assertEqual(ev.level, "ERROR")
+
+    def test_drop(self) -> None:
+        [t] = build_transforms([{"type": "drop", "field": "password"}])
+        ev = t(_ev(password="hunter2", keep="yes"))
+        self.assertNotIn("password", ev.extra)
+        self.assertIn("keep", ev.extra)
+
+    def test_rename(self) -> None:
+        [t] = build_transforms([{"type": "rename", "field": "msg", "to": "message"}])
+        ev = t(_ev(msg="renamed"))
+        self.assertEqual(ev.message, "renamed")
+        self.assertNotIn("msg", ev.extra)
+
+    def test_normalize_level(self) -> None:
+        [t] = build_transforms([{"type": "normalize_level", "field": "lvl"}])
+        ev = t(_ev(level=None, lvl="warn"))
+        self.assertEqual(ev.level, "WARNING")
+
+    def test_unknown_transform_skipped(self) -> None:
+        out = build_transforms([{"type": "nope"}])
+        self.assertEqual(out, [])
+
+
+if __name__ == "__main__":
+    unittest.main()
