@@ -0,0 +1,198 @@
+"""Unit tests for every filter and transform type, plus combined pipelines."""
+from __future__ import annotations
+
+import unittest
+from datetime import datetime
+
+from logpipe.event import LogEvent
+from logpipe.filters import build_filters, build_transforms, apply_pipeline
+
+
+def _ev(
+    level: str | None = "INFO",
+    message: str = "ok",
+    ts: datetime | None = datetime(2026, 4, 19, 10, 0, 0),
+    **extra,
+) -> LogEvent:
+    return LogEvent(
+        timestamp=ts,
+        level=level,
+        message=message,
+        source="test",
+        raw=message,
+        extra=dict(extra),
+    )
+
+
+class TestLevelFilter(unittest.TestCase):
+    def test_min_level(self) -> None:
+        [f] = build_filters([{"type": "level", "min": "WARNING"}])
+        self.assertFalse(f(_ev(level="INFO")))
+        self.assertFalse(f(_ev(level="DEBUG")))
+        self.assertTrue(f(_ev(level="WARNING")))
+        self.assertTrue(f(_ev(level="ERROR")))
+        self.assertTrue(f(_ev(level="CRITICAL")))
+
+    def test_no_level_rejected_when_floor_set(self) -> None:
+        [f] = build_filters([{"type": "level", "min": "INFO"}])
+        self.assertFalse(f(_ev(level=None)))
+
+    def test_no_level_accepted_when_no_floor(self) -> None:
+        """If min is missing / invalid, everything passes (floor is 0)."""
+        [f] = build_filters([{"type": "level", "min": "banana"}])
+        self.assertTrue(f(_ev(level=None)))
+
+    def test_aliases_normalised(self) -> None:
+        [f] = build_filters([{"type": "level", "min": "warn"}])
+        self.assertTrue(f(_ev(level="ERROR")))
+
+
+class TestMatchFilter(unittest.TestCase):
+    def test_match_include(self) -> None:
+        [f] = build_filters([{"type": "match", "field": "message", "pattern": "timeout"}])
+        self.assertTrue(f(_ev(message="got a timeout")))
+        self.assertFalse(f(_ev(message="all good")))
+
+    def test_default_field_is_message(self) -> None:
+        [f] = build_filters([{"type": "match", "pattern": "X"}])
+        self.assertTrue(f(_ev(message="has X inside")))
+
+    def test_match_on_extra_field(self) -> None:
+        [f] = build_filters([{"type": "match", "field": "request_id", "pattern": "abc"}])
+        self.assertTrue(f(_ev(request_id="abc-123")))
+        self.assertFalse(f(_ev(request_id="xyz")))
+
+    def test_match_on_absent_field(self) -> None:
+        [f] = build_filters([{"type": "match", "field": "nope", "pattern": "x"}])
+        self.assertFalse(f(_ev()))
+
+
+class TestExcludeFilter(unittest.TestCase):
+    def test_exclude(self) -> None:
+        [f] = build_filters([{"type": "exclude", "field": "message", "pattern": "health"}])
+        self.assertFalse(f(_ev(message="healthcheck")))
+        self.assertTrue(f(_ev(message="real error")))
+
+
+class TestEqualsFilter(unittest.TestCase):
+    def test_equals(self) -> None:
+        [f] = build_filters([{"type": "equals", "field": "host", "value": "web1"}])
+        ev_yes = _ev()
+        ev_yes.host = "web1"
+        ev_no = _ev()
+        ev_no.host = "web2"
+        self.assertTrue(f(ev_yes))
+        self.assertFalse(f(ev_no))
+
+
+class TestTimeRangeFilter(unittest.TestCase):
+    def test_after(self) -> None:
+        [f] = build_filters([{"type": "time_range", "after": "2026-04-19T10:00:00"}])
+        self.assertTrue(f(_ev(ts=datetime(2026, 4, 19, 10, 0, 0))))
+        self.assertFalse(f(_ev(ts=datetime(2026, 4, 19, 9, 59, 59))))
+
+    def test_before(self) -> None:
+        [f] = build_filters([{"type": "time_range", "before": "2026-04-19T11:00:00"}])
+        self.assertTrue(f(_ev(ts=datetime(2026, 4, 19, 10, 0, 0))))
+        self.assertFalse(f(_ev(ts=datetime(2026, 4, 19, 12, 0, 0))))
+
+    def test_no_timestamp_passes(self) -> None:
+        [f] = build_filters([{"type": "time_range", "after": "2026-01-01T00:00:00"}])
+        self.assertTrue(f(_ev(ts=None)))
+
+    def test_combined_range(self) -> None:
+        [f] = build_filters([{"type": "time_range",
+                              "after": "2026-04-19T09:00:00",
+                              "before": "2026-04-19T11:00:00"}])
+        self.assertTrue(f(_ev(ts=datetime(2026, 4, 19, 10, 0, 0))))
+        self.assertFalse(f(_ev(ts=datetime(2026, 4, 19, 8, 0, 0))))
+        self.assertFalse(f(_ev(ts=datetime(2026, 4, 19, 12, 0, 0))))
+
+
+class TestCombinedFilters(unittest.TestCase):
+    def test_all_must_pass(self) -> None:
+        filters = build_filters([
+            {"type": "level", "min": "WARNING"},
+            {"type": "match", "pattern": "timeout"},
+        ])
+        # matches both: WARNING + contains timeout
+        ev = _ev(level="ERROR", message="timeout after 5s")
+        result = apply_pipeline(ev, filters, [])
+        self.assertIsNotNone(result)
+        # fails level
+        ev2 = _ev(level="INFO", message="timeout")
+        self.assertIsNone(apply_pipeline(ev2, filters, []))
+        # fails match
+        ev3 = _ev(level="ERROR", message="disk full")
+        self.assertIsNone(apply_pipeline(ev3, filters, []))
+
+
+class TestUnknownFilterWarns(unittest.TestCase):
+    def test_unknown_type_skipped(self) -> None:
+        filters = build_filters([{"type": "nonexistent_type"}])
+        self.assertEqual(len(filters), 0)
+
+
+class TestBadFilterSpec(unittest.TestCase):
+    def test_bad_regex_skipped(self) -> None:
+        filters = build_filters([{"type": "match", "pattern": "[invalid"}])
+        self.assertEqual(len(filters), 0)
+
+
+# ---- transforms -----------------------------------------------------------
+
+
+class TestSetTransform(unittest.TestCase):
+    def test_set_extra(self) -> None:
+        [t] = build_transforms([{"type": "set", "field": "env", "value": "prod"}])
+        ev = t(_ev())
+        self.assertEqual(ev.extra["env"], "prod")
+
+    def test_set_core_field(self) -> None:
+        [t] = build_transforms([{"type": "set", "field": "host", "value": "overridden"}])
+        ev = t(_ev())
+        self.assertEqual(ev.host, "overridden")
+
+
+class TestDropTransform(unittest.TestCase):
+    def test_drop(self) -> None:
+        [t] = build_transforms([{"type": "drop", "field": "secret"}])
+        ev = _ev(secret="password123")
+        ev = t(ev)
+        self.assertNotIn("secret", ev.extra)
+
+    def test_drop_absent_is_noop(self) -> None:
+        [t] = build_transforms([{"type": "drop", "field": "nope"}])
+        ev = _ev()
+        t(ev)  # must not raise
+
+
+class TestRenameTransform(unittest.TestCase):
+    def test_rename(self) -> None:
+        [t] = build_transforms([{"type": "rename", "field": "old_name", "to": "new_name"}])
+        ev = _ev(old_name="value")
+        ev = t(ev)
+        self.assertEqual(ev.extra["new_name"], "value")
+        self.assertNotIn("old_name", ev.extra)
+
+
+class TestCombinedPipeline(unittest.TestCase):
+    def test_filter_then_transform(self) -> None:
+        filters = build_filters([{"type": "level", "min": "WARNING"}])
+        transforms = build_transforms([{"type": "set", "field": "flagged", "value": True}])
+        ev = _ev(level="ERROR")
+        out = apply_pipeline(ev, filters, transforms)
+        self.assertIsNotNone(out)
+        self.assertTrue(out.extra["flagged"])
+
+    def test_filtered_out_never_transformed(self) -> None:
+        filters = build_filters([{"type": "level", "min": "ERROR"}])
+        transforms = build_transforms([{"type": "set", "field": "tag", "value": "x"}])
+        ev = _ev(level="INFO")
+        out = apply_pipeline(ev, filters, transforms)
+        self.assertIsNone(out)
+        self.assertNotIn("tag", ev.extra)  # transform never ran
+
+
+if __name__ == "__main__":
+    unittest.main()
