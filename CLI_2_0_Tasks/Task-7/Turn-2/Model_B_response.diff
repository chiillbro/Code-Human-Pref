+"""Integration test: create temp log files, run ``logpipe analyze``, verify JSON report."""
+from __future__ import annotations
+
+import json
+import os
+import textwrap
+import unittest
+from tempfile import TemporaryDirectory
+
+from logpipe.cli import main
+from logpipe.config import ConfigError
+
+
+class TestAnalyzeIntegration(unittest.TestCase):
+    """Run the full ``logpipe analyze`` CLI against real temp files."""
+
+    def setUp(self) -> None:
+        self.tmpdir = TemporaryDirectory()
+        d = self.tmpdir.name
+
+        # JSONL file with a mix of levels and one malformed line
+        self.jsonl = os.path.join(d, "app.jsonl")
+        lines = []
+        for i in range(10):
+            lines.append(json.dumps({
+                "ts": f"2026-04-19T10:{i:02d}:00Z",
+                "level": "info",
+                "msg": f"request {i}",
+            }))
+        lines.append(json.dumps({
+            "ts": "2026-04-19T10:10:00Z",
+            "level": "error",
+            "msg": "timeout",
+        }))
+        lines.append("NOT JSON")
+        with open(self.jsonl, "w") as f:
+            f.write("\n".join(lines) + "\n")
+
+        # Syslog file
+        self.syslog = os.path.join(d, "sys.log")
+        with open(self.syslog, "w") as f:
+            f.write(textwrap.dedent("""\
+                Apr 19 10:00:01 web1 sshd[42]: login ok
+                Apr 19 10:00:30 web1 app[7]: processing
+                <11>Apr 19 10:01:02 web1 app[7]: db refused
+            """))
+
+        # CLF file
+        self.clf = os.path.join(d, "access.log")
+        with open(self.clf, "w") as f:
+            f.write(textwrap.dedent("""\
+                127.0.0.1 - - [19/Apr/2026:10:00:00 +0000] "GET / HTTP/1.1" 200 512
+                127.0.0.1 - - [19/Apr/2026:10:00:10 +0000] "GET /fail HTTP/1.1" 500 0
+            """))
+
+        self.report_path = os.path.join(d, "report.json")
+
+    def tearDown(self) -> None:
+        self.tmpdir.cleanup()
+
+    def test_analyze_produces_valid_json_report(self) -> None:
+        rc = main([
+            "analyze",
+            self.jsonl, self.syslog, self.clf,
+            "-o", self.report_path,
+            "-f", "json",
+        ])
+        self.assertEqual(rc, 0)
+        with open(self.report_path) as f:
+            report = json.load(f)
+
+        ing = report["ingest"]
+        self.assertEqual(len(ing["files_ok"]), 3)
+        self.assertEqual(ing["files_failed"], {})
+        self.assertGreaterEqual(ing["lines_malformed"], 1)
+        self.assertGreater(ing["events_emitted"], 0)
+
+        an = report["analysis"]
+        self.assertGreater(an["total_events"], 0)
+        self.assertIn("ERROR", an["by_level"])
+        self.assertIn("INFO", an["by_level"])
+        self.assertIsNotNone(an["time_range"]["first"])
+        self.assertIsNotNone(an["time_range"]["last"])
+        self.assertGreater(len(an["rate_per_window"]), 0)
+        self.assertGreater(len(an["top_messages"]), 0)
+        self.assertIn("anomalies", an)
+
+        # parsers should be auto-detected
+        parsers = ing["parsers_used"]
+        self.assertIn("jsonl", parsers.values())
+        self.assertIn("syslog", parsers.values())
+        self.assertIn("clf", parsers.values())
+
+    def test_analyze_with_missing_file_still_works(self) -> None:
+        missing = os.path.join(self.tmpdir.name, "missing.log")
+        rc = main(["analyze", self.jsonl, missing, "-f", "json"])
+        # exit 0 because at least one file succeeded
+        self.assertEqual(rc, 0)
+
+    def test_analyze_all_files_missing_exits_1(self) -> None:
+        missing = os.path.join(self.tmpdir.name, "nope.log")
+        rc = main(["analyze", missing, "-f", "json"])
+        self.assertEqual(rc, 1)
+
+    def test_text_format_output(self) -> None:
+        rc = main(["analyze", self.jsonl, "-f", "text"])
+        self.assertEqual(rc, 0)
+
+    def test_both_format_output(self) -> None:
+        rc = main(["analyze", self.jsonl, "-f", "both"])
+        self.assertEqual(rc, 0)
+
+    def test_config_filter_applied(self) -> None:
+        cfg_path = os.path.join(self.tmpdir.name, "filter.yaml")
+        with open(cfg_path, "w") as f:
+            # Only keep ERROR level — should drastically reduce event count
+            f.write("filters:\n  - type: level\n    min: ERROR\n")
+        rc = main([
+            "analyze", self.jsonl, self.syslog, self.clf,
+            "-c", cfg_path, "-o", self.report_path, "-f", "json",
+        ])
+        self.assertEqual(rc, 0)
+        with open(self.report_path) as f:
+            report = json.load(f)
+        # Only error-level events should survive
+        levels = set(report["analysis"]["by_level"].keys())
+        self.assertTrue(levels <= {"ERROR", "CRITICAL", "EMERGENCY", "ALERT"})
+
+    def test_window_override(self) -> None:
+        rc = main([
+            "analyze", self.jsonl, "-w", "120",
+            "-o", self.report_path, "-f", "json",
+        ])
+        self.assertEqual(rc, 0)
+        with open(self.report_path) as f:
+            report = json.load(f)
+        self.assertEqual(report["analysis"]["window_seconds"], 120)
+
+
+class TestConfigErrorIntegration(unittest.TestCase):
+    def test_missing_config_exits_1(self) -> None:
+        rc = main(["analyze", "/dev/null", "-c", "/nonexistent/typo.yaml", "-f", "json"])
+        self.assertEqual(rc, 1)
+
+    def test_invalid_yaml_config_exits_1(self) -> None:
+        with TemporaryDirectory() as d:
+            bad = os.path.join(d, "bad.yaml")
+            with open(bad, "w") as f:
+                f.write(":\n  - : [\n")  # malformed YAML
+            rc = main(["analyze", "/dev/null", "-c", bad, "-f", "json"])
+            self.assertEqual(rc, 1)
+
+
+class TestDetectIntegration(unittest.TestCase):
+    def test_detect_subcommand(self) -> None:
+        with TemporaryDirectory() as d:
+            path = os.path.join(d, "test.jsonl")
+            with open(path, "w") as f:
+                f.write('{"msg":"hi"}\n')
+            rc = main(["detect", path])
+            self.assertEqual(rc, 0)
+
+
+if __name__ == "__main__":
+    unittest.main()
