+"""Unit tests for every parser: JSONL edge cases, syslog with/without PRI,
+CLF common+combined, regex with missing groups."""
+from __future__ import annotations
+
+import json
+import unittest
+
+from logpipe.parsers import JSONLinesParser, SyslogParser, CLFParser, RegexParser
+
+
+class TestJSONLinesParser(unittest.TestCase):
+    def setUp(self) -> None:
+        self.p = JSONLinesParser()
+
+    def test_standard_fields(self) -> None:
+        line = json.dumps({"timestamp": "2026-04-19T12:00:00Z", "level": "error", "message": "boom"})
+        ev = self.p.parse(line, "f")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.message, "boom")
+        self.assertIsNotNone(ev.timestamp)
+
+    def test_field_aliases(self) -> None:
+        """ts/lvl/msg and @timestamp/severity/text should all be recognised."""
+        for ts_key in ("ts", "time", "@timestamp", "asctime"):
+            for lvl_key in ("level", "severity", "lvl", "levelname"):
+                for msg_key in ("msg", "text", "event"):
+                    line = json.dumps({ts_key: "2026-01-01T00:00:00Z", lvl_key: "info", msg_key: "ok"})
+                    ev = self.p.parse(line, "f")
+                    self.assertIsNotNone(ev, f"failed for {ts_key}/{lvl_key}/{msg_key}")
+                    self.assertEqual(ev.level, "INFO")
+
+    def test_missing_all_optional_fields(self) -> None:
+        ev = self.p.parse('{"foo": "bar"}', "f")
+        assert ev is not None
+        self.assertIsNone(ev.timestamp)
+        self.assertIsNone(ev.level)
+        self.assertIn("foo", ev.extra)
+
+    def test_epoch_seconds(self) -> None:
+        ev = self.p.parse(json.dumps({"ts": 1745064000, "msg": "hi"}), "f")
+        assert ev is not None
+        self.assertIsNotNone(ev.timestamp)
+        self.assertEqual(ev.timestamp.year, 2025)
+
+    def test_epoch_milliseconds(self) -> None:
+        ev = self.p.parse(json.dumps({"ts": 1745064000000, "msg": "hi"}), "f")
+        assert ev is not None
+        self.assertIsNotNone(ev.timestamp)
+        self.assertEqual(ev.timestamp.year, 2025)
+
+    def test_host_extraction(self) -> None:
+        ev = self.p.parse(json.dumps({"hostname": "web3", "msg": "x"}), "f")
+        assert ev is not None
+        self.assertEqual(ev.host, "web3")
+
+    def test_level_aliases(self) -> None:
+        for raw, want in [("warn", "WARNING"), ("FATAL", "CRITICAL"), ("err", "ERROR"),
+                          ("emerg", "EMERGENCY"), ("crit", "CRITICAL")]:
+            ev = self.p.parse(json.dumps({"level": raw, "msg": "x"}), "f")
+            assert ev is not None, f"{raw} returned None"
+            self.assertEqual(ev.level, want, f"level {raw!r}")
+
+    def test_unknown_level_becomes_none(self) -> None:
+        ev = self.p.parse(json.dumps({"level": "banana", "msg": "x"}), "f")
+        assert ev is not None
+        self.assertIsNone(ev.level)
+
+    def test_non_dict_json_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("[1,2,3]", "f"))
+
+    def test_empty_and_whitespace_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("", "f"))
+        self.assertIsNone(self.p.parse("   ", "f"))
+
+    def test_non_json_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("this is not json", "f"))
+
+    def test_extra_fields_preserved(self) -> None:
+        ev = self.p.parse(json.dumps({"msg": "x", "request_id": "abc", "latency": 42}), "f")
+        assert ev is not None
+        self.assertEqual(ev.extra["request_id"], "abc")
+        self.assertEqual(ev.extra["latency"], 42)
+
+    def test_comma_in_timestamp(self) -> None:
+        """Python logging uses comma-separated milliseconds: 2026-04-19 10:00:00,123"""
+        ev = self.p.parse(json.dumps({"timestamp": "2026-04-19 10:00:00,123", "msg": "x"}), "f")
+        assert ev is not None
+        self.assertIsNotNone(ev.timestamp)
+
+    def test_score(self) -> None:
+        lines = [json.dumps({"msg": "ok"})] * 5 + ["not json"]
+        self.assertAlmostEqual(self.p.score(lines), 5 / 6, places=2)
+        self.assertEqual(self.p.score([]), 0.0)
+
+
+class TestSyslogParser(unittest.TestCase):
+    def setUp(self) -> None:
+        self.p = SyslogParser(default_year=2026)
+
+    def test_without_pri(self) -> None:
+        ev = self.p.parse("Apr 19 10:00:01 web1 nginx[123]: GET /health 200", "f")
+        assert ev is not None
+        self.assertEqual(ev.host, "web1")
+        self.assertEqual(ev.extra["process"], "nginx")
+        self.assertEqual(ev.extra["pid"], 123)
+        self.assertEqual(ev.message, "GET /health 200")
+        self.assertIsNone(ev.level)  # no PRI means no severity
+
+    def test_with_pri(self) -> None:
+        ev = self.p.parse("<11>Apr 19 10:01:02 web1 app[77]: db down", "f")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")  # 11 & 7 == 3 → ERROR
+        self.assertEqual(ev.extra["facility"], 1)  # 11 >> 3 == 1
+        self.assertEqual(ev.extra["pid"], 77)
+
+    def test_without_pid(self) -> None:
+        ev = self.p.parse("Apr 19 10:00:30 web1 kernel: oom-killer invoked", "f")
+        assert ev is not None
+        self.assertEqual(ev.extra["process"], "kernel")
+        self.assertNotIn("pid", ev.extra)
+
+    def test_all_severities_from_pri(self) -> None:
+        for severity, expected in [(0, "EMERGENCY"), (1, "ALERT"), (2, "CRITICAL"),
+                                   (3, "ERROR"), (4, "WARNING"), (5, "NOTICE"),
+                                   (6, "INFO"), (7, "DEBUG")]:
+            pri = severity  # facility 0
+            ev = self.p.parse(f"<{pri}>Apr  1 00:00:00 h p: msg", "f")
+            assert ev is not None, f"pri={pri}"
+            self.assertEqual(ev.level, expected, f"severity {severity}")
+
+    def test_single_digit_day(self) -> None:
+        ev = self.p.parse("Apr  1 09:00:00 host proc: msg", "f")
+        assert ev is not None
+        self.assertEqual(ev.timestamp.day, 1)
+
+    def test_malformed_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("not a syslog line", "f"))
+        self.assertIsNone(self.p.parse("", "f"))
+
+    def test_timestamp_year(self) -> None:
+        ev = self.p.parse("Jan  5 12:00:00 h p: m", "f")
+        assert ev is not None
+        self.assertEqual(ev.timestamp.year, 2026)
+
+    def test_score(self) -> None:
+        lines = ["Apr 19 10:00:01 web1 sshd[42]: ok"] * 4 + ['{"msg":"json"}']
+        self.assertAlmostEqual(self.p.score(lines), 0.8, places=2)
+
+
+class TestCLFParser(unittest.TestCase):
+    def setUp(self) -> None:
+        self.p = CLFParser()
+
+    def test_common_format(self) -> None:
+        line = '127.0.0.1 - frank [19/Apr/2026:10:00:00 +0000] "GET / HTTP/1.1" 200 512'
+        ev = self.p.parse(line, "f")
+        assert ev is not None
+        self.assertEqual(ev.host, "127.0.0.1")
+        self.assertEqual(ev.extra["status"], 200)
+        self.assertEqual(ev.extra["bytes"], 512)
+        self.assertEqual(ev.level, "INFO")
+
+    def test_combined_format(self) -> None:
+        line = '10.0.0.1 - - [19/Apr/2026:10:00:00 +0000] "POST /api HTTP/1.1" 500 128 "http://ref" "curl/8"'
+        ev = self.p.parse(line, "f")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.extra["referer"], "http://ref")
+        self.assertEqual(ev.extra["user_agent"], "curl/8")
+
+    def test_404_is_warning(self) -> None:
+        line = '1.2.3.4 - - [19/Apr/2026:10:00:00 +0000] "GET /x HTTP/1.1" 404 0'
+        ev = self.p.parse(line, "f")
+        assert ev is not None
+        self.assertEqual(ev.level, "WARNING")
+
+    def test_dash_bytes(self) -> None:
+        line = '1.2.3.4 - - [19/Apr/2026:10:00:00 +0000] "GET / HTTP/1.1" 200 -'
+        ev = self.p.parse(line, "f")
+        assert ev is not None
+        self.assertEqual(ev.extra["bytes"], 0)
+
+    def test_malformed_rejected(self) -> None:
+        self.assertIsNone(self.p.parse("random text", "f"))
+        self.assertIsNone(self.p.parse("", "f"))
+
+    def test_score(self) -> None:
+        lines = [
+            '1.2.3.4 - - [19/Apr/2026:10:00:00 +0000] "GET / HTTP/1.1" 200 100',
+            '1.2.3.4 - - [19/Apr/2026:10:00:01 +0000] "GET / HTTP/1.1" 200 100',
+        ]
+        self.assertEqual(self.p.score(lines), 1.0)
+
+
+class TestRegexParser(unittest.TestCase):
+    def test_full_match(self) -> None:
+        p = RegexParser(
+            name="test",
+            pattern=r"^(?P<timestamp>\S+) \[(?P<level>\w+)\] (?P<message>.*)$",
+            time_format="%Y-%m-%dT%H:%M:%S",
+        )
+        ev = p.parse("2026-04-19T10:00:00 [ERROR] something broke", "f")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.message, "something broke")
+        self.assertIsNotNone(ev.timestamp)
+
+    def test_missing_optional_groups(self) -> None:
+        p = RegexParser(name="minimal", pattern=r"^(?P<message>.+)$")
+        ev = p.parse("just a message", "f")
+        assert ev is not None
+        self.assertIsNone(ev.timestamp)
+        self.assertIsNone(ev.level)
+        self.assertEqual(ev.message, "just a message")
+
+    def test_extra_groups_in_extra(self) -> None:
+        p = RegexParser(name="extra", pattern=r"^(?P<message>\w+) pid=(?P<pid>\d+)$")
+        ev = p.parse("restart pid=42", "f")
+        assert ev is not None
+        self.assertEqual(ev.extra["pid"], "42")
+
+    def test_iso_timestamp_without_time_format(self) -> None:
+        p = RegexParser(name="iso", pattern=r"^(?P<timestamp>\S+) (?P<message>.*)$")
+        ev = p.parse("2026-04-19T10:00:00Z hello", "f")
+        assert ev is not None
+        self.assertIsNotNone(ev.timestamp)
+
+    def test_no_match_returns_none(self) -> None:
+        p = RegexParser(name="x", pattern=r"^MARKER: (?P<message>.*)$")
+        self.assertIsNone(p.parse("doesn't match", "f"))
+
+
+if __name__ == "__main__":
+    unittest.main()
