@@ -0,0 +1,97 @@
+"""Command-line interface — ``logpipe analyze`` and ``logpipe tail``."""
+
+from __future__ import annotations
+
+import argparse
+import sys
+
+from logpipe import __version__
+from logpipe.analysis import analyze
+from logpipe.config import load_config
+from logpipe.pipeline import PipelineStats, run_pipeline
+from logpipe.report import build_report, build_summary, report_to_json
+from logpipe.tail import tail_follow
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="logpipe",
+        description="CLI log analysis tool — normalize, filter, analyze, report.",
+    )
+    parser.add_argument("--version", action="version", version=f"logpipe {__version__}")
+
+    sub = parser.add_subparsers(dest="command")
+
+    # --- analyze ---
+    an = sub.add_parser("analyze", help="Batch-analyze log files and produce a report.")
+    an.add_argument("files", nargs="+", help="Log files to analyze.")
+    an.add_argument("-c", "--config", default=None, help="YAML config file.")
+    an.add_argument(
+        "-o", "--output", default=None,
+        help="Write JSON report to this file (default: stdout).",
+    )
+
+    # --- tail ---
+    ta = sub.add_parser("tail", help="Follow log files in real time.")
+    ta.add_argument("files", nargs="+", help="Log files to tail.")
+    ta.add_argument("-c", "--config", default=None, help="YAML config file.")
+    ta.add_argument(
+        "--interval", type=float, default=30.0,
+        help="Seconds between periodic analysis summaries (default: 30).",
+    )
+
+    return parser
+
+
+def main(argv: list[str] | None = None) -> None:
+    parser = _build_parser()
+    args = parser.parse_args(argv)
+
+    if args.command is None:
+        parser.print_help()
+        sys.exit(1)
+
+    if args.command == "analyze":
+        _cmd_analyze(args)
+    elif args.command == "tail":
+        _cmd_tail(args)
+
+
+# ── analyze ──────────────────────────────────────────────────────────
+
+def _cmd_analyze(args: argparse.Namespace) -> None:
+    config = load_config(args.config)
+
+    # Drain the generator to collect events and stats.
+    gen = run_pipeline(args.files, config)
+    events = []
+    stats: PipelineStats | None = None
+    try:
+        while True:
+            events.append(next(gen))
+    except StopIteration as stop:
+        stats = stop.value
+
+    if stats is None:
+        stats = PipelineStats()
+
+    result = analyze(events, config.analysis)
+    report = build_report(result, stats)
+
+    json_str = report_to_json(report)
+    if args.output:
+        with open(args.output, "w") as f:
+            f.write(json_str + "\n")
+        print(f"logpipe: report written to {args.output}", file=sys.stderr)
+    else:
+        print(json_str)
+
+    # Always print the human-readable summary to stderr.
+    print("\n" + build_summary(report), file=sys.stderr)
+
+
+# ── tail ─────────────────────────────────────────────────────────────
+
+def _cmd_tail(args: argparse.Namespace) -> None:
+    config = load_config(args.config)
+    tail_follow(args.files, config, interval=args.interval)
