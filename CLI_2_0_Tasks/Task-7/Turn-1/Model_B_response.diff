@@ -0,0 +1,77 @@
+"""Configurable event filters."""
+
+from __future__ import annotations
+
+import re
+from datetime import datetime
+from typing import Any, Callable
+
+from logpipe.config import FilterSpec
+from logpipe.models import LEVEL_ORDER, LogEvent
+
+
+def build_filters(specs: list[FilterSpec]) -> list[Callable[[LogEvent], bool]]:
+    """Return a list of predicate functions from filter specs.
+
+    Each predicate returns True if the event should be **kept**.
+    """
+    out: list[Callable[[LogEvent], bool]] = []
+    for spec in specs:
+        builder = _REGISTRY.get(spec.type)
+        if builder is None:
+            raise ValueError(f"Unknown filter type: {spec.type!r}")
+        out.append(builder(spec.params))
+    return out
+
+
+# -- individual builders ---------------------------------------------------
+
+
+def _level_filter(params: dict[str, Any]) -> Callable[[LogEvent], bool]:
+    min_level = params.get("min_level", "WARNING").upper()
+    threshold = LEVEL_ORDER.get(min_level, 0)
+
+    def _keep(event: LogEvent) -> bool:
+        if event.level is None:
+            return True  # keep events with unknown level
+        return LEVEL_ORDER.get(event.level, 0) >= threshold
+
+    return _keep
+
+
+def _regex_filter(params: dict[str, Any]) -> Callable[[LogEvent], bool]:
+    pattern = re.compile(params["pattern"], re.IGNORECASE)
+    field = params.get("field", "message")
+
+    def _keep(event: LogEvent) -> bool:
+        if field == "message":
+            text = event.message
+        else:
+            text = str(event.fields.get(field, ""))
+        return pattern.search(text) is not None
+
+    return _keep
+
+
+def _timerange_filter(params: dict[str, Any]) -> Callable[[LogEvent], bool]:
+    start = datetime.fromisoformat(params["start"]) if "start" in params else None
+    end = datetime.fromisoformat(params["end"]) if "end" in params else None
+
+    def _keep(event: LogEvent) -> bool:
+        if event.timestamp is None:
+            return True
+        ts = event.timestamp
+        if start and ts < start:
+            return False
+        if end and ts > end:
+            return False
+        return True
+
+    return _keep
+
+
+_REGISTRY: dict[str, Callable[[dict[str, Any]], Callable[[LogEvent], bool]]] = {
+    "level": _level_filter,
+    "regex": _regex_filter,
+    "timerange": _timerange_filter,
+}
