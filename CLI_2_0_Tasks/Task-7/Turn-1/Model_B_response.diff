+++ b/src/logpipe/analysis.py
@@ -0,0 +1,131 @@
+"""Windowed metrics, severity breakdown, and anomaly detection."""
+
+from __future__ import annotations
+
+import math
+import re
+from collections import Counter, defaultdict
+from datetime import datetime, timedelta
+from typing import Any
+
+from logpipe.config import AnalysisSettings
+from logpipe.models import LogEvent
+
+
+def _window_key(ts: datetime, window_seconds: int) -> str:
+    """Round a timestamp down to the start of its window."""
+    epoch = ts.timestamp()
+    bucket = int(epoch // window_seconds) * window_seconds
+    return datetime.fromtimestamp(bucket).isoformat()
+
+
+# Collapse numbers / hex / uuids so similar messages cluster together.
+_COLLAPSE = [
+    (re.compile(r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}", re.I), "<UUID>"),
+    (re.compile(r"0x[0-9a-fA-F]+"), "<HEX>"),
+    (re.compile(r"\b\d+\b"), "<N>"),
+]
+
+
+def _signature(message: str) -> str:
+    sig = message
+    for pat, repl in _COLLAPSE:
+        sig = pat.sub(repl, sig)
+    return sig
+
+
+class AnalysisResult:
+    """Container for all computed metrics."""
+
+    __slots__ = (
+        "total_events",
+        "level_counts",
+        "windows",
+        "anomalies",
+        "top_patterns",
+        "time_range",
+    )
+
+    def __init__(self) -> None:
+        self.total_events: int = 0
+        self.level_counts: Counter[str] = Counter()
+        self.windows: dict[str, dict[str, Any]] = {}
+        self.anomalies: list[dict[str, Any]] = []
+        self.top_patterns: list[tuple[str, int]] = []
+        self.time_range: tuple[str | None, str | None] = (None, None)
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "total_events": self.total_events,
+            "level_counts": dict(self.level_counts),
+            "time_range": {"start": self.time_range[0], "end": self.time_range[1]},
+            "windows": self.windows,
+            "anomalies": self.anomalies,
+            "top_patterns": [{"pattern": p, "count": c} for p, c in self.top_patterns],
+        }
+
+
+def analyze(events: list[LogEvent], settings: AnalysisSettings) -> AnalysisResult:
+    """Run full analysis on a batch of events."""
+    result = AnalysisResult()
+    result.total_events = len(events)
+
+    if not events:
+        return result
+
+    # Level breakdown
+    for ev in events:
+        if ev.level:
+            result.level_counts[ev.level] += 1
+
+    # Time range
+    timestamps = [ev.timestamp for ev in events if ev.timestamp]
+    if timestamps:
+        mn, mx = min(timestamps), max(timestamps)
+        result.time_range = (mn.isoformat(), mx.isoformat())
+
+    # Windowed counts
+    window_counts: dict[str, int] = defaultdict(int)
+    window_levels: dict[str, Counter[str]] = defaultdict(Counter)
+    for ev in events:
+        if ev.timestamp is None:
+            continue
+        wk = _window_key(ev.timestamp, settings.window_seconds)
+        window_counts[wk] += 1
+        if ev.level:
+            window_levels[wk][ev.level] += 1
+
+    for wk in sorted(window_counts):
+        result.windows[wk] = {
+            "count": window_counts[wk],
+            "levels": dict(window_levels[wk]),
+        }
+
+    # Anomaly detection (z-score on window counts)
+    if len(window_counts) >= 3:
+        counts = list(window_counts.values())
+        mean = sum(counts) / len(counts)
+        variance = sum((c - mean) ** 2 for c in counts) / len(counts)
+        stddev = math.sqrt(variance) if variance > 0 else 0.0
+
+        if stddev > 0:
+            for wk in sorted(window_counts):
+                c = window_counts[wk]
+                z = (c - mean) / stddev
+                if abs(z) >= settings.anomaly_threshold:
+                    result.anomalies.append({
+                        "window": wk,
+                        "count": c,
+                        "z_score": round(z, 2),
+                        "type": "spike" if z > 0 else "drop",
+                        "mean": round(mean, 2),
+                        "stddev": round(stddev, 2),
+                    })
+
+    # Top message patterns
+    sig_counter: Counter[str] = Counter()
+    for ev in events:
+        sig_counter[_signature(ev.message)] += 1
+    result.top_patterns = sig_counter.most_common(10)
+
+    return result
