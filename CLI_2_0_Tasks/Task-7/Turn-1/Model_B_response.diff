@@ -0,0 +1,34 @@
+"""Log format parsers and auto-detection."""
+
+from __future__ import annotations
+
+import sys
+from typing import TYPE_CHECKING
+
+from logpipe.formats.jsonl import JSONLParser
+from logpipe.formats.kv import KVParser
+from logpipe.formats.syslog import SyslogParser
+from logpipe.formats.base import Parser
+
+if TYPE_CHECKING:
+    pass
+
+PARSERS: list[Parser] = [JSONLParser(), SyslogParser(), KVParser()]
+
+
+def detect_parser(sample_lines: list[str]) -> Parser:
+    """Pick the best parser for *sample_lines* by confidence score.
+
+    Falls back to the KV parser (which can treat plain lines as message-only).
+    """
+    if not sample_lines:
+        return KVParser()
+
+    best: Parser = PARSERS[-1]
+    best_score = 0.0
+    for parser in PARSERS:
+        score = parser.probe(sample_lines)
+        if score > best_score:
+            best_score = score
+            best = parser
+    return best
