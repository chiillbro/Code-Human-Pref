index 0000000..63c70d0
--- /dev/null
+++ b/src/logpipe/report.py
@@ -0,0 +1,93 @@
+"""Build the JSON report and a human-readable natural-language summary."""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+
+from logpipe.analysis import AnalysisResult
+from logpipe.pipeline import PipelineStats
+
+
+def build_report(
+    result: AnalysisResult,
+    stats: PipelineStats,
+) -> dict[str, Any]:
+    """Return the full JSON-serialisable report dict."""
+    return {
+        "pipeline": {
+            "files_processed": stats.files_processed,
+            "files_skipped": stats.files_skipped,
+            "lines_processed": stats.lines_processed,
+            "lines_skipped": stats.lines_skipped,
+        },
+        "analysis": result.to_dict(),
+    }
+
+
+def report_to_json(report: dict[str, Any]) -> str:
+    return json.dumps(report, indent=2)
+
+
+def build_summary(report: dict[str, Any]) -> str:
+    """Produce a natural-language summary from the report dict."""
+    lines: list[str] = []
+    pipe = report["pipeline"]
+    analysis = report["analysis"]
+
+    lines.append("=== logpipe analysis summary ===\n")
+
+    # Pipeline stats
+    lines.append(
+        f"Processed {pipe['files_processed']} file(s) "
+        f"({pipe['lines_processed']} lines). "
+        f"Skipped {pipe['files_skipped']} unreadable file(s) and "
+        f"{pipe['lines_skipped']} malformed line(s)."
+    )
+
+    total = analysis["total_events"]
+    lines.append(f"\nTotal matching events: {total}")
+
+    # Time range
+    tr = analysis["time_range"]
+    if tr["start"]:
+        lines.append(f"Time range: {tr['start']}  to  {tr['end']}")
+
+    # Severity breakdown
+    lc = analysis["level_counts"]
+    if lc:
+        parts = ", ".join(f"{lvl}: {cnt}" for lvl, cnt in sorted(lc.items()))
+        lines.append(f"Severity breakdown: {parts}")
+
+    # Anomalies
+    anomalies = analysis["anomalies"]
+    if anomalies:
+        lines.append(f"\n!! {len(anomalies)} anomalous window(s) detected:")
+        for a in anomalies:
+            direction = "SPIKE" if a["type"] == "spike" else "DROP"
+            lines.append(
+                f"  - {a['window']}: {direction} — {a['count']} events "
+                f"(z-score {a['z_score']:+.2f}, mean {a['mean']:.1f}, "
+                f"stddev {a['stddev']:.1f})"
+            )
+    else:
+        lines.append("\nNo anomalous windows detected.")
+
+    # Top patterns
+    patterns = analysis["top_patterns"]
+    if patterns:
+        lines.append("\nTop recurring message patterns:")
+        for i, entry in enumerate(patterns[:5], start=1):
+            lines.append(f"  {i}. ({entry['count']}x) {entry['pattern'][:120]}")
+
+    # Windows overview
+    windows = analysis["windows"]
+    if windows:
+        counts = [w["count"] for w in windows.values()]
+        lines.append(
+            f"\nWindowed metrics: {len(windows)} window(s), "
+            f"min {min(counts)} / max {max(counts)} / "
+            f"avg {sum(counts)/len(counts):.1f} events per window."
+        )
+
+    return "\n".join(lines)
diff --git a/src/logpipe/tail.py b/src/logpipe/tail.py
new file mode 100644
index 0000000..be692bc
--- /dev/null
+++ b/src/logpipe/tail.py
@@ -0,0 +1,150 @@
+"""Real-time file following with the same analysis pipeline."""
+
+from __future__ import annotations
+
+import os
+import sys
+import time
+from collections.abc import Callable
+from pathlib import Path
+
+from logpipe.analysis import AnalysisResult, analyze
+from logpipe.config import Config
+from logpipe.filters import build_filters
+from logpipe.formats import detect_parser
+from logpipe.formats.base import Parser
+from logpipe.models import LogEvent
+from logpipe.report import build_report, build_summary
+from logpipe.pipeline import PipelineStats
+from logpipe.transforms import build_transforms
+
+SAMPLE_SIZE = 20
+
+
+class _TailedFile:
+    """Track one file being tailed."""
+
+    __slots__ = ("path", "fh", "parser", "lineno")
+
+    def __init__(self, path: Path, fh, parser: Parser, lineno: int) -> None:  # noqa: ANN001
+        self.path = path
+        self.fh = fh
+        self.parser = parser
+        self.lineno = lineno
+
+
+def _open_tail(path: Path, stats: PipelineStats) -> _TailedFile | None:
+    try:
+        fh = open(path, errors="replace")
+    except OSError as exc:
+        print(f"logpipe: warning: cannot open {path}: {exc}", file=sys.stderr)
+        stats.files_skipped += 1
+        return None
+
+    # Read sample for format detection, then seek to end.
+    sample: list[str] = []
+    for _ in range(SAMPLE_SIZE):
+        ln = fh.readline()
+        if not ln:
+            break
+        sample.append(ln)
+    parser = detect_parser(sample)
+
+    # Count existing lines so we start line numbers correctly.
+    fh.seek(0, os.SEEK_END)
+    total_lines = sum(1 for _ in open(path, errors="replace"))
+    stats.files_processed += 1
+    return _TailedFile(path=path, fh=fh, parser=parser, lineno=total_lines)
+
+
+def tail_follow(
+    files: list[str | Path],
+    config: Config,
+    interval: float = 30.0,
+) -> None:
+    """Follow *files* for new lines, applying the analysis pipeline.
+
+    Prints matching events in real-time.  Every *interval* seconds prints
+    a summary of events seen in that window.  Runs until interrupted.
+    """
+    predicates = build_filters(config.filters)
+    mutators = build_transforms(config.transforms)
+    stats = PipelineStats()
+
+    tailed: list[_TailedFile] = []
+    for fp in files:
+        tf = _open_tail(Path(fp), stats)
+        if tf:
+            tailed.append(tf)
+
+    if not tailed:
+        print("logpipe: no files to tail.", file=sys.stderr)
+        return
+
+    window_events: list[LogEvent] = []
+    last_summary = time.monotonic()
+
+    print(f"logpipe: tailing {len(tailed)} file(s), Ctrl+C to stop.\n", file=sys.stderr)
+    try:
+        while True:
+            got_new = False
+            for tf in tailed:
+                while True:
+                    line = tf.fh.readline()
+                    if not line:
+                        break
+                    got_new = True
+                    tf.lineno += 1
+                    stats.lines_processed += 1
+                    try:
+                        event = tf.parser.parse_line(
+                            line, source=str(tf.path), line_number=tf.lineno
+                        )
+                    except Exception as exc:
+                        print(
+                            f"logpipe: warning: {tf.path}:{tf.lineno}: {exc}",
+                            file=sys.stderr,
+                        )
+                        stats.lines_skipped += 1
+                        continue
+
+                    if event is None:
+                        stats.lines_skipped += 1
+                        continue
+
+                    if not all(p(event) for p in predicates):
+                        continue
+                    for m in mutators:
+                        m(event)
+
+                    window_events.append(event)
+                    _print_event(event)
+
+            # Periodic summary
+            now = time.monotonic()
+            if now - last_summary >= interval and window_events:
+                result = analyze(window_events, config.analysis)
+                report = build_report(result, stats)
+                print("\n" + build_summary(report) + "\n", file=sys.stderr)
+                window_events.clear()
+                last_summary = now
+
+            if not got_new:
+                time.sleep(0.25)
+    except KeyboardInterrupt:
+        # Final summary
+        if window_events:
+            result = analyze(window_events, config.analysis)
+            report = build_report(result, stats)
+            print("\n" + build_summary(report), file=sys.stderr)
+        print("\nlogpipe: stopped.", file=sys.stderr)
+    finally:
+        for tf in tailed:
+            tf.fh.close()
+
+
+def _print_event(event: LogEvent) -> None:
+    ts = event.timestamp.isoformat() if event.timestamp else "----"
+    lvl = (event.level or "---").ljust(8)
+    src = Path(event.source).name
+    print(f"[{ts}] {lvl} {src}: {event.message}")
diff --git a/src/logpipe/transforms.py b/src/logpipe/transforms.py
new file mode 100644
index 0000000..06dbabf
--- /dev/null
+++ b/src/logpipe/transforms.py
@@ -0,0 +1,53 @@
+"""Configurable event transforms (mutate events in-place)."""
+
+from __future__ import annotations
+
+import re
+from typing import Any, Callable
+
+from logpipe.config import TransformSpec
+from logpipe.models import LogEvent
+
+
+def build_transforms(specs: list[TransformSpec]) -> list[Callable[[LogEvent], None]]:
+    """Return a list of mutator functions from transform specs."""
+    out: list[Callable[[LogEvent], None]] = []
+    for spec in specs:
+        builder = _REGISTRY.get(spec.type)
+        if builder is None:
+            raise ValueError(f"Unknown transform type: {spec.type!r}")
+        out.append(builder(spec.params))
+    return out
+
+
+# -- individual builders ---------------------------------------------------
+
+
+def _extract_transform(params: dict[str, Any]) -> Callable[[LogEvent], None]:
+    pattern = re.compile(params["pattern"])
+    field = params.get("field", "message")
+
+    def _apply(event: LogEvent) -> None:
+        text = event.message if field == "message" else str(event.fields.get(field, ""))
+        m = pattern.search(text)
+        if m:
+            event.fields.update(m.groupdict())
+
+    return _apply
+
+
+def _rename_transform(params: dict[str, Any]) -> Callable[[LogEvent], None]:
+    src = params["from"]
+    dst = params["to"]
+
+    def _apply(event: LogEvent) -> None:
+        if src in event.fields:
+            event.fields[dst] = event.fields.pop(src)
+
+    return _apply
+
+
+_REGISTRY: dict[str, Callable[[dict[str, Any]], Callable[[LogEvent], None]]] = {
+    "extract": _extract_transform,
+    "rename": _rename_transform,
+}
