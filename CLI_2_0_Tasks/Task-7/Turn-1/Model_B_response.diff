@@ -0,0 +1,21 @@
+"""Abstract base for log format parsers."""
+
+from __future__ import annotations
+
+import abc
+
+from logpipe.models import LogEvent
+
+
+class Parser(abc.ABC):
+    """Interface every format parser must implement."""
+
+    name: str = "base"
+
+    @abc.abstractmethod
+    def probe(self, sample_lines: list[str]) -> float:
+        """Return 0.0–1.0 confidence that *sample_lines* match this format."""
+
+    @abc.abstractmethod
+    def parse_line(self, line: str, *, source: str, line_number: int) -> LogEvent | None:
+        """Parse a single raw line into a LogEvent, or None on failure."""
