@@ -0,0 +1,66 @@
+"""Load and validate YAML configuration for filters, transforms, and analysis."""
+
+from __future__ import annotations
+
+import dataclasses
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+
+@dataclasses.dataclass(slots=True)
+class FilterSpec:
+    type: str
+    params: dict[str, Any]
+
+
+@dataclasses.dataclass(slots=True)
+class TransformSpec:
+    type: str
+    params: dict[str, Any]
+
+
+@dataclasses.dataclass(slots=True)
+class AnalysisSettings:
+    window_seconds: int = 60
+    anomaly_threshold: float = 2.0
+
+
+@dataclasses.dataclass(slots=True)
+class Config:
+    filters: list[FilterSpec] = dataclasses.field(default_factory=list)
+    transforms: list[TransformSpec] = dataclasses.field(default_factory=list)
+    analysis: AnalysisSettings = dataclasses.field(default_factory=AnalysisSettings)
+
+
+def load_config(path: str | Path | None) -> Config:
+    """Load config from a YAML file, or return defaults when *path* is None."""
+    if path is None:
+        return Config()
+
+    with open(path) as f:
+        raw = yaml.safe_load(f)
+
+    if not isinstance(raw, dict):
+        return Config()
+
+    filters: list[FilterSpec] = []
+    for entry in raw.get("filters") or []:
+        ftype = entry.pop("type", None)
+        if ftype:
+            filters.append(FilterSpec(type=ftype, params=entry))
+
+    transforms: list[TransformSpec] = []
+    for entry in raw.get("transforms") or []:
+        ttype = entry.pop("type", None)
+        if ttype:
+            transforms.append(TransformSpec(type=ttype, params=entry))
+
+    analysis_raw = raw.get("analysis") or {}
+    analysis = AnalysisSettings(
+        window_seconds=int(analysis_raw.get("window_seconds", 60)),
+        anomaly_threshold=float(analysis_raw.get("anomaly_threshold", 2.0)),
+    )
+
+    return Config(filters=filters, transforms=transforms, analysis=analysis)
