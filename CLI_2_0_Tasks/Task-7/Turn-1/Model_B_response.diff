+++ b/src/logpipe/formats/jsonl.py
@@ -0,0 +1,93 @@
+"""JSON-lines log parser."""
+
+from __future__ import annotations
+
+import json
+from datetime import datetime, timezone
+from typing import Any
+
+from logpipe.formats.base import Parser
+from logpipe.models import LogEvent, normalize_level
+
+
+_TS_KEYS = ("timestamp", "time", "ts", "@timestamp", "datetime", "date")
+_LEVEL_KEYS = ("level", "severity", "loglevel", "log_level", "lvl")
+_MSG_KEYS = ("message", "msg", "text", "log", "body")
+
+
+def _first_match(data: dict[str, Any], candidates: tuple[str, ...]) -> Any | None:
+    for key in candidates:
+        if key in data:
+            return data[key]
+    return None
+
+
+def _parse_ts(raw: Any) -> datetime | None:
+    if raw is None:
+        return None
+    if isinstance(raw, (int, float)):
+        try:
+            return datetime.fromtimestamp(raw, tz=timezone.utc)
+        except (OSError, ValueError):
+            return None
+    s = str(raw)
+    for fmt in (
+        "%Y-%m-%dT%H:%M:%S.%fZ",
+        "%Y-%m-%dT%H:%M:%SZ",
+        "%Y-%m-%dT%H:%M:%S.%f%z",
+        "%Y-%m-%dT%H:%M:%S%z",
+        "%Y-%m-%d %H:%M:%S.%f",
+        "%Y-%m-%d %H:%M:%S",
+    ):
+        try:
+            return datetime.strptime(s, fmt)
+        except ValueError:
+            continue
+    return None
+
+
+class JSONLParser(Parser):
+    name = "jsonl"
+
+    def probe(self, sample_lines: list[str]) -> float:
+        hits = 0
+        for line in sample_lines:
+            line = line.strip()
+            if not line:
+                continue
+            try:
+                obj = json.loads(line)
+                if isinstance(obj, dict):
+                    hits += 1
+            except (json.JSONDecodeError, ValueError):
+                pass
+        return hits / max(len(sample_lines), 1)
+
+    def parse_line(self, line: str, *, source: str, line_number: int) -> LogEvent | None:
+        line = line.strip()
+        if not line:
+            return None
+        try:
+            data = json.loads(line)
+        except (json.JSONDecodeError, ValueError):
+            return None
+        if not isinstance(data, dict):
+            return None
+
+        ts = _parse_ts(_first_match(data, _TS_KEYS))
+        level = normalize_level(str(_first_match(data, _LEVEL_KEYS) or ""))
+        message = str(_first_match(data, _MSG_KEYS) or "")
+
+        # Everything else goes into fields
+        skip = set(_TS_KEYS) | set(_LEVEL_KEYS) | set(_MSG_KEYS)
+        fields = {k: v for k, v in data.items() if k not in skip}
+
+        return LogEvent(
+            timestamp=ts,
+            level=level,
+            message=message,
+            source=source,
+            line_number=line_number,
+            raw=line,
+            fields=fields,
+        )
diff --git a/src/logpipe/formats/kv.py b/src/logpipe/formats/kv.py
