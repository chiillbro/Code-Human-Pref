index 0000000..cfb6dce
--- /dev/null
+++ b/src/logpipe/filters.py
@@ -0,0 +1,190 @@
+"""Config-driven filters and transforms.
+
+Both are built from the lists of dicts in the config file. A *filter* is a
+predicate ``LogEvent -> bool``; a *transform* is ``LogEvent -> LogEvent``.
+Unknown ``type`` values are warned about and ignored so a typo in the config
+cannot bring the pipeline down.
+"""
+from __future__ import annotations
+
+import re
+import sys
+from datetime import datetime
+from typing import Any, Callable, Dict, List, Optional
+
+from .event import LEVEL_ORDER, LogEvent, normalize_level
+
+Predicate = Callable[[LogEvent], bool]
+Transform = Callable[[LogEvent], LogEvent]
+
+
+# ---- filters --------------------------------------------------------------
+
+def _f_level(spec: Dict[str, Any]) -> Predicate:
+    floor = LEVEL_ORDER.get(normalize_level(spec.get("min")) or "", 0)
+
+    def pred(ev: LogEvent) -> bool:
+        if ev.level is None:
+            return floor == 0  # only keep unlevelled events when no floor set
+        return LEVEL_ORDER.get(ev.level, 0) >= floor
+
+    return pred
+
+
+def _f_match(spec: Dict[str, Any], *, negate: bool = False) -> Predicate:
+    field = spec.get("field", "message")
+    rx = re.compile(spec["pattern"])
+
+    def pred(ev: LogEvent) -> bool:
+        val = ev.get(field)
+        hit = val is not None and rx.search(str(val)) is not None
+        return (not hit) if negate else hit
+
+    return pred
+
+
+def _f_equals(spec: Dict[str, Any]) -> Predicate:
+    field = spec["field"]
+    want = spec["value"]
+
+    def pred(ev: LogEvent) -> bool:
+        return ev.get(field) == want
+
+    return pred
+
+
+def _parse_dt(s: Optional[str]) -> Optional[datetime]:
+    if not s:
+        return None
+    try:
+        return datetime.fromisoformat(s.replace("Z", "+00:00"))
+    except ValueError:
+        return None
+
+
+def _f_time_range(spec: Dict[str, Any]) -> Predicate:
+    after = _parse_dt(spec.get("after"))
+    before = _parse_dt(spec.get("before"))
+
+    def _comparable(a: datetime, b: datetime) -> tuple[datetime, datetime]:
+        # Mixing naive and aware datetimes raises; strip tzinfo when they differ.
+        if (a.tzinfo is None) != (b.tzinfo is None):
+            return a.replace(tzinfo=None), b.replace(tzinfo=None)
+        return a, b
+
+    def pred(ev: LogEvent) -> bool:
+        if ev.timestamp is None:
+            return True
+        if after is not None:
+            x, y = _comparable(ev.timestamp, after)
+            if x < y:
+                return False
+        if before is not None:
+            x, y = _comparable(ev.timestamp, before)
+            if x > y:
+                return False
+        return True
+
+    return pred
+
+
+_FILTER_BUILDERS: Dict[str, Callable[[Dict[str, Any]], Predicate]] = {
+    "level": _f_level,
+    "match": _f_match,
+    "exclude": lambda s: _f_match(s, negate=True),
+    "equals": _f_equals,
+    "time_range": _f_time_range,
+}
+
+
+def build_filters(specs: List[Dict[str, Any]]) -> List[Predicate]:
+    out: List[Predicate] = []
+    for spec in specs:
+        t = spec.get("type")
+        builder = _FILTER_BUILDERS.get(t)
+        if builder is None:
+            print(f"logpipe: warning: unknown filter type {t!r}, skipping", file=sys.stderr)
+            continue
+        try:
+            out.append(builder(spec))
+        except (KeyError, re.error, TypeError) as exc:
+            print(f"logpipe: warning: bad filter {spec!r}: {exc}", file=sys.stderr)
+    return out
+
+
+# ---- transforms -----------------------------------------------------------
+
+def _t_set(spec: Dict[str, Any]) -> Transform:
+    field, value = spec["field"], spec["value"]
+
+    def tr(ev: LogEvent) -> LogEvent:
+        ev.set(field, value)
+        return ev
+
+    return tr
+
+
+def _t_drop(spec: Dict[str, Any]) -> Transform:
+    field = spec["field"]
+
+    def tr(ev: LogEvent) -> LogEvent:
+        ev.extra.pop(field, None)
+        return ev
+
+    return tr
+
+
+def _t_rename(spec: Dict[str, Any]) -> Transform:
+    src, dst = spec["field"], spec["to"]
+
+    def tr(ev: LogEvent) -> LogEvent:
+        if src in ev.extra:
+            ev.set(dst, ev.extra.pop(src))
+        return ev
+
+    return tr
+
+
+def _t_normalize_level(spec: Dict[str, Any]) -> Transform:
+    field = spec.get("field", "level")
+
+    def tr(ev: LogEvent) -> LogEvent:
+        ev.level = normalize_level(ev.get(field)) or ev.level
+        return ev
+
+    return tr
+
+
+_TRANSFORM_BUILDERS: Dict[str, Callable[[Dict[str, Any]], Transform]] = {
+    "set": _t_set,
+    "drop": _t_drop,
+    "rename": _t_rename,
+    "normalize_level": _t_normalize_level,
+}
+
+
+def build_transforms(specs: List[Dict[str, Any]]) -> List[Transform]:
+    out: List[Transform] = []
+    for spec in specs:
+        t = spec.get("type")
+        builder = _TRANSFORM_BUILDERS.get(t)
+        if builder is None:
+            print(f"logpipe: warning: unknown transform type {t!r}, skipping", file=sys.stderr)
+            continue
+        try:
+            out.append(builder(spec))
+        except (KeyError, TypeError) as exc:
+            print(f"logpipe: warning: bad transform {spec!r}: {exc}", file=sys.stderr)
+    return out
+
+
+def apply_pipeline(
+    ev: LogEvent, filters: List[Predicate], transforms: List[Transform]
+) -> Optional[LogEvent]:
+    """Run one event through filters then transforms; ``None`` if filtered out."""
+    for f in filters:
+        if not f(ev):
+            return None
+    for t in transforms:
+        ev = t(ev)
+    return ev
