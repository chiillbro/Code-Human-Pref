@@ -0,0 +1,189 @@
+"""Windowed metrics and anomaly flagging.
+
+The analyzer consumes :class:`LogEvent` objects and accumulates:
+
+* global counts (total, per level, per source, per host);
+* time-bucketed counts at ``window_seconds`` resolution, both overall and per
+  level — this gives event-rate series;
+* a "top messages" table built on a normalised message signature so that
+  ``error: timeout after 53ms`` and ``error: timeout after 7ms`` collapse;
+* anomalous windows: buckets whose total count is more than ``anomaly_z``
+  standard deviations from the mean (spikes *and* drops).
+
+Everything is stdlib; ``statistics`` handles mean/stdev.
+"""
+from __future__ import annotations
+
+import re
+import statistics
+from collections import Counter, defaultdict
+from dataclasses import dataclass, field
+from datetime import datetime, timedelta
+from typing import Any, Dict, Iterable, List, Optional, Tuple
+
+from .config import AnalysisConfig
+from .event import LogEvent
+
+_NUM = re.compile(r"\d+")
+_HEX = re.compile(r"\b[0-9a-fA-F]{8,}\b")
+_UUID = re.compile(r"\b[0-9a-fA-F-]{32,36}\b")
+
+
+def _signature(msg: str) -> str:
+    """Collapse volatile bits of a message so similar lines group together."""
+    s = _UUID.sub("<id>", msg)
+    s = _HEX.sub("<hex>", s)
+    s = _NUM.sub("<n>", s)
+    return s.strip()[:200]
+
+
+def _floor(ts: datetime, seconds: int) -> datetime:
+    epoch = ts.replace(tzinfo=None).timestamp() if ts.tzinfo else ts.timestamp()
+    base = int(epoch // seconds) * seconds
+    return datetime.fromtimestamp(base)
+
+
+@dataclass
+class Anomaly:
+    window_start: datetime
+    count: int
+    z_score: float
+    kind: str  # "spike" or "drop"
+
+    def to_dict(self) -> Dict[str, Any]:
+        return {
+            "window_start": self.window_start.isoformat(),
+            "count": self.count,
+            "z_score": round(self.z_score, 2),
+            "kind": self.kind,
+        }
+
+
+@dataclass
+class AnalysisResult:
+    total: int = 0
+    by_level: Counter = field(default_factory=Counter)
+    by_source: Counter = field(default_factory=Counter)
+    by_host: Counter = field(default_factory=Counter)
+    first_ts: Optional[datetime] = None
+    last_ts: Optional[datetime] = None
+    windows: Dict[datetime, int] = field(default_factory=dict)
+    windows_by_level: Dict[datetime, Counter] = field(default_factory=lambda: defaultdict(Counter))
+    top_messages: List[Tuple[str, int]] = field(default_factory=list)
+    anomalies: List[Anomaly] = field(default_factory=list)
+    window_seconds: int = 60
+
+    def to_dict(self) -> Dict[str, Any]:
+        ordered = sorted(self.windows.items(), key=lambda kv: kv[0])
+        return {
+            "total_events": self.total,
+            "time_range": {
+                "first": self.first_ts.isoformat() if self.first_ts else None,
+                "last": self.last_ts.isoformat() if self.last_ts else None,
+            },
+            "by_level": dict(self.by_level),
+            "by_source": dict(self.by_source),
+            "by_host": dict(self.by_host),
+            "window_seconds": self.window_seconds,
+            "rate_per_window": [
+                {
+                    "start": w.isoformat(),
+                    "count": c,
+                    "by_level": dict(self.windows_by_level.get(w, {})),
+                }
+                for w, c in ordered
+            ],
+            "top_messages": [{"signature": s, "count": c} for s, c in self.top_messages],
+            "anomalies": [a.to_dict() for a in self.anomalies],
+        }
+
+
+class Analyzer:
+    def __init__(self, cfg: AnalysisConfig) -> None:
+        self.cfg = cfg
+        self._by_level: Counter = Counter()
+        self._by_source: Counter = Counter()
+        self._by_host: Counter = Counter()
+        self._windows: Dict[datetime, int] = defaultdict(int)
+        self._windows_by_level: Dict[datetime, Counter] = defaultdict(Counter)
+        self._messages: Counter = Counter()
+        self._total = 0
+        self._first: Optional[datetime] = None
+        self._last: Optional[datetime] = None
+
+    # -- feed -------------------------------------------------------------
+
+    def feed(self, ev: LogEvent) -> None:
+        self._total += 1
+        self._by_level[ev.level or "UNKNOWN"] += 1
+        self._by_source[ev.source] += 1
+        if ev.host:
+            self._by_host[ev.host] += 1
+        self._messages[_signature(ev.message)] += 1
+        if ev.timestamp is not None:
+            ts = ev.timestamp.replace(tzinfo=None) if ev.timestamp.tzinfo else ev.timestamp
+            if self._first is None or ts < self._first:
+                self._first = ts
+            if self._last is None or ts > self._last:
+                self._last = ts
+            bucket = _floor(ev.timestamp, self.cfg.window_seconds)
+            self._windows[bucket] += 1
+            self._windows_by_level[bucket][ev.level or "UNKNOWN"] += 1
+
+    def feed_all(self, events: Iterable[LogEvent]) -> None:
+        for ev in events:
+            self.feed(ev)
+
+    # -- finish -----------------------------------------------------------
+
+    def result(self) -> AnalysisResult:
+        windows = self._fill_gaps(dict(self._windows))
+        anomalies = self._detect_anomalies(windows)
+        return AnalysisResult(
+            total=self._total,
+            by_level=Counter(self._by_level),
+            by_source=Counter(self._by_source),
+            by_host=Counter(self._by_host),
+            first_ts=self._first,
+            last_ts=self._last,
+            windows=windows,
+            windows_by_level=dict(self._windows_by_level),
+            top_messages=self._messages.most_common(self.cfg.top_messages),
+            anomalies=anomalies,
+            window_seconds=self.cfg.window_seconds,
+        )
+
+    def _fill_gaps(self, windows: Dict[datetime, int]) -> Dict[datetime, int]:
+        """Insert zero-count buckets between first and last so drops are visible."""
+        if len(windows) < 2:
+            return windows
+        keys = sorted(windows)
+        step = timedelta(seconds=self.cfg.window_seconds)
+        span = (keys[-1] - keys[0]) // step
+        if span > 10_000:
+            # Refuse to materialise an absurd number of empty buckets (e.g. one
+            # stray 1970 timestamp). Keep only what we observed.
+            return windows
+        cur = keys[0]
+        while cur <= keys[-1]:
+            windows.setdefault(cur, 0)
+            cur += step
+        return windows
+
+    def _detect_anomalies(self, windows: Dict[datetime, int]) -> List[Anomaly]:
+        if len(windows) < 3:
+            return []
+        ordered = sorted(windows.items(), key=lambda kv: kv[0])
+        counts = [c for _, c in ordered]
+        mean = statistics.fmean(counts)
+        stdev = statistics.pstdev(counts)
+        if stdev == 0:
+            return []
+        out: List[Anomaly] = []
+        for start, c in ordered:
+            z = (c - mean) / stdev
+            if z >= self.cfg.anomaly_z:
+                out.append(Anomaly(start, c, z, "spike"))
+            elif z <= -self.cfg.anomaly_z:
+                out.append(Anomaly(start, c, z, "drop"))
+        return out
