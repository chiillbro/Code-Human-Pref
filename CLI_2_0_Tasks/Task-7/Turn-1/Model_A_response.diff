@@ -0,0 +1,82 @@
+"""Configuration loading.
+
+The config file is YAML and every section is optional::
+
+    parsers:
+      custom:
+        - name: myapp
+          pattern: '^(?P<timestamp>\\S+) \\[(?P<level>\\w+)\\] (?P<message>.*)$'
+          time_format: '%Y-%m-%dT%H:%M:%S'
+
+    filters:
+      - type: level
+        min: WARNING
+      - type: match
+        field: message
+        pattern: 'timeout|refused'
+      - type: exclude
+        field: message
+        pattern: 'healthcheck'
+      - type: time_range
+        after: '2026-01-01T00:00:00'
+
+    transforms:
+      - type: set
+        field: env
+        value: prod
+      - type: drop
+        field: password
+      - type: rename
+        field: msg
+        to: message
+
+    analysis:
+      window_seconds: 60
+      anomaly_z: 2.5
+      top_messages: 10
+"""
+from __future__ import annotations
+
+import sys
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Optional
+
+import yaml
+
+
+@dataclass
+class AnalysisConfig:
+    window_seconds: int = 60
+    anomaly_z: float = 2.5
+    top_messages: int = 10
+
+
+@dataclass
+class Config:
+    filters: List[Dict[str, Any]] = field(default_factory=list)
+    transforms: List[Dict[str, Any]] = field(default_factory=list)
+    custom_parsers: List[Dict[str, Any]] = field(default_factory=list)
+    analysis: AnalysisConfig = field(default_factory=AnalysisConfig)
+
+    @classmethod
+    def load(cls, path: Optional[str]) -> "Config":
+        if not path:
+            return cls()
+        try:
+            with open(path, "r", encoding="utf-8") as fh:
+                data = yaml.safe_load(fh) or {}
+        except (OSError, yaml.YAMLError) as exc:
+            print(f"logpipe: warning: could not load config {path!r}: {exc}", file=sys.stderr)
+            return cls()
+
+        an = data.get("analysis") or {}
+        return cls(
+            filters=list(data.get("filters") or []),
+            transforms=list(data.get("transforms") or []),
+            custom_parsers=list((data.get("parsers") or {}).get("custom") or []),
+            analysis=AnalysisConfig(
+                window_seconds=int(an.get("window_seconds", 60)),
+                anomaly_z=float(an.get("anomaly_z", 2.5)),
+                top_messages=int(an.get("top_messages", 10)),
+            ),
+        )
