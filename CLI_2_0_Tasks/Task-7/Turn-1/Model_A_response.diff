new file mode 100644
index 0000000..5399eda
--- /dev/null
+++ b/src/logpipe/parsers/base.py
@@ -0,0 +1,32 @@
+"""Parser base class.
+
+A parser takes one raw line and returns a :class:`LogEvent` if it can make
+sense of it, or ``None`` if it cannot. Parsers must never raise on malformed
+input — the pipeline relies on ``None`` to count and skip bad lines without
+crashing.
+"""
+from __future__ import annotations
+
+from abc import ABC, abstractmethod
+from typing import Optional
+
+from ..event import LogEvent
+
+
+class Parser(ABC):
+    #: short identifier shown in reports / detection output
+    name: str = "base"
+
+    @abstractmethod
+    def parse(self, line: str, source: str) -> Optional[LogEvent]:  # pragma: no cover
+        ...
+
+    def score(self, sample_lines: list[str]) -> float:
+        """Fraction of sample lines this parser successfully handles.
+
+        Used by auto-detection to pick the best parser for a file.
+        """
+        if not sample_lines:
+            return 0.0
+        ok = sum(1 for ln in sample_lines if self.parse(ln, "<detect>") is not None)
+        return ok / len(sample_lines)
diff --git a/src/logpipe/parsers/clf.py b/src/logpipe/parsers/clf.py
new file mode 100644
index 0000000..dcd1f43
--- /dev/null
+++ b/src/logpipe/parsers/clf.py
@@ -0,0 +1,66 @@
+"""Apache / nginx Common Log Format (and the Combined variant).
+
+``host ident authuser [date] "request" status bytes [ "referer" "ua" ]``
+
+HTTP access logs do not carry a syslog-style severity, so we synthesize one
+from the status code (5xx -> ERROR, 4xx -> WARNING, else INFO) so they can be
+mixed with other sources in severity breakdowns.
+"""
+from __future__ import annotations
+
+import re
+from datetime import datetime
+from typing import Optional
+
+from ..event import LogEvent
+from .base import Parser
+
+_PAT = re.compile(
+    r'^(?P<host>\S+)\s+\S+\s+\S+\s+'
+    r'\[(?P<ts>[^\]]+)\]\s+'
+    r'"(?P<request>[^"]*)"\s+'
+    r'(?P<status>\d{3})\s+'
+    r'(?P<bytes>\d+|-)'
+    r'(?:\s+"(?P<referer>[^"]*)"\s+"(?P<ua>[^"]*)")?'
+    r"\s*$"
+)
+
+
+def _level_for_status(status: int) -> str:
+    if status >= 500:
+        return "ERROR"
+    if status >= 400:
+        return "WARNING"
+    return "INFO"
+
+
+class CLFParser(Parser):
+    name = "clf"
+
+    def parse(self, line: str, source: str) -> Optional[LogEvent]:
+        m = _PAT.match(line.rstrip("\n"))
+        if not m:
+            return None
+        try:
+            ts = datetime.strptime(m["ts"], "%d/%b/%Y:%H:%M:%S %z")
+        except ValueError:
+            ts = None
+        status = int(m["status"])
+        size = m["bytes"]
+        extra = {
+            "status": status,
+            "bytes": int(size) if size != "-" else 0,
+            "request": m["request"],
+        }
+        if m.group("referer") is not None:
+            extra["referer"] = m["referer"]
+            extra["user_agent"] = m["ua"]
+        return LogEvent(
+            timestamp=ts,
+            level=_level_for_status(status),
+            message=m["request"] or line.rstrip("\n"),
+            source=source,
+            raw=line.rstrip("\n"),
+            host=m["host"],
+            extra=extra,
+        )
diff --git a/src/logpipe/parsers/detect.py b/src/logpipe/parsers/detect.py
new file mode 100644
index 0000000..e7e7d4e
--- /dev/null
+++ b/src/logpipe/parsers/detect.py
@@ -0,0 +1,74 @@
+"""Format auto-detection.
+
+We sample the first few non-blank lines of a file, ask every registered parser
+to score itself against the sample, and pick the highest scorer above a
+confidence floor. If nothing clears the floor we fall back to the JSON-lines
+parser (which degrades gracefully to "whole line as message" for non-JSON).
+"""
+from __future__ import annotations
+
+import sys
+from typing import List, Optional, Sequence
+
+from .base import Parser
+from .jsonl import JSONLinesParser
+from .syslog import SyslogParser
+from .clf import CLFParser
+from .regex import RegexParser
+
+
+def build_registry(custom: Optional[Sequence[dict]] = None) -> List[Parser]:
+    """Built-in parsers plus any custom regex parsers from config."""
+    reg: List[Parser] = [JSONLinesParser(), SyslogParser(), CLFParser()]
+    for spec in custom or []:
+        try:
+            reg.append(
+                RegexParser(
+                    name=spec["name"],
+                    pattern=spec["pattern"],
+                    time_format=spec.get("time_format"),
+                )
+            )
+        except (KeyError, Exception) as exc:  # noqa: BLE001 — config errors must not crash
+            print(f"logpipe: warning: skipping custom parser {spec!r}: {exc}", file=sys.stderr)
+    return reg
+
+
+def _sample(path: str, n: int = 25) -> List[str]:
+    lines: List[str] = []
+    with open(path, "r", encoding="utf-8", errors="replace") as fh:
+        for raw in fh:
+            if raw.strip():
+                lines.append(raw)
+            if len(lines) >= n:
+                break
+    return lines
+
+
+def detect_parser(
+    path: str,
+    registry: Sequence[Parser],
+    *,
+    min_confidence: float = 0.5,
+) -> tuple[Parser, float]:
+    """Return ``(parser, confidence)`` for *path*.
+
+    Never raises on I/O errors — callers handle the unreadable-file case
+    separately, but if sampling itself fails we return the fallback at 0.0.
+    """
+    try:
+        sample = _sample(path)
+    except OSError:
+        return registry[0], 0.0
+
+    best: Parser = registry[0]
+    best_score = -1.0
+    for p in registry:
+        s = p.score(sample)
+        if s > best_score:
+            best, best_score = p, s
+    if best_score < min_confidence:
+        # Nobody is confident — keep the best guess but report the low score so
+        # the caller can warn the user.
+        return best, best_score
+    return best, best_score
