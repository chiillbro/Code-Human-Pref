@@ -0,0 +1,80 @@
+"""Normalized log event model shared by every parser, filter and analyzer."""
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from datetime import datetime
+from typing import Any, Dict, Optional
+
+
+# Canonical ordering for severity comparison / filtering.
+LEVEL_ORDER = {
+    "TRACE": 5,
+    "DEBUG": 10,
+    "INFO": 20,
+    "NOTICE": 25,
+    "WARNING": 30,
+    "ERROR": 40,
+    "CRITICAL": 50,
+    "ALERT": 60,
+    "EMERGENCY": 70,
+}
+
+_LEVEL_ALIASES = {
+    "WARN": "WARNING",
+    "ERR": "ERROR",
+    "FATAL": "CRITICAL",
+    "CRIT": "CRITICAL",
+    "EMERG": "EMERGENCY",
+    "PANIC": "EMERGENCY",
+}
+
+
+def normalize_level(value: Any) -> Optional[str]:
+    """Map an arbitrary level token to one of the canonical names, or None."""
+    if value is None:
+        return None
+    s = str(value).strip().upper()
+    if not s:
+        return None
+    s = _LEVEL_ALIASES.get(s, s)
+    return s if s in LEVEL_ORDER else None
+
+
+@dataclass
+class LogEvent:
+    """A single log line after format-specific parsing.
+
+    Every parser produces these so the rest of the pipeline (filters,
+    transforms, analysis, reporting) is format-agnostic.
+    """
+
+    timestamp: Optional[datetime]
+    level: Optional[str]
+    message: str
+    source: str
+    raw: str
+    host: Optional[str] = None
+    extra: Dict[str, Any] = field(default_factory=dict)
+
+    def get(self, name: str, default: Any = None) -> Any:
+        """Field access that falls back to ``extra`` — used by filters/transforms."""
+        if name in ("timestamp", "level", "message", "source", "raw", "host"):
+            return getattr(self, name)
+        return self.extra.get(name, default)
+
+    def set(self, name: str, value: Any) -> None:
+        if name in ("timestamp", "level", "message", "source", "raw", "host"):
+            setattr(self, name, value)
+        else:
+            self.extra[name] = value
+
+    def to_dict(self) -> Dict[str, Any]:
+        d: Dict[str, Any] = {
+            "timestamp": self.timestamp.isoformat() if self.timestamp else None,
+            "level": self.level,
+            "message": self.message,
+            "source": self.source,
+            "host": self.host,
+        }
+        d.update(self.extra)
+        return d
