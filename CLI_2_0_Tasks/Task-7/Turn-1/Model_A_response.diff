@@ -0,0 +1,134 @@
+"""``logpipe tail`` — follow files in real time through the same pipeline.
+
+Pure-stdlib polling tail (no inotify): each tracked file remembers its last
+read offset and inode. On every tick we read any new bytes, push complete lines
+through the parser/filter/transform chain, print matching events, and feed a
+rolling :class:`Analyzer` whose summary is re-rendered every ``--refresh``
+seconds.
+
+Rotation is detected by inode change or file shrink, in which case we reopen
+from the start.
+"""
+from __future__ import annotations
+
+import os
+import sys
+import time
+from typing import List, Optional, Sequence
+
+from .analysis import Analyzer
+from .config import Config
+from .parsers import Parser, detect_parser
+from .pipeline import Pipeline
+
+
+class _Tracked:
+    def __init__(self, path: str, parser: Parser, from_start: bool) -> None:
+        self.path = path
+        self.parser = parser
+        self.buf = ""
+        self.fh = None
+        self.inode: Optional[int] = None
+        self._open(seek_end=not from_start)
+
+    def _open(self, *, seek_end: bool) -> None:
+        try:
+            self.fh = open(self.path, "r", encoding="utf-8", errors="replace")
+            st = os.fstat(self.fh.fileno())
+            self.inode = st.st_ino
+            if seek_end:
+                self.fh.seek(0, os.SEEK_END)
+        except OSError as exc:
+            print(f"logpipe: warning: cannot open {self.path!r}: {exc}", file=sys.stderr)
+            self.fh = None
+            self.inode = None
+
+    def _maybe_reopen(self) -> None:
+        try:
+            st = os.stat(self.path)
+        except OSError:
+            return
+        if self.fh is None or st.st_ino != self.inode or st.st_size < self.fh.tell():
+            if self.fh:
+                self.fh.close()
+            self.buf = ""
+            self._open(seek_end=False)
+
+    def poll(self) -> List[str]:
+        self._maybe_reopen()
+        if self.fh is None:
+            return []
+        chunk = self.fh.read()
+        if not chunk:
+            return []
+        self.buf += chunk
+        lines: List[str] = []
+        while "\n" in self.buf:
+            line, self.buf = self.buf.split("\n", 1)
+            if line.strip():
+                lines.append(line)
+        return lines
+
+
+def _format_event(ev) -> str:
+    ts = ev.timestamp.isoformat(sep=" ", timespec="seconds") if ev.timestamp else "-"
+    lvl = ev.level or "-"
+    return f"[{ts}] {lvl:<8} {ev.source}: {ev.message}"
+
+
+def run_tail(
+    paths: Sequence[str],
+    config: Config,
+    *,
+    interval: float = 0.5,
+    refresh: float = 5.0,
+    from_start: bool = False,
+) -> int:
+    pipe = Pipeline(config)
+    analyzer = Analyzer(config.analysis)
+
+    tracked: List[_Tracked] = []
+    for p in paths:
+        parser, conf = detect_parser(p, pipe.registry)
+        print(f"logpipe: following {p} (format: {parser.name}, confidence {conf:.0%})",
+              file=sys.stderr)
+        tracked.append(_Tracked(p, parser, from_start))
+
+    last_refresh = time.monotonic()
+    try:
+        while True:
+            activity = False
+            for t in tracked:
+                for line in t.poll():
+                    activity = True
+                    ev = pipe.process_line(line, t.parser, t.path)
+                    if ev is None:
+                        continue
+                    analyzer.feed(ev)
+                    print(_format_event(ev))
+            now = time.monotonic()
+            if now - last_refresh >= refresh:
+                _print_rolling_summary(analyzer)
+                last_refresh = now
+            if not activity:
+                time.sleep(interval)
+    except KeyboardInterrupt:
+        print("\nlogpipe: interrupted — final summary:", file=sys.stderr)
+        _print_rolling_summary(analyzer)
+        return 0
+
+
+def _print_rolling_summary(analyzer: Analyzer) -> None:
+    res = analyzer.result()
+    levels = ", ".join(f"{k}={v}" for k, v in sorted(res.by_level.items(), key=lambda kv: -kv[1]))
+    anom = f", {len(res.anomalies)} anomalous window(s)" if res.anomalies else ""
+    print(
+        f"--- summary: {res.total} events | {levels or 'no levels'} | "
+        f"{len(res.windows)} x {res.window_seconds}s windows{anom} ---",
+        file=sys.stderr,
+    )
+    for a in res.anomalies[-3:]:
+        print(
+            f"    {a.kind.upper()} at {a.window_start.isoformat()} count={a.count} z={a.z_score:.2f}",
+            file=sys.stderr,
+        )
