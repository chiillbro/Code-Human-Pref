new file mode 100644
index 0000000..8fc5779
--- /dev/null
+++ b/src/logpipe/parsers/jsonl.py
@@ -0,0 +1,86 @@
+"""JSON-lines parser.
+
+Handles structured logs where each line is a JSON object. Field names vary a
+lot in the wild so we probe a list of common aliases for timestamp / level /
+message and dump everything else into ``extra``.
+"""
+from __future__ import annotations
+
+import json
+from datetime import datetime, timezone
+from typing import Any, Optional
+
+from ..event import LogEvent, normalize_level
+from .base import Parser
+
+_TS_KEYS = ("timestamp", "time", "ts", "@timestamp", "asctime", "date")
+_LEVEL_KEYS = ("level", "severity", "lvl", "levelname", "loglevel")
+_MSG_KEYS = ("message", "msg", "text", "event", "log")
+_HOST_KEYS = ("host", "hostname", "node")
+
+
+def _parse_ts(value: Any) -> Optional[datetime]:
+    if value is None:
+        return None
+    if isinstance(value, (int, float)):
+        # Heuristic: > 1e12 means milliseconds since epoch.
+        try:
+            if value > 1e12:
+                value = value / 1000.0
+            return datetime.fromtimestamp(value, tz=timezone.utc)
+        except (OverflowError, OSError, ValueError):
+            return None
+    s = str(value).strip()
+    if not s:
+        return None
+    # ISO-8601 (allow trailing Z)
+    try:
+        return datetime.fromisoformat(s.replace("Z", "+00:00"))
+    except ValueError:
+        pass
+    for fmt in ("%Y-%m-%d %H:%M:%S,%f", "%Y-%m-%d %H:%M:%S", "%d/%b/%Y:%H:%M:%S %z"):
+        try:
+            return datetime.strptime(s, fmt)
+        except ValueError:
+            continue
+    return None
+
+
+def _first(d: dict, keys: tuple[str, ...]) -> tuple[Optional[str], Any]:
+    for k in keys:
+        if k in d:
+            return k, d[k]
+    return None, None
+
+
+class JSONLinesParser(Parser):
+    name = "jsonl"
+
+    def parse(self, line: str, source: str) -> Optional[LogEvent]:
+        s = line.strip()
+        if not s or s[0] not in "{[":
+            return None
+        try:
+            obj = json.loads(s)
+        except (json.JSONDecodeError, ValueError):
+            return None
+        if not isinstance(obj, dict):
+            return None
+
+        ts_key, ts_raw = _first(obj, _TS_KEYS)
+        lvl_key, lvl_raw = _first(obj, _LEVEL_KEYS)
+        msg_key, msg_raw = _first(obj, _MSG_KEYS)
+        host_key, host_raw = _first(obj, _HOST_KEYS)
+
+        used = {ts_key, lvl_key, msg_key, host_key}
+        extra = {k: v for k, v in obj.items() if k not in used}
+
+        return LogEvent(
+            timestamp=_parse_ts(ts_raw),
+            level=normalize_level(lvl_raw),
+            message=str(msg_raw) if msg_raw is not None else s,
+            source=source,
+            raw=line.rstrip("\n"),
+            host=str(host_raw) if host_raw is not None else None,
+            extra=extra,
+        )
diff --git a/src/logpipe/parsers/regex.py b/src/logpipe/parsers/regex.py
new file mode 100644
index 0000000..b816477
--- /dev/null
+++ b/src/logpipe/parsers/regex.py
@@ -0,0 +1,52 @@
+"""User-defined regex parser.
+
+Lets the config file describe a custom format with a regex containing named
+groups. Recognised group names: ``timestamp``, ``level``, ``message``, ``host``;
+any other group is stored in ``extra``.
+"""
+from __future__ import annotations
+
+import re
+from datetime import datetime
+from typing import Optional
+
+from ..event import LogEvent, normalize_level
+from .base import Parser
+
+
+class RegexParser(Parser):
+    def __init__(self, name: str, pattern: str, time_format: Optional[str] = None) -> None:
+        self.name = name
+        self._re = re.compile(pattern)
+        self._time_format = time_format
+
+    def parse(self, line: str, source: str) -> Optional[LogEvent]:
+        m = self._re.match(line.rstrip("\n"))
+        if not m:
+            return None
+        gd = m.groupdict()
+        ts = None
+        ts_raw = gd.pop("timestamp", None)
+        if ts_raw and self._time_format:
+            try:
+                ts = datetime.strptime(ts_raw, self._time_format)
+            except ValueError:
+                ts = None
+        elif ts_raw:
+            try:
+                ts = datetime.fromisoformat(ts_raw.replace("Z", "+00:00"))
+            except ValueError:
+                ts = None
+        level = normalize_level(gd.pop("level", None))
+        message = gd.pop("message", None) or line.rstrip("\n")
+        host = gd.pop("host", None)
+        extra = {k: v for k, v in gd.items() if v is not None}
+        return LogEvent(
+            timestamp=ts,
+            level=level,
+            message=message,
+            source=source,
+            raw=line.rstrip("\n"),
+            host=host,
+            extra=extra,
+        )
diff --git a/src/logpipe/parsers/syslog.py b/src/logpipe/parsers/syslog.py
new file mode 100644
index 0000000..320daf6
--- /dev/null
+++ b/src/logpipe/parsers/syslog.py
@@ -0,0 +1,72 @@
+"""RFC-3164 (BSD syslog) parser.
+
+Covers the classic ``<PRI>MMM dd HH:MM:SS host proc[pid]: message`` shape and
+the very common variant without the ``<PRI>`` prefix (what you usually see in
+``/var/log/syslog``). The year is not encoded in RFC-3164 so we default to the
+current year.
+"""
+from __future__ import annotations
+
+import re
+from datetime import datetime
+from typing import Optional
+
+from ..event import LogEvent, normalize_level
+from .base import Parser
+
+# severity portion of the PRI value (RFC 5424 table 2)
+_SYSLOG_SEVERITY = {
+    0: "EMERGENCY",
+    1: "ALERT",
+    2: "CRITICAL",
+    3: "ERROR",
+    4: "WARNING",
+    5: "NOTICE",
+    6: "INFO",
+    7: "DEBUG",
+}
+
+_PAT = re.compile(
+    r"^(?:<(?P<pri>\d{1,3})>)?"
+    r"(?P<ts>[A-Z][a-z]{2}\s+\d{1,2}\s+\d{2}:\d{2}:\d{2})\s+"
+    r"(?P<host>[^\s]+)\s+"
+    r"(?P<proc>[^\s\[:]+)(?:\[(?P<pid>\d+)\])?:\s?"
+    r"(?P<msg>.*)$"
+)
+
+
+class SyslogParser(Parser):
+    name = "syslog"
+
+    def __init__(self, default_year: Optional[int] = None) -> None:
+        self._year = default_year or datetime.now().year
+
+    def parse(self, line: str, source: str) -> Optional[LogEvent]:
+        m = _PAT.match(line.rstrip("\n"))
+        if not m:
+            return None
+        try:
+            ts = datetime.strptime(f"{self._year} {m['ts']}", "%Y %b %d %H:%M:%S")
+        except ValueError:
+            ts = None
+
+        level = None
+        pri = m.group("pri")
+        if pri is not None:
+            level = _SYSLOG_SEVERITY.get(int(pri) & 7)
+
+        extra = {"process": m["proc"]}
+        if m.group("pid"):
+            extra["pid"] = int(m["pid"])
+        if pri is not None:
+            extra["facility"] = int(pri) >> 3
+
+        return LogEvent(
+            timestamp=ts,
+            level=normalize_level(level),
+            message=m["msg"],
+            source=source,
+            raw=line.rstrip("\n"),
+            host=m["host"],
+            extra=extra,
+        )
diff --git a/src/logpipe/pipeline.py b/src/logpipe/pipeline.py
new file mode 100644
index 0000000..233a56b
--- /dev/null
+++ b/src/logpipe/pipeline.py
@@ -0,0 +1,103 @@
+"""Ingestion pipeline: files -> parsed, filtered, transformed events.
+
+This module owns the resilience guarantees:
+
+* unreadable files are reported and skipped, never fatal;
+* lines a parser cannot handle are counted and skipped;
+* the generator keeps yielding regardless of per-line failures.
+"""
+from __future__ import annotations
+
+import sys
+from dataclasses import dataclass, field
+from typing import Dict, Iterable, Iterator, List, Sequence
+
+from .config import Config
+from .event import LogEvent
+from .filters import Predicate, Transform, apply_pipeline, build_filters, build_transforms
+from .parsers import Parser, build_registry, detect_parser
+
+
+@dataclass
+class IngestStats:
+    files_ok: List[str] = field(default_factory=list)
+    files_failed: Dict[str, str] = field(default_factory=dict)  # path -> reason
+    parsers_used: Dict[str, str] = field(default_factory=dict)  # path -> parser name
+    lines_read: int = 0
+    lines_malformed: int = 0
+    events_emitted: int = 0
+    events_filtered: int = 0
+
+
+class Pipeline:
+    def __init__(self, config: Config) -> None:
+        self.config = config
+        self.registry: List[Parser] = build_registry(config.custom_parsers)
+        self.filters: List[Predicate] = build_filters(config.filters)
+        self.transforms: List[Transform] = build_transforms(config.transforms)
+
+    # -- batch ------------------------------------------------------------
+
+    def read_paths(self, paths: Sequence[str]) -> tuple[Iterator[LogEvent], IngestStats]:
+        stats = IngestStats()
+
+        def gen() -> Iterator[LogEvent]:
+            for path in paths:
+                yield from self._read_one(path, stats)
+
+        return gen(), stats
+
+    def _read_one(self, path: str, stats: IngestStats) -> Iterator[LogEvent]:
+        try:
+            fh = open(path, "r", encoding="utf-8", errors="replace")
+        except OSError as exc:
+            stats.files_failed[path] = str(exc)
+            print(f"logpipe: warning: cannot open {path!r}: {exc}", file=sys.stderr)
+            return
+        try:
+            parser, conf = detect_parser(path, self.registry)
+        except Exception as exc:  # noqa: BLE001 — detection must never be fatal
+            fh.close()
+            stats.files_failed[path] = f"detect: {exc}"
+            print(f"logpipe: warning: cannot inspect {path!r}: {exc}", file=sys.stderr)
+            return
+        stats.parsers_used[path] = parser.name
+        if conf < 0.5:
+            print(
+                f"logpipe: warning: low confidence ({conf:.0%}) detecting format of "
+                f"{path!r}; using {parser.name}",
+                file=sys.stderr,
+            )
+        stats.files_ok.append(path)
+        with fh:
+            yield from self._consume(fh, parser, path, stats)
+
+    def _consume(
+        self,
+        lines: Iterable[str],
+        parser: Parser,
+        source: str,
+        stats: IngestStats,
+    ) -> Iterator[LogEvent]:
+        for raw in lines:
+            if not raw.strip():
+                continue
+            stats.lines_read += 1
+            ev = parser.parse(raw, source)
+            if ev is None:
+                stats.lines_malformed += 1
+                continue
+            out = apply_pipeline(ev, self.filters, self.transforms)
+            if out is None:
+                stats.events_filtered += 1
+                continue
+            stats.events_emitted += 1
+            yield out
+
+    # -- streaming (used by tail) ----------------------------------------
+
+    def process_line(self, raw: str, parser: Parser, source: str) -> LogEvent | None:
+        ev = parser.parse(raw, source)
+        if ev is None:
+            return None
+        return apply_pipeline(ev, self.filters, self.transforms)
diff --git a/src/logpipe/report.py b/src/logpipe/report.py
new file mode 100644
index 0000000..d754724
--- /dev/null
+++ b/src/logpipe/report.py
@@ -0,0 +1,103 @@
+"""Render an :class:`AnalysisResult` + ingest stats as JSON and as prose."""
+from __future__ import annotations
+
+import json
+from typing import Any, Dict
+
+from .analysis import AnalysisResult
+from .pipeline import IngestStats
+
+
+def build_report(result: AnalysisResult, stats: IngestStats) -> Dict[str, Any]:
+    return {
+        "ingest": {
+            "files_ok": stats.files_ok,
+            "files_failed": stats.files_failed,
+            "parsers_used": stats.parsers_used,
+            "lines_read": stats.lines_read,
+            "lines_malformed": stats.lines_malformed,
+            "events_emitted": stats.events_emitted,
+            "events_filtered": stats.events_filtered,
+        },
+        "analysis": result.to_dict(),
+    }
+
+
+def to_json(report: Dict[str, Any]) -> str:
+    return json.dumps(report, indent=2, default=str)
+
+
+def _fmt_span(first: str | None, last: str | None) -> str:
+    if not first or not last:
+        return "an unknown time range (no timestamps found)"
+    return f"{first} to {last}"
+
+
+def to_text(report: Dict[str, Any]) -> str:
+    ing = report["ingest"]
+    an = report["analysis"]
+    lines: list[str] = []
+
+    n_files = len(ing["files_ok"])
+    lines.append(
+        f"Analyzed {an['total_events']} events from {n_files} file(s) "
+        f"spanning {_fmt_span(an['time_range']['first'], an['time_range']['last'])}."
+    )
+    if ing["files_failed"]:
+        for p, why in ing["files_failed"].items():
+            lines.append(f"  ! Skipped {p}: {why}")
+    if ing["lines_malformed"]:
+        lines.append(
+            f"  ! {ing['lines_malformed']} malformed line(s) were skipped "
+            f"({ing['lines_read']} read total)."
+        )
+    if ing["events_filtered"]:
+        lines.append(f"  - {ing['events_filtered']} event(s) removed by filters.")
+
+    lines.append("")
+    lines.append(f"Parsers chosen per file:")
+    for p, name in ing["parsers_used"].items():
+        lines.append(f"  {p}: {name}")
+
+    lines.append("")
+    lines.append("Severity breakdown:")
+    by_level = sorted(an["by_level"].items(), key=lambda kv: -kv[1])
+    for lvl, c in by_level:
+        lines.append(f"  {lvl:<10} {c}")
+
+    if an["by_host"]:
+        lines.append("")
+        lines.append("Top hosts:")
+        for h, c in sorted(an["by_host"].items(), key=lambda kv: -kv[1])[:5]:
+            lines.append(f"  {h:<20} {c}")
+
+    rates = an["rate_per_window"]
+    if rates:
+        counts = [w["count"] for w in rates]
+        avg = sum(counts) / len(counts)
+        peak = max(rates, key=lambda w: w["count"])
+        lines.append("")
+        lines.append(
+            f"Event rate: avg {avg:.1f} / {an['window_seconds']}s window across "
+            f"{len(rates)} windows; peak {peak['count']} at {peak['start']}."
+        )
+
+    if an["anomalies"]:
+        lines.append("")
+        lines.append(f"Flagged {len(an['anomalies'])} anomalous window(s):")
+        for a in an["anomalies"]:
+            lines.append(
+                f"  {a['kind'].upper():<5} at {a['window_start']}: "
+                f"{a['count']} events (z={a['z_score']})"
+            )
+    else:
+        lines.append("")
+        lines.append("No anomalous windows detected.")
+
+    if an["top_messages"]:
+        lines.append("")
+        lines.append("Most frequent message patterns:")
+        for m in an["top_messages"][:10]:
+            lines.append(f"  {m['count']:>6}  {m['signature']}")
+
+    return "\n".join(lines)
