@@ -0,0 +1,139 @@
+"""End-to-end smoke tests covering detection, resilience, analysis, reporting."""
+from __future__ import annotations
+
+import json
+import os
+import textwrap
+import unittest
+from tempfile import TemporaryDirectory
+
+from logpipe.analysis import Analyzer
+from logpipe.config import Config, AnalysisConfig
+from logpipe.parsers import JSONLinesParser, SyslogParser, CLFParser, build_registry, detect_parser
+from logpipe.pipeline import Pipeline
+from logpipe.report import build_report, to_json, to_text
+
+
+JSONL = "\n".join(
+    json.dumps({"ts": f"2026-04-19T10:{m:02d}:00Z", "level": lvl, "msg": msg})
+    for m, lvl, msg in [
+        (0, "info", "boot ok"),
+        (0, "warn", "disk 80%"),
+        (1, "error", "timeout after 53ms"),
+        (1, "error", "timeout after 7ms"),
+        (5, "info", "boot ok"),
+    ]
+) + "\nNOT JSON AT ALL\n"
+
+SYSLOG = textwrap.dedent(
+    """\
+    Apr 19 10:00:01 web1 nginx[123]: GET /health 200
+    Apr 19 10:00:30 web1 kernel: oom-killer invoked
+    <11>Apr 19 10:01:02 web1 app[77]: db connection refused
+    """
+)
+
+CLF = textwrap.dedent(
+    """\
+    127.0.0.1 - - [19/Apr/2026:10:00:00 +0000] "GET / HTTP/1.1" 200 512
+    127.0.0.1 - - [19/Apr/2026:10:00:10 +0000] "GET /missing HTTP/1.1" 404 0
+    10.0.0.5 - - [19/Apr/2026:10:00:20 +0000] "POST /api HTTP/1.1" 500 128 "-" "curl/8"
+    """
+)
+
+
+class ParserTests(unittest.TestCase):
+    def test_jsonl(self) -> None:
+        p = JSONLinesParser()
+        ev = p.parse('{"ts": "2026-04-19T10:00:00Z", "level": "warn", "msg": "hi"}', "x")
+        assert ev is not None
+        self.assertEqual(ev.level, "WARNING")
+        self.assertEqual(ev.message, "hi")
+        self.assertIsNone(p.parse("not json", "x"))
+
+    def test_syslog(self) -> None:
+        p = SyslogParser(default_year=2026)
+        ev = p.parse("<11>Apr 19 10:01:02 web1 app[77]: boom", "x")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")  # 11 & 7 == 3 -> ERROR
+        self.assertEqual(ev.host, "web1")
+        self.assertEqual(ev.extra["pid"], 77)
+
+    def test_clf(self) -> None:
+        p = CLFParser()
+        ev = p.parse(CLF.splitlines()[2], "x")
+        assert ev is not None
+        self.assertEqual(ev.level, "ERROR")
+        self.assertEqual(ev.extra["status"], 500)
+        self.assertEqual(ev.extra["user_agent"], "curl/8")
+
+
+class DetectTests(unittest.TestCase):
+    def test_detect_each_format(self) -> None:
+        reg = build_registry()
+        with TemporaryDirectory() as d:
+            for name, content, expect in [
+                ("a.jsonl", JSONL, "jsonl"),
+                ("b.syslog", SYSLOG, "syslog"),
+                ("c.clf", CLF, "clf"),
+            ]:
+                path = os.path.join(d, name)
+                with open(path, "w") as fh:
+                    fh.write(content)
+                parser, conf = detect_parser(path, reg)
+                self.assertEqual(parser.name, expect, f"{name}: got {parser.name}")
+                self.assertGreaterEqual(conf, 0.5)
+
+
+class PipelineTests(unittest.TestCase):
+    def test_resilience_and_report(self) -> None:
+        cfg = Config(
+            filters=[{"type": "exclude", "field": "message", "pattern": "health"}],
+            analysis=AnalysisConfig(window_seconds=60, anomaly_z=1.0),
+        )
+        pipe = Pipeline(cfg)
+        with TemporaryDirectory() as d:
+            paths = []
+            for name, content in [("a.jsonl", JSONL), ("b.syslog", SYSLOG), ("c.clf", CLF)]:
+                p = os.path.join(d, name)
+                with open(p, "w") as fh:
+                    fh.write(content)
+                paths.append(p)
+            paths.append(os.path.join(d, "does-not-exist.log"))  # must not crash
+
+            events, stats = pipe.read_paths(paths)
+            an = Analyzer(cfg.analysis)
+            an.feed_all(events)
+            res = an.result()
+
+        self.assertEqual(len(stats.files_ok), 3)
+        self.assertEqual(len(stats.files_failed), 1)
+        self.assertGreaterEqual(stats.lines_malformed, 1)  # the "NOT JSON" line
+        self.assertGreater(stats.events_filtered, 0)       # healthcheck excluded
+        self.assertGreater(res.total, 0)
+        self.assertIn("ERROR", res.by_level)
+        self.assertGreater(len(res.windows), 1)
+
+        report = build_report(res, stats)
+        js = to_json(report)
+        self.assertIn('"total_events"', js)
+        text = to_text(report)
+        self.assertIn("Analyzed", text)
+        self.assertIn("Severity breakdown", text)
+
+    def test_anomaly_spike(self) -> None:
+        an = Analyzer(AnalysisConfig(window_seconds=60, anomaly_z=1.5))
+        from datetime import datetime
+        from logpipe.event import LogEvent
+        # 5 quiet windows of 1 event, one window of 20
+        for minute in range(5):
+            an.feed(LogEvent(datetime(2026, 4, 19, 10, minute, 0), "INFO", "x", "s", "x"))
+        for _ in range(20):
+            an.feed(LogEvent(datetime(2026, 4, 19, 10, 5, 0), "ERROR", "boom", "s", "boom"))
+        res = an.result()
+        kinds = {a.kind for a in res.anomalies}
+        self.assertIn("spike", kinds)
+
+
+if __name__ == "__main__":
+    unittest.main()
