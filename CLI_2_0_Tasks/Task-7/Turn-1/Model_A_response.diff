index 0000000..3abbe57
--- /dev/null
+++ b/src/logpipe/cli.py
@@ -0,0 +1,106 @@
+"""Command-line entry point.  ``logpipe analyze`` / ``logpipe tail`` / ``logpipe detect``."""
+from __future__ import annotations
+
+import argparse
+import sys
+from typing import Sequence
+
+from .analysis import Analyzer
+from .config import Config
+from .parsers import build_registry, detect_parser
+from .pipeline import Pipeline
+from .report import build_report, to_json, to_text
+from .tail import run_tail
+
+
+def _cmd_analyze(args: argparse.Namespace) -> int:
+    cfg = Config.load(args.config)
+    if args.window:
+        cfg.analysis.window_seconds = args.window
+    pipe = Pipeline(cfg)
+    events, stats = pipe.read_paths(args.paths)
+    analyzer = Analyzer(cfg.analysis)
+    analyzer.feed_all(events)
+    result = analyzer.result()
+    report = build_report(result, stats)
+
+    if args.output:
+        with open(args.output, "w", encoding="utf-8") as fh:
+            fh.write(to_json(report))
+        print(f"logpipe: wrote JSON report to {args.output}", file=sys.stderr)
+
+    if args.format in ("json", "both"):
+        print(to_json(report))
+    if args.format in ("text", "both"):
+        if args.format == "both":
+            print("\n" + "=" * 60 + "\n")
+        print(to_text(report))
+
+    # non-zero exit if every input failed to open
+    return 0 if stats.files_ok or not args.paths else 1
+
+
+def _cmd_tail(args: argparse.Namespace) -> int:
+    cfg = Config.load(args.config)
+    if args.window:
+        cfg.analysis.window_seconds = args.window
+    return run_tail(
+        args.paths,
+        cfg,
+        interval=args.interval,
+        refresh=args.refresh,
+        from_start=args.from_start,
+    )
+
+
+def _cmd_detect(args: argparse.Namespace) -> int:
+    cfg = Config.load(args.config)
+    registry = build_registry(cfg.custom_parsers)
+    for p in args.paths:
+        parser, conf = detect_parser(p, registry)
+        print(f"{p}: {parser.name} (confidence {conf:.0%})")
+    return 0
+
+
+def build_parser() -> argparse.ArgumentParser:
+    ap = argparse.ArgumentParser(
+        prog="logpipe",
+        description="Normalize, filter, analyze and report on heterogeneous log files.",
+    )
+    sub = ap.add_subparsers(dest="cmd", required=True)
+
+    a = sub.add_parser("analyze", help="batch-analyze one or more log files")
+    a.add_argument("paths", nargs="+", help="log file(s) to analyze")
+    a.add_argument("-c", "--config", help="YAML config file")
+    a.add_argument("-o", "--output", help="write JSON report to this path")
+    a.add_argument("-w", "--window", type=int, help="override analysis window (seconds)")
+    a.add_argument(
+        "-f", "--format", choices=("text", "json", "both"), default="text",
+        help="what to print to stdout (default: text)",
+    )
+    a.set_defaults(func=_cmd_analyze)
+
+    t = sub.add_parser("tail", help="follow files in real time through the pipeline")
+    t.add_argument("paths", nargs="+", help="log file(s) to follow")
+    t.add_argument("-c", "--config", help="YAML config file")
+    t.add_argument("-w", "--window", type=int, help="override analysis window (seconds)")
+    t.add_argument("--interval", type=float, default=0.5, help="poll interval seconds")
+    t.add_argument("--refresh", type=float, default=5.0, help="summary refresh seconds")
+    t.add_argument("--from-start", action="store_true", help="read existing content first")
+    t.set_defaults(func=_cmd_tail)
+
+    d = sub.add_parser("detect", help="show which parser would be picked for each file")
+    d.add_argument("paths", nargs="+")
+    d.add_argument("-c", "--config", help="YAML config file")
+    d.set_defaults(func=_cmd_detect)
+
+    return ap
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":  # pragma: no cover
+    raise SystemExit(main())
