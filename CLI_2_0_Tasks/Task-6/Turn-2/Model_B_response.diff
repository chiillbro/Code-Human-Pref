+		assertEquals(utc(2026, 1, 1, 1, 0), result);
+	}
+
+	@Test
+	public void estimateNReturnsConservativeLowerBound() {
+		Date anchor = utc(2020, 1, 31, 0, 0);
+		Date target = utc(2026, 6, 15, 0, 0);
+		int n = service.estimateN(anchor, TimePeriod.MONTH, target);
+		// The estimate should be below or equal to the real index so the
+		// linear scan always converges forward, never backwards.
+		Date estimated = service.occurrence(anchor, TimePeriod.MONTH, n);
+		assert !estimated.after(target) :
+				"estimate overshoot: occurrence(" + n + ")=" + estimated + " > target=" + target;
+		// And it should be close — no more than 2 off.
+		Date nPlus2 = service.occurrence(anchor, TimePeriod.MONTH, n + 2);
+		assert !nPlus2.before(target) :
+				"estimate too low: occurrence(" + (n + 2) + ")=" + nPlus2 + " still before target=" + target;
+	}
+
+	@Test
