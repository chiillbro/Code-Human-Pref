+		// missing from the update (user deleted the item).
+		if (existingItems != null) {
+			for (Item existing : existingItems) {
+				if (!hasRecurrenceEnabled(existing)) {
+					continue;
+				}
+				Item inUpdate = findItemByTitle(updatedItems, existing.getTitle());
+				if (inUpdate == null) {
+					// Before flagging for cleanup, check whether the item
