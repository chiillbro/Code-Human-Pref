import java.math.BigDecimal;
import java.time.LocalDateTime;
import java.time.ZoneOffset;
import java.util.Collections;
import java.util.Date;
import java.util.List;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertNotNull;

/**
 * Integration tests that run against the embedded Mongo started by
 * {@link DataMongoTest}. These verify behaviour that unit-test mocks
 * cannot: the unique compound index, the derived query for pending
 * cleanup, and the full end-to-end engine against real persistence.
 *
 * <p>{@link RecurringTransactionService} normally gets a
 * {@link com.piggymetrics.account.client.StatisticsServiceClient}
 * injected via Feign. Under {@code @DataMongoTest} only Mongo-related
 * beans are loaded, so we supply the service and its stat-less
 * dependencies manually via the {@link IntegrationTestConfig} inner
 * configuration.
 */
@RunWith(SpringRunner.class)
@DataMongoTest
@Import(TransactionRepositoryIntegrationTest.IntegrationTestConfig.class)
public class TransactionRepositoryIntegrationTest {

	@Autowired
	private TransactionRepository transactionRepository;

	@Autowired
	private AccountRepository accountRepository;

	@Autowired
	private MongoTemplate mongoTemplate;

	@Autowired
	private RecurringTransactionService recurringTransactionService;

	/**
	 * {@code @MockBean} replaces the Feign-generated proxy for
	 * {@link StatisticsServiceClient} with a Mockito mock, avoiding the
	 * missing {@code FeignContext} under {@code @DataMongoTest}.
	 */
	@MockBean
	@SuppressWarnings("unused")
	private StatisticsServiceClient statisticsClient;

	private Date utc(int y, int m, int d) {
		return Date.from(LocalDateTime.of(y, m, d, 0, 0)
				.atZone(ZoneOffset.UTC).toInstant());
	}

	// ---- Unique index ----

	@Test
	public void uniqueIndexRejectsDuplicateTransaction() {
		Transaction first = new Transaction();
		first.setAccountName("idx-test");
		first.setSourceItemTitle("Salary");
		first.setScheduledDate(utc(2026, 5, 1));
		first.setType(TransactionType.INCOME);
		first.setStatus(TransactionStatus.POSTED);
		first.setAmount(new BigDecimal(1000));
		first.setCurrency(Currency.USD);
		first.setCreatedDate(new Date());
		transactionRepository.save(first);

		Transaction duplicate = new Transaction();
		duplicate.setAccountName("idx-test");
		duplicate.setSourceItemTitle("Salary");
		duplicate.setScheduledDate(utc(2026, 5, 1));
		duplicate.setType(TransactionType.INCOME);
		duplicate.setStatus(TransactionStatus.PENDING_REVIEW);
		duplicate.setAmount(new BigDecimal(2000));
		duplicate.setCurrency(Currency.EUR);
		duplicate.setCreatedDate(new Date());

		DuplicateKeyException thrown = null;
		try {
			transactionRepository.save(duplicate);
		} catch (DuplicateKeyException ex) {
			thrown = ex;
		}
		assertNotNull("expected DuplicateKeyException for same compound key", thrown);
	}

	@Test
	public void uniqueIndexAllowsSameDateDifferentType() {
		Transaction income = new Transaction();
		income.setAccountName("idx-type");
		income.setSourceItemTitle("Salary");
		income.setScheduledDate(utc(2026, 5, 1));
		income.setType(TransactionType.INCOME);
		income.setStatus(TransactionStatus.POSTED);
		income.setAmount(new BigDecimal(1000));
		income.setCurrency(Currency.USD);
		income.setCreatedDate(new Date());
		transactionRepository.save(income);

		Transaction expense = new Transaction();
		expense.setAccountName("idx-type");
		expense.setSourceItemTitle("Salary");
		expense.setScheduledDate(utc(2026, 5, 1));
		expense.setType(TransactionType.EXPENSE);
		expense.setStatus(TransactionStatus.POSTED);
		expense.setAmount(new BigDecimal(500));
		expense.setCurrency(Currency.USD);
		expense.setCreatedDate(new Date());
		// Must not throw: same (accountName, title, date) but different type.
		transactionRepository.save(expense);
	}

	// ---- Pending cleanup ----

	@Test
	public void deleteByAccountNameAndSourceItemTitleAndStatusRemovesOnlyPending() {
		String acct = "cleanup-test";
		String item = "Rent";

		Transaction posted = tx(acct, item, TransactionStatus.POSTED, utc(2026, 4, 1));
		Transaction skipped = tx(acct, item, TransactionStatus.SKIPPED, utc(2026, 4, 2));
		Transaction pending1 = tx(acct, item, TransactionStatus.PENDING_REVIEW, utc(2026, 4, 3));
		Transaction pending2 = tx(acct, item, TransactionStatus.PENDING_REVIEW, utc(2026, 4, 4));
		transactionRepository.save(posted);
		transactionRepository.save(skipped);
		transactionRepository.save(pending1);
		transactionRepository.save(pending2);

		transactionRepository.deleteByAccountNameAndSourceItemTitleAndStatus(
				acct, item, TransactionStatus.PENDING_REVIEW);

		List<Transaction> remaining = mongoTemplate.findAll(Transaction.class).stream()
				.filter(t -> acct.equals(t.getAccountName()) && item.equals(t.getSourceItemTitle()))
				.collect(java.util.stream.Collectors.toList());
		assertEquals(2, remaining.size());
		for (Transaction t : remaining) {
			assertNotNull("remaining should be non-pending",
					t.getStatus() == TransactionStatus.POSTED
							|| t.getStatus() == TransactionStatus.SKIPPED
							? "ok" : null);
		}
	}

	// ---- End-to-end engine ----

	@Test
	public void processAllAccountsGeneratesTransactionsInMongo() {
		// Seed an account with a daily recurring expense.
		Saving saving = new Saving();
		saving.setAmount(BigDecimal.ZERO);
		saving.setCurrency(Currency.USD);
		saving.setInterest(BigDecimal.ZERO);
		saving.setDeposit(false);
		saving.setCapitalization(false);

		Item coffee = new Item();
		coffee.setTitle("Coffee");
		coffee.setAmount(new BigDecimal("4.50"));
		coffee.setCurrency(Currency.USD);
		coffee.setPeriod(TimePeriod.DAY);
		coffee.setIcon("coffee");
		RecurrenceSettings r = new RecurrenceSettings();
		r.setEnabled(true);
		r.setAnchorDate(utc(2026, 6, 1));
		r.setAutoPost(true);
		r.setNextScheduledDate(utc(2026, 6, 1));
		coffee.setRecurrence(r);

		Account account = new Account();
		account.setName("e2e-test");
		account.setLastSeen(new Date());
		account.setSaving(saving);
		account.setExpenses(Collections.singletonList(coffee));
		accountRepository.save(account);

		// Run the engine as-of June 3 → due dates: Jun 1, 2, 3.
		recurringTransactionService.processAllAccounts(utc(2026, 6, 3));

		List<Transaction> txns = mongoTemplate.findAll(Transaction.class).stream()
				.filter(t -> "e2e-test".equals(t.getAccountName()))
				.collect(java.util.stream.Collectors.toList());
		assertEquals(3, txns.size());

		long posted = txns.stream()
				.filter(t -> t.getStatus() == TransactionStatus.POSTED).count();
		long pending = txns.stream()
				.filter(t -> t.getStatus() == TransactionStatus.PENDING_REVIEW).count();
		// Latest (Jun 3) is auto-posted; the two earlier are backfilled
		// → PENDING_REVIEW regardless of autoPost.
		assertEquals(1, posted);
		assertEquals(2, pending);

		// Cursor must have advanced past the last generated date.
		Account updated = accountRepository.findByName("e2e-test");
		Date nextScheduled = updated.getExpenses().get(0)
				.getRecurrence().getNextScheduledDate();
		assertEquals(utc(2026, 6, 4), nextScheduled);
	}

	private Transaction tx(String acct, String item, TransactionStatus status, Date scheduled) {
		Transaction t = new Transaction();
		t.setAccountName(acct);
		t.setSourceItemTitle(item);
		t.setType(TransactionType.EXPENSE);
		t.setStatus(status);
		t.setScheduledDate(scheduled);
		t.setAmount(BigDecimal.ONE);
		t.setCurrency(Currency.USD);
		t.setCreatedDate(new Date());
		return t;
	}

	/**
	 * Provides the non-Mongo beans that {@link RecurringTransactionService}
	 * needs. {@code @DataMongoTest} only boots the Mongo slice, so
	 * services are absent. The statistics client is handled by the
	 * {@code @MockBean} above; here we supply the real
	 * {@link RecurrenceService} and the engine.
	 */
	@org.springframework.boot.test.context.TestConfiguration
	static class IntegrationTestConfig {

		@org.springframework.context.annotation.Bean
		public RecurrenceService recurrenceService() {
			return new RecurrenceService(ZoneOffset.UTC);
		}

		@org.springframework.context.annotation.Bean
		public RecurringTransactionService recurringTransactionService() {
			return new RecurringTransactionService();
		}
	}
