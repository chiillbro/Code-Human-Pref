import com.piggymetrics.account.domain.transaction.TransactionStatus;
import com.piggymetrics.account.domain.transaction.TransactionType;
import com.piggymetrics.account.client.StatisticsServiceClient;
import com.piggymetrics.account.service.transaction.RecurrenceService;
import com.piggymetrics.account.service.transaction.RecurringTransactionService;
import org.junit.Test;
import org.junit.runner.RunWith;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.data.mongo.DataMongoTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.context.annotation.Import;
import org.springframework.dao.DuplicateKeyException;
