+	/**
+	 * Deletes any {@code PENDING_REVIEW} transactions belonging to items
+	 * that the update either removes entirely or flips to
+	 * non-recurring. Posted and skipped transactions are deliberately
+	 * left intact: they are historical records of money that moved (or
+	 * was explicitly ignored) and must not be rewritten when the user
+	 * edits their account settings.
+	 *
+	 * <p>Matches items across both incomes and expenses so that simply
+	 * moving an item between categories (same title) does not trigger
+	 * cleanup — only true removal does.
+	 */
+	private void cleanupOrphanedPendingTransactions(String accountName,
+			Account existing, Account update) {
+
+		List<Item> updatedAll = new ArrayList<>();
+		if (update.getIncomes() != null) {
+			updatedAll.addAll(update.getIncomes());
+		}
+		if (update.getExpenses() != null) {
+			updatedAll.addAll(update.getExpenses());
+		}
+
+		cleanupOrphansInList(accountName, existing.getIncomes(), updatedAll);
+		cleanupOrphansInList(accountName, existing.getExpenses(), updatedAll);
+	}
+
+	private void cleanupOrphansInList(String accountName, List<Item> existingItems,
+			List<Item> updatedAll) {
+		if (existingItems == null) {
+			return;
+		}
+		for (Item existingItem : existingItems) {
+			RecurrenceSettings existingRecurrence = existingItem.getRecurrence();
+			boolean wasRecurring = existingRecurrence != null
+					&& Boolean.TRUE.equals(existingRecurrence.getEnabled());
+			if (!wasRecurring) {
+				// Never generated transactions, so nothing can be orphaned.
+				continue;
+			}
+
+			Item updated = findItemByTitle(updatedAll, existingItem.getTitle());
+			boolean fullyRemoved = (updated == null);
+			boolean recurrenceDisabled = !fullyRemoved
+					&& (updated.getRecurrence() == null
+							|| !Boolean.TRUE.equals(updated.getRecurrence().getEnabled()));
+
+			if (!fullyRemoved && !recurrenceDisabled) {
+				continue;
+			}
+
+			long deleted = transactionRepository
+					.deleteByAccountNameAndSourceItemTitleAndStatus(
+							accountName, existingItem.getTitle(), TransactionStatus.PENDING_REVIEW);
+			if (deleted > 0) {
+				log.info("cleaned up {} pending transaction(s) for account={} item={} ({})",
+						deleted, accountName, existingItem.getTitle(),
+						fullyRemoved ? "item removed" : "recurrence disabled");
+			}
+		}
+	}
 }
