import org.springframework.data.mongodb.core.MongoTemplate;
import org.springframework.data.mongodb.core.index.MongoPersistentEntityIndexResolver;
import org.springframework.data.mongodb.core.mapping.MongoMappingContext;
import org.springframework.data.mongodb.core.query.Query;
import org.springframework.test.context.junit4.SpringRunner;

import java.math.BigDecimal;
import java.time.LocalDateTime;
import java.time.ZoneOffset;
import java.util.Collections;
import java.util.Date;
import java.util.List;

import static org.junit.Assert.assertEquals;
import static org.junit.Assert.assertNotNull;
import static org.junit.Assert.assertTrue;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.times;
import static org.mockito.Mockito.verify;

/**
 * End-to-end integration test for {@link RecurringTransactionService}
 * running against embedded Mongo. The unit tests mock the repository,
 * so they cannot catch serialisation bugs, missing indexes, or
 * misconfigured collection names. Exercising the full wiring here
 * fills that gap.
 */
@RunWith(SpringRunner.class)
@DataMongoTest
@Import({RecurringTransactionService.class, RecurrenceService.class, TransactionRepositoryImpl.class})
public class RecurringTransactionIntegrationTest {

	@Autowired
	private RecurringTransactionService service;

	@Autowired
	private AccountRepository accountRepository;

	@Autowired
	private TransactionRepository transactionRepository;

	@Autowired
	private MongoTemplate mongoTemplate;

	@Autowired
	private MongoMappingContext mongoMappingContext;

	@MockBean
	private StatisticsServiceClient statisticsClient;

	@Before
	public void cleanSlate() {
		// Ensure each test starts from an empty Mongo with the unique
		// index in place. Recreating indexes explicitly is sturdy
		// against cross-test interference in the shared embedded
		// instance.
		mongoTemplate.remove(new Query(), Transaction.class);
		mongoTemplate.remove(new Query(), Account.class);
		MongoPersistentEntityIndexResolver resolver =
				new MongoPersistentEntityIndexResolver(mongoMappingContext);
		resolver.resolveIndexForEntity(mongoMappingContext.getPersistentEntity(Transaction.class))
				.forEach(mongoTemplate.indexOps(Transaction.class)::ensureIndex);
	}

	private Date utc(int y, int m, int d) {
		return Date.from(LocalDateTime.of(y, m, d, 0, 0).atZone(ZoneOffset.UTC).toInstant());
	}

	private Account accountWithRecurringItem(String name, String itemTitle,
			TimePeriod period, Date anchor, boolean autoPost) {
		Item item = new Item();
		item.setTitle(itemTitle);
		item.setAmount(new BigDecimal(100));
		item.setCurrency(Currency.USD);
		item.setPeriod(period);
		item.setIcon("icon");

		RecurrenceSettings r = new RecurrenceSettings();
		r.setEnabled(true);
		r.setAnchorDate(anchor);
		r.setAutoPost(autoPost);
		r.setNextScheduledDate(anchor);
		item.setRecurrence(r);

		Saving saving = new Saving();
		saving.setAmount(new BigDecimal(0));
		saving.setCurrency(Currency.USD);
		saving.setInterest(new BigDecimal(0));
		saving.setDeposit(false);
		saving.setCapitalization(false);

		Account account = new Account();
		account.setName(name);
		account.setSaving(saving);
		account.setExpenses(Collections.singletonList(item));
		return account;
	}

	@Test
	public void processAllAccountsWritesTransactionsToMongoAndAdvancesCursor() {
		Account a = accountWithRecurringItem(
				"demo", "Rent", TimePeriod.DAY, utc(2026, 4, 17), true);
		accountRepository.save(a);

		// Now = Apr 19: three due dates (17, 18, 19).
		service.processAllAccounts(utc(2026, 4, 19));

		List<Transaction> saved = transactionRepository.findAll();
		assertEquals(3, saved.size());
		for (Transaction t : saved) {
			assertEquals("demo", t.getAccountName());
			assertEquals("Rent", t.getSourceItemTitle());
			assertEquals(TransactionType.EXPENSE, t.getType());
			assertNotNull(t.getId());
		}

		// Cursor persisted to Mongo: the next run would start at Apr 20.
		Account reloaded = accountRepository.findByName("demo");
		assertEquals(utc(2026, 4, 20),
				reloaded.getExpenses().get(0).getRecurrence().getNextScheduledDate());
		assertEquals(utc(2026, 4, 19),
				reloaded.getExpenses().get(0).getRecurrence().getLastGeneratedDate());

		// Statistics refresh fired once (the Apr 19 occurrence was
		// auto-posted; the two earlier dates were backfill/pending).
		verify(statisticsClient, times(1))
				.updateStatistics(eq("demo"), any(Account.class));
	}

	@Test
	public void rerunningProcessAllAccountsIsIdempotent() {
		// If a second cron instance fires (or the same one re-runs) and
		// sees the already-written transactions, the unique index
		// rejects the duplicates and the scheduler must not crash.
		Account a = accountWithRecurringItem(
				"demo", "Rent", TimePeriod.DAY, utc(2026, 4, 19), true);
		accountRepository.save(a);

		service.processAllAccounts(utc(2026, 4, 19));
		assertEquals(1, transactionRepository.findAll().size());

		// Simulate the other-instance race: reset the in-Mongo cursor
		// back to today so the engine "rediscovers" the same due date.
		Account aAgain = accountRepository.findByName("demo");
		aAgain.getExpenses().get(0).getRecurrence().setNextScheduledDate(utc(2026, 4, 19));
		aAgain.getExpenses().get(0).getRecurrence().setLastGeneratedDate(null);
		accountRepository.save(aAgain);

		// Second run — should silently skip the duplicate rather than blow up.
		service.processAllAccounts(utc(2026, 4, 19));

		// Still exactly one transaction in the collection.
		assertEquals(1, transactionRepository.findAll().size());
		// Cursor advanced again to Apr 20.
		Account reloaded = accountRepository.findByName("demo");
		assertEquals(utc(2026, 4, 20),
				reloaded.getExpenses().get(0).getRecurrence().getNextScheduledDate());
	}

	@Test
	public void processAllAccountsSkipsItemsWithoutRecurrence() {
		Item plain = new Item();
		plain.setTitle("Plain");
		plain.setAmount(new BigDecimal(10));
		plain.setCurrency(Currency.USD);
		plain.setPeriod(TimePeriod.DAY);
		plain.setIcon("icon");
		// No recurrence settings — should be ignored by the scheduler.

		Saving saving = new Saving();
		saving.setAmount(new BigDecimal(0));
		saving.setCurrency(Currency.USD);
		saving.setInterest(new BigDecimal(0));
		saving.setDeposit(false);
		saving.setCapitalization(false);

		Account a = new Account();
		a.setName("demo");
		a.setSaving(saving);
		a.setExpenses(Collections.singletonList(plain));
		accountRepository.save(a);

		service.processAllAccounts(utc(2026, 4, 19));

		assertTrue("non-recurring items must not produce transactions",
				transactionRepository.findAll().isEmpty());
	}

	@Test
	public void pendingTransactionsNotCreatedWhenAutoPostFalseAndOnDueDate() {
		Account a = accountWithRecurringItem(
				"demo", "Rent", TimePeriod.DAY, utc(2026, 4, 19), false);
		accountRepository.save(a);

		service.processAllAccounts(utc(2026, 4, 19));

		List<Transaction> saved = transactionRepository.findAll();
		assertEquals(1, saved.size());
		Transaction tx = saved.get(0);
		assertEquals(TransactionStatus.PENDING_REVIEW, tx.getStatus());
	}
}



package com.piggymetrics.account.repository;

import com.piggymetrics.account.domain.Currency;
import com.piggymetrics.account.domain.transaction.Transaction;
import com.piggymetrics.account.domain.transaction.TransactionStatus;
import com.piggymetrics.account.domain.transaction.TransactionType;
import org.junit.Before;
import org.junit.Test;
import org.junit.runner.RunWith;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.data.mongo.DataMongoTest;
import org.springframework.dao.DuplicateKeyException;
import org.springframework.data.mongodb.core.MongoTemplate;
import org.springframework.data.mongodb.core.index.MongoPersistentEntityIndexResolver;
import org.springframework.data.mongodb.core.mapping.MongoMappingContext;
import org.springframework.data.mongodb.core.query.Query;
import org.springframework.test.context.junit4.SpringRunner;

import java.math.BigDecimal;
import java.util.Date;

import static org.junit.Assert.fail;

/**
 * Integration test verifying the unique compound index on the
 * {@code transactions} collection actually prevents duplicate inserts
 * at the MongoDB level — the unit tests mock the repository, so they
 * cannot catch a mis-configured index annotation.
 */
@RunWith(SpringRunner.class)
@DataMongoTest
public class TransactionRepositoryIntegrationTest {

	@Autowired
	private TransactionRepository repository;

	@Autowired
	private MongoTemplate mongoTemplate;

	@Autowired
	private MongoMappingContext mongoMappingContext;

	@Before
	public void ensureCleanCollectionWithIndexes() {
		// Wipe any residual data from other tests in the same embedded
		// Mongo instance. We ensure indexes explicitly: the compound-
		// index auto-creator runs on entity discovery which might not
		// have happened yet when a fresh test class boots.
		mongoTemplate.remove(new Query(), Transaction.class);
		MongoPersistentEntityIndexResolver resolver =
				new MongoPersistentEntityIndexResolver(mongoMappingContext);
		resolver.resolveIndexForEntity(mongoMappingContext.getPersistentEntity(Transaction.class))
				.forEach(mongoTemplate.indexOps(Transaction.class)::ensureIndex);
	}

	private Transaction tx(String account, String title, TransactionType type, Date scheduled) {
		Transaction t = new Transaction();
		t.setAccountName(account);
		t.setSourceItemTitle(title);
		t.setType(type);
		t.setAmount(new BigDecimal(10));
		t.setCurrency(Currency.USD);
		t.setScheduledDate(scheduled);
		t.setCreatedDate(new Date());
		t.setStatus(TransactionStatus.POSTED);
		return t;
	}

	@Test
	public void uniqueCompoundIndexRejectsDuplicateScheduledOccurrence() {
		Date scheduled = new Date();
		repository.save(tx("demo", "Rent", TransactionType.EXPENSE, scheduled));

		try {
			// Same (accountName, sourceItemTitle, scheduledDate, type).
			repository.save(tx("demo", "Rent", TransactionType.EXPENSE, scheduled));
			fail("expected DuplicateKeyException from unique compound index");
		} catch (DuplicateKeyException expected) {
			// Ok — this is the contract the scheduler relies on to stay
			// idempotent across concurrent instances.
		}
	}

	@Test
	public void allowsDifferentScheduledDatesForSameItem() {
		repository.save(tx("demo", "Rent", TransactionType.EXPENSE, new Date(1_000_000L)));
		// No exception: same item, different scheduled date is fine —
		// each recurrence occurrence is its own unique key.
		repository.save(tx("demo", "Rent", TransactionType.EXPENSE, new Date(2_000_000L)));
	}

	@Test
	public void allowsSameScheduledDateForDifferentItems() {
		Date scheduled = new Date();
		repository.save(tx("demo", "Rent", TransactionType.EXPENSE, scheduled));
		// Different sourceItemTitle — not a duplicate even though
		// the scheduled date matches.
		repository.save(tx("demo", "Groceries", TransactionType.EXPENSE, scheduled));
	}

	@Test
	public void allowsSameScheduledDateForDifferentAccounts() {
		Date scheduled = new Date();
		repository.save(tx("alice", "Rent", TransactionType.EXPENSE, scheduled));
		// Different accountName — isolation between users.
		repository.save(tx("bob", "Rent", TransactionType.EXPENSE, scheduled));
	}

	@Test
	public void allowsSameScheduledDateForDifferentTypes() {
		// Contrived but legal: an item that moves category keeps the
		// previous type's history — the index segregates by type.
		Date scheduled = new Date();
		repository.save(tx("demo", "Coffee", TransactionType.EXPENSE, scheduled));
		repository.save(tx("demo", "Coffee", TransactionType.INCOME, scheduled));
	}
}
