+
+	private TransactionType type;
+
+	private BigDecimal amount;
+
+	private Currency currency;
+
+	/**
+	 * Title of the source {@link com.piggymetrics.account.domain.Item} that
+	 * generated this transaction. Items do not have a stable identifier of
+	 * their own, so the title is used as a soft reference.
+	 */
+	private String sourceItemTitle;
+
+	private TransactionStatus status;
+
+	/**
+	 * Date at which the occurrence was supposed to happen (based on the
+	 * item's recurrence anchor and period).
+	 */
+	private Date scheduledDate;
+
+	/**
+	 * Date at which the transaction was actually posted. Null until the
+	 * transaction leaves the pending state via auto-post or approval.
+	 */
+	private Date postedDate;
+
+	private Date createdDate;
+
+	/**
+	 * True if this transaction was created to backfill a missed schedule.
+	 * Backfilled transactions are always created in {@code PENDING_REVIEW}
+	 * regardless of the item's auto-post flag.
+	 */
+	private boolean backfilled;
+
+	public String getId() {
+		return id;
+	}
+
+	public void setId(String id) {
+		this.id = id;
+	}
+
+	public String getAccountName() {
+		return accountName;
+	}
+
+	public void setAccountName(String accountName) {
+		this.accountName = accountName;
+	}
+
+	public TransactionType getType() {
+		return type;
+	}
+
+	public void setType(TransactionType type) {
+		this.type = type;
+	}
+
+	public BigDecimal getAmount() {
+		return amount;
+	}
+
+	public void setAmount(BigDecimal amount) {
+		this.amount = amount;
+	}
+
+	public Currency getCurrency() {
+		return currency;
+	}
+
+	public void setCurrency(Currency currency) {
+		this.currency = currency;
+	}
+
+	public String getSourceItemTitle() {
+		return sourceItemTitle;
+	}
+
+	public void setSourceItemTitle(String sourceItemTitle) {
+		this.sourceItemTitle = sourceItemTitle;
+	}
+
+	public TransactionStatus getStatus() {
+		return status;
+	}
+
+	public void setStatus(TransactionStatus status) {
+		this.status = status;
+	}
+
+	public Date getScheduledDate() {
+		return scheduledDate;
+	}
+
+	public void setScheduledDate(Date scheduledDate) {
+		this.scheduledDate = scheduledDate;
+	}
+
+	public Date getPostedDate() {
+		return postedDate;
+	}
+
+	public void setPostedDate(Date postedDate) {
+		this.postedDate = postedDate;
+	}
+
+	public Date getCreatedDate() {
+		return createdDate;
+	}
+
+	public void setCreatedDate(Date createdDate) {
+		this.createdDate = createdDate;
+	}
