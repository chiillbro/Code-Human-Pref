+package com.piggymetrics.account.service.transaction;
+
+import com.piggymetrics.account.domain.transaction.Transaction;
+import com.piggymetrics.account.domain.transaction.TransactionStatus;
+import com.piggymetrics.account.domain.transaction.TransactionType;
+import org.springframework.data.domain.Page;
+import org.springframework.data.domain.Pageable;
+
+import java.util.Date;
+
+public interface TransactionService {
+
+	/**
+	 * Lists transactions for the given account, optionally filtered by
+	 * status, type and scheduled-date range, with pagination.
+	 */
+	Page<Transaction> list(String accountName,
+			TransactionStatus status,
+			TransactionType type,
+			Date from,
+			Date to,
+			Pageable pageable);
+
+	/**
+	 * Returns the transaction with the given id, asserting it belongs to
+	 * the given account.
+	 */
+	Transaction get(String accountName, String id);
+
+	/**
+	 * Approves a pending-review transaction, flipping its status to
+	 * {@code POSTED} and stamping the posted date.
+	 */
+	Transaction approve(String accountName, String id);
+
+	/**
+	 * Marks a pending-review transaction as {@code SKIPPED}.
+	 */
+	Transaction skip(String accountName, String id);
+
+	/**
+	 * Deletes a pending-review transaction. Posted/skipped transactions
+	 * are kept for audit and cannot be deleted via this API.
+	 */
+	void delete(String accountName, String id);
+}
diff --git a/account-service/src/main/java/com/piggymetrics/account/service/transaction/TransactionServiceImpl.java b/account-service/src/main/java/com/piggymetrics/account/service/transaction/TransactionServiceImpl.java
