@@ -0,0 +1,218 @@
+package com.piggymetrics.account.service.transaction;
+
+import com.piggymetrics.account.client.StatisticsServiceClient;
+import com.piggymetrics.account.domain.Account;
+import com.piggymetrics.account.domain.Item;
+import com.piggymetrics.account.domain.RecurrenceSettings;
+import com.piggymetrics.account.domain.transaction.Transaction;
+import com.piggymetrics.account.domain.transaction.TransactionStatus;
+import com.piggymetrics.account.domain.transaction.TransactionType;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.TransactionRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Service;
+
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.Date;
+import java.util.List;
+
+/**
+ * Core engine that materialises {@link Transaction} records from each
+ * account's recurring {@link Item}s. The scheduled entry point is
+ * {@link #processAllAccounts()}; {@link #processAccount(Account, Date)} is
+ * exposed for unit testing and for on-demand processing.
+ */
+@Service
+public class RecurringTransactionService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private TransactionRepository transactionRepository;
+
+	@Autowired
+	private RecurrenceService recurrenceService;
+
+	@Autowired
+	private StatisticsServiceClient statisticsClient;
+
+	/**
+	 * Maximum number of missed occurrences that will be backfilled in a
+	 * single run. When the gap between the item's next-scheduled date and
+	 * {@code now} exceeds this many periods, the oldest missed occurrences
+	 * are dropped and the job resumes from the most-recent
+	 * {@code maxBackfill} occurrences.
+	 */
+	@Value("${recurring.maxBackfill:30}")
+	private int maxBackfill;
+
+	/**
+	 * Runs the engine across every account. Invoked by
+	 * {@link RecurringTransactionJob} on a cron schedule, but can also be
+	 * driven manually in tests.
+	 */
+	public void processAllAccounts() {
+		processAllAccounts(new Date());
+	}
+
+	void processAllAccounts(Date now) {
+		log.info("starting recurring-transaction run at {}", now);
+		int accountsTouched = 0;
+		for (Account account : accountRepository.findAll()) {
+			if (processAccount(account, now) > 0) {
+				accountsTouched++;
+			}
+		}
+		log.info("recurring-transaction run complete; {} account(s) touched", accountsTouched);
+	}
+
+	/**
+	 * Processes a single account. Returns the number of transactions that
+	 * were created (across all items).
+	 */
+	public int processAccount(Account account, Date now) {
+		if (account == null) {
+			return 0;
+		}
+		int createdForAccount = 0;
+		createdForAccount += processItems(account, account.getIncomes(), TransactionType.INCOME, now);
+		createdForAccount += processItems(account, account.getExpenses(), TransactionType.EXPENSE, now);
+
+		if (createdForAccount > 0) {
+			accountRepository.save(account);
+
+			// At least one transaction was auto-posted or backfilled; keep
+			// the statistics service in sync with the new activity.
+			try {
+				statisticsClient.updateStatistics(account.getName(), account);
+			} catch (RuntimeException ex) {
+				log.warn("failed to update statistics for {} after recurring run",
+						account.getName(), ex);
+			}
+		}
+		return createdForAccount;
+	}
+
+	private int processItems(Account account, List<Item> items, TransactionType type, Date now) {
+		if (items == null || items.isEmpty()) {
+			return 0;
+		}
+		int created = 0;
+		for (Item item : items) {
+			created += processItem(account, item, type, now);
+		}
+		return created;
+	}
+
+	private int processItem(Account account, Item item, TransactionType type, Date now) {
+		RecurrenceSettings settings = item.getRecurrence();
+		if (settings == null
+				|| !Boolean.TRUE.equals(settings.getEnabled())
+				|| settings.getAnchorDate() == null
+				|| item.getPeriod() == null) {
+			return 0;
+		}
+
+		// Initialise the cursor if the user has just enabled recurrence
+		// without going through saveChanges (defensive).
+		if (settings.getNextScheduledDate() == null) {
+			settings.setNextScheduledDate(
+					recurrenceService.firstOccurrenceAtOrAfter(
+							settings.getAnchorDate(), item.getPeriod(), now));
+		}
+
+		List<Date> dueDates = collectDueDates(settings, item, now);
+		if (dueDates.isEmpty()) {
+			return 0;
+		}
+
+		boolean autoPost = Boolean.TRUE.equals(settings.getAutoPost());
+		// The most-recent due date represents the "current" on-time
+		// occurrence; everything earlier is considered backfill.
+		Date current = dueDates.get(dueDates.size() - 1);
+
+		List<Transaction> toSave = new ArrayList<>(dueDates.size());
+		for (Date scheduled : dueDates) {
+			boolean isCurrent = scheduled.equals(current);
+			boolean isBackfill = !isCurrent;
+			Transaction tx = buildTransaction(account, item, type, scheduled, now,
+					autoPost, isBackfill);
+			toSave.add(tx);
+		}
+		transactionRepository.saveAll(toSave);
+
+		// Advance the cursor past the latest occurrence we just generated.
+		settings.setLastGeneratedDate(current);
+		settings.setNextScheduledDate(
+				recurrenceService.nextAfter(settings.getAnchorDate(), item.getPeriod(), current));
+
+		log.debug("generated {} transaction(s) for account={} item={} (backfilled={})",
+				toSave.size(), account.getName(), item.getTitle(), toSave.size() - 1);
+		return toSave.size();
+	}
+
+	/**
+	 * Returns every occurrence from {@code nextScheduledDate} up to and
+	 * including {@code now}, in chronological order, capped at the
+	 * configured maximum. When the cap is hit, the oldest overflow dates
+	 * are discarded so that the window always ends at the current
+	 * occurrence.
+	 */
+	private List<Date> collectDueDates(RecurrenceSettings settings, Item item, Date now) {
+		Date cursor = settings.getNextScheduledDate();
+		if (cursor == null || cursor.after(now)) {
+			return Collections.emptyList();
+		}
+
+		List<Date> due = new ArrayList<>();
+		Date current = cursor;
+		// Guard against malformed state (e.g. an HOUR period that has been
+		// dormant for years) by stopping after a very large window; the
+		// cap below trims to the real limit.
+		int iterations = 0;
+		while (!current.after(now) && iterations < 10 * maxBackfill + 10) {
+			due.add(current);
+			current = recurrenceService.nextAfter(
+					settings.getAnchorDate(), item.getPeriod(), current);
+			iterations++;
+		}
+
+		if (due.size() > maxBackfill) {
+			// Keep the most recent `maxBackfill` occurrences so that the
+			// current on-time run is always preserved.
+			due = new ArrayList<>(due.subList(due.size() - maxBackfill, due.size()));
+		}
+		return due;
+	}
+
+	private Transaction buildTransaction(Account account, Item item, TransactionType type,
+			Date scheduled, Date now, boolean autoPost, boolean backfilled) {
+		Transaction tx = new Transaction();
+		tx.setAccountName(account.getName());
+		tx.setType(type);
+		tx.setAmount(item.getAmount());
+		tx.setCurrency(item.getCurrency());
+		tx.setSourceItemTitle(item.getTitle());
+		tx.setScheduledDate(scheduled);
+		tx.setCreatedDate(now);
+		tx.setBackfilled(backfilled);
+
+		// Backfilled transactions always require user review regardless of
+		// the item's autoPost flag: the user should confirm historical
+		// posts explicitly rather than having them silently applied.
+		if (backfilled || !autoPost) {
+			tx.setStatus(TransactionStatus.PENDING_REVIEW);
+		} else {
+			tx.setStatus(TransactionStatus.POSTED);
+			tx.setPostedDate(now);
+		}
+		return tx;
+	}
+}
