+import static org.mockito.MockitoAnnotations.initMocks;
+
+public class RecurringTransactionServiceTest {
+
+	@InjectMocks
+	private RecurringTransactionService service;
+
+	@Mock
+	private AccountRepository accountRepository;
+
+	@Mock
+	private TransactionRepository transactionRepository;
+
+	@Mock
+	private StatisticsServiceClient statisticsClient;
+
+	@Spy
+	private RecurrenceService recurrenceService = new RecurrenceService(ZoneOffset.UTC);
+
+	@Before
+	public void setup() {
+		initMocks(this);
+		ReflectionTestUtils.setField(service, "maxBackfill", 5);
+	}
+
+	private Date utc(int y, int m, int d) {
+		return Date.from(LocalDateTime.of(y, m, d, 0, 0).atZone(ZoneOffset.UTC).toInstant());
+	}
+
+	private Item recurringItem(String title, BigDecimal amount, TimePeriod period,
+			Date anchor, Boolean autoPost, Date next) {
+		Item item = new Item();
+		item.setTitle(title);
+		item.setAmount(amount);
+		item.setCurrency(Currency.USD);
+		item.setPeriod(period);
+		item.setIcon("icon");
+
+		RecurrenceSettings r = new RecurrenceSettings();
+		r.setEnabled(true);
+		r.setAnchorDate(anchor);
+		r.setAutoPost(autoPost);
+		r.setNextScheduledDate(next);
+		item.setRecurrence(r);
+		return item;
+	}
+
+	@Test
+	public void generatesSingleTransactionOnDueDateWhenAutoPostEnabled() {
+		Account account = new Account();
+		account.setName("demo");
+
+		Date anchor = utc(2026, 4, 19);
+		Item salary = recurringItem("Salary", new BigDecimal(1000), TimePeriod.MONTH,
+				anchor, true, anchor);
+		account.setIncomes(Collections.singletonList(salary));
+
+		int count = service.processAccount(account, utc(2026, 4, 19));
+
+		assertEquals(1, count);
+		ArgumentCaptor<List<Transaction>> captor = listCaptor();
+		verify(transactionRepository, times(1)).saveAll(captor.capture());
+		List<Transaction> saved = captor.getValue();
+		assertEquals(1, saved.size());
+		Transaction tx = saved.get(0);
+		assertEquals(TransactionStatus.POSTED, tx.getStatus());
+		assertEquals(TransactionType.INCOME, tx.getType());
+		assertEquals("Salary", tx.getSourceItemTitle());
+		assertEquals(utc(2026, 4, 19), tx.getScheduledDate());
+		assertNotNull(tx.getPostedDate());
+		assertFalse(tx.isBackfilled());
+
+		// Cursor advanced to next occurrence and lastGenerated stamped.
+		assertEquals(utc(2026, 5, 19), salary.getRecurrence().getNextScheduledDate());
+		assertEquals(utc(2026, 4, 19), salary.getRecurrence().getLastGeneratedDate());
+
+		// Statistics refreshed because activity was posted.
+		verify(statisticsClient, times(1)).updateStatistics(anyString(), any(Account.class));
+	}
+
+	@Test
+	public void generatesPendingReviewWhenAutoPostDisabled() {
+		Account account = new Account();
+		account.setName("demo");
+		Date anchor = utc(2026, 4, 19);
+		Item rent = recurringItem("Rent", new BigDecimal(500), TimePeriod.MONTH,
+				anchor, false, anchor);
+		account.setExpenses(Collections.singletonList(rent));
+
+		service.processAccount(account, utc(2026, 4, 19));
+
+		ArgumentCaptor<List<Transaction>> captor = listCaptor();
+		verify(transactionRepository).saveAll(captor.capture());
+		Transaction tx = captor.getValue().get(0);
+		assertEquals(TransactionStatus.PENDING_REVIEW, tx.getStatus());
+		assertEquals(TransactionType.EXPENSE, tx.getType());
+		assertNull(tx.getPostedDate());
+	}
+
+	@Test
+	public void backfillsMissedDatesAsPendingReviewEvenWhenAutoPostEnabled() {
+		// Daily item, anchor Apr 15, cursor Apr 15, now Apr 19 → 5 dates
+		// (15, 16, 17, 18, 19). Latest = current (auto-post),
+		// rest = backfill (pending_review).
+		Account account = new Account();
+		account.setName("demo");
+		Date anchor = utc(2026, 4, 15);
+		Item groceries = recurringItem("Groceries", new BigDecimal(10), TimePeriod.DAY,
+				anchor, true, anchor);
+		account.setExpenses(Collections.singletonList(groceries));
+
+		service.processAccount(account, utc(2026, 4, 19));
+
+		ArgumentCaptor<List<Transaction>> captor = listCaptor();
+		verify(transactionRepository).saveAll(captor.capture());
+		List<Transaction> saved = captor.getValue();
+		assertEquals(5, saved.size());
+		// The first four are backfill / pending_review:
+		for (int i = 0; i < 4; i++) {
+			Transaction t = saved.get(i);
+			assertTrue("expected backfilled for " + t.getScheduledDate(), t.isBackfilled());
+			assertEquals(TransactionStatus.PENDING_REVIEW, t.getStatus());
+		}
+		// The last is the current on-time occurrence: auto-posted.
+		Transaction current = saved.get(4);
+		assertFalse(current.isBackfilled());
+		assertEquals(TransactionStatus.POSTED, current.getStatus());
+		assertEquals(utc(2026, 4, 19), current.getScheduledDate());
+
+		// Cursor advanced past the latest we just generated.
+		assertEquals(utc(2026, 4, 20), groceries.getRecurrence().getNextScheduledDate());
+	}
+
+	@Test
+	public void capsBackfillAtConfiguredMaximumDroppingOldestMissed() {
+		ReflectionTestUtils.setField(service, "maxBackfill", 3);
+		Account account = new Account();
+		account.setName("demo");
+		Date anchor = utc(2026, 4, 10);
+		Item daily = recurringItem("Coffee", new BigDecimal(4), TimePeriod.DAY,
+				anchor, true, anchor);
+		account.setExpenses(Collections.singletonList(daily));
+
+		// 10 missed days (Apr 10..Apr 19) but cap is 3: keep the 3 most
+		// recent (Apr 17, 18, 19) and drop older.
+		service.processAccount(account, utc(2026, 4, 19));
+
+		ArgumentCaptor<List<Transaction>> captor = listCaptor();
+		verify(transactionRepository).saveAll(captor.capture());
+		List<Transaction> saved = captor.getValue();
+		assertEquals(3, saved.size());
+		assertEquals(utc(2026, 4, 17), saved.get(0).getScheduledDate());
+		assertEquals(utc(2026, 4, 18), saved.get(1).getScheduledDate());
+		assertEquals(utc(2026, 4, 19), saved.get(2).getScheduledDate());
+		// First two are backfilled pending-review.
+		assertEquals(TransactionStatus.PENDING_REVIEW, saved.get(0).getStatus());
+		assertEquals(TransactionStatus.PENDING_REVIEW, saved.get(1).getStatus());
+		// Latest is the current run and applies auto-post.
+		assertEquals(TransactionStatus.POSTED, saved.get(2).getStatus());
+	}
+
+	@Test
+	public void skipsItemsWithoutRecurrenceOrDisabled() {
+		Account account = new Account();
+		account.setName("demo");
+
+		Item plain = new Item();
+		plain.setTitle("Plain");
+		plain.setAmount(new BigDecimal(1));
+		plain.setCurrency(Currency.USD);
+		plain.setPeriod(TimePeriod.MONTH);
+		plain.setIcon("icon");
+		// no recurrence settings at all
+
+		Item disabled = recurringItem("Disabled", new BigDecimal(1), TimePeriod.MONTH,
+				utc(2026, 4, 19), true, utc(2026, 4, 19));
+		disabled.getRecurrence().setEnabled(false);
+
+		account.setExpenses(Arrays.asList(plain, disabled));
+
+		int count = service.processAccount(account, utc(2026, 5, 20));
+		assertEquals(0, count);
+		verify(transactionRepository, never()).saveAll(any());
+		verify(statisticsClient, never()).updateStatistics(anyString(), any());
+	}
+
+	@Test
+	public void skipsItemsWhoseNextScheduledIsInTheFuture() {
+		Account account = new Account();
+		account.setName("demo");
+		// Cursor is tomorrow relative to "now".
+		Item future = recurringItem("Future", new BigDecimal(1), TimePeriod.DAY,
+				utc(2026, 4, 20), true, utc(2026, 4, 20));
+		account.setIncomes(Collections.singletonList(future));
+
+		int count = service.processAccount(account, utc(2026, 4, 19));
+		assertEquals(0, count);
+		verify(transactionRepository, never()).saveAll(any());
+	}
+
+	@Test
+	public void processAllAccountsIteratesAndSavesEachAccount() {
+		Account a = new Account();
+		a.setName("a");
+		a.setIncomes(Collections.singletonList(
+				recurringItem("Salary", new BigDecimal(100), TimePeriod.DAY,
+						utc(2026, 4, 19), true, utc(2026, 4, 19))));
+
+		Account b = new Account();
+		b.setName("b");
+		// no recurring items: should not be saved.
+
+		when(accountRepository.findAll()).thenReturn(Arrays.asList(a, b));
+
+		service.processAllAccounts(utc(2026, 4, 19));
+
+		verify(accountRepository, times(1)).save(a);
+		verify(accountRepository, never()).save(b);
+	}
+
+	@SuppressWarnings({"unchecked", "rawtypes"})
+	private ArgumentCaptor<List<Transaction>> listCaptor() {
+		return ArgumentCaptor.forClass((Class) List.class);
+	}
+}
