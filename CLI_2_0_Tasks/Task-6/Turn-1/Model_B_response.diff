+package com.piggymetrics.account.service.transaction;
+
+import com.piggymetrics.account.domain.TimePeriod;
+import org.springframework.stereotype.Service;
+
+import java.time.LocalDate;
+import java.time.LocalDateTime;
+import java.time.YearMonth;
+import java.time.ZoneId;
+import java.util.Date;
+
+/**
+ * Computes recurrence schedule dates from a fixed anchor date and a
+ * {@link TimePeriod}. All occurrences are derived from the original anchor
+ * (not iteratively from the previous occurrence) so month-end anchors such
+ * as the 31st snap to the last day of shorter months without drifting.
+ */
+@Service
+public class RecurrenceService {
+
+	private final ZoneId zoneId;
+
+	public RecurrenceService() {
+		this(ZoneId.systemDefault());
+	}
+
+	RecurrenceService(ZoneId zoneId) {
+		this.zoneId = zoneId;
+	}
+
+	/**
+	 * Returns the nth occurrence (n = 0, 1, 2, ...) counting from the
+	 * anchor. Monthly and quarterly schedules saturate to the last day of
+	 * the target month to handle anchors on the 29th, 30th or 31st.
+	 */
+	public Date occurrence(Date anchor, TimePeriod period, int n) {
+		if (anchor == null || period == null) {
+			throw new IllegalArgumentException("anchor and period are required");
+		}
+		if (n < 0) {
+			throw new IllegalArgumentException("n must be non-negative");
+		}
+		LocalDateTime anchorDt = LocalDateTime.ofInstant(anchor.toInstant(), zoneId);
+		LocalDateTime result;
+		switch (period) {
+			case YEAR:
+				result = addMonthsPreservingDay(anchorDt, 12 * n);
+				break;
+			case QUARTER:
+				result = addMonthsPreservingDay(anchorDt, 3 * n);
+				break;
+			case MONTH:
+				result = addMonthsPreservingDay(anchorDt, n);
+				break;
+			case DAY:
+				result = anchorDt.plusDays(n);
+				break;
+			case HOUR:
+				result = anchorDt.plusHours(n);
+				break;
+			default:
+				throw new IllegalStateException("unsupported period: " + period);
+		}
+		return Date.from(result.atZone(zoneId).toInstant());
+	}
+
+	/**
+	 * Returns the first occurrence that is strictly after {@code after}.
+	 * If {@code after} is null, returns the anchor itself.
+	 */
+	public Date nextAfter(Date anchor, TimePeriod period, Date after) {
+		if (after == null) {
+			return anchor;
+		}
+		int n = 0;
+		Date candidate = occurrence(anchor, period, n);
+		while (!candidate.after(after)) {
+			n++;
+			candidate = occurrence(anchor, period, n);
+			// Defensive upper bound to avoid runaway loops on pathological
+			// inputs (e.g. an anchor far in the past with an HOUR period).
+			if (n > 1_000_000) {
+				throw new IllegalStateException(
+						"could not locate next occurrence within 1,000,000 iterations");
+			}
+		}
+		return candidate;
+	}
+
+	/**
+	 * Returns the first occurrence that is greater than or equal to
+	 * {@code at}. Used when (re-)initialising {@code nextScheduledDate}
+	 * after a user updates recurrence settings.
+	 */
+	public Date firstOccurrenceAtOrAfter(Date anchor, TimePeriod period, Date at) {
+		if (at == null || !anchor.before(at)) {
+			return anchor;
+		}
+		int n = 0;
+		Date candidate = occurrence(anchor, period, n);
+		while (candidate.before(at)) {
+			n++;
+			candidate = occurrence(anchor, period, n);
+			if (n > 1_000_000) {
+				throw new IllegalStateException(
+						"could not locate first occurrence within 1,000,000 iterations");
+			}
+		}
+		return candidate;
+	}
+
+	/**
+	 * Adds {@code months} to the given date-time while preserving the
+	 * anchor's day-of-month. If the target month is shorter than the
+	 * anchor's day-of-month (e.g. Jan 31 → Feb), the day is clamped to the
+	 * last day of the target month. Crucially, subsequent occurrences are
+	 * computed from the original anchor so that e.g. Jan 31 → Feb 28 →
+	 * Mar 31 (not Mar 28).
+	 */
+	private LocalDateTime addMonthsPreservingDay(LocalDateTime anchor, int months) {
+		LocalDate anchorDate = anchor.toLocalDate();
+		int anchorDay = anchorDate.getDayOfMonth();
+		YearMonth targetMonth = YearMonth.from(anchorDate).plusMonths(months);
+		int day = Math.min(anchorDay, targetMonth.lengthOfMonth());
+		LocalDate resultDate = targetMonth.atDay(day);
+		return LocalDateTime.of(resultDate, anchor.toLocalTime());
+	}
+}
