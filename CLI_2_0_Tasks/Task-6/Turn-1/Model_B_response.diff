+package com.piggymetrics.account.service.transaction;
+
+import com.piggymetrics.account.domain.TimePeriod;
+import org.junit.Before;
+import org.junit.Test;
+
+import java.time.LocalDateTime;
+import java.time.ZoneId;
+import java.time.ZoneOffset;
+import java.util.Date;
+
+import static org.junit.Assert.assertEquals;
+
+public class RecurrenceServiceTest {
+
+	private RecurrenceService service;
+	private final ZoneId zone = ZoneOffset.UTC;
+
+	@Before
+	public void setup() {
+		service = new RecurrenceService(zone);
+	}
+
+	private Date utc(int year, int month, int day, int hour, int minute) {
+		return Date.from(LocalDateTime.of(year, month, day, hour, minute)
+				.atZone(zone).toInstant());
+	}
+
+	@Test
+	public void monthlyAnchorOn31stSaturatesToLastDayInShorterMonths() {
+		Date anchor = utc(2026, 1, 31, 9, 0);
+
+		// Feb 2026 has 28 days: occurrence 1 must land on Feb 28.
+		assertEquals(utc(2026, 2, 28, 9, 0), service.occurrence(anchor, TimePeriod.MONTH, 1));
+		// Crucially, the following month returns to the 31st (we compute
+		// from the original anchor, not from the previous occurrence).
+		assertEquals(utc(2026, 3, 31, 9, 0), service.occurrence(anchor, TimePeriod.MONTH, 2));
+		// April has 30 days: clamp back down to 30.
+		assertEquals(utc(2026, 4, 30, 9, 0), service.occurrence(anchor, TimePeriod.MONTH, 3));
+		assertEquals(utc(2026, 5, 31, 9, 0), service.occurrence(anchor, TimePeriod.MONTH, 4));
+	}
+
+	@Test
+	public void monthlyAnchorOn31stLeapYearFebruary() {
+		Date anchor = utc(2024, 1, 31, 0, 0);
+		// 2024 is a leap year so February has 29 days.
+		assertEquals(utc(2024, 2, 29, 0, 0), service.occurrence(anchor, TimePeriod.MONTH, 1));
+	}
+
+	@Test
+	public void quarterlyPreservesDayOfMonthWithClamping() {
+		Date anchor = utc(2026, 1, 31, 0, 0);
+		// +3 months = Apr 30 (clamped), +6 months = Jul 31, +9 = Oct 31.
+		assertEquals(utc(2026, 4, 30, 0, 0), service.occurrence(anchor, TimePeriod.QUARTER, 1));
+		assertEquals(utc(2026, 7, 31, 0, 0), service.occurrence(anchor, TimePeriod.QUARTER, 2));
+		assertEquals(utc(2026, 10, 31, 0, 0), service.occurrence(anchor, TimePeriod.QUARTER, 3));
+	}
+
+	@Test
+	public void yearlyAdds12Months() {
+		Date anchor = utc(2026, 3, 15, 12, 0);
+		assertEquals(utc(2027, 3, 15, 12, 0), service.occurrence(anchor, TimePeriod.YEAR, 1));
+	}
+
+	@Test
+	public void dailyAddsOneDay() {
+		Date anchor = utc(2026, 4, 19, 8, 30);
+		assertEquals(utc(2026, 4, 20, 8, 30), service.occurrence(anchor, TimePeriod.DAY, 1));
+		assertEquals(utc(2026, 4, 26, 8, 30), service.occurrence(anchor, TimePeriod.DAY, 7));
+	}
+
+	@Test
+	public void hourlyAddsOneHour() {
+		Date anchor = utc(2026, 4, 19, 8, 30);
+		assertEquals(utc(2026, 4, 19, 9, 30), service.occurrence(anchor, TimePeriod.HOUR, 1));
+	}
+
+	@Test
+	public void nextAfterSkipsPastOccurrencesToFirstStrictlyLater() {
+		Date anchor = utc(2026, 1, 31, 9, 0);
+		Date after = utc(2026, 3, 15, 0, 0);
+		// Next monthly occurrence strictly after Mar 15 is Mar 31.
+		assertEquals(utc(2026, 3, 31, 9, 0), service.nextAfter(anchor, TimePeriod.MONTH, after));
+	}
+
+	@Test
+	public void nextAfterReturnsAnchorWhenAfterIsNull() {
+		Date anchor = utc(2026, 1, 31, 9, 0);
+		assertEquals(anchor, service.nextAfter(anchor, TimePeriod.MONTH, null));
+	}
+
+	@Test
+	public void firstOccurrenceAtOrAfterReturnsAnchorWhenAnchorIsInFuture() {
+		Date anchor = utc(2030, 1, 1, 0, 0);
+		Date at = utc(2026, 4, 19, 0, 0);
+		assertEquals(anchor,
+				service.firstOccurrenceAtOrAfter(anchor, TimePeriod.MONTH, at));
+	}
+
+	@Test
+	public void firstOccurrenceAtOrAfterAdvancesPastAnchorWhenAnchorIsInPast() {
+		Date anchor = utc(2026, 1, 31, 0, 0);
+		Date at = utc(2026, 4, 1, 0, 0);
+		// Next monthly occurrence at-or-after Apr 1 is Apr 30.
+		assertEquals(utc(2026, 4, 30, 0, 0),
+				service.firstOccurrenceAtOrAfter(anchor, TimePeriod.MONTH, at));
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void rejectsNegativeOccurrenceIndex() {
+		service.occurrence(new Date(), TimePeriod.DAY, -1);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void rejectsNullAnchor() {
+		service.occurrence(null, TimePeriod.DAY, 1);
+	}
+}
