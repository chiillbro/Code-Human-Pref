@@ -0,0 +1,103 @@
+package com.piggymetrics.account.service.transaction;
+
+import com.piggymetrics.account.client.StatisticsServiceClient;
+import com.piggymetrics.account.domain.Account;
+import com.piggymetrics.account.domain.transaction.Transaction;
+import com.piggymetrics.account.domain.transaction.TransactionStatus;
+import com.piggymetrics.account.domain.transaction.TransactionType;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.TransactionRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.data.domain.Page;
+import org.springframework.data.domain.Pageable;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.util.Date;
+import java.util.Optional;
+
+@Service
+public class TransactionServiceImpl implements TransactionService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private TransactionRepository transactionRepository;
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private StatisticsServiceClient statisticsClient;
+
+	@Override
+	public Page<Transaction> list(String accountName,
+			TransactionStatus status,
+			TransactionType type,
+			Date from,
+			Date to,
+			Pageable pageable) {
+		Assert.hasLength(accountName);
+		return transactionRepository.findByFilter(accountName, status, type, from, to, pageable);
+	}
+
+	@Override
+	public Transaction get(String accountName, String id) {
+		Transaction tx = loadOwned(accountName, id);
+		return tx;
+	}
+
+	@Override
+	public Transaction approve(String accountName, String id) {
+		Transaction tx = loadOwned(accountName, id);
+		Assert.isTrue(tx.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only pending-review transactions can be approved, got: " + tx.getStatus());
+
+		tx.setStatus(TransactionStatus.POSTED);
+		tx.setPostedDate(new Date());
+		Transaction saved = transactionRepository.save(tx);
+		log.info("transaction {} approved for account {}", saved.getId(), accountName);
+
+		// Approving changes the effective balance for the account, so
+		// refresh statistics as we do on auto-post.
+		Account account = accountRepository.findByName(accountName);
+		if (account != null) {
+			statisticsClient.updateStatistics(accountName, account);
+		}
+		return saved;
+	}
+
+	@Override
+	public Transaction skip(String accountName, String id) {
+		Transaction tx = loadOwned(accountName, id);
+		Assert.isTrue(tx.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only pending-review transactions can be skipped, got: " + tx.getStatus());
+
+		tx.setStatus(TransactionStatus.SKIPPED);
+		Transaction saved = transactionRepository.save(tx);
+		log.info("transaction {} skipped for account {}", saved.getId(), accountName);
+		return saved;
+	}
+
+	@Override
+	public void delete(String accountName, String id) {
+		Transaction tx = loadOwned(accountName, id);
+		Assert.isTrue(tx.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only pending-review transactions can be deleted, got: " + tx.getStatus());
+		transactionRepository.delete(tx);
+		log.info("transaction {} deleted for account {}", id, accountName);
+	}
+
+	private Transaction loadOwned(String accountName, String id) {
+		Assert.hasLength(accountName);
+		Assert.hasLength(id);
+		Optional<Transaction> found = transactionRepository.findById(id);
+		Assert.isTrue(found.isPresent(), "transaction not found: " + id);
+		Transaction tx = found.get();
+		Assert.isTrue(accountName.equals(tx.getAccountName()),
+				"transaction does not belong to account: " + accountName);
+		return tx;
+	}
+}
