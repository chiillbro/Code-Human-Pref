+
+	@InjectMocks
+	private TransactionServiceImpl service;
+
+	@Mock
+	private TransactionRepository transactionRepository;
+
+	@Mock
+	private AccountRepository accountRepository;
+
+	@Mock
+	private StatisticsServiceClient statisticsClient;
+
+	@Before
+	public void setup() {
+		initMocks(this);
+	}
+
+	private Transaction pending() {
+		Transaction t = new Transaction();
+		t.setId("tx-1");
+		t.setAccountName("demo");
+		t.setStatus(TransactionStatus.PENDING_REVIEW);
+		return t;
+	}
+
+	@Test
+	public void approveFlipsToPostedAndRefreshesStatistics() {
+		Transaction tx = pending();
+		Account account = new Account();
+		account.setName("demo");
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		when(accountRepository.findByName("demo")).thenReturn(account);
+		when(transactionRepository.save(tx)).thenReturn(tx);
+
+		Transaction result = service.approve("demo", "tx-1");
+
+		assertEquals(TransactionStatus.POSTED, result.getStatus());
+		assertNotNull(result.getPostedDate());
+		verify(transactionRepository, times(1)).save(tx);
+		verify(statisticsClient, times(1)).updateStatistics("demo", account);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void approveRejectsAlreadyPosted() {
+		Transaction tx = pending();
+		tx.setStatus(TransactionStatus.POSTED);
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		service.approve("demo", "tx-1");
+	}
+
+	@Test
+	public void skipFlipsToSkipped() {
+		Transaction tx = pending();
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		when(transactionRepository.save(tx)).thenReturn(tx);
+
+		Transaction result = service.skip("demo", "tx-1");
+		assertEquals(TransactionStatus.SKIPPED, result.getStatus());
+		verify(statisticsClient, never()).updateStatistics(anyString(), any());
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void skipRejectsNonPending() {
+		Transaction tx = pending();
+		tx.setStatus(TransactionStatus.SKIPPED);
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		service.skip("demo", "tx-1");
+	}
+
+	@Test
+	public void deleteRemovesPendingTransaction() {
+		Transaction tx = pending();
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		service.delete("demo", "tx-1");
+		verify(transactionRepository, times(1)).delete(tx);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void deleteRejectsNonPending() {
+		Transaction tx = pending();
+		tx.setStatus(TransactionStatus.POSTED);
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		service.delete("demo", "tx-1");
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void rejectsAccessFromWrongAccount() {
+		Transaction tx = pending();
+		tx.setAccountName("someone-else");
+		when(transactionRepository.findById("tx-1")).thenReturn(Optional.of(tx));
+		service.get("demo", "tx-1");
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void rejectsMissingTransaction() {
+		when(transactionRepository.findById("nope")).thenReturn(Optional.empty());
+		service.get("demo", "nope");
+	}
+}
