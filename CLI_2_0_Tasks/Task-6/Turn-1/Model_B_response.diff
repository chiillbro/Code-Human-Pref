+package com.piggymetrics.account.service.transaction;
+
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+/**
+ * Thin cron entry point for {@link RecurringTransactionService}. The cron
+ * expression is sourced from Spring Cloud Config via the
+ * {@code recurring.cron} property (default: every day at 01:00).
+ */
+@Component
+public class RecurringTransactionJob {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private RecurringTransactionService service;
+
+	@Scheduled(cron = "${recurring.cron:0 0 1 * * *}")
+	public void runDaily() {
+		try {
+			service.processAllAccounts();
+		} catch (RuntimeException ex) {
+			log.error("recurring-transaction job failed", ex);
+		}
+	}
+}
