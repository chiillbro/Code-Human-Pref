+package com.piggymetrics.account.domain;
+
+import java.util.Date;
+
+/**
+ * Per-item recurrence configuration. When {@code enabled} is true and an
+ * {@code anchorDate} is provided, the recurring-transaction job materialises
+ * {@link com.piggymetrics.account.domain.transaction.Transaction} records
+ * on the schedule defined by the item's {@link TimePeriod}.
+ */
+public class RecurrenceSettings {
+
+	/**
+	 * Whether the user opted this item in to transaction generation.
+	 */
+	private Boolean enabled;
+
+	/**
+	 * The date of the first occurrence; every subsequent occurrence is
+	 * computed as {@code anchorDate + n * period}.
+	 */
+	private Date anchorDate;
+
+	/**
+	 * When true, on-time transactions (i.e. not backfilled) are created
+	 * directly in the {@code POSTED} state. When false they land in
+	 * {@code PENDING_REVIEW} for the user to approve or skip.
+	 */
+	private Boolean autoPost;
+
+	/**
+	 * Internal book-keeping field: the next date for which a transaction
+	 * should be generated. Kept on the item so that the job can scan
+	 * accounts efficiently without recomputing history from scratch.
+	 */
+	private Date nextScheduledDate;
+
+	/**
+	 * The scheduled date of the most recent transaction that the job
+	 * generated for this item. Used to resume after settings changes
+	 * without losing the cursor.
+	 */
+	private Date lastGeneratedDate;
+
+	public Boolean getEnabled() {
+		return enabled;
+	}
+
+	public void setEnabled(Boolean enabled) {
+		this.enabled = enabled;
+	}
+
+	public Date getAnchorDate() {
+		return anchorDate;
+	}
+
+	public void setAnchorDate(Date anchorDate) {
+		this.anchorDate = anchorDate;
+	}
+
+	public Boolean getAutoPost() {
+		return autoPost;
+	}
+
+	public void setAutoPost(Boolean autoPost) {
+		this.autoPost = autoPost;
+	}
+
+	public Date getNextScheduledDate() {
+		return nextScheduledDate;
+	}
+
+	public void setNextScheduledDate(Date nextScheduledDate) {
+		this.nextScheduledDate = nextScheduledDate;
+	}
+
+	public Date getLastGeneratedDate() {
+		return lastGeneratedDate;
+	}
+
+	public void setLastGeneratedDate(Date lastGeneratedDate) {
+		this.lastGeneratedDate = lastGeneratedDate;
+	}
+}
