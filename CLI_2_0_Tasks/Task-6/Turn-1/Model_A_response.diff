+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.Transaction;
+import com.piggymetrics.account.domain.TransactionStatus;
+import com.piggymetrics.account.domain.TransactionType;
+import com.piggymetrics.account.repository.TransactionRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.data.domain.Page;
+import org.springframework.data.domain.Pageable;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.util.Date;
+
+@Service
+public class TransactionServiceImpl implements TransactionService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private TransactionRepository transactionRepository;
+
+	@Override
+	public Page<Transaction> listTransactions(String accountName, TransactionStatus status, TransactionType type,
+			Date dateFrom, Date dateTo, Pageable pageable) {
+		Assert.hasLength(accountName);
+
+		boolean hasDateRange = dateFrom != null && dateTo != null;
+		boolean hasStatus = status != null;
+		boolean hasType = type != null;
+
+		if (hasDateRange && hasStatus && hasType) {
+			return transactionRepository.findByAccountNameAndStatusAndTypeAndScheduledDateBetween(
+					accountName, status, type, dateFrom, dateTo, pageable);
+		} else if (hasDateRange && hasStatus) {
+			return transactionRepository.findByAccountNameAndStatusAndScheduledDateBetween(
+					accountName, status, dateFrom, dateTo, pageable);
+		} else if (hasDateRange && hasType) {
+			return transactionRepository.findByAccountNameAndTypeAndScheduledDateBetween(
+					accountName, type, dateFrom, dateTo, pageable);
+		} else if (hasDateRange) {
+			return transactionRepository.findByAccountNameAndScheduledDateBetween(
+					accountName, dateFrom, dateTo, pageable);
+		} else if (hasStatus && hasType) {
+			return transactionRepository.findByAccountNameAndStatusAndType(
+					accountName, status, type, pageable);
+		} else if (hasStatus) {
+			return transactionRepository.findByAccountNameAndStatus(
+					accountName, status, pageable);
+		} else if (hasType) {
+			return transactionRepository.findByAccountNameAndType(
+					accountName, type, pageable);
+		} else {
+			return transactionRepository.findByAccountName(accountName, pageable);
+		}
+	}
+
+	@Override
+	public Transaction findById(String accountName, String transactionId) {
+		Assert.hasLength(accountName);
+		Assert.hasLength(transactionId);
+
+		Transaction transaction = transactionRepository.findByIdAndAccountName(transactionId, accountName);
+		Assert.notNull(transaction, "transaction not found: " + transactionId);
+		return transaction;
+	}
+
+	@Override
+	public Transaction approve(String accountName, String transactionId) {
+		Transaction transaction = findById(accountName, transactionId);
+		Assert.isTrue(transaction.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only pending_review transactions can be approved");
+
+		transaction.setStatus(TransactionStatus.POSTED);
+		transaction.setPostedDate(new Date());
+		transactionRepository.save(transaction);
+
+		log.info("transaction {} approved for account {}", transactionId, accountName);
+		return transaction;
+	}
+
+	@Override
+	public Transaction skip(String accountName, String transactionId) {
+		Transaction transaction = findById(accountName, transactionId);
+		Assert.isTrue(transaction.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only pending_review transactions can be skipped");
+
+		transaction.setStatus(TransactionStatus.SKIPPED);
+		transactionRepository.save(transaction);
+
+		log.info("transaction {} skipped for account {}", transactionId, accountName);
+		return transaction;
+	}
+
+	@Override
+	public void delete(String accountName, String transactionId) {
+		Transaction transaction = findById(accountName, transactionId);
+		Assert.isTrue(transaction.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only pending_review transactions can be deleted");
+
+		transactionRepository.delete(transaction);
+		log.info("transaction {} deleted for account {}", transactionId, accountName);
+	}
+}
