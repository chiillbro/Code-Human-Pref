+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.TimePeriod;
+import org.junit.Before;
+import org.junit.Test;
+
+import java.util.Calendar;
+import java.util.Date;
+
+import static org.junit.Assert.*;
+
+public class RecurrenceServiceTest {
+
+	private RecurrenceService recurrenceService;
+
+	@Before
+	public void setup() {
+		recurrenceService = new RecurrenceService();
+	}
+
+	@Test
+	public void shouldComputeNextDailyDate() {
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JANUARY, 1, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2025, Calendar.JANUARY, 3, 12, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.DAY, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2025, result.get(Calendar.YEAR));
+		assertEquals(Calendar.JANUARY, result.get(Calendar.MONTH));
+		assertEquals(4, result.get(Calendar.DAY_OF_MONTH));
+	}
+
+	@Test
+	public void shouldComputeNextMonthlyDate() {
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JANUARY, 15, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2025, Calendar.MARCH, 1, 0, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.MONTH, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2025, result.get(Calendar.YEAR));
+		assertEquals(Calendar.MARCH, result.get(Calendar.MONTH));
+		assertEquals(15, result.get(Calendar.DAY_OF_MONTH));
+	}
+
+	@Test
+	public void shouldHandleMonthlyAnchorOn31stInFebruary() {
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JANUARY, 31, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2025, Calendar.JANUARY, 31, 12, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.MONTH, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2025, result.get(Calendar.YEAR));
+		assertEquals(Calendar.FEBRUARY, result.get(Calendar.MONTH));
+		// February 2025 has 28 days
+		assertEquals(28, result.get(Calendar.DAY_OF_MONTH));
+	}
+
+	@Test
+	public void shouldHandleMonthlyAnchorOn31stInApril() {
+		// After Feb 28, next should be March 31
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JANUARY, 31, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		// from = March 1 (after Feb 28 was processed)
+		cal.set(2025, Calendar.MARCH, 1, 0, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.MONTH, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2025, result.get(Calendar.YEAR));
+		assertEquals(Calendar.MARCH, result.get(Calendar.MONTH));
+		assertEquals(31, result.get(Calendar.DAY_OF_MONTH));
+	}
+
+	@Test
+	public void shouldComputeNextQuarterlyDate() {
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JANUARY, 15, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2025, Calendar.FEBRUARY, 1, 0, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.QUARTER, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2025, result.get(Calendar.YEAR));
+		assertEquals(Calendar.APRIL, result.get(Calendar.MONTH));
+		assertEquals(15, result.get(Calendar.DAY_OF_MONTH));
+	}
+
+	@Test
+	public void shouldComputeNextYearlyDate() {
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JUNE, 10, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2025, Calendar.JUNE, 10, 12, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.YEAR, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2026, result.get(Calendar.YEAR));
+		assertEquals(Calendar.JUNE, result.get(Calendar.MONTH));
+		assertEquals(10, result.get(Calendar.DAY_OF_MONTH));
+	}
+
+	@Test
+	public void shouldComputeNextHourlyDate() {
+		Calendar cal = Calendar.getInstance();
+		cal.set(2025, Calendar.JANUARY, 1, 10, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2025, Calendar.JANUARY, 1, 12, 30, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.HOUR, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(13, result.get(Calendar.HOUR_OF_DAY));
+	}
+
+	@Test
+	public void shouldReturnNullWhenAnchorIsNull() {
+		Date result = recurrenceService.computeNextScheduledDate(null, TimePeriod.DAY, new Date());
+		assertNull(result);
+	}
+
+	@Test
+	public void shouldReturnNullWhenPeriodIsNull() {
+		Date result = recurrenceService.computeNextScheduledDate(new Date(), null, new Date());
+		assertNull(result);
+	}
+
+	@Test
+	public void shouldHandleLeapYearForMonthlyOn29th() {
+		// Anchor on Jan 29, compute for Feb in a leap year (2024)
+		Calendar cal = Calendar.getInstance();
+		cal.set(2024, Calendar.JANUARY, 29, 0, 0, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+		Date anchor = cal.getTime();
+
+		cal.set(2024, Calendar.JANUARY, 30, 0, 0, 0);
+		Date from = cal.getTime();
+
+		Date next = recurrenceService.computeNextScheduledDate(anchor, TimePeriod.MONTH, from);
+
+		Calendar result = Calendar.getInstance();
+		result.setTime(next);
+		assertEquals(2024, result.get(Calendar.YEAR));
+		assertEquals(Calendar.FEBRUARY, result.get(Calendar.MONTH));
+		assertEquals(29, result.get(Calendar.DAY_OF_MONTH));
+	}
+}
