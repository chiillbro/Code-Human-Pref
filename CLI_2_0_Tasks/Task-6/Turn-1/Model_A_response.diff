@@ -0,0 +1,171 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.client.StatisticsServiceClient;
+import com.piggymetrics.account.domain.*;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.TransactionRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+import java.util.ArrayList;
+import java.util.Date;
+import java.util.List;
+
+@Component
+public class RecurringTransactionScheduler {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private TransactionRepository transactionRepository;
+
+	@Autowired
+	private RecurrenceService recurrenceService;
+
+	@Autowired
+	private StatisticsServiceClient statisticsClient;
+
+	@Value("${recurrence.backfill.max:10}")
+	private int maxBackfill;
+
+	@Scheduled(cron = "${recurrence.cron:0 0 1 * * *}")
+	public void processRecurringTransactions() {
+		log.info("Starting recurring transaction processing");
+
+		Date now = new Date();
+		List<Account> accounts = new ArrayList<>();
+		accountRepository.findAll().forEach(accounts::add);
+
+		int totalCreated = 0;
+		for (Account account : accounts) {
+			totalCreated += processAccount(account, now);
+		}
+
+		log.info("Recurring transaction processing complete. Created {} transactions", totalCreated);
+	}
+
+	int processAccount(Account account, Date now) {
+		int created = 0;
+		boolean accountUpdated = false;
+		boolean needsStatisticsUpdate = false;
+
+		created += processItems(account, account.getIncomes(), TransactionType.INCOME, now,
+				new boolean[]{false}, new boolean[]{false});
+		needsStatisticsUpdate = created > 0;
+		accountUpdated = created > 0;
+
+		int expenseCount = processItems(account, account.getExpenses(), TransactionType.EXPENSE, now,
+				new boolean[]{false}, new boolean[]{false});
+		created += expenseCount;
+		if (expenseCount > 0) {
+			needsStatisticsUpdate = true;
+			accountUpdated = true;
+		}
+
+		if (accountUpdated) {
+			accountRepository.save(account);
+		}
+
+		if (needsStatisticsUpdate) {
+			try {
+				statisticsClient.updateStatistics(account.getName(), account);
+			} catch (Exception e) {
+				log.error("Failed to update statistics for account {}: {}", account.getName(), e.getMessage());
+			}
+		}
+
+		return created;
+	}
+
+	private int processItems(Account account, List<Item> items, TransactionType type, Date now,
+			boolean[] accountUpdatedFlag, boolean[] statsFlag) {
+		if (items == null) {
+			return 0;
+		}
+
+		int created = 0;
+		for (Item item : items) {
+			if (!Boolean.TRUE.equals(item.getRecurrenceEnabled())) {
+				continue;
+			}
+			if (item.getAnchorDate() == null || item.getNextScheduledDate() == null) {
+				continue;
+			}
+
+			created += generateTransactions(account, item, type, now);
+		}
+		return created;
+	}
+
+	int generateTransactions(Account account, Item item, TransactionType type, Date now) {
+		int created = 0;
+		int backfillCount = 0;
+
+		// Count how many dates are due (to determine backfill)
+		Date cursor = item.getNextScheduledDate();
+		List<Date> dueDates = new ArrayList<>();
+		while (!cursor.after(now)) {
+			dueDates.add(cursor);
+			cursor = recurrenceService.computeNextScheduledDate(
+					item.getAnchorDate(), item.getPeriod(), cursor);
+		}
+
+		// If more than 1 date is due, the earlier ones are backfill
+		boolean hasBackfill = dueDates.size() > 1;
+
+		for (int i = 0; i < dueDates.size(); i++) {
+			boolean isBackfill = hasBackfill && i < dueDates.size() - 1;
+
+			if (isBackfill && backfillCount >= maxBackfill) {
+				log.warn("Backfill cap reached for item '{}' on account '{}'",
+						item.getTitle(), account.getName());
+				break;
+			}
+
+			Transaction transaction = new Transaction();
+			transaction.setAccountName(account.getName());
+			transaction.setType(type);
+			transaction.setAmount(item.getAmount());
+			transaction.setCurrency(item.getCurrency());
+			transaction.setSourceItemTitle(item.getTitle());
+			transaction.setScheduledDate(dueDates.get(i));
+			transaction.setCreatedDate(now);
+			transaction.setBackfilled(isBackfill);
+
+			if (isBackfill) {
+				transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+				backfillCount++;
+			} else if (Boolean.TRUE.equals(item.getAutoPost())) {
+				transaction.setStatus(TransactionStatus.POSTED);
+				transaction.setPostedDate(now);
+			} else {
+				transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+			}
+
+			transactionRepository.save(transaction);
+			created++;
+
+			log.debug("Created {} transaction for item '{}' on account '{}', scheduled: {}, backfill: {}",
+					transaction.getStatus(), item.getTitle(), account.getName(),
+					dueDates.get(i), isBackfill);
+		}
+
+		// Update the item's next scheduled date
+		if (!dueDates.isEmpty()) {
+			Date lastProcessed = dueDates.get(Math.min(dueDates.size() - 1,
+					hasBackfill ? backfillCount : dueDates.size() - 1));
+			Date nextDate = recurrenceService.computeNextScheduledDate(
+					item.getAnchorDate(), item.getPeriod(), lastProcessed);
+			item.setNextScheduledDate(nextDate);
+		}
+
