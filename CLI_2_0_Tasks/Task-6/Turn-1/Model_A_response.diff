@@ -0,0 +1,81 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.TimePeriod;
+import org.springframework.stereotype.Service;
+
+import java.util.Calendar;
+import java.util.Date;
+
+@Service
+public class RecurrenceService {
+
+	/**
+	 * Computes the next scheduled date after {@code from}, based on the anchor date and period.
+	 * Handles month-end anchoring: if the anchor day is 31 but the target month has fewer days,
+	 * it uses the last day of that month.
+	 */
+	public Date computeNextScheduledDate(Date anchor, TimePeriod period, Date from) {
+		if (anchor == null || period == null || from == null) {
+			return null;
+		}
+
+		Calendar anchorCal = Calendar.getInstance();
+		anchorCal.setTime(anchor);
+		int anchorDay = anchorCal.get(Calendar.DAY_OF_MONTH);
+
+		Calendar next = Calendar.getInstance();
+		next.setTime(anchor);
+		zeroTime(next);
+
+		Calendar fromCal = Calendar.getInstance();
+		fromCal.setTime(from);
+
+		// Advance until next is strictly after from
+		while (!next.getTime().after(from)) {
+			advance(next, period, anchorDay);
+		}
+
+		return next.getTime();
+	}
+
+	/**
+	 * Advances the calendar by one period, handling month-end anchoring.
+	 */
+	private void advance(Calendar cal, TimePeriod period, int anchorDay) {
+		switch (period) {
+			case HOUR:
+				cal.add(Calendar.HOUR_OF_DAY, 1);
+				break;
+			case DAY:
+				cal.add(Calendar.DAY_OF_MONTH, 1);
+				break;
+			case MONTH:
+				cal.add(Calendar.MONTH, 1);
+				clampDay(cal, anchorDay);
+				break;
+			case QUARTER:
+				cal.add(Calendar.MONTH, 3);
+				clampDay(cal, anchorDay);
+				break;
+			case YEAR:
+				cal.add(Calendar.YEAR, 1);
+				clampDay(cal, anchorDay);
+				break;
+		}
+	}
+
+	/**
+	 * Sets the day of month to the anchor day, or the last day of the month if the month is shorter.
+	 */
+	private void clampDay(Calendar cal, int anchorDay) {
+		int maxDay = cal.getActualMaximum(Calendar.DAY_OF_MONTH);
+		cal.set(Calendar.DAY_OF_MONTH, Math.min(anchorDay, maxDay));
+	}
+
+	private void zeroTime(Calendar cal) {
+		cal.set(Calendar.HOUR_OF_DAY, 0);
+		cal.set(Calendar.MINUTE, 0);
+		cal.set(Calendar.SECOND, 0);
+		cal.set(Calendar.MILLISECOND, 0);
+	}
+}
diff --git a/account-service/src/main/java/com/piggymetrics/account/service/RecurringTransactionScheduler.java b/account-service/src/main/java/com/piggymetrics/account/service/RecurringTransactionScheduler.java
