+package com.piggymetrics.account.controller;
+
+import com.piggymetrics.account.domain.Transaction;
+import com.piggymetrics.account.domain.TransactionStatus;
+import com.piggymetrics.account.domain.TransactionType;
+import com.piggymetrics.account.service.TransactionService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.data.domain.Page;
+import org.springframework.data.domain.PageRequest;
+import org.springframework.data.domain.Sort;
+import org.springframework.format.annotation.DateTimeFormat;
+import org.springframework.web.bind.annotation.*;
+
+import java.security.Principal;
+import java.util.Date;
+
+@RestController
+@RequestMapping("/current/transactions")
+public class TransactionController {
+
+	@Autowired
+	private TransactionService transactionService;
+
+	@RequestMapping(method = RequestMethod.GET)
+	public Page<Transaction> listTransactions(
+			Principal principal,
+			@RequestParam(required = false) TransactionStatus status,
+			@RequestParam(required = false) TransactionType type,
+			@RequestParam(required = false) @DateTimeFormat(iso = DateTimeFormat.ISO.DATE) Date dateFrom,
+			@RequestParam(required = false) @DateTimeFormat(iso = DateTimeFormat.ISO.DATE) Date dateTo,
+			@RequestParam(defaultValue = "0") int page,
+			@RequestParam(defaultValue = "20") int size) {
+
+		PageRequest pageRequest = PageRequest.of(page, size, Sort.by(Sort.Direction.DESC, "scheduledDate"));
+		return transactionService.listTransactions(principal.getName(), status, type, dateFrom, dateTo, pageRequest);
+	}
+
+	@RequestMapping(path = "/{id}", method = RequestMethod.GET)
+	public Transaction getTransaction(Principal principal, @PathVariable String id) {
+		return transactionService.findById(principal.getName(), id);
+	}
+
+	@RequestMapping(path = "/{id}/approve", method = RequestMethod.PUT)
+	public Transaction approveTransaction(Principal principal, @PathVariable String id) {
+		return transactionService.approve(principal.getName(), id);
+	}
+
+	@RequestMapping(path = "/{id}/skip", method = RequestMethod.PUT)
+	public Transaction skipTransaction(Principal principal, @PathVariable String id) {
+		return transactionService.skip(principal.getName(), id);
+	}
+
+	@RequestMapping(path = "/{id}", method = RequestMethod.DELETE)
+	public void deleteTransaction(Principal principal, @PathVariable String id) {
+		transactionService.delete(principal.getName(), id);
+	}
+}
