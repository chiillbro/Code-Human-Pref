+		Date after = toDate(2024, 6, 1);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.YEAR, after);
+
+		assertEquals(toDate(2025, 1, 15), next);
+	}
+
+	// ========================= month-end clamping =========================
+
+	@Test
+	public void shouldClampJan31ToFeb28InNonLeapYear() {
+		Date anchor = toDate(2023, 1, 31);
+		Date after = toDate(2023, 1, 31);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.MONTH, after);
+
+		assertEquals(toDate(2023, 2, 28), next);
+	}
+
+	@Test
+	public void shouldClampJan31ToFeb29InLeapYear() {
+		Date anchor = toDate(2024, 1, 31);
+		Date after = toDate(2024, 1, 31);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.MONTH, after);
+
+		assertEquals(toDate(2024, 2, 29), next);
+	}
+
+	@Test
