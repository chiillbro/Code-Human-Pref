+		Date anchor = toDate(2024, 1, 15);
+		Date after = toDate(2024, 1, 20);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.MONTH, after);
+
+		assertEquals(toDate(2024, 2, 15), next);
+	}
+
+	@Test
+	public void shouldReturnNextQuarterAfterAnchor() {
+		Date anchor = toDate(2024, 1, 15);
+		Date after = toDate(2024, 1, 20);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.QUARTER, after);
+
+		assertEquals(toDate(2024, 4, 15), next);
+	}
