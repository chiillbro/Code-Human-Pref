+
+public class RecurrenceCalculatorTest {
+
+	// ========================= computeNextDate =========================
+
+	@Test
+	public void shouldReturnNextDayAfterAnchor() {
+		Date anchor = toDate(2024, 1, 15);
+		Date after = toDate(2024, 1, 15);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.DAY, after);
