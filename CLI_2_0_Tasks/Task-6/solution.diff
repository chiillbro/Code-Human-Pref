+		Date anchor = toDate(2024, 2, 29);
+		Date after = toDate(2024, 2, 29);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.YEAR, after);
+
+		assertEquals(toDate(2025, 2, 28), next);
+	}
+
+	// ========================= computeNextDates =========================
+
+	@Test
+	public void shouldReturnMultipleDailyDates() {
+		Date anchor = toDate(2024, 1, 1);
+		Date after = toDate(2024, 1, 1);
+
+		List<Date> dates = RecurrenceCalculator.computeNextDates(anchor, TimePeriod.DAY, after, 3);
+
+		assertEquals(3, dates.size());
+		assertEquals(toDate(2024, 1, 2), dates.get(0));
+		assertEquals(toDate(2024, 1, 3), dates.get(1));
+		assertEquals(toDate(2024, 1, 4), dates.get(2));
+	}
+
+	@Test
+	public void shouldReturnMultipleMonthlyDatesWithClamping() {
+		Date anchor = toDate(2023, 1, 31);
+		Date after = toDate(2023, 1, 30);
+
+		List<Date> dates = RecurrenceCalculator.computeNextDates(anchor, TimePeriod.MONTH, after, 4);
+
+		assertEquals(4, dates.size());
+		assertEquals(toDate(2023, 1, 31), dates.get(0));
+		assertEquals(toDate(2023, 2, 28), dates.get(1));
+		assertEquals(toDate(2023, 3, 31), dates.get(2));
+		assertEquals(toDate(2023, 4, 30), dates.get(3));
+	}
+
+	// ========================= computeDatesBetween =========================
+
+	@Test
+	public void shouldReturnDatesInRange() {
+		Date anchor = toDate(2024, 1, 1);
+		Date after = toDate(2024, 1, 1);
+		Date until = toDate(2024, 1, 5);
+
+		List<Date> dates = RecurrenceCalculator.computeDatesBetween(anchor, TimePeriod.DAY, after, until, 100);
+
+		assertEquals(4, dates.size());
+		assertEquals(toDate(2024, 1, 2), dates.get(0));
+		assertEquals(toDate(2024, 1, 3), dates.get(1));
+		assertEquals(toDate(2024, 1, 4), dates.get(2));
+		assertEquals(toDate(2024, 1, 5), dates.get(3));
+	}
+
+	@Test
+	public void shouldCapResultsAtMaxCount() {
+		Date anchor = toDate(2024, 1, 1);
+		Date after = toDate(2024, 1, 1);
+		Date until = toDate(2024, 12, 31);
+
+		List<Date> dates = RecurrenceCalculator.computeDatesBetween(anchor, TimePeriod.DAY, after, until, 5);
+
+		assertEquals(5, dates.size());
+	}
+
+	@Test
+	public void shouldReturnEmptyWhenRangeHasNoDates() {
+		Date anchor = toDate(2024, 1, 1);
+		Date after = toDate(2024, 1, 1);
+		Date until = toDate(2024, 1, 1); // same as after, exclusive start
+
+		List<Date> dates = RecurrenceCalculator.computeDatesBetween(anchor, TimePeriod.MONTH, after, until, 100);
+
+		assertTrue(dates.isEmpty());
+	}
+
+	// ========================= null/invalid input =========================
+
+	@Test
+	public void shouldReturnNullForNullAnchor() {
+		Date result = RecurrenceCalculator.computeNextDate(null, TimePeriod.DAY, new Date());
+		assertNull(result);
+	}
+
+	@Test
+	public void shouldReturnEmptyListForNullPeriod() {
+		List<Date> dates = RecurrenceCalculator.computeNextDates(new Date(), null, new Date(), 3);
+		assertTrue(dates.isEmpty());
+	}
+
+	@Test
+	public void shouldReturnEmptyListForZeroCount() {
+		List<Date> dates = RecurrenceCalculator.computeNextDates(new Date(), TimePeriod.DAY, new Date(), 0);
+		assertTrue(dates.isEmpty());
+	}
+
+	@Test
+	public void shouldReturnEmptyListForBetweenWithNullUntil() {
+		List<Date> dates = RecurrenceCalculator.computeDatesBetween(new Date(), TimePeriod.DAY, new Date(), null, 10);
+		assertTrue(dates.isEmpty());
+	}
+
+	// ========================= HOUR period =========================
+
+	@Test
+	public void shouldComputeHourlyDates() {
+		Date anchor = toDateTime(2024, 1, 1, 10, 0);
+		Date after = toDateTime(2024, 1, 1, 10, 0);
+
+		List<Date> dates = RecurrenceCalculator.computeNextDates(anchor, TimePeriod.HOUR, after, 3);
+
+		assertEquals(3, dates.size());
+		assertEquals(toDateTime(2024, 1, 1, 11, 0), dates.get(0));
+		assertEquals(toDateTime(2024, 1, 1, 12, 0), dates.get(1));
+		assertEquals(toDateTime(2024, 1, 1, 13, 0), dates.get(2));
+	}
+
+	// ========================= anchor far in the past =========================
+
+	@Test
+	public void shouldHandleAnchorFarInThePast() {
+		Date anchor = toDate(2020, 1, 15);
+		Date after = toDate(2024, 6, 1);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.MONTH, after);
+
+		assertEquals(toDate(2024, 6, 15), next);
+	}
+
+	// ========================= helpers =========================
+
+	private static Date toDate(int year, int month, int day) {
+		return Date.from(LocalDate.of(year, month, day)
+				.atStartOfDay(ZoneId.systemDefault()).toInstant());
+	}
+
+	private static Date toDateTime(int year, int month, int day, int hour, int minute) {
+		return Date.from(LocalDateTime.of(year, month, day, hour, minute)
+				.atZone(ZoneId.systemDefault()).toInstant());
+	}
+}
diff --git a/account-service/src/test/java/com/piggymetrics/account/service/TransactionServiceImplTest.java b/account-service/src/test/java/com/piggymetrics/account/service/TransactionServiceImplTest.java
