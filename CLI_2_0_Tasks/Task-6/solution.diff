+		// anchor is Jan 31, after Feb 28: next should be Mar 31 (restores to anchor day)
+		Date anchor = toDate(2023, 1, 31);
+		Date after = toDate(2023, 2, 28);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.MONTH, after);
+
+		assertEquals(toDate(2023, 3, 31), next);
