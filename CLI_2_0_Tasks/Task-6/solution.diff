+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.data.domain.Page;
+import org.springframework.data.domain.PageRequest;
+import org.springframework.data.domain.Pageable;
+import org.springframework.data.domain.Sort;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Service;
+import org.springframework.util.Assert;
+
+import java.util.ArrayList;
+import java.util.Date;
+import java.util.List;
+
+@Service
+public class TransactionServiceImpl implements TransactionService {
+
+	private final Logger log = LoggerFactory.getLogger(getClass());
+
+	@Value("${recurrence.max-backfill-count:30}")
+	private int maxBackfillCount;
+
+	@Autowired
+	private TransactionRepository transactionRepository;
+
+	@Autowired
+	private AccountRepository accountRepository;
+
+	@Autowired
+	private StatisticsServiceClient statisticsClient;
+
+	@Override
+	public Page<Transaction> getTransactions(String accountName, TransactionStatus status, TransactionType type,
+			Date from, Date to, int page, int size) {
+
+		Assert.hasLength(accountName, "accountName is required");
+
+		Pageable pageable = PageRequest.of(page, size, Sort.by(Sort.Direction.DESC, "scheduledDate"));
+
+		boolean hasDateRange = (from != null && to != null);
+		boolean hasStatus = (status != null);
+		boolean hasType = (type != null);
+
+		if (hasDateRange && hasStatus && hasType) {
+			return transactionRepository.findByAccountNameAndStatusAndTypeAndScheduledDateBetween(
+					accountName, status, type, from, to, pageable);
+		} else if (hasDateRange && hasStatus) {
+			return transactionRepository.findByAccountNameAndStatusAndScheduledDateBetween(
+					accountName, status, from, to, pageable);
+		} else if (hasDateRange && hasType) {
+			return transactionRepository.findByAccountNameAndTypeAndScheduledDateBetween(
+					accountName, type, from, to, pageable);
+		} else if (hasDateRange) {
+			return transactionRepository.findByAccountNameAndScheduledDateBetween(
+					accountName, from, to, pageable);
+		} else if (hasStatus && hasType) {
+			return transactionRepository.findByAccountNameAndStatusAndType(
+					accountName, status, type, pageable);
+		} else if (hasStatus) {
+			return transactionRepository.findByAccountNameAndStatus(
+					accountName, status, pageable);
+		} else if (hasType) {
+			return transactionRepository.findByAccountNameAndType(
+					accountName, type, pageable);
+		} else {
+			return transactionRepository.findByAccountName(accountName, pageable);
+		}
+	}
+
+	@Override
+	public Transaction getTransaction(String accountName, String transactionId) {
+		Assert.hasLength(accountName, "accountName is required");
+		Assert.hasLength(transactionId, "transactionId is required");
+
+		Transaction transaction = transactionRepository.findByIdAndAccountName(transactionId, accountName);
+		Assert.notNull(transaction, "transaction not found: " + transactionId);
+
+		return transaction;
+	}
+
+	@Override
+	public Transaction approveTransaction(String accountName, String transactionId) {
+		Transaction transaction = getTransaction(accountName, transactionId);
+
+		Assert.isTrue(transaction.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only PENDING_REVIEW transactions can be approved");
+
+		transaction.setStatus(TransactionStatus.POSTED);
+		transaction.setPostedDate(new Date());
+		transactionRepository.save(transaction);
+
+		log.info("transaction {} approved for account {}", transactionId, accountName);
+
+		// Trigger statistics update
+		Account account = accountRepository.findByName(accountName);
+		if (account != null) {
+			statisticsClient.updateStatistics(accountName, account);
+		}
+
+		return transaction;
+	}
+
+	@Override
+	public Transaction skipTransaction(String accountName, String transactionId) {
+		Transaction transaction = getTransaction(accountName, transactionId);
+
+		Assert.isTrue(transaction.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only PENDING_REVIEW transactions can be skipped");
+
+		transaction.setStatus(TransactionStatus.SKIPPED);
+		transactionRepository.save(transaction);
+
+		log.info("transaction {} skipped for account {}", transactionId, accountName);
+
+		return transaction;
+	}
+
+	@Override
+	public void deleteTransaction(String accountName, String transactionId) {
+		Transaction transaction = getTransaction(accountName, transactionId);
+
+		Assert.isTrue(transaction.getStatus() == TransactionStatus.PENDING_REVIEW,
+				"only PENDING_REVIEW transactions can be deleted");
+
+		transactionRepository.delete(transaction);
+
+		log.info("transaction {} deleted for account {}", transactionId, accountName);
+	}
+
+	@Override
+	@Scheduled(cron = "${recurrence.job.cron}")
+	public void processRecurringTransactions() {
+
+		log.info("starting recurring transaction processing");
+
+		Date now = new Date();
+		Iterable<Account> allAccounts = accountRepository.findAll();
+
+		for (Account account : allAccounts) {
+			try {
+				boolean statsNeedUpdate = processAccountRecurrences(account, now);
+				if (statsNeedUpdate) {
+					statisticsClient.updateStatistics(account.getName(), account);
+				}
+			} catch (Exception e) {
+				log.error("error processing recurrences for account {}", account.getName(), e);
+			}
+		}
+
+		log.info("recurring transaction processing completed");
+	}
+
+	private boolean processAccountRecurrences(Account account, Date now) {
+		boolean anyPosted = false;
+
+		anyPosted |= processItemList(account, account.getIncomes(), TransactionType.INCOME, now);
+		anyPosted |= processItemList(account, account.getExpenses(), TransactionType.EXPENSE, now);
+
+		if (anyPosted) {
+			account.setLastSeen(now);
+			accountRepository.save(account);
+		}
+
+		return anyPosted;
+	}
+
+	private boolean processItemList(Account account, List<Item> items, TransactionType type, Date now) {
+		if (items == null) {
+			return false;
+		}
+
+		boolean anyPosted = false;
+
+		for (Item item : items) {
+			RecurrenceConfig config = item.getRecurrenceConfig();
+			if (config == null || !config.isEnabled() || config.getAnchorDate() == null) {
+				continue;
+			}
+
+			if (config.getNextScheduledDate() == null) {
+				config.setNextScheduledDate(
+						RecurrenceCalculator.computeNextDate(config.getAnchorDate(), item.getPeriod(), config.getAnchorDate()));
+				if (config.getNextScheduledDate() == null) {
+					continue;
+				}
+			}
+
+			if (config.getNextScheduledDate().after(now)) {
+				continue;
+			}
+
+			// Determine how many missed dates there are (backfill)
+			List<Date> missedDates = computeMissedDates(config, item.getPeriod(), now);
+
+			for (Date scheduledDate : missedDates) {
+				Transaction transaction = createTransaction(account, item, type, scheduledDate, config, missedDates.size() > 1);
+				try {
+					transactionRepository.save(transaction);
+					if (transaction.getStatus() == TransactionStatus.POSTED) {
+						anyPosted = true;
+					}
+				} catch (org.springframework.dao.DuplicateKeyException e) {
+					log.warn("duplicate transaction skipped for {}/{}/{}", account.getName(), item.getTitle(), scheduledDate);
+				}
+			}
+
+			// Advance nextScheduledDate past now
+			Date nextDate = RecurrenceCalculator.computeNextDate(config.getAnchorDate(), item.getPeriod(), now);
+			config.setNextScheduledDate(nextDate);
+		}
+
+		return anyPosted;
+	}
+
+	private List<Date> computeMissedDates(RecurrenceConfig config, TimePeriod period, Date now) {
+		// Compute a reference point: one period step before the current nextScheduledDate
+		// so that computeDatesBetween starts from the right place
+		Date startFrom = new Date(config.getNextScheduledDate().getTime() - 1);
+		return RecurrenceCalculator.computeDatesBetween(config.getAnchorDate(), period, startFrom, now, maxBackfillCount);
+	}
+
+	private Transaction createTransaction(Account account, Item item, TransactionType type,
+			Date scheduledDate, RecurrenceConfig config, boolean isBackfill) {
+		Transaction transaction = new Transaction();
+		transaction.setAccountName(account.getName());
+		transaction.setType(type);
+		transaction.setTitle(item.getTitle());
+		transaction.setAmount(item.getAmount());
+		transaction.setCurrency(item.getCurrency());
+		transaction.setSourceItemTitle(item.getTitle());
+		transaction.setScheduledDate(scheduledDate);
+
+		// Backfill transactions are always PENDING_REVIEW regardless of autoPost
+		if (isBackfill) {
+			transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+		} else if (config.isAutoPost()) {
+			transaction.setStatus(TransactionStatus.POSTED);
+			transaction.setPostedDate(new Date());
+		} else {
+			transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+		}
+
+		return transaction;
+	}
+}
