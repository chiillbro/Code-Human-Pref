--- /dev/null
+++ b/account-service/src/main/java/com/piggymetrics/account/service/RecurrenceCalculator.java
@@ -0,0 +1,144 @@
+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.domain.TimePeriod;
+
+import java.time.LocalDate;
+import java.time.LocalDateTime;
+import java.time.ZoneId;
+import java.util.ArrayList;
+import java.util.Date;
+import java.util.List;
+
+public class RecurrenceCalculator {
+
+	private RecurrenceCalculator() {
+	}
+
+	/**
+	 * Computes the next N scheduled dates starting after {@code after},
+	 * based on the given anchor date and period.
+	 *
+	 * For MONTH: advances by 1 month, clamping to last day of month
+	 * (e.g., anchor Jan 31 → Feb 28 → Mar 31 → Apr 30).
+	 *
+	 * For QUARTER: advances by 3 months with the same clamping.
+	 * For YEAR: advances by 1 year, handling Feb 29 → Feb 28 in non-leap years.
+	 * For DAY: advances by 1 day.
+	 * For HOUR: advances by 1 hour.
+	 */
+	public static List<Date> computeNextDates(Date anchorDate, TimePeriod period, Date after, int count) {
+		if (anchorDate == null || period == null || after == null || count <= 0) {
+			return new ArrayList<>();
+		}
+
+		List<Date> dates = new ArrayList<>();
+		LocalDateTime anchor = toLocalDateTime(anchorDate);
+		LocalDateTime boundary = toLocalDateTime(after);
+		int anchorDayOfMonth = anchor.getDayOfMonth();
+
+		// Walk forward from anchor until we pass 'after', then collect 'count' dates
+		LocalDateTime current = anchor;
+
+		// First, advance to the first occurrence at or after 'after'
+		while (!current.isAfter(boundary)) {
+			current = advanceByPeriod(current, period, anchorDayOfMonth);
+		}
+
+		// Now collect 'count' dates
+		for (int i = 0; i < count; i++) {
+			dates.add(toDate(current));
+			current = advanceByPeriod(current, period, anchorDayOfMonth);
+		}
+
+		return dates;
+	}
+
+	/**
+	 * Computes the single next scheduled date after {@code after}.
+	 */
+	public static Date computeNextDate(Date anchorDate, TimePeriod period, Date after) {
+		List<Date> dates = computeNextDates(anchorDate, period, after, 1);
+		return dates.isEmpty() ? null : dates.get(0);
+	}
+
+	/**
+	 * Computes all scheduled dates between {@code after} (exclusive) and {@code until} (inclusive),
+	 * capped at {@code maxCount}.
+	 */
+	public static List<Date> computeDatesBetween(Date anchorDate, TimePeriod period, Date after, Date until, int maxCount) {
+		if (anchorDate == null || period == null || after == null || until == null || maxCount <= 0) {
+			return new ArrayList<>();
+		}
+
+		List<Date> dates = new ArrayList<>();
+		LocalDateTime anchor = toLocalDateTime(anchorDate);
+		LocalDateTime boundary = toLocalDateTime(after);
+		LocalDateTime end = toLocalDateTime(until);
+		int anchorDayOfMonth = anchor.getDayOfMonth();
+
+		LocalDateTime current = anchor;
+
+		// Advance to first occurrence after 'after'
+		while (!current.isAfter(boundary)) {
+			current = advanceByPeriod(current, period, anchorDayOfMonth);
+		}
+
+		// Collect dates up to 'until', capped at maxCount
+		while (!current.isAfter(end) && dates.size() < maxCount) {
+			dates.add(toDate(current));
+			current = advanceByPeriod(current, period, anchorDayOfMonth);
+		}
+
+		return dates;
+	}
+
+	private static LocalDateTime advanceByPeriod(LocalDateTime dateTime, TimePeriod period, int anchorDayOfMonth) {
+		switch (period) {
+			case HOUR:
+				return dateTime.plusHours(1);
+			case DAY:
+				return dateTime.plusDays(1);
+			case MONTH:
+				return advanceMonths(dateTime, 1, anchorDayOfMonth);
+			case QUARTER:
+				return advanceMonths(dateTime, 3, anchorDayOfMonth);
+			case YEAR:
+				return advanceYears(dateTime, anchorDayOfMonth);
+			default:
+				throw new IllegalArgumentException("Unsupported period: " + period);
+		}
+	}
+
+	/**
+	 * Advances by N months, clamping day-of-month to the target month's last day.
+	 * E.g., Jan 31 + 1 month = Feb 28 (or 29). Feb 28 + 1 month = Mar 28?
+	 * No — we always use the ORIGINAL anchor day, clamped to the target month's length.
+	 * So anchor=31: Jan 31 → Feb 28 → Mar 31 → Apr 30.
+	 */
+	private static LocalDateTime advanceMonths(LocalDateTime dateTime, int months, int anchorDayOfMonth) {
+		LocalDate date = dateTime.toLocalDate().plusMonths(months);
+		int lastDay = date.lengthOfMonth();
+		int targetDay = Math.min(anchorDayOfMonth, lastDay);
+		date = date.withDayOfMonth(targetDay);
+		return date.atTime(dateTime.toLocalTime());
+	}
+
+	/**
+	 * Advances by 1 year, clamping day-of-month for Feb 29 in non-leap years.
+	 */
+	private static LocalDateTime advanceYears(LocalDateTime dateTime, int anchorDayOfMonth) {
+		LocalDate date = dateTime.toLocalDate().plusYears(1);
+		int lastDay = date.lengthOfMonth();
+		int targetDay = Math.min(anchorDayOfMonth, lastDay);
+		date = date.withDayOfMonth(targetDay);
+		return date.atTime(dateTime.toLocalTime());
+	}
+
+	private static LocalDateTime toLocalDateTime(Date date) {
+		return date.toInstant().atZone(ZoneId.systemDefault()).toLocalDateTime();
+	}
+
+	private static Date toDate(LocalDateTime dateTime) {
+		return Date.from(dateTime.atZone(ZoneId.systemDefault()).toInstant());
+	}
+}
