+		Date anchor = toDate(2023, 1, 31);
+		Date after = toDate(2023, 3, 31);
+
+		Date next = RecurrenceCalculator.computeNextDate(anchor, TimePeriod.MONTH, after);
+
+		assertEquals(toDate(2023, 4, 30), next);
+	}
