+package com.piggymetrics.account.controller;
+
+import com.piggymetrics.account.domain.Transaction;
+import com.piggymetrics.account.domain.TransactionStatus;
+import com.piggymetrics.account.domain.TransactionType;
+import com.piggymetrics.account.service.TransactionService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.data.domain.Page;
+import org.springframework.format.annotation.DateTimeFormat;
+import org.springframework.web.bind.annotation.*;
+
+import java.security.Principal;
+import java.util.Date;
+
+@RestController
+@RequestMapping("/current/transactions")
+public class TransactionController {
+
+	@Autowired
+	private TransactionService transactionService;
+
+	@RequestMapping(method = RequestMethod.GET)
+	public Page<Transaction> getTransactions(
+			Principal principal,
+			@RequestParam(value = "status", required = false) TransactionStatus status,
+			@RequestParam(value = "type", required = false) TransactionType type,
+			@RequestParam(value = "from", required = false) @DateTimeFormat(pattern = "yyyy-MM-dd") Date from,
+			@RequestParam(value = "to", required = false) @DateTimeFormat(pattern = "yyyy-MM-dd") Date to,
+			@RequestParam(value = "page", defaultValue = "0") int page,
+			@RequestParam(value = "size", defaultValue = "20") int size) {
+
+		return transactionService.getTransactions(principal.getName(), status, type, from, to, page, size);
+	}
+
+	@RequestMapping(value = "/{transactionId}", method = RequestMethod.GET)
+	public Transaction getTransaction(Principal principal, @PathVariable String transactionId) {
+		return transactionService.getTransaction(principal.getName(), transactionId);
+	}
+
+	@RequestMapping(value = "/{transactionId}/approve", method = RequestMethod.PUT)
+	public Transaction approveTransaction(Principal principal, @PathVariable String transactionId) {
+		return transactionService.approveTransaction(principal.getName(), transactionId);
+	}
+
+	@RequestMapping(value = "/{transactionId}/skip", method = RequestMethod.PUT)
+	public Transaction skipTransaction(Principal principal, @PathVariable String transactionId) {
+		return transactionService.skipTransaction(principal.getName(), transactionId);
+	}
+
+	@RequestMapping(value = "/{transactionId}", method = RequestMethod.DELETE)
+	public void deleteTransaction(Principal principal, @PathVariable String transactionId) {
+		transactionService.deleteTransaction(principal.getName(), transactionId);
+	}
+}
