+package com.piggymetrics.account.service;
+
+import com.piggymetrics.account.client.StatisticsServiceClient;
+import com.piggymetrics.account.domain.*;
+import com.piggymetrics.account.repository.AccountRepository;
+import com.piggymetrics.account.repository.TransactionRepository;
+import org.junit.Before;
+import org.junit.Test;
+import org.mockito.ArgumentCaptor;
+import org.mockito.InjectMocks;
+import org.mockito.Mock;
+import org.springframework.dao.DuplicateKeyException;
+import org.springframework.data.domain.Page;
+import org.springframework.data.domain.PageImpl;
+import org.springframework.data.domain.Pageable;
+
+import java.math.BigDecimal;
+import java.time.LocalDate;
+import java.time.ZoneId;
+import java.util.ArrayList;
+import java.util.Arrays;
+import java.util.Collections;
+import java.util.Date;
+import java.util.List;
+
+import static org.junit.Assert.*;
+import static org.mockito.Mockito.*;
+import static org.mockito.MockitoAnnotations.initMocks;
+
+public class TransactionServiceImplTest {
+
+	@InjectMocks
+	private TransactionServiceImpl transactionService;
+
+	@Mock
+	private TransactionRepository transactionRepository;
+
+	@Mock
+	private AccountRepository accountRepository;
+
+	@Mock
+	private StatisticsServiceClient statisticsClient;
+
+	@Before
+	public void setup() {
+		initMocks(this);
+	}
+
+	// ========================= getTransactions =========================
+
+	@Test
+	public void shouldGetTransactionsWithNoFilters() {
+		Page<Transaction> page = new PageImpl<>(Collections.emptyList());
+		when(transactionRepository.findByAccountName(eq("test"), any(Pageable.class))).thenReturn(page);
+
+		Page<Transaction> result = transactionService.getTransactions("test", null, null, null, null, 0, 20);
+
+		assertNotNull(result);
+		verify(transactionRepository).findByAccountName(eq("test"), any(Pageable.class));
+	}
+
+	@Test
+	public void shouldGetTransactionsWithStatusFilter() {
+		Page<Transaction> page = new PageImpl<>(Collections.emptyList());
+		when(transactionRepository.findByAccountNameAndStatus(eq("test"), eq(TransactionStatus.POSTED), any(Pageable.class)))
+				.thenReturn(page);
+
+		Page<Transaction> result = transactionService.getTransactions("test", TransactionStatus.POSTED, null, null, null, 0, 20);
+
+		assertNotNull(result);
+		verify(transactionRepository).findByAccountNameAndStatus(eq("test"), eq(TransactionStatus.POSTED), any(Pageable.class));
+	}
+
+	@Test
+	public void shouldGetTransactionsWithAllFilters() {
+		Page<Transaction> page = new PageImpl<>(Collections.emptyList());
+		Date from = new Date();
+		Date to = new Date();
+		when(transactionRepository.findByAccountNameAndStatusAndTypeAndScheduledDateBetween(
+				eq("test"), eq(TransactionStatus.POSTED), eq(TransactionType.EXPENSE),
+				eq(from), eq(to), any(Pageable.class))).thenReturn(page);
+
+		Page<Transaction> result = transactionService.getTransactions("test", TransactionStatus.POSTED,
+				TransactionType.EXPENSE, from, to, 0, 20);
+
+		assertNotNull(result);
+		verify(transactionRepository).findByAccountNameAndStatusAndTypeAndScheduledDateBetween(
+				eq("test"), eq(TransactionStatus.POSTED), eq(TransactionType.EXPENSE),
+				eq(from), eq(to), any(Pageable.class));
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailGetTransactionsWithEmptyAccountName() {
+		transactionService.getTransactions("", null, null, null, null, 0, 20);
+	}
+
+	// ========================= getTransaction =========================
+
+	@Test
+	public void shouldGetTransactionById() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		Transaction result = transactionService.getTransaction("test", "tx-1");
+
+		assertEquals("tx-1", result.getId());
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailGetTransactionWhenNotFound() {
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(null);
+		transactionService.getTransaction("test", "tx-1");
+	}
+
+	// ========================= approveTransaction =========================
+
+	@Test
+	public void shouldApproveTransaction() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		Account account = new Account();
+		account.setName("test");
+		when(accountRepository.findByName("test")).thenReturn(account);
+
+		Transaction result = transactionService.approveTransaction("test", "tx-1");
+
+		assertEquals(TransactionStatus.POSTED, result.getStatus());
+		assertNotNull(result.getPostedDate());
+		verify(transactionRepository).save(transaction);
+		verify(statisticsClient).updateStatistics("test", account);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailApproveWhenNotPendingReview() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		transaction.setStatus(TransactionStatus.POSTED);
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		transactionService.approveTransaction("test", "tx-1");
+	}
+
+	// ========================= skipTransaction =========================
+
+	@Test
+	public void shouldSkipTransaction() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		Transaction result = transactionService.skipTransaction("test", "tx-1");
+
+		assertEquals(TransactionStatus.SKIPPED, result.getStatus());
+		verify(transactionRepository).save(transaction);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailSkipWhenNotPendingReview() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		transaction.setStatus(TransactionStatus.POSTED);
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		transactionService.skipTransaction("test", "tx-1");
+	}
+
+	// ========================= deleteTransaction =========================
+
+	@Test
+	public void shouldDeleteTransaction() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		transaction.setStatus(TransactionStatus.PENDING_REVIEW);
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		transactionService.deleteTransaction("test", "tx-1");
+
+		verify(transactionRepository).delete(transaction);
+	}
+
+	@Test(expected = IllegalArgumentException.class)
+	public void shouldFailDeleteWhenNotPendingReview() {
+		Transaction transaction = new Transaction();
+		transaction.setId("tx-1");
+		transaction.setAccountName("test");
+		transaction.setStatus(TransactionStatus.SKIPPED);
+		when(transactionRepository.findByIdAndAccountName("tx-1", "test")).thenReturn(transaction);
+
+		transactionService.deleteTransaction("test", "tx-1");
+	}
+
+	// ========================= processRecurringTransactions =========================
+
+	@Test
+	public void shouldProcessRecurringTransactionsForAccountWithEnabledRecurrence() {
+		Account account = createAccountWithRecurrence(true, true);
+		when(accountRepository.findAll()).thenReturn(Collections.singletonList(account));
+
+		transactionService.processRecurringTransactions();
+
+		verify(transactionRepository, atLeastOnce()).save(any(Transaction.class));
+		verify(statisticsClient, atLeastOnce()).updateStatistics(eq("test"), eq(account));
+	}
+
+	@Test
+	public void shouldSkipItemsWithDisabledRecurrence() {
+		Account account = createAccountWithRecurrence(false, true);
+		when(accountRepository.findAll()).thenReturn(Collections.singletonList(account));
+
+		transactionService.processRecurringTransactions();
+
+		verify(transactionRepository, never()).save(any(Transaction.class));
+	}
+
+	@Test
+	public void shouldCreatePendingReviewTransactionWhenAutoPostDisabled() {
+		Account account = createAccountWithRecurrence(true, false);
+		when(accountRepository.findAll()).thenReturn(Collections.singletonList(account));
+
+		ArgumentCaptor<Transaction> captor = ArgumentCaptor.forClass(Transaction.class);
+
+		transactionService.processRecurringTransactions();
+
+		verify(transactionRepository, atLeastOnce()).save(captor.capture());
+
+		// single (non-backfill) transaction with autoPost=false should be PENDING_REVIEW
+		Transaction saved = captor.getValue();
+		assertEquals(TransactionStatus.PENDING_REVIEW, saved.getStatus());
+	}
+
+	@Test
+	public void shouldHandleDuplicateKeyExceptionGracefully() {
+		Account account = createAccountWithRecurrence(true, true);
+		when(accountRepository.findAll()).thenReturn(Collections.singletonList(account));
+		doThrow(new DuplicateKeyException("duplicate")).when(transactionRepository).save(any(Transaction.class));
+
+		// Should not throw — DuplicateKeyException is expected to be caught
+		transactionService.processRecurringTransactions();
+	}
+
+	@Test
+	public void shouldHandleExceptionForSingleAccountWithoutAffectingOthers() {
+		Account badAccount = new Account();
+		badAccount.setName("bad");
+		// null incomes/expenses will cause issues if not handled
+
+		Account goodAccount = createAccountWithRecurrence(true, true);
+
+		when(accountRepository.findAll()).thenReturn(Arrays.asList(badAccount, goodAccount));
+
+		// Should not throw — errors for individual accounts are caught
+		transactionService.processRecurringTransactions();
+	}
+
+	@Test
+	public void shouldAdvanceNextScheduledDateAfterProcessing() {
+		Account account = createAccountWithRecurrence(true, true);
+		when(accountRepository.findAll()).thenReturn(Collections.singletonList(account));
+
+		transactionService.processRecurringTransactions();
+
+		// nextScheduledDate should have been advanced past now
+		Item income = account.getIncomes().get(0);
+		RecurrenceConfig config = income.getRecurrenceConfig();
+		assertNotNull(config.getNextScheduledDate());
+		assertTrue("nextScheduledDate should be in the future",
+				config.getNextScheduledDate().after(new Date(System.currentTimeMillis() - 60000)));
+	}
+
+	// ========================= helpers =========================
+
+	private Account createAccountWithRecurrence(boolean enabled, boolean autoPost) {
+		// Anchor date 2 days ago so there's a missed date to process
+		Date anchorDate = Date.from(LocalDate.now().minusDays(2)
+				.atStartOfDay(ZoneId.systemDefault()).toInstant());
+		Date nextScheduledDate = Date.from(LocalDate.now().minusDays(1)
+				.atStartOfDay(ZoneId.systemDefault()).toInstant());
+
+		RecurrenceConfig config = new RecurrenceConfig();
+		config.setEnabled(enabled);
+		config.setAnchorDate(anchorDate);
+		config.setNextScheduledDate(nextScheduledDate);
+		config.setAutoPost(autoPost);
+
+		Item salary = new Item();
+		salary.setTitle("Salary");
+		salary.setAmount(new BigDecimal(9100));
+		salary.setCurrency(Currency.USD);
+		salary.setPeriod(TimePeriod.DAY);
+		salary.setIcon("wallet");
+		salary.setRecurrenceConfig(config);
+
+		Account account = new Account();
+		account.setName("test");
+		account.setNote("test");
+		account.setLastSeen(new Date());
+		account.setIncomes(new ArrayList<>(Collections.singletonList(salary)));
+		account.setExpenses(new ArrayList<>());
+
+		Saving saving = new Saving();
+		saving.setAmount(new BigDecimal(0));
+		saving.setCurrency(Currency.getDefault());
+		saving.setInterest(new BigDecimal(0));
+		saving.setDeposit(false);
+		saving.setCapitalization(false);
+		account.setSaving(saving);
+
+		return account;
+	}
+}
