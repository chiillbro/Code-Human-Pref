     ops = compute_diff(current, desired)
     assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+# --- Rename detection ---
+
+def test_rename_column_detected():
+    """A column disappears and a new one with same type/nullable/default/unique appears -> rename."""
+    cols_old = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="name", type="TEXT", nullable=False),
+    )
+    cols_new = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="full_name", type="TEXT", nullable=False),
+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    rename_ops = [op for op in ops if isinstance(op, RenameColumn)]
+    assert len(rename_ops) == 1
+    assert rename_ops[0].old_name == "name"
+    assert rename_ops[0].new_name == "full_name"
+    # Should NOT be a reconstruct (rename is simple ALTER TABLE RENAME COLUMN)
+    assert not any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_rename_column_with_different_type_is_not_rename():
+    """If the type changes alongside the name change, it's not a rename — it's a reconstruct."""
+    cols_old = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="name", type="TEXT", nullable=False),
+    )
+    cols_new = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="full_name", type="INTEGER", nullable=False),
+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    assert not any(isinstance(op, RenameColumn) for op in ops)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_rename_column_with_default_match():
+    """Rename detected when default values also match."""
+    cols_old = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="status", type="INTEGER", nullable=False, default="0"),
+    )
+    cols_new = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="state", type="INTEGER", nullable=False, default="0"),
+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    rename_ops = [op for op in ops if isinstance(op, RenameColumn)]
+    assert len(rename_ops) == 1
+    assert rename_ops[0].old_name == "status"
+    assert rename_ops[0].new_name == "state"
+
+
+def test_rename_plus_add_column():
+    """A rename and an unrelated add can coexist."""
+    cols_old = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="name", type="TEXT"),
+    )
+    cols_new = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="full_name", type="TEXT"),
+        ColumnDef(name="bio", type="TEXT"),
+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    rename_ops = [op for op in ops if isinstance(op, RenameColumn)]
+    add_ops = [op for op in ops if isinstance(op, AddColumn)]
+    assert len(rename_ops) == 1
+    assert rename_ops[0].old_name == "name"
+    assert rename_ops[0].new_name == "full_name"
+    assert len(add_ops) == 1
+    assert add_ops[0].column.name == "bio"
+
+
+def test_rename_with_reconstruct_carries_mapping():
+    """When a rename happens alongside a PK change (requiring reconstruct),
+    the ReconstructTable op carries the rename info."""
+    cols_old = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="name", type="TEXT"),
+    )
+    cols_new = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="full_name", type="TEXT"),
+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old, pk=("id",))})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new, pk=("id", "full_name"))})
+    ops = compute_diff(current, desired)
+    recon_ops = [op for op in ops if isinstance(op, ReconstructTable)]
+    assert len(recon_ops) == 1
+    assert ("name", "full_name") in recon_ops[0].column_renames
+
+
+# --- FK dependency ordering (3-level chain) ---
+
+def test_create_three_level_fk_chain_in_order():
+    """users -> orders -> audit_log should be created in that order."""
+    users = _simple_table("users")
+    fk_orders = ForeignKeyDef(
+        columns=("user_id",), ref_table="users", ref_columns=("id",)
+    )
+    orders = _simple_table(
+        "orders",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="user_id", type="INTEGER"),
+        ),
+        fks=(fk_orders,),
+    )
+    fk_audit = ForeignKeyDef(
+        columns=("order_id",), ref_table="orders", ref_columns=("id",)
+    )
+    audit_log = _simple_table(
+        "audit_log",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="order_id", type="INTEGER"),
+        ),
+        fks=(fk_audit,),
+    )
+    current = SchemaDef(tables={})
+    desired = SchemaDef(tables={
+        "audit_log": audit_log, "orders": orders, "users": users,
+    })
+    ops = compute_diff(current, desired)
+    create_ops = [op for op in ops if isinstance(op, CreateTable)]
