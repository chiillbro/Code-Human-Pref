index 0000000..4f5dd85
--- /dev/null
+++ b/src/vijaybase/commands/diff_cmd.py
@@ -0,0 +1,129 @@
+from __future__ import annotations
+
+import argparse
+
+from vijaybase.config import load_config
+from vijaybase.diff import (
+    AddColumn,
+    AddIndex,
+    CreateTable,
+    DropColumn,
+    DropIndex,
+    DropTable,
+    ReconstructTable,
+    RenameColumn,
+    compute_diff,
+)
+from vijaybase.introspector import introspect_database
+from vijaybase.schema_parser import parse_schema_dir, validate_schema
+
+
+def run_diff(args: argparse.Namespace) -> int:
+    config = load_config()
+
+    desired = parse_schema_dir(config.schema_path)
+    if not desired.tables:
+        print("No schema files found. Add .yaml files to the schema/ directory.")
+        return 1
+    errors = validate_schema(desired)
+    if errors:
+        print("Schema validation failed:")
+        for err in errors:
+            print(f"  - {err}")
+        return 1
+
+    current = introspect_database(config.database_path)
+    ops = compute_diff(current, desired)
+
+    if not ops:
+        print("No changes detected. Database schema matches YAML definition.")
+        return 0
+
+    print(f"Detected {len(ops)} operation(s):\n")
+    for op in ops:
+        print(f"  {_format_op(op)}")
+
+    print()
+    print("Run 'vijaybase generate <description>' to create a migration from these changes.")
+    return 0
+
+
+def _format_op(op) -> str:
+    if isinstance(op, CreateTable):
+        cols = ", ".join(c.name for c in op.table.columns)
+        return f"+ Create table '{op.table.name}' ({cols})"
+    elif isinstance(op, DropTable):
+        return f"- Drop table '{op.table.name}'"
+    elif isinstance(op, AddColumn):
+        nullable = "" if op.column.nullable else " NOT NULL"
+        default = f" DEFAULT {op.column.default}" if op.column.default else ""
+        return (
+            f"+ Add column '{op.table_name}.{op.column.name}' "
+            f"{op.column.type}{nullable}{default}"
+        )
+    elif isinstance(op, DropColumn):
+        return f"- Drop column '{op.table_name}.{op.column.name}'"
+    elif isinstance(op, RenameColumn):
+        return (
+            f"~ Rename column '{op.table_name}.{op.old_name}' "
+            f"-> '{op.new_name}'"
+        )
+    elif isinstance(op, AddIndex):
+        unique = "unique " if op.index.unique else ""
+        cols = ", ".join(op.index.columns)
+        return (
+            f"+ Add {unique}index '{op.index.name}' "
+            f"on '{op.index.table}' ({cols})"
+        )
+    elif isinstance(op, DropIndex):
+        return f"- Drop index '{op.index.name}'"
+    elif isinstance(op, ReconstructTable):
+        changes = _describe_reconstruct(op)
+        return (
+            f"~ Reconstruct table '{op.table_name}' ({changes})"
+        )
+    return f"  {op}"
+
+
+def _describe_reconstruct(op: ReconstructTable) -> str:
+    """Build a human-readable summary of what changed inside a ReconstructTable."""
+    parts: list[str] = []
+
+    old_cols = {c.name for c in op.old_table.columns}
+    new_cols = {c.name for c in op.new_table.columns}
+    rename_map = dict(op.column_renames)
+    reverse_rename = {v: k for k, v in rename_map.items()}
+
+    # Renamed columns
+    for old_name, new_name in op.column_renames:
+        parts.append(f"rename {old_name} -> {new_name}")
+
+    # Truly added columns (not renames)
+    for name in sorted(new_cols - old_cols):
+        if name not in reverse_rename:
+            parts.append(f"add column {name}")
+
+    # Truly dropped columns (not renames)
+    for name in sorted(old_cols - new_cols):
+        if name not in rename_map:
+            parts.append(f"drop column {name}")
+
+    # Modified columns
+    old_col_map = {c.name: c for c in op.old_table.columns}
+    new_col_map = {c.name: c for c in op.new_table.columns}
+    for name in sorted(old_cols & new_cols):
+        if old_col_map[name] != new_col_map[name]:
+            parts.append(f"alter column {name}")
+
+    if op.old_table.primary_key != op.new_table.primary_key:
+        parts.append("change primary key")
+
+    if frozenset(op.old_table.foreign_keys) != frozenset(op.new_table.foreign_keys):
+        parts.append("change foreign keys")
+
+    old_checks = frozenset(c.expression for c in op.old_table.checks)
+    new_checks = frozenset(c.expression for c in op.new_table.checks)
+    if old_checks != new_checks:
+        parts.append("change constraints")
+
+    return ", ".join(parts) if parts else "rebuild"


