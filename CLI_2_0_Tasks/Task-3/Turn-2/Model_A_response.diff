+def test_three_level_fk_create_and_drop(tmp_path, monkeypatch):
+    """users -> orders -> audit_log: create in order, drop in reverse."""
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+
+    schema = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      name:
+        type: TEXT
+        nullable: false
+  orders:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      user_id:
+        type: INTEGER
+        nullable: false
+    foreign_keys:
+      - columns: [user_id]
+        references:
+          table: users
+          columns: [id]
+        on_delete: CASCADE
+  audit_log:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      order_id:
+        type: INTEGER
+        nullable: false
+    foreign_keys:
+      - columns: [order_id]
+        references:
+          table: orders
+          columns: [id]
+        on_delete: CASCADE
+"""
+    (tmp_path / "schema" / "all.yaml").write_text(schema)
+    assert main(["generate", "initial"]) == 0
+    assert main(["apply"]) == 0
+
+    # Verify all tables exist and FK constraints work
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    conn.execute("PRAGMA foreign_keys = ON")
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert {"users", "orders", "audit_log"}.issubset(tables)
+
+    conn.execute("INSERT INTO users (id, name) VALUES (1, 'Alice')")
+    conn.execute("INSERT INTO orders (id, user_id) VALUES (1, 1)")
+    conn.execute("INSERT INTO audit_log (id, order_id) VALUES (1, 1)")
+    conn.commit()
+
+    # Cascade delete: deleting user cascades to orders, which cascades to audit_log
+    conn.execute("DELETE FROM users WHERE id = 1")
+    conn.commit()
+    assert conn.execute("SELECT COUNT(*) FROM orders").fetchone()[0] == 0
+    assert conn.execute("SELECT COUNT(*) FROM audit_log").fetchone()[0] == 0
+    conn.close()
+
+    # Rollback should drop in correct order (audit_log, orders, users)
+    assert main(["rollback"]) == 0
+
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert "users" not in tables
+    assert "orders" not in tables
+    assert "audit_log" not in tables
+    conn.close()
