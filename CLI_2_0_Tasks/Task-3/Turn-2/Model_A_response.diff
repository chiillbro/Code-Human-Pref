+def test_column_rename_preserves_data(tmp_path, monkeypatch):
+    """Renaming a column should preserve data, not drop+add."""
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+
+    schema_v1 = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      name:
+        type: TEXT
+        nullable: false
+"""
+    (tmp_path / "schema" / "users.yaml").write_text(schema_v1)
+    main(["generate", "initial"])
+    main(["apply"])
+
+    # Insert data
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    conn.execute("INSERT INTO users (id, name) VALUES (1, 'Alice')")
+    conn.execute("INSERT INTO users (id, name) VALUES (2, 'Bob')")
+    conn.commit()
+    conn.close()
+
+    # Rename name -> full_name (same type, nullable, default, unique)
+    schema_v2 = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      full_name:
+        type: TEXT
+        nullable: false
+"""
+    (tmp_path / "schema" / "users.yaml").write_text(schema_v2)
+    assert main(["generate", "rename_name_to_full_name"]) == 0
+    assert main(["apply"]) == 0
+
+    # Data should be preserved under the new column name
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    rows = conn.execute("SELECT full_name FROM users ORDER BY id").fetchall()
+    assert rows == [("Alice",), ("Bob",)]
+
+    cols = {r[1] for r in conn.execute("PRAGMA table_info(users)").fetchall()}
+    assert "full_name" in cols
+    assert "name" not in cols
+    conn.close()
+
+    # Rollback should restore the old column name and data
+    assert main(["rollback"]) == 0
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    rows = conn.execute("SELECT name FROM users ORDER BY id").fetchall()
+    assert rows == [("Alice",), ("Bob",)]
