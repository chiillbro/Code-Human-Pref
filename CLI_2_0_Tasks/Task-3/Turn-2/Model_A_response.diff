+
+
+def test_diff_shows_changes(tmp_path, monkeypatch, sample_schema_yaml, capsys):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+
+    # Diff before any migrations applied (all tables are new)
+    rc = main(["diff"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "Create table" in output
+    assert "users" in output
+
+
+def test_diff_no_changes(tmp_path, monkeypatch, sample_schema_yaml, capsys):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+    main(["generate", "initial"])
+    main(["apply"])
+
+    rc = main(["diff"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "No changes" in output
+
+
+def test_diff_shows_rename(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    schema_v1 = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      name:
+        type: TEXT
+        nullable: false
+"""
+    (tmp_path / "schema" / "users.yaml").write_text(schema_v1)
+    main(["generate", "initial"])
+    main(["apply"])
+    capsys.readouterr()  # clear
+
+    # Rename name -> full_name
+    schema_v2 = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      full_name:
+        type: TEXT
+        nullable: false
+"""
+    (tmp_path / "schema" / "users.yaml").write_text(schema_v2)
+    rc = main(["diff"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "Rename column" in output
+    assert "name" in output
+    assert "full_name" in output
