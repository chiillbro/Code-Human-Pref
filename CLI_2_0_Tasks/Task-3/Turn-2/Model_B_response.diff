+def _detect_renames(
+    cur_cols: dict[str, ColumnDef],
+    des_cols: dict[str, ColumnDef],
+    removed: set[str],
+    added: set[str],
+) -> list[tuple[str, str]]:
+    """Match removed columns to added columns with identical signatures.
+
+    Returns list of (old_name, new_name) pairs. Each column participates
+    in at most one rename (greedy 1:1 matching).
+    """
+    if not removed or not added:
+        return []
+
+    # Build signature -> list of column names for each side
+    removed_by_sig: dict[tuple, list[str]] = {}
+    for name in sorted(removed):
+        sig = _column_signature(cur_cols[name])
+        removed_by_sig.setdefault(sig, []).append(name)
+
+    added_by_sig: dict[tuple, list[str]] = {}
+    for name in sorted(added):
+        sig = _column_signature(des_cols[name])
+        added_by_sig.setdefault(sig, []).append(name)
+
+    renames: list[tuple[str, str]] = []
+    for sig, old_names in removed_by_sig.items():
+        new_names = added_by_sig.get(sig, [])
+        # Pair them 1:1 in sorted order
+        for old_name, new_name in zip(old_names, new_names):
+            renames.append((old_name, new_name))
+
+    return renames
