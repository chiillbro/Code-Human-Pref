+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old, pk=())})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new, pk=())})
+    ops = compute_diff(current, desired)
+    # Rename should still be detected
+    rename_ops = [op for op in ops if isinstance(op, RenameColumn)]
+    assert len(rename_ops) == 1
