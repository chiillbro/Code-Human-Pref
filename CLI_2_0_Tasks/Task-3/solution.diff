+"""Tests for the schema parser."""
+
+import tempfile
+from pathlib import Path
+
+import pytest
+
+from schemav.schema_parser import load_schema, parse_schema_file
+
+
+def _write_yaml(tmpdir: Path, filename: str, content: str) -> Path:
+    path = tmpdir / filename
+    path.write_text(content, encoding="utf-8")
+    return path
+
+
+class TestParseSchemaFile:
+    def test_valid_single_table(self, tmp_path):
+        content = """
+tables:
+  users:
+    columns:
+      - name: id
+        type: INTEGER
+        nullable: false
+      - name: email
+        type: TEXT
+        nullable: false
+        unique: true
+      - name: created_at
+        type: DATETIME
+    primary_key: id
+"""
+        path = _write_yaml(tmp_path, "users.yaml", content)
+        tables, errors = parse_schema_file(path)
+        assert not errors
+        assert "users" in tables
+        t = tables["users"]
+        assert len(t.columns) == 3
+        assert t.primary_key == ["id"]
+        assert t.columns[1].unique is True
+        assert t.columns[0].nullable is False
+
+    def test_valid_composite_primary_key(self, tmp_path):
+        content = """
+tables:
