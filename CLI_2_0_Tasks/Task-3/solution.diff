+    columns:
+      - name: order_id
+        type: INTEGER
+        nullable: false
+      - name: product_id
+        type: INTEGER
+        nullable: false
+      - name: quantity
+        type: INTEGER
+    primary_key:
+      - order_id
+      - product_id
+"""
+        path = _write_yaml(tmp_path, "order_items.yaml", content)
+        tables, errors = parse_schema_file(path)
+        assert not errors
+        assert tables["order_items"].primary_key == ["order_id", "product_id"]
+
+    def test_valid_with_indexes(self, tmp_path):
+        content = """
+tables:
+  users:
+    columns:
+      - name: id
+        type: INTEGER
+      - name: email
+        type: TEXT
+    indexes:
+      - name: idx_users_email
+        columns: [email]
+        unique: true
+"""
+        path = _write_yaml(tmp_path, "users.yaml", content)
+        tables, errors = parse_schema_file(path)
