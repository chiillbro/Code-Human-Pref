@@ -0,0 +1,208 @@
+"""Conflict detector — builds migration DAG, detects branches, diamonds, and creates merge migrations."""
+
+from __future__ import annotations
+
+import datetime
+from collections import defaultdict
+from pathlib import Path
+
+from schemav.models import Migration
+from schemav.migration_generator import write_migration_file
+
+
+class MigrationConflict:
+    def __init__(self, parent_id: str | None, branch_ids: list[str]):
+        self.parent_id = parent_id
+        self.branch_ids = branch_ids
+
+    def __repr__(self) -> str:
+        return f"MigrationConflict(parent={self.parent_id!r}, branches={self.branch_ids})"
+
+
+def build_dependency_graph(
+    migrations: dict[str, Migration],
+) -> tuple[dict[str | None, list[str]], dict[str, str | None]]:
+    """Build parent->children and child->parent mappings.
+
+    Returns:
+        children_of: mapping from parent_id (or None for roots) to list of child migration IDs
+        parent_of: mapping from migration_id to its parent_id (or None)
+    """
+    children_of: dict[str | None, list[str]] = defaultdict(list)
+    parent_of: dict[str, str | None] = {}
+
+    for mid, mig in migrations.items():
+        parent_of[mid] = mig.depends_on
+        children_of[mig.depends_on].append(mid)
+
+    return dict(children_of), parent_of
+
+
+def find_leaf_migrations(
+    migrations: dict[str, Migration],
+    children_of: dict[str | None, list[str]],
+) -> list[str]:
+    """Find migration IDs that have no children (leaf nodes)."""
+    all_ids = set(migrations.keys())
+    has_children = set()
+    for parent, kids in children_of.items():
+        if parent is not None:
+            has_children.update(kid for kid in kids if kid in all_ids)
+        # The parent itself has children
+    # A leaf is a migration that is never a parent
+    parents_with_children = set()
+    for kids in children_of.values():
+        for kid in kids:
+            if kid in all_ids:
+                parent = migrations[kid].depends_on
+                if parent is not None:
+                    parents_with_children.add(parent)
+
+    # Leaf = not a parent of anyone
+    non_leaf = set()
+    for kids in children_of.values():
+        for kid in kids:
+            parent = migrations.get(kid)
+            if parent:
+                dep = parent.depends_on
+                if dep:
+                    non_leaf.add(dep)
+
+    leaves = [mid for mid in all_ids if mid not in non_leaf]
+    return sorted(leaves)
+
+
+def detect_conflicts(migrations: dict[str, Migration]) -> list[MigrationConflict]:
+    """Detect branch points where multiple migrations share the same depends_on parent."""
+    children_of, _ = build_dependency_graph(migrations)
+    conflicts: list[MigrationConflict] = []
+
+    for parent_id, children in children_of.items():
+        # Filter to only children that actually exist in our migrations set
+        existing_children = [c for c in children if c in migrations]
+        if len(existing_children) > 1:
+            conflicts.append(MigrationConflict(
+                parent_id=parent_id,
+                branch_ids=sorted(existing_children),
+            ))
+
+    return conflicts
+
+
+def detect_diamond_patterns(migrations: dict[str, Migration]) -> list[dict]:
+    """Detect diamond patterns: two branches that diverge from a common ancestor
+    and independently converge on a common descendant.
+
+    Returns list of dicts with 'diverge_at', 'branches', 'converge_at'."""
+    children_of, parent_of = build_dependency_graph(migrations)
+    diamonds: list[dict] = []
+
+    # Find all fork points
+    fork_points: dict[str | None, list[str]] = {}
+    for parent_id, children in children_of.items():
+        existing = [c for c in children if c in migrations]
+        if len(existing) > 1:
+            fork_points[parent_id] = existing
+
+    # For each fork point, trace each branch to see if they converge
+    for fork_id, branches in fork_points.items():
+        # Build all descendants for each branch
+        branch_descendants: dict[str, set[str]] = {}
+        for branch_root in branches:
+            descendants: set[str] = set()
+            queue = [branch_root]
+            while queue:
+                current = queue.pop(0)
+                descendants.add(current)
+                for child in children_of.get(current, []):
+                    if child in migrations and child not in descendants:
+                        queue.append(child)
+            branch_descendants[branch_root] = descendants
+
+        # Check if any migration appears in multiple branch descendant sets
+        all_descendants: dict[str, list[str]] = defaultdict(list)
+        for branch_root, descs in branch_descendants.items():
+            for d in descs:
+                if d != branch_root:
+                    all_descendants[d].append(branch_root)
+
+        for convergence_point, from_branches in all_descendants.items():
+            if len(from_branches) > 1:
+                diamonds.append({
+                    "diverge_at": fork_id,
+                    "branches": sorted(from_branches),
+                    "converge_at": convergence_point,
+                })
+
+    return diamonds
+
+
+def get_migration_order(migrations: dict[str, Migration]) -> list[str]:
+    """Topological sort of migrations by dependency order.
+    Raises ValueError if cycles are detected."""
+    children_of, parent_of = build_dependency_graph(migrations)
+
+    # Kahn's algorithm
+    in_degree: dict[str, int] = {mid: 0 for mid in migrations}
+    for mid in migrations:
+        if parent_of[mid] is not None and parent_of[mid] in migrations:
+            in_degree[mid] = 1
+
+    queue = sorted([mid for mid, deg in in_degree.items() if deg == 0])
+    result: list[str] = []
+
+    while queue:
+        current = queue.pop(0)
+        result.append(current)
+        for child in sorted(children_of.get(current, [])):
+            if child in migrations:
+                in_degree[child] -= 1
+                if in_degree[child] == 0:
+                    queue.append(child)
+
+    if len(result) != len(migrations):
+        missing = set(migrations) - set(result)
+        raise ValueError(
+            f"Cycle detected in migration dependencies among: {sorted(missing)}"
+        )
+
+    return result
+
+
+def create_merge_migration(
+    migrations: dict[str, Migration],
+    migrations_dir: Path,
+    description: str = "merge_branches",
+) -> Migration:
+    """Create a merge migration that depends on all current leaf migrations.
+
+    The merge migration has empty up/down SQL — it's a structural bookmark."""
+    children_of, _ = build_dependency_graph(migrations)
+    leaves = find_leaf_migrations(migrations, children_of)
+
+    if len(leaves) < 2:
+        raise ValueError("No conflicting branches to merge (fewer than 2 leaf migrations)")
+
+    timestamp = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%d%H%M%S")
+    slug = Migration.slug_from_description(description)
+    migration_id = f"{timestamp}_{slug}"
+
+    # The merge migration depends on the first leaf (primary parent).
+    # We store all leaf dependencies as a note in the description.
+    merge_mig = Migration(
+        migration_id=migration_id,
+        description=f"Merge migration: depends on {', '.join(leaves)}",
+        depends_on=leaves[0],  # primary parent
+        up_sql=[
+            f"-- Merge migration: structural bookmark merging branches: {', '.join(leaves)}",
+            "-- This migration has no SQL statements.",
+            "-- Generate a new migration from the merged state to bring the schema up to date.",
+        ],
+        down_sql=[
+            f"-- Undo merge: this was a structural bookmark for branches: {', '.join(leaves)}",
+            "-- No SQL statements to reverse.",
+        ],
+    )
+
+    write_migration_file(merge_mig, migrations_dir)
+    return merge_mig
