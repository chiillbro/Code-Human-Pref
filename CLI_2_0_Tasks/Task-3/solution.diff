+"""Tests for the diff engine."""
+
+import pytest
+
+from schemav.diff_engine import diff_schemas, diff_tables
+from schemav.models import (
+    CheckConstraint,
+    Column,
+    ColumnType,
+    DiffOpType,
+    ForeignKey,
+    Index,
+    OnDeleteAction,
+    Schema,
+    Table,
+)
+
+
+def _make_table(name, columns, **kwargs):
+    return Table(name=name, columns=columns, **kwargs)
+
+
+class TestDiffTables:
+    def test_add_column(self):
+        old = _make_table("t", [Column("id", ColumnType.INTEGER)])
+        new = _make_table("t", [Column("id", ColumnType.INTEGER), Column("name", ColumnType.TEXT)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ADD_COLUMN
+        assert ops[0].details["column_name"] == "name"
+
+    def test_drop_column(self):
+        old = _make_table("t", [Column("id", ColumnType.INTEGER), Column("name", ColumnType.TEXT)])
+        new = _make_table("t", [Column("id", ColumnType.INTEGER)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.DROP_COLUMN
+        assert ops[0].details["column_name"] == "name"
+        assert ops[0].lossy is True
+
+    def test_alter_column_type(self):
+        old = _make_table("t", [Column("val", ColumnType.INTEGER)])
+        new = _make_table("t", [Column("val", ColumnType.TEXT)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ALTER_COLUMN
+        assert "type" in ops[0].details["changes"]
+
+    def test_alter_column_nullability(self):
+        old = _make_table("t", [Column("val", ColumnType.TEXT, nullable=True)])
+        new = _make_table("t", [Column("val", ColumnType.TEXT, nullable=False)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ALTER_COLUMN
+        assert "nullable" in ops[0].details["changes"]
+
+    def test_alter_column_default(self):
+        old = _make_table("t", [Column("val", ColumnType.TEXT, default=None)])
+        new = _make_table("t", [Column("val", ColumnType.TEXT, default="'hello'")])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ALTER_COLUMN
+
+    def test_add_index(self):
+        idx = Index("idx_val", ("val",), unique=False)
+        old = _make_table("t", [Column("val", ColumnType.TEXT)])
+        new = _make_table("t", [Column("val", ColumnType.TEXT)], indexes=[idx])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ADD_INDEX
+
+    def test_drop_index(self):
+        idx = Index("idx_val", ("val",), unique=False)
+        old = _make_table("t", [Column("val", ColumnType.TEXT)], indexes=[idx])
+        new = _make_table("t", [Column("val", ColumnType.TEXT)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.DROP_INDEX
+
+    def test_add_foreign_key(self):
+        fk = ForeignKey(("user_id",), "users", ("id",), OnDeleteAction.CASCADE)
+        old = _make_table("t", [Column("user_id", ColumnType.INTEGER)])
+        new = _make_table("t", [Column("user_id", ColumnType.INTEGER)], foreign_keys=[fk])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ADD_FOREIGN_KEY
+
+    def test_drop_foreign_key(self):
+        fk = ForeignKey(("user_id",), "users", ("id",), OnDeleteAction.CASCADE)
+        old = _make_table("t", [Column("user_id", ColumnType.INTEGER)], foreign_keys=[fk])
+        new = _make_table("t", [Column("user_id", ColumnType.INTEGER)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.DROP_FOREIGN_KEY
+
+    def test_add_constraint(self):
+        con = CheckConstraint("chk_pos", "val > 0")
+        old = _make_table("t", [Column("val", ColumnType.INTEGER)])
+        new = _make_table("t", [Column("val", ColumnType.INTEGER)], constraints=[con])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.ADD_CONSTRAINT
+
+    def test_drop_constraint(self):
+        con = CheckConstraint("chk_pos", "val > 0")
+        old = _make_table("t", [Column("val", ColumnType.INTEGER)], constraints=[con])
+        new = _make_table("t", [Column("val", ColumnType.INTEGER)])
+        ops = diff_tables(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.DROP_CONSTRAINT
+
+    def test_potential_rename_detection(self):
+        """Same type, same position, different name -> potential rename."""
+        old = _make_table("t", [
+            Column("id", ColumnType.INTEGER),
+            Column("old_name", ColumnType.TEXT),
+        ])
+        new = _make_table("t", [
+            Column("id", ColumnType.INTEGER),
+            Column("new_name", ColumnType.TEXT),
+        ])
+        ops = diff_tables(old, new)
+        rename_ops = [o for o in ops if o.op_type == DiffOpType.POTENTIAL_RENAME_COLUMN]
+        assert len(rename_ops) == 1
+        assert rename_ops[0].details["old_name"] == "old_name"
+        assert rename_ops[0].details["new_name"] == "new_name"
+
+    def test_no_false_rename_different_type(self):
+        """Different type at same position -> NOT a rename, just drop+add."""
+        old = _make_table("t", [
+            Column("id", ColumnType.INTEGER),
+            Column("old_name", ColumnType.TEXT),
+        ])
+        new = _make_table("t", [
+            Column("id", ColumnType.INTEGER),
+            Column("new_name", ColumnType.INTEGER),
+        ])
+        ops = diff_tables(old, new)
+        rename_ops = [o for o in ops if o.op_type == DiffOpType.POTENTIAL_RENAME_COLUMN]
+        assert len(rename_ops) == 0
+
+    def test_no_changes(self):
+        cols = [Column("id", ColumnType.INTEGER), Column("name", ColumnType.TEXT)]
+        old = _make_table("t", cols)
+        new = _make_table("t", cols)
+        ops = diff_tables(old, new)
+        assert len(ops) == 0
+
+
+class TestDiffSchemas:
+    def test_add_table(self):
+        old = Schema(tables={})
+        new = Schema(tables={"users": _make_table("users", [Column("id", ColumnType.INTEGER)])})
+        ops = diff_schemas(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.CREATE_TABLE
+
+    def test_drop_table(self):
+        old = Schema(tables={"users": _make_table("users", [Column("id", ColumnType.INTEGER)])})
+        new = Schema(tables={})
+        ops = diff_schemas(old, new)
+        assert len(ops) == 1
+        assert ops[0].op_type == DiffOpType.DROP_TABLE
+        assert ops[0].lossy is True
+
+    def test_combined_add_drop_modify(self):
+        old = Schema(tables={
+            "users": _make_table("users", [Column("id", ColumnType.INTEGER)]),
+            "old_table": _make_table("old_table", [Column("x", ColumnType.TEXT)]),
+        })
+        new = Schema(tables={
+            "users": _make_table("users", [
+                Column("id", ColumnType.INTEGER),
+                Column("email", ColumnType.TEXT),
+            ]),
+            "new_table": _make_table("new_table", [Column("y", ColumnType.TEXT)]),
+        })
+        ops = diff_schemas(old, new)
+        op_types = {o.op_type for o in ops}
+        assert DiffOpType.DROP_TABLE in op_types
+        assert DiffOpType.CREATE_TABLE in op_types
+        assert DiffOpType.ADD_COLUMN in op_types
