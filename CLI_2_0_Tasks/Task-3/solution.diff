@@ -0,0 +1,375 @@
+"""Migration file generator — turns DiffOps into migration YAML files with up/down SQL."""
+
+from __future__ import annotations
+
+import datetime
+import yaml
+from collections import defaultdict
+from pathlib import Path
+
+from schemav.models import (
+    DiffOp,
+    DiffOpType,
+    Migration,
+    Table,
+)
+
+
+def _table_create_sql(table: Table) -> str:
+    parts: list[str] = []
+    for col in table.columns:
+        parts.append(f"  {col.to_sql_fragment()}")
+
+    if table.primary_key:
+        pk_cols = ", ".join(f'"{c}"' for c in table.primary_key)
+        parts.append(f"  PRIMARY KEY ({pk_cols})")
+
+    for fk in table.foreign_keys:
+        parts.append(f"  {fk.to_sql_fragment()}")
+
+    for con in table.constraints:
+        parts.append(f"  {con.to_sql_fragment()}")
+
+    body = ",\n".join(parts)
+    return f'CREATE TABLE "{table.name}" (\n{body}\n);'
+
+
+def _table_drop_sql(table_name: str) -> str:
+    return f'DROP TABLE IF EXISTS "{table_name}";'
+
+
+def _topological_sort_tables(tables: list[Table]) -> list[Table]:
+    """Sort tables by foreign key dependencies so referenced tables are created first.
+    Raises ValueError if circular foreign key dependencies are detected."""
+    table_map = {t.name: t for t in tables}
+    # Build adjacency: table -> set of tables it depends on
+    deps: dict[str, set[str]] = defaultdict(set)
+    for t in tables:
+        deps.setdefault(t.name, set())
+        for fk in t.foreign_keys:
+            if fk.references_table in table_map and fk.references_table != t.name:
+                deps[t.name].add(fk.references_table)
+
+    # Kahn's algorithm
+    in_degree: dict[str, int] = {t.name: 0 for t in tables}
+    # Build reverse map: if A depends on B, then B has an edge to A
+    reverse: dict[str, set[str]] = defaultdict(set)
+    for t_name, t_deps in deps.items():
+        for dep in t_deps:
+            reverse[dep].add(t_name)
+            in_degree[t_name] = in_degree.get(t_name, 0)  # ensure key exists
+
+    # Recount in_degree properly
+    for t_name in in_degree:
+        in_degree[t_name] = len(deps.get(t_name, set()))
+
+    queue = [t for t in in_degree if in_degree[t] == 0]
+    queue.sort()  # deterministic ordering
+    result: list[str] = []
+
+    while queue:
+        current = queue.pop(0)
+        result.append(current)
+        for dependent in sorted(reverse.get(current, set())):
+            in_degree[dependent] -= 1
+            if in_degree[dependent] == 0:
+                queue.append(dependent)
+
+    if len(result) != len(tables):
+        missing = set(t.name for t in tables) - set(result)
+        raise ValueError(
+            f"Circular foreign key dependency detected among tables: {sorted(missing)}. "
+            "Manual intervention required — break the cycle or use deferred constraints."
+        )
+
+    return [table_map[name] for name in result]
+
+
+def _generate_up_sql(ops: list[DiffOp]) -> list[str]:
+    stmts: list[str] = []
+
+    # Collect CREATE TABLE ops for topological sorting
+    create_table_ops = [op for op in ops if op.op_type == DiffOpType.CREATE_TABLE]
+    other_ops = [op for op in ops if op.op_type != DiffOpType.CREATE_TABLE]
+
+    # Topologically sort new tables by FK deps
+    if create_table_ops:
+        tables_to_create = [op.details["table"] for op in create_table_ops]
+        try:
+            sorted_tables = _topological_sort_tables(tables_to_create)
+        except ValueError as e:
+            stmts.append(f"-- ERROR: {e}")
+            sorted_tables = tables_to_create
+
+        for table in sorted_tables:
+            stmts.append(_table_create_sql(table))
+            for idx in table.indexes:
+                stmts.append(idx.to_sql(table.name))
+
+    for op in other_ops:
+        match op.op_type:
+            case DiffOpType.DROP_TABLE:
+                stmts.append(_table_drop_sql(op.table_name))
+
+            case DiffOpType.ADD_COLUMN:
+                col = op.details["column"]
+                stmts.append(
+                    f'ALTER TABLE "{op.table_name}" ADD COLUMN {col.to_sql_fragment()};'
+                )
+
+            case DiffOpType.DROP_COLUMN:
+                stmts.append(
+                    f'ALTER TABLE "{op.table_name}" DROP COLUMN "{op.details["column_name"]}";'
+                )
+
+            case DiffOpType.ALTER_COLUMN:
+                # SQLite doesn't support ALTER COLUMN natively.
+                # For type/nullability/default changes we need table rebuild.
+                new_col = op.details["new_column"]
+                changes = op.details["changes"]
+                desc_parts = []
+                for attr, (old_val, new_val) in changes.items():
+                    desc_parts.append(f"{attr}: {old_val} -> {new_val}")
+                desc = ", ".join(desc_parts)
+                stmts.append(
+                    f"-- ALTER COLUMN '{op.details['column_name']}' in '{op.table_name}': {desc}"
+                )
+                stmts.append(
+                    f"-- SQLite does not support ALTER COLUMN. Table rebuild required."
+                )
+                stmts.append(
+                    f"-- Use: CREATE TABLE new -> INSERT INTO new SELECT ... FROM old -> DROP old -> ALTER TABLE new RENAME TO old"
+                )
+
+            case DiffOpType.POTENTIAL_RENAME_COLUMN:
+                old_name = op.details["old_name"]
+                new_name = op.details["new_name"]
+                stmts.append(
+                    f'ALTER TABLE "{op.table_name}" RENAME COLUMN "{old_name}" TO "{new_name}";'
+                )
+
+            case DiffOpType.ADD_INDEX:
+                idx = op.details["index"]
+                stmts.append(idx.to_sql(op.table_name))
+
+            case DiffOpType.DROP_INDEX:
+                idx = op.details["index"]
+                stmts.append(idx.drop_sql())
+
+            case DiffOpType.ADD_FOREIGN_KEY:
+                stmts.append(
+                    f"-- Adding foreign key to existing table '{op.table_name}' "
+                    f"requires table rebuild in SQLite."
+                )
+
+            case DiffOpType.DROP_FOREIGN_KEY:
+                stmts.append(
+                    f"-- Dropping foreign key from existing table '{op.table_name}' "
+                    f"requires table rebuild in SQLite."
+                )
+
+            case DiffOpType.ADD_CONSTRAINT:
+                stmts.append(
+                    f"-- Adding CHECK constraint '{op.details['constraint_name']}' "
+                    f"to existing table '{op.table_name}' requires table rebuild in SQLite."
+                )
+
+            case DiffOpType.DROP_CONSTRAINT:
+                stmts.append(
+                    f"-- Dropping CHECK constraint '{op.details['constraint_name']}' "
+                    f"from existing table '{op.table_name}' requires table rebuild in SQLite."
+                )
+
+    return stmts
+
+
+def _generate_down_sql(ops: list[DiffOp]) -> list[str]:
+    stmts: list[str] = []
+
+    for op in reversed(ops):
+        match op.op_type:
+            case DiffOpType.CREATE_TABLE:
+                stmts.append(_table_drop_sql(op.table_name))
+
+            case DiffOpType.DROP_TABLE:
+                table = op.details["table"]
+                stmts.append(
+                    "-- WARNING: Lossy rollback — re-creating table structure "
+                    f"but original data in '{op.table_name}' cannot be restored."
+                )
+                stmts.append(_table_create_sql(table))
+                for idx in table.indexes:
+                    stmts.append(idx.to_sql(table.name))
+
+            case DiffOpType.ADD_COLUMN:
+                stmts.append(
+                    f'ALTER TABLE "{op.table_name}" DROP COLUMN "{op.details["column_name"]}";'
+                )
+
+            case DiffOpType.DROP_COLUMN:
+                col = op.details["column"]
+                stmts.append(
+                    "-- WARNING: Lossy rollback — re-adding column "
+                    f"'{col.name}' but original data cannot be restored."
+                )
+                stmts.append(
+                    f'ALTER TABLE "{op.table_name}" ADD COLUMN {col.to_sql_fragment()};'
+                )
+
+            case DiffOpType.ALTER_COLUMN:
+                stmts.append(
+                    f"-- Reversing ALTER COLUMN '{op.details['column_name']}' "
+                    f"in '{op.table_name}' requires table rebuild."
+                )
+
+            case DiffOpType.POTENTIAL_RENAME_COLUMN:
+                old_name = op.details["old_name"]
+                new_name = op.details["new_name"]
+                stmts.append(
+                    f'ALTER TABLE "{op.table_name}" RENAME COLUMN "{new_name}" TO "{old_name}";'
+                )
+
+            case DiffOpType.ADD_INDEX:
+                idx = op.details["index"]
+                stmts.append(idx.drop_sql())
+
+            case DiffOpType.DROP_INDEX:
+                idx = op.details["index"]
+                stmts.append(idx.to_sql(op.table_name))
+
+            case DiffOpType.ADD_FOREIGN_KEY:
+                stmts.append(
+                    f"-- Reversing FK addition on '{op.table_name}' "
+                    f"requires table rebuild in SQLite."
+                )
+
+            case DiffOpType.DROP_FOREIGN_KEY:
+                stmts.append(
+                    f"-- Reversing FK removal on '{op.table_name}' "
+                    f"requires table rebuild in SQLite."
+                )
+
+            case DiffOpType.ADD_CONSTRAINT:
+                stmts.append(
+                    f"-- Reversing constraint '{op.details['constraint_name']}' "
+                    f"addition on '{op.table_name}' requires table rebuild."
+                )
+
+            case DiffOpType.DROP_CONSTRAINT:
+                stmts.append(
+                    f"-- Reversing constraint '{op.details['constraint_name']}' "
+                    f"removal on '{op.table_name}' requires table rebuild."
+                )
+
+    return stmts
+
+
+def has_lossy_operations(ops: list[DiffOp]) -> bool:
+    return any(op.lossy for op in ops)
+
+
+def generate_migration(
+    description: str,
+    ops: list[DiffOp],
+    depends_on: str | None,
+    migrations_dir: Path,
+) -> Migration:
+    timestamp = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%d%H%M%S")
+    slug = Migration.slug_from_description(description)
+    migration_id = f"{timestamp}_{slug}"
+
+    up_sql = _generate_up_sql(ops)
+    down_sql = _generate_down_sql(ops)
+
+    migration = Migration(
+        migration_id=migration_id,
+        description=description,
+        depends_on=depends_on,
+        up_sql=up_sql,
+        down_sql=down_sql,
+    )
+
+    write_migration_file(migration, migrations_dir)
+    return migration
+
+
+def write_migration_file(migration: Migration, migrations_dir: Path) -> Path:
+    migrations_dir.mkdir(parents=True, exist_ok=True)
+    filepath = migrations_dir / f"{migration.migration_id}.yaml"
+
+    data = {
+        "migration_id": migration.migration_id,
+        "description": migration.description,
+        "depends_on": migration.depends_on,
+        "up": migration.up_sql,
+        "down": migration.down_sql,
+    }
+
+    filepath.write_text(
+        yaml.dump(data, default_flow_style=False, sort_keys=False, allow_unicode=True),
+        encoding="utf-8",
+    )
+    return filepath
+
+
+def load_migration_file(path: Path) -> tuple[Migration | None, list[str]]:
+    errors: list[str] = []
+    try:
+        content = path.read_text(encoding="utf-8")
+    except OSError as e:
+        return None, [f"Cannot read migration file '{path}': {e}"]
+
+    try:
+        data = yaml.safe_load(content)
+    except yaml.YAMLError as e:
+        return None, [f"Invalid YAML in migration file '{path}': {e}"]
+
+    if not isinstance(data, dict):
+        return None, [f"Migration file '{path}': expected a mapping"]
+
+    mid = data.get("migration_id")
+    if not mid:
+        errors.append(f"Migration file '{path}': missing 'migration_id'")
+
+    desc = data.get("description", "")
+
+    depends_on = data.get("depends_on")
+    up = data.get("up", [])
+    down = data.get("down", [])
+
+    if not isinstance(up, list):
+        errors.append(f"Migration '{mid}': 'up' must be a list of SQL strings")
+        up = []
+    if not isinstance(down, list):
+        errors.append(f"Migration '{mid}': 'down' must be a list of SQL strings")
+        down = []
+
+    if errors:
+        return None, errors
+
+    return Migration(
+        migration_id=mid,
+        description=desc,
+        depends_on=depends_on,
+        up_sql=[str(s) for s in up],
+        down_sql=[str(s) for s in down],
+    ), []
+
+
+def load_all_migrations(migrations_dir: Path) -> tuple[dict[str, Migration], list[str]]:
+    all_errors: list[str] = []
+    migrations: dict[str, Migration] = {}
+
+    if not migrations_dir.is_dir():
+        return migrations, []
+
+    for path in sorted(migrations_dir.glob("*.yaml")):
+        mig, errs = load_migration_file(path)
+        all_errors.extend(errs)
+        if mig:
+            if mig.migration_id in migrations:
+                all_errors.append(f"Duplicate migration ID '{mig.migration_id}'")
+            else:
+                migrations[mig.migration_id] = mig
+
+    return migrations, all_errors
