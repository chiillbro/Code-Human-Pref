+"""Tests for migration generator — SQL generation, topological sort, file I/O."""
+
+import pytest
+from pathlib import Path
+
+from schemav.migration_generator import (
+    _topological_sort_tables,
+    generate_migration,
+    has_lossy_operations,
+    load_migration_file,
+    load_all_migrations,
+)
+from schemav.models import (
+    Column,
+    ColumnType,
+    DiffOp,
+    DiffOpType,
+    ForeignKey,
+    Index,
+    OnDeleteAction,
+    Table,
+)
+
+
+class TestTopologicalSortTables:
+    def test_no_foreign_keys(self):
+        t1 = Table(name="a", columns=[Column("id", ColumnType.INTEGER)])
+        t2 = Table(name="b", columns=[Column("id", ColumnType.INTEGER)])
+        result = _topological_sort_tables([t1, t2])
+        names = [t.name for t in result]
+        assert set(names) == {"a", "b"}
+
+    def test_simple_dependency(self):
+        t_users = Table(name="users", columns=[Column("id", ColumnType.INTEGER)])
+        t_orders = Table(
+            name="orders",
+            columns=[Column("id", ColumnType.INTEGER), Column("user_id", ColumnType.INTEGER)],
+            foreign_keys=[ForeignKey(("user_id",), "users", ("id",))],
+        )
+        result = _topological_sort_tables([t_orders, t_users])
+        names = [t.name for t in result]
+        assert names.index("users") < names.index("orders")
+
+    def test_chain_dependency(self):
+        t_a = Table(name="a", columns=[Column("id", ColumnType.INTEGER)])
+        t_b = Table(
+            name="b",
+            columns=[Column("id", ColumnType.INTEGER), Column("a_id", ColumnType.INTEGER)],
+            foreign_keys=[ForeignKey(("a_id",), "a", ("id",))],
+        )
+        t_c = Table(
+            name="c",
+            columns=[Column("id", ColumnType.INTEGER), Column("b_id", ColumnType.INTEGER)],
+            foreign_keys=[ForeignKey(("b_id",), "b", ("id",))],
+        )
+        result = _topological_sort_tables([t_c, t_b, t_a])
+        names = [t.name for t in result]
+        assert names.index("a") < names.index("b") < names.index("c")
+
+    def test_circular_dependency_raises(self):
+        t_a = Table(
+            name="a",
+            columns=[Column("id", ColumnType.INTEGER), Column("b_id", ColumnType.INTEGER)],
+            foreign_keys=[ForeignKey(("b_id",), "b", ("id",))],
+        )
+        t_b = Table(
+            name="b",
+            columns=[Column("id", ColumnType.INTEGER), Column("a_id", ColumnType.INTEGER)],
+            foreign_keys=[ForeignKey(("a_id",), "a", ("id",))],
+        )
+        with pytest.raises(ValueError, match="Circular"):
+            _topological_sort_tables([t_a, t_b])
+
+    def test_self_referencing_excluded(self):
+        t = Table(
+            name="categories",
+            columns=[Column("id", ColumnType.INTEGER), Column("parent_id", ColumnType.INTEGER)],
+            foreign_keys=[ForeignKey(("parent_id",), "categories", ("id",))],
+        )
+        result = _topological_sort_tables([t])
+        assert len(result) == 1
+
+
+class TestGenerateMigration:
+    def test_generates_file(self, tmp_path):
+        ops = [DiffOp(
+            op_type=DiffOpType.CREATE_TABLE,
+            table_name="users",
+            details={"table": Table(
+                name="users",
+                columns=[
+                    Column("id", ColumnType.INTEGER, nullable=False),
+                    Column("email", ColumnType.TEXT, nullable=False, unique=True),
+                ],
+                primary_key=["id"],
+            )},
+        )]
+        mig = generate_migration("add_users_table", ops, None, tmp_path)
+        assert mig.migration_id.endswith("_add_users_table")
+        assert len(mig.up_sql) > 0
+        assert len(mig.down_sql) > 0
+
+        # Verify file was written
+        path = tmp_path / f"{mig.migration_id}.yaml"
+        assert path.exists()
+
+    def test_lossy_detection(self):
+        ops = [DiffOp(
+            op_type=DiffOpType.DROP_TABLE,
+            table_name="old",
+            details={"table": Table("old", [Column("id", ColumnType.INTEGER)])},
+            lossy=True,
+        )]
+        assert has_lossy_operations(ops) is True
+
+        ops2 = [DiffOp(
+            op_type=DiffOpType.ADD_COLUMN,
+            table_name="t",
+            details={"column_name": "x", "column": Column("x", ColumnType.TEXT)},
+        )]
+        assert has_lossy_operations(ops2) is False
+
+
+class TestLoadMigrationFile:
+    def test_roundtrip(self, tmp_path):
+        ops = [DiffOp(
+            op_type=DiffOpType.CREATE_TABLE,
+            table_name="t",
+            details={"table": Table("t", [Column("id", ColumnType.INTEGER)])},
+        )]
+        mig = generate_migration("test_migration", ops, None, tmp_path)
+        path = tmp_path / f"{mig.migration_id}.yaml"
+        loaded, errors = load_migration_file(path)
+        assert not errors
+        assert loaded is not None
+        assert loaded.migration_id == mig.migration_id
+        assert loaded.depends_on is None
+        assert len(loaded.up_sql) > 0
+
+    def test_invalid_file(self, tmp_path):
+        path = tmp_path / "bad.yaml"
+        path.write_text(": invalid [", encoding="utf-8")
+        loaded, errors = load_migration_file(path)
+        assert loaded is None
+        assert len(errors) > 0
+
+    def test_missing_migration_id(self, tmp_path):
+        path = tmp_path / "noid.yaml"
+        path.write_text("up: []\ndown: []\n", encoding="utf-8")
+        loaded, errors = load_migration_file(path)
+        assert len(errors) > 0
+
+
+class TestLoadAllMigrations:
+    def test_loads_multiple(self, tmp_path):
+        ops1 = [DiffOp(
+            op_type=DiffOpType.CREATE_TABLE,
+            table_name="a",
+            details={"table": Table("a", [Column("id", ColumnType.INTEGER)])},
+        )]
+        ops2 = [DiffOp(
+            op_type=DiffOpType.CREATE_TABLE,
+            table_name="b",
+            details={"table": Table("b", [Column("id", ColumnType.INTEGER)])},
+        )]
+        m1 = generate_migration("first", ops1, None, tmp_path)
+        m2 = generate_migration("second", ops2, m1.migration_id, tmp_path)
+
+        migrations, errors = load_all_migrations(tmp_path)
+        assert not errors
+        assert len(migrations) == 2
+        assert m2.migration_id in migrations
+        assert migrations[m2.migration_id].depends_on == m1.migration_id
+
+    def test_empty_dir(self, tmp_path):
+        migrations, errors = load_all_migrations(tmp_path)
+        assert not errors
+        assert len(migrations) == 0
