+"""Data models for schemav."""
+
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass, field
+from enum import Enum
+
+
+class ColumnType(Enum):
+    TEXT = "TEXT"
+    INTEGER = "INTEGER"
+    REAL = "REAL"
+    BLOB = "BLOB"
+    BOOLEAN = "BOOLEAN"
+    DATETIME = "DATETIME"
+
+    @property
+    def sql_type(self) -> str:
+        if self == ColumnType.BOOLEAN:
+            return "INTEGER"  # SQLite stores booleans as integers
+        if self == ColumnType.DATETIME:
+            return "TEXT"  # SQLite stores datetimes as text
+        return self.value
+
+
+class OnDeleteAction(Enum):
+    CASCADE = "CASCADE"
+    SET_NULL = "SET NULL"
+    RESTRICT = "RESTRICT"
+    NO_ACTION = "NO ACTION"
+
+
+@dataclass(frozen=True)
+class Column:
+    name: str
+    type: ColumnType
+    nullable: bool = True
+    default: str | None = None
+    unique: bool = False
+
+    def to_sql_fragment(self) -> str:
+        parts = [f'"{self.name}" {self.type.sql_type}']
+        if not self.nullable:
+            parts.append("NOT NULL")
+        if self.unique:
+            parts.append("UNIQUE")
+        if self.default is not None:
+            parts.append(f"DEFAULT {self.default}")
+        return " ".join(parts)
+
+
+@dataclass(frozen=True)
+class Index:
+    name: str
+    columns: tuple[str, ...]
+    unique: bool = False
+
+    def to_sql(self, table_name: str) -> str:
+        unique = "UNIQUE " if self.unique else ""
+        cols = ", ".join(f'"{c}"' for c in self.columns)
+        return f'CREATE {unique}INDEX "{self.name}" ON "{table_name}" ({cols});'
+
+    def drop_sql(self) -> str:
+        return f'DROP INDEX IF EXISTS "{self.name}";'
+
+
+@dataclass(frozen=True)
+class ForeignKey:
+    columns: tuple[str, ...]
+    references_table: str
+    references_columns: tuple[str, ...]
+    on_delete: OnDeleteAction = OnDeleteAction.NO_ACTION
+
+    def to_sql_fragment(self) -> str:
+        local_cols = ", ".join(f'"{c}"' for c in self.columns)
+        ref_cols = ", ".join(f'"{c}"' for c in self.references_columns)
+        return (
+            f'FOREIGN KEY ({local_cols}) REFERENCES "{self.references_table}" '
+            f"({ref_cols}) ON DELETE {self.on_delete.value}"
+        )
+
+
+@dataclass(frozen=True)
+class CheckConstraint:
+    name: str
+    expression: str
+
+    def to_sql_fragment(self) -> str:
+        return f"CONSTRAINT \"{self.name}\" CHECK ({self.expression})"
+
+
+@dataclass
+class Table:
+    name: str
+    columns: list[Column] = field(default_factory=list)
+    primary_key: list[str] = field(default_factory=list)
+    indexes: list[Index] = field(default_factory=list)
+    foreign_keys: list[ForeignKey] = field(default_factory=list)
+    constraints: list[CheckConstraint] = field(default_factory=list)
+
+    def column_by_name(self, name: str) -> Column | None:
+        for col in self.columns:
+            if col.name == name:
+                return col
+        return None
+
+
+@dataclass
+class Schema:
+    tables: dict[str, Table] = field(default_factory=dict)
+
+
+@dataclass
+class Migration:
+    migration_id: str
+    description: str
+    depends_on: str | None
+    up_sql: list[str] = field(default_factory=list)
+    down_sql: list[str] = field(default_factory=list)
+
+    @staticmethod
+    def slug_from_description(description: str) -> str:
+        slug = re.sub(r"[^a-zA-Z0-9]+", "_", description.strip().lower())
+        return slug.strip("_")[:60]
+
+
+@dataclass
+class MigrationHistoryEntry:
+    migration_id: str
+    applied_at: str
+    direction: str  # "up" or "down"
+    checksum: str
+
+
+# --- Diff result types ---
+
+class DiffOpType(Enum):
+    CREATE_TABLE = "create_table"
+    DROP_TABLE = "drop_table"
+    ADD_COLUMN = "add_column"
+    DROP_COLUMN = "drop_column"
+    ALTER_COLUMN = "alter_column"
+    ADD_INDEX = "add_index"
+    DROP_INDEX = "drop_index"
+    ADD_FOREIGN_KEY = "add_foreign_key"
+    DROP_FOREIGN_KEY = "drop_foreign_key"
+    ADD_CONSTRAINT = "add_constraint"
+    DROP_CONSTRAINT = "drop_constraint"
+    POTENTIAL_RENAME_COLUMN = "potential_rename_column"
+
+
+@dataclass
+class DiffOp:
+    op_type: DiffOpType
+    table_name: str
+    details: dict = field(default_factory=dict)
+    lossy: bool = False
+
+    @property
+    def description(self) -> str:
+        match self.op_type:
+            case DiffOpType.CREATE_TABLE:
+                return f"Create table '{self.table_name}'"
+            case DiffOpType.DROP_TABLE:
+                return f"Drop table '{self.table_name}'"
+            case DiffOpType.ADD_COLUMN:
+                return f"Add column '{self.details['column_name']}' to '{self.table_name}'"
+            case DiffOpType.DROP_COLUMN:
+                return f"Drop column '{self.details['column_name']}' from '{self.table_name}'"
+            case DiffOpType.ALTER_COLUMN:
+                return f"Alter column '{self.details['column_name']}' in '{self.table_name}'"
+            case DiffOpType.ADD_INDEX:
+                return f"Add index '{self.details['index_name']}' on '{self.table_name}'"
+            case DiffOpType.DROP_INDEX:
+                return f"Drop index '{self.details['index_name']}' from '{self.table_name}'"
+            case DiffOpType.ADD_FOREIGN_KEY:
+                cols = self.details.get("columns", ())
+                return f"Add foreign key ({', '.join(cols)}) on '{self.table_name}'"
+            case DiffOpType.DROP_FOREIGN_KEY:
+                cols = self.details.get("columns", ())
+                return f"Drop foreign key ({', '.join(cols)}) from '{self.table_name}'"
+            case DiffOpType.ADD_CONSTRAINT:
+                return f"Add constraint '{self.details['constraint_name']}' on '{self.table_name}'"
+            case DiffOpType.DROP_CONSTRAINT:
+                return f"Drop constraint '{self.details['constraint_name']}' from '{self.table_name}'"
+            case DiffOpType.POTENTIAL_RENAME_COLUMN:
+                return (
+                    f"Potential rename: '{self.details['old_name']}' -> "
+                    f"'{self.details['new_name']}' in '{self.table_name}'"
+                )
+            case _:
+                return str(self.op_type)
