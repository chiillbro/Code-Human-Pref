@@ -0,0 +1,214 @@
+"""Migration state tracker — manages _schemav_history table and migration execution."""
+
+from __future__ import annotations
+
+import datetime
+import hashlib
+import sqlite3
+import sys
+from pathlib import Path
+
+from schemav.models import Migration, MigrationHistoryEntry
+
+HISTORY_TABLE = "_schemav_history"
+
+CREATE_HISTORY_SQL = f"""
+CREATE TABLE IF NOT EXISTS "{HISTORY_TABLE}" (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    migration_id TEXT NOT NULL,
+    applied_at TEXT NOT NULL,
+    direction TEXT NOT NULL CHECK (direction IN ('up', 'down')),
+    checksum TEXT NOT NULL
+);
+"""
+
+
+def compute_checksum(migration_path: Path) -> str:
+    raw_bytes = migration_path.read_bytes()
+    return hashlib.sha256(raw_bytes).hexdigest()
+
+
+def _ensure_history_table(conn: sqlite3.Connection) -> None:
+    conn.execute(CREATE_HISTORY_SQL)
+    conn.commit()
+
+
+def get_connection(db_path: str) -> sqlite3.Connection:
+    conn = sqlite3.connect(db_path)
+    conn.execute("PRAGMA foreign_keys = ON;")
+    _ensure_history_table(conn)
+    return conn
+
+
+def get_applied_migrations(conn: sqlite3.Connection) -> list[MigrationHistoryEntry]:
+    """Return the list of applied migrations in order, accounting for rollbacks.
+
+    We replay the history log: an 'up' entry means the migration is applied,
+    a 'down' entry means it was rolled back. We return only the currently-applied set."""
+    cursor = conn.execute(
+        f'SELECT migration_id, applied_at, direction, checksum FROM "{HISTORY_TABLE}" ORDER BY id ASC'
+    )
+    applied: dict[str, MigrationHistoryEntry] = {}
+
+    for row in cursor:
+        entry = MigrationHistoryEntry(
+            migration_id=row[0],
+            applied_at=row[1],
+            direction=row[2],
+            checksum=row[3],
+        )
+        if entry.direction == "up":
+            applied[entry.migration_id] = entry
+        elif entry.direction == "down":
+            applied.pop(entry.migration_id, None)
+
+    return list(applied.values())
+
+
+def get_latest_applied_id(conn: sqlite3.Connection) -> str | None:
+    applied = get_applied_migrations(conn)
+    if not applied:
+        return None
+    return applied[-1].migration_id
+
+
+def apply_migration(
+    conn: sqlite3.Connection,
+    migration: Migration,
+    migration_path: Path,
+    dry_run: bool = False,
+) -> None:
+    checksum = compute_checksum(migration_path)
+    now = datetime.datetime.now(datetime.timezone.utc).isoformat()
+
+    if dry_run:
+        print(f"[DRY RUN] Would apply migration: {migration.migration_id}")
+        for stmt in migration.up_sql:
+            print(f"  {stmt}")
+        return
+
+    # Execute within a single transaction
+    try:
+        conn.execute("BEGIN IMMEDIATE;")
+        for stmt in migration.up_sql:
+            # Skip comments
+            stripped = stmt.strip()
+            if stripped.startswith("--"):
+                continue
+            conn.execute(stripped)
+
+        conn.execute(
+            f'INSERT INTO "{HISTORY_TABLE}" (migration_id, applied_at, direction, checksum) '
+            "VALUES (?, ?, 'up', ?)",
+            (migration.migration_id, now, checksum),
+        )
+        conn.execute("COMMIT;")
+    except Exception:
+        try:
+            conn.execute("ROLLBACK;")
+        except Exception:
+            pass
+        raise
+
+
+def rollback_migration(
+    conn: sqlite3.Connection,
+    migration: Migration,
+    migration_path: Path,
+    dry_run: bool = False,
+    force: bool = False,
+) -> None:
+    checksum = compute_checksum(migration_path)
+    now = datetime.datetime.now(datetime.timezone.utc).isoformat()
+
+    # Verify checksum
+    applied = get_applied_migrations(conn)
+    for entry in applied:
+        if entry.migration_id == migration.migration_id:
+            if entry.checksum != checksum:
+                msg = (
+                    f"Checksum mismatch for migration '{migration.migration_id}': "
+                    f"applied checksum={entry.checksum}, current file checksum={checksum}. "
+                    "The migration file may have been modified after it was applied."
+                )
+                if not force:
+                    raise ValueError(msg)
+                print(f"WARNING: {msg}", file=sys.stderr)
+            break
+
+    # Check for lossy operations
+    has_lossy = any(
+        s.strip().startswith("-- WARNING: Lossy rollback")
+        for s in migration.down_sql
+    )
+
+    if dry_run:
+        print(f"[DRY RUN] Would rollback migration: {migration.migration_id}")
+        if has_lossy:
+            print("  WARNING: This rollback contains lossy operations (data loss possible)")
+        for stmt in migration.down_sql:
+            print(f"  {stmt}")
+        return
+
+    if has_lossy and not force:
+        print(
+            f"WARNING: Rolling back '{migration.migration_id}' involves lossy operations "
+            "(data may be permanently lost). Use --force to proceed.",
+            file=sys.stderr,
+        )
+        raise ValueError(
+            f"Rollback of '{migration.migration_id}' requires --force due to lossy operations"
+        )
+
+    try:
+        conn.execute("BEGIN IMMEDIATE;")
+        for stmt in migration.down_sql:
+            stripped = stmt.strip()
+            if stripped.startswith("--"):
+                continue
+            conn.execute(stripped)
+
+        conn.execute(
+            f'INSERT INTO "{HISTORY_TABLE}" (migration_id, applied_at, direction, checksum) '
+            "VALUES (?, ?, 'down', ?)",
+            (migration.migration_id, now, checksum),
+        )
+        conn.execute("COMMIT;")
+    except Exception:
+        try:
+            conn.execute("ROLLBACK;")
+        except Exception:
+            pass
+        raise
+
+
+def verify_checksums(
+    conn: sqlite3.Connection,
+    migrations: dict[str, Migration],
+    migrations_dir: Path,
+) -> list[str]:
+    warnings: list[str] = []
+    applied = get_applied_migrations(conn)
+
+    for entry in applied:
+        if entry.migration_id not in migrations:
+            warnings.append(
+                f"Migration '{entry.migration_id}' was applied but its file is missing from disk"
+            )
+            continue
+
+        path = migrations_dir / f"{entry.migration_id}.yaml"
+        if not path.exists():
+            warnings.append(
+                f"Migration file for '{entry.migration_id}' not found at '{path}'"
+            )
+            continue
+
+        current_checksum = compute_checksum(path)
+        if current_checksum != entry.checksum:
+            warnings.append(
+                f"Checksum mismatch for '{entry.migration_id}': "
+                f"applied={entry.checksum[:12]}..., current={current_checksum[:12]}..."
+            )
+
+    return warnings
