@@ -0,0 +1,232 @@
+"""Schema diff engine — compares old and new schemas to produce a list of DiffOps."""
+
+from __future__ import annotations
+
+from schemav.models import (
+    CheckConstraint,
+    Column,
+    DiffOp,
+    DiffOpType,
+    ForeignKey,
+    Index,
+    Schema,
+    Table,
+)
+
+
+def _fk_key(fk: ForeignKey) -> tuple:
+    return (fk.columns, fk.references_table, fk.references_columns)
+
+
+def _detect_potential_renames(
+    old_table: Table, new_table: Table, dropped: list[Column], added: list[Column]
+) -> list[tuple[Column, Column]]:
+    """Heuristic: if a dropped and added column have the same type, same position
+    index, and same nullability, flag as a potential rename."""
+    renames: list[tuple[Column, Column]] = []
+    used_old: set[str] = set()
+    used_new: set[str] = set()
+
+    old_positions = {c.name: i for i, c in enumerate(old_table.columns)}
+    new_positions = {c.name: i for i, c in enumerate(new_table.columns)}
+
+    for old_col in dropped:
+        for new_col in added:
+            if new_col.name in used_new or old_col.name in used_old:
+                continue
+            same_type = old_col.type == new_col.type
+            same_nullable = old_col.nullable == new_col.nullable
+            same_position = old_positions.get(old_col.name) == new_positions.get(new_col.name)
+            if same_type and same_nullable and same_position:
+                renames.append((old_col, new_col))
+                used_old.add(old_col.name)
+                used_new.add(new_col.name)
+
+    return renames
+
+
+def diff_tables(old_table: Table, new_table: Table) -> list[DiffOp]:
+    ops: list[DiffOp] = []
+    old_col_names = {c.name for c in old_table.columns}
+    new_col_names = {c.name for c in new_table.columns}
+
+    dropped_cols = [c for c in old_table.columns if c.name not in new_col_names]
+    added_cols = [c for c in new_table.columns if c.name not in old_col_names]
+
+    # Detect potential renames before emitting drop+add
+    potential_renames = _detect_potential_renames(old_table, new_table, dropped_cols, added_cols)
+    rename_old_names = {r[0].name for r in potential_renames}
+    rename_new_names = {r[1].name for r in potential_renames}
+
+    for old_col, new_col in potential_renames:
+        ops.append(DiffOp(
+            op_type=DiffOpType.POTENTIAL_RENAME_COLUMN,
+            table_name=old_table.name,
+            details={
+                "old_name": old_col.name,
+                "new_name": new_col.name,
+                "old_column": old_col,
+                "new_column": new_col,
+            },
+        ))
+
+    # Dropped columns (exclude those flagged as potential renames)
+    for col in dropped_cols:
+        if col.name not in rename_old_names:
+            ops.append(DiffOp(
+                op_type=DiffOpType.DROP_COLUMN,
+                table_name=old_table.name,
+                details={"column_name": col.name, "column": col},
+                lossy=True,
+            ))
+
+    # Added columns (exclude those flagged as potential renames)
+    for col in added_cols:
+        if col.name not in rename_new_names:
+            ops.append(DiffOp(
+                op_type=DiffOpType.ADD_COLUMN,
+                table_name=new_table.name,
+                details={"column_name": col.name, "column": col},
+            ))
+
+    # Altered columns (same name, different attributes)
+    for col_name in old_col_names & new_col_names:
+        old_col = old_table.column_by_name(col_name)
+        new_col = new_table.column_by_name(col_name)
+        if old_col and new_col and old_col != new_col:
+            changes: dict[str, tuple] = {}
+            if old_col.type != new_col.type:
+                changes["type"] = (old_col.type.value, new_col.type.value)
+            if old_col.nullable != new_col.nullable:
+                changes["nullable"] = (old_col.nullable, new_col.nullable)
+            if old_col.default != new_col.default:
+                changes["default"] = (old_col.default, new_col.default)
+            if old_col.unique != new_col.unique:
+                changes["unique"] = (old_col.unique, new_col.unique)
+            if changes:
+                ops.append(DiffOp(
+                    op_type=DiffOpType.ALTER_COLUMN,
+                    table_name=old_table.name,
+                    details={
+                        "column_name": col_name,
+                        "changes": changes,
+                        "old_column": old_col,
+                        "new_column": new_col,
+                    },
+                ))
+
+    # Indexes
+    old_indexes = {idx.name: idx for idx in old_table.indexes}
+    new_indexes = {idx.name: idx for idx in new_table.indexes}
+
+    for name in set(old_indexes) - set(new_indexes):
+        ops.append(DiffOp(
+            op_type=DiffOpType.DROP_INDEX,
+            table_name=old_table.name,
+            details={"index_name": name, "index": old_indexes[name]},
+        ))
+
+    for name in set(new_indexes) - set(old_indexes):
+        ops.append(DiffOp(
+            op_type=DiffOpType.ADD_INDEX,
+            table_name=new_table.name,
+            details={"index_name": name, "index": new_indexes[name]},
+        ))
+
+    # Changed indexes (same name, different definition)
+    for name in set(old_indexes) & set(new_indexes):
+        if old_indexes[name] != new_indexes[name]:
+            ops.append(DiffOp(
+                op_type=DiffOpType.DROP_INDEX,
+                table_name=old_table.name,
+                details={"index_name": name, "index": old_indexes[name]},
+            ))
+            ops.append(DiffOp(
+                op_type=DiffOpType.ADD_INDEX,
+                table_name=new_table.name,
+                details={"index_name": name, "index": new_indexes[name]},
+            ))
+
+    # Foreign keys (keyed by local columns + ref table + ref columns)
+    old_fks = {_fk_key(fk): fk for fk in old_table.foreign_keys}
+    new_fks = {_fk_key(fk): fk for fk in new_table.foreign_keys}
+
+    for key in set(old_fks) - set(new_fks):
+        fk = old_fks[key]
+        ops.append(DiffOp(
+            op_type=DiffOpType.DROP_FOREIGN_KEY,
+            table_name=old_table.name,
+            details={"columns": fk.columns, "fk": fk},
+        ))
+
+    for key in set(new_fks) - set(old_fks):
+        fk = new_fks[key]
+        ops.append(DiffOp(
+            op_type=DiffOpType.ADD_FOREIGN_KEY,
+            table_name=new_table.name,
+            details={"columns": fk.columns, "fk": fk},
+        ))
+
+    # Check constraints
+    old_cons = {c.name: c for c in old_table.constraints}
+    new_cons = {c.name: c for c in new_table.constraints}
+
+    for name in set(old_cons) - set(new_cons):
+        ops.append(DiffOp(
+            op_type=DiffOpType.DROP_CONSTRAINT,
+            table_name=old_table.name,
+            details={"constraint_name": name, "constraint": old_cons[name]},
+        ))
+
+    for name in set(new_cons) - set(old_cons):
+        ops.append(DiffOp(
+            op_type=DiffOpType.ADD_CONSTRAINT,
+            table_name=new_table.name,
+            details={"constraint_name": name, "constraint": new_cons[name]},
+        ))
+
+    # Changed constraints
+    for name in set(old_cons) & set(new_cons):
+        if old_cons[name] != new_cons[name]:
+            ops.append(DiffOp(
+                op_type=DiffOpType.DROP_CONSTRAINT,
+                table_name=old_table.name,
+                details={"constraint_name": name, "constraint": old_cons[name]},
+            ))
+            ops.append(DiffOp(
+                op_type=DiffOpType.ADD_CONSTRAINT,
+                table_name=new_table.name,
+                details={"constraint_name": name, "constraint": new_cons[name]},
+            ))
+
+    return ops
+
+
+def diff_schemas(old_schema: Schema, new_schema: Schema) -> list[DiffOp]:
+    ops: list[DiffOp] = []
+    old_tables = set(old_schema.tables)
+    new_tables = set(new_schema.tables)
+
+    # Dropped tables
+    for name in sorted(old_tables - new_tables):
+        ops.append(DiffOp(
+            op_type=DiffOpType.DROP_TABLE,
+            table_name=name,
+            details={"table": old_schema.tables[name]},
+            lossy=True,
+        ))
+
+    # New tables
+    for name in sorted(new_tables - old_tables):
+        ops.append(DiffOp(
+            op_type=DiffOpType.CREATE_TABLE,
+            table_name=name,
+            details={"table": new_schema.tables[name]},
+        ))
+
+    # Modified tables
+    for name in sorted(old_tables & new_tables):
+        table_ops = diff_tables(old_schema.tables[name], new_schema.tables[name])
+        ops.extend(table_ops)
+
+    return ops
