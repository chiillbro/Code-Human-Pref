+    columns:
+      - name: id
+        type: INTEGER
+""")
+        schema, errors = load_schema(schema_dir)
+        assert not errors
+        assert "users" in schema.tables
+        assert "orders" in schema.tables
+
+    def test_duplicate_table_across_files(self, tmp_path):
+        schema_dir = tmp_path / "schema"
+        schema_dir.mkdir()
+        _write_yaml(schema_dir, "a.yaml", """
+tables:
+  users:
+    columns:
+      - name: id
+        type: INTEGER
+""")
+        _write_yaml(schema_dir, "b.yaml", """
+tables:
+  users:
+    columns:
+      - name: id
+        type: TEXT
+""")
+        schema, errors = load_schema(schema_dir)
+        assert any("duplicate" in e.lower() for e in errors)
+
+    def test_missing_directory(self, tmp_path):
