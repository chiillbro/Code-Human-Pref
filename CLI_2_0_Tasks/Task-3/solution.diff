+"""Tests for state tracker — apply, rollback, checksums, history tracking."""
+
+import sqlite3
+import pytest
+from pathlib import Path
+
+from schemav.migration_generator import generate_migration
+from schemav.models import (
+    Column,
+    ColumnType,
+    DiffOp,
+    DiffOpType,
+    Migration,
+    Table,
+)
+from schemav.state_tracker import (
+    apply_migration,
+    compute_checksum,
+    get_applied_migrations,
+    get_connection,
+    get_latest_applied_id,
+    rollback_migration,
+    verify_checksums,
+)
+
+
+def _create_table_op(name: str) -> DiffOp:
+    return DiffOp(
+        op_type=DiffOpType.CREATE_TABLE,
+        table_name=name,
+        details={"table": Table(name, [Column("id", ColumnType.INTEGER, nullable=False)], primary_key=["id"])},
+    )
+
+
+def _setup_migration(tmp_path: Path, description: str, depends_on: str | None = None) -> Migration:
+    ops = [_create_table_op(description)]
+    return generate_migration(description, ops, depends_on, tmp_path / "migrations")
+
+
+class TestApplyMigration:
+    def test_apply_creates_table(self, tmp_path):
+        mig = _setup_migration(tmp_path, "users")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, mig, mig_path)
+
+        # Verify table exists
+        cursor = conn.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='users'")
+        assert cursor.fetchone() is not None
+
+        # Verify history entry
+        applied = get_applied_migrations(conn)
+        assert len(applied) == 1
+        assert applied[0].migration_id == mig.migration_id
+        assert applied[0].direction == "up"
+        conn.close()
+
+    def test_apply_dry_run_no_changes(self, tmp_path, capsys):
+        mig = _setup_migration(tmp_path, "users")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, mig, mig_path, dry_run=True)
+
+        # Table should NOT exist
+        cursor = conn.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='users'")
+        assert cursor.fetchone() is None
+
+        # No history
+        applied = get_applied_migrations(conn)
+        assert len(applied) == 0
+
+        captured = capsys.readouterr()
+        assert "DRY RUN" in captured.out
+        conn.close()
+
+    def test_apply_failure_rolls_back(self, tmp_path):
+        """A migration with intentionally bad SQL should fail and roll back."""
+        mig = Migration(
+            migration_id="bad_migration",
+            description="bad",
+            depends_on=None,
+            up_sql=["CREATE TABLE good (id INTEGER);", "INVALID SQL STATEMENT;"],
+            down_sql=["DROP TABLE good;"],
+        )
+        mig_dir = tmp_path / "migrations"
+        mig_dir.mkdir()
+        from schemav.migration_generator import write_migration_file
+        write_migration_file(mig, mig_dir)
+        mig_path = mig_dir / f"{mig.migration_id}.yaml"
+
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        with pytest.raises(Exception):
+            apply_migration(conn, mig, mig_path)
+
+        # "good" table should NOT exist since we rolled back
+        cursor = conn.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='good'")
+        assert cursor.fetchone() is None
+
+        applied = get_applied_migrations(conn)
+        assert len(applied) == 0
+        conn.close()
+
+
+class TestRollbackMigration:
+    def test_rollback_removes_table(self, tmp_path):
+        mig = _setup_migration(tmp_path, "users_rb")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, mig, mig_path)
+        assert get_latest_applied_id(conn) == mig.migration_id
+
+        rollback_migration(conn, mig, mig_path, force=True)
+
+        applied = get_applied_migrations(conn)
+        assert len(applied) == 0
+        conn.close()
+
+    def test_multi_step_rollback(self, tmp_path):
+        m1 = _setup_migration(tmp_path, "table_a")
+        m1_path = tmp_path / "migrations" / f"{m1.migration_id}.yaml"
+
+        import time; time.sleep(0.01)  # ensure different timestamps
+
+        m2 = _setup_migration(tmp_path, "table_b", depends_on=m1.migration_id)
+        m2_path = tmp_path / "migrations" / f"{m2.migration_id}.yaml"
+
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, m1, m1_path)
+        apply_migration(conn, m2, m2_path)
+        assert len(get_applied_migrations(conn)) == 2
+
+        # Rollback m2
+        rollback_migration(conn, m2, m2_path, force=True)
+        assert len(get_applied_migrations(conn)) == 1
+        assert get_latest_applied_id(conn) == m1.migration_id
+
+        # Rollback m1
+        rollback_migration(conn, m1, m1_path, force=True)
+        assert len(get_applied_migrations(conn)) == 0
+        conn.close()
+
+    def test_rollback_dry_run(self, tmp_path, capsys):
+        mig = _setup_migration(tmp_path, "drytest")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, mig, mig_path)
+        rollback_migration(conn, mig, mig_path, dry_run=True)
+
+        # Still applied
+        assert len(get_applied_migrations(conn)) == 1
+
+        captured = capsys.readouterr()
+        assert "DRY RUN" in captured.out
+        conn.close()
+
+
+class TestChecksums:
+    def test_checksum_consistency(self, tmp_path):
+        mig = _setup_migration(tmp_path, "chk")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        c1 = compute_checksum(mig_path)
+        c2 = compute_checksum(mig_path)
+        assert c1 == c2
+
+    def test_checksum_mismatch_detected(self, tmp_path):
+        mig = _setup_migration(tmp_path, "tamper")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, mig, mig_path)
+
+        # Tamper with the file
+        original = mig_path.read_text()
+        mig_path.write_text(original + "\n# tampered", encoding="utf-8")
+
+        from schemav.migration_generator import load_all_migrations
+        migrations, _ = load_all_migrations(tmp_path / "migrations")
+        warnings = verify_checksums(conn, migrations, tmp_path / "migrations")
+        assert len(warnings) == 1
+        assert "mismatch" in warnings[0].lower()
+        conn.close()
+
+    def test_rollback_checksum_mismatch_blocks_without_force(self, tmp_path):
+        mig = _setup_migration(tmp_path, "blocktest")
+        mig_path = tmp_path / "migrations" / f"{mig.migration_id}.yaml"
+        db_path = str(tmp_path / "test.db")
+        conn = get_connection(db_path)
+
+        apply_migration(conn, mig, mig_path)
+
+        # Tamper
+        original = mig_path.read_text()
+        mig_path.write_text(original + "\n# tampered", encoding="utf-8")
+
+        with pytest.raises(ValueError, match="Checksum mismatch"):
+            rollback_migration(conn, mig, mig_path, force=False)
+        conn.close()
