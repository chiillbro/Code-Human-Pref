+"""schemav - A CLI database schema migration and versioning tool for SQLite."""
+
+__version__ = "0.1.0"
diff --git a/src/schemav/cli.py b/src/schemav/cli.py
new file mode 100644
index 0000000..4f7d25b
--- /dev/null
+++ b/src/schemav/cli.py
@@ -0,0 +1,635 @@
+"""CLI entry point for schemav."""
+
+from __future__ import annotations
+
+import argparse
+import sys
+import yaml
+from pathlib import Path
+
+from schemav import __version__
+from schemav.conflict_detector import (
+    create_merge_migration,
+    detect_conflicts,
+    detect_diamond_patterns,
+    get_migration_order,
+)
+from schemav.diff_engine import diff_schemas
+from schemav.migration_generator import (
+    generate_migration,
+    has_lossy_operations,
+    load_all_migrations,
+)
+from schemav.models import DiffOp, DiffOpType, Schema
+from schemav.schema_parser import load_schema
+from schemav.state_tracker import (
+    apply_migration,
+    get_applied_migrations,
+    get_connection,
+    get_latest_applied_id,
+    rollback_migration,
+    verify_checksums,
+)
+
+EXIT_SUCCESS = 0
+EXIT_VALIDATION_ERROR = 1
+EXIT_MIGRATION_FAILURE = 2
+EXIT_CONFLICT = 3
+
+DEFAULT_CONFIG = {
+    "database": "schemav.db",
+    "schema_dir": "schema",
+    "migrations_dir": "migrations",
+}
+
+
+def _load_config(config_path: Path) -> dict:
+    if not config_path.exists():
+        print(f"Error: Config file '{config_path}' not found. Run 'schemav init' first.", file=sys.stderr)
+        sys.exit(EXIT_VALIDATION_ERROR)
+
+    with open(config_path, "r") as f:
+        data = yaml.safe_load(f) or {}
+
+    config = dict(DEFAULT_CONFIG)
+    config.update(data)
+    return config
+
+
+def _resolve_paths(config: dict, base: Path) -> tuple[Path, Path, str]:
+    schema_dir = base / config["schema_dir"]
+    migrations_dir = base / config["migrations_dir"]
+    db_path = str(base / config["database"])
+    return schema_dir, migrations_dir, db_path
+
+
+def cmd_init(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    schema_dir = base / "schema"
+    migrations_dir = base / "migrations"
+    config_path = base / "schemav.yaml"
+
+    schema_dir.mkdir(exist_ok=True)
+    migrations_dir.mkdir(exist_ok=True)
+
+    if not config_path.exists():
+        config_path.write_text(
+            yaml.dump(DEFAULT_CONFIG, default_flow_style=False, sort_keys=False),
+            encoding="utf-8",
+        )
+        print(f"Created config: {config_path}")
+    else:
+        print(f"Config already exists: {config_path}")
+
+    print(f"Created directories: {schema_dir}, {migrations_dir}")
+    print("Project initialized. Add your table definitions as YAML files in schema/.")
+    return EXIT_SUCCESS
+
+
+def cmd_validate(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    config = _load_config(base / "schemav.yaml")
+    schema_dir, migrations_dir, _ = _resolve_paths(config, base)
+
+    all_errors: list[str] = []
+
+    # Validate schema files
+    schema, schema_errors = load_schema(schema_dir)
+    all_errors.extend(schema_errors)
+
+    # Validate migration files
+    migrations, mig_errors = load_all_migrations(migrations_dir)
+    all_errors.extend(mig_errors)
+
+    # Validate migration dependency chain
+    if migrations:
+        for mid, mig in migrations.items():
+            if mig.depends_on is not None and mig.depends_on not in migrations:
+                all_errors.append(
+                    f"Migration '{mid}': depends_on '{mig.depends_on}' not found"
+                )
+
+        # Check for cycles
+        try:
+            get_migration_order(migrations)
+        except ValueError as e:
+            all_errors.append(str(e))
+
+    if all_errors:
+        print("Validation errors:", file=sys.stderr)
+        for err in all_errors:
+            print(f"  - {err}", file=sys.stderr)
+        return EXIT_VALIDATION_ERROR
+
+    print(f"Validation passed: {len(schema.tables)} table(s), {len(migrations)} migration(s)")
+    return EXIT_SUCCESS
+
+
+def cmd_generate(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    config = _load_config(base / "schemav.yaml")
+    schema_dir, migrations_dir, db_path = _resolve_paths(config, base)
+
+    # Load desired schema
+    new_schema, schema_errors = load_schema(schema_dir)
+    if schema_errors:
+        print("Schema validation errors:", file=sys.stderr)
+        for err in schema_errors:
+            print(f"  - {err}", file=sys.stderr)
+        return EXIT_VALIDATION_ERROR
+
+    # Load migrations on disk to build "current" schema state
+    migrations, mig_errors = load_all_migrations(migrations_dir)
+    if mig_errors:
+        print("Migration file errors:", file=sys.stderr)
+        for err in mig_errors:
+            print(f"  - {err}", file=sys.stderr)
+        return EXIT_VALIDATION_ERROR
+
+    # Build the old schema from the chain of applied up_sql
+    # For simplicity, the "old schema" is derived from actually applied migrations' schema
+    # We reconstruct from the database's actual state
+    conn = get_connection(db_path)
+    old_schema = _introspect_db_schema(conn)
+    conn.close()
+
+    # Compute diff
+    ops = diff_schemas(old_schema, new_schema)
+
+    if not ops:
+        print("No schema changes detected.")
+        return EXIT_SUCCESS
+
+    # Check for potential renames and interactive mode
+    rename_ops = [op for op in ops if op.op_type == DiffOpType.POTENTIAL_RENAME_COLUMN]
+    if rename_ops and args.interactive:
+        confirmed_renames = []
+        for op in rename_ops:
+            old_name = op.details["old_name"]
+            new_name = op.details["new_name"]
+            table = op.table_name
+            answer = input(
+                f"Column '{old_name}' in table '{table}' appears to have been renamed to "
+                f"'{new_name}'. Treat as rename? [y/N]: "
+            )
+            if answer.strip().lower() == "y":
+                confirmed_renames.append(op)
+            else:
+                # Replace rename op with drop + add
+                ops.remove(op)
+                drop_col = op.details["old_column"]
+                add_col = op.details["new_column"]
+                ops.append(DiffOp(
+                    op_type=DiffOpType.DROP_COLUMN,
+                    table_name=table,
+                    details={"column_name": drop_col.name, "column": drop_col},
+                    lossy=True,
+                ))
+                ops.append(DiffOp(
+                    op_type=DiffOpType.ADD_COLUMN,
+                    table_name=table,
+                    details={"column_name": add_col.name, "column": add_col},
+                ))
+    elif rename_ops and not args.interactive:
+        print("WARNING: Potential column renames detected:", file=sys.stderr)
+        for op in rename_ops:
+            print(
+                f"  - '{op.details['old_name']}' -> '{op.details['new_name']}' "
+                f"in table '{op.table_name}'",
+                file=sys.stderr,
+            )
+        print(
+            "Use --interactive to confirm renames, or they will be treated as renames by default.",
+            file=sys.stderr,
+        )
+
+    # Determine parent migration
+    latest_id = None
+    if migrations:
+        try:
+            order = get_migration_order(migrations)
+            latest_id = order[-1] if order else None
+        except ValueError:
+            # If cycle, just pick the last one alphabetically
+            latest_id = sorted(migrations.keys())[-1]
+
+    description = args.description
+    migration = generate_migration(description, ops, latest_id, migrations_dir)
+
+    print(f"Generated migration: {migration.migration_id}")
+    print("Changes detected:")
+    for op in ops:
+        lossy_tag = " [LOSSY]" if op.lossy else ""
+        print(f"  - {op.description}{lossy_tag}")
+
+    if has_lossy_operations(ops):
+        print(
+            "\nWARNING: This migration includes lossy operations. "
+            "Rollback will not fully restore data.",
+            file=sys.stderr,
+        )
+
+    return EXIT_SUCCESS
+
+
+def cmd_apply(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    config = _load_config(base / "schemav.yaml")
+    schema_dir, migrations_dir, db_path = _resolve_paths(config, base)
+
+    migrations, mig_errors = load_all_migrations(migrations_dir)
+    if mig_errors:
+        print("Migration file errors:", file=sys.stderr)
+        for err in mig_errors:
+            print(f"  - {err}", file=sys.stderr)
+        return EXIT_VALIDATION_ERROR
+
+    if not migrations:
+        print("No migrations found.")
+        return EXIT_SUCCESS
+
+    # Detect conflicts
+    conflicts = detect_conflicts(migrations)
+    if conflicts:
+        print("Migration conflicts detected! Resolve before applying:", file=sys.stderr)
+        for conflict in conflicts:
+            parent = conflict.parent_id or "(root)"
+            print(
+                f"  - Parent '{parent}' has multiple children: {conflict.branch_ids}",
+                file=sys.stderr,
+            )
+        print("Run 'schemav merge' to create a merge migration.", file=sys.stderr)
+        return EXIT_CONFLICT
+
+    # Get ordered list
+    try:
+        order = get_migration_order(migrations)
+    except ValueError as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return EXIT_VALIDATION_ERROR
+
+    conn = get_connection(db_path)
+
+    # Verify checksums
+    warnings = verify_checksums(conn, migrations, migrations_dir)
+    for w in warnings:
+        print(f"WARNING: {w}", file=sys.stderr)
+
+    # Determine what needs to be applied
+    applied = get_applied_migrations(conn)
+    applied_ids = {e.migration_id for e in applied}
+
+    target_id = args.target
+    to_apply: list[str] = []
+    for mid in order:
+        if mid not in applied_ids:
+            to_apply.append(mid)
+        if target_id and mid == target_id:
+            break
+
+    if not to_apply:
+        print("All migrations are already applied.")
+        conn.close()
+        return EXIT_SUCCESS
+
+    print(f"Applying {len(to_apply)} migration(s)...")
+
+    for mid in to_apply:
+        mig = migrations[mid]
+        mig_path = migrations_dir / f"{mid}.yaml"
+        try:
+            apply_migration(conn, mig, mig_path, dry_run=args.dry_run)
+            status = "[DRY RUN] " if args.dry_run else ""
+            print(f"  {status}Applied: {mid}")
+        except Exception as e:
+            print(f"Error applying migration '{mid}': {e}", file=sys.stderr)
+            conn.close()
+            return EXIT_MIGRATION_FAILURE
+
+    conn.close()
+    return EXIT_SUCCESS
+
+
+def cmd_rollback(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    config = _load_config(base / "schemav.yaml")
+    schema_dir, migrations_dir, db_path = _resolve_paths(config, base)
+
+    migrations, mig_errors = load_all_migrations(migrations_dir)
+    if mig_errors:
+        for err in mig_errors:
+            print(f"WARNING: {err}", file=sys.stderr)
+
+    conn = get_connection(db_path)
+    applied = get_applied_migrations(conn)
+
+    if not applied:
+        print("No migrations to rollback.")
+        conn.close()
+        return EXIT_SUCCESS
+
+    steps = args.steps
+    to_rollback = list(reversed(applied[-steps:]))
+
+    print(f"Rolling back {len(to_rollback)} migration(s)...")
+
+    for entry in to_rollback:
+        mid = entry.migration_id
+        if mid not in migrations:
+            print(f"Error: Migration file for '{mid}' not found on disk.", file=sys.stderr)
+            conn.close()
+            return EXIT_MIGRATION_FAILURE
+
+        mig = migrations[mid]
+        mig_path = migrations_dir / f"{mid}.yaml"
+        try:
+            rollback_migration(
+                conn, mig, mig_path,
+                dry_run=args.dry_run,
+                force=args.force,
+            )
+            status = "[DRY RUN] " if args.dry_run else ""
+            print(f"  {status}Rolled back: {mid}")
+        except ValueError as e:
+            print(f"Error: {e}", file=sys.stderr)
+            conn.close()
+            return EXIT_MIGRATION_FAILURE
+        except Exception as e:
+            print(f"Error rolling back migration '{mid}': {e}", file=sys.stderr)
+            conn.close()
+            return EXIT_MIGRATION_FAILURE
+
+    conn.close()
+    return EXIT_SUCCESS
+
+
+def cmd_status(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    config = _load_config(base / "schemav.yaml")
+    schema_dir, migrations_dir, db_path = _resolve_paths(config, base)
+
+    migrations, mig_errors = load_all_migrations(migrations_dir)
+    if mig_errors:
+        for err in mig_errors:
+            print(f"WARNING: {err}", file=sys.stderr)
+
+    conn = get_connection(db_path)
+    applied = get_applied_migrations(conn)
+    applied_ids = {e.migration_id for e in applied}
+
+    # Check conflicts
+    conflicts = detect_conflicts(migrations)
+    diamonds = detect_diamond_patterns(migrations)
+
+    # Checksums
+    warnings = verify_checksums(conn, migrations, migrations_dir)
+    conn.close()
+
+    # Display
+    print(f"{'Migration ID':<45} {'Status':<12} {'Depends On'}")
+    print("-" * 90)
+
+    try:
+        order = get_migration_order(migrations)
+    except ValueError:
+        order = sorted(migrations.keys())
+
+    for mid in order:
+        mig = migrations[mid]
+        status = "applied" if mid in applied_ids else "pending"
+        dep = mig.depends_on or "(root)"
+        print(f"{mid:<45} {status:<12} {dep}")
+
+    if conflicts:
+        print(f"\n⚠ CONFLICTS DETECTED ({len(conflicts)}):")
+        for c in conflicts:
+            parent = c.parent_id or "(root)"
+            print(f"  Parent '{parent}' has branches: {c.branch_ids}")
+
+    if diamonds:
+        print(f"\n⚠ DIAMOND PATTERNS DETECTED ({len(diamonds)}):")
+        for d in diamonds:
+            print(
+                f"  Diverges at '{d['diverge_at']}', "
+                f"branches {d['branches']}, converges at '{d['converge_at']}'"
+            )
+
+    if warnings:
+        print(f"\n⚠ CHECKSUM WARNINGS ({len(warnings)}):")
+        for w in warnings:
+            print(f"  {w}")
+
+    return EXIT_SUCCESS
+
+
+def cmd_merge(args: argparse.Namespace) -> int:
+    base = Path.cwd()
+    config = _load_config(base / "schemav.yaml")
+    _, migrations_dir, _ = _resolve_paths(config, base)
+
+    migrations, mig_errors = load_all_migrations(migrations_dir)
+    if mig_errors:
+        for err in mig_errors:
+            print(f"WARNING: {err}", file=sys.stderr)
+
+    conflicts = detect_conflicts(migrations)
+    if not conflicts:
+        print("No conflicts detected. Nothing to merge.")
+        return EXIT_SUCCESS
+
+    try:
+        merge_mig = create_merge_migration(migrations, migrations_dir)
+    except ValueError as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return EXIT_VALIDATION_ERROR
+
+    print(f"Created merge migration: {merge_mig.migration_id}")
+    print(f"Description: {merge_mig.description}")
+    print(
+        "\nNext steps: run 'schemav generate <description>' to generate a new "
+        "migration from the merged state."
+    )
+    return EXIT_SUCCESS
+
+
+def _introspect_db_schema(conn) -> Schema:
+    """Introspect the current SQLite database to build a Schema object.
+
+    This is used as the 'old' schema when generating diffs."""
+    from schemav.models import (
+        CheckConstraint,
+        Column,
+        ColumnType,
+        ForeignKey,
+        Index,
+        OnDeleteAction,
+        Schema,
+        Table,
+    )
+
+    tables: dict[str, Table] = {}
+
+    cursor = conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' AND name != ? AND name NOT LIKE 'sqlite_%' ORDER BY name",
+        ("_schemav_history",),
+    )
+    table_names = [row[0] for row in cursor]
+
+    type_map = {
+        "TEXT": ColumnType.TEXT,
+        "INTEGER": ColumnType.INTEGER,
+        "REAL": ColumnType.REAL,
+        "BLOB": ColumnType.BLOB,
+    }
+
+    for table_name in table_names:
+        columns: list[Column] = []
+        pk_columns: list[str] = []
+
+        # Get column info
+        col_cursor = conn.execute(f'PRAGMA table_info("{table_name}")')
+        for row in col_cursor:
+            cid, col_name, col_type, notnull, default_val, is_pk = row
+            ct = type_map.get(col_type.upper(), ColumnType.TEXT) if col_type else ColumnType.TEXT
+            # Check if the original type was BOOLEAN or DATETIME
+            if col_type and "BOOLEAN" in col_type.upper():
+                ct = ColumnType.BOOLEAN
+            elif col_type and "DATETIME" in col_type.upper():
+                ct = ColumnType.DATETIME
+
+            default_str = str(default_val) if default_val is not None else None
+            columns.append(Column(
+                name=col_name,
+                type=ct,
+                nullable=not bool(notnull),
+                default=default_str,
+                unique=False,  # We'll patch this from index info
+            ))
+            if is_pk:
+                pk_columns.append(col_name)
+
+        # Get indexes
+        indexes: list[Index] = []
+        idx_cursor = conn.execute(f'PRAGMA index_list("{table_name}")')
+        for row in idx_cursor:
+            idx_name = row[1]
+            idx_unique = bool(row[2])
+            # Skip auto-generated indexes
+            if idx_name.startswith("sqlite_"):
+                continue
+            idx_info = conn.execute(f'PRAGMA index_info("{idx_name}")')
+            idx_cols = tuple(r[2] for r in idx_info)
+            indexes.append(Index(name=idx_name, columns=idx_cols, unique=idx_unique))
+
+        # Get foreign keys
+        foreign_keys: list[ForeignKey] = []
+        fk_cursor = conn.execute(f'PRAGMA foreign_key_list("{table_name}")')
+        # Group by id
+        fk_groups: dict[int, dict] = {}
+        for row in fk_cursor:
+            fk_id = row[0]
+            if fk_id not in fk_groups:
+                fk_groups[fk_id] = {
+                    "ref_table": row[2],
+                    "local_cols": [],
+                    "ref_cols": [],
+                    "on_delete": row[6] if len(row) > 6 else "NO ACTION",
+                }
+            fk_groups[fk_id]["local_cols"].append(row[3])
+            fk_groups[fk_id]["ref_cols"].append(row[4])
+
+        for fk_data in fk_groups.values():
+            on_del_str = (fk_data.get("on_delete") or "NO ACTION").upper()
+            try:
+                on_del = OnDeleteAction(on_del_str)
+            except ValueError:
+                on_del = OnDeleteAction.NO_ACTION
+            foreign_keys.append(ForeignKey(
+                columns=tuple(fk_data["local_cols"]),
+                references_table=fk_data["ref_table"],
+                references_columns=tuple(fk_data["ref_cols"]),
+                on_delete=on_del,
+            ))
+
+        tables[table_name] = Table(
+            name=table_name,
+            columns=columns,
+            primary_key=pk_columns,
+            indexes=indexes,
+            foreign_keys=foreign_keys,
+            constraints=[],  # SQLite doesn't expose CHECK constraints via PRAGMA
+        )
+
+    return Schema(tables=tables)
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="schemav",
+        description="Database schema migration and versioning tool for SQLite",
+    )
+    parser.add_argument("--version", action="version", version=f"schemav {__version__}")
+    subparsers = parser.add_subparsers(dest="command", help="Available commands")
+
+    # init
+    subparsers.add_parser("init", help="Initialize a new schemav project")
+
+    # validate
+    subparsers.add_parser("validate", help="Validate schema and migration files")
+
+    # generate
+    gen_parser = subparsers.add_parser("generate", help="Generate a new migration from schema diff")
+    gen_parser.add_argument("description", help="Short description for the migration")
+    gen_parser.add_argument(
+        "--interactive", "-i", action="store_true",
+        help="Interactively confirm potential column renames",
+    )
+
+    # apply
+    apply_parser = subparsers.add_parser("apply", help="Apply pending migrations")
+    apply_parser.add_argument("--dry-run", action="store_true", help="Show SQL without executing")
+    apply_parser.add_argument("--target", default=None, help="Apply up to this migration ID")
+
+    # rollback
+    rb_parser = subparsers.add_parser("rollback", help="Roll back applied migrations")
+    rb_parser.add_argument("--dry-run", action="store_true", help="Show SQL without executing")
+    rb_parser.add_argument("--steps", type=int, default=1, help="Number of migrations to roll back")
+    rb_parser.add_argument("--force", action="store_true", help="Force rollback even for lossy ops")
+
+    # status
+    subparsers.add_parser("status", help="Show migration status")
+
+    # merge
+    subparsers.add_parser("merge", help="Create a merge migration for conflicting branches")
+
+    return parser
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = build_parser()
+    args = parser.parse_args(argv)
+
+    if not args.command:
+        parser.print_help()
+        return EXIT_SUCCESS
+
+    commands = {
+        "init": cmd_init,
+        "validate": cmd_validate,
+        "generate": cmd_generate,
+        "apply": cmd_apply,
+        "rollback": cmd_rollback,
+        "status": cmd_status,
+        "merge": cmd_merge,
+    }
+
+    handler = commands.get(args.command)
+    if handler is None:
+        parser.print_help()
+        return EXIT_VALIDATION_ERROR
+
+    return handler(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
