+"""Tests for conflict detector — DAG building, branch detection, diamonds, merge."""
+
+import pytest
+
+from schemav.conflict_detector import (
+    build_dependency_graph,
+    create_merge_migration,
+    detect_conflicts,
+    detect_diamond_patterns,
+    find_leaf_migrations,
+    get_migration_order,
+)
+from schemav.models import Migration
+
+
+def _mig(mid: str, depends_on: str | None = None) -> Migration:
+    return Migration(
+        migration_id=mid,
+        description=f"desc_{mid}",
+        depends_on=depends_on,
+        up_sql=[],
+        down_sql=[],
+    )
+
+
+class TestBuildDependencyGraph:
+    def test_linear_chain(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "b"),
+        }
+        children_of, parent_of = build_dependency_graph(migs)
+        assert parent_of["a"] is None
+        assert parent_of["b"] == "a"
+        assert parent_of["c"] == "b"
+        assert "b" in children_of["a"]
+        assert "c" in children_of["b"]
+
+    def test_fork(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+        }
+        children_of, _ = build_dependency_graph(migs)
+        assert set(children_of["a"]) == {"b", "c"}
+
+
+class TestDetectConflicts:
+    def test_no_conflict_linear(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "b"),
+        }
+        conflicts = detect_conflicts(migs)
+        assert len(conflicts) == 0
+
+    def test_simple_fork_conflict(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+        }
+        conflicts = detect_conflicts(migs)
+        assert len(conflicts) == 1
+        assert conflicts[0].parent_id == "a"
+        assert set(conflicts[0].branch_ids) == {"b", "c"}
+
+    def test_triple_fork(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+            "d": _mig("d", "a"),
+        }
+        conflicts = detect_conflicts(migs)
+        assert len(conflicts) == 1
+        assert len(conflicts[0].branch_ids) == 3
+
+    def test_two_independent_forks(self):
+        migs = {
+            "root": _mig("root", None),
+            "b1": _mig("b1", "root"),
+            "b2": _mig("b2", "root"),
+            "b1_child1": _mig("b1_child1", "b1"),
+            "b1_child2": _mig("b1_child2", "b1"),
+        }
+        conflicts = detect_conflicts(migs)
+        assert len(conflicts) == 2
+
+    def test_root_fork(self):
+        """Two migrations with depends_on=None -> root fork."""
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", None),
+        }
+        conflicts = detect_conflicts(migs)
+        assert len(conflicts) == 1
+        assert conflicts[0].parent_id is None
+
+
+class TestDetectDiamondPatterns:
+    def test_simple_diamond(self):
+        """a -> b, a -> c, b -> d, c -> d => diamond"""
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+            "d": _mig("d", "b"),  # d also logically depends on c but can only have 1 parent in our model
+        }
+        # In our model, d can only have one parent. So a true diamond
+        # requires d to be in both branches' descendant sets via its parent chain.
+        # Actually, our diamond detection traces descendants from fork point.
+        # d is a descendant of b (one of the branches from fork at a).
+        # d is NOT a descendant of c.
+        # So this isn't a diamond in our model. Let's test what we actually detect.
+        diamonds = detect_diamond_patterns(migs)
+        # d only descends from b, not c. So no diamond.
+        assert len(diamonds) == 0
+
+    def test_no_diamond_in_linear(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "b"),
+        }
+        diamonds = detect_diamond_patterns(migs)
+        assert len(diamonds) == 0
+
+
+class TestFindLeafMigrations:
+    def test_linear(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "b"),
+        }
+        children_of, _ = build_dependency_graph(migs)
+        leaves = find_leaf_migrations(migs, children_of)
+        assert leaves == ["c"]
+
+    def test_fork_two_leaves(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+        }
+        children_of, _ = build_dependency_graph(migs)
+        leaves = find_leaf_migrations(migs, children_of)
+        assert set(leaves) == {"b", "c"}
+
+
+class TestGetMigrationOrder:
+    def test_linear(self):
+        migs = {
+            "c": _mig("c", "b"),
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+        }
+        order = get_migration_order(migs)
+        assert order == ["a", "b", "c"]
+
+    def test_fork(self):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+        }
+        order = get_migration_order(migs)
+        assert order[0] == "a"
+        assert set(order[1:]) == {"b", "c"}
+
+    def test_cycle_raises(self):
+        migs = {
+            "a": _mig("a", "b"),
+            "b": _mig("b", "a"),
+        }
+        with pytest.raises(ValueError, match="Cycle"):
+            get_migration_order(migs)
+
+
+class TestCreateMergeMigration:
+    def test_creates_merge(self, tmp_path):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+            "c": _mig("c", "a"),
+        }
+        merge = create_merge_migration(migs, tmp_path)
+        assert "merge" in merge.migration_id
+        assert merge.depends_on in {"b", "c"}
+        # Verify file created
+        path = tmp_path / f"{merge.migration_id}.yaml"
+        assert path.exists()
+
+    def test_no_conflict_raises(self, tmp_path):
+        migs = {
+            "a": _mig("a", None),
+            "b": _mig("b", "a"),
+        }
+        with pytest.raises(ValueError, match="fewer than 2"):
+            create_merge_migration(migs, tmp_path)
