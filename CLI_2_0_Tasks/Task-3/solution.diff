+"""YAML schema file parser and validator for schemav."""
+
+from __future__ import annotations
+
+import re
+import yaml
+from pathlib import Path
+
+from schemav.models import (
+    CheckConstraint,
+    Column,
+    ColumnType,
+    ForeignKey,
+    Index,
+    OnDeleteAction,
+    Schema,
+    Table,
+)
+
+VALID_COLUMN_TYPES = {ct.value for ct in ColumnType}
+VALID_ON_DELETE = {a.value for a in OnDeleteAction}
+STEP_NAME_RE = re.compile(r"^[a-zA-Z_][a-zA-Z0-9_]*$")
+
+
+class SchemaValidationError(Exception):
+    def __init__(self, errors: list[str]):
+        self.errors = errors
+        super().__init__(f"Schema validation failed with {len(errors)} error(s)")
+
+
+def _validate_column(col_data: dict, table_name: str, idx: int) -> tuple[Column | None, list[str]]:
+    errors: list[str] = []
+    name = col_data.get("name")
+    if not name or not isinstance(name, str):
+        errors.append(f"Table '{table_name}', column {idx}: 'name' is required and must be a string")
+        return None, errors
+
+    raw_type = col_data.get("type")
+    if not raw_type or str(raw_type).upper() not in VALID_COLUMN_TYPES:
+        errors.append(
+            f"Table '{table_name}', column '{name}': "
+            f"'type' must be one of {sorted(VALID_COLUMN_TYPES)}, got '{raw_type}'"
+        )
+        return None, errors
+
+    col_type = ColumnType(str(raw_type).upper())
+    nullable = col_data.get("nullable", True)
+    if not isinstance(nullable, bool):
+        errors.append(f"Table '{table_name}', column '{name}': 'nullable' must be a boolean")
+        return None, errors
+
+    unique = col_data.get("unique", False)
+    if not isinstance(unique, bool):
+        errors.append(f"Table '{table_name}', column '{name}': 'unique' must be a boolean")
+        return None, errors
+
+    default = col_data.get("default")
+    if default is not None:
+        default = str(default)
+
+    return Column(name=name, type=col_type, nullable=nullable, default=default, unique=unique), errors
+
+
+def _validate_index(idx_data: dict, table_name: str, col_names: set[str], i: int) -> tuple[Index | None, list[str]]:
+    errors: list[str] = []
+    name = idx_data.get("name")
+    if not name or not isinstance(name, str):
+        errors.append(f"Table '{table_name}', index {i}: 'name' is required")
+        return None, errors
+
+    columns = idx_data.get("columns", [])
+    if not isinstance(columns, list) or len(columns) == 0:
+        errors.append(f"Table '{table_name}', index '{name}': 'columns' must be a non-empty list")
+        return None, errors
+
+    for c in columns:
+        if c not in col_names:
+            errors.append(f"Table '{table_name}', index '{name}': references unknown column '{c}'")
+
+    unique = idx_data.get("unique", False)
+    if not isinstance(unique, bool):
+        errors.append(f"Table '{table_name}', index '{name}': 'unique' must be a boolean")
+
+    if errors:
+        return None, errors
+    return Index(name=name, columns=tuple(columns), unique=unique), errors
+
+
+def _validate_foreign_key(
+    fk_data: dict, table_name: str, col_names: set[str], i: int
+) -> tuple[ForeignKey | None, list[str]]:
+    errors: list[str] = []
+
+    columns = fk_data.get("columns", [])
+    if not isinstance(columns, list) or len(columns) == 0:
+        errors.append(f"Table '{table_name}', foreign_key {i}: 'columns' must be a non-empty list")
+        return None, errors
+
+    for c in columns:
+        if c not in col_names:
+            errors.append(f"Table '{table_name}', foreign_key {i}: references unknown local column '{c}'")
+
+    ref_table = fk_data.get("references_table")
+    if not ref_table or not isinstance(ref_table, str):
+        errors.append(f"Table '{table_name}', foreign_key {i}: 'references_table' is required")
+        return None, errors
+
+    ref_columns = fk_data.get("references_columns", [])
+    if not isinstance(ref_columns, list) or len(ref_columns) == 0:
+        errors.append(f"Table '{table_name}', foreign_key {i}: 'references_columns' must be a non-empty list")
+        return None, errors
+
+    on_delete_raw = fk_data.get("on_delete", "NO ACTION")
+    if str(on_delete_raw).upper() not in VALID_ON_DELETE:
+        errors.append(
+            f"Table '{table_name}', foreign_key {i}: "
+            f"'on_delete' must be one of {sorted(VALID_ON_DELETE)}, got '{on_delete_raw}'"
+        )
+        return None, errors
+
+    if errors:
+        return None, errors
+
+    return ForeignKey(
+        columns=tuple(columns),
+        references_table=ref_table,
+        references_columns=tuple(ref_columns),
+        on_delete=OnDeleteAction(str(on_delete_raw).upper()),
+    ), errors
+
+
+def _validate_table(name: str, table_data: dict) -> tuple[Table | None, list[str]]:
+    errors: list[str] = []
+
+    if not STEP_NAME_RE.match(name):
+        errors.append(f"Table name '{name}' is invalid — must match [a-zA-Z_][a-zA-Z0-9_]*")
+
+    # --- columns ---
+    raw_columns = table_data.get("columns", [])
+    if not isinstance(raw_columns, list) or len(raw_columns) == 0:
+        errors.append(f"Table '{name}': must have at least one column")
+        return None, errors
+
+    columns: list[Column] = []
+    col_names: set[str] = set()
+    for i, col_data in enumerate(raw_columns):
+        col, col_errs = _validate_column(col_data, name, i)
+        errors.extend(col_errs)
+        if col:
+            if col.name in col_names:
+                errors.append(f"Table '{name}': duplicate column name '{col.name}'")
+            col_names.add(col.name)
+            columns.append(col)
+
+    # --- primary key ---
+    pk_raw = table_data.get("primary_key")
+    primary_key: list[str] = []
+    if pk_raw is not None:
+        if isinstance(pk_raw, str):
+            primary_key = [pk_raw]
+        elif isinstance(pk_raw, list):
+            primary_key = pk_raw
+        else:
+            errors.append(f"Table '{name}': 'primary_key' must be a string or list of strings")
+
+        for pk_col in primary_key:
+            if pk_col not in col_names:
+                errors.append(f"Table '{name}': primary_key references unknown column '{pk_col}'")
+
+    # --- indexes ---
+    indexes: list[Index] = []
+    for i, idx_data in enumerate(table_data.get("indexes", [])):
+        idx, idx_errs = _validate_index(idx_data, name, col_names, i)
+        errors.extend(idx_errs)
+        if idx:
+            indexes.append(idx)
+
+    # --- foreign keys ---
+    foreign_keys: list[ForeignKey] = []
+    for i, fk_data in enumerate(table_data.get("foreign_keys", [])):
+        fk, fk_errs = _validate_foreign_key(fk_data, name, col_names, i)
+        errors.extend(fk_errs)
+        if fk:
+            foreign_keys.append(fk)
+
+    # --- constraints ---
+    constraints: list[CheckConstraint] = []
+    for i, con_data in enumerate(table_data.get("constraints", [])):
+        con_name = con_data.get("name")
+        expression = con_data.get("expression")
+        if not con_name or not isinstance(con_name, str):
+            errors.append(f"Table '{name}', constraint {i}: 'name' is required")
+            continue
+        if not expression or not isinstance(expression, str):
+            errors.append(f"Table '{name}', constraint '{con_name}': 'expression' is required")
+            continue
+        constraints.append(CheckConstraint(name=con_name, expression=expression))
+
+    if errors:
+        return None, errors
+
+    return Table(
+        name=name,
+        columns=columns,
+        primary_key=primary_key,
+        indexes=indexes,
+        foreign_keys=foreign_keys,
+        constraints=constraints,
+    ), errors
+
+
+def parse_schema_file(path: Path) -> tuple[dict[str, Table], list[str]]:
+    errors: list[str] = []
+    tables: dict[str, Table] = {}
+
+    try:
+        content = path.read_text(encoding="utf-8")
+    except OSError as e:
+        return tables, [f"Cannot read '{path}': {e}"]
+
+    try:
+        data = yaml.safe_load(content)
+    except yaml.YAMLError as e:
+        return tables, [f"Invalid YAML in '{path}': {e}"]
+
+    if not isinstance(data, dict):
+        return tables, [f"'{path}': expected a mapping of table names to definitions"]
+
+    # Support both top-level tables directly, or under a "tables" key
+    table_defs = data.get("tables", data)
+    if not isinstance(table_defs, dict):
+        return tables, [f"'{path}': 'tables' must be a mapping"]
+
+    for table_name, table_data in table_defs.items():
+        if not isinstance(table_data, dict):
+            errors.append(f"'{path}': table '{table_name}' must be a mapping")
+            continue
+        table, tbl_errs = _validate_table(table_name, table_data)
+        errors.extend(tbl_errs)
+        if table:
+            tables[table_name] = table
+
+    return tables, errors
+
+
+def load_schema(schema_dir: Path) -> tuple[Schema, list[str]]:
+    errors: list[str] = []
+    all_tables: dict[str, Table] = {}
+
+    if not schema_dir.is_dir():
+        return Schema(), [f"Schema directory '{schema_dir}' does not exist"]
+
+    yaml_files = sorted(schema_dir.glob("*.yaml")) + sorted(schema_dir.glob("*.yml"))
+    if not yaml_files:
+        return Schema(), [f"No YAML files found in '{schema_dir}'"]
+
+    for path in yaml_files:
+        tables, file_errors = parse_schema_file(path)
+        errors.extend(file_errors)
+        for tname, table in tables.items():
+            if tname in all_tables:
+                errors.append(f"Duplicate table '{tname}' defined in '{path}' (already defined elsewhere)")
+            else:
+                all_tables[tname] = table
+
+    return Schema(tables=all_tables), errors
