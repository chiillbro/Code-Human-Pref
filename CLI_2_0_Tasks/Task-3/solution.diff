+"""Integration test — full workflow: init, generate, apply, modify schema, generate, apply, rollback."""
+
+import sqlite3
+import yaml
+import pytest
+from pathlib import Path
+from unittest.mock import patch
+
+from schemav.cli import main
+
+
+@pytest.fixture
+def project_dir(tmp_path, monkeypatch):
+    monkeypatch.chdir(tmp_path)
+    return tmp_path
+
+
+class TestFullWorkflow:
+    def test_init_creates_structure(self, project_dir):
+        result = main(["init"])
+        assert result == 0
+        assert (project_dir / "schema").is_dir()
+        assert (project_dir / "migrations").is_dir()
+        assert (project_dir / "schemav.yaml").exists()
+
+    def test_validate_empty_project(self, project_dir):
+        main(["init"])
+        # No schema files yet -> error
+        result = main(["validate"])
+        assert result == 1
+
+    def test_full_lifecycle(self, project_dir):
+        # 1. Init
+        assert main(["init"]) == 0
+
+        # 2. Create initial schema
+        schema_dir = project_dir / "schema"
+        (schema_dir / "users.yaml").write_text(yaml.dump({
+            "tables": {
+                "users": {
+                    "columns": [
+                        {"name": "id", "type": "INTEGER", "nullable": False},
+                        {"name": "email", "type": "TEXT", "nullable": False, "unique": True},
+                        {"name": "created_at", "type": "DATETIME"},
+                    ],
+                    "primary_key": "id",
+                }
+            }
+        }), encoding="utf-8")
+
+        # 3. Validate
+        assert main(["validate"]) == 0
+
+        # 4. Generate migration
+        assert main(["generate", "create_users_table"]) == 0
+        migration_files = list((project_dir / "migrations").glob("*.yaml"))
+        assert len(migration_files) == 1
+
+        # 5. Apply migration
+        assert main(["apply"]) == 0
+
+        # Verify the table exists in SQLite
+        config = yaml.safe_load((project_dir / "schemav.yaml").read_text())
+        db_path = str(project_dir / config["database"])
+        conn = sqlite3.connect(db_path)
+        cursor = conn.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='users'")
+        assert cursor.fetchone() is not None
+
+        # Verify columns
+        cursor = conn.execute("PRAGMA table_info('users')")
+        cols = {row[1]: row[2] for row in cursor}
+        assert "id" in cols
+        assert "email" in cols
+        assert "created_at" in cols
+        conn.close()
+
+        # 6. Modify schema — add a column
+        (schema_dir / "users.yaml").write_text(yaml.dump({
+            "tables": {
+                "users": {
+                    "columns": [
+                        {"name": "id", "type": "INTEGER", "nullable": False},
+                        {"name": "email", "type": "TEXT", "nullable": False, "unique": True},
+                        {"name": "display_name", "type": "TEXT"},
+                        {"name": "created_at", "type": "DATETIME"},
+                    ],
+                    "primary_key": "id",
+                }
+            }
+        }), encoding="utf-8")
+
+        # 7. Generate second migration
+        assert main(["generate", "add_display_name"]) == 0
+        migration_files = list((project_dir / "migrations").glob("*.yaml"))
+        assert len(migration_files) == 2
+
+        # 8. Apply second migration
+        assert main(["apply"]) == 0
+
+        conn = sqlite3.connect(db_path)
+        cursor = conn.execute("PRAGMA table_info('users')")
+        cols = {row[1] for row in cursor}
+        assert "display_name" in cols
+        conn.close()
+
+        # 9. Check status
+        assert main(["status"]) == 0
+
+        # 10. Rollback the last migration
+        assert main(["rollback", "--force"]) == 0
+
+        conn = sqlite3.connect(db_path)
+        cursor = conn.execute("PRAGMA table_info('users')")
+        cols = {row[1] for row in cursor}
+        assert "display_name" not in cols
+        conn.close()
+
+    def test_apply_dry_run(self, project_dir, capsys):
+        main(["init"])
+        schema_dir = project_dir / "schema"
+        (schema_dir / "items.yaml").write_text(yaml.dump({
+            "tables": {
+                "items": {
+                    "columns": [
+                        {"name": "id", "type": "INTEGER", "nullable": False},
+                        {"name": "name", "type": "TEXT"},
+                    ],
+                    "primary_key": "id",
+                }
+            }
+        }), encoding="utf-8")
+
+        main(["generate", "create_items"])
+        result = main(["apply", "--dry-run"])
+        assert result == 0
+
+        captured = capsys.readouterr()
+        assert "DRY RUN" in captured.out
+
+        # Table should NOT exist
+        config = yaml.safe_load((project_dir / "schemav.yaml").read_text())
+        db_path = str(project_dir / config["database"])
+        conn = sqlite3.connect(db_path)
+        cursor = conn.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='items'")
+        assert cursor.fetchone() is None
+        conn.close()
+
+    def test_conflict_detection_blocks_apply(self, project_dir):
+        main(["init"])
+        mig_dir = project_dir / "migrations"
+
+        # Create two migrations with the same parent (None)
+        from schemav.migration_generator import write_migration_file
+        from schemav.models import Migration
+
+        m1 = Migration("20240101_branch_a", "branch a", None, ["SELECT 1;"], ["SELECT 1;"])
+        m2 = Migration("20240101_branch_b", "branch b", None, ["SELECT 1;"], ["SELECT 1;"])
+        write_migration_file(m1, mig_dir)
+        write_migration_file(m2, mig_dir)
+
+        result = main(["apply"])
+        assert result == 3  # EXIT_CONFLICT
+
+    def test_merge_resolves_conflict(self, project_dir):
+        main(["init"])
+        mig_dir = project_dir / "migrations"
+
+        from schemav.migration_generator import write_migration_file
+        from schemav.models import Migration
+
+        m_root = Migration("20240101_root", "root", None, ["SELECT 1;"], ["SELECT 1;"])
+        m_a = Migration("20240102_branch_a", "branch a", "20240101_root", ["SELECT 1;"], ["SELECT 1;"])
+        m_b = Migration("20240102_branch_b", "branch b", "20240101_root", ["SELECT 1;"], ["SELECT 1;"])
+        write_migration_file(m_root, mig_dir)
+        write_migration_file(m_a, mig_dir)
+        write_migration_file(m_b, mig_dir)
+
+        # Confirm conflict
+        conflicts_result = main(["apply"])
+        assert conflicts_result == 3
+
+        # Merge
+        merge_result = main(["merge"])
+        assert merge_result == 0
+
+        migrations = list(mig_dir.glob("*.yaml"))
+        assert len(migrations) == 4  # root + a + b + merge
+
+    def test_cli_version(self, capsys):
+        with pytest.raises(SystemExit) as exc_info:
+            main(["--version"])
+        assert exc_info.value.code == 0
+
+    def test_no_command_shows_help(self, capsys):
+        result = main([])
+        assert result == 0
