@@ -0,0 +1,58 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from pathlib import Path
+
+import yaml
+
+from .errors import VijaybaseError
+
+CONFIG_FILE = "vijaybase.yaml"
+
+
+@dataclass
+class Config:
+    database: str
+    schema_dir: str
+    migrations_dir: str
+
+
+def load_config(project_dir: str = ".") -> Config:
+    config_path = Path(project_dir) / CONFIG_FILE
+    if not config_path.exists():
+        raise VijaybaseError(
+            f"'{CONFIG_FILE}' not found. Run 'vijaybase init' first."
+        )
+    with open(config_path) as f:
+        data = yaml.safe_load(f)
+    if not isinstance(data, dict):
+        raise VijaybaseError(f"Invalid config file '{CONFIG_FILE}'")
+    return Config(
+        database=data.get("database", "vijaybase.db"),
+        schema_dir=data.get("schema_dir", "schema"),
+        migrations_dir=data.get("migrations_dir", "migrations"),
+    )
+
+
+def create_config(project_dir: str = ".", db_path: str = "vijaybase.db") -> Config:
+    config = Config(
+        database=db_path,
+        schema_dir="schema",
+        migrations_dir="migrations",
+    )
+    config_path = Path(project_dir) / CONFIG_FILE
+    with open(config_path, "w") as f:
+        yaml.dump(
+            {
+                "database": config.database,
+                "schema_dir": config.schema_dir,
+                "migrations_dir": config.migrations_dir,
+            },
+            f,
+            default_flow_style=False,
+        )
+
+    Path(project_dir, config.schema_dir).mkdir(exist_ok=True)
+    Path(project_dir, config.migrations_dir).mkdir(exist_ok=True)
+
+    return config
