+class VijaybaseError(Exception):
+    """Base exception for vijaybase."""
+
+
+class SchemaError(VijaybaseError):
+    """Invalid schema definition."""
+
+
+class MigrationError(VijaybaseError):
+    """Migration-related error."""
+
+
+class ConflictError(VijaybaseError):
+    """Migration conflict / fork detected."""
+
+
+class ChecksumError(VijaybaseError):
