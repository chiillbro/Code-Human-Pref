@@ -0,0 +1,155 @@
+"""Diff two Schema objects and produce a list of structured operations."""
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+from .schema import Check, Column, ForeignKey, Index, Schema, Table
+
+
+# ---- diff operation types ---------------------------------------------------
+
+@dataclass(frozen=True)
+class CreateTable:
+    table: Table
+
+@dataclass(frozen=True)
+class DropTable:
+    table: Table
+
+@dataclass(frozen=True)
+class AddColumn:
+    table_name: str
+    column: Column
+
+@dataclass(frozen=True)
+class DropColumn:
+    table_name: str
+    column: Column
+
+@dataclass(frozen=True)
+class AlterColumn:
+    table_name: str
+    old: Column
+    new: Column
+
+@dataclass(frozen=True)
+class AddIndex:
+    table_name: str
+    index: Index
+
+@dataclass(frozen=True)
+class DropIndex:
+    table_name: str
+    index: Index
+
+@dataclass(frozen=True)
+class AddForeignKey:
+    table_name: str
+    fk: ForeignKey
+
+@dataclass(frozen=True)
+class DropForeignKey:
+    table_name: str
+    fk: ForeignKey
+
+@dataclass(frozen=True)
+class AddCheck:
+    table_name: str
+    check: Check
+
+@dataclass(frozen=True)
+class DropCheck:
+    table_name: str
+    check: Check
+
+@dataclass(frozen=True)
+class ChangePrimaryKey:
+    table_name: str
+    old_pk: tuple[str, ...]
+    new_pk: tuple[str, ...]
+
+
+DiffOp = (
+    CreateTable | DropTable
+    | AddColumn | DropColumn | AlterColumn
+    | AddIndex | DropIndex
+    | AddForeignKey | DropForeignKey
+    | AddCheck | DropCheck
+    | ChangePrimaryKey
+)
+
+
+# ---- public API -------------------------------------------------------------
+
+def compute_diff(current: Schema, desired: Schema) -> list[DiffOp]:
+    ops: list[DiffOp] = []
+    cur_names = set(current.tables)
+    des_names = set(desired.tables)
+
+    for name in sorted(des_names - cur_names):
+        ops.append(CreateTable(table=desired.tables[name]))
+
+    for name in sorted(cur_names - des_names):
+        ops.append(DropTable(table=current.tables[name]))
+
+    for name in sorted(cur_names & des_names):
+        ops.extend(_diff_table(current.tables[name], desired.tables[name]))
+
+    return ops
+
+
+# ---- per-table diff ---------------------------------------------------------
+
+def _diff_table(cur: Table, des: Table) -> list[DiffOp]:
+    ops: list[DiffOp] = []
+    name = cur.name
+
+    # columns
+    cur_cols = {c.name: c for c in cur.columns}
+    des_cols = {c.name: c for c in des.columns}
+
+    for cn in sorted(set(des_cols) - set(cur_cols)):
+        ops.append(AddColumn(table_name=name, column=des_cols[cn]))
+    for cn in sorted(set(cur_cols) - set(des_cols)):
+        ops.append(DropColumn(table_name=name, column=cur_cols[cn]))
+    for cn in sorted(set(cur_cols) & set(des_cols)):
+        if cur_cols[cn] != des_cols[cn]:
+            ops.append(AlterColumn(table_name=name, old=cur_cols[cn], new=des_cols[cn]))
+
+    # primary key
+    if cur.primary_key != des.primary_key:
+        ops.append(ChangePrimaryKey(table_name=name, old_pk=cur.primary_key, new_pk=des.primary_key))
+
+    # indexes
+    cur_idx = {i.name: i for i in cur.indexes}
+    des_idx = {i.name: i for i in des.indexes}
+    for iname in sorted(set(des_idx) - set(cur_idx)):
+        ops.append(AddIndex(table_name=name, index=des_idx[iname]))
+    for iname in sorted(set(cur_idx) - set(des_idx)):
+        ops.append(DropIndex(table_name=name, index=cur_idx[iname]))
+    for iname in sorted(set(cur_idx) & set(des_idx)):
+        if cur_idx[iname] != des_idx[iname]:
+            ops.append(DropIndex(table_name=name, index=cur_idx[iname]))
+            ops.append(AddIndex(table_name=name, index=des_idx[iname]))
+
+    # foreign keys (compared by value, not name)
+    cur_fks = set(cur.foreign_keys)
+    des_fks = set(des.foreign_keys)
+    for fk in sorted(des_fks - cur_fks, key=lambda f: f.columns):
+        ops.append(AddForeignKey(table_name=name, fk=fk))
+    for fk in sorted(cur_fks - des_fks, key=lambda f: f.columns):
+        ops.append(DropForeignKey(table_name=name, fk=fk))
+
+    # CHECK constraints
+    cur_chk = {c.name: c for c in cur.checks}
+    des_chk = {c.name: c for c in des.checks}
+    for cn in sorted(set(des_chk) - set(cur_chk)):
+        ops.append(AddCheck(table_name=name, check=des_chk[cn]))
+    for cn in sorted(set(cur_chk) - set(des_chk)):
+        ops.append(DropCheck(table_name=name, check=cur_chk[cn]))
+    for cn in sorted(set(cur_chk) & set(des_chk)):
+        if cur_chk[cn] != des_chk[cn]:
+            ops.append(DropCheck(table_name=name, check=cur_chk[cn]))
+            ops.append(AddCheck(table_name=name, check=des_chk[cn]))
+
+    return ops
