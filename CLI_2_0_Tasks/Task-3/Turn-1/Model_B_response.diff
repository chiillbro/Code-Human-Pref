index 0000000..00a213e
--- /dev/null
+++ b/src/vijaybase/cli.py
@@ -0,0 +1,399 @@
+"""vijaybase CLI entry-point."""
+from __future__ import annotations
+
+import argparse
+import sys
+
+from .config import Config, create_config, load_config
+from .conflict import detect_conflicts
+from .diff import compute_diff
+from .errors import ConflictError, VijaybaseError
+from .history import HistoryManager
+from .introspect import introspect_db
+from .migration import (
+    apply_migration_sql,
+    create_migration_file,
+    get_pending_chain,
+    load_all_migrations,
+    verify_checksum,
+)
+from .schema import load_schema
+from .sql_generator import generate_sql
+
+
+def main(argv: list[str] | None = None) -> None:
+    parser = argparse.ArgumentParser(
+        prog="vijaybase",
+        description="Schema migration & versioning for SQLite",
+    )
+    sub = parser.add_subparsers(dest="command")
+
+    # init
+    p_init = sub.add_parser("init", help="Initialise a new vijaybase project")
+    p_init.add_argument("--db", default="vijaybase.db", help="SQLite database path")
+
+    # generate
+    p_gen = sub.add_parser("generate", help="Generate a migration from schema diff")
+    p_gen.add_argument("description", help="Short description of the change")
+
+    # apply
+    p_app = sub.add_parser("apply", help="Apply pending migrations")
+    p_app.add_argument("--dry-run", action="store_true", help="Print SQL only")
+    p_app.add_argument("--target", default=None, help="Stop after this migration ID")
+
+    # rollback
+    p_rb = sub.add_parser("rollback", help="Rollback applied migrations")
+    p_rb.add_argument("--dry-run", action="store_true", help="Print SQL only")
+    p_rb.add_argument("--steps", type=int, default=1, help="Number of migrations to undo")
+
+    # status
+    sub.add_parser("status", help="Show migration status")
+
+    # validate
+    sub.add_parser("validate", help="Validate schema files and migration integrity")
+
+    # merge
+    sub.add_parser("merge", help="Create a merge migration to resolve forks")
+
+    args = parser.parse_args(argv)
+    if not args.command:
+        parser.print_help()
+        sys.exit(1)
+
+    try:
+        {
+            "init": _cmd_init,
+            "generate": _cmd_generate,
+            "apply": _cmd_apply,
+            "rollback": _cmd_rollback,
+            "status": _cmd_status,
+            "validate": _cmd_validate,
+            "merge": _cmd_merge,
+        }[args.command](args)
+    except VijaybaseError as exc:
+        print(f"Error: {exc}", file=sys.stderr)
+        sys.exit(1)
+
+
+# ---------------------------------------------------------------------------
+# init
+# ---------------------------------------------------------------------------
+
+def _cmd_init(args: argparse.Namespace) -> None:
+    cfg = create_config(db_path=args.db)
+    HistoryManager(cfg.database)  # creates DB + history table
+    print(f"Initialised vijaybase project.")
+    print(f"  config   : vijaybase.yaml")
+    print(f"  database : {cfg.database}")
+    print(f"  schema   : {cfg.schema_dir}/")
+    print(f"  migrations: {cfg.migrations_dir}/")
+    print(f"\nCreate your table definitions in {cfg.schema_dir}/*.yaml, then run:")
+    print(f"  vijaybase generate <description>")
+
+
+# ---------------------------------------------------------------------------
+# generate
+# ---------------------------------------------------------------------------
+
+def _cmd_generate(args: argparse.Namespace) -> None:
+    cfg = load_config()
+    desired = load_schema(cfg.schema_dir)
+    history = HistoryManager(cfg.database)
+    current = introspect_db(cfg.database)
+    head = history.get_current_head()
+
+    ops = compute_diff(current, desired)
+    if not ops:
+        print("No schema changes detected.")
+        return
+
+    up_sql, down_sql = generate_sql(ops, current, desired)
+    mf = create_migration_file(
+        migrations_dir=cfg.migrations_dir,
+        description=args.description,
+        parent=head,
+        up_sql=up_sql,
+        down_sql=down_sql,
+    )
+    print(f"Created migration: {mf.id}")
+    print(f"  file: {mf.file_path}")
+    _print_ops_summary(ops)
+    print(f"\nRun 'vijaybase apply' to execute.")
+
+
+# ---------------------------------------------------------------------------
+# apply
+# ---------------------------------------------------------------------------
+
+def _cmd_apply(args: argparse.Namespace) -> None:
+    cfg = load_config()
+    history = HistoryManager(cfg.database)
+    all_migs = load_all_migrations(cfg.migrations_dir)
+    applied = history.get_applied_migrations()
+
+    # Conflict check
+    forks = detect_conflicts(all_migs, applied)
+    if forks:
+        _print_forks(forks)
+        raise ConflictError("Resolve forks before applying. Run 'vijaybase merge'.")
+
+    chain = get_pending_chain(all_migs, applied)
+    if not chain:
+        print("Nothing to apply – database is up to date.")
+        return
+
+    # Optionally stop at --target
+    if args.target:
+        cut: list = []
+        for m in chain:
+            cut.append(m)
+            if m.id == args.target:
+                break
+        else:
+            raise VijaybaseError(f"Target migration '{args.target}' not found in pending chain.")
+        chain = cut
+
+    for mf in chain:
+        verify_checksum(mf)
+        if args.dry_run:
+            print(f"-- Migration: {mf.id} (up)")
+            print(mf.up_sql)
+            print()
+        else:
+            apply_migration_sql(cfg.database, mf.up_sql)
+            history.record(mf.id, "up", mf.checksum)
+            print(f"Applied: {mf.id}")
+
+    if args.dry_run:
+        print("(dry-run – no changes made)")
+
+
+# ---------------------------------------------------------------------------
+# rollback
+# ---------------------------------------------------------------------------
+
+def _cmd_rollback(args: argparse.Namespace) -> None:
+    cfg = load_config()
+    history = HistoryManager(cfg.database)
+    all_migs = load_all_migrations(cfg.migrations_dir)
+    applied = history.get_applied_migrations()
+
+    if not applied:
+        print("Nothing to rollback.")
+        return
+
+    idx = {m.id: m for m in all_migs}
+    to_rollback = list(reversed(applied[-args.steps :]))
+
+    for mid in to_rollback:
+        mf = idx.get(mid)
+        if mf is None:
+            raise VijaybaseError(f"Migration file for '{mid}' not found.")
+        verify_checksum(mf)
+        if args.dry_run:
+            print(f"-- Migration: {mf.id} (down)")
+            print(mf.down_sql)
+            print()
+        else:
+            apply_migration_sql(cfg.database, mf.down_sql)
+            history.record(mf.id, "down", mf.checksum)
+            print(f"Rolled back: {mf.id}")
+
+    if args.dry_run:
+        print("(dry-run – no changes made)")
+
+
+# ---------------------------------------------------------------------------
+# status
+# ---------------------------------------------------------------------------
+
+def _cmd_status(args: argparse.Namespace) -> None:
+    cfg = load_config()
+    history = HistoryManager(cfg.database)
+    all_migs = load_all_migrations(cfg.migrations_dir)
+    applied = history.get_applied_migrations()
+    head = applied[-1] if applied else "(none)"
+
+    print(f"Database : {cfg.database}")
+    print(f"Head     : {head}")
+    print()
+
+    if applied:
+        print(f"Applied ({len(applied)}):")
+        for mid in applied:
+            print(f"  [applied] {mid}")
+    else:
+        print("No migrations applied yet.")
+
+    try:
+        pending = get_pending_chain(all_migs, applied)
+    except ConflictError:
+        pending = []
+    if pending:
+        print(f"\nPending ({len(pending)}):")
+        for mf in pending:
+            print(f"  [pending] {mf.id}")
+
+    forks = detect_conflicts(all_migs, applied)
+    if forks:
+        print()
+        _print_forks(forks)
+
+
+# ---------------------------------------------------------------------------
+# validate
+# ---------------------------------------------------------------------------
+
+def _cmd_validate(args: argparse.Namespace) -> None:
+    cfg = load_config()
+    errors: list[str] = []
+
+    # 1. Schema files
+    try:
+        load_schema(cfg.schema_dir)
+        print("[OK] Schema YAML is valid.")
+    except VijaybaseError as e:
+        errors.append(f"Schema: {e}")
+        print(f"[FAIL] Schema: {e}")
+
+    # 2. Migration files
+    all_migs = load_all_migrations(cfg.migrations_dir)
+    idx = {m.id: m for m in all_migs}
+
+    for mf in all_migs:
+        try:
+            verify_checksum(mf)
+        except VijaybaseError as e:
+            errors.append(str(e))
+            print(f"[FAIL] {e}")
+
+        if mf.parent and mf.parent not in idx:
+            msg = f"Migration '{mf.id}' references unknown parent '{mf.parent}'"
+            errors.append(msg)
+            print(f"[FAIL] {msg}")
+
+        if mf.merge_parent and mf.merge_parent not in idx:
+            msg = f"Migration '{mf.id}' references unknown merge_parent '{mf.merge_parent}'"
+            errors.append(msg)
+            print(f"[FAIL] {msg}")
+
+    if not errors:
+        print(f"[OK] All {len(all_migs)} migration(s) valid.")
+
+    # 3. Conflict check
+    history = HistoryManager(cfg.database)
+    applied = history.get_applied_migrations()
+    forks = detect_conflicts(all_migs, applied)
+    if forks:
+        _print_forks(forks)
+        errors.append("Unresolved forks detected.")
+    else:
+        print("[OK] No migration conflicts.")
+
+    if errors:
+        print(f"\n{len(errors)} problem(s) found.")
+        sys.exit(1)
+    else:
+        print("\nAll checks passed.")
+
+
+# ---------------------------------------------------------------------------
+# merge
+# ---------------------------------------------------------------------------
+
+def _cmd_merge(args: argparse.Namespace) -> None:
+    cfg = load_config()
+    history = HistoryManager(cfg.database)
+    all_migs = load_all_migrations(cfg.migrations_dir)
+    applied = history.get_applied_migrations()
+    head = history.get_current_head()
+
+    forks = detect_conflicts(all_migs, applied)
+    if not forks:
+        print("No conflicts to merge.")
+        return
+
+    for fork in forks:
+        print(f"Fork at parent '{fork.parent}':")
+        print(f"  applied   : {fork.applied_branches}")
+        print(f"  unapplied : {fork.unapplied_branches}")
+
+        # Re-diff current DB against the desired YAML schema to produce a
+        # migration that reconciles the unapplied branch.
+        desired = load_schema(cfg.schema_dir)
+        current = introspect_db(cfg.database)
+        ops = compute_diff(current, desired)
+
+        if ops:
+            up_sql, down_sql = generate_sql(ops, current, desired)
+        else:
+            up_sql = "-- No SQL changes needed (merge bookkeeping only)"
+            down_sql = "-- No SQL changes needed (merge bookkeeping only)"
+
+        merge_parent = fork.unapplied_branches[0]
+        mf = create_migration_file(
+            migrations_dir=cfg.migrations_dir,
+            description="merge",
+            parent=head,
+            up_sql=up_sql,
+            down_sql=down_sql,
+            merge_parent=merge_parent,
+        )
+        print(f"\nCreated merge migration: {mf.id}")
+        print(f"  merges '{merge_parent}' into current head '{head}'")
+        print(f"  file  : {mf.file_path}")
+        print(f"\nReview the file, then run 'vijaybase apply'.")
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def _print_ops_summary(ops) -> None:
+    from .diff import (
+        AddCheck, AddColumn, AddForeignKey, AddIndex, AlterColumn,
+        ChangePrimaryKey, CreateTable, DropCheck, DropColumn,
+        DropForeignKey, DropIndex, DropTable,
+    )
+    labels = {
+        CreateTable: "create table",
+        DropTable: "drop table",
+        AddColumn: "add column",
+        DropColumn: "drop column",
+        AlterColumn: "alter column",
+        AddIndex: "add index",
+        DropIndex: "drop index",
+        AddForeignKey: "add foreign key",
+        DropForeignKey: "drop foreign key",
+        AddCheck: "add check",
+        DropCheck: "drop check",
+        ChangePrimaryKey: "change primary key",
+    }
+    for op in ops:
+        lbl = labels.get(type(op), type(op).__name__)
+        detail = ""
+        if hasattr(op, "table"):
+            detail = op.table.name
+        elif hasattr(op, "table_name"):
+            detail = op.table_name
+            if hasattr(op, "column"):
+                detail += f".{op.column.name}"
+            elif hasattr(op, "index"):
+                detail += f".{op.index.name}"
+            elif hasattr(op, "fk"):
+                detail += f" -> {op.fk.references_table}"
+            elif hasattr(op, "check"):
+                detail += f".{op.check.name}"
+            elif hasattr(op, "new"):
+                detail += f".{op.new.name}"
+        print(f"  {lbl}: {detail}")
+
+
+def _print_forks(forks) -> None:
+    for f in forks:
+        print(f"CONFLICT – fork at parent '{f.parent}':")
+        for b in f.applied_branches:
+            print(f"  [applied]   {b}")
+        for b in f.unapplied_branches:
+            print(f"  [unapplied] {b}")
+        print("  Run 'vijaybase merge' to resolve.")
