--- /dev/null
+++ b/src/vijaybase/conflict.py
@@ -0,0 +1,46 @@
+"""Detect migration forks and support merging."""
+from __future__ import annotations
+
+from collections import defaultdict
+from dataclasses import dataclass
+
+from .migration import MigrationFile
+
+
+@dataclass
+class Fork:
+    parent: str | None
+    applied_branches: list[str]
+    unapplied_branches: list[str]
+
+
+def detect_conflicts(
+    all_migrations: list[MigrationFile],
+    applied_ids: list[str],
+) -> list[Fork]:
+    """Return unresolved forks (same parent, one branch applied, the other not)."""
+    applied_set = set(applied_ids)
+
+    children_of: dict[str | None, list[MigrationFile]] = defaultdict(list)
+    for m in all_migrations:
+        children_of[m.parent].append(m)
+
+    # Which unapplied branches already have a merge migration?
+    merged_ids: set[str] = set()
+    for m in all_migrations:
+        if m.merge_parent:
+            merged_ids.add(m.merge_parent)
+
+    forks: list[Fork] = []
+    for parent, kids in children_of.items():
+        if len(kids) <= 1:
+            continue
+        applied = [k.id for k in kids if k.id in applied_set]
+        unapplied = [
+            k.id for k in kids
+            if k.id not in applied_set and k.id not in merged_ids
+        ]
+        if applied and unapplied:
+            forks.append(Fork(parent=parent, applied_branches=applied, unapplied_branches=unapplied))
+
+    return forks
