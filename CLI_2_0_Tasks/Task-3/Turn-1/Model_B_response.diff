@@ -0,0 +1,73 @@
+"""Manage the _vijaybase_history table inside the target SQLite DB."""
+from __future__ import annotations
+
+import sqlite3
+
+_CREATE_HISTORY = """\
+CREATE TABLE IF NOT EXISTS _vijaybase_history (
+    id          INTEGER PRIMARY KEY AUTOINCREMENT,
+    migration_id TEXT    NOT NULL,
+    direction   TEXT    NOT NULL CHECK(direction IN ('up', 'down')),
+    applied_at  TEXT    NOT NULL DEFAULT (datetime('now')),
+    checksum    TEXT    NOT NULL
+);
+"""
+
+
+class HistoryManager:
+    def __init__(self, db_path: str):
+        self.db_path = db_path
+        self._ensure_table()
+
+    # ---- public API ---------------------------------------------------------
+
+    def get_applied_migrations(self) -> list[str]:
+        """Return an ordered list of currently-applied migration IDs."""
+        conn = self._connect()
+        try:
+            rows = conn.execute(
+                "SELECT migration_id, direction "
+                "FROM _vijaybase_history ORDER BY id"
+            ).fetchall()
+        finally:
+            conn.close()
+
+        applied: list[str] = []
+        for mid, direction in rows:
+            if direction == "up":
+                applied.append(mid)
+            else:
+                try:
+                    applied.remove(mid)
+                except ValueError:
+                    pass
+        return applied
+
+    def get_current_head(self) -> str | None:
+        applied = self.get_applied_migrations()
+        return applied[-1] if applied else None
+
+    def record(self, migration_id: str, direction: str, checksum: str) -> None:
+        conn = self._connect()
+        try:
+            conn.execute(
+                "INSERT INTO _vijaybase_history (migration_id, direction, checksum) "
+                "VALUES (?, ?, ?)",
+                (migration_id, direction, checksum),
+            )
+            conn.commit()
+        finally:
+            conn.close()
+
+    # ---- internal -----------------------------------------------------------
+
+    def _ensure_table(self) -> None:
+        conn = self._connect()
+        try:
+            conn.execute(_CREATE_HISTORY)
+            conn.commit()
+        finally:
+            conn.close()
+
+    def _connect(self) -> sqlite3.Connection:
+        return sqlite3.connect(self.db_path)
diff --git a/src/vijaybase/introspect.py b/src/vijaybase/introspect.py
new file mode 100644
index 0000000..6c417f6
--- /dev/null
+++ b/src/vijaybase/introspect.py
@@ -0,0 +1,191 @@
+"""Read the live SQLite schema into our data-model objects."""
+from __future__ import annotations
+
+import os
+import re
+import sqlite3
+
+from .schema import Check, Column, ForeignKey, Index, Schema, Table
+
+_SKIP_TABLES = {"sqlite_sequence", "_vijaybase_history"}
+
+
+def introspect_db(db_path: str) -> Schema:
+    if not os.path.exists(db_path):
+        return Schema()
+    conn = sqlite3.connect(db_path)
+    conn.row_factory = sqlite3.Row
+    try:
+        return _introspect(conn)
+    finally:
+        conn.close()
+
+
+def _introspect(conn: sqlite3.Connection) -> Schema:
+    schema = Schema()
+    cursor = conn.execute(
+        "SELECT name, sql FROM sqlite_master "
+        "WHERE type='table' AND name NOT LIKE 'sqlite_%'"
+    )
+    rows = cursor.fetchall()
+    for row in rows:
+        tname = row["name"]
+        if tname in _SKIP_TABLES:
+            continue
+        create_sql = row["sql"] or ""
+        schema.tables[tname] = Table(
+            name=tname,
+            columns=_columns(conn, tname),
+            primary_key=_primary_key(conn, tname),
+            indexes=_indexes(conn, tname),
+            foreign_keys=_foreign_keys(conn, tname),
+            checks=_checks(create_sql),
+        )
+    return schema
+
+
+# ---- columns ---------------------------------------------------------------
+
+def _columns(conn: sqlite3.Connection, table: str) -> list[Column]:
+    cols: list[Column] = []
+    for row in conn.execute(f'PRAGMA table_info("{table}")').fetchall():
+        default = row["dflt_value"]
+        if default is not None:
+            if (
+                len(default) >= 2
+                and default[0] in ("'", '"')
+                and default[-1] == default[0]
+            ):
+                default = default[1:-1]
+        col_type = (row["type"] or "TEXT").upper()
+        cols.append(
+            Column(
+                name=row["name"],
+                type=col_type,
+                nullable=not row["notnull"],
+                default=default,
+                unique=_col_has_unique(conn, table, row["name"]),
+            )
+        )
+    return cols
+
+
+def _col_has_unique(conn: sqlite3.Connection, table: str, column: str) -> bool:
+    for idx in conn.execute(f'PRAGMA index_list("{table}")').fetchall():
+        if not idx["unique"] or idx["origin"] != "u":
+            continue
+        info = conn.execute(f'PRAGMA index_info("{idx["name"]}")').fetchall()
+        if len(info) == 1 and info[0]["name"] == column:
+            return True
+    return False
+
+
+# ---- primary key -----------------------------------------------------------
+
+def _primary_key(conn: sqlite3.Connection, table: str) -> tuple[str, ...]:
+    pk_parts: list[tuple[int, str]] = []
+    for row in conn.execute(f'PRAGMA table_info("{table}")').fetchall():
+        if row["pk"]:
+            pk_parts.append((row["pk"], row["name"]))
+    pk_parts.sort()
+    return tuple(n for _, n in pk_parts)
+
+
+# ---- indexes ---------------------------------------------------------------
+
+def _indexes(conn: sqlite3.Connection, table: str) -> list[Index]:
+    result: list[Index] = []
+    for row in conn.execute(f'PRAGMA index_list("{table}")').fetchall():
+        if row["origin"] != "c":  # only explicit CREATE INDEX
+            continue
+        info = conn.execute(f'PRAGMA index_info("{row["name"]}")').fetchall()
+        result.append(
+            Index(
+                name=row["name"],
+                columns=tuple(r["name"] for r in info),
+                unique=bool(row["unique"]),
+            )
+        )
+    return result
+
+
+# ---- foreign keys ----------------------------------------------------------
+
+def _foreign_keys(conn: sqlite3.Connection, table: str) -> list[ForeignKey]:
+    rows = conn.execute(f'PRAGMA foreign_key_list("{table}")').fetchall()
+    buckets: dict[int, dict] = {}
+    for row in rows:
+        fk_id = row["id"]
+        if fk_id not in buckets:
+            buckets[fk_id] = {
+                "cols": [],
+                "ref_table": row["table"],
+                "ref_cols": [],
+                "on_delete": (row["on_delete"] or "NO ACTION").upper(),
+            }
+        buckets[fk_id]["cols"].append((row["seq"], row["from"]))
+        buckets[fk_id]["ref_cols"].append((row["seq"], row["to"]))
+
+    fks: list[ForeignKey] = []
+    for b in buckets.values():
+        b["cols"].sort()
+        b["ref_cols"].sort()
+        fks.append(
+            ForeignKey(
+                columns=tuple(c for _, c in b["cols"]),
+                references_table=b["ref_table"],
+                references_columns=tuple(c for _, c in b["ref_cols"]),
+                on_delete=b["on_delete"],
+            )
+        )
+    return fks
+
+
+# ---- CHECK constraints (parsed from CREATE TABLE SQL) ----------------------
+
+def _checks(create_sql: str) -> list[Check]:
+    if not create_sql:
+        return []
+
+    results: list[Check] = []
+    seen_exprs: set[str] = set()
+
+    # Named: CONSTRAINT name CHECK (...)
+    for m in re.finditer(
+        r"CONSTRAINT\s+[\"']?(\w+)[\"']?\s+CHECK\s*\(",
+        create_sql,
+        re.IGNORECASE,
+    ):
+        name = m.group(1)
+        body, _ = _balanced(create_sql, m.end() - 1)
+        if body and body not in seen_exprs:
+            results.append(Check(name=name, expression=body))
+            seen_exprs.add(body)
+
+    # Unnamed CHECK (...)
+    for m in re.finditer(r"CHECK\s*\(", create_sql, re.IGNORECASE):
+        prefix = create_sql[: m.start()].rstrip()
+        if re.search(r"CONSTRAINT\s+[\"']?\w+[\"']?\s*$", prefix, re.IGNORECASE):
+            continue  # already captured above
+        body, _ = _balanced(create_sql, m.end() - 1)
+        if body and body not in seen_exprs:
+            results.append(Check(name=f"chk_{len(results)}", expression=body))
+            seen_exprs.add(body)
+
+    return results
+
+
+def _balanced(sql: str, start: int) -> tuple[str, int]:
+    """Return the content inside balanced parentheses starting at *start*."""
+    depth = 0
+    i = start
+    while i < len(sql):
+        ch = sql[i]
+        if ch == "(":
+            depth += 1
+        elif ch == ")":
+            depth -= 1
+            if depth == 0:
+                return sql[start + 1 : i].strip(), i
+        i += 1
+    return "", len(sql)
diff --git a/src/vijaybase/migration.py b/src/vijaybase/migration.py
new file mode 100644
index 0000000..3772754
--- /dev/null
+++ b/src/vijaybase/migration.py
@@ -0,0 +1,255 @@
+"""Read / write migration YAML files and execute SQL against the DB."""
+from __future__ import annotations
+
+import hashlib
+import sqlite3
+from dataclasses import dataclass
+from datetime import datetime, timezone
+from pathlib import Path
+
+import yaml
+
+from .errors import ChecksumError, MigrationError
+
+
+@dataclass
+class MigrationFile:
+    id: str
+    parent: str | None
+    merge_parent: str | None
+    description: str
+    created_at: str
+    checksum: str
+    up_sql: str
+    down_sql: str
+    file_path: Path | None = None
+
+
+def checksum_of(up_sql: str, down_sql: str) -> str:
+    blob = (up_sql + "\n---\n" + down_sql).encode()
+    return "sha256:" + hashlib.sha256(blob).hexdigest()
+
+
+# ---------------------------------------------------------------------------
+# File I/O
+# ---------------------------------------------------------------------------
+
+def load_migration(path: Path) -> MigrationFile:
+    with open(path) as f:
+        data = yaml.safe_load(f)
+    if not isinstance(data, dict):
+        raise MigrationError(f"Invalid migration file: {path}")
+    return MigrationFile(
+        id=data["id"],
+        parent=data.get("parent"),
+        merge_parent=data.get("merge_parent"),
+        description=data.get("description", ""),
+        created_at=data.get("created_at", ""),
+        checksum=data.get("checksum", ""),
+        up_sql=data.get("up", ""),
+        down_sql=data.get("down", ""),
+        file_path=path,
+    )
+
+
+def load_all_migrations(migrations_dir: str | Path) -> list[MigrationFile]:
+    mdir = Path(migrations_dir)
+    if not mdir.is_dir():
+        return []
+    files = sorted(mdir.glob("*.yaml")) + sorted(mdir.glob("*.yml"))
+    return [load_migration(f) for f in files]
+
+
+def create_migration_file(
+    migrations_dir: str | Path,
+    description: str,
+    parent: str | None,
+    up_sql: str,
+    down_sql: str,
+    merge_parent: str | None = None,
+) -> MigrationFile:
+    mdir = Path(migrations_dir)
+    mdir.mkdir(exist_ok=True)
+
+    ts = datetime.now(timezone.utc)
+    slug = _slugify(description)
+    mid = f"{ts:%Y%m%d_%H%M%S}_{slug}"
+    cs = checksum_of(up_sql, down_sql)
+
+    mf = MigrationFile(
+        id=mid,
+        parent=parent,
+        merge_parent=merge_parent,
+        description=description,
+        created_at=ts.isoformat(),
+        checksum=cs,
+        up_sql=up_sql,
+        down_sql=down_sql,
+    )
+
+    filename = f"{mid}.yaml"
+    path = mdir / filename
+    mf.file_path = path
+
+    data = {
+        "id": mf.id,
+        "parent": mf.parent,
+        "description": mf.description,
+        "created_at": mf.created_at,
+        "checksum": mf.checksum,
+        "up": mf.up_sql,
+        "down": mf.down_sql,
+    }
+    if merge_parent:
+        data["merge_parent"] = merge_parent
+
+    with open(path, "w") as f:
+        yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
+
+    return mf
+
+
+# ---------------------------------------------------------------------------
+# Helpers for building the migration chain
+# ---------------------------------------------------------------------------
+
+def build_migration_index(migrations: list[MigrationFile]) -> dict[str, MigrationFile]:
+    return {m.id: m for m in migrations}
+
+
+def get_pending_chain(
+    all_migrations: list[MigrationFile],
+    applied_ids: list[str],
+) -> list[MigrationFile]:
+    """Return the ordered list of not-yet-applied migrations reachable from
+    the current head, following parent -> child links."""
+    idx = build_migration_index(all_migrations)
+    applied_set = set(applied_ids)
+
+    # parent -> [children]
+    children_of: dict[str | None, list[MigrationFile]] = {}
+    for m in all_migrations:
+        children_of.setdefault(m.parent, []).append(m)
+
+    head: str | None = applied_ids[-1] if applied_ids else None
+    chain: list[MigrationFile] = []
+
+    while True:
+        kids = children_of.get(head, [])
+        unapplied = [k for k in kids if k.id not in applied_set]
+        if not unapplied:
+            break
+        if len(unapplied) > 1:
+            # Prefer a merge migration if one exists
+            merges = [k for k in unapplied if k.merge_parent]
+            if len(merges) == 1:
+                nxt = merges[0]
+            else:
+                from .errors import ConflictError
+                ids = ", ".join(k.id for k in unapplied)
+                raise ConflictError(
+                    f"Fork detected at '{head}': [{ids}]. "
+                    f"Run 'vijaybase merge' to resolve."
+                )
+        else:
+            nxt = unapplied[0]
+        chain.append(nxt)
+        head = nxt.id
+
+    return chain
+
+
+# ---------------------------------------------------------------------------
+# Execute a migration
+# ---------------------------------------------------------------------------
+
+def _split_sql(sql: str) -> list[str]:
+    """Split SQL into statements, respecting quoted strings and comments."""
+    stmts: list[str] = []
+    current: list[str] = []
+    in_string = False
+    i = 0
+    while i < len(sql):
+        ch = sql[i]
+        if in_string:
+            current.append(ch)
+            if ch == "'":
+                if i + 1 < len(sql) and sql[i + 1] == "'":
+                    current.append("'")
+                    i += 2
+                    continue
+                in_string = False
+        elif ch == "'":
+            in_string = True
+            current.append(ch)
+        elif ch == "-" and i + 1 < len(sql) and sql[i + 1] == "-":
+            while i < len(sql) and sql[i] != "\n":
+                i += 1
+            continue
+        elif ch == ";":
+            stmt = "".join(current).strip()
+            if stmt:
+                stmts.append(stmt)
+            current = []
+        else:
+            current.append(ch)
+        i += 1
+    tail = "".join(current).strip()
+    if tail:
+        stmts.append(tail)
+    return stmts
+
+
+def apply_migration_sql(db_path: str, sql: str) -> None:
+    """Execute migration SQL wrapped in a transaction.
+
+    PRAGMA foreign_keys cannot be toggled inside a transaction, so we set it
+    once before BEGIN and restore it after COMMIT/ROLLBACK.
+    """
+    stmts = _split_sql(sql)
+    regular_stmts = [s for s in stmts if not s.upper().startswith("PRAGMA")]
+    needs_fk_off = any(s.upper().startswith("PRAGMA") for s in stmts)
+
+    conn = sqlite3.connect(db_path, isolation_level=None)
+    try:
+        if needs_fk_off:
+            conn.execute("PRAGMA foreign_keys = OFF")
+
+        conn.execute("BEGIN TRANSACTION")
+        try:
+            for stmt in regular_stmts:
+                conn.execute(stmt)
+            conn.execute("COMMIT")
+        except Exception:
+            conn.execute("ROLLBACK")
+            raise
+        finally:
+            conn.execute("PRAGMA foreign_keys = ON")
+    finally:
+        conn.close()
+
+
+def verify_checksum(mf: MigrationFile) -> None:
+    expected = checksum_of(mf.up_sql, mf.down_sql)
+    if mf.checksum != expected:
+        raise ChecksumError(
+            f"Migration '{mf.id}' checksum mismatch "
+            f"(expected {expected}, got {mf.checksum}). "
+            f"The file may have been modified."
+        )
+
+
+# ---------------------------------------------------------------------------
+# Misc
+# ---------------------------------------------------------------------------
+
+def _slugify(text: str) -> str:
+    slug = text.lower().strip()
+    out: list[str] = []
+    for ch in slug:
+        if ch.isalnum():
+            out.append(ch)
+        elif ch in (" ", "-", "_"):
+            if out and out[-1] != "_":
+                out.append("_")
+    return "".join(out).strip("_")[:60]
diff --git a/src/vijaybase/schema.py b/src/vijaybase/schema.py
new file mode 100644
index 0000000..709345f
--- /dev/null
+++ b/src/vijaybase/schema.py
@@ -0,0 +1,154 @@
+"""Schema models and YAML parsing."""
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from pathlib import Path
+
+import yaml
+
+from .errors import SchemaError
+
+
+@dataclass(frozen=True)
+class Column:
+    name: str
+    type: str
+    nullable: bool = True
+    default: str | None = None
+    unique: bool = False
+
+
+@dataclass(frozen=True)
+class ForeignKey:
+    columns: tuple[str, ...]
+    references_table: str
+    references_columns: tuple[str, ...]
+    on_delete: str = "NO ACTION"
+
+
+@dataclass(frozen=True)
+class Index:
+    name: str
+    columns: tuple[str, ...]
+    unique: bool = False
+
+
+@dataclass(frozen=True)
+class Check:
+    name: str
+    expression: str
+
+
+@dataclass
+class Table:
+    name: str
+    columns: list[Column]
+    primary_key: tuple[str, ...]
+    indexes: list[Index] = field(default_factory=list)
+    foreign_keys: list[ForeignKey] = field(default_factory=list)
+    checks: list[Check] = field(default_factory=list)
+
+
+@dataclass
+class Schema:
+    tables: dict[str, Table] = field(default_factory=dict)
+
+
+# ---------------------------------------------------------------------------
+# YAML -> Schema
+# ---------------------------------------------------------------------------
+
+def _parse_column(name: str, defn) -> Column:
+    if not isinstance(defn, dict):
+        raise SchemaError(f"Column '{name}' definition must be a mapping")
+    col_type = defn.get("type")
+    if not col_type:
+        raise SchemaError(f"Column '{name}' must specify a 'type'")
+    raw_default = defn.get("default")
+    default = str(raw_default) if raw_default is not None else None
+    return Column(
+        name=name,
+        type=col_type.upper(),
+        nullable=defn.get("nullable", True),
+        default=default,
+        unique=defn.get("unique", False),
+    )
+
+
+def _parse_table(name: str, defn: dict) -> Table:
+    if not isinstance(defn, dict):
+        raise SchemaError(f"Table '{name}' definition must be a mapping")
+
+    raw_cols = defn.get("columns")
+    if not raw_cols:
+        raise SchemaError(f"Table '{name}' must have at least one column")
+    columns = [_parse_column(cn, cd) for cn, cd in raw_cols.items()]
+
+    pk = defn.get("primary_key", [])
+    if isinstance(pk, str):
+        pk = [pk]
+    primary_key = tuple(pk)
+
+    indexes: list[Index] = []
+    for idx_name, idx_def in (defn.get("indexes") or {}).items():
+        if not isinstance(idx_def, dict):
+            raise SchemaError(f"Index '{idx_name}' on '{name}' must be a mapping")
+        indexes.append(
+            Index(
+                name=idx_name,
+                columns=tuple(idx_def.get("columns", [])),
+                unique=idx_def.get("unique", False),
+            )
+        )
+
+    foreign_keys: list[ForeignKey] = []
+    for fk_def in defn.get("foreign_keys") or []:
+        foreign_keys.append(
+            ForeignKey(
+                columns=tuple(fk_def.get("columns", [])),
+                references_table=fk_def.get("references_table", ""),
+                references_columns=tuple(fk_def.get("references_columns", [])),
+                on_delete=fk_def.get("on_delete", "NO ACTION").upper(),
+            )
+        )
+
+    checks: list[Check] = []
+    for chk_def in defn.get("checks") or []:
+        checks.append(
+            Check(
+                name=chk_def.get("name", ""),
+                expression=chk_def.get("expression", ""),
+            )
+        )
+
+    return Table(
+        name=name,
+        columns=columns,
+        primary_key=primary_key,
+        indexes=indexes,
+        foreign_keys=foreign_keys,
+        checks=checks,
+    )
+
+
+def load_schema(schema_dir: str | Path) -> Schema:
+    """Load and merge all YAML files in *schema_dir* into a single Schema."""
+    schema_dir = Path(schema_dir)
+    if not schema_dir.is_dir():
+        raise SchemaError(f"Schema directory '{schema_dir}' does not exist")
+
+    yaml_files = sorted(schema_dir.glob("*.yaml")) + sorted(schema_dir.glob("*.yml"))
+    if not yaml_files:
+        raise SchemaError(f"No YAML files found in '{schema_dir}'")
+
+    schema = Schema()
+    for yf in yaml_files:
+        with open(yf) as f:
+            data = yaml.safe_load(f)
+        if not data or "tables" not in data:
+            continue
+        for tname, tdef in data["tables"].items():
+            if tname in schema.tables:
+                raise SchemaError(f"Table '{tname}' defined in multiple files")
+            schema.tables[tname] = _parse_table(tname, tdef)
+    return schema
