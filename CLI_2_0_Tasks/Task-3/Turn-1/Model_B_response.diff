+"""Turn diff operations into executable SQLite SQL."""
+from __future__ import annotations
+
+from collections import defaultdict
+
+from .diff import (
+    AddCheck,
+    AddColumn,
+    AddForeignKey,
+    AddIndex,
+    AlterColumn,
+    ChangePrimaryKey,
+    CreateTable,
+    DiffOp,
+    DropCheck,
+    DropColumn,
+    DropForeignKey,
+    DropIndex,
+    DropTable,
+)
+from .schema import Column, ForeignKey, Index, Schema, Table
+
+# Operations that require the "recreate table" pattern in SQLite.
+_NEEDS_RECREATE = (
+    AlterColumn,
+    ChangePrimaryKey,
+    AddForeignKey,
+    DropForeignKey,
+    AddCheck,
+    DropCheck,
+    DropColumn,
+)
+
+
+def generate_sql(
+    ops: list[DiffOp],
+    old_schema: Schema,
+    new_schema: Schema,
+) -> tuple[str, str]:
+    """Return ``(up_sql, down_sql)``."""
+    up: list[str] = []
+    down: list[str] = []
+
+    # whole-table creates / drops
+    creates = [o for o in ops if isinstance(o, CreateTable)]
+    drops = [o for o in ops if isinstance(o, DropTable)]
+
+    for op in creates:
+        up.append(_create_table_ddl(op.table))
+        for idx in op.table.indexes:
+            up.append(_create_index_ddl(op.table.name, idx))
+        down.insert(0, f"DROP TABLE IF EXISTS {op.table.name};")
+
+    for op in drops:
+        up.append(f"DROP TABLE IF EXISTS {op.table.name};")
+        down.insert(0, _create_table_ddl(op.table))
+        for idx in op.table.indexes:
+            down.insert(1, _create_index_ddl(op.table.name, idx))
+
+    # group remaining ops by table
+    by_table: dict[str, list[DiffOp]] = defaultdict(list)
+    for op in ops:
+        if isinstance(op, (CreateTable, DropTable)):
+            continue
+        by_table[getattr(op, "table_name")].append(op)
+
+    for tname, tops in sorted(by_table.items()):
+        needs_recreate = any(isinstance(o, _NEEDS_RECREATE) for o in tops)
+        if needs_recreate:
+            u, d = _recreate_table(
+                old_schema.tables[tname], new_schema.tables[tname]
+            )
+            up.append(u)
+            down.append(d)
+        else:
+            for op in tops:
+                if isinstance(op, AddColumn):
+                    up.append(_add_column_ddl(op.table_name, op.column))
+                    down.append(
+                        _drop_column_ddl(op.table_name, op.column.name)
+                    )
+                elif isinstance(op, AddIndex):
+                    up.append(_create_index_ddl(op.table_name, op.index))
+                    down.append(f"DROP INDEX IF EXISTS {op.index.name};")
+                elif isinstance(op, DropIndex):
+                    up.append(f"DROP INDEX IF EXISTS {op.index.name};")
+                    down.append(_create_index_ddl(op.table_name, op.index))
+
+    return "\n\n".join(up), "\n\n".join(down)
+
+
+# ---------------------------------------------------------------------------
+# DDL helpers
+# ---------------------------------------------------------------------------
+
+def _fmt_default(value: str) -> str:
+    upper = value.upper()
+    if upper in ("NULL", "CURRENT_TIMESTAMP", "CURRENT_DATE", "CURRENT_TIME", "TRUE", "FALSE"):
+        return value
+    try:
+        float(value)
+        return value
+    except ValueError:
+        return f"'{value}'"
+
+
+def _col_def(col: Column) -> str:
+    parts = [f"{col.name} {col.type}"]
+    if not col.nullable:
+        parts.append("NOT NULL")
+    if col.default is not None:
+        parts.append(f"DEFAULT {_fmt_default(col.default)}")
+    if col.unique:
+        parts.append("UNIQUE")
+    return " ".join(parts)
+
+
+def _create_table_ddl(table: Table) -> str:
+    lines: list[str] = []
+    for col in table.columns:
+        lines.append(f"    {_col_def(col)}")
+    if table.primary_key:
+        lines.append(f"    PRIMARY KEY ({', '.join(table.primary_key)})")
+    for fk in table.foreign_keys:
+        fk_sql = (
+            f"    FOREIGN KEY ({', '.join(fk.columns)}) "
+            f"REFERENCES {fk.references_table} "
+            f"({', '.join(fk.references_columns)})"
+        )
+        if fk.on_delete and fk.on_delete != "NO ACTION":
+            fk_sql += f" ON DELETE {fk.on_delete}"
+        lines.append(fk_sql)
+    for chk in table.checks:
+        lines.append(f"    CONSTRAINT {chk.name} CHECK ({chk.expression})")
+    return f"CREATE TABLE {table.name} (\n" + ",\n".join(lines) + "\n);"
+
+
+def _create_index_ddl(table_name: str, idx: Index) -> str:
+    unique = "UNIQUE " if idx.unique else ""
+    cols = ", ".join(idx.columns)
+    return f"CREATE {unique}INDEX {idx.name} ON {table_name} ({cols});"
+
+
+def _add_column_ddl(table: str, col: Column) -> str:
+    return f"ALTER TABLE {table} ADD COLUMN {_col_def(col)};"
+
+
+def _drop_column_ddl(table: str, col_name: str) -> str:
+    return f"ALTER TABLE {table} DROP COLUMN {col_name};"
+
+
+# ---------------------------------------------------------------------------
+# Table recreation (required for many ALTER operations in SQLite)
+# ---------------------------------------------------------------------------
+
+def _recreate_table(old: Table, new: Table) -> tuple[str, str]:
+    """Use the SQLite-recommended recreation pattern: create NEW temp table,
+    copy data from the original, drop original, rename temp to original.
+
+    This avoids the problem where ``ALTER TABLE x RENAME TO tmp`` causes
+    SQLite to rewrite FK references in *other* tables to point at ``tmp``.
+    """
+    old_names = [c.name for c in old.columns]
+    new_names = [c.name for c in new.columns]
+    common = [n for n in old_names if n in new_names]
+    cols_csv = ", ".join(common)
+    tmp = f"_vijaybase_new_{new.name}"
+
+    # UP: old schema -> new schema
+    up_lines = [
+        f"-- Recreate table {new.name}",
+        f"PRAGMA foreign_keys = OFF;",
+        _create_table_ddl(new).replace(
+            f"CREATE TABLE {new.name} (", f"CREATE TABLE {tmp} (", 1
+        ),
+    ]
+    if common:
+        up_lines.append(
+            f"INSERT INTO {tmp} ({cols_csv}) SELECT {cols_csv} FROM {new.name};"
+        )
+    up_lines.append(f"DROP TABLE {new.name};")
+    up_lines.append(f"ALTER TABLE {tmp} RENAME TO {new.name};")
+    for idx in new.indexes:
+        up_lines.append(_create_index_ddl(new.name, idx))
+    up_lines.append("PRAGMA foreign_keys = ON;")
+
+    # DOWN: new schema -> old schema
+    down_lines = [
+        f"-- Reverse-recreate table {old.name}",
+        f"PRAGMA foreign_keys = OFF;",
+        _create_table_ddl(old).replace(
+            f"CREATE TABLE {old.name} (", f"CREATE TABLE {tmp} (", 1
+        ),
+    ]
+    if common:
+        down_lines.append(
+            f"INSERT INTO {tmp} ({cols_csv}) SELECT {cols_csv} FROM {old.name};"
+        )
+    down_lines.append(f"DROP TABLE {old.name};")
+    down_lines.append(f"ALTER TABLE {tmp} RENAME TO {old.name};")
+    for idx in old.indexes:
+        down_lines.append(_create_index_ddl(old.name, idx))
+    down_lines.append("PRAGMA foreign_keys = ON;")
+
+    return "\n".join(up_lines), "\n".join(down_lines)
