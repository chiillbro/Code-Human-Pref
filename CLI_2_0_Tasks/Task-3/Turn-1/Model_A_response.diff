index 0000000..0ffb634
--- /dev/null
+++ b/src/vijaybase/commands/generate_cmd.py
@@ -0,0 +1,83 @@
+from __future__ import annotations
+
+import argparse
+
+from vijaybase.chain import find_heads
+from vijaybase.config import load_config
+from vijaybase.diff import compute_diff
+from vijaybase.errors import MigrationConflictError
+from vijaybase.introspector import introspect_database
+from vijaybase.migration_generator import generate_down_sql, generate_up_sql
+from vijaybase.migration_io import (
+    MigrationFile,
+    compute_checksum,
+    generate_migration_id,
+    list_migration_files,
+    write_migration,
+)
+from vijaybase.schema_parser import parse_schema_dir, validate_schema
+
+
+def run_generate(args: argparse.Namespace) -> int:
+    config = load_config()
+    description = args.description
+
+    # Parse and validate desired schema
+    desired = parse_schema_dir(config.schema_path)
+    if not desired.tables:
+        print("No schema files found. Add .yaml files to the schema/ directory.")
+        return 1
+    errors = validate_schema(desired)
+    if errors:
+        print("Schema validation failed:")
+        for err in errors:
+            print(f"  - {err}")
+        return 1
+
+    # Introspect current DB state
+    current = introspect_database(config.database_path)
+
+    # Compute diff
+    ops = compute_diff(current, desired)
+    if not ops:
+        print("No changes detected. Database schema matches YAML definition.")
+        return 0
+
+    # Generate SQL
+    up_sql = generate_up_sql(ops)
+    down_sql = generate_down_sql(ops, current)
+
+    # Determine parent
+    existing = list_migration_files(config.migrations_path)
+    if existing:
+        heads = find_heads(existing)
+        if len(heads) > 1:
+            raise MigrationConflictError(
+                "Cannot generate: migration fork detected. "
+                "Run 'vijaybase merge' first."
+            )
+        parent = heads[0] if heads else existing[-1].migration_id
+    else:
+        parent = None
+
+    # Create migration
+    migration_id = generate_migration_id()
+    checksum = compute_checksum(migration_id, parent, None, up_sql, down_sql)
+
+    migration = MigrationFile(
+        migration_id=migration_id,
+        description=description,
+        parent=parent,
+        parents=None,
+        up_sql=up_sql,
+        down_sql=down_sql,
+        checksum=checksum,
+    )
+
+    path = write_migration(config.migrations_path, migration)
+    print(f"Generated migration: {path.name}")
+    print(f"  ID:     {migration_id}")
+    print(f"  Parent: {parent or '(initial)'}")
+    print(f"  Up:     {len(up_sql)} statement(s)")
+    print(f"  Down:   {len(down_sql)} statement(s)")
+    return 0
