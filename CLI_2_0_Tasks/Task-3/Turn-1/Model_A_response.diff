@@ -0,0 +1,38 @@
+from vijaybase.models import ColumnDef, IndexDef, SchemaDef, TableDef
+
+
+def test_column_def_frozen():
+    col = ColumnDef(name="id", type="INTEGER")
+    assert hash(col)  # hashable
+
+
+def test_column_def_equality():
+    a = ColumnDef(name="id", type="INTEGER", nullable=False)
+    b = ColumnDef(name="id", type="INTEGER", nullable=False)
+    assert a == b
+
+
+def test_column_def_inequality():
+    a = ColumnDef(name="id", type="INTEGER")
+    b = ColumnDef(name="id", type="TEXT")
+    assert a != b
+
+
+def test_table_def_equality():
+    cols = (ColumnDef(name="id", type="INTEGER"),)
+    a = TableDef(name="t", columns=cols, primary_key=("id",))
+    b = TableDef(name="t", columns=cols, primary_key=("id",))
+    assert a == b
+
+
+def test_schema_def_equality():
+    cols = (ColumnDef(name="id", type="INTEGER"),)
+    t = TableDef(name="t", columns=cols, primary_key=("id",))
+    a = SchemaDef(tables={"t": t})
+    b = SchemaDef(tables={"t": t})
+    assert a == b
+
+
+def test_index_def_frozen():
+    idx = IndexDef(name="idx", table="t", columns=("a",))
+    assert hash(idx)
diff --git a/tests/test_schema_parser.py b/tests/test_schema_parser.py
new file mode 100644
index 0000000..c2f1ba8
--- /dev/null
+++ b/tests/test_schema_parser.py
@@ -0,0 +1,145 @@
+import pytest
+
+from vijaybase.errors import SchemaValidationError
+from vijaybase.schema_parser import parse_schema_file, parse_schema_dir, validate_schema
+
+
+def test_parse_basic_table(tmp_path, sample_schema_yaml):
+    schema_file = tmp_path / "users.yaml"
+    schema_file.write_text(sample_schema_yaml)
+    tables = parse_schema_file(schema_file)
+    assert "users" in tables
+    t = tables["users"]
+    assert t.name == "users"
+    assert len(t.columns) == 3
+    assert t.primary_key == ("id",)
+    assert t.columns[0].name == "id"
+    assert t.columns[0].type == "INTEGER"
+    assert t.columns[1].nullable is False
+    assert t.columns[2].unique is True
+    assert len(t.indexes) == 1
+    assert t.indexes[0].name == "idx_users_name"
+    assert len(t.checks) == 1
+    assert t.checks[0].name == "chk_name_len"
+
+
+def test_parse_foreign_key(tmp_path, sample_schema_with_fk_yaml):
+    schema_file = tmp_path / "all.yaml"
+    schema_file.write_text(sample_schema_with_fk_yaml)
+    tables = parse_schema_file(schema_file)
+    assert "posts" in tables
+    assert len(tables["posts"].foreign_keys) == 1
+    fk = tables["posts"].foreign_keys[0]
+    assert fk.columns == ("user_id",)
+    assert fk.ref_table == "users"
+    assert fk.ref_columns == ("id",)
+    assert fk.on_delete == "CASCADE"
+
+
+def test_parse_composite_pk(tmp_path):
+    yaml_text = """\
+tables:
+  post_tags:
+    columns:
+      post_id:
+        type: INTEGER
+        nullable: false
+      tag_id:
+        type: INTEGER
+        nullable: false
+    primary_key: [post_id, tag_id]
+"""
+    schema_file = tmp_path / "tags.yaml"
+    schema_file.write_text(yaml_text)
+    tables = parse_schema_file(schema_file)
+    assert tables["post_tags"].primary_key == ("post_id", "tag_id")
+
+
+def test_parse_schema_dir(tmp_path, sample_schema_yaml):
+    schema_dir = tmp_path / "schema"
+    schema_dir.mkdir()
+    (schema_dir / "users.yaml").write_text(sample_schema_yaml)
+    schema = parse_schema_dir(schema_dir)
+    assert "users" in schema.tables
+
+
+def test_duplicate_table_across_files(tmp_path):
+    schema_dir = tmp_path / "schema"
+    schema_dir.mkdir()
+    yaml_text = "tables:\n  users:\n    columns:\n      id:\n        type: INTEGER\n"
+    (schema_dir / "a.yaml").write_text(yaml_text)
+    (schema_dir / "b.yaml").write_text(yaml_text)
+    with pytest.raises(SchemaValidationError, match="Duplicate table"):
+        parse_schema_dir(schema_dir)
+
+
+def test_invalid_type(tmp_path):
+    yaml_text = "tables:\n  t:\n    columns:\n      id:\n        type: VARCHAR\n"
+    schema_file = tmp_path / "bad.yaml"
+    schema_file.write_text(yaml_text)
+    with pytest.raises(SchemaValidationError, match="invalid type"):
+        parse_schema_file(schema_file)
+
+
+def test_validate_fk_references_nonexistent_table(tmp_path):
+    yaml_text = """\
+tables:
+  posts:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      user_id:
+        type: INTEGER
+    foreign_keys:
+      - columns: [user_id]
+        references:
+          table: nonexistent
+          columns: [id]
+"""
+    schema_dir = tmp_path / "schema"
+    schema_dir.mkdir()
+    (schema_dir / "posts.yaml").write_text(yaml_text)
+    schema = parse_schema_dir(schema_dir)
+    errors = validate_schema(schema)
+    assert any("nonexistent" in e for e in errors)
+
+
+def test_validate_pk_nonexistent_column(tmp_path):
+    yaml_text = """\
+tables:
+  t:
+    columns:
+      id:
+        type: INTEGER
+    primary_key: [nonexistent]
+"""
+    schema_dir = tmp_path / "schema"
+    schema_dir.mkdir()
+    (schema_dir / "t.yaml").write_text(yaml_text)
+    schema = parse_schema_dir(schema_dir)
+    errors = validate_schema(schema)
+    assert any("nonexistent" in e for e in errors)
+
+
+def test_parse_column_default(tmp_path):
+    yaml_text = """\
+tables:
+  t:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      status:
+        type: INTEGER
+        default: "1"
+      name:
+        type: TEXT
+        default: "'anonymous'"
+"""
+    schema_file = tmp_path / "t.yaml"
+    schema_file.write_text(yaml_text)
+    tables = parse_schema_file(schema_file)
+    cols = {c.name: c for c in tables["t"].columns}
+    assert cols["status"].default == "1"
+    assert cols["name"].default == "'anonymous'"
