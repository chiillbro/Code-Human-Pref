diff --git a/src/vijaybase/chain.py b/src/vijaybase/chain.py
new file mode 100644
index 0000000..a100611
--- /dev/null
+++ b/src/vijaybase/chain.py
@@ -0,0 +1,214 @@
+from __future__ import annotations
+
+from vijaybase.errors import MigrationConflictError, MigrationNotFoundError
+from vijaybase.migration_io import MigrationFile
+
+
+def build_chain(migrations: list[MigrationFile]) -> dict[str, MigrationFile]:
+    chain: dict[str, MigrationFile] = {}
+    for m in migrations:
+        chain[m.migration_id] = m
+    # Validate parent references
+    for m in migrations:
+        for parent_id in m.all_parents:
+            if parent_id not in chain:
+                raise MigrationNotFoundError(
+                    f"Migration '{m.migration_id}' references parent "
+                    f"'{parent_id}' which does not exist"
+                )
+    return chain
+
+
+def find_heads(migrations: list[MigrationFile]) -> list[str]:
+    """Find migration IDs that are not referenced as parent by any other migration.
+
+    Multiple heads = fork detected.
+    """
+    if not migrations:
+        return []
+    all_ids = {m.migration_id for m in migrations}
+    referenced_as_parent: set[str] = set()
+    for m in migrations:
+        referenced_as_parent.update(m.all_parents)
+    heads = all_ids - referenced_as_parent
+    return sorted(heads)
+
+
+def detect_conflicts(migrations: list[MigrationFile]) -> list[tuple[str, str, str]]:
+    """Return list of (head_a, head_b, common_ancestor) for each fork."""
+    heads = find_heads(migrations)
+    if len(heads) <= 1:
+        return []
+
+    chain = build_chain(migrations)
+    conflicts = []
+
+    for i, head_a in enumerate(heads):
+        for head_b in heads[i + 1 :]:
+            ancestor = find_common_ancestor(chain, head_a, head_b)
+            conflicts.append((head_a, head_b, ancestor))
+
+    return conflicts
+
+
+def find_common_ancestor(
+    chain: dict[str, MigrationFile], head_a: str, head_b: str
+) -> str:
+    """Find the most recent common ancestor of two migration heads."""
+    # Build ancestor sets by walking back from each head
+    ancestors_a = _get_ancestors(chain, head_a)
+    ancestors_a.add(head_a)
+
+    # Walk back from head_b and find first match
+    current = head_b
+    visited = {current}
+    queue = [current]
+
+    while queue:
+        current = queue.pop(0)
+        if current in ancestors_a:
+            return current
+        m = chain.get(current)
+        if m:
+            for parent_id in m.all_parents:
+                if parent_id not in visited:
+                    visited.add(parent_id)
+                    queue.append(parent_id)
+
+    return ""  # No common ancestor (shouldn't happen in valid chains)
+
+
+def _get_ancestors(chain: dict[str, MigrationFile], migration_id: str) -> set[str]:
+    """Get all ancestors of a migration."""
+    ancestors: set[str] = set()
+    queue = []
+    m = chain.get(migration_id)
+    if m:
+        queue.extend(m.all_parents)
+    while queue:
+        current = queue.pop(0)
+        if current in ancestors:
+            continue
+        ancestors.add(current)
+        m = chain.get(current)
+        if m:
+            queue.extend(m.all_parents)
+    return ancestors
+
+
+def get_linear_order(
+    migrations: list[MigrationFile],
+) -> list[MigrationFile]:
+    """Topological sort of migration chain.
+
+    Raises MigrationConflictError if there are multiple heads (fork).
+    """
+    if not migrations:
+        return []
+
+    heads = find_heads(migrations)
+    if len(heads) > 1:
+        chain = build_chain(migrations)
+        conflicts = detect_conflicts(migrations)
+        msg_parts = ["Migration fork detected!"]
+        for head_a, head_b, ancestor in conflicts:
+            desc_a = chain[head_a].description
+            desc_b = chain[head_b].description
+            msg_parts.append(
+                f"  '{head_a}' ({desc_a}) and '{head_b}' ({desc_b}) "
+                f"both branch from '{ancestor}'"
+            )
+        msg_parts.append("\nRun 'vijaybase merge' to create a merge migration.")
+        raise MigrationConflictError("\n".join(msg_parts))
+
+    # Topological sort (Kahn's algorithm)
+    chain = build_chain(migrations)
+    in_degree: dict[str, int] = {m.migration_id: 0 for m in migrations}
+    for m in migrations:
+        for parent_id in m.all_parents:
+            if parent_id in in_degree:
+                in_degree[m.migration_id] += 1
+            # else: parent from outside this set, ignore
+
+    # We also need children map for the sort
+    queue = sorted(
+        [mid for mid, deg in in_degree.items() if deg == 0]
+    )
+    result: list[MigrationFile] = []
+
+    while queue:
+        mid = queue.pop(0)
+        result.append(chain[mid])
+        # Find migrations whose parent is mid
+        for m in migrations:
+            if mid in m.all_parents:
+                in_degree[m.migration_id] -= 1
+                if in_degree[m.migration_id] == 0:
+                    # Insert sorted
+                    insert_id = m.migration_id
+                    idx = 0
+                    while idx < len(queue) and queue[idx] < insert_id:
+                        idx += 1
+                    queue.insert(idx, insert_id)
+
+    return result
+
+
+def get_pending_migrations(
+    all_migrations: list[MigrationFile],
+    applied_ids: set[str],
+    target: str | None = None,
+) -> list[MigrationFile]:
+    """Return migrations not yet applied, in correct order.
+
+    Raises MigrationConflictError if pending migrations form a fork.
+    """
+    ordered = get_linear_order(all_migrations)
+    pending = []
+    for m in ordered:
+        if m.migration_id in applied_ids:
+            continue
+        pending.append(m)
+        if target and m.migration_id == target:
+            break
+    return pending
+
+
+def get_applied_in_order(
+    all_migrations: list[MigrationFile],
+    applied_ids: set[str],
+) -> list[MigrationFile]:
+    """Return applied migrations in chain order (for rollback)."""
+    ordered = get_linear_order(all_migrations)
+    return [m for m in ordered if m.migration_id in applied_ids]
+
+
+def validate_chain_integrity(
+    migrations: list[MigrationFile],
+) -> list[str]:
+    """Validate the migration chain. Return list of error messages."""
+    errors = []
+    chain = {m.migration_id: m for m in migrations}
+
+    for m in migrations:
+        for parent_id in m.all_parents:
+            if parent_id not in chain:
+                errors.append(
+                    f"Migration '{m.migration_id}' references missing "
+                    f"parent '{parent_id}'"
+                )
+
+    # Check for checksum consistency
+    from vijaybase.migration_io import compute_checksum
+
+    for m in migrations:
+        expected = compute_checksum(
+            m.migration_id, m.parent, m.parents, m.up_sql, m.down_sql
+        )
+        if m.checksum and m.checksum != expected:
+            errors.append(
+                f"Migration '{m.migration_id}' has invalid checksum "
+                f"(expected {expected[:12]}..., got {m.checksum[:12]}...)"
+            )
+
+    return errors
diff --git a/src/vijaybase/cli.py b/src/vijaybase/cli.py
new file mode 100644
index 0000000..8c96ec0
