@@ -0,0 +1,95 @@
+from vijaybase.introspector import introspect_connection
+
+
+def test_introspect_empty_db(memory_db):
+    schema = introspect_connection(memory_db)
+    assert schema.tables == {}
+
+
+def test_introspect_basic_table(memory_db):
+    memory_db.execute(
+        "CREATE TABLE users ("
+        "  id INTEGER PRIMARY KEY,"
+        "  name TEXT NOT NULL,"
+        "  email TEXT UNIQUE"
+        ")"
+    )
+    schema = introspect_connection(memory_db)
+    assert "users" in schema.tables
+    t = schema.tables["users"]
+    assert t.primary_key == ("id",)
+    cols = {c.name: c for c in t.columns}
+    assert cols["name"].nullable is False
+    assert cols["email"].unique is True
+
+
+def test_introspect_composite_pk(memory_db):
+    memory_db.execute(
+        "CREATE TABLE t (a INTEGER NOT NULL, b INTEGER NOT NULL, PRIMARY KEY (a, b))"
+    )
+    schema = introspect_connection(memory_db)
+    assert schema.tables["t"].primary_key == ("a", "b")
+
+
+def test_introspect_indexes(memory_db):
+    memory_db.execute("CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)")
+    memory_db.execute("CREATE INDEX idx_t_name ON t(name)")
+    memory_db.execute("CREATE UNIQUE INDEX idx_t_name_uniq ON t(name)")
+    schema = introspect_connection(memory_db)
+    idx_names = {i.name for i in schema.tables["t"].indexes}
+    assert "idx_t_name" in idx_names
+    assert "idx_t_name_uniq" in idx_names
+
+
+def test_introspect_foreign_keys(memory_db):
+    memory_db.execute("CREATE TABLE users (id INTEGER PRIMARY KEY)")
+    memory_db.execute(
+        "CREATE TABLE posts ("
+        "  id INTEGER PRIMARY KEY,"
+        "  user_id INTEGER,"
+        "  FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE"
+        ")"
+    )
+    schema = introspect_connection(memory_db)
+    fks = schema.tables["posts"].foreign_keys
+    assert len(fks) == 1
+    assert fks[0].ref_table == "users"
+    assert fks[0].on_delete == "CASCADE"
+
+
+def test_introspect_check_constraints(memory_db):
+    memory_db.execute(
+        "CREATE TABLE t ("
+        "  id INTEGER PRIMARY KEY,"
+        "  age INTEGER,"
+        "  CHECK(age > 0)"
+        ")"
+    )
+    schema = introspect_connection(memory_db)
+    checks = schema.tables["t"].checks
+    assert len(checks) == 1
+    assert "age > 0" in checks[0].expression
+
+
+def test_introspect_skips_history_table(memory_db):
+    memory_db.execute(
+        "CREATE TABLE _vijaybase_history (id INTEGER PRIMARY KEY)"
+    )
+    memory_db.execute("CREATE TABLE users (id INTEGER PRIMARY KEY)")
+    schema = introspect_connection(memory_db)
+    assert "_vijaybase_history" not in schema.tables
+    assert "users" in schema.tables
+
+
+def test_introspect_column_defaults(memory_db):
+    memory_db.execute(
+        "CREATE TABLE t ("
+        "  id INTEGER PRIMARY KEY,"
+        "  status INTEGER DEFAULT 1,"
+        "  name TEXT DEFAULT 'anon'"
+        ")"
+    )
+    schema = introspect_connection(memory_db)
+    cols = {c.name: c for c in schema.tables["t"].columns}
+    assert cols["status"].default == "1"
+    assert cols["name"].default == "'anon'"
diff --git a/tests/test_migration_generator.py b/tests/test_migration_generator.py
new file mode 100644
index 0000000..3900898
--- /dev/null
+++ b/tests/test_migration_generator.py
@@ -0,0 +1,153 @@
+from vijaybase.diff import AddColumn, AddIndex, CreateTable, DropTable, ReconstructTable
+from vijaybase.migration_generator import generate_down_sql, generate_up_sql
+from vijaybase.models import (
+    CheckConstraintDef,
+    ColumnDef,
+    ForeignKeyDef,
+    IndexDef,
+    SchemaDef,
+    TableDef,
+)
+
+
+def _make_table(name="t", cols=None, pk=("id",), indexes=(), fks=(), checks=()):
+    if cols is None:
+        cols = (ColumnDef(name="id", type="INTEGER"),)
+    return TableDef(
+        name=name, columns=cols, primary_key=pk,
+        indexes=indexes, foreign_keys=fks, checks=checks,
+    )
+
+
+def test_create_table_sql():
+    t = _make_table(
+        "users",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="name", type="TEXT", nullable=False),
+        ),
+    )
+    ops = [CreateTable(t)]
+    stmts = generate_up_sql(ops)
+    assert len(stmts) == 1
+    assert "CREATE TABLE [users]" in stmts[0]
+    assert "NOT NULL" in stmts[0]
+
+
+def test_create_table_with_fk():
+    fk = ForeignKeyDef(
+        columns=("user_id",), ref_table="users", ref_columns=("id",),
+        on_delete="CASCADE",
+    )
+    t = _make_table(
+        "posts",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="user_id", type="INTEGER"),
+        ),
+        fks=(fk,),
+    )
+    ops = [CreateTable(t)]
+    stmts = generate_up_sql(ops)
+    sql = stmts[0]
+    assert "FOREIGN KEY" in sql
+    assert "ON DELETE CASCADE" in sql
+
+
+def test_create_table_with_check():
+    chk = CheckConstraintDef(name="chk_pos", expression="id > 0")
+    t = _make_table("t", checks=(chk,))
+    ops = [CreateTable(t)]
+    stmts = generate_up_sql(ops)
+    assert "CHECK(id > 0)" in stmts[0]
+
+
+def test_create_table_with_indexes():
+    idx = IndexDef(name="idx_name", table="t", columns=("name",), unique=True)
+    t = _make_table(
+        "t",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="name", type="TEXT"),
+        ),
+        indexes=(idx,),
+    )
+    ops = [CreateTable(t)]
+    stmts = generate_up_sql(ops)
+    assert len(stmts) == 2  # CREATE TABLE + CREATE INDEX
+    assert "UNIQUE INDEX" in stmts[1]
+
+
+def test_drop_table_sql():
+    t = _make_table("t")
+    ops = [DropTable(t)]
+    stmts = generate_up_sql(ops)
+    assert any("DROP TABLE" in s for s in stmts)
+
+
+def test_add_column_sql():
+    col = ColumnDef(name="bio", type="TEXT", nullable=True, default="''")
+    ops = [AddColumn("users", col)]
+    stmts = generate_up_sql(ops)
+    assert len(stmts) == 1
+    assert "ALTER TABLE [users] ADD COLUMN [bio]" in stmts[0]
+    assert "DEFAULT ''" in stmts[0]
+
+
+def test_reconstruct_table_sql():
+    old = _make_table(
+        "t",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="name", type="TEXT"),
+        ),
+    )
+    new = _make_table(
+        "t",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="name", type="TEXT", nullable=False),
+        ),
+    )
+    ops = [ReconstructTable("t", old, new)]
+    stmts = generate_up_sql(ops)
+    assert any("PRAGMA foreign_keys=OFF" in s for s in stmts)
+    assert any("RENAME TO" in s for s in stmts)
+    assert any("INSERT INTO" in s for s in stmts)
+    assert any("DROP TABLE [__t_old]" in s for s in stmts)
+    assert any("PRAGMA foreign_keys=ON" in s for s in stmts)
+
+
+def test_down_sql_is_inverse():
+    t = _make_table("t")
+    ops = [CreateTable(t)]
+    current = SchemaDef(tables={})
+    down = generate_down_sql(ops, current)
+    assert any("DROP TABLE" in s for s in down)
+
+
+def test_composite_pk_sql():
+    t = _make_table(
+        "t",
+        cols=(
+            ColumnDef(name="a", type="INTEGER"),
+            ColumnDef(name="b", type="INTEGER"),
+        ),
+        pk=("a", "b"),
+    )
+    ops = [CreateTable(t)]
+    stmts = generate_up_sql(ops)
+    assert "PRIMARY KEY ([a], [b])" in stmts[0]
+
+
+def test_column_unique_sql():
+    t = _make_table(
+        "t",
+        cols=(
+            ColumnDef(name="id", type="INTEGER"),
+            ColumnDef(name="email", type="TEXT", unique=True),
+        ),
+    )
+    ops = [CreateTable(t)]
+    stmts = generate_up_sql(ops)
+    assert "UNIQUE" in stmts[0]
diff --git a/tests/test_migration_io.py b/tests/test_migration_io.py
new file mode 100644
index 0000000..2329a66
--- /dev/null
+++ b/tests/test_migration_io.py
@@ -0,0 +1,78 @@
+from vijaybase.migration_io import (
+    MigrationFile,
+    compute_checksum,
+    read_migration,
+    write_migration,
+)
+
+
+def test_write_and_read_roundtrip(tmp_path):
+    m = MigrationFile(
+        migration_id="20260417150000",
+        description="create_users",
+        parent=None,
+        parents=None,
+        up_sql=["CREATE TABLE users (id INTEGER PRIMARY KEY)"],
+        down_sql=["DROP TABLE users"],
+    )
+    m.checksum = compute_checksum(
+        m.migration_id, m.parent, m.parents, m.up_sql, m.down_sql
+    )
+    path = write_migration(tmp_path, m)
+    assert path.exists()
+    assert "20260417150000" in path.name
+    assert "create_users" in path.name
+
+    loaded = read_migration(path)
+    assert loaded.migration_id == m.migration_id
+    assert loaded.description == m.description
+    assert loaded.parent is None
+    assert loaded.up_sql == m.up_sql
+    assert loaded.down_sql == m.down_sql
+    assert loaded.checksum == m.checksum
+
+
+def test_checksum_deterministic():
+    a = compute_checksum("123", "parent", None, ["UP"], ["DOWN"])
+    b = compute_checksum("123", "parent", None, ["UP"], ["DOWN"])
+    assert a == b
+
+
+def test_checksum_changes_on_content_change():
+    a = compute_checksum("123", None, None, ["UP1"], ["DOWN"])
+    b = compute_checksum("123", None, None, ["UP2"], ["DOWN"])
+    assert a != b
+
+
+def test_merge_migration_roundtrip(tmp_path):
+    m = MigrationFile(
+        migration_id="20260418120000",
+        description="merge",
+        parent=None,
+        parents=["20260417160000", "20260417161500"],
+        up_sql=["-- merge"],
+        down_sql=["-- rollback merge"],
+    )
+    m.checksum = compute_checksum(
+        m.migration_id, m.parent, m.parents, m.up_sql, m.down_sql
+    )
+    path = write_migration(tmp_path, m)
+    loaded = read_migration(path)
+    assert loaded.is_merge is True
+    assert loaded.parents == ["20260417160000", "20260417161500"]
+    assert loaded.parent is None
+
+
+def test_migration_file_all_parents():
+    m = MigrationFile(
+        migration_id="1", description="t", parent="0",
+    )
+    assert m.all_parents == ["0"]
+
+    m2 = MigrationFile(
+        migration_id="2", description="t", parents=["0", "1"],
+    )
+    assert m2.all_parents == ["0", "1"]
+
+    m3 = MigrationFile(migration_id="3", description="t")
+    assert m3.all_parents == []
