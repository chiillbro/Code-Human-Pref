@@ -0,0 +1,86 @@
+from __future__ import annotations
+
+import argparse
+import sqlite3
+
+from vijaybase.chain import (
+    detect_conflicts,
+    find_heads,
+    get_applied_in_order,
+    get_linear_order,
+    validate_chain_integrity,
+)
+from vijaybase.config import load_config
+from vijaybase.errors import MigrationConflictError
+from vijaybase.history import (
+    ensure_history_table,
+    get_applied_migrations,
+    get_current_head,
+)
+from vijaybase.migration_io import list_migration_files
+
+
+def run_status(args: argparse.Namespace) -> int:
+    config = load_config()
+
+    all_migrations = list_migration_files(config.migrations_path)
+    if not all_migrations:
+        print("No migration files found.")
+        return 0
+
+    # Check chain integrity
+    integrity_errors = validate_chain_integrity(all_migrations)
+    if integrity_errors:
+        print("Chain integrity issues:")
+        for err in integrity_errors:
+            print(f"  ! {err}")
+        print()
+
+    # Check for conflicts
+    conflicts = detect_conflicts(all_migrations)
+    if conflicts:
+        print("CONFLICT: Migration fork detected!")
+        for head_a, head_b, ancestor in conflicts:
+            print(f"  '{head_a}' and '{head_b}' both branch from '{ancestor}'")
+        print("  Run 'vijaybase merge' to resolve.\n")
+
+    # DB state
+    if not config.database_path.exists():
+        print(f"Database: {config.database} (not yet created)")
+        print(f"Total migrations: {len(all_migrations)}")
+        print(f"Pending: {len(all_migrations)}")
+        return 0
+
+    conn = sqlite3.connect(str(config.database_path))
+    try:
+        conn.execute("PRAGMA foreign_keys = ON")
+        ensure_history_table(conn)
+        applied_ids = get_applied_migrations(conn)
+        current = get_current_head(conn)
+
+        print(f"Database: {config.database}")
+        print(f"Current head: {current or '(none)'}")
+        print(f"Total migrations: {len(all_migrations)}")
+        print(f"Applied: {len(applied_ids)}")
+        print(f"Pending: {len(all_migrations) - len(applied_ids)}")
+
+        if all_migrations:
+            print("\nMigration chain:")
+            heads = find_heads(all_migrations)
+            for m in all_migrations:
+                status = "applied" if m.migration_id in applied_ids else "pending"
+                marker = "*" if m.migration_id == current else " "
+                head_marker = " [HEAD]" if m.migration_id in heads else ""
+                parent_info = ""
+                if m.parents:
+                    parent_info = f" (merge of {', '.join(m.parents)})"
+                elif m.parent:
+                    parent_info = f" (parent: {m.parent})"
+                print(
+                    f"  {marker} [{status:7s}] {m.migration_id}: "
+                    f"{m.description}{parent_info}{head_marker}"
+                )
+
+        return 0
+    finally:
+        conn.close()
