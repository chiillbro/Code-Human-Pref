+++ b/src/vijaybase/cli.py
@@ -0,0 +1,99 @@
+from __future__ import annotations
+
+import argparse
+import sys
+
+from vijaybase import __version__
+from vijaybase.commands import (
+    apply_cmd,
+    generate_cmd,
+    init_cmd,
+    merge_cmd,
+    rollback_cmd,
+    status_cmd,
+    validate_cmd,
+)
+from vijaybase.errors import VijaybaseError
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="vijaybase",
+        description="SQLite schema migration and versioning tool",
+    )
+    parser.add_argument(
+        "--version", action="version", version=f"%(prog)s {__version__}"
+    )
+
+    subparsers = parser.add_subparsers(dest="command")
+
+    # init
+    p_init = subparsers.add_parser("init", help="Initialize a vijaybase project")
+    p_init.add_argument(
+        "--database",
+        default="mydb.sqlite",
+        help="SQLite database filename (default: mydb.sqlite)",
+    )
+    p_init.set_defaults(func=init_cmd.run_init)
+
+    # generate
+    p_gen = subparsers.add_parser(
+        "generate", help="Generate migration from schema diff"
+    )
+    p_gen.add_argument("description", help="Short description (used in filename)")
+    p_gen.set_defaults(func=generate_cmd.run_generate)
+
+    # apply
+    p_apply = subparsers.add_parser("apply", help="Apply pending migrations")
+    p_apply.add_argument(
+        "--dry-run", action="store_true", help="Print SQL without executing"
+    )
+    p_apply.add_argument("--target", help="Apply up to this migration ID")
+    p_apply.set_defaults(func=apply_cmd.run_apply)
+
+    # rollback
+    p_rb = subparsers.add_parser("rollback", help="Rollback migrations")
+    p_rb.add_argument(
+        "--dry-run", action="store_true", help="Print SQL without executing"
+    )
+    p_rb.add_argument(
+        "--steps",
+        type=int,
+        default=1,
+        help="Number of migrations to rollback (default: 1)",
+    )
+    p_rb.set_defaults(func=rollback_cmd.run_rollback)
+
+    # status
+    p_status = subparsers.add_parser("status", help="Show migration status")
+    p_status.set_defaults(func=status_cmd.run_status)
+
+    # validate
+    p_val = subparsers.add_parser("validate", help="Validate YAML schema files")
+    p_val.set_defaults(func=validate_cmd.run_validate)
+
+    # merge
+    p_merge = subparsers.add_parser(
+        "merge", help="Create merge migration for forks"
+    )
+    p_merge.set_defaults(func=merge_cmd.run_merge)
+
+    return parser
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = build_parser()
+    args = parser.parse_args(argv)
+
+    if not hasattr(args, "func"):
+        parser.print_help()
+        return 1
+
+    try:
+        return args.func(args)
+    except VijaybaseError as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return 1
+    except KeyboardInterrupt:
+        print("\nAborted.", file=sys.stderr)
+        return 130
