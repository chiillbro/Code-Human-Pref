index 0000000..ad165f4
--- /dev/null
+++ b/tests/test_executor.py
@@ -0,0 +1,91 @@
+import sqlite3
+
+import pytest
+
+from vijaybase.errors import DatabaseError
+from vijaybase.executor import apply_migration, rollback_migration
+from vijaybase.history import ensure_history_table, get_applied_migrations
+from vijaybase.migration_io import MigrationFile, compute_checksum
+
+
+def _make_migration(mid="001", parent=None, up=None, down=None):
+    up = up or ["CREATE TABLE t (id INTEGER PRIMARY KEY)"]
+    down = down or ["DROP TABLE t"]
+    chk = compute_checksum(mid, parent, None, up, down)
+    return MigrationFile(
+        migration_id=mid, description="test",
+        parent=parent, up_sql=up, down_sql=down, checksum=chk,
+    )
+
+
+def test_apply_migration(memory_db):
+    ensure_history_table(memory_db)
+    m = _make_migration()
+    stmts = apply_migration(memory_db, m)
+    assert len(stmts) > 0
+    # Table should exist
+    rows = memory_db.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' AND name='t'"
+    ).fetchall()
+    assert len(rows) == 1
+    # History should record it
+    applied = get_applied_migrations(memory_db)
+    assert "001" in applied
+
+
+def test_apply_dry_run(memory_db):
+    ensure_history_table(memory_db)
+    m = _make_migration()
+    stmts = apply_migration(memory_db, m, dry_run=True)
+    assert len(stmts) > 0
+    # Table should NOT exist
+    rows = memory_db.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' AND name='t'"
+    ).fetchall()
+    assert len(rows) == 0
+
+
+def test_rollback_migration(memory_db):
+    ensure_history_table(memory_db)
+    m = _make_migration()
+    apply_migration(memory_db, m)
+    rollback_migration(memory_db, m)
+    # Table should be gone
+    rows = memory_db.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' AND name='t'"
+    ).fetchall()
+    assert len(rows) == 0
+    applied = get_applied_migrations(memory_db)
+    assert "001" not in applied
+
+
+def test_apply_bad_sql_rolls_back(memory_db):
+    ensure_history_table(memory_db)
+    m = _make_migration(up=["INVALID SQL HERE"], down=["SELECT 1"])
+    m.checksum = compute_checksum(m.migration_id, m.parent, m.parents, m.up_sql, m.down_sql)
+    with pytest.raises(DatabaseError, match="Failed executing"):
+        apply_migration(memory_db, m)
+    # Nothing should be applied
+    applied = get_applied_migrations(memory_db)
+    assert "001" not in applied
+
+
+def test_apply_multiple_in_sequence(memory_db):
+    ensure_history_table(memory_db)
+    m1 = _make_migration("001", up=["CREATE TABLE a (id INTEGER PRIMARY KEY)"], down=["DROP TABLE a"])
+    m1.checksum = compute_checksum(m1.migration_id, m1.parent, m1.parents, m1.up_sql, m1.down_sql)
+    m2 = _make_migration("002", parent="001", up=["CREATE TABLE b (id INTEGER PRIMARY KEY)"], down=["DROP TABLE b"])
+    m2.checksum = compute_checksum(m2.migration_id, m2.parent, m2.parents, m2.up_sql, m2.down_sql)
+
+    apply_migration(memory_db, m1)
+    apply_migration(memory_db, m2)
+
+    applied = get_applied_migrations(memory_db)
+    assert applied == {"001", "002"}
+
+    # Both tables exist
+    tables = {r[0] for r in memory_db.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()} - {"_vijaybase_history"}
+    assert "a" in tables
+    assert "b" in tables
