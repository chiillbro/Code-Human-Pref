@@ -0,0 +1,59 @@
+from __future__ import annotations
+
+import argparse
+import sqlite3
+
+from vijaybase.chain import get_applied_in_order
+from vijaybase.config import load_config
+from vijaybase.executor import rollback_migration
+from vijaybase.history import ensure_history_table, get_applied_migrations
+from vijaybase.migration_io import list_migration_files
+
+
+def run_rollback(args: argparse.Namespace) -> int:
+    config = load_config()
+    dry_run = args.dry_run
+    steps = args.steps
+
+    all_migrations = list_migration_files(config.migrations_path)
+    if not all_migrations:
+        print("No migration files found.")
+        return 0
+
+    conn = sqlite3.connect(str(config.database_path))
+    try:
+        conn.execute("PRAGMA foreign_keys = ON")
+        ensure_history_table(conn)
+
+        applied_ids = get_applied_migrations(conn)
+        applied_ordered = get_applied_in_order(all_migrations, applied_ids)
+
+        if not applied_ordered:
+            print("No migrations to rollback.")
+            return 0
+
+        # Take the last N applied migrations (in reverse order for rollback)
+        to_rollback = list(reversed(applied_ordered[-steps:]))
+
+        mode = " (dry-run)" if dry_run else ""
+        print(f"Rolling back {len(to_rollback)} migration(s){mode}:\n")
+
+        for migration in to_rollback:
+            print(f"  <- {migration.migration_id}: {migration.description}")
+            stmts = rollback_migration(conn, migration, dry_run=dry_run)
+
+            if dry_run:
+                for stmt in stmts:
+                    stmt = stmt.strip()
+                    if stmt and not stmt.startswith("--"):
+                        print(f"     {stmt};")
+                print()
+
+        if dry_run:
+            print("Dry-run complete. No changes were made to the database.")
+        else:
+            print(f"\nSuccessfully rolled back {len(to_rollback)} migration(s).")
+
+        return 0
+    finally:
+        conn.close()
