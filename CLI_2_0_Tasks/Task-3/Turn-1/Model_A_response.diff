+import os
+
+from vijaybase.cli import main
+
+
+def test_init(tmp_path, monkeypatch):
+    monkeypatch.chdir(tmp_path)
+    rc = main(["init", "--database", "test.sqlite"])
+    assert rc == 0
+    assert (tmp_path / "vijaybase.yaml").exists()
+    assert (tmp_path / "schema").is_dir()
+    assert (tmp_path / "migrations").is_dir()
+
+
+def test_init_already_initialized(tmp_path, monkeypatch):
+    monkeypatch.chdir(tmp_path)
+    main(["init"])
+    rc = main(["init"])
+    assert rc == 1  # Already initialized
+
+
+def test_validate_no_schema(tmp_path, monkeypatch):
+    monkeypatch.chdir(tmp_path)
+    main(["init"])
+    rc = main(["validate"])
+    assert rc == 1  # No schema files
+
+
+def test_validate_valid_schema(tmp_path, monkeypatch, sample_schema_yaml):
+    monkeypatch.chdir(tmp_path)
+    main(["init"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+    rc = main(["validate"])
+    assert rc == 0
+
+
+def test_generate_and_apply(tmp_path, monkeypatch, sample_schema_yaml):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+
+    # Generate
+    rc = main(["generate", "create_users"])
+    assert rc == 0
+    migration_files = list((tmp_path / "migrations").glob("*.yaml"))
+    assert len(migration_files) == 1
+
+    # Apply
+    rc = main(["apply"])
+    assert rc == 0
+
+    # Verify DB has the table
+    import sqlite3
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert "users" in tables
+    conn.close()
+
+
+def test_apply_dry_run(tmp_path, monkeypatch, sample_schema_yaml, capsys):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+    main(["generate", "create_users"])
+
+    rc = main(["apply", "--dry-run"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "dry-run" in output.lower() or "Dry-run" in output
+
+    # DB should NOT have the table (file might not even exist)
+    import sqlite3
+    db_path = tmp_path / "test.sqlite"
+    if db_path.exists():
+        conn = sqlite3.connect(str(db_path))
+        tables = {r[0] for r in conn.execute(
+            "SELECT name FROM sqlite_master WHERE type='table'"
+        ).fetchall()}
+        assert "users" not in tables
+        conn.close()
+
+
+def test_status(tmp_path, monkeypatch, sample_schema_yaml, capsys):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+    main(["generate", "create_users"])
+    main(["apply"])
+
+    rc = main(["status"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "applied" in output.lower()
+
+
+def test_rollback(tmp_path, monkeypatch, sample_schema_yaml):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+    main(["generate", "create_users"])
+    main(["apply"])
+
+    rc = main(["rollback"])
+    assert rc == 0
+
+    import sqlite3
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert "users" not in tables
+    conn.close()
+
+
+def test_no_changes_generate(tmp_path, monkeypatch, sample_schema_yaml, capsys):
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(sample_schema_yaml)
+    main(["generate", "create_users"])
+    main(["apply"])
+
+    # No changes -> generate should detect nothing
+    rc = main(["generate", "no_changes"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "no changes" in output.lower() or "No changes" in output
diff --git a/tests/test_diff.py b/tests/test_diff.py
new file mode 100644
index 0000000..c63b687
--- /dev/null
+++ b/tests/test_diff.py
@@ -0,0 +1,174 @@
+from vijaybase.diff import (
+    AddColumn,
+    AddIndex,
+    CreateTable,
+    DropIndex,
+    DropTable,
+    ReconstructTable,
+    compute_diff,
+)
+from vijaybase.models import (
+    CheckConstraintDef,
+    ColumnDef,
+    ForeignKeyDef,
+    IndexDef,
+    SchemaDef,
+    TableDef,
+)
+
+
+def _simple_table(name, cols=None, pk=("id",), indexes=(), fks=(), checks=()):
+    if cols is None:
+        cols = (ColumnDef(name="id", type="INTEGER"),)
+    return TableDef(
+        name=name,
+        columns=cols,
+        primary_key=pk,
+        indexes=indexes,
+        foreign_keys=fks,
+        checks=checks,
+    )
+
+
+def test_no_changes():
+    t = _simple_table("t")
+    current = SchemaDef(tables={"t": t})
+    desired = SchemaDef(tables={"t": t})
+    ops = compute_diff(current, desired)
+    assert ops == []
+
+
+def test_create_new_table():
+    current = SchemaDef(tables={})
+    t = _simple_table("t")
+    desired = SchemaDef(tables={"t": t})
+    ops = compute_diff(current, desired)
+    assert len(ops) == 1
+    assert isinstance(ops[0], CreateTable)
+    assert ops[0].table.name == "t"
+
+
+def test_drop_table():
+    t = _simple_table("t")
+    current = SchemaDef(tables={"t": t})
+    desired = SchemaDef(tables={})
+    ops = compute_diff(current, desired)
+    assert len(ops) == 1
+    assert isinstance(ops[0], DropTable)
+
+
+def test_add_nullable_column():
+    cols_old = (ColumnDef(name="id", type="INTEGER"),)
+    cols_new = cols_old + (ColumnDef(name="bio", type="TEXT", nullable=True),)
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    assert len(ops) == 1
+    assert isinstance(ops[0], AddColumn)
+    assert ops[0].column.name == "bio"
+
+
+def test_add_non_nullable_column_without_default_requires_reconstruct():
+    cols_old = (ColumnDef(name="id", type="INTEGER"),)
+    cols_new = cols_old + (ColumnDef(name="name", type="TEXT", nullable=False),)
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_change_column_type_requires_reconstruct():
+    cols_old = (ColumnDef(name="id", type="INTEGER"),)
+    cols_new = (ColumnDef(name="id", type="TEXT"),)
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old, pk=())})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new, pk=())})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_change_pk_requires_reconstruct():
+    cols = (
+        ColumnDef(name="a", type="INTEGER"),
+        ColumnDef(name="b", type="INTEGER"),
+    )
+    current = SchemaDef(tables={"t": _simple_table("t", cols, pk=("a",))})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols, pk=("b",))})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_add_fk_requires_reconstruct():
+    cols = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="ref_id", type="INTEGER"),
+    )
+    ref_table = _simple_table("ref")
+    fk = ForeignKeyDef(
+        columns=("ref_id",), ref_table="ref", ref_columns=("id",)
+    )
+    current = SchemaDef(
+        tables={"t": _simple_table("t", cols), "ref": ref_table}
+    )
+    desired = SchemaDef(
+        tables={"t": _simple_table("t", cols, fks=(fk,)), "ref": ref_table}
+    )
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_add_check_requires_reconstruct():
+    cols = (ColumnDef(name="id", type="INTEGER"),)
+    chk = CheckConstraintDef(name="chk_pos", expression="id > 0")
+    current = SchemaDef(tables={"t": _simple_table("t", cols)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols, checks=(chk,))})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
+
+
+def test_add_index():
+    cols = (ColumnDef(name="id", type="INTEGER"), ColumnDef(name="name", type="TEXT"))
+    idx = IndexDef(name="idx_name", table="t", columns=("name",))
+    current = SchemaDef(tables={"t": _simple_table("t", cols)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols, indexes=(idx,))})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, AddIndex) for op in ops)
+
+
+def test_drop_index():
+    cols = (ColumnDef(name="id", type="INTEGER"), ColumnDef(name="name", type="TEXT"))
+    idx = IndexDef(name="idx_name", table="t", columns=("name",))
+    current = SchemaDef(tables={"t": _simple_table("t", cols, indexes=(idx,))})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols)})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, DropIndex) for op in ops)
+
+
+def test_create_tables_in_dependency_order():
+    users = _simple_table("users")
+    fk = ForeignKeyDef(
+        columns=("user_id",), ref_table="users", ref_columns=("id",)
+    )
+    posts_cols = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="user_id", type="INTEGER"),
+    )
+    posts = _simple_table("posts", posts_cols, fks=(fk,))
+    current = SchemaDef(tables={})
+    desired = SchemaDef(tables={"posts": posts, "users": users})
+    ops = compute_diff(current, desired)
+    # users should be created before posts
+    create_ops = [op for op in ops if isinstance(op, CreateTable)]
+    names = [op.table.name for op in create_ops]
+    assert names.index("users") < names.index("posts")
+
+
+def test_remove_column_requires_reconstruct():
+    cols_old = (
+        ColumnDef(name="id", type="INTEGER"),
+        ColumnDef(name="old_col", type="TEXT"),
+    )
+    cols_new = (ColumnDef(name="id", type="INTEGER"),)
+    current = SchemaDef(tables={"t": _simple_table("t", cols_old)})
+    desired = SchemaDef(tables={"t": _simple_table("t", cols_new)})
+    ops = compute_diff(current, desired)
+    assert any(isinstance(op, ReconstructTable) for op in ops)
diff --git a/tests/test_end_to_end.py b/tests/test_end_to_end.py
new file mode 100644
index 0000000..103258b
--- /dev/null
+++ b/tests/test_end_to_end.py
@@ -0,0 +1,329 @@
+"""End-to-end tests covering full vijaybase workflows."""
+
+import sqlite3
+
+from vijaybase.cli import main
+from vijaybase.migration_io import MigrationFile, compute_checksum, write_migration
+
+
+SCHEMA_V1 = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      name:
+        type: TEXT
+        nullable: false
+      email:
+        type: TEXT
+        nullable: false
+    indexes:
+      - name: idx_users_email
+        columns: [email]
+        unique: true
+"""
+
+SCHEMA_V2 = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      name:
+        type: TEXT
+        nullable: false
+      email:
+        type: TEXT
+        nullable: false
+      bio:
+        type: TEXT
+        default: "''"
+    indexes:
+      - name: idx_users_email
+        columns: [email]
+        unique: true
+"""
+
+SCHEMA_WITH_FK = """\
+tables:
+  users:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      name:
+        type: TEXT
+        nullable: false
+  posts:
+    columns:
+      id:
+        type: INTEGER
+        primary_key: true
+      user_id:
+        type: INTEGER
+        nullable: false
+      title:
+        type: TEXT
+        nullable: false
+    foreign_keys:
+      - columns: [user_id]
+        references:
+          table: users
+          columns: [id]
+        on_delete: CASCADE
+    indexes:
+      - name: idx_posts_user_id
+        columns: [user_id]
+"""
+
+
+def test_full_lifecycle(tmp_path, monkeypatch):
+    """Full lifecycle: init -> schema -> generate -> apply -> modify -> generate -> apply -> rollback -> status."""
+    monkeypatch.chdir(tmp_path)
+
+    # 1. Init
+    assert main(["init", "--database", "test.sqlite"]) == 0
+
+    # 2. Write schema v1
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V1)
+
+    # 3. Validate
+    assert main(["validate"]) == 0
+
+    # 4. Generate initial migration
+    assert main(["generate", "create_users"]) == 0
+    migrations = list((tmp_path / "migrations").glob("*.yaml"))
+    assert len(migrations) == 1
+
+    # 5. Apply
+    assert main(["apply"]) == 0
+
+    # 6. Verify DB
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    conn.execute("PRAGMA foreign_keys = ON")
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert "users" in tables
+
+    # Verify columns
+    cols = conn.execute("PRAGMA table_info(users)").fetchall()
+    col_names = {r[1] for r in cols}
+    assert col_names == {"id", "name", "email"}
+
+    # Verify index
+    indexes = conn.execute("PRAGMA index_list(users)").fetchall()
+    idx_names = {r[1] for r in indexes}
+    assert "idx_users_email" in idx_names
+    conn.close()
+
+    # 7. Update schema to v2 (add bio column)
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V2)
+
+    # 8. Generate second migration
+    assert main(["generate", "add_bio"]) == 0
+    migrations = list((tmp_path / "migrations").glob("*.yaml"))
+    assert len(migrations) == 2
+
+    # 9. Apply
+    assert main(["apply"]) == 0
+
+    # 10. Verify bio column exists
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    cols = conn.execute("PRAGMA table_info(users)").fetchall()
+    col_names = {r[1] for r in cols}
+    assert "bio" in col_names
+    conn.close()
+
+    # 11. Rollback 1 step
+    assert main(["rollback", "--steps", "1"]) == 0
+
+    # 12. Verify bio column gone
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    cols = conn.execute("PRAGMA table_info(users)").fetchall()
+    col_names = {r[1] for r in cols}
+    assert "bio" not in col_names
+    conn.close()
+
+    # 13. Status shows 1 pending
+    assert main(["status"]) == 0
+
+
+def test_conflict_and_merge(tmp_path, monkeypatch, capsys):
+    """Test fork detection and merge resolution."""
+    monkeypatch.chdir(tmp_path)
+
+    # Setup: init + schema + generate + apply
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V1)
+    main(["generate", "initial"])
+    main(["apply"])
+
+    # Get the initial migration ID
+    from vijaybase.migration_io import list_migration_files
+    initial_migrations = list_migration_files(tmp_path / "migrations")
+    initial_id = initial_migrations[0].migration_id
+
+    # Simulate dev A: create migration m2a
+    m2a_up = ["ALTER TABLE [users] ADD COLUMN [avatar] TEXT"]
+    m2a_down = ["ALTER TABLE [users] DROP COLUMN [avatar]"]
+    m2a = MigrationFile(
+        migration_id="20260417160000",
+        description="add_avatar",
+        parent=initial_id,
+        up_sql=m2a_up,
+        down_sql=m2a_down,
+    )
+    m2a.checksum = compute_checksum(
+        m2a.migration_id, m2a.parent, m2a.parents, m2a.up_sql, m2a.down_sql
+    )
+    write_migration(tmp_path / "migrations", m2a)
+
+    # Simulate dev B: create migration m2b with same parent
+    m2b_up = ["ALTER TABLE [users] ADD COLUMN [phone] TEXT"]
+    m2b_down = ["ALTER TABLE [users] DROP COLUMN [phone]"]
+    m2b = MigrationFile(
+        migration_id="20260417161500",
+        description="add_phone",
+        parent=initial_id,
+        up_sql=m2b_up,
+        down_sql=m2b_down,
+    )
+    m2b.checksum = compute_checksum(
+        m2b.migration_id, m2b.parent, m2b.parents, m2b.up_sql, m2b.down_sql
+    )
+    write_migration(tmp_path / "migrations", m2b)
+
+    # Try to apply -> should fail with conflict
+    rc = main(["apply"])
+    assert rc == 1
+    stderr = capsys.readouterr().err
+    assert "fork" in stderr.lower() or "conflict" in stderr.lower()
+
+    # Merge
+    rc = main(["merge"])
+    assert rc == 0
+    migrations = list((tmp_path / "migrations").glob("*.yaml"))
+    assert len(migrations) == 4  # initial + m2a + m2b + merge
+
+    # Now apply should succeed
+    rc = main(["apply"])
+    assert rc == 0
+
+    # Verify both columns exist
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    cols = conn.execute("PRAGMA table_info(users)").fetchall()
+    col_names = {r[1] for r in cols}
+    assert "avatar" in col_names
+    assert "phone" in col_names
+    conn.close()
+
+
+def test_foreign_key_tables(tmp_path, monkeypatch):
+    """Test schema with foreign keys creates tables in correct order."""
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "all.yaml").write_text(SCHEMA_WITH_FK)
+    main(["generate", "initial_with_fk"])
+    assert main(["apply"]) == 0
+
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    conn.execute("PRAGMA foreign_keys = ON")
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert "users" in tables
+    assert "posts" in tables
+
+    # Verify FK constraint works
+    conn.execute("INSERT INTO users (id, name) VALUES (1, 'Alice')")
+    conn.execute("INSERT INTO posts (id, user_id, title) VALUES (1, 1, 'Hello')")
+    conn.commit()
+
+    # Delete user should cascade
+    conn.execute("DELETE FROM users WHERE id = 1")
+    conn.commit()
+    count = conn.execute("SELECT COUNT(*) FROM posts").fetchone()[0]
+    assert count == 0
+    conn.close()
+
+
+def test_dry_run_no_side_effects(tmp_path, monkeypatch, capsys):
+    """Dry-run should print SQL but not modify DB."""
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V1)
+    main(["generate", "initial"])
+
+    # Apply dry-run
+    rc = main(["apply", "--dry-run"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "CREATE TABLE" in output
+
+    # DB should have no tables (or not even exist)
+    db_path = tmp_path / "test.sqlite"
+    if db_path.exists():
+        conn = sqlite3.connect(str(db_path))
+        tables = {r[0] for r in conn.execute(
+            "SELECT name FROM sqlite_master WHERE type='table'"
+        ).fetchall()} - {"_vijaybase_history"}
+        assert "users" not in tables
+        conn.close()
+
+
+def test_rollback_dry_run(tmp_path, monkeypatch, capsys):
+    """Rollback dry-run should print SQL but not modify DB."""
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V1)
+    main(["generate", "initial"])
+    main(["apply"])
+
+    rc = main(["rollback", "--dry-run"])
+    assert rc == 0
+    output = capsys.readouterr().out
+    assert "DROP TABLE" in output or "dry-run" in output.lower()
+
+    # Table should still exist
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    tables = {r[0] for r in conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table'"
+    ).fetchall()}
+    assert "users" in tables
+    conn.close()
+
+
+def test_apply_with_target(tmp_path, monkeypatch):
+    """Apply with --target should stop at the specified migration."""
+    monkeypatch.chdir(tmp_path)
+    main(["init", "--database", "test.sqlite"])
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V1)
+    main(["generate", "create_users"])
+    main(["apply"])
+
+    # Add bio
+    (tmp_path / "schema" / "users.yaml").write_text(SCHEMA_V2)
+    main(["generate", "add_bio"])
+
+    # Get migration IDs
+    from vijaybase.migration_io import list_migration_files
+    all_migs = list_migration_files(tmp_path / "migrations")
+    first_id = all_migs[0].migration_id
+
+    # Rollback everything
+    main(["rollback", "--steps", "999"])
+
+    # Apply only up to first migration
+    rc = main(["apply", "--target", first_id])
+    assert rc == 0
+
+    conn = sqlite3.connect(str(tmp_path / "test.sqlite"))
+    cols = conn.execute("PRAGMA table_info(users)").fetchall()
+    col_names = {r[1] for r in cols}
+    assert "bio" not in col_names  # Second migration not applied
+    assert "name" in col_names  # First migration applied
+    conn.close()
