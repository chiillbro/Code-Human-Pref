+
+
+class SchemaValidationError(VijaybaseError):
+    """Invalid YAML schema definition."""
+
+
+class MigrationConflictError(VijaybaseError):
+    """Fork detected in migration chain."""
+
+
+class MigrationChecksumError(VijaybaseError):
+    """Migration file content has been tampered with."""
+
+
+class MigrationNotFoundError(VijaybaseError):
+    """Referenced migration ID does not exist."""
+
+
+class DatabaseError(VijaybaseError):
+    """Error during database operation."""
+
+
+class ConfigError(VijaybaseError):
+    """Missing or invalid vijaybase.yaml."""
diff --git a/src/vijaybase/executor.py b/src/vijaybase/executor.py
new file mode 100644
index 0000000..1f8eda0
--- /dev/null
+++ b/src/vijaybase/executor.py
@@ -0,0 +1,111 @@
+from __future__ import annotations
+
+import sqlite3
+
+from vijaybase.errors import DatabaseError, MigrationChecksumError
+from vijaybase.history import ensure_history_table, record_migration
+from vijaybase.migration_io import MigrationFile, compute_checksum
+
+
+def apply_migration(
+    conn: sqlite3.Connection,
+    migration: MigrationFile,
+    dry_run: bool = False,
+) -> list[str]:
+    """Apply a single migration (up direction).
+
+    Returns list of SQL statements executed/to-execute.
+    """
+    _verify_checksum(migration)
+    return _execute_migration(
+        conn, migration, migration.up_sql, "up", dry_run
+    )
+
+
+def rollback_migration(
+    conn: sqlite3.Connection,
+    migration: MigrationFile,
+    dry_run: bool = False,
+) -> list[str]:
+    """Rollback a single migration (down direction).
+
+    Returns list of SQL statements executed/to-execute.
+    """
+    _verify_checksum(migration)
+    return _execute_migration(
+        conn, migration, migration.down_sql, "down", dry_run
+    )
+
+
+def _verify_checksum(migration: MigrationFile) -> None:
+    if not migration.checksum:
+        return
+    expected = compute_checksum(
+        migration.migration_id,
+        migration.parent,
+        migration.parents,
+        migration.up_sql,
+        migration.down_sql,
+    )
+    if migration.checksum != expected:
+        raise MigrationChecksumError(
+            f"Migration '{migration.migration_id}' checksum mismatch. "
+            f"File may have been tampered with."
+        )
+
+
+def _execute_migration(
+    conn: sqlite3.Connection,
+    migration: MigrationFile,
+    statements: list[str],
+    direction: str,
+    dry_run: bool,
+) -> list[str]:
+    if dry_run:
+        return statements
+
+    # Ensure history table exists before starting savepoint
+    # (this commits, which would release any active savepoint)
+    ensure_history_table(conn)
+
+    savepoint = f"vijaybase_{migration.migration_id}"
+
+    try:
+        conn.execute(f"SAVEPOINT [{savepoint}]")
+
+        for stmt in statements:
+            stmt = stmt.strip()
+            if not stmt or stmt.startswith("--"):
+                continue
+            try:
+                conn.execute(stmt)
+            except sqlite3.Error as e:
+                raise DatabaseError(
+                    f"Failed executing SQL in migration "
+                    f"'{migration.migration_id}': {e}\n"
+                    f"Statement: {stmt}"
+                ) from e
+
+        # Record in history (no commit — savepoint manages it)
+        record_migration(
+            conn,
+            migration.migration_id,
+            direction,
+            migration.checksum,
+            migration.description,
+        )
+
+        conn.execute(f"RELEASE [{savepoint}]")
+        conn.commit()
+        return statements
+
+    except DatabaseError:
+        conn.execute(f"ROLLBACK TO [{savepoint}]")
+        conn.execute(f"RELEASE [{savepoint}]")
+        raise
+    except Exception as e:
+        conn.execute(f"ROLLBACK TO [{savepoint}]")
+        conn.execute(f"RELEASE [{savepoint}]")
+        raise DatabaseError(
+            f"Unexpected error in migration '{migration.migration_id}': {e}"
+        ) from e
diff --git a/src/vijaybase/history.py b/src/vijaybase/history.py
new file mode 100644
index 0000000..5ced01f
--- /dev/null
+++ b/src/vijaybase/history.py
@@ -0,0 +1,97 @@
+from __future__ import annotations
+
+import sqlite3
+
+HISTORY_TABLE = "_vijaybase_history"
+
+HISTORY_DDL = """\
+CREATE TABLE IF NOT EXISTS _vijaybase_history (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    migration_id TEXT NOT NULL,
+    direction TEXT NOT NULL CHECK(direction IN ('up', 'down')),
+    checksum TEXT NOT NULL,
+    description TEXT NOT NULL DEFAULT '',
+    applied_at TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ', 'now'))
+)"""
+
+HISTORY_INDEX_DDL = """\
+CREATE INDEX IF NOT EXISTS idx_vijaybase_history_migration
+    ON _vijaybase_history(migration_id)"""
+
+
+def ensure_history_table(conn: sqlite3.Connection) -> None:
+    conn.execute(HISTORY_DDL)
+    conn.execute(HISTORY_INDEX_DDL)
+    conn.commit()
+
+
+def record_migration(
+    conn: sqlite3.Connection,
+    migration_id: str,
+    direction: str,
+    checksum: str,
+    description: str,
+) -> None:
+    conn.execute(
+        "INSERT INTO _vijaybase_history (migration_id, direction, checksum, description) "
+        "VALUES (?, ?, ?, ?)",
+        (migration_id, direction, checksum, description),
+    )
+
+
+def get_applied_migrations(conn: sqlite3.Connection) -> set[str]:
+    """Return set of currently-applied migration IDs (net up - down)."""
+    ensure_history_table(conn)
+    rows = conn.execute(
+        "SELECT migration_id, direction FROM _vijaybase_history ORDER BY id"
+    ).fetchall()
+    applied: set[str] = set()
+    for mid, direction in rows:
+        if direction == "up":
+            applied.add(mid)
+        else:
+            applied.discard(mid)
+    return applied
+
+
+def get_current_head(conn: sqlite3.Connection) -> str | None:
+    """Return the migration_id of the most recently applied migration.
+
+    This is the last 'up' that hasn't been rolled back.
+    """
+    ensure_history_table(conn)
+    rows = conn.execute(
+        "SELECT migration_id, direction FROM _vijaybase_history ORDER BY id"
+    ).fetchall()
+    applied: list[str] = []
+    applied_set: set[str] = set()
+    for mid, direction in rows:
+        if direction == "up":
+            if mid not in applied_set:
+                applied.append(mid)
+                applied_set.add(mid)
+        else:
+            applied_set.discard(mid)
+            if mid in applied:
+                applied.remove(mid)
+    return applied[-1] if applied else None
+
+
+def get_full_history(conn: sqlite3.Connection) -> list[dict]:
+    """Return complete chronological history."""
+    ensure_history_table(conn)
+    rows = conn.execute(
+        "SELECT id, migration_id, direction, checksum, description, applied_at "
+        "FROM _vijaybase_history ORDER BY id"
+    ).fetchall()
+    return [
+        {
+            "id": r[0],
+            "migration_id": r[1],
+            "direction": r[2],
+            "checksum": r[3],
+            "description": r[4],
+            "applied_at": r[5],
+        }
+        for r in rows
+    ]
diff --git a/src/vijaybase/introspector.py b/src/vijaybase/introspector.py
new file mode 100644
index 0000000..87d5749
--- /dev/null
+++ b/src/vijaybase/introspector.py
@@ -0,0 +1,237 @@
+from __future__ import annotations
+
+import re
+import sqlite3
+from pathlib import Path
+
+from vijaybase.models import (
+    CheckConstraintDef,
+    ColumnDef,
+    ForeignKeyDef,
+    IndexDef,
+    SchemaDef,
+    TableDef,
+)
+
+SKIP_TABLES = {"_vijaybase_history"}
+CHECK_RE = re.compile(
+    r"(?:CONSTRAINT\s+(\w+)\s+)?CHECK\s*\((.+?)\)(?=\s*[,)])",
+    re.IGNORECASE | re.DOTALL,
+)
+
+
+def introspect_database(db_path: Path) -> SchemaDef:
+    if not db_path.exists():
+        return SchemaDef(tables={})
+    conn = sqlite3.connect(str(db_path))
+    try:
+        conn.execute("PRAGMA foreign_keys = ON")
+        tables = {}
+        for table_name in _get_tables(conn):
+            tables[table_name] = _get_table_def(conn, table_name)
+        return SchemaDef(tables=tables)
+    finally:
+        conn.close()
+
+
+def introspect_connection(conn: sqlite3.Connection) -> SchemaDef:
+    tables = {}
+    for table_name in _get_tables(conn):
+        tables[table_name] = _get_table_def(conn, table_name)
+    return SchemaDef(tables=tables)
+
+
+def _get_tables(conn: sqlite3.Connection) -> list[str]:
+    rows = conn.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' "
+        "AND name NOT LIKE 'sqlite_%' ORDER BY name"
+    ).fetchall()
+    return [r[0] for r in rows if r[0] not in SKIP_TABLES]
+
+
+def _get_table_def(conn: sqlite3.Connection, table_name: str) -> TableDef:
+    columns, primary_key = _get_columns(conn, table_name)
+    indexes = _get_indexes(conn, table_name)
+    foreign_keys = _get_foreign_keys(conn, table_name)
+    checks = _get_check_constraints(conn, table_name)
+    return TableDef(
+        name=table_name,
+        columns=tuple(columns),
+        primary_key=primary_key,
+        indexes=tuple(indexes),
+        foreign_keys=tuple(foreign_keys),
+        checks=tuple(checks),
+    )
+
+
+def _get_columns(
+    conn: sqlite3.Connection, table_name: str
+) -> tuple[list[ColumnDef], tuple[str, ...]]:
+    rows = conn.execute(f"PRAGMA table_info([{table_name}])").fetchall()
+    columns = []
+    pk_cols = []
+    for row in rows:
+        # cid, name, type, notnull, dflt_value, pk
+        cid, name, col_type, notnull, default, pk = row
+        col_type = col_type.upper() if col_type else "TEXT"
+        # Determine if column has UNIQUE constraint via unique index
+        unique = _column_has_unique(conn, table_name, name)
+        columns.append(
+            ColumnDef(
+                name=name,
+                type=col_type,
+                nullable=not notnull,
+                default=default,
+                unique=unique,
+            )
+        )
+        if pk:
+            pk_cols.append((pk, name))
+    pk_cols.sort()
+    primary_key = tuple(name for _, name in pk_cols)
+    return columns, primary_key
+
+
+def _column_has_unique(
+    conn: sqlite3.Connection, table_name: str, col_name: str
+) -> bool:
+    indexes = conn.execute(f"PRAGMA index_list([{table_name}])").fetchall()
+    for idx_row in indexes:
+        # seq, name, unique, origin, partial
+        idx_name = idx_row[1]
+        is_unique = idx_row[2]
+        origin = idx_row[3] if len(idx_row) > 3 else ""
+        if not is_unique:
+            continue
+        # Only consider auto-created unique constraints, not explicit indexes
+        if origin not in ("u", ""):
+            continue
+        idx_cols = conn.execute(f"PRAGMA index_info([{idx_name}])").fetchall()
+        if len(idx_cols) == 1 and idx_cols[0][2] == col_name:
+            # Single-column unique index with origin 'u' = column UNIQUE constraint
+            if origin == "u":
+                return True
+    return False
+
+
+def _get_indexes(conn: sqlite3.Connection, table_name: str) -> list[IndexDef]:
+    indexes = []
+    rows = conn.execute(f"PRAGMA index_list([{table_name}])").fetchall()
+    for row in rows:
+        idx_name = row[1]
+        is_unique = bool(row[2])
+        origin = row[3] if len(row) > 3 else ""
+        # Skip auto-created indexes (pk, unique constraints)
+        if origin in ("pk", "u"):
+            continue
+        idx_cols = conn.execute(f"PRAGMA index_info([{idx_name}])").fetchall()
+        col_names = tuple(r[2] for r in idx_cols)
+        indexes.append(
+            IndexDef(
+                name=idx_name,
+                table=table_name,
+                columns=col_names,
+                unique=is_unique,
+            )
+        )
+    return indexes
+
+
+def _get_foreign_keys(conn: sqlite3.Connection, table_name: str) -> list[ForeignKeyDef]:
+    rows = conn.execute(f"PRAGMA foreign_key_list([{table_name}])").fetchall()
+    # Group by id (FK id)
+    fk_map: dict[int, dict] = {}
+    for row in rows:
+        # id, seq, table, from, to, on_update, on_delete, match
+        fk_id = row[0]
+        if fk_id not in fk_map:
+            fk_map[fk_id] = {
+                "ref_table": row[2],
+                "columns": [],
+                "ref_columns": [],
+                "on_update": row[5] if row[5] else "NO ACTION",
+                "on_delete": row[6] if row[6] else "NO ACTION",
+            }
+        fk_map[fk_id]["columns"].append(row[3])
+        fk_map[fk_id]["ref_columns"].append(row[4])
+
+    fks = []
+    for fk_data in fk_map.values():
+        fks.append(
+            ForeignKeyDef(
+                columns=tuple(fk_data["columns"]),
+                ref_table=fk_data["ref_table"],
+                ref_columns=tuple(fk_data["ref_columns"]),
+                on_delete=fk_data["on_delete"].upper(),
+                on_update=fk_data["on_update"].upper(),
+            )
+        )
+    return fks
+
+
+def _get_check_constraints(
+    conn: sqlite3.Connection, table_name: str
+) -> list[CheckConstraintDef]:
+    row = conn.execute(
+        "SELECT sql FROM sqlite_master WHERE type='table' AND name=?",
+        (table_name,),
+    ).fetchone()
+    if not row or not row[0]:
+        return []
+    return _parse_check_constraints(row[0])
+
+
+def _parse_check_constraints(create_sql: str) -> list[CheckConstraintDef]:
+    checks = []
+    # Find all CHECK(...) in the CREATE TABLE statement
+    # We need to handle nested parentheses
+    i = 0
+    sql_upper = create_sql.upper()
+    while i < len(create_sql):
+        # Look for CONSTRAINT name CHECK or just CHECK
+        constraint_name = None
+
+        # Try to match CONSTRAINT <name> CHECK
+        constraint_match = re.match(
+            r"\s*CONSTRAINT\s+(\w+)\s+CHECK\s*",
+            create_sql[i:],
+            re.IGNORECASE,
+        )
+        check_match = re.match(r"\s*CHECK\s*", create_sql[i:], re.IGNORECASE)
+
+        if constraint_match:
+            constraint_name = constraint_match.group(1)
+            i += constraint_match.end()
+        elif check_match:
+            i += check_match.end()
+        else:
+            i += 1
+            continue
+
+        # Now extract the parenthesized expression
+        if i < len(create_sql) and create_sql[i] == "(":
+            expr = _extract_parens(create_sql, i)
+            if expr is not None:
+                checks.append(
+                    CheckConstraintDef(name=constraint_name, expression=expr)
+                )
+                i += len(expr) + 2  # +2 for the parens
+                continue
+        i += 1
+    return checks
+
+
+def _extract_parens(sql: str, start: int) -> str | None:
+    if sql[start] != "(":
+        return None
+    depth = 0
+    i = start
+    while i < len(sql):
+        if sql[i] == "(":
+            depth += 1
+        elif sql[i] == ")":
+            depth -= 1
+            if depth == 0:
+                return sql[start + 1 : i]
+        i += 1
+    return None
diff --git a/src/vijaybase/migration_generator.py b/src/vijaybase/migration_generator.py
new file mode 100644
index 0000000..4fd2c10
--- /dev/null
+++ b/src/vijaybase/migration_generator.py
@@ -0,0 +1,202 @@
+from __future__ import annotations
+
+from vijaybase.diff import (
+    AddColumn,
+    AddIndex,
+    CreateTable,
+    DiffOp,
+    DropColumn,
+    DropIndex,
+    DropTable,
+    ReconstructTable,
+)
+from vijaybase.models import (
+    ColumnDef,
+    IndexDef,
+    SchemaDef,
+    TableDef,
+)
+
+
+def generate_up_sql(ops: list[DiffOp]) -> list[str]:
+    statements: list[str] = []
+    for op in ops:
+        statements.extend(_op_to_up_sql(op))
+    return statements
+
+
+def generate_down_sql(ops: list[DiffOp], current_schema: SchemaDef) -> list[str]:
+    statements: list[str] = []
+    # Reverse the ops for rollback
+    for op in reversed(ops):
+        statements.extend(_op_to_down_sql(op, current_schema))
+    return statements
+
+
+def _op_to_up_sql(op: DiffOp) -> list[str]:
+    if isinstance(op, CreateTable):
+        stmts = [_create_table_sql(op.table)]
+        for idx in op.table.indexes:
+            stmts.append(_create_index_sql(idx))
+        return stmts
+    elif isinstance(op, DropTable):
+        stmts = []
+        for idx in op.table.indexes:
+            stmts.append(_drop_index_sql(idx))
+        stmts.append(f"DROP TABLE [{op.table.name}]")
+        return stmts
+    elif isinstance(op, AddColumn):
+        return [_add_column_sql(op.table_name, op.column)]
+    elif isinstance(op, DropColumn):
+        return [f"ALTER TABLE [{op.table_name}] DROP COLUMN [{op.column.name}]"]
+    elif isinstance(op, AddIndex):
+        return [_create_index_sql(op.index)]
+    elif isinstance(op, DropIndex):
+        return [_drop_index_sql(op.index)]
+    elif isinstance(op, ReconstructTable):
+        return _reconstruct_table_sql(op.table_name, op.old_table, op.new_table)
+    return []
+
+
+def _op_to_down_sql(op: DiffOp, current_schema: SchemaDef) -> list[str]:
+    if isinstance(op, CreateTable):
+        stmts = []
+        for idx in reversed(op.table.indexes):
+            stmts.append(_drop_index_sql(idx))
+        stmts.append(f"DROP TABLE IF EXISTS [{op.table.name}]")
+        return stmts
+    elif isinstance(op, DropTable):
+        stmts = [_create_table_sql(op.table)]
+        for idx in op.table.indexes:
+            stmts.append(_create_index_sql(idx))
+        return stmts
+    elif isinstance(op, AddColumn):
+        return [f"ALTER TABLE [{op.table_name}] DROP COLUMN [{op.column.name}]"]
+    elif isinstance(op, DropColumn):
+        return [_add_column_sql(op.table_name, op.column)]
+    elif isinstance(op, AddIndex):
+        return [_drop_index_sql(op.index)]
+    elif isinstance(op, DropIndex):
+        return [_create_index_sql(op.index)]
+    elif isinstance(op, ReconstructTable):
+        # Rollback: reconstruct back to old table
+        return _reconstruct_table_sql(op.table_name, op.new_table, op.old_table)
+    return []
+
+
+def _create_table_sql(table: TableDef) -> str:
+    parts: list[str] = []
+
+    for col in table.columns:
+        col_def = _column_def_sql(col, table.primary_key)
+        parts.append(col_def)
+
+    # Composite primary key (only if > 1 column)
+    if len(table.primary_key) > 1:
+        pk_cols = ", ".join(f"[{c}]" for c in table.primary_key)
+        parts.append(f"PRIMARY KEY ({pk_cols})")
+
+    # Foreign keys
+    for fk in table.foreign_keys:
+        fk_cols = ", ".join(f"[{c}]" for c in fk.columns)
+        ref_cols = ", ".join(f"[{c}]" for c in fk.ref_columns)
+        fk_sql = f"FOREIGN KEY ({fk_cols}) REFERENCES [{fk.ref_table}]({ref_cols})"
+        if fk.on_delete != "NO ACTION":
+            fk_sql += f" ON DELETE {fk.on_delete}"
+        if fk.on_update != "NO ACTION":
+            fk_sql += f" ON UPDATE {fk.on_update}"
+        parts.append(fk_sql)
+
+    # CHECK constraints
+    for chk in table.checks:
+        if chk.name:
+            parts.append(f"CONSTRAINT [{chk.name}] CHECK({chk.expression})")
+        else:
+            parts.append(f"CHECK({chk.expression})")
+
+    body = ",\n    ".join(parts)
+    return f"CREATE TABLE [{table.name}] (\n    {body}\n)"
+
+
+def _column_def_sql(col: ColumnDef, primary_key: tuple[str, ...]) -> str:
+    parts = [f"[{col.name}]", col.type]
+
+    # Single-column PK
+    if len(primary_key) == 1 and col.name == primary_key[0]:
+        parts.append("PRIMARY KEY")
+
+    if not col.nullable:
+        parts.append("NOT NULL")
+
+    if col.unique:
+        parts.append("UNIQUE")
+
+    if col.default is not None:
+        parts.append(f"DEFAULT {col.default}")
+
+    return " ".join(parts)
+
+
+def _add_column_sql(table_name: str, col: ColumnDef) -> str:
+    parts = [f"ALTER TABLE [{table_name}] ADD COLUMN [{col.name}]", col.type]
+    if not col.nullable:
+        parts.append("NOT NULL")
+    if col.unique:
+        parts.append("UNIQUE")
+    if col.default is not None:
+        parts.append(f"DEFAULT {col.default}")
+    return " ".join(parts)
+
+
+def _create_index_sql(index: IndexDef) -> str:
+    unique = "UNIQUE " if index.unique else ""
+    cols = ", ".join(f"[{c}]" for c in index.columns)
+    return f"CREATE {unique}INDEX [{index.name}] ON [{index.table}]({cols})"
+
+
+def _drop_index_sql(index: IndexDef) -> str:
+    return f"DROP INDEX IF EXISTS [{index.name}]"
+
+
+def _reconstruct_table_sql(
+    table_name: str, old_table: TableDef, new_table: TableDef
+) -> list[str]:
+    """Generate the 12-step table reconstruction sequence.
+
+    This is the SQLite-recommended approach for changes that ALTER TABLE
+    cannot handle (column type changes, PK changes, FK changes, etc.).
+    """
+    temp_name = f"__{table_name}_old"
+    stmts: list[str] = []
+
+    stmts.append("PRAGMA foreign_keys=OFF")
+
+    # Rename old table
+    stmts.append(f"ALTER TABLE [{table_name}] RENAME TO [{temp_name}]")
+
+    # Create new table
+    stmts.append(_create_table_sql(new_table))
+
+    # Copy data: use columns common to both old and new
+    old_col_names = {c.name for c in old_table.columns}
+    new_col_names = {c.name for c in new_table.columns}
+    common_cols = sorted(old_col_names & new_col_names)
+
+    if common_cols:
+        cols_sql = ", ".join(f"[{c}]" for c in common_cols)
+        stmts.append(
+            f"INSERT INTO [{table_name}] ({cols_sql}) "
+            f"SELECT {cols_sql} FROM [{temp_name}]"
+        )
+
+    # Drop old table
+    stmts.append(f"DROP TABLE [{temp_name}]")
+
+    # Recreate indexes on the new table
+    for idx in new_table.indexes:
+        stmts.append(_create_index_sql(idx))
+
+    stmts.append("PRAGMA foreign_keys=ON")
+    stmts.append(f"PRAGMA foreign_key_check([{table_name}])")
+
+    return stmts
diff --git a/src/vijaybase/migration_io.py b/src/vijaybase/migration_io.py
new file mode 100644
index 0000000..4d45db5
--- /dev/null
+++ b/src/vijaybase/migration_io.py
@@ -0,0 +1,120 @@
+from __future__ import annotations
+
+import hashlib
+import re
+from dataclasses import dataclass, field
+from datetime import datetime, timezone
+from pathlib import Path
+
+import yaml
+
+from vijaybase.errors import MigrationNotFoundError
+
+
+@dataclass
+class MigrationFile:
+    migration_id: str
+    description: str
+    parent: str | None = None
+    parents: list[str] | None = None
+    up_sql: list[str] = field(default_factory=list)
+    down_sql: list[str] = field(default_factory=list)
+    checksum: str = ""
+
+    @property
+    def is_merge(self) -> bool:
+        return self.parents is not None and len(self.parents) > 1
+
+    @property
+    def all_parents(self) -> list[str]:
+        if self.parents:
+            return list(self.parents)
+        if self.parent:
+            return [self.parent]
+        return []
+
+
+def generate_migration_id() -> str:
+    # Use microseconds to avoid collisions across rapid successive invocations
+    return datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S%f")
+
+
+def compute_checksum(
+    migration_id: str,
+    parent: str | None,
+    parents: list[str] | None,
+    up_sql: list[str],
+    down_sql: list[str],
+) -> str:
+    content = migration_id
+    if parents:
+        content += "|".join(sorted(parents))
+    elif parent:
+        content += parent
+    content += "||"
+    content += ";;".join(up_sql) + "||" + ";;".join(down_sql)
+    return hashlib.sha256(content.encode("utf-8")).hexdigest()
+
+
+def write_migration(migrations_dir: Path, migration: MigrationFile) -> Path:
+    # Sanitize description for filename
+    safe_desc = re.sub(r"[^a-zA-Z0-9_]", "_", migration.description).strip("_")
+    filename = f"{migration.migration_id}_{safe_desc}.yaml"
+    path = migrations_dir / filename
+
+    data: dict = {
+        "migration_id": migration.migration_id,
+        "description": migration.description,
+    }
+
+    if migration.parents:
+        data["parents"] = migration.parents
+        data["parent"] = None
+    else:
+        data["parent"] = migration.parent
+        data["parents"] = None
+
+    data["checksum"] = migration.checksum
+    data["up"] = migration.up_sql
+    data["down"] = migration.down_sql
+
+    with open(path, "w") as f:
+        yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
+
+    return path
+
+
+def read_migration(path: Path) -> MigrationFile:
+    with open(path) as f:
+        data = yaml.safe_load(f)
+    if not isinstance(data, dict):
+        raise MigrationNotFoundError(f"Invalid migration file: {path}")
+    parents = data.get("parents")
+    if isinstance(parents, list) and len(parents) > 0:
+        parent = None
+    else:
+        parent = data.get("parent")
+        parents = None
+    return MigrationFile(
+        migration_id=str(data["migration_id"]),
+        description=data.get("description", ""),
+        parent=parent,
+        parents=parents,
+        up_sql=data.get("up", []) or [],
+        down_sql=data.get("down", []) or [],
+        checksum=data.get("checksum", ""),
+    )
+
+
+def list_migration_files(migrations_dir: Path) -> list[MigrationFile]:
+    if not migrations_dir.is_dir():
+        return []
+    files = sorted(migrations_dir.glob("*.yaml")) + sorted(
+        migrations_dir.glob("*.yml")
+    )
+    migrations = []
+    for path in files:
+        migrations.append(read_migration(path))
+    # Sort by migration_id (timestamp-based, so lexicographic == chronological)
+    migrations.sort(key=lambda m: m.migration_id)
+    return migrations
diff --git a/src/vijaybase/models.py b/src/vijaybase/models.py
new file mode 100644
index 0000000..eb0d9fe
--- /dev/null
+++ b/src/vijaybase/models.py
@@ -0,0 +1,53 @@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+
+
+@dataclass(frozen=True)
+class ColumnDef:
+    name: str
+    type: str  # TEXT, INTEGER, REAL, BLOB, NUMERIC
+    nullable: bool = True
+    default: str | None = None
+    unique: bool = False
+
+
+@dataclass(frozen=True)
+class IndexDef:
+    name: str
+    table: str
+    columns: tuple[str, ...]
+    unique: bool = False
+
+
+@dataclass(frozen=True)
+class ForeignKeyDef:
+    columns: tuple[str, ...]
+    ref_table: str
+    ref_columns: tuple[str, ...]
+    on_delete: str = "NO ACTION"
+    on_update: str = "NO ACTION"
+
+
+@dataclass(frozen=True)
+class CheckConstraintDef:
+    name: str | None
+    expression: str
+
+
+@dataclass(frozen=True)
+class TableDef:
+    name: str
+    columns: tuple[ColumnDef, ...]
+    primary_key: tuple[str, ...]
+    indexes: tuple[IndexDef, ...] = ()
+    foreign_keys: tuple[ForeignKeyDef, ...] = ()
+    checks: tuple[CheckConstraintDef, ...] = ()
+
+
+@dataclass(frozen=True)
+class SchemaDef:
+    tables: dict[str, TableDef] = field(default_factory=dict)
+
+    def __hash__(self) -> int:
+        return hash(tuple(sorted(self.tables.items())))
diff --git a/src/vijaybase/schema_parser.py b/src/vijaybase/schema_parser.py
new file mode 100644
index 0000000..a24d4de
--- /dev/null
+++ b/src/vijaybase/schema_parser.py
@@ -0,0 +1,243 @@
+from __future__ import annotations
+
+from pathlib import Path
+
+import yaml
+
+from vijaybase.errors import SchemaValidationError
+from vijaybase.models import (
+    CheckConstraintDef,
+    ColumnDef,
+    ForeignKeyDef,
+    IndexDef,
+    SchemaDef,
+    TableDef,
+)
+
+VALID_TYPES = {"TEXT", "INTEGER", "REAL", "BLOB", "NUMERIC"}
+VALID_ON_ACTIONS = {"NO ACTION", "CASCADE", "SET NULL", "SET DEFAULT", "RESTRICT"}
+
+
+def parse_schema_file(path: Path) -> dict[str, TableDef]:
+    with open(path) as f:
+        data = yaml.safe_load(f)
+    if not isinstance(data, dict) or "tables" not in data:
+        raise SchemaValidationError(
+            f"{path}: expected a YAML mapping with a 'tables' key"
+        )
+    tables = {}
+    for table_name, table_data in data["tables"].items():
+        tables[table_name] = _parse_table(table_name, table_data, path)
+    return tables
+
+
+def _parse_table(name: str, data: dict, path: Path) -> TableDef:
+    if not isinstance(data, dict):
+        raise SchemaValidationError(f"{path}: table '{name}' must be a mapping")
+
+    columns_data = data.get("columns", {})
+    if not columns_data:
+        raise SchemaValidationError(f"{path}: table '{name}' has no columns")
+
+    columns = []
+    pk_from_columns = []
+    for col_name, col_data in columns_data.items():
+        col = _parse_column(col_name, col_data, name, path)
+        columns.append(col)
+        if isinstance(col_data, dict) and col_data.get("primary_key"):
+            pk_from_columns.append(col_name)
+
+    # Primary key: top-level overrides column-level
+    if "primary_key" in data:
+        pk_val = data["primary_key"]
+        if isinstance(pk_val, list):
+            primary_key = tuple(pk_val)
+        else:
+            primary_key = (str(pk_val),)
+    elif pk_from_columns:
+        primary_key = tuple(pk_from_columns)
+    else:
+        primary_key = ()
+
+    # Indexes
+    indexes = []
+    for idx_data in data.get("indexes", []) or []:
+        indexes.append(_parse_index(idx_data, name, path))
+
+    # Foreign keys
+    foreign_keys = []
+    for fk_data in data.get("foreign_keys", []) or []:
+        foreign_keys.append(_parse_foreign_key(fk_data, name, path))
+
+    # CHECK constraints
+    checks = []
+    for chk_data in data.get("checks", []) or []:
+        checks.append(_parse_check(chk_data, name, path))
+
+    return TableDef(
+        name=name,
+        columns=tuple(columns),
+        primary_key=primary_key,
+        indexes=tuple(indexes),
+        foreign_keys=tuple(foreign_keys),
+        checks=tuple(checks),
+    )
+
+
+def _parse_column(
+    name: str, data: dict | str, table_name: str, path: Path
+) -> ColumnDef:
+    if isinstance(data, str):
+        # Shorthand: column_name: TYPE
+        col_type = data.upper()
+        if col_type not in VALID_TYPES:
+            raise SchemaValidationError(
+                f"{path}: table '{table_name}', column '{name}': "
+                f"invalid type '{data}'. Must be one of {VALID_TYPES}"
+            )
+        return ColumnDef(name=name, type=col_type)
+
+    if not isinstance(data, dict):
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}', column '{name}' must be a mapping or type string"
+        )
+
+    col_type = data.get("type", "").upper()
+    if col_type not in VALID_TYPES:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}', column '{name}': "
+            f"invalid type '{data.get('type')}'. Must be one of {VALID_TYPES}"
+        )
+    return ColumnDef(
+        name=name,
+        type=col_type,
+        nullable=data.get("nullable", True),
+        default=str(data["default"]) if "default" in data else None,
+        unique=data.get("unique", False),
+    )
+
+
+def _parse_index(data: dict, table_name: str, path: Path) -> IndexDef:
+    if "name" not in data:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': index missing 'name'"
+        )
+    if "columns" not in data or not data["columns"]:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': index '{data['name']}' missing 'columns'"
+        )
+    return IndexDef(
+        name=data["name"],
+        table=table_name,
+        columns=tuple(data["columns"]),
+        unique=data.get("unique", False),
+    )
+
+
+def _parse_foreign_key(data: dict, table_name: str, path: Path) -> ForeignKeyDef:
+    if "columns" not in data:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': foreign key missing 'columns'"
+        )
+    refs = data.get("references", {})
+    if "table" not in refs or "columns" not in refs:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': foreign key missing "
+            "'references.table' or 'references.columns'"
+        )
+    on_delete = data.get("on_delete", "NO ACTION").upper()
+    on_update = data.get("on_update", "NO ACTION").upper()
+    if on_delete not in VALID_ON_ACTIONS:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': invalid on_delete '{on_delete}'"
+        )
+    if on_update not in VALID_ON_ACTIONS:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': invalid on_update '{on_update}'"
+        )
+    return ForeignKeyDef(
+        columns=tuple(data["columns"]),
+        ref_table=refs["table"],
+        ref_columns=tuple(refs["columns"]),
+        on_delete=on_delete,
+        on_update=on_update,
+    )
+
+
+def _parse_check(data: dict, table_name: str, path: Path) -> CheckConstraintDef:
+    if "expression" not in data:
+        raise SchemaValidationError(
+            f"{path}: table '{table_name}': check constraint missing 'expression'"
+        )
+    return CheckConstraintDef(
+        name=data.get("name"),
+        expression=data["expression"],
+    )
+
+
+def parse_schema_dir(schema_dir: Path) -> SchemaDef:
+    if not schema_dir.is_dir():
+        raise SchemaValidationError(f"Schema directory not found: {schema_dir}")
+    all_tables: dict[str, TableDef] = {}
+    yaml_files = sorted(schema_dir.glob("*.yaml")) + sorted(schema_dir.glob("*.yml"))
+    if not yaml_files:
+        return SchemaDef(tables={})
+    for path in yaml_files:
+        tables = parse_schema_file(path)
+        for table_name, table_def in tables.items():
+            if table_name in all_tables:
+                raise SchemaValidationError(
+                    f"Duplicate table '{table_name}' defined in multiple schema files"
+                )
+            all_tables[table_name] = table_def
+    return SchemaDef(tables=all_tables)
+
+
+def validate_schema(schema: SchemaDef) -> list[str]:
+    errors = []
+    all_table_names = set(schema.tables.keys())
+
+    for table_name, table in schema.tables.items():
+        col_names = {c.name for c in table.columns}
+
+        # Validate PK columns exist
+        for pk_col in table.primary_key:
+            if pk_col not in col_names:
+                errors.append(
+                    f"Table '{table_name}': primary key column '{pk_col}' "
+                    "does not exist"
+                )
+
+        # Validate index columns exist
+        for idx in table.indexes:
+            for idx_col in idx.columns:
+                if idx_col not in col_names:
+                    errors.append(
+                        f"Table '{table_name}': index '{idx.name}' references "
+                        f"non-existent column '{idx_col}'"
+                    )
+
+        # Validate FK references
+        for fk in table.foreign_keys:
+            for fk_col in fk.columns:
+                if fk_col not in col_names:
+                    errors.append(
+                        f"Table '{table_name}': foreign key column '{fk_col}' "
+                        "does not exist"
+                    )
+            if fk.ref_table not in all_table_names:
+                errors.append(
+                    f"Table '{table_name}': foreign key references "
+                    f"non-existent table '{fk.ref_table}'"
+                )
+            elif fk.ref_columns:
+                ref_col_names = {
+                    c.name for c in schema.tables[fk.ref_table].columns
+                }
+                for ref_col in fk.ref_columns:
+                    if ref_col not in ref_col_names:
+                        errors.append(
+                            f"Table '{table_name}': foreign key references "
+                            f"non-existent column '{fk.ref_table}.{ref_col}'"
+                        )
+    return errors
