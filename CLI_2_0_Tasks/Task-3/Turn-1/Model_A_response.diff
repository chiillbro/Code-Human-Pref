@@ -0,0 +1,56 @@
+from __future__ import annotations
+
+import argparse
+import sqlite3
+
+from vijaybase.chain import get_pending_migrations
+from vijaybase.config import load_config
+from vijaybase.executor import apply_migration
+from vijaybase.history import ensure_history_table, get_applied_migrations
+from vijaybase.migration_io import list_migration_files
+
+
+def run_apply(args: argparse.Namespace) -> int:
+    config = load_config()
+    dry_run = args.dry_run
+    target = args.target
+
+    all_migrations = list_migration_files(config.migrations_path)
+    if not all_migrations:
+        print("No migration files found.")
+        return 0
+
+    conn = sqlite3.connect(str(config.database_path))
+    try:
+        conn.execute("PRAGMA foreign_keys = ON")
+        ensure_history_table(conn)
+
+        applied_ids = get_applied_migrations(conn)
+        pending = get_pending_migrations(all_migrations, applied_ids, target)
+
+        if not pending:
+            print("No pending migrations to apply.")
+            return 0
+
+        mode = " (dry-run)" if dry_run else ""
+        print(f"Applying {len(pending)} migration(s){mode}:\n")
+
+        for migration in pending:
+            print(f"  -> {migration.migration_id}: {migration.description}")
+            stmts = apply_migration(conn, migration, dry_run=dry_run)
+
+            if dry_run:
+                for stmt in stmts:
+                    stmt = stmt.strip()
+                    if stmt and not stmt.startswith("--"):
+                        print(f"     {stmt};")
+                print()
+
+        if dry_run:
+            print("Dry-run complete. No changes were made to the database.")
+        else:
+            print(f"\nSuccessfully applied {len(pending)} migration(s).")
+
+        return 0
+    finally:
+        conn.close()
