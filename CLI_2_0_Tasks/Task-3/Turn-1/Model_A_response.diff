@@ -0,0 +1,43 @@
+from __future__ import annotations
+
+import argparse
+from pathlib import Path
+
+import yaml
+
+
+def run_init(args: argparse.Namespace) -> int:
+    project_dir = Path.cwd()
+    database = getattr(args, "database", "mydb.sqlite")
+    schema_dir = "schema"
+    migrations_dir = "migrations"
+
+    config_path = project_dir / "vijaybase.yaml"
+    if config_path.exists():
+        print(f"Already initialized: {config_path} exists")
+        return 1
+
+    # Create directories
+    (project_dir / schema_dir).mkdir(exist_ok=True)
+    (project_dir / migrations_dir).mkdir(exist_ok=True)
+
+    # Write config
+    config = {
+        "database": database,
+        "schema_dir": schema_dir,
+        "migrations_dir": migrations_dir,
+    }
+    with open(config_path, "w") as f:
+        yaml.dump(config, f, default_flow_style=False, sort_keys=False)
+
+    print(f"Initialized vijaybase project in {project_dir}")
+    print(f"  Config:     {config_path}")
+    print(f"  Schema dir: {project_dir / schema_dir}")
+    print(f"  Migrations: {project_dir / migrations_dir}")
+    print(f"  Database:   {database}")
+    print()
+    print("Next steps:")
+    print("  1. Define your schema in schema/*.yaml")
+    print("  2. Run 'vijaybase generate <description>' to create a migration")
+    print("  3. Run 'vijaybase apply' to apply migrations")
+    return 0
diff --git a/src/vijaybase/commands/merge_cmd.py b/src/vijaybase/commands/merge_cmd.py
new file mode 100644
index 0000000..2b36449
--- /dev/null
+++ b/src/vijaybase/commands/merge_cmd.py
@@ -0,0 +1,127 @@
+from __future__ import annotations
+
+import argparse
+
+from vijaybase.chain import build_chain, detect_conflicts, find_heads
+from vijaybase.config import load_config
+from vijaybase.migration_io import (
+    MigrationFile,
+    compute_checksum,
+    generate_migration_id,
+    list_migration_files,
+    write_migration,
+)
+
+
+def run_merge(args: argparse.Namespace) -> int:
+    config = load_config()
+
+    all_migrations = list_migration_files(config.migrations_path)
+    if not all_migrations:
+        print("No migration files found.")
+        return 1
+
+    heads = find_heads(all_migrations)
+    if len(heads) <= 1:
+        print("No fork detected. Nothing to merge.")
+        return 0
+
+    chain = build_chain(all_migrations)
+    conflicts = detect_conflicts(all_migrations)
+
+    print("Fork detected! Creating merge migration.")
+    print(f"  Heads: {', '.join(heads)}")
+    for head_a, head_b, ancestor in conflicts:
+        desc_a = chain[head_a].description
+        desc_b = chain[head_b].description
+        print(
+            f"  '{head_a}' ({desc_a}) and '{head_b}' ({desc_b}) "
+            f"branch from '{ancestor}'"
+        )
+
+    # Check if branches touch the same tables (informational)
+    _report_overlap(chain, heads, conflicts)
+
+    # Create merge migration
+    migration_id = generate_migration_id()
+    up_sql = ["-- Merge migration: reconciles forked migration chain"]
+    down_sql = ["-- Merge migration rollback: no SQL needed"]
+
+    checksum = compute_checksum(migration_id, None, heads, up_sql, down_sql)
+
+    merge = MigrationFile(
+        migration_id=migration_id,
+        description="merge_" + "_and_".join(h[:8] for h in heads),
+        parent=None,
+        parents=heads,
+        up_sql=up_sql,
+        down_sql=down_sql,
+        checksum=checksum,
+    )
+
+    path = write_migration(config.migrations_path, merge)
+    print(f"\nCreated merge migration: {path.name}")
+    print(f"  ID:      {migration_id}")
+    print(f"  Parents: {', '.join(heads)}")
+    print("\nYou can now run 'vijaybase apply' to apply all pending migrations.")
+    return 0
+
+
+def _report_overlap(
+    chain: dict[str, MigrationFile],
+    heads: list[str],
+    conflicts: list[tuple[str, str, str]],
+) -> None:
+    """Report if branches modify the same tables (informational warning)."""
+    for head_a, head_b, ancestor in conflicts:
+        tables_a = _collect_tables_in_branch(chain, head_a, ancestor)
+        tables_b = _collect_tables_in_branch(chain, head_b, ancestor)
+        overlap = tables_a & tables_b
+        if overlap:
+            print(
+                f"\n  WARNING: Both branches modify table(s): "
+                f"{', '.join(sorted(overlap))}"
+            )
+            print(
+                "  Review the merge migration and schema files to ensure "
+                "consistency."
+            )
+
+
+def _collect_tables_in_branch(
+    chain: dict[str, MigrationFile],
+    head: str,
+    ancestor: str,
+) -> set[str]:
+    """Collect table names referenced in SQL from ancestor to head."""
+    tables: set[str] = set()
+    current = head
+    while current and current != ancestor:
+        m = chain.get(current)
+        if not m:
+            break
+        for stmt in m.up_sql:
+            tables.update(_extract_table_names(stmt))
+        parents = m.all_parents
+        current = parents[0] if parents else ""
+    return tables
+
+
+def _extract_table_names(sql: str) -> set[str]:
+    """Extract table names from SQL statements (best-effort)."""
+    import re
+
+    tables: set[str] = set()
+    # CREATE TABLE [name] or CREATE TABLE name
+    for match in re.finditer(
+        r"(?:CREATE|DROP|ALTER)\s+TABLE\s+(?:IF\s+(?:NOT\s+)?EXISTS\s+)?\[?(\w+)\]?",
+        sql,
+        re.IGNORECASE,
+    ):
+        tables.add(match.group(1))
+    # INSERT INTO [name]
+    for match in re.finditer(
+        r"INSERT\s+INTO\s+\[?(\w+)\]?", sql, re.IGNORECASE
+    ):
+        tables.add(match.group(1))
+    return tables
