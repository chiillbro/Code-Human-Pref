new file mode 100644
index 0000000..db6a051
--- /dev/null
+++ b/tests/test_chain.py
@@ -0,0 +1,133 @@
+import pytest
+
+from vijaybase.chain import (
+    detect_conflicts,
+    find_common_ancestor,
+    find_heads,
+    build_chain,
+    get_linear_order,
+    get_pending_migrations,
+    validate_chain_integrity,
+)
+from vijaybase.errors import MigrationConflictError
+from vijaybase.migration_io import MigrationFile, compute_checksum
+
+
+def _mig(mid, parent=None, parents=None, desc="test"):
+    up = [f"-- {mid} up"]
+    down = [f"-- {mid} down"]
+    chk = compute_checksum(mid, parent, parents, up, down)
+    return MigrationFile(
+        migration_id=mid, description=desc,
+        parent=parent, parents=parents,
+        up_sql=up, down_sql=down, checksum=chk,
+    )
+
+
+def test_linear_chain_single_head():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="002")
+    heads = find_heads([m1, m2, m3])
+    assert heads == ["003"]
+
+
+def test_fork_detected():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")  # dev A
+    m3 = _mig("003", parent="001")  # dev B
+    heads = find_heads([m1, m2, m3])
+    assert sorted(heads) == ["002", "003"]
+
+
+def test_detect_conflicts():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="001")
+    conflicts = detect_conflicts([m1, m2, m3])
+    assert len(conflicts) == 1
+    assert conflicts[0][2] == "001"  # common ancestor
+
+
+def test_find_common_ancestor():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="001")
+    chain = build_chain([m1, m2, m3])
+    ancestor = find_common_ancestor(chain, "002", "003")
+    assert ancestor == "001"
+
+
+def test_merge_resolves_fork():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="001")
+    m4 = _mig("004", parents=["002", "003"], desc="merge")
+    heads = find_heads([m1, m2, m3, m4])
+    assert heads == ["004"]
+
+
+def test_get_linear_order():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="002")
+    order = get_linear_order([m1, m2, m3])
+    ids = [m.migration_id for m in order]
+    assert ids == ["001", "002", "003"]
+
+
+def test_get_linear_order_raises_on_fork():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="001")
+    with pytest.raises(MigrationConflictError, match="fork"):
+        get_linear_order([m1, m2, m3])
+
+
+def test_get_linear_order_after_merge():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="001")
+    m4 = _mig("004", parents=["002", "003"])
+    order = get_linear_order([m1, m2, m3, m4])
+    ids = [m.migration_id for m in order]
+    assert ids[0] == "001"
+    assert ids[-1] == "004"
+    assert set(ids[1:3]) == {"002", "003"}
+
+
+def test_get_pending_migrations():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="002")
+    pending = get_pending_migrations([m1, m2, m3], {"001"})
+    assert [m.migration_id for m in pending] == ["002", "003"]
+
+
+def test_get_pending_with_target():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    m3 = _mig("003", parent="002")
+    pending = get_pending_migrations([m1, m2, m3], set(), target="002")
+    assert [m.migration_id for m in pending] == ["001", "002"]
+
+
+def test_validate_chain_integrity_ok():
+    m1 = _mig("001")
+    m2 = _mig("002", parent="001")
+    errors = validate_chain_integrity([m1, m2])
+    assert errors == []
+
+
+def test_validate_chain_missing_parent():
+    m2 = _mig("002", parent="001")
+    errors = validate_chain_integrity([m2])
+    assert any("missing parent" in e for e in errors)
+
+
+def test_validate_chain_bad_checksum():
+    m1 = _mig("001")
+    m1.checksum = "bad"
+    # MigrationFile is not frozen, so this works
+    errors = validate_chain_integrity([m1])
+    assert any("invalid checksum" in e for e in errors)
