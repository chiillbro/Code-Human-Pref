+from __future__ import annotations
+
+import argparse
+
+from vijaybase.config import load_config
+from vijaybase.schema_parser import parse_schema_dir, validate_schema
+
+
+def run_validate(args: argparse.Namespace) -> int:
+    config = load_config()
+    schema = parse_schema_dir(config.schema_path)
+
+    if not schema.tables:
+        print("No schema files found. Add .yaml files to the schema/ directory.")
+        return 1
+
+    errors = validate_schema(schema)
+    if errors:
+        print("Schema validation failed:")
+        for err in errors:
+            print(f"  - {err}")
+        return 1
+
+    table_count = len(schema.tables)
+    col_count = sum(len(t.columns) for t in schema.tables.values())
+    print(f"Schema is valid: {table_count} table(s), {col_count} column(s)")
+    return 0
