--- /dev/null
+++ b/src/vijaybase/config.py
@@ -0,0 +1,62 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from pathlib import Path
+
+import yaml
+
+from vijaybase.errors import ConfigError
+
+CONFIG_FILENAME = "vijaybase.yaml"
+
+
+@dataclass
+class VijaybaseConfig:
+    database: str
+    schema_dir: str
+    migrations_dir: str
+    project_root: Path
+
+    @property
+    def database_path(self) -> Path:
+        return self.project_root / self.database
+
+    @property
+    def schema_path(self) -> Path:
+        return self.project_root / self.schema_dir
+
+    @property
+    def migrations_path(self) -> Path:
+        return self.project_root / self.migrations_dir
+
+
+def find_project_root(start: Path | None = None) -> Path:
+    current = (start or Path.cwd()).resolve()
+    while True:
+        if (current / CONFIG_FILENAME).exists():
+            return current
+        parent = current.parent
+        if parent == current:
+            raise ConfigError(
+                f"Could not find {CONFIG_FILENAME} in {start or Path.cwd()} "
+                "or any parent directory. Run 'vijaybase init' first."
+            )
+        current = parent
+
+
+def load_config(project_root: Path | None = None) -> VijaybaseConfig:
+    if project_root is None:
+        project_root = find_project_root()
+    config_path = project_root / CONFIG_FILENAME
+    if not config_path.exists():
+        raise ConfigError(f"{CONFIG_FILENAME} not found in {project_root}")
+    with open(config_path) as f:
+        data = yaml.safe_load(f)
+    if not isinstance(data, dict):
+        raise ConfigError(f"Invalid {CONFIG_FILENAME}: expected a YAML mapping")
+    return VijaybaseConfig(
+        database=data.get("database", "mydb.sqlite"),
+        schema_dir=data.get("schema_dir", "schema"),
+        migrations_dir=data.get("migrations_dir", "migrations"),
+        project_root=project_root,
+    )
diff --git a/src/vijaybase/diff.py b/src/vijaybase/diff.py
new file mode 100644
index 0000000..1130f25
--- /dev/null
+++ b/src/vijaybase/diff.py
@@ -0,0 +1,272 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+from vijaybase.models import (
+    CheckConstraintDef,
+    ColumnDef,
+    ForeignKeyDef,
+    IndexDef,
+    SchemaDef,
+    TableDef,
+)
+
+
+# --- Diff operation types ---
+
+@dataclass(frozen=True)
+class DiffOp:
+    pass
+
+
+@dataclass(frozen=True)
+class CreateTable(DiffOp):
+    table: TableDef
+
+
+@dataclass(frozen=True)
+class DropTable(DiffOp):
+    table: TableDef
+
+
+@dataclass(frozen=True)
+class AddColumn(DiffOp):
+    table_name: str
+    column: ColumnDef
+
+
+@dataclass(frozen=True)
+class DropColumn(DiffOp):
+    table_name: str
+    column: ColumnDef
+
+
+@dataclass(frozen=True)
+class AddIndex(DiffOp):
+    index: IndexDef
+
+
+@dataclass(frozen=True)
+class DropIndex(DiffOp):
+    index: IndexDef
+
+
+@dataclass(frozen=True)
+class ReconstructTable(DiffOp):
+    table_name: str
+    old_table: TableDef
+    new_table: TableDef
+
+
+# --- Diff computation ---
+
+def compute_diff(current: SchemaDef, desired: SchemaDef) -> list[DiffOp]:
+    ops: list[DiffOp] = []
+
+    current_names = set(current.tables.keys())
+    desired_names = set(desired.tables.keys())
+
+    # Tables to drop (reverse dependency order)
+    removed = current_names - desired_names
+    for name in _toposort_for_drop(removed, current):
+        ops.append(DropTable(current.tables[name]))
+
+    # Tables to create (dependency order)
+    added = desired_names - current_names
+    for name in _toposort_for_create(added, desired):
+        ops.append(CreateTable(desired.tables[name]))
+
+    # Tables to potentially modify
+    common = current_names & desired_names
+    for name in sorted(common):
+        cur_t = current.tables[name]
+        des_t = desired.tables[name]
+        if _tables_equal(cur_t, des_t):
+            continue
+        table_ops = _diff_table(cur_t, des_t)
+        ops.extend(table_ops)
+
+    return ops
+
+
+def _normalize_default(val: str | None) -> str | None:
+    """Normalize a DEFAULT value for comparison.
+
+    SQLite's PRAGMA table_info strips outer parentheses from expression defaults,
+    so '(strftime(...))' becomes 'strftime(...)'. We normalize both sides by
+    stripping outer parens.
+    """
+    if val is None:
+        return None
+    v = val.strip()
+    while v.startswith("(") and v.endswith(")"):
+        v = v[1:-1].strip()
+    return v
+
+
+def _columns_equal(a: ColumnDef, b: ColumnDef) -> bool:
+    """Compare columns with normalized defaults."""
+    return (
+        a.name == b.name
+        and a.type == b.type
+        and a.nullable == b.nullable
+        and _normalize_default(a.default) == _normalize_default(b.default)
+        and a.unique == b.unique
+    )
+
+
+def _tables_equal(a: TableDef, b: TableDef) -> bool:
+    """Compare two TableDefs, normalizing for SQLite round-trip differences:
+    - CHECK constraint names are ignored (SQLite doesn't preserve them)
+    - DEFAULT values have outer parens stripped (SQLite strips them in PRAGMA)
+    """
+    if a.name != b.name:
+        return False
+    if len(a.columns) != len(b.columns):
+        return False
+    for ca, cb in zip(a.columns, b.columns):
+        if not _columns_equal(ca, cb):
+            return False
+    if a.primary_key != b.primary_key:
+        return False
+    if a.indexes != b.indexes:
+        return False
+    if a.foreign_keys != b.foreign_keys:
+        return False
+    # Compare checks by expression only
+    a_exprs = frozenset(c.expression for c in a.checks)
+    b_exprs = frozenset(c.expression for c in b.checks)
+    return a_exprs == b_exprs
+
+
+def _diff_table(cur_t: TableDef, des_t: TableDef) -> list[DiffOp]:
+    table_name = cur_t.name
+    needs_reconstruct = False
+    simple_ops: list[DiffOp] = []
+
+    # Compare primary key
+    if cur_t.primary_key != des_t.primary_key:
+        needs_reconstruct = True
+
+    # Compare foreign keys
+    if frozenset(cur_t.foreign_keys) != frozenset(des_t.foreign_keys):
+        needs_reconstruct = True
+
+    # Compare check constraints (by expression only — SQLite doesn't round-trip names)
+    cur_check_exprs = frozenset(c.expression for c in cur_t.checks)
+    des_check_exprs = frozenset(c.expression for c in des_t.checks)
+    if cur_check_exprs != des_check_exprs:
+        needs_reconstruct = True
+
+    # Compare columns
+    cur_cols = {c.name: c for c in cur_t.columns}
+    des_cols = {c.name: c for c in des_t.columns}
+
+    added_cols = set(des_cols) - set(cur_cols)
+    removed_cols = set(cur_cols) - set(des_cols)
+    common_cols = set(cur_cols) & set(des_cols)
+
+    for col_name in sorted(added_cols):
+        col = des_cols[col_name]
+        # ALTER TABLE ADD COLUMN only works if nullable or has default
+        if col.nullable or col.default is not None:
+            simple_ops.append(AddColumn(table_name, col))
+        else:
+            needs_reconstruct = True
+
+    for col_name in sorted(removed_cols):
+        # SQLite 3.35+ supports ALTER TABLE DROP COLUMN but with restrictions.
+        # For safety, if dropping a column, use reconstruct.
+        needs_reconstruct = True
+
+    for col_name in sorted(common_cols):
+        if not _columns_equal(cur_cols[col_name], des_cols[col_name]):
+            # Any column modification requires reconstruction in SQLite
+            needs_reconstruct = True
+
+    # Compare indexes
+    cur_idx = {i.name: i for i in cur_t.indexes}
+    des_idx = {i.name: i for i in des_t.indexes}
+
+    for idx_name in sorted(set(des_idx) - set(cur_idx)):
+        simple_ops.append(AddIndex(des_idx[idx_name]))
+
+    for idx_name in sorted(set(cur_idx) - set(des_idx)):
+        simple_ops.append(DropIndex(cur_idx[idx_name]))
+
+    for idx_name in sorted(set(cur_idx) & set(des_idx)):
+        if cur_idx[idx_name] != des_idx[idx_name]:
+            simple_ops.append(DropIndex(cur_idx[idx_name]))
+            simple_ops.append(AddIndex(des_idx[idx_name]))
+
+    if needs_reconstruct:
+        # Collapse everything into a single ReconstructTable
+        # But keep index ops that are purely additive on the new table
+        return [ReconstructTable(table_name, cur_t, des_t)]
+    return simple_ops
+
+
+def _toposort_for_create(
+    table_names: set[str], schema: SchemaDef
+) -> list[str]:
+    """Sort tables so that referenced tables are created before referencing ones."""
+    if not table_names:
+        return []
+
+    # Build dependency graph: table -> set of tables it depends on
+    deps: dict[str, set[str]] = {}
+    for name in table_names:
+        table = schema.tables[name]
+        deps[name] = set()
+        for fk in table.foreign_keys:
+            if fk.ref_table in table_names and fk.ref_table != name:
+                deps[name].add(fk.ref_table)
+
+    return _kahn_sort(deps)
+
+
+def _toposort_for_drop(
+    table_names: set[str], schema: SchemaDef
+) -> list[str]:
+    """Sort tables so that referencing tables are dropped before referenced ones."""
+    if not table_names:
+        return []
+
+    # Build reverse dependency: table -> set of tables that reference it
+    deps: dict[str, set[str]] = {name: set() for name in table_names}
+    for name in table_names:
+        table = schema.tables[name]
+        for fk in table.foreign_keys:
+            if fk.ref_table in table_names and fk.ref_table != name:
+                # ref_table depends on name being dropped first
+                deps[fk.ref_table].add(name)
+
+    return _kahn_sort(deps)
+
+
+def _kahn_sort(deps: dict[str, set[str]]) -> list[str]:
+    """Kahn's algorithm for topological sort."""
+    in_degree = {node: len(d) for node, d in deps.items()}
+    queue = sorted(node for node, deg in in_degree.items() if deg == 0)
+    result = []
+
+    while queue:
+        node = queue.pop(0)
+        result.append(node)
+        for other, d in deps.items():
+            if node in d:
+                d.discard(node)
+                in_degree[other] -= 1
+                if in_degree[other] == 0:
+                    # Insert sorted to keep deterministic
+                    idx = 0
+                    while idx < len(queue) and queue[idx] < other:
+                        idx += 1
+                    queue.insert(idx, other)
+
+    if len(result) != len(deps):
+        # Circular dependency — just return alphabetical
+        remaining = sorted(set(deps) - set(result))
+        result.extend(remaining)
+
+    return result
