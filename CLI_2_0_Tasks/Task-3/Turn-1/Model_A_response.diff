@@ -0,0 +1,53 @@
+from vijaybase.history import (
+    ensure_history_table,
+    get_applied_migrations,
+    get_current_head,
+    get_full_history,
+    record_migration,
+)
+
+
+def test_ensure_history_table(memory_db):
+    ensure_history_table(memory_db)
+    rows = memory_db.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' AND name='_vijaybase_history'"
+    ).fetchall()
+    assert len(rows) == 1
+
+
+def test_record_and_get_applied(memory_db):
+    ensure_history_table(memory_db)
+    record_migration(memory_db, "m1", "up", "chk1", "first")
+    record_migration(memory_db, "m2", "up", "chk2", "second")
+    applied = get_applied_migrations(memory_db)
+    assert applied == {"m1", "m2"}
+
+
+def test_rollback_removes_from_applied(memory_db):
+    ensure_history_table(memory_db)
+    record_migration(memory_db, "m1", "up", "chk1", "first")
+    record_migration(memory_db, "m2", "up", "chk2", "second")
+    record_migration(memory_db, "m2", "down", "chk2", "second")
+    applied = get_applied_migrations(memory_db)
+    assert applied == {"m1"}
+
+
+def test_get_current_head(memory_db):
+    ensure_history_table(memory_db)
+    assert get_current_head(memory_db) is None
+    record_migration(memory_db, "m1", "up", "chk1", "first")
+    assert get_current_head(memory_db) == "m1"
+    record_migration(memory_db, "m2", "up", "chk2", "second")
+    assert get_current_head(memory_db) == "m2"
+    record_migration(memory_db, "m2", "down", "chk2", "second")
+    assert get_current_head(memory_db) == "m1"
+
+
+def test_get_full_history(memory_db):
+    ensure_history_table(memory_db)
+    record_migration(memory_db, "m1", "up", "chk1", "first")
+    record_migration(memory_db, "m1", "down", "chk1", "first")
+    history = get_full_history(memory_db)
+    assert len(history) == 2
+    assert history[0]["direction"] == "up"
+    assert history[1]["direction"] == "down"
diff --git a/tests/test_introspector.py b/tests/test_introspector.py
