+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST TOOLTIP
+Test widget tooltip system.
+"""
+
+__all__ = ['TooltipTest']
+
+import time
+
+from test._utils import BaseTest, MenuUtils, WIDGET_MOUSEOVER, \
+    reset_widgets_over, surface
+
+import pygame_menu
+
+
+# noinspection PyProtectedMember
+class TooltipTest(BaseTest):
+
+    def setUp(self) -> None:
+        reset_widgets_over()
+
+    def tearDown(self) -> None:
+        reset_widgets_over()
+
+    def test_widget_tooltip_api(self) -> None:
+        """
+        Test set_tooltip / get_tooltip / get_mouseover_time on the base
+        Widget class.
+        """
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button('Button')
+
+        # Default: no tooltip
+        self.assertEqual(btn.get_tooltip(), '')
+
+        # Set tooltip text
+        self.assertEqual(btn.set_tooltip('Hello'), btn)
+        self.assertEqual(btn.get_tooltip(), 'Hello')
+
+        # Clear tooltip with None
+        btn.set_tooltip(None)
+        self.assertEqual(btn.get_tooltip(), '')
+
+        # Set tooltip with custom delay
+        btn.set_tooltip('World', delay_ms=1000)
+        self.assertEqual(btn.get_tooltip(), 'World')
+        self.assertEqual(btn._tooltip_delay_ms, 1000)
+
+        # Invalid delay raises
+        self.assertRaises(AssertionError, lambda: btn.set_tooltip('x', delay_ms=-1))
+        self.assertRaises(AssertionError, lambda: btn.set_tooltip('x', delay_ms='bad'))
+
+        # get_mouseover_time returns 0 when not hovered
+        self.assertEqual(btn.get_mouseover_time(), 0)
+
+        # Simulate hover
+        btn._mouseover = True
+        btn._mouseover_time = time.time() - 0.05
+        self.assertGreater(btn.get_mouseover_time(), 0)
+
+        # Clear hover
+        btn._mouseover = False
+        btn._mouseover_time = 0
+        self.assertEqual(btn.get_mouseover_time(), 0)
+
+    def test_widget_tooltip_kwargs(self) -> None:
+        """
+        Test that tooltip/tooltip_delay_ms can be passed as kwargs when adding
+        a widget via the WidgetManager and that the theme default delay is
+        inherited otherwise.
+        """
+        theme = pygame_menu.themes.THEME_DEFAULT.copy()
+        theme.widget_tooltip_delay_ms = 750
+        menu = MenuUtils.generic_menu(theme=theme)
+
+        # Tooltip passed as kwarg
+        btn = menu.add.button('With tooltip', tooltip='Click me!')
+        self.assertEqual(btn.get_tooltip(), 'Click me!')
+        self.assertEqual(btn._tooltip_delay_ms, 750)
+
+        # Override delay per-widget via kwarg
+        btn2 = menu.add.button('Fast tooltip', tooltip='Quick', tooltip_delay_ms=100)
+        self.assertEqual(btn2.get_tooltip(), 'Quick')
+        self.assertEqual(btn2._tooltip_delay_ms, 100)
+
+        # No tooltip kwarg → empty tooltip, theme delay
+        btn3 = menu.add.button('No tooltip')
+        self.assertEqual(btn3.get_tooltip(), '')
+        self.assertEqual(btn3._tooltip_delay_ms, 750)
+
+    def test_theme_tooltip_attributes(self) -> None:
+        """
+        Test tooltip theme attribute defaults and validation.
+        """
+        t = pygame_menu.themes.Theme()
+        self.assertEqual(t.widget_tooltip_background_color, (255, 255, 230, 255))
+        self.assertEqual(t.widget_tooltip_border_color, (40, 40, 40, 255))
+        self.assertEqual(t.widget_tooltip_border_width, 1)
+        self.assertEqual(t.widget_tooltip_delay_ms, 500)
+        self.assertEqual(t.widget_tooltip_font_color, (20, 20, 20, 255))
+        self.assertEqual(t.widget_tooltip_font_size, 16)
+        self.assertEqual(t.widget_tooltip_margin, (16, 16))
+        self.assertEqual(t.widget_tooltip_padding, (6, 3))
+        self.assertTrue(t.widget_tooltip_font_antialias)
+        self.assertEqual(t.validate(), t)
+
+        # Custom tooltip theme via kwargs
+        t2 = pygame_menu.themes.Theme(
+            widget_tooltip_delay_ms=1000,
+            widget_tooltip_font_size=20,
+            widget_tooltip_padding=(10, 5)
+        )
+        self.assertEqual(t2.widget_tooltip_delay_ms, 1000)
+        self.assertEqual(t2.widget_tooltip_font_size, 20)
+        self.assertEqual(t2.widget_tooltip_padding, (10, 5))
+        self.assertEqual(t2.validate(), t2)
+
+        # Invalid values fail validation
+        t3 = pygame_menu.themes.Theme()
+        t3.widget_tooltip_delay_ms = -1
+        self.assertRaises(AssertionError, lambda: t3.validate())
+        t3.widget_tooltip_delay_ms = 500
+        t3.widget_tooltip_font_size = 0
+        self.assertRaises(AssertionError, lambda: t3.validate())
+
+    def test_menu_draw_tooltip(self) -> None:
+        """
+        Test that Menu._draw_tooltip renders without errors and that the
+        tooltip is actually blitted onto the target surface.
+        """
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button('Button')
+        btn.set_tooltip('Hello, world!', delay_ms=0)
+
+        # Initial draw: nothing is hovered, tooltip must not render. The menu
+        # draw pass itself must still succeed.
+        menu.draw(surface)
+
+        # Simulate hover directly – this bypasses the event pipeline but
+        # exercises the tooltip draw path.
+        btn._mouseover = True
+        btn._mouseover_time = time.time() - 1  # Been hovering for 1 s
+        WIDGET_MOUSEOVER[0] = btn
+        WIDGET_MOUSEOVER[1] = [btn, None, []]
+
+        # Draw directly on a fresh surface and check that pixels changed
+        probe = pygame_menu.utils.make_surface(600, 600, alpha=True)
+        probe.fill((0, 0, 0, 0))
+        before = probe.copy()
+        menu._draw_tooltip(probe)
+        self.assertNotEqual(
+            probe.get_buffer().raw,
+            before.get_buffer().raw,
+            'tooltip was not drawn onto the surface'
+        )
+
+        # Full menu draw with tooltip active must not raise
+        menu.draw(surface)
+
+        # Multi-line tooltip also works
+        btn.set_tooltip('Line 1\nLine 2\nLine 3', delay_ms=0)
+        menu.draw(surface)
+
+        # Tooltip not yet elapsed → nothing drawn
+        btn.set_tooltip('Delayed', delay_ms=10000)
+        btn._mouseover_time = time.time()  # Just started hovering
+        probe2 = pygame_menu.utils.make_surface(600, 600, alpha=True)
+        probe2.fill((0, 0, 0, 0))
+        before2 = probe2.copy()
+        menu._draw_tooltip(probe2)
+        self.assertEqual(
+            probe2.get_buffer().raw,
+            before2.get_buffer().raw,
+            'tooltip was drawn before the configured delay elapsed'
+        )
+
+        # Clean up the global mouseover state
+        btn._mouseover = False
+        btn._mouseover_time = 0
+        WIDGET_MOUSEOVER[0] = None
+        WIDGET_MOUSEOVER[1] = []
+
+    def test_menu_draw_tooltip_skips_other_menu(self) -> None:
+        """
+        If the hovered widget belongs to a different Menu instance the tooltip
+        must not be drawn by this Menu.
+        """
+        menu_a = MenuUtils.generic_menu()
+        menu_b = MenuUtils.generic_menu()
+        btn_b = menu_b.add.button('Foreign')
+        btn_b.set_tooltip('Not mine', delay_ms=0)
+
+        btn_b._mouseover = True
+        btn_b._mouseover_time = time.time() - 1
+        WIDGET_MOUSEOVER[0] = btn_b
+        WIDGET_MOUSEOVER[1] = [btn_b, None, []]
+
+        probe = pygame_menu.utils.make_surface(600, 600, alpha=True)
+        probe.fill((0, 0, 0, 0))
+        before = probe.copy()
+        menu_a._draw_tooltip(probe)
+        self.assertEqual(
+            probe.get_buffer().raw,
+            before.get_buffer().raw,
+            'menu_a drew a tooltip for a widget belonging to menu_b'
+        )
+
+        # Clean up
+        btn_b._mouseover = False
+        btn_b._mouseover_time = 0
+        WIDGET_MOUSEOVER[0] = None
+        WIDGET_MOUSEOVER[1] = []
