+    # noinspection PyProtectedMember
+    def _draw_tooltip(self, surface: 'pygame.Surface') -> None:
+        """
+        Draw the tooltip of the currently hovered widget (if any) near the
+        mouse cursor, on top of every other Menu element. Called as the last
+        step of :py:meth:`Menu.draw`.
+
+        :param surface: Pygame surface to draw on
+        """
+        widget: Optional['Widget'] = WIDGET_MOUSEOVER[0]
+        if widget is None or widget.get_menu() is not self:
+            return
+        tooltip = widget.get_tooltip()
+        if tooltip == '':
+            return
+        if widget.get_mouseover_time() < widget._tooltip_delay_ms:
+            return
+
+        theme = self._theme
+
+        # Lazily (re)build the tooltip font if theme settings changed
+        key = (theme.widget_tooltip_font, theme.widget_tooltip_font_size)
+        if self._tooltip_font is None or self._tooltip_font_key != key:
+            self._tooltip_font = get_font(
+                theme.widget_tooltip_font,
+                theme.widget_tooltip_font_size
+            )
+            self._tooltip_font_key = key
+
+        # Render text (support simple multi-line via '\n')
+        pad_x, pad_y = theme.widget_tooltip_padding
+        lines = tooltip.split('\n')
+        line_surfaces = [
+            self._tooltip_font.render(
+                line,
+                theme.widget_tooltip_font_antialias,
+                theme.widget_tooltip_font_color
+            )
+            for line in lines
+        ]
+        text_w = max(s.get_width() for s in line_surfaces)
+        text_h = sum(s.get_height() for s in line_surfaces)
+        box_w = text_w + 2 * pad_x
+        box_h = text_h + 2 * pad_y
+
+        box = make_surface(box_w, box_h, alpha=True)
+        box.fill(theme.widget_tooltip_background_color)
+        y = pad_y
+        for s in line_surfaces:
+            box.blit(s, (pad_x, y))
+            y += s.get_height()
+        if theme.widget_tooltip_border_width > 0:
+            pygame.draw.rect(
+                box,
+                theme.widget_tooltip_border_color,
+                box.get_rect(),
+                theme.widget_tooltip_border_width
+            )
+
+        # Position near the mouse cursor, clamped to the surface bounds
+        mx, my = pygame.mouse.get_pos()
+        ox, oy = theme.widget_tooltip_margin
+        tx, ty = mx + ox, my + oy
+        sw, sh = surface.get_width(), surface.get_height()
+        if tx + box_w > sw:
+            tx = max(0, sw - box_w)
+        if ty + box_h > sh:
+            ty = max(0, my - oy - box_h)  # Flip above cursor
+        if ty < 0:
+            ty = 0
+
+        surface.blit(box, (tx, ty))
+
