diff --git a/pygame_menu/transitions.py b/pygame_menu/transitions.py
new file mode 100644
index 00000000..7eb07234
--- /dev/null
+++ b/pygame_menu/transitions.py
@@ -0,0 +1,311 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TRANSITIONS
+Pre-built transition helpers for common widget animations (fade, slide,
+colour transitions, pulse).
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "color_transition",
+    "fade_in",
+    "fade_out",
+    "pulse",
+    "slide_in",
+    "slide_out",
+]
+
+from typing import TYPE_CHECKING, Any
+
+from pygame_menu.utils import assert_color
+
+if TYPE_CHECKING:
+    from collections.abc import Callable
+
+    from pygame_menu._types import ColorInputType
+
+
+def _get_animation_manager(widget: Any) -> Any:
+    """
+    Retrieve the :class:`AnimationManager` from the widget's owning menu.
+
+    :param widget: A widget instance
+    :return: The menu's ``AnimationManager``
+    :raises RuntimeError: If the widget is not attached to a menu
+    """
+    menu = widget.get_menu()
+    if menu is None:
+        raise RuntimeError(
+            "widget must be added to a Menu before applying transitions"
+        )
+    return menu.get_animation_manager()
+
+
+# ---------------------------------------------------------------------------
+# Fade helpers
+# ---------------------------------------------------------------------------
+
+def fade_in(
+    widget: Any,
+    duration_ms: float = 300,
+    easing: str | Callable[[float], float] = "ease_out_quad",
+    on_complete: Callable[[], Any] | None = None,
+) -> str:
+    """
+    Animate the widget's opacity from ``0`` to ``255`` (fully visible).
+
+    :param widget: Target widget
+    :param duration_ms: Duration in milliseconds
+    :param easing: Easing function or name
+    :param on_complete: Optional callback on completion
+    :return: The animation ID
+    """
+    manager = _get_animation_manager(widget)
+    widget.set_opacity(0)
+    return manager.create_animation(
+        widget=widget,
+        property_name="_opacity",
+        start_value=0,
+        end_value=255,
+        duration_ms=duration_ms,
+        easing=easing,
+        on_complete=on_complete,
+    )
+
+
+def fade_out(
+    widget: Any,
+    duration_ms: float = 300,
+    easing: str | Callable[[float], float] = "ease_out_quad",
+    on_complete: Callable[[], Any] | None = None,
+) -> str:
+    """
+    Animate the widget's opacity from ``255`` to ``0`` (fully transparent).
+
+    :param widget: Target widget
+    :param duration_ms: Duration in milliseconds
+    :param easing: Easing function or name
+    :param on_complete: Optional callback on completion
+    :return: The animation ID
+    """
+    manager = _get_animation_manager(widget)
+    widget.set_opacity(255)
+    return manager.create_animation(
+        widget=widget,
+        property_name="_opacity",
+        start_value=255,
+        end_value=0,
+        duration_ms=duration_ms,
+        easing=easing,
+        on_complete=on_complete,
+    )
+
+
+# ---------------------------------------------------------------------------
+# Slide helpers
+# ---------------------------------------------------------------------------
+
+_SLIDE_DIRECTION_OFFSETS: dict[str, tuple[int, int]] = {
+    "left": (-1, 0),
+    "right": (1, 0),
+    "up": (0, -1),
+    "down": (0, 1),
+}
+
+
+def slide_in(
+    widget: Any,
+    direction: str = "left",
+    distance: float = 50,
+    duration_ms: float = 400,
+    easing: str | Callable[[float], float] = "ease_out_cubic",
+    on_complete: Callable[[], Any] | None = None,
+) -> str:
+    """
+    Slide the widget **into** its natural position from an offset in the given
+    direction.
+
+    :param widget: Target widget
+    :param direction: ``'left'``, ``'right'``, ``'up'``, or ``'down'``
+    :param distance: Distance in pixels of the start offset
+    :param duration_ms: Duration in milliseconds
+    :param easing: Easing function or name
+    :param on_complete: Optional callback on completion
+    :return: The animation ID
+    :raises ValueError: If direction is invalid
+    """
+    offsets = _SLIDE_DIRECTION_OFFSETS.get(direction)
+    if offsets is None:
+        raise ValueError(
+            f"invalid slide direction '{direction}'; "
+            f"valid: {', '.join(sorted(_SLIDE_DIRECTION_OFFSETS))}"
+        )
+
+    manager = _get_animation_manager(widget)
+    start_x = offsets[0] * distance
+    start_y = offsets[1] * distance
+
+    # Set the widget to the offset position
+    widget._translate_virtual = (
+        widget._translate_virtual[0] + start_x,
+        widget._translate_virtual[1] + start_y,
+    )
+    # Snap position so rect updates
+    widget.set_position(widget._position[0], widget._position[1])
+
+    start_translate = widget._translate_virtual
+    end_translate = (
+        start_translate[0] - start_x,
+        start_translate[1] - start_y,
+    )
+
+    return manager.create_animation(
+        widget=widget,
+        property_name="_translate_virtual",
+        start_value=start_translate,
+        end_value=end_translate,
+        duration_ms=duration_ms,
+        easing=easing,
+        on_complete=on_complete,
+    )
+
+
+def slide_out(
+    widget: Any,
+    direction: str = "right",
+    distance: float = 50,
+    duration_ms: float = 400,
+    easing: str | Callable[[float], float] = "ease_out_cubic",
+    on_complete: Callable[[], Any] | None = None,
+) -> str:
+    """
+    Slide the widget **out** from its natural position in the given direction.
+
+    :param widget: Target widget
+    :param direction: ``'left'``, ``'right'``, ``'up'``, or ``'down'``
+    :param distance: Distance in pixels of the end offset
+    :param duration_ms: Duration in milliseconds
+    :param easing: Easing function or name
+    :param on_complete: Optional callback on completion
+    :return: The animation ID
+    :raises ValueError: If direction is invalid
+    """
+    offsets = _SLIDE_DIRECTION_OFFSETS.get(direction)
+    if offsets is None:
+        raise ValueError(
+            f"invalid slide direction '{direction}'; "
+            f"valid: {', '.join(sorted(_SLIDE_DIRECTION_OFFSETS))}"
+        )
+
+    manager = _get_animation_manager(widget)
+    start_translate = widget._translate_virtual
+    end_translate = (
+        start_translate[0] + offsets[0] * distance,
+        start_translate[1] + offsets[1] * distance,
+    )
+
+    return manager.create_animation(
+        widget=widget,
+        property_name="_translate_virtual",
+        start_value=start_translate,
+        end_value=end_translate,
+        duration_ms=duration_ms,
+        easing=easing,
+        on_complete=on_complete,
+    )
+
+
+# ---------------------------------------------------------------------------
+# Color transition
+# ---------------------------------------------------------------------------
+
+def color_transition(
+    widget: Any,
+    from_color: ColorInputType,
+    to_color: ColorInputType,
+    duration_ms: float = 500,
+    easing: str | Callable[[float], float] = "linear",
+    on_complete: Callable[[], Any] | None = None,
+) -> str:
+    """
+    Smoothly transition the widget's font colour between two colours.
+
+    :param widget: Target widget
+    :param from_color: Starting colour
+    :param to_color: Ending colour
+    :param duration_ms: Duration in milliseconds
+    :param easing: Easing function or name
+    :param on_complete: Optional callback on completion
+    :return: The animation ID
+    """
+    from_color = assert_color(from_color)
+    to_color = assert_color(to_color)
+
+    manager = _get_animation_manager(widget)
+    widget._font_color = from_color
+
+    return manager.create_animation(
+        widget=widget,
+        property_name="_font_color",
+        start_value=from_color,
+        end_value=to_color,
+        duration_ms=duration_ms,
+        easing=easing,
+        on_complete=on_complete,
+    )
+
+
+# ---------------------------------------------------------------------------
+# Pulse
+# ---------------------------------------------------------------------------
+
+def pulse(
+    widget: Any,
+    scale: float = 1.1,
+    duration_ms: float = 600,
+    easing: str | Callable[[float], float] = "ease_in_out_quad",
+    loop: bool = True,
+    on_complete: Callable[[], Any] | None = None,
+) -> str:
+    """
+    Create a pulsing effect by oscillating the widget's virtual translation
+    (a slight grow/shrink illusion). Uses ``_translate_virtual`` to avoid
+    conflicting with theme padding.
+
+    The widget is shifted by a small offset derived from *scale* and then
+    animated back, creating a "breathing" effect when *loop* and *bounce*
+    are ``True``.
+
+    :param widget: Target widget
+    :param scale: Scale factor controlling the pulse amplitude (pixels offset)
+    :param duration_ms: Duration of one half-cycle in milliseconds
+    :param easing: Easing function or name
+    :param loop: Whether to repeat the pulse indefinitely
+    :param on_complete: Optional callback (fires each cycle if looping)
+    :return: The animation ID
+    """
+    manager = _get_animation_manager(widget)
+
+    # Compute a pixel offset based on scale — the widget shifts by a few pixels
+    # vertically to simulate a pulse
+    offset = int(round((scale - 1.0) * 10))
+    if offset < 1:
+        offset = 1
+
+    base = widget._translate_virtual
+    pulse_target = (base[0], base[1] - offset)
+
+    return manager.create_animation(
+        widget=widget,
+        property_name="_translate_virtual",
+        start_value=base,
+        end_value=pulse_target,
+        duration_ms=duration_ms,
+        easing=easing,
+        on_complete=on_complete,
+        loop=loop,
+        bounce=True,
+    )
