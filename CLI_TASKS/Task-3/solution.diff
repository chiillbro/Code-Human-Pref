+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST ANIMATION
+Test animation engine: easing functions, Animation class, AnimationManager.
+"""
+
+import pytest
+
+from pygame_menu.animation import (
+    EASING_FUNCTIONS,
+    Animation,
+    AnimationManager,
+    _clamp_opacity,
+    _interpolate,
+    _resolve_easing,
+)
+
+# ---------------------------------------------------------------------------
+# Easing function tests
+# ---------------------------------------------------------------------------
+
+class TestEasingFunctions:
+    """Verify all easing functions satisfy boundary and monotonicity contracts."""
+
+    @pytest.mark.parametrize("name", list(EASING_FUNCTIONS.keys()))
+    def test_boundaries(self, name):
+        fn = EASING_FUNCTIONS[name]
+        assert fn(0.0) == pytest.approx(0.0, abs=1e-9)
+        assert fn(1.0) == pytest.approx(1.0, abs=1e-9)
+
+    @pytest.mark.parametrize("name", [
+        "linear", "ease_in_quad", "ease_out_quad",
+        "ease_in_out_quad", "ease_in_cubic", "ease_out_cubic",
+    ])
+    def test_monotonic_non_decreasing(self, name):
+        fn = EASING_FUNCTIONS[name]
+        prev = fn(0.0)
+        for i in range(1, 101):
+            t = i / 100.0
+            cur = fn(t)
+            assert cur >= prev - 1e-9
+            prev = cur
+
+    def test_ease_out_back_overshoot(self):
+        fn = EASING_FUNCTIONS["ease_out_back"]
+        mid_values = [fn(t / 100.0) for t in range(50, 90)]
+        assert any(v > 1.0 for v in mid_values), (
+            "ease_out_back should overshoot past 1.0"
+        )
+
+
+class TestResolveEasing:
+    def test_known_name(self):
+        fn = _resolve_easing("linear")
+        assert fn is EASING_FUNCTIONS["linear"]
+
+    def test_unknown_raises(self):
+        with pytest.raises(ValueError, match="unknown easing"):
+            _resolve_easing("nonexistent")
+
+
+# ---------------------------------------------------------------------------
+# Interpolation helpers
+# ---------------------------------------------------------------------------
+
+class TestInterpolate:
+    def test_scalar(self):
+        assert _interpolate(0, 100, 0.5) == pytest.approx(50.0)
+
+    def test_scalar_boundaries(self):
+        assert _interpolate(10, 20, 0.0) == pytest.approx(10.0)
+        assert _interpolate(10, 20, 1.0) == pytest.approx(20.0)
+
+    def test_color_tuple_rgb(self):
+        result = _interpolate((0, 0, 0), (255, 255, 255), 0.5)
+        assert result == (128, 128, 128)
+
+    def test_color_tuple_rgba(self):
+        result = _interpolate((0, 0, 0, 0), (255, 255, 255, 255), 1.0)
+        assert result == (255, 255, 255, 255)
+
+    def test_color_clamping(self):
+        # If easing overshoots, color channels should clamp to [0, 255]
+        result = _interpolate((200, 200, 200), (255, 255, 255), 1.5)
+        for ch in result:
+            assert 0 <= ch <= 255
+
+    def test_generic_tuple(self):
+        result = _interpolate((0.0, 0.0), (10.0, 20.0), 0.5)
+        assert result == pytest.approx((5.0, 10.0))
+
+
+class TestClampOpacity:
+    def test_within_range(self):
+        assert _clamp_opacity(128) == 128
+
+    def test_below(self):
+        assert _clamp_opacity(-10) == 0
+
+    def test_above(self):
+        assert _clamp_opacity(300) == 255
+
+    def test_float_rounds(self):
+        assert _clamp_opacity(128.7) == 129
+
+
+# ---------------------------------------------------------------------------
+# Animation class
+# ---------------------------------------------------------------------------
+
+class TestAnimation:
+    def _make_widget_stub(self):
+        """Return a simple object with animatable attributes."""
+        class Stub:
+            _opacity = 0
+            _translate_virtual = (0.0, 0.0)
+        return Stub()
+
+    def test_basic_lifecycle(self):
+        widget = self._make_widget_stub()
+        anim = Animation(
+            animation_id="test-1",
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=100,
+            easing="linear",
+        )
+        assert not anim.completed
+        anim.update(50)
+        assert widget._opacity == pytest.approx(127.5, abs=1)
+        anim.update(50)
+        assert anim.completed
+        assert widget._opacity == 255
+
+    def test_completion_callback(self):
+        widget = self._make_widget_stub()
+        called = []
+        anim = Animation(
+            animation_id="test-cb",
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=50,
+            easing="linear",
+            on_complete=lambda: called.append(True),
+        )
+        anim.update(100)
+        assert called == [True]
+
+    def test_callback_only_fires_once(self):
+        widget = self._make_widget_stub()
+        count = []
+        anim = Animation(
+            animation_id="test-cb2",
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=128,
+            duration_ms=50,
+            easing="linear",
+            on_complete=lambda: count.append(1),
+        )
+        anim.update(100)
+        anim.update(100)
+        assert len(count) == 1
+
+    def test_bounce_mode(self):
+        widget = self._make_widget_stub()
+        anim = Animation(
+            animation_id="test-bounce",
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=100,
+            easing="linear",
+            bounce=True,
+            loop=True,  # bounce requires loop to reverse
+        )
+        # Forward half
+        anim.update(100)
+        assert widget._opacity == 255
+        # Bounce back (now _forward=False, elapsed resets)
+        anim.update(50)
+        assert widget._opacity == pytest.approx(127.5, abs=1)
+        anim.update(50)
+        assert widget._opacity == pytest.approx(0, abs=1)
+
+    def test_opacity_clamping(self):
+        widget = self._make_widget_stub()
+        anim = Animation(
+            animation_id="test-clamp",
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=100,
+            easing="ease_out_back",  # overshoots
+        )
+        anim.update(80)  # mid-flight with possible overshoot
+        assert 0 <= widget._opacity <= 255
+
+
+# ---------------------------------------------------------------------------
+# AnimationManager
+# ---------------------------------------------------------------------------
+
+class TestAnimationManager:
+    def _make_widget_stub(self):
+        class Stub:
+            _opacity = 0
+            id = "test_widget"
+        return Stub()
+
+    def test_create_and_update(self):
+        mgr = AnimationManager()
+        widget = self._make_widget_stub()
+        mgr.create_animation(
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=100,
+            easing="linear",
+        )
+        assert mgr.has_animations_for(widget)
+        mgr.update(100)
+        assert widget._opacity == 255
+        # update() calls _cleanup, so completed anims are removed
+        assert not mgr.has_animations_for(widget)
+
+    def test_cancel_for_widget(self):
+        mgr = AnimationManager()
+        widget = self._make_widget_stub()
+        mgr.create_animation(
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=1000,
+            easing="linear",
+        )
+        mgr.cancel_for_widget(widget)
+        assert not mgr.has_animations_for(widget)
+
+    def test_cancel_by_id(self):
+        mgr = AnimationManager()
+        widget = self._make_widget_stub()
+        anim_id = mgr.create_animation(
+            widget=widget,
+            property_name="_opacity",
+            start_value=0,
+            end_value=255,
+            duration_ms=1000,
+            easing="linear",
+        )
+        mgr.cancel_by_id(anim_id)
+        assert not mgr.has_animations_for(widget)
+
+    def test_clear(self):
+        mgr = AnimationManager()
+        w1 = self._make_widget_stub()
+        w2 = self._make_widget_stub()
+        mgr.create_animation(widget=w1, property_name="_opacity",
+                             start_value=0, end_value=128,
+                             duration_ms=100, easing="linear")
+        mgr.create_animation(widget=w2, property_name="_opacity",
+                             start_value=0, end_value=128,
+                             duration_ms=100, easing="linear")
+        mgr.clear()
+        assert not mgr.has_animations_for(w1)
+        assert not mgr.has_animations_for(w2)
+
+    def test_multiple_properties(self):
+        mgr = AnimationManager()
+        widget = self._make_widget_stub()
+        widget._opacity = 0
+        widget._custom = 0.0
+        mgr.create_animation(widget=widget, property_name="_opacity",
+                             start_value=0, end_value=200,
+                             duration_ms=100, easing="linear")
+        mgr.create_animation(widget=widget, property_name="_custom",
+                             start_value=0.0, end_value=10.0,
+                             duration_ms=100, easing="linear")
+        mgr.update(100)
