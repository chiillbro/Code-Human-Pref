+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST TRANSITIONS
+Integration tests for pre-built transition helpers (fade, slide, color, pulse).
+"""
+
+import pygame
+import pytest
+
+import pygame_menu
+from pygame_menu.animation import AnimationManager
+from pygame_menu.transitions import (
+    color_transition,
+    fade_in,
+    fade_out,
+    pulse,
+    slide_in,
+    slide_out,
+)
+from test._utils import MenuUtils, surface
+
+
+@pytest.fixture
+def menu():
+    """Create a simple menu with one button widget."""
+    m = MenuUtils.generic_menu(title="TransTest")
+    return m
+
+
+@pytest.fixture
+def widget(menu):
+    """Add a button to the menu and return it."""
+    btn = menu.add.button("Test", lambda: None)
+    return btn
+
+
+class TestFadeIn:
+    def test_sets_opacity_to_zero_initially(self, widget):
+        fade_in(widget, duration_ms=200)
+        assert widget.get_opacity() == 0
+
+    def test_animation_registered(self, widget, menu):
+        fade_in(widget, duration_ms=200)
+        assert menu.get_animation_manager().has_animations_for(widget)
+
+    def test_completes_to_full_opacity(self, widget, menu):
+        fade_in(widget, duration_ms=100)
+        menu.get_animation_manager().update(150)
+        assert widget.get_opacity() == 255
+
+
+class TestFadeOut:
+    def test_sets_opacity_to_255_initially(self, widget):
+        widget.set_opacity(128)
+        fade_out(widget, duration_ms=200)
+        assert widget.get_opacity() == 255
+
+    def test_completes_to_zero(self, widget, menu):
+        fade_out(widget, duration_ms=100)
+        menu.get_animation_manager().update(150)
+        assert widget.get_opacity() == 0
+
+
+class TestSlideIn:
+    @pytest.mark.parametrize("direction", ["left", "right", "up", "down"])
+    def test_accepted_directions(self, widget, direction):
+        anim_id = slide_in(widget, direction=direction, duration_ms=200)
+        assert isinstance(anim_id, str)
+
+    def test_invalid_direction_raises(self, widget):
+        with pytest.raises(ValueError, match="invalid slide direction"):
+            slide_in(widget, direction="diagonal")
+
+
+class TestSlideOut:
+    @pytest.mark.parametrize("direction", ["left", "right", "up", "down"])
+    def test_accepted_directions(self, widget, direction):
+        anim_id = slide_out(widget, direction=direction, duration_ms=200)
+        assert isinstance(anim_id, str)
+
+    def test_invalid_direction_raises(self, widget):
+        with pytest.raises(ValueError, match="invalid slide direction"):
+            slide_out(widget, direction="diagonal")
+
+
+class TestColorTransition:
+    def test_registers_animation(self, widget, menu):
+        color_transition(
+            widget, from_color=(70, 70, 70), to_color=(255, 0, 0), duration_ms=200
+        )
+        assert menu.get_animation_manager().has_animations_for(widget)
+
+    def test_completes_to_target(self, widget, menu):
+        color_transition(
+            widget, from_color=(70, 70, 70), to_color=(255, 0, 0), duration_ms=100
+        )
+        menu.get_animation_manager().update(150)
+        # Font color should be close to the target
+        r, g, b = widget._font_color[:3]
+        assert r == 255
+        assert g == 0
+        assert b == 0
+
+
+class TestPulse:
+    def test_registers_animation(self, widget, menu):
+        pulse(widget, scale=1.1, duration_ms=200)
+        assert menu.get_animation_manager().has_animations_for(widget)
+
+
+class TestWidgetAnimationAPI:
+    """Test the public animation methods on Widget."""
+
+    def test_set_get_opacity(self, widget):
+        widget.set_opacity(128)
+        assert widget.get_opacity() == 128
+
+    def test_opacity_clamping(self, widget):
+        widget.set_opacity(-10)
+        assert widget.get_opacity() == 0
+        widget.set_opacity(999)
+        assert widget.get_opacity() == 255
+
+    def test_animate_property(self, widget, menu):
+        widget.set_opacity(0)
+        anim_id = widget.animate_property("_opacity", 255, duration_ms=100)
+        assert isinstance(anim_id, str)
+        assert widget.has_active_animation()
+        menu.get_animation_manager().update(150)
+        assert widget.get_opacity() == 255
+        assert not widget.has_active_animation()
+
+    def test_cancel_animations(self, widget, menu):
+        widget.set_opacity(0)
+        widget.animate_property("_opacity", 255, duration_ms=1000)
+        widget.cancel_animations()
+        assert not widget.has_active_animation()
+
+    def test_animate_invalid_property_raises(self, widget):
+        with pytest.raises(AssertionError):
+            widget.animate_property("_nonexistent_attr", 42)
+
+
+class TestMenuAnimationManager:
+    """Test AnimationManager integration with Menu."""
+
+    def test_menu_has_animation_manager(self, menu):
+        mgr = menu.get_animation_manager()
+        assert isinstance(mgr, AnimationManager)
+
+    def test_remove_widget_cancels_animations(self, menu):
+        btn = menu.add.button("Removable", lambda: None)
+        btn.set_opacity(0)
+        btn.animate_property("_opacity", 255, duration_ms=1000)
+        assert menu.get_animation_manager().has_animations_for(btn)
+        menu.remove_widget(btn)
+        assert not menu.get_animation_manager().has_animations_for(btn)
