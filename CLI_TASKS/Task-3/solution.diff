diff --git a/pygame_menu/animation.py b/pygame_menu/animation.py
new file mode 100644
index 00000000..fd345ca3
--- /dev/null
+++ b/pygame_menu/animation.py
@@ -0,0 +1,481 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+ANIMATION
+Animation engine providing tweens, easing functions, and an animation manager
+for smooth widget property transitions.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "Animation",
+    "AnimationManager",
+    "EASING_FUNCTIONS",
+    "ease_in_cubic",
+    "ease_in_out_quad",
+    "ease_in_quad",
+    "ease_out_back",
+    "ease_out_cubic",
+    "ease_out_quad",
+    "linear",
+]
+
+import math
+from typing import TYPE_CHECKING, Any
+
+from pygame_menu.utils import uuid4
+
+if TYPE_CHECKING:
+    from collections.abc import Callable
+
+# ---------------------------------------------------------------------------
+# Easing functions
+# ---------------------------------------------------------------------------
+# Every easing function accepts a normalised time ``t`` in [0, 1] and returns
+# the eased value.  Some functions (e.g. ``ease_out_back``) intentionally
+# overshoot, so the result may exceed the [0, 1] range.
+
+
+def linear(t: float) -> float:
+    """
+    Linear easing — no acceleration.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value
+    """
+    return t
+
+
+def ease_in_quad(t: float) -> float:
+    """
+    Quadratic ease-in — accelerating from zero velocity.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value
+    """
+    return t * t
+
+
+def ease_out_quad(t: float) -> float:
+    """
+    Quadratic ease-out — decelerating to zero velocity.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value
+    """
+    return t * (2 - t)
+
+
+def ease_in_out_quad(t: float) -> float:
+    """
+    Quadratic ease-in-out — acceleration then deceleration.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value
+    """
+    if t < 0.5:
+        return 2 * t * t
+    return -1 + (4 - 2 * t) * t
+
+
+def ease_in_cubic(t: float) -> float:
+    """
+    Cubic ease-in — accelerating from zero velocity.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value
+    """
+    return t * t * t
+
+
+def ease_out_cubic(t: float) -> float:
+    """
+    Cubic ease-out — decelerating to zero velocity.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value
+    """
+    t -= 1
+    return t * t * t + 1
+
+
+def ease_out_back(t: float) -> float:
+    """
+    Ease-out with overshoot (back easing). The result intentionally exceeds 1.0
+    before settling.
+
+    :param t: Normalised time (0.0–1.0)
+    :return: Eased value (may overshoot above 1.0)
+    """
+    c1 = 1.70158
+    c3 = c1 + 1
+    return 1 + c3 * math.pow(t - 1, 3) + c1 * math.pow(t - 1, 2)
+
+
+# Registry mapping string names to easing callables
+EASING_FUNCTIONS: dict[str, Callable[[float], float]] = {
+    "linear": linear,
+    "ease_in_quad": ease_in_quad,
+    "ease_out_quad": ease_out_quad,
+    "ease_in_out_quad": ease_in_out_quad,
+    "ease_in_cubic": ease_in_cubic,
+    "ease_out_cubic": ease_out_cubic,
+    "ease_out_back": ease_out_back,
+}
+
+
+def _resolve_easing(easing: str | Callable[[float], float]) -> Callable[[float], float]:
+    """
+    Resolve an easing argument to a callable.
+
+    :param easing: Either a function or a string key (e.g. ``'ease_out_quad'``)
+    :return: The easing function
+    :raises ValueError: If the string name is not in the registry
+    """
+    if callable(easing):
+        return easing
+    if isinstance(easing, str):
+        fn = EASING_FUNCTIONS.get(easing)
+        if fn is None:
+            raise ValueError(
+                f"unknown easing function '{easing}'; "
+                f"available: {', '.join(sorted(EASING_FUNCTIONS))}"
+            )
+        return fn
+    raise TypeError(f"easing must be a callable or string, got {type(easing).__name__}")
+
+
+# ---------------------------------------------------------------------------
+# Value interpolation helpers
+# ---------------------------------------------------------------------------
+
+def _is_color_tuple(value: Any) -> bool:
+    """Check whether *value* looks like an RGB/RGBA colour tuple."""
+    return (
+        isinstance(value, (tuple, list))
+        and len(value) in (3, 4)
+        and all(isinstance(c, (int, float)) for c in value)
+    )
+
+
+def _interpolate(start: Any, end: Any, t: float) -> Any:
+    """
+    Interpolate between *start* and *end* by factor *t* (0.0–1.0).
+
+    Handles:
+    - Numeric scalars (int / float)
+    - Colour tuples (3 or 4 elements) with per-channel clamping 0–255
+    - 2-element numeric tuples (e.g. ``_translate_virtual``)
+
+    :param start: Start value
+    :param end: End value
+    :param t: Interpolation factor
+    :return: Interpolated value, same type as *start*
+    """
+    # Numeric scalar
+    if isinstance(start, (int, float)) and isinstance(end, (int, float)):
+        return start + (end - start) * t
+
+    # Colour tuples  — clamp each channel to [0, 255]
+    if _is_color_tuple(start) and _is_color_tuple(end):
+        max_len = max(len(start), len(end))
+        # Pad shorter tuple with 255 alpha if necessary
+        s = list(start) + [255] * (max_len - len(start))
+        e = list(end) + [255] * (max_len - len(end))
+        result = tuple(
+            int(round(max(0, min(255, s[i] + (e[i] - s[i]) * t))))
+            for i in range(max_len)
+        )
+        return result
+
+    # Generic numeric tuples / lists (e.g. translate_virtual (x, y))
+    if isinstance(start, (tuple, list)) and isinstance(end, (tuple, list)):
+        if len(start) == len(end) and all(
+            isinstance(a, (int, float)) and isinstance(b, (int, float))
+            for a, b in zip(start, end)
+        ):
+            interp = tuple(a + (b - a) * t for a, b in zip(start, end))
+            if isinstance(start, list):
+                return list(interp)
+            return interp
+
+    # Fallback — cannot interpolate, snap at the end
+    return end if t >= 1.0 else start
+
+
+# ---------------------------------------------------------------------------
+# Clampers
+# ---------------------------------------------------------------------------
+
+def _clamp_opacity(value: Any) -> int:
+    """Clamp an opacity value to the valid range [0, 255]."""
+    if isinstance(value, (int, float)):
+        return int(round(max(0, min(255, value))))
+    return value  # type: ignore[return-value]
+
+
+# Property-specific clamping rules
+_PROPERTY_CLAMPERS: dict[str, Callable[[Any], Any]] = {
+    "_opacity": _clamp_opacity,
+}
+
+
+# ---------------------------------------------------------------------------
+# Animation
+# ---------------------------------------------------------------------------
+
+class Animation:
+    """
+    A single tween that drives a widget attribute from *start_value* to
+    *end_value* over *duration_ms* using an *easing* curve.
+
+    :param animation_id: Unique identifier
+    :param widget: The widget whose property is animated
+    :param property_name: Name of the widget attribute (e.g. ``'_opacity'``)
+    :param start_value: Value at *t* = 0
+    :param end_value: Value at *t* = 1
+    :param duration_ms: Duration in milliseconds (must be > 0)
+    :param easing: Easing function or name string
+    :param on_complete: Optional callback fired when the animation finishes
+    :param loop: If ``True`` the animation restarts when it finishes
+    :param bounce: If ``True`` the animation reverses direction each cycle
+    """
+
+    def __init__(
+        self,
+        animation_id: str,
+        widget: Any,
+        property_name: str,
+        start_value: Any,
+        end_value: Any,
+        duration_ms: float,
+        easing: str | Callable[[float], float] = "linear",
+        on_complete: Callable[[], Any] | None = None,
+        loop: bool = False,
+        bounce: bool = False,
+    ) -> None:
+        assert duration_ms > 0, "animation duration must be greater than 0"
+        if not hasattr(widget, property_name):
+            raise AttributeError(
+                f"widget {widget!r} has no attribute '{property_name}'"
+            )
+
+        self.id: str = animation_id
+        self.widget = widget
+        self.property_name: str = property_name
+        self.start_value = start_value
+        self.end_value = end_value
+        self.duration_ms: float = float(duration_ms)
+        self.easing: Callable[[float], float] = _resolve_easing(easing)
+        self.on_complete = on_complete
+        self.loop: bool = loop
+        self.bounce: bool = bounce
+
+        self._elapsed_ms: float = 0.0
+        self._completed: bool = False
+        self._forward: bool = True  # Direction for bounce
+
+        # Clamper for this property (if any)
+        self._clamper = _PROPERTY_CLAMPERS.get(property_name)
+
+    @property
+    def completed(self) -> bool:
+        """Return whether the animation has finished."""
+        return self._completed
+
+    def update(self, dt_ms: float) -> bool:
+        """
+        Advance the animation by *dt_ms* milliseconds.
+
+        :param dt_ms: Elapsed time in milliseconds since last frame
+        :return: ``True`` if the animation completed on this tick
+        """
+        if self._completed:
+            return False
+
+        self._elapsed_ms += dt_ms
+
+        # Compute normalised progress
+        raw_t = min(self._elapsed_ms / self.duration_ms, 1.0)
+
+        # Bounce: reverse direction when a full cycle completes
+        if self.bounce and not self._forward:
+            raw_t = 1.0 - raw_t
+
+        eased_t = self.easing(raw_t)
+
+        # Interpolate
+        value = _interpolate(self.start_value, self.end_value, eased_t)
+
+        # Apply per-property clamp
+        if self._clamper is not None:
+            value = self._clamper(value)
+
+        # Set the property on the widget
+        setattr(self.widget, self.property_name, value)
+
+        # Check completion
+        if self._elapsed_ms >= self.duration_ms:
+            if self.loop:
+                self._elapsed_ms = 0.0
+                if self.bounce:
+                    self._forward = not self._forward
+                return False
+            else:
+                self._completed = True
+                # Snap to final value
+                final = self.end_value
+                if self._clamper is not None:
+                    final = self._clamper(final)
+                setattr(self.widget, self.property_name, final)
+                if self.on_complete is not None:
+                    self.on_complete()
+                return True
+
+        return False
+
+
+# ---------------------------------------------------------------------------
+# AnimationManager
+# ---------------------------------------------------------------------------
+
+class AnimationManager:
+    """
+    Manages a collection of active :class:`Animation` instances.  Call
+    :meth:`update` once per frame with the elapsed delta-time to tick all
+    animations forward.
+    """
+
+    def __init__(self) -> None:
+        self._animations: list[Animation] = []
+        self._widget_animations: dict[str, list[Animation]] = {}
+        # Maps widget id → list of active animations
+
+    def add(self, animation: Animation) -> None:
+        """
+        Register a new animation.
+
+        :param animation: The animation to add
+        """
+        self._animations.append(animation)
+        wid = id(animation.widget)
+        key = str(wid)
+        self._widget_animations.setdefault(key, []).append(animation)
+
+    def cancel_for_widget(self, widget: Any) -> None:
+        """
+        Cancel **all** active animations targeting *widget*.
+
+        :param widget: The widget whose animations should be removed
+        """
+        key = str(id(widget))
+        removed = self._widget_animations.pop(key, [])
+        for anim in removed:
+            anim._completed = True
+        self._animations = [a for a in self._animations if not a._completed]
+
+    def cancel_by_id(self, animation_id: str) -> None:
+        """
+        Cancel a specific animation by its ID.
+
+        :param animation_id: The animation's unique identifier
+        """
+        for anim in self._animations:
+            if anim.id == animation_id:
+                anim._completed = True
+        self._cleanup()
+
+    def has_animations_for(self, widget: Any) -> bool:
+        """
+        Return ``True`` if there are active (non-completed) animations for
+        *widget*.
+
+        :param widget: Widget to check
+        :return: Whether active animations exist
+        """
+        key = str(id(widget))
+        anims = self._widget_animations.get(key, [])
+        return any(not a._completed for a in anims)
+
+    def update(self, dt_ms: float) -> None:
+        """
+        Advance all active animations by *dt_ms* milliseconds and remove
+        completed ones.
+
+        :param dt_ms: Elapsed time in milliseconds since last frame
+        """
+        if not self._animations:
+            return
+
+        for anim in self._animations:
+            anim.update(dt_ms)
+
+        self._cleanup()
+
+    def _cleanup(self) -> None:
+        """Remove completed (non-looping) animations."""
+        self._animations = [a for a in self._animations if not a._completed]
+        # Clean up per-widget tracking
+        keys_to_remove: list[str] = []
+        for key, anims in self._widget_animations.items():
+            self._widget_animations[key] = [a for a in anims if not a._completed]
+            if not self._widget_animations[key]:
+                keys_to_remove.append(key)
+        for key in keys_to_remove:
+            del self._widget_animations[key]
+
+    def clear(self) -> None:
+        """Cancel all animations."""
+        for anim in self._animations:
+            anim._completed = True
+        self._animations.clear()
+        self._widget_animations.clear()
+
+    @property
+    def active_count(self) -> int:
+        """Return the number of active animations."""
+        return len(self._animations)
+
+    def create_animation(
+        self,
+        widget: Any,
+        property_name: str,
+        start_value: Any,
+        end_value: Any,
+        duration_ms: float,
+        easing: str | Callable[[float], float] = "linear",
+        on_complete: Callable[[], Any] | None = None,
+        loop: bool = False,
+        bounce: bool = False,
+    ) -> str:
+        """
+        Create, register, and return the ID of a new Animation.
+
+        :param widget: Target widget
+        :param property_name: Attribute name on the widget
+        :param start_value: Value at t = 0
+        :param end_value: Value at t = 1
+        :param duration_ms: Duration in ms
+        :param easing: Easing function or name
+        :param on_complete: Completion callback
+        :param loop: Restart on complete
+        :param bounce: Reverse direction on each cycle
+        :return: The animation ID
+        """
+        anim_id = uuid4()
+        anim = Animation(
+            animation_id=anim_id,
+            widget=widget,
+            property_name=property_name,
+            start_value=start_value,
+            end_value=end_value,
+            duration_ms=duration_ms,
+            easing=easing,
+            on_complete=on_complete,
+            loop=loop,
+            bounce=bounce,
+        )
+        self.add(anim)
+        return anim_id
