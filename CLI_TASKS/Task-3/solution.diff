+class _OffsetSurface:
+    """
+    Lightweight proxy that redirects all ``blit`` and ``pygame.draw.*`` calls
+    to an underlying surface with a constant (dx, dy) translation.  This lets
+    the widget draw pipeline work with its normal screen-space coordinates
+    while actually targeting a temporary off-screen surface for opacity
+    compositing.
+
+    Only the methods actually invoked by widget drawing code are forwarded;
+    everything else is delegated to the underlying surface.
+    """
+
+    def __init__(self, real_surface: pygame.Surface, dx: int, dy: int) -> None:
+        self._surface = real_surface
+        self._dx = dx
+        self._dy = dy
+
+    # --- forwarded drawing methods -------------------------------------------
+
+    def blit(self, source: pygame.Surface, dest: Any, *args: Any, **kwargs: Any) -> pygame.Rect:
+        if isinstance(dest, pygame.Rect):
+            dest = dest.move(self._dx, self._dy)
+        elif isinstance(dest, (tuple, list)) and len(dest) >= 2:
+            dest = (dest[0] + self._dx, dest[1] + self._dy)
+        return self._surface.blit(source, dest, *args, **kwargs)
+
+    def fill(self, *args: Any, **kwargs: Any) -> pygame.Rect:
+        return self._surface.fill(*args, **kwargs)
+
+    def get_rect(self, **kwargs: Any) -> pygame.Rect:
+        return self._surface.get_rect(**kwargs)
+
+    def get_size(self) -> tuple[int, int]:
+        return self._surface.get_size()
+
+    def get_width(self) -> int:
+        return self._surface.get_width()
+
+    def get_height(self) -> int:
+        return self._surface.get_height()
+
+    def get_abs_offset(self) -> tuple[int, int]:
+        return self._surface.get_abs_offset()
+
+    def __getattr__(self, name: str) -> Any:
+        return getattr(self._surface, name)
+
+
