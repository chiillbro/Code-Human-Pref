diff --git a/pygame_menu/transitions.py b/pygame_menu/transitions.py
new file mode 100644
index 00000000..a016d9c2
--- /dev/null
+++ b/pygame_menu/transitions.py
@@ -0,0 +1,299 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TRANSITIONS
+Pre-built animation transition helpers for common widget effects.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "fade_in",
+    "fade_out",
+    "slide_in",
+    "slide_out",
+    "scale_in",
+    "TRANSITION_FUNCTIONS",
+]
+
+from collections.abc import Callable
+from typing import TYPE_CHECKING, Any
+
+from pygame_menu.animation import (
+    Animation,
+    ease_in_quad,
+    ease_out_back,
+    ease_out_quad,
+)
+
+if TYPE_CHECKING:
+    from pygame_menu.widgets.core.widget import Widget
+
+
+def fade_in(
+    widget: Widget,
+    duration: float = 300,
+    easing: Callable[[float], float] = ease_out_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a fade-in animation (opacity 0 -> 255).
+    Sets the widget opacity to 0 and makes it visible before starting.
+
+    :param widget: Target widget
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    widget.set_opacity(0)
+    widget.show()
+    anim = Animation(
+        start_value=0,
+        end_value=255,
+        duration=duration,
+        easing=easing,
+        on_update=lambda v: widget.set_opacity(v),
+        on_complete=on_complete,
+        delay=delay,
+    )
+    anim._widget = widget
+    return anim
+
+
+def fade_out(
+    widget: Widget,
+    duration: float = 300,
+    easing: Callable[[float], float] = ease_in_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a fade-out animation (current opacity -> 0).
+    Hides the widget when the animation completes.
+
+    :param widget: Target widget
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    start = widget.get_opacity()
+
+    def _on_complete() -> None:
+        widget.hide()
+        if on_complete is not None:
+            on_complete()
+
+    anim = Animation(
+        start_value=start,
+        end_value=0,
+        duration=duration,
+        easing=easing,
+        on_update=lambda v: widget.set_opacity(v),
+        on_complete=_on_complete,
+        delay=delay,
+    )
+    anim._widget = widget
+    return anim
+
+
+def slide_in(
+    widget: Widget,
+    direction: str = "left",
+    distance: float = 50,
+    duration: float = 400,
+    easing: Callable[[float], float] = ease_out_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a slide-in animation. The widget slides from an offset position
+    to its current position.
+
+    :param widget: Target widget
+    :param direction: Direction to slide from: ``'left'``, ``'right'``, ``'up'``, ``'down'``
+    :param distance: Slide distance in pixels
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    tx, ty = widget._translate
+
+    if direction == "left":
+        widget.translate(-distance, ty)
+        anim = Animation(
+            start_value=-distance,
+            end_value=tx,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "right":
+        widget.translate(distance, ty)
+        anim = Animation(
+            start_value=distance,
+            end_value=tx,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "up":
+        widget.translate(tx, -distance)
+        anim = Animation(
+            start_value=-distance,
+            end_value=ty,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "down":
+        widget.translate(tx, distance)
+        anim = Animation(
+            start_value=distance,
+            end_value=ty,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    else:
+        raise ValueError(
+            f"invalid direction '{direction}', expected 'left', 'right', 'up', or 'down'"
+        )
+
+    anim._widget = widget
+    return anim
+
+
+def slide_out(
+    widget: Widget,
+    direction: str = "left",
+    distance: float = 50,
+    duration: float = 400,
+    easing: Callable[[float], float] = ease_in_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a slide-out animation. The widget slides from its current position
+    to an offset position.
+
+    :param widget: Target widget
+    :param direction: Direction to slide to: ``'left'``, ``'right'``, ``'up'``, ``'down'``
+    :param distance: Slide distance in pixels
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    tx, ty = widget._translate
+
+    if direction == "left":
+        end_val = tx - distance
+        anim = Animation(
+            start_value=tx,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "right":
+        end_val = tx + distance
+        anim = Animation(
+            start_value=tx,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "up":
+        end_val = ty - distance
+        anim = Animation(
+            start_value=ty,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "down":
+        end_val = ty + distance
+        anim = Animation(
+            start_value=ty,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    else:
+        raise ValueError(
+            f"invalid direction '{direction}', expected 'left', 'right', 'up', or 'down'"
+        )
+
+    anim._widget = widget
+    return anim
+
+
+def scale_in(
+    widget: Widget,
+    duration: float = 300,
+    easing: Callable[[float], float] = ease_out_back,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a scale-in animation. The widget scales from near-zero to its
+    full size.
+
+    :param widget: Target widget
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    widget.scale(0.01, 0.01, smooth=True)
+    anim = Animation(
+        start_value=0.01,
+        end_value=1.0,
+        duration=duration,
+        easing=easing,
+        on_update=lambda v: widget.scale(max(0.01, v), max(0.01, v), smooth=True),
+        on_complete=on_complete,
+        delay=delay,
+    )
+    anim._widget = widget
+    return anim
+
+
+# Mapping of transition names (used by theme) to factory functions
+TRANSITION_FUNCTIONS: dict[str, Callable[..., Animation]] = {
+    "fade_in": fade_in,
+    "slide_in_left": lambda w, **kw: slide_in(w, direction="left", **kw),
+    "slide_in_right": lambda w, **kw: slide_in(w, direction="right", **kw),
+    "slide_in_up": lambda w, **kw: slide_in(w, direction="up", **kw),
+    "slide_in_down": lambda w, **kw: slide_in(w, direction="down", **kw),
+    "scale_in": scale_in,
+}
