diff --git a/pygame_menu/animation.py b/pygame_menu/animation.py
new file mode 100644
index 00000000..d41cdae1
--- /dev/null
+++ b/pygame_menu/animation.py
@@ -0,0 +1,270 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+ANIMATION
+Animation engine for widget transitions and tweening.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "Animation",
+    "AnimationManager",
+    # Easing functions
+    "linear",
+    "ease_in_quad",
+    "ease_out_quad",
+    "ease_in_out_quad",
+    "ease_in_cubic",
+    "ease_out_back",
+    "EASING_FUNCTIONS",
+]
+
+import math
+from collections.abc import Callable
+from typing import TYPE_CHECKING, Any
+
+if TYPE_CHECKING:
+    from pygame_menu.widgets.core.widget import Widget
+
+
+# ---------------------------------------------------------------------------
+# Easing functions
+# ---------------------------------------------------------------------------
+# Each takes t in [0, 1] and returns the eased value.
+
+def linear(t: float) -> float:
+    """Linear easing (no acceleration)."""
+    return t
+
+
+def ease_in_quad(t: float) -> float:
+    """Quadratic ease-in (accelerating from zero)."""
+    return t * t
+
+
+def ease_out_quad(t: float) -> float:
+    """Quadratic ease-out (decelerating to zero)."""
+    return t * (2 - t)
+
+
+def ease_in_out_quad(t: float) -> float:
+    """Quadratic ease-in-out (accelerate then decelerate)."""
+    if t < 0.5:
+        return 2 * t * t
+    return -1 + (4 - 2 * t) * t
+
+
+def ease_in_cubic(t: float) -> float:
+    """Cubic ease-in (accelerating from zero)."""
+    return t * t * t
+
+
+def ease_out_back(t: float) -> float:
+    """Ease-out with overshoot (back effect)."""
+    c1 = 1.70158
+    c3 = c1 + 1
+    return 1 + c3 * math.pow(t - 1, 3) + c1 * math.pow(t - 1, 2)
+
+
+EASING_FUNCTIONS: dict[str, Callable[[float], float]] = {
+    "linear": linear,
+    "ease_in_quad": ease_in_quad,
+    "ease_out_quad": ease_out_quad,
+    "ease_in_out_quad": ease_in_out_quad,
+    "ease_in_cubic": ease_in_cubic,
+    "ease_out_back": ease_out_back,
+}
+
+
+# ---------------------------------------------------------------------------
+# Animation
+# ---------------------------------------------------------------------------
+
+class Animation:
+    """
+    Represents a single tween/transition that interpolates a numeric value
+    over time using an easing function.
+
+    :param start_value: Starting value
+    :param end_value: Ending value
+    :param duration: Duration in milliseconds
+    :param easing: Easing function ``f(t) -> float`` where ``t`` is in [0, 1]
+    :param on_update: Called each tick with the current interpolated value
+    :param on_complete: Called once when the animation finishes
+    :param loop: If ``True`` the animation restarts from the beginning on completion
+    :param bounce: If ``True`` the animation reverses direction on completion
+    :param delay: Delay in milliseconds before the animation starts
+    """
+
+    _completed: bool
+    _delay: float
+    _elapsed: float
+    _forward: bool
+    _value: float
+    _widget: Widget | None
+
+    def __init__(
+        self,
+        start_value: float,
+        end_value: float,
+        duration: float,
+        easing: Callable[[float], float] = linear,
+        on_update: Callable[[float], Any] | None = None,
+        on_complete: Callable[[], Any] | None = None,
+        loop: bool = False,
+        bounce: bool = False,
+        delay: float = 0,
+    ) -> None:
+        assert duration > 0, "duration must be positive"
+        assert delay >= 0, "delay cannot be negative"
+        assert callable(easing), "easing must be callable"
+
+        self._start_value = start_value
+        self._end_value = end_value
+        self._duration = float(duration)
+        self._easing = easing
+        self._on_update = on_update
+        self._on_complete = on_complete
+        self._loop = loop
+        self._bounce = bounce
+        self._delay = float(delay)
+
+        self._elapsed = 0.0
+        self._delay_elapsed = 0.0
+        self._completed = False
+        self._forward = True
+        self._value = start_value
+        self._widget = None  # Set externally for cleanup tracking
+
+    def tick(self, dt: float) -> bool:
+        """
+        Advance the animation by ``dt`` milliseconds.
+
+        :param dt: Delta time in milliseconds
+        :return: ``True`` if the animation has completed (not looping/bouncing)
+        """
+        if self._completed:
+            return True
+
+        # Handle delay
+        if self._delay_elapsed < self._delay:
+            self._delay_elapsed += dt
+            if self._delay_elapsed < self._delay:
+                return False
+            # Carry over extra time past delay
+            dt = self._delay_elapsed - self._delay
+
+        self._elapsed += dt
+
+        # Compute progress [0, 1]
+        t = min(self._elapsed / self._duration, 1.0)
+
+        # Apply direction for bounce
+        if not self._forward:
+            t = 1.0 - t
+
+        # Apply easing
+        eased_t = self._easing(t)
+
+        # Interpolate value
+        self._value = self._start_value + (self._end_value - self._start_value) * eased_t
+
+        # Notify listener
+        if self._on_update is not None:
+            self._on_update(self._value)
+
+        # Check completion
+        if self._elapsed >= self._duration:
+            if self._bounce:
+                self._elapsed = 0.0
+                self._forward = not self._forward
+            elif self._loop:
+                self._elapsed = 0.0
+            else:
+                self._completed = True
+                if self._on_complete is not None:
+                    self._on_complete()
+                return True
+
+        return False
+
+    def cancel(self) -> None:
+        """Cancel the animation immediately."""
+        self._completed = True
+
+    def is_completed(self) -> bool:
+        """Return ``True`` if the animation has finished."""
+        return self._completed
+
+    def get_current_value(self) -> float:
+        """Return the current interpolated value."""
+        return self._value
+
+
+# ---------------------------------------------------------------------------
+# AnimationManager
+# ---------------------------------------------------------------------------
+
+class AnimationManager:
+    """
+    Tracks and ticks active animations each frame. Automatically removes
+    completed animations.
+    """
+
+    _animations: list[Animation]
+
+    def __init__(self) -> None:
+        self._animations = []
+
+    def add(self, animation: Animation) -> Animation:
+        """
+        Add an animation to be managed.
+
+        :param animation: Animation instance
+        :return: The same animation (for chaining)
+        """
+        assert isinstance(animation, Animation)
+        self._animations.append(animation)
+        return animation
+
+    def tick(self, dt: float) -> None:
+        """
+        Advance all active animations by ``dt`` milliseconds and remove
+        completed ones.
+
+        :param dt: Delta time in milliseconds
+        """
+        if not self._animations:
+            return
+        # Iterate on a copy so removals during tick are safe
+        still_active: list[Animation] = []
+        for anim in self._animations:
+            if not anim.tick(dt):
+                still_active.append(anim)
+        self._animations = still_active
+
+    def remove_for_widget(self, widget: Widget) -> None:
+        """
+        Cancel and remove all animations associated with the given widget.
+
+        :param widget: Widget whose animations should be removed
+        """
+        remaining: list[Animation] = []
+        for anim in self._animations:
+            if anim._widget is widget:
+                anim.cancel()
+            else:
+                remaining.append(anim)
+        self._animations = remaining
+
+    def cancel_all(self) -> None:
+        """Cancel all active animations."""
+        for anim in self._animations:
+            anim.cancel()
+        self._animations.clear()
+
+    def is_empty(self) -> bool:
+        """Return ``True`` if there are no active animations."""
+        return len(self._animations) == 0
