+    duration: float = 0.35,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_out_quad,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Slide a widget in from the left while fading in.
+
+    :param widget: Target widget
+    :param distance: Horizontal offset to start from (px)
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param easing: Easing function
+    :param on_complete: Optional completion callback
+    """
+    return _slide_in(widget, -distance, 0, duration, delay, easing, on_complete)
+
+
+def slide_in_right(
+    widget: pygame_menu.widgets.Widget,
+    distance: int = 60,
+    duration: float = 0.35,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_out_quad,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Slide a widget in from the right while fading in.
+
+    :param widget: Target widget
+    :param distance: Horizontal offset to start from (px)
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param easing: Easing function
+    :param on_complete: Optional completion callback
+    """
+    return _slide_in(widget, distance, 0, duration, delay, easing, on_complete)
+
+
+def slide_in_top(
+    widget: pygame_menu.widgets.Widget,
+    distance: int = 40,
+    duration: float = 0.35,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_out_quad,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Slide a widget in from the top while fading in.
+
+    :param widget: Target widget
+    :param distance: Vertical offset to start from (px)
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param easing: Easing function
+    :param on_complete: Optional completion callback
+    """
+    return _slide_in(widget, 0, -distance, duration, delay, easing, on_complete)
+
+
+def slide_in_bottom(
+    widget: pygame_menu.widgets.Widget,
+    distance: int = 40,
+    duration: float = 0.35,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_out_quad,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Slide a widget in from the bottom while fading in.
+
+    :param widget: Target widget
+    :param distance: Vertical offset to start from (px)
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param easing: Easing function
+    :param on_complete: Optional completion callback
+    """
+    return _slide_in(widget, 0, distance, duration, delay, easing, on_complete)
+
+
+# ---------------------------------------------------------------------------
+# Scale transition (opacity-based approximation)
+# ---------------------------------------------------------------------------
+
+def scale_in(
+    widget: pygame_menu.widgets.Widget,
+    duration: float = 0.35,
+    delay: float = 0.0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Fade the widget in with an ease-out-back easing to give a "grow/pop-in" feel.
+
+    :param widget: Target widget
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param on_complete: Optional completion callback
+    """
+    return fade_in(
+        widget,
+        duration=duration,
+        delay=delay,
+        easing=ease_out_back,
+        on_complete=on_complete,
+    )
+
+
+def bounce_in(
+    widget: pygame_menu.widgets.Widget,
+    duration: float = 0.5,
+    delay: float = 0.0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Fade a widget in with a bouncy overshoot easing.
+
+    :param widget: Target widget
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param on_complete: Optional completion callback
+    """
+    return fade_in(
+        widget,
+        duration=duration,
+        delay=delay,
+        easing=ease_out_back,
+        on_complete=on_complete,
+    )
