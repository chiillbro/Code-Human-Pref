diff --git a/pygame_menu/animation.py b/pygame_menu/animation.py
new file mode 100644
index 00000000..94043679
--- /dev/null
+++ b/pygame_menu/animation.py
@@ -0,0 +1,373 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+ANIMATION
+Animation engine: easing functions, Animation class, and AnimationManager.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    # Easing functions
+    "ease_in_cubic",
+    "ease_in_out_quad",
+    "ease_in_quad",
+    "ease_out_back",
+    "ease_out_quad",
+    "linear",
+    # Classes
+    "Animation",
+    "AnimationManager",
+    # Loop modes
+    "ANIMATION_LOOP_NONE",
+    "ANIMATION_LOOP_LOOP",
+    "ANIMATION_LOOP_BOUNCE",
+]
+
+import time
+from collections.abc import Callable
+from typing import Any
+
+# ---------------------------------------------------------------------------
+# Loop mode constants
+# ---------------------------------------------------------------------------
+ANIMATION_LOOP_NONE = "none"
+ANIMATION_LOOP_LOOP = "loop"
+ANIMATION_LOOP_BOUNCE = "bounce"
+
+EasingType = Callable[[float], float]
+
+
+# ---------------------------------------------------------------------------
+# Easing functions  (t in [0, 1] -> value in [0, 1])
+# ---------------------------------------------------------------------------
+
+def linear(t: float) -> float:
+    """Linear easing – no acceleration."""
+    return t
+
+
+def ease_in_quad(t: float) -> float:
+    """Quadratic ease-in – accelerates from zero velocity."""
+    return t * t
+
+
+def ease_out_quad(t: float) -> float:
+    """Quadratic ease-out – decelerates to zero velocity."""
+    return t * (2 - t)
+
+
+def ease_in_out_quad(t: float) -> float:
+    """Quadratic ease-in-out – accelerates then decelerates."""
+    if t < 0.5:
+        return 2 * t * t
+    return -1 + (4 - 2 * t) * t
+
+
+def ease_in_cubic(t: float) -> float:
+    """Cubic ease-in – accelerates from zero velocity (stronger than quad)."""
+    return t * t * t
+
+
+def ease_out_back(t: float) -> float:
+    """Ease-out with a slight overshoot (back easing)."""
+    c1 = 1.70158
+    c3 = c1 + 1
+    return 1 + c3 * pow(t - 1, 3) + c1 * pow(t - 1, 2)
+
+
+# ---------------------------------------------------------------------------
+# Animation
+# ---------------------------------------------------------------------------
+
+class Animation:
+    """
+    Represents a single tween/transition between two numeric values.
+
+    The animation interpolates ``start_value`` → ``end_value`` over
+    ``duration`` seconds using an ``easing`` function.
+
+    :param start_value: Starting value of the animation
+    :param end_value: Target value of the animation
+    :param duration: Duration of the animation in seconds
+    :param on_update: Callback called each frame with the current interpolated value
+    :param on_complete: Optional callback called once the animation finishes
+    :param easing: Easing function to use (defaults to ``linear``)
+    :param loop: Loop mode – one of ``ANIMATION_LOOP_NONE``, ``ANIMATION_LOOP_LOOP``,
+        ``ANIMATION_LOOP_BOUNCE``
+    :param delay: Delay in seconds before the animation starts
+    """
+
+    _start_value: float
+    _end_value: float
+    _duration: float
+    _on_update: Callable[[float], Any]
+    _on_complete: Callable[[], Any] | None
+    _easing: EasingType
+    _loop: str
+    _delay: float
+
+    _elapsed: float       # seconds elapsed since animation started (after delay)
+    _delay_elapsed: float # seconds elapsed during the delay phase
+    _started: bool
+    _finished: bool
+    _direction: int       # +1 forward, -1 reverse (for bounce)
+
+    def __init__(
+        self,
+        start_value: float,
+        end_value: float,
+        duration: float,
+        on_update: Callable[[float], Any],
+        on_complete: Callable[[], Any] | None = None,
+        easing: EasingType = linear,
+        loop: str = ANIMATION_LOOP_NONE,
+        delay: float = 0.0,
+    ) -> None:
+        assert duration > 0, "animation duration must be greater than zero"
+        assert loop in (ANIMATION_LOOP_NONE, ANIMATION_LOOP_LOOP, ANIMATION_LOOP_BOUNCE), \
+            f"unknown loop mode '{loop}'"
+        assert callable(on_update), "on_update must be callable"
+        assert on_complete is None or callable(on_complete), \
+            "on_complete must be callable or None"
+        assert callable(easing), "easing must be callable"
+        assert delay >= 0, "delay must be >= 0"
+
+        self._start_value = float(start_value)
+        self._end_value = float(end_value)
+        self._duration = float(duration)
+        self._on_update = on_update
+        self._on_complete = on_complete
+        self._easing = easing
+        self._loop = loop
+        self._delay = float(delay)
+
+        self._elapsed = 0.0
+        self._delay_elapsed = 0.0
+        self._started = False
+        self._finished = False
+        self._direction = 1
+
+    # ------------------------------------------------------------------
+    # Properties
+    # ------------------------------------------------------------------
+
+    def is_finished(self) -> bool:
+        """Return ``True`` if the animation has completed."""
+        return self._finished
+
+    def get_progress(self) -> float:
+        """Return the raw progress ``t`` in ``[0, 1]``."""
+        if self._duration == 0:
+            return 1.0
+        t = max(0.0, min(1.0, self._elapsed / self._duration))
+        if self._direction == -1:
+            t = 1.0 - t
+        return t
+
+    def get_value(self) -> float:
+        """Return the current interpolated value."""
+        t = self.get_progress()
+        eased = self._easing(t)
+        return self._start_value + (self._end_value - self._start_value) * eased
+
+    # ------------------------------------------------------------------
+    # Control
+    # ------------------------------------------------------------------
+
+    def reset(self) -> Animation:
+        """Reset the animation to the beginning."""
+        self._elapsed = 0.0
+        self._delay_elapsed = 0.0
+        self._finished = False
+        self._direction = 1
+        return self
+
+    def finish(self) -> Animation:
+        """Jump immediately to the end of the animation and fire on_complete."""
+        self._elapsed = self._duration
+        self._finished = True
+        value = self._end_value if self._direction == 1 else self._start_value
+        self._on_update(value)
+        if self._on_complete is not None:
+            self._on_complete()
+        return self
+
+    # ------------------------------------------------------------------
+    # Tick
+    # ------------------------------------------------------------------
+
+    def tick(self, dt: float) -> bool:
+        """
+        Advance the animation by ``dt`` seconds.
+
+        :param dt: Delta time in seconds
+        :return: ``True`` if the animation is still running, ``False`` if finished
+        """
+        if self._finished:
+            return False
+
+        # Handle delay phase
+        if self._delay_elapsed < self._delay:
+            self._delay_elapsed += dt
+            if self._delay_elapsed < self._delay:
+                return True  # Still in delay
+            # Consume the overshoot
+            dt = self._delay_elapsed - self._delay
+
+        self._elapsed += dt
+
+        if self._elapsed >= self._duration:
+            # End of one cycle
+            if self._loop == ANIMATION_LOOP_NONE:
+                self._elapsed = self._duration
+                self._finished = True
+                self._on_update(self.get_value())
+                if self._on_complete is not None:
+                    self._on_complete()
+                return False
+
+            elif self._loop == ANIMATION_LOOP_LOOP:
+                self._elapsed = self._elapsed % self._duration
+                self._on_update(self.get_value())
+                return True
+
+            elif self._loop == ANIMATION_LOOP_BOUNCE:
+                overshoot = self._elapsed - self._duration
+                self._elapsed = self._duration - overshoot
+                self._direction *= -1  # Reverse direction
+                self._on_update(self.get_value())
+                return True
+
+        self._on_update(self.get_value())
+        return True
+
+
+# ---------------------------------------------------------------------------
+# AnimationManager
+# ---------------------------------------------------------------------------
+
+class AnimationManager:
+    """
+    Tracks and ticks all active :py:class:`Animation` instances each frame.
+
+    A single ``AnimationManager`` is owned by each :py:class:`pygame_menu.Menu`
+    and updated once per frame inside ``mainloop()`` / ``draw()``.
+    """
+
+    _animations: list[Animation]
+    # Maps an owner object (e.g. a Widget) to its animations for quick cleanup
+    _owner_map: dict[int, list[Animation]]
+
+    def __init__(self) -> None:
+        self._animations = []
+        self._owner_map = {}
+
+    # ------------------------------------------------------------------
+    # Animation lifecycle
+    # ------------------------------------------------------------------
+
+    def add(
+        self,
+        animation: Animation,
+        owner: Any = None,
+    ) -> Animation:
+        """
+        Register an animation for tracking.
+
+        :param animation: Animation to track
+        :param owner: Optional owner object (e.g. a Widget).  When ``owner``
+            is removed from the menu all its animations are stopped automatically.
+        :return: The animation (for chaining)
+        """
+        self._animations.append(animation)
+        if owner is not None:
+            key = id(owner)
+            if key not in self._owner_map:
+                self._owner_map[key] = []
+            self._owner_map[key].append(animation)
+        return animation
+
+    def remove(self, animation: Animation) -> None:
+        """
+        Remove a specific animation from tracking (does not fire on_complete).
+
+        :param animation: Animation to remove
+        """
+        try:
+            self._animations.remove(animation)
+        except ValueError:
+            pass
+        # Remove from owner map too
+        for key in list(self._owner_map.keys()):
+            lst = self._owner_map[key]
+            if animation in lst:
+                lst.remove(animation)
+                if not lst:
+                    del self._owner_map[key]
+                break
+
+    def remove_owner(self, owner: Any) -> None:
+        """
+        Remove all animations that belong to the given owner.
+
+        This is called automatically when a widget is removed from the menu
+        while an animation is still running.
+
+        :param owner: Owner object (typically a Widget)
+        """
+        key = id(owner)
+        if key not in self._owner_map:
+            return
+        for anim in self._owner_map[key]:
+            try:
+                self._animations.remove(anim)
+            except ValueError:
+                pass
+        del self._owner_map[key]
+
+    def clear(self) -> None:
+        """Remove all animations."""
+        self._animations.clear()
+        self._owner_map.clear()
+
+    # ------------------------------------------------------------------
+    # Per-frame tick
+    # ------------------------------------------------------------------
+
+    def tick(self, dt: float) -> None:
+        """
+        Advance all animations by ``dt`` seconds and remove finished ones.
+
+        :param dt: Delta time in seconds
+        """
+        if not self._animations:
+            return
+        finished: list[Animation] = []
+        for anim in self._animations:
+            still_running = anim.tick(dt)
+            if not still_running:
+                finished.append(anim)
+        for anim in finished:
+            self.remove(anim)
+
+    # ------------------------------------------------------------------
+    # Queries
+    # ------------------------------------------------------------------
+
+    def is_empty(self) -> bool:
+        """Return ``True`` if there are no active animations."""
+        return len(self._animations) == 0
+
+    def count(self) -> int:
+        """Return the number of active animations."""
+        return len(self._animations)
+
+    def has_owner(self, owner: Any) -> bool:
+        """
+        Return ``True`` if the owner has at least one active animation.
+
+        :param owner: Owner object
+        """
+        return id(owner) in self._owner_map and bool(self._owner_map[id(owner)])
