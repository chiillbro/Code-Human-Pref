diff --git a/pygame_menu/transitions.py b/pygame_menu/transitions.py
new file mode 100644
index 00000000..2165d5b2
--- /dev/null
+++ b/pygame_menu/transitions.py
@@ -0,0 +1,356 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TRANSITIONS
+Pre-built transition helpers that operate on Widget instances.
+All helpers return the created :py:class:`pygame_menu.animation.Animation`
+so callers can chain or inspect them.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "fade_in",
+    "fade_out",
+    "fade_in_out",
+    "slide_in_left",
+    "slide_in_right",
+    "slide_in_top",
+    "slide_in_bottom",
+    "scale_in",
+    "bounce_in",
+]
+
+from collections.abc import Callable
+from typing import TYPE_CHECKING, Any
+
+from pygame_menu.animation import (
+    Animation,
+    AnimationManager,
+    ANIMATION_LOOP_NONE,
+    ease_in_out_quad,
+    ease_out_back,
+    ease_out_quad,
+    linear,
+)
+
+if TYPE_CHECKING:
+    import pygame_menu
+
+
+# ---------------------------------------------------------------------------
+# Internal helper
+# ---------------------------------------------------------------------------
+
+def _get_manager(widget: pygame_menu.widgets.Widget) -> AnimationManager | None:
+    """Return the AnimationManager from the widget's parent menu, or None."""
+    menu = widget.get_menu()
+    if menu is None:
+        return None
+    return getattr(menu, "_animation_manager", None)
+
+
+# ---------------------------------------------------------------------------
+# Opacity transitions
+# ---------------------------------------------------------------------------
+
+def fade_in(
+    widget: pygame_menu.widgets.Widget,
+    duration: float = 0.4,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_out_quad,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Fade a widget from fully transparent to fully opaque.
+
+    :param widget: Target widget
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param easing: Easing function
+    :param on_complete: Optional completion callback
+    :return: Created :py:class:`Animation`, or ``None`` if no manager available
+    """
+    manager = _get_manager(widget)
+    if manager is None:
+        return None
+    manager.remove_owner(widget)  # Cancel previous animations on this widget
+
+    widget.set_opacity(0)
+
+    anim = Animation(
+        start_value=0,
+        end_value=255,
+        duration=duration,
+        on_update=lambda v: widget.set_opacity(int(v)),
+        on_complete=on_complete,
+        easing=easing,
+        loop=ANIMATION_LOOP_NONE,
+        delay=delay,
+    )
+    manager.add(anim, owner=widget)
+    return anim
+
+
+def fade_out(
+    widget: pygame_menu.widgets.Widget,
+    duration: float = 0.4,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_in_out_quad,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Fade a widget from fully opaque to fully transparent.
+
+    :param widget: Target widget
+    :param duration: Duration in seconds
+    :param delay: Delay before starting in seconds
+    :param easing: Easing function
+    :param on_complete: Optional completion callback
+    :return: Created :py:class:`Animation`, or ``None`` if no manager available
+    """
+    manager = _get_manager(widget)
+    if manager is None:
+        return None
+    manager.remove_owner(widget)
+
+    widget.set_opacity(255)
+
+    anim = Animation(
+        start_value=255,
+        end_value=0,
+        duration=duration,
+        on_update=lambda v: widget.set_opacity(int(v)),
+        on_complete=on_complete,
+        easing=easing,
+        loop=ANIMATION_LOOP_NONE,
+        delay=delay,
+    )
+    manager.add(anim, owner=widget)
+    return anim
+
+
+def fade_in_out(
+    widget: pygame_menu.widgets.Widget,
+    duration: float = 0.8,
+    delay: float = 0.0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation | None:
+    """
+    Fade a widget in then out (pulse).
+
+    :param widget: Target widget
+    :param duration: Total duration of a single in→out cycle in seconds
+    :param delay: Delay before starting in seconds
+    :param on_complete: Optional completion callback
+    :return: Created :py:class:`Animation`, or ``None`` if no manager available
+    """
+    from pygame_menu.animation import ANIMATION_LOOP_BOUNCE
+
+    manager = _get_manager(widget)
+    if manager is None:
+        return None
+    manager.remove_owner(widget)
+
+    widget.set_opacity(0)
+
+    anim = Animation(
+        start_value=0,
+        end_value=255,
+        duration=duration / 2,
+        on_update=lambda v: widget.set_opacity(int(v)),
+        on_complete=on_complete,
+        easing=ease_in_out_quad,
+        loop=ANIMATION_LOOP_BOUNCE,
+        delay=delay,
+    )
+    manager.add(anim, owner=widget)
+    return anim
+
+
+# ---------------------------------------------------------------------------
+# Slide transitions (translation-based)
+# ---------------------------------------------------------------------------
+
+def _slide_in(
+    widget: pygame_menu.widgets.Widget,
+    offset_start_x: int,
+    offset_start_y: int,
+    duration: float = 0.35,
+    delay: float = 0.0,
+    easing: Callable[[float], float] = ease_out_quad,
+    on_complete: Callable[[], Any] | None = None,
