+class _OffsetSurface(pygame.Surface):
+    """
+    A lightweight :py:class:`pygame.Surface` subclass that transparently
+    remaps ``blit`` destination coordinates by a fixed offset.
+
+    Because it inherits from the real C-level ``Surface``, instances are
+    accepted by ``pygame.draw.*`` functions.  Those functions write to the
+    underlying pixel buffer using the coordinates they receive directly
+    (typically via the widget's :py:meth:`get_rect`, which already applies
+    ``Widget._draw_offset``).  ``blit()`` calls, on the other hand, receive
+    their destination from the caller, so this subclass subtracts the offset
+    before delegating to the parent implementation.
+    """
+
+    __slots__ = ("_ox", "_oy")
+
+    def __init__(self, width: int, height: int, ox: int, oy: int) -> None:
+        super().__init__((width, height), pygame.SRCALPHA, 32)
+        self._ox = ox
+        self._oy = oy
+
+    # noinspection PyMethodOverriding
+    def blit(self, source: pygame.Surface, dest, *args, **kwargs):  # type: ignore
+        if isinstance(dest, pygame.Rect):
+            dest = pygame.Rect(
+                dest.x - self._ox, dest.y - self._oy,
+                dest.width, dest.height,
+            )
+        elif isinstance(dest, (tuple, list)):
+            dest = (dest[0] - self._ox, dest[1] - self._oy)
+        return super().blit(source, dest, *args, **kwargs)
+
+
