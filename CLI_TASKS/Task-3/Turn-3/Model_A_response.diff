+class _OffsetSurface:
+    """
+    Lightweight proxy that wraps a :py:class:`pygame.Surface` off-screen buffer
+    and transparently remaps every ``blit()`` destination so that widgets can
+    draw using their real absolute-coordinate positions while the pixels land
+    in the correct location inside a smaller local buffer.
+
+    For example, if a widget sits at ``(ox, oy)`` on the shared widgets surface
+    and the buffer represents only the widget's bounding rect, constructing
+    ``_OffsetSurface(buffer, ox, oy)`` means that a blit to ``(ox + dx, oy + dy)``
+    on this proxy will land at ``(dx, dy)`` in the real buffer.
+
+    The raw inner surface is exposed via :py:attr:`surface` for the rare cases
+    where a real :py:class:`pygame.Surface` is required (e.g. ``pygame.draw.*``
+    C-level functions).  Callers that use the inner surface directly are
+    responsible for shifting their own coordinates.
+    """
+
+    __slots__ = ("_surface", "_ox", "_oy")
+
+    def __init__(self, surface: pygame.Surface, ox: int, oy: int) -> None:
+        self._surface = surface
+        self._ox = ox
+        self._oy = oy
+
+    # ------------------------------------------------------------------
+    # Surface-like interface used by _draw_* methods and decorators
+    # ------------------------------------------------------------------
+
+    def blit(
+        self,
+        source: pygame.Surface,
+        dest: tuple | pygame.Rect,
+        area: pygame.Rect | None = None,
+        special_flags: int = 0,
+    ) -> pygame.Rect:
+        """Blit ``source`` onto the inner buffer, offsetting ``dest`` by ``(-ox, -oy)``."""
+        if isinstance(dest, pygame.Rect):
+            shifted = pygame.Rect(dest.x - self._ox, dest.y - self._oy, dest.w, dest.h)
+        else:
+            shifted = (dest[0] - self._ox, dest[1] - self._oy)
+        if area is not None:
+            return self._surface.blit(source, shifted, area, special_flags)
+        return self._surface.blit(source, shifted, special_flags=special_flags)
+
+    def fill(
+        self,
+        color: tuple,
+        rect: pygame.Rect | None = None,
+        special_flags: int = 0,
+    ) -> pygame.Rect:
+        """Fill the inner buffer, shifting ``rect`` if provided."""
+        if rect is not None:
+            shifted = pygame.Rect(
+                rect.x - self._ox, rect.y - self._oy, rect.w, rect.h
+            )
+            return self._surface.fill(color, shifted, special_flags)
+        return self._surface.fill(color, special_flags=special_flags)
+
+    def get_rect(self, **kwargs) -> pygame.Rect:
+        """Return the rect of the inner buffer, offset to the proxy's origin."""
+        r = self._surface.get_rect(**kwargs)
+        r.x += self._ox
+        r.y += self._oy
+        return r
+
+    def get_width(self) -> int:
+        return self._surface.get_width()
+
+    def get_height(self) -> int:
+        return self._surface.get_height()
+
+    def get_size(self) -> tuple[int, int]:
+        return self._surface.get_size()
+
+    def get_flags(self) -> int:
+        return self._surface.get_flags()
+
+    def set_alpha(self, value: int, flags: int = 0) -> None:
+        self._surface.set_alpha(value, flags)
+
+    def get_alpha(self) -> int | None:
+        return self._surface.get_alpha()
+
+    @property
+    def surface(self) -> pygame.Surface:
+        """The underlying real :py:class:`pygame.Surface` buffer."""
+        return self._surface
+
+
