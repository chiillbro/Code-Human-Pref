+# ---------------------------------------------------------------------------
+# fade_in integration test (transitions module)
+# ---------------------------------------------------------------------------
+
+class TestFadeInIntegration:
+
+    def test_fade_in_registered_and_ticks(self):
+        """transitions.fade_in() must add to menu manager and animate opacity."""
+        from pygame_menu import transitions
+
+        menu = MenuUtils.generic_menu(title="Fade")
+        label = menu.add.label("hello")
+
+        # fade_in sets opacity to 0, makes visible, and registers animation
+        anim = transitions.fade_in(label, duration=300)
+
+        assert label.get_opacity() == 0
+        assert label.is_visible()
+        assert not menu.get_animation_manager().is_empty()
+        assert anim._widget is label
+
+        # Tick halfway through. ease_out_quad(0.5) = 0.5*(2-0.5) = 0.75,
+        # so expected opacity = 0.75 * 255 ≈ 191.
+        menu.get_animation_manager().tick(150)
+        assert label.get_opacity() == pytest.approx(191, abs=5)
+
+        # Tick to completion
+        menu.get_animation_manager().tick(150)
+        assert label.get_opacity() == 255
+        assert menu.get_animation_manager().is_empty()
+
+    def test_fade_in_without_menu_still_returns_animation(self):
+        """fade_in on a widget with no menu returns an Animation, just not registered."""
+        from pygame_menu import transitions
+        from pygame_menu.widgets.widget.label import Label
+
+        # Create a label not attached to any menu
+        label = Label(title="orphan")
+        anim = transitions.fade_in(label, duration=200)
+
+        assert isinstance(anim, Animation)
+        assert anim._widget is label
+        # No menu → manager not available; animation must still tick manually
+        anim.tick(200)
+        assert label.get_opacity() == 255
+
+    def test_fade_out_hides_widget_on_complete(self):
+        """transitions.fade_out() hides the widget when done."""
+        from pygame_menu import transitions
+
+        menu = MenuUtils.generic_menu(title="FadeOut")
+        label = menu.add.label("bye")
+        label.set_opacity(255)
+
+        transitions.fade_out(label, duration=200)
+
+        # Run the animation to completion
+        menu.get_animation_manager().tick(200)
+        assert label.get_opacity() == 0
+        assert not label.is_visible(check_frame=False)
+
+    def test_animation_cleanup_on_widget_removal(self):
+        """Removing a widget mid-animation cancels and removes its animations."""
+        from pygame_menu import transitions
+
+        menu = MenuUtils.generic_menu(title="Cleanup")
+        label = menu.add.label("remove me")
