+        menu, label = self._make_label()
+        label.set_opacity(0)
+        # Use ease_out_back which overshoots; clamp should keep opacity in [0, 255]
+        anim = label.animate_opacity(255, duration=300, easing=ease_out_back)
+        # Tick to the overshoot region
+        menu.get_animation_manager().tick(280)
+        # Clamping must have kept opacity at most 255
+        assert label.get_opacity() <= 255
+        assert label.get_opacity() >= 0
