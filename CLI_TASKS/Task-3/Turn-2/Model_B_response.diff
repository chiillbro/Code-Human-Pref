diff --git a/pygame_menu/transitions.py b/pygame_menu/transitions.py
new file mode 100644
index 00000000..4574b613
--- /dev/null
+++ b/pygame_menu/transitions.py
@@ -0,0 +1,314 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TRANSITIONS
+Pre-built animation transition helpers for common widget effects.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "fade_in",
+    "fade_out",
+    "slide_in",
+    "slide_out",
+    "scale_in",
+    "TRANSITION_FUNCTIONS",
+]
+
+from collections.abc import Callable
+from typing import TYPE_CHECKING, Any
+
+from pygame_menu.animation import (
+    Animation,
+    ease_in_quad,
+    ease_out_back,
+    ease_out_quad,
+)
+
+if TYPE_CHECKING:
+    from pygame_menu.widgets.core.widget import Widget
+
+
+def _register(anim: Animation, widget: Widget) -> Animation:
+    """
+    Set the widget reference on the animation and, if the widget belongs to a
+    menu, add the animation to that menu's :py:class:`~pygame_menu.animation.AnimationManager`
+    so it is ticked automatically each frame.
+
+    :param anim: Animation to register
+    :param widget: Owner widget
+    :return: The same animation (for chaining)
+    """
+    anim._widget = widget
+    if widget._menu is not None:
+        widget._menu.get_animation_manager().add(anim)
+    return anim
+
+
+def fade_in(
+    widget: Widget,
+    duration: float = 300,
+    easing: Callable[[float], float] = ease_out_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a fade-in animation (opacity 0 -> 255).
+    Sets the widget opacity to 0 and makes it visible before starting.
+
+    :param widget: Target widget
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    widget.set_opacity(0)
+    widget.show()
+    anim = Animation(
+        start_value=0,
+        end_value=255,
+        duration=duration,
+        easing=easing,
+        on_update=lambda v: widget.set_opacity(v),
+        on_complete=on_complete,
+        delay=delay,
+        value_min=0,
+        value_max=255,
+    )
+    return _register(anim, widget)
+
+
+def fade_out(
+    widget: Widget,
+    duration: float = 300,
+    easing: Callable[[float], float] = ease_in_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a fade-out animation (current opacity -> 0).
+    Hides the widget when the animation completes.
+
+    :param widget: Target widget
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    start = widget.get_opacity()
+
+    def _on_complete() -> None:
+        widget.hide()
+        if on_complete is not None:
+            on_complete()
+
+    anim = Animation(
+        start_value=start,
+        end_value=0,
+        duration=duration,
+        easing=easing,
+        on_update=lambda v: widget.set_opacity(v),
+        on_complete=_on_complete,
+        delay=delay,
+        value_min=0,
+        value_max=255,
+    )
+    return _register(anim, widget)
+
+
+def slide_in(
+    widget: Widget,
+    direction: str = "left",
+    distance: float = 50,
+    duration: float = 400,
+    easing: Callable[[float], float] = ease_out_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a slide-in animation. The widget slides from an offset position
+    to its current position.
+
+    :param widget: Target widget
+    :param direction: Direction to slide from: ``'left'``, ``'right'``, ``'up'``, ``'down'``
+    :param distance: Slide distance in pixels
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    tx, ty = widget._translate
+
+    if direction == "left":
+        widget.translate(-distance, ty)
+        anim = Animation(
+            start_value=-distance,
+            end_value=tx,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "right":
+        widget.translate(distance, ty)
+        anim = Animation(
+            start_value=distance,
+            end_value=tx,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "up":
+        widget.translate(tx, -distance)
+        anim = Animation(
+            start_value=-distance,
+            end_value=ty,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "down":
+        widget.translate(tx, distance)
+        anim = Animation(
+            start_value=distance,
+            end_value=ty,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    else:
+        raise ValueError(
+            f"invalid direction '{direction}', expected 'left', 'right', 'up', or 'down'"
+        )
+
+    return _register(anim, widget)
+
+
+def slide_out(
+    widget: Widget,
+    direction: str = "left",
+    distance: float = 50,
+    duration: float = 400,
+    easing: Callable[[float], float] = ease_in_quad,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a slide-out animation. The widget slides from its current position
+    to an offset position.
+
+    :param widget: Target widget
+    :param direction: Direction to slide to: ``'left'``, ``'right'``, ``'up'``, ``'down'``
+    :param distance: Slide distance in pixels
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    tx, ty = widget._translate
+
+    if direction == "left":
+        end_val = tx - distance
+        anim = Animation(
+            start_value=tx,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "right":
+        end_val = tx + distance
+        anim = Animation(
+            start_value=tx,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(int(v), ty),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "up":
+        end_val = ty - distance
+        anim = Animation(
+            start_value=ty,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    elif direction == "down":
+        end_val = ty + distance
+        anim = Animation(
+            start_value=ty,
+            end_value=end_val,
+            duration=duration,
+            easing=easing,
+            on_update=lambda v: widget.translate(tx, int(v)),
+            on_complete=on_complete,
+            delay=delay,
+        )
+    else:
+        raise ValueError(
+            f"invalid direction '{direction}', expected 'left', 'right', 'up', or 'down'"
+        )
+
+    return _register(anim, widget)
+
+
+def scale_in(
+    widget: Widget,
+    duration: float = 300,
+    easing: Callable[[float], float] = ease_out_back,
+    delay: float = 0,
+    on_complete: Callable[[], Any] | None = None,
+) -> Animation:
+    """
+    Create a scale-in animation. The widget scales from near-zero to its
+    full size.
+
+    :param widget: Target widget
+    :param duration: Duration in milliseconds
+    :param easing: Easing function
+    :param delay: Delay before starting in milliseconds
+    :param on_complete: Called when animation finishes
+    :return: Animation instance
+    """
+    widget.scale(0.01, 0.01, smooth=True)
+    anim = Animation(
+        start_value=0.01,
+        end_value=1.0,
+        duration=duration,
+        easing=easing,
+        on_update=lambda v: widget.scale(max(0.01, v), max(0.01, v), smooth=True),
+        on_complete=on_complete,
+        delay=delay,
+    )
+    return _register(anim, widget)
+
+
+# Mapping of transition names (used by theme) to factory functions
