+# ---------------------------------------------------------------------------
+# AnimationManager lifecycle tests
+# ---------------------------------------------------------------------------
+
+class TestAnimationManager:
+
+    def test_add_and_is_empty(self):
+        mgr = AnimationManager()
+        assert mgr.is_empty()
+        anim = Animation(start_value=0, end_value=10, duration=100)
+        mgr.add(anim)
+        assert not mgr.is_empty()
+
+    def test_add_returns_animation(self):
+        mgr = AnimationManager()
+        anim = Animation(start_value=0, end_value=10, duration=100)
+        returned = mgr.add(anim)
+        assert returned is anim
+
+    def test_tick_advances_and_removes_completed(self):
+        mgr = AnimationManager()
+        done = [False]
+        anim = Animation(
+            start_value=0,
+            end_value=10,
+            duration=100,
+            on_complete=lambda: done.__setitem__(0, True),
+        )
+        mgr.add(anim)
+        mgr.tick(100)
+        assert done[0]
+        assert mgr.is_empty()
+
+    def test_tick_keeps_active(self):
+        mgr = AnimationManager()
+        anim = Animation(start_value=0, end_value=100, duration=500)
+        mgr.add(anim)
+        mgr.tick(100)  # only 100ms of 500ms elapsed
+        assert not mgr.is_empty()
+
+    def test_cancel_all(self):
+        mgr = AnimationManager()
+        for _ in range(3):
+            mgr.add(Animation(start_value=0, end_value=1, duration=1000))
+        mgr.cancel_all()
+        assert mgr.is_empty()
+
+    def test_remove_for_widget(self):
+        """remove_for_widget cancels and removes only matching animations."""
+        mgr = AnimationManager()
+
+        # Create a fake widget sentinel
+        class FakeWidget:
+            pass
+
+        w1, w2 = FakeWidget(), FakeWidget()
+
+        anim_w1 = Animation(start_value=0, end_value=1, duration=500)
+        anim_w1._widget = w1
+
+        anim_w2 = Animation(start_value=0, end_value=1, duration=500)
+        anim_w2._widget = w2
+
+        mgr.add(anim_w1)
+        mgr.add(anim_w2)
+
+        mgr.remove_for_widget(w1)
+
+        # w1 animation removed, w2 still active
+        assert len(mgr._animations) == 1
+        assert mgr._animations[0]._widget is w2
+        assert anim_w1.is_completed()
+        assert not anim_w2.is_completed()
+
+    def test_multiple_animations_tick_independently(self):
+        """Each animation in the manager ticks with the same dt."""
+        values_a, values_b = [], []
+        mgr = AnimationManager()
+        mgr.add(
+            Animation(
+                start_value=0,
+                end_value=100,
+                duration=1000,
+                easing=linear,
+                on_update=values_a.append,
+            )
+        )
+        mgr.add(
+            Animation(
+                start_value=200,
+                end_value=300,
+                duration=500,
+                easing=linear,
+                on_update=values_b.append,
+            )
+        )
+        mgr.tick(500)
+        # First animation: 500/1000 = 0.5 → value 50
+        assert values_a[-1] == pytest.approx(50.0)
+        # Second animation: 500/500 = 1.0 → value 300 (completed)
+        assert values_b[-1] == pytest.approx(300.0)
+        # Second animation removed from manager
+        assert len(mgr._animations) == 1
+
