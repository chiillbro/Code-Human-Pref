+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST ANIMATION
+Unit tests for the animation engine, AnimationManager, and transitions.
+"""
+
+import pytest
+
+import pygame_menu
+from pygame_menu.animation import (
+    Animation,
+    AnimationManager,
+    EASING_FUNCTIONS,
+    ease_in_cubic,
+    ease_in_out_quad,
+    ease_in_quad,
+    ease_out_back,
+    ease_out_quad,
+    linear,
+)
+from test._utils import MenuUtils, surface
+
+
+# ---------------------------------------------------------------------------
+# Easing function boundary tests
+# ---------------------------------------------------------------------------
+
+class TestEasingFunctions:
+    """Each easing must satisfy f(0) == 0 and f(1) == 1 (except ease_out_back
+    which is allowed to overshoot above 1 for t near 1)."""
+
+    def test_linear_boundaries(self):
+        assert linear(0) == pytest.approx(0.0)
+        assert linear(1) == pytest.approx(1.0)
+        assert linear(0.5) == pytest.approx(0.5)
+
+    def test_ease_in_quad_boundaries(self):
+        assert ease_in_quad(0) == pytest.approx(0.0)
+        assert ease_in_quad(1) == pytest.approx(1.0)
+        # Accelerating: output at 0.5 should be less than 0.5
+        assert ease_in_quad(0.5) < 0.5
+
+    def test_ease_out_quad_boundaries(self):
+        assert ease_out_quad(0) == pytest.approx(0.0)
+        assert ease_out_quad(1) == pytest.approx(1.0)
+        # Decelerating: output at 0.5 should be greater than 0.5
+        assert ease_out_quad(0.5) > 0.5
+
+    def test_ease_in_out_quad_boundaries(self):
+        assert ease_in_out_quad(0) == pytest.approx(0.0)
+        assert ease_in_out_quad(1) == pytest.approx(1.0)
+        # Symmetric: midpoint maps to exactly 0.5
+        assert ease_in_out_quad(0.5) == pytest.approx(0.5)
+
+    def test_ease_in_cubic_boundaries(self):
+        assert ease_in_cubic(0) == pytest.approx(0.0)
+        assert ease_in_cubic(1) == pytest.approx(1.0)
+        # More aggressive than quad
+        assert ease_in_cubic(0.5) < ease_in_quad(0.5)
+
+    def test_ease_out_back_boundaries(self):
+        assert ease_out_back(0) == pytest.approx(0.0)
+        assert ease_out_back(1) == pytest.approx(1.0)
+        # Must overshoot: maximum in (0, 1) must exceed 1.0
+        samples = [ease_out_back(t / 100) for t in range(1, 100)]
+        assert max(samples) > 1.0, "ease_out_back must overshoot above 1.0"
+
+    def test_all_easings_in_dict(self):
+        expected = {
+            "linear",
+            "ease_in_quad",
+            "ease_out_quad",
+            "ease_in_out_quad",
+            "ease_in_cubic",
+            "ease_out_back",
+        }
+        assert expected <= set(EASING_FUNCTIONS.keys())
+
+
+# ---------------------------------------------------------------------------
+# Animation lifecycle tests
+# ---------------------------------------------------------------------------
+
+class TestAnimation:
+
+    def test_basic_interpolation_linear(self):
+        """Halfway through should give halfway value with linear easing."""
+        values = []
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=1000,
+            easing=linear,
+            on_update=values.append,
+        )
+        anim.tick(500)
+        assert values[-1] == pytest.approx(50.0)
+        assert not anim.is_completed()
+
+    def test_completes_at_duration(self):
+        """Animation should complete when elapsed >= duration."""
+        complete_called = [False]
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=500,
+            on_complete=lambda: complete_called.__setitem__(0, True),
+        )
+        done = anim.tick(500)
+        assert done is True
+        assert anim.is_completed()
+        assert complete_called[0]
+
+    def test_final_value_is_end_value(self):
+        """on_update receives end_value on the completing tick."""
+        values = []
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=200,
+            easing=linear,
+            on_update=values.append,
+        )
+        anim.tick(200)
+        assert values[-1] == pytest.approx(100.0)
+
+    def test_loop_resets_elapsed(self):
+        """A looping animation never completes and resets elapsed."""
+        tick_count = [0]
+
+        def counter(v):
+            tick_count[0] += 1
+
+        anim = Animation(
+            start_value=0,
+            end_value=10,
+            duration=100,
+            loop=True,
+            on_update=counter,
+        )
+        # Tick past 3 full cycles
+        for _ in range(5):
+            anim.tick(100)
+        assert not anim.is_completed()
+        assert tick_count[0] == 5
+
+    def test_bounce_reverses_direction(self):
+        """Bounce animation should reverse: value decreases after first cycle."""
+        values = []
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=200,
+            easing=linear,
+            bounce=True,
+            on_update=values.append,
+        )
+        # End of first cycle -> value should be 100
+        anim.tick(200)
+        assert values[-1] == pytest.approx(100.0)
+        # Into second cycle (reversed) -> value should drop
+        anim.tick(100)
+        assert values[-1] < 100.0
+        assert not anim.is_completed()
+
+    def test_delay_holds_start(self):
+        """No update should fire before the delay expires."""
+        values = []
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=500,
+            delay=200,
+            easing=linear,
+            on_update=values.append,
+        )
+        anim.tick(100)  # still in delay
+        assert len(values) == 0
+
+        anim.tick(100)  # delay exactly consumed (total 200ms), 0ms carry-over
+        # When delay is exactly consumed, dt carry-over is 0, so on_update fires
+        # with value == start_value (t=0).
+        assert len(values) == 1
+        assert values[0] == pytest.approx(0.0)
+
+        anim.tick(250)  # halfway through actual animation
+        assert values[-1] == pytest.approx(50.0, abs=1.0)
+
+    def test_cancel(self):
+        """Cancelled animation is immediately marked complete."""
+        anim = Animation(start_value=0, end_value=100, duration=500)
+        anim.cancel()
+        assert anim.is_completed()
+        # Ticking a cancelled animation returns True immediately
+        assert anim.tick(100) is True
+
+    def test_get_current_value(self):
+        """get_current_value returns most recently computed value."""
+        anim = Animation(start_value=10, end_value=20, duration=1000, easing=linear)
+        assert anim.get_current_value() == pytest.approx(10.0)
+        anim.tick(500)
+        assert anim.get_current_value() == pytest.approx(15.0)
+
+    def test_value_min_clamp(self):
+        """value_min clamps interpolated values that go below the bound."""
+        values = []
+        # Use an easing that could go below 0 is impossible here, but we can
+        # artificially test by setting value_min above the interpolated midpoint.
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=1000,
+            easing=linear,
+            value_min=40,
+            on_update=values.append,
+        )
+        anim.tick(200)  # raw interpolated value = 20, clamped to 40
+        assert values[-1] == pytest.approx(40.0)
+
+    def test_value_max_clamp_for_ease_out_back(self):
+        """value_max prevents ease_out_back overshoot from exceeding the cap."""
+        max_seen = [0.0]
+
+        def track(v):
+            if v > max_seen[0]:
+                max_seen[0] = v
+
+        anim = Animation(
+            start_value=0,
+            end_value=100,
+            duration=500,
+            easing=ease_out_back,
+            on_update=track,
+            value_max=100.0,
+        )
+        # Tick in small steps to capture the peak
+        for _ in range(50):
+            anim.tick(10)
+        assert max_seen[0] == pytest.approx(100.0)
+
+    def test_invalid_duration(self):
+        with pytest.raises(AssertionError):
+            Animation(start_value=0, end_value=1, duration=0)
+
+    def test_invalid_delay(self):
+        with pytest.raises(AssertionError):
+            Animation(start_value=0, end_value=1, duration=100, delay=-1)
+
+    def test_invalid_value_bounds(self):
+        with pytest.raises(AssertionError):
+            Animation(start_value=0, end_value=1, duration=100, value_min=10, value_max=5)
+
