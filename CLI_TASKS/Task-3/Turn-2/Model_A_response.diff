+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST ANIMATION
+Test animation engine, easing functions, AnimationManager, and widget integration.
+"""
+
+import pytest
+
+import pygame_menu
+from pygame_menu.animation import (
+    Animation,
+    AnimationManager,
+    ease_in_cubic,
+    ease_in_out_quad,
+    ease_in_quad,
+    ease_out_back,
+    ease_out_quad,
+    linear,
+)
+from test._utils import MenuUtils
+
+
+# ---------------------------------------------------------------------------
+# Easing function boundary tests
+# ---------------------------------------------------------------------------
+
+class TestEasingFunctions:
+    """Test easing functions return correct boundary values."""
+
+    @pytest.mark.parametrize(
+        "fn",
+        [linear, ease_in_quad, ease_out_quad, ease_in_out_quad, ease_in_cubic],
+    )
+    def test_boundaries_0_and_1(self, fn):
+        """All standard easing functions should return 0 at t=0 and 1 at t=1."""
+        assert fn(0.0) == pytest.approx(0.0)
+        assert fn(1.0) == pytest.approx(1.0)
+
+    def test_ease_out_back_boundaries(self):
+        """ease_out_back returns 0 at t=0 and 1 at t=1."""
+        assert ease_out_back(0.0) == pytest.approx(0.0)
+        assert ease_out_back(1.0) == pytest.approx(1.0)
+
+    def test_ease_out_back_overshoots(self):
+        """ease_out_back should overshoot above 1.0 at some intermediate t."""
+        # Sample mid-range values
+        vals = [ease_out_back(t / 100.0) for t in range(1, 100)]
+        assert max(vals) > 1.0, "ease_out_back should overshoot above 1.0"
+
+    def test_linear_midpoint(self):
+        assert linear(0.5) == pytest.approx(0.5)
+
+    def test_ease_in_quad_midpoint(self):
+        assert ease_in_quad(0.5) == pytest.approx(0.25)
+
+    def test_ease_out_quad_midpoint(self):
+        assert ease_out_quad(0.5) == pytest.approx(0.75)
+
+    def test_ease_in_out_quad_midpoint(self):
+        assert ease_in_out_quad(0.5) == pytest.approx(0.5)
+
+    def test_ease_in_cubic_midpoint(self):
+        assert ease_in_cubic(0.5) == pytest.approx(0.125)
+
+
+# ---------------------------------------------------------------------------
+# Animation lifecycle tests
+# ---------------------------------------------------------------------------
+
+class TestAnimation:
+    """Test Animation create / tick / complete / cancel lifecycle."""
+
+    def test_basic_interpolation(self):
+        """Animation at 50% of duration should produce ~50 for linear 0->100."""
+        anim = Animation(0, 100, 1000, easing=linear)
+        anim.tick(500)
+        assert anim.get_current_value() == pytest.approx(50.0)
+        assert not anim.is_completed()
+
+    def test_completion(self):
+        """Animation completes after full duration."""
+        anim = Animation(0, 100, 1000, easing=linear)
+        done = anim.tick(1000)
+        assert done is True
+        assert anim.is_completed()
+        assert anim.get_current_value() == pytest.approx(100.0)
+
+    def test_on_update_called(self):
+        """on_update is called each tick with the current value."""
+        values = []
+        anim = Animation(0, 100, 1000, easing=linear, on_update=values.append)
+        anim.tick(250)
+        anim.tick(250)
+        assert len(values) == 2
+        assert values[0] == pytest.approx(25.0)
+        assert values[1] == pytest.approx(50.0)
+
+    def test_on_complete_called_once(self):
+        """on_complete fires exactly once at the end."""
+        calls = []
+        anim = Animation(0, 100, 100, easing=linear, on_complete=lambda: calls.append(1))
+        anim.tick(100)
+        anim.tick(100)  # already completed
+        assert len(calls) == 1
+
+    def test_cancel(self):
+        """Cancelled animation reports completed."""
+        anim = Animation(0, 100, 1000)
+        anim.cancel()
+        assert anim.is_completed()
+        assert anim.tick(100) is True
+
+    def test_delay(self):
+        """Animation waits for delay before starting."""
+        anim = Animation(0, 100, 1000, easing=linear, delay=200)
+        anim.tick(100)
+        # Still in delay
+        assert anim.get_current_value() == pytest.approx(0.0)
+        assert not anim.is_completed()
+
+        anim.tick(200)
+        # delay=200 elapsed, 100ms of extra carried over into animation
+        assert anim.get_current_value() == pytest.approx(10.0)
+
+    def test_loop(self):
+        """Looping animation restarts after completing."""
+        anim = Animation(0, 100, 100, easing=linear, loop=True)
+        done = anim.tick(100)
+        assert done is False  # not finished, loops
+        assert not anim.is_completed()
+
+        # Should have reset elapsed to 0
+        anim.tick(50)
+        assert anim.get_current_value() == pytest.approx(50.0)
+
+    def test_bounce(self):
+        """Bouncing animation reverses direction."""
+        anim = Animation(0, 100, 100, easing=linear, bounce=True)
+        done = anim.tick(100)
+        assert done is False
+
+        # Now going backward
+        anim.tick(50)
+        assert anim.get_current_value() == pytest.approx(50.0)
+
+        # Complete the reverse
+        anim.tick(50)
+        assert anim.get_current_value() == pytest.approx(0.0)
+
+    def test_min_max_clamping(self):
+        """min_value/max_value clamp the interpolated output."""
+        # ease_out_back overshoots above 1.0, so 0->255 can exceed 255
+        anim = Animation(
+            0, 255, 1000, easing=ease_out_back, min_value=0, max_value=255
+        )
+        # Tick in small steps and verify value never exceeds bounds
+        for _ in range(100):
+            anim.tick(10)
+            v = anim.get_current_value()
+            assert 0 <= v <= 255, f"value {v} out of bounds"
+
+    def test_no_clamping_without_bounds(self):
+        """Without min/max, easing overshoot is preserved."""
+        values = []
+        anim = Animation(
+            0, 100, 1000, easing=ease_out_back, on_update=values.append
+        )
+        for _ in range(100):
+            anim.tick(10)
+        # ease_out_back overshoots, so some value should exceed 100
+        assert any(v > 100 for v in values), (
+            "ease_out_back should overshoot without clamping"
+        )
+
+
+# ---------------------------------------------------------------------------
+# AnimationManager tests
+# ---------------------------------------------------------------------------
+
+class TestAnimationManager:
+    """Test AnimationManager add / tick / cancel / remove lifecycle."""
+
+    def test_add_and_tick(self):
+        """Manager ticks added animations and removes completed ones."""
+        mgr = AnimationManager()
+        anim = Animation(0, 100, 100)
+        mgr.add(anim)
+        assert not mgr.is_empty()
+
+        mgr.tick(100)
+        assert anim.is_completed()
+        assert mgr.is_empty()
+
+    def test_multiple_animations(self):
+        """Manager handles multiple animations simultaneously."""
+        mgr = AnimationManager()
+        a1 = Animation(0, 100, 100)
+        a2 = Animation(0, 100, 200)
+        mgr.add(a1)
+        mgr.add(a2)
+
+        mgr.tick(100)
+        assert a1.is_completed()
+        assert not a2.is_completed()
+        # a1 should be removed, a2 still active
+        assert not mgr.is_empty()
+
+        mgr.tick(100)
+        assert a2.is_completed()
+        assert mgr.is_empty()
+
+    def test_cancel_all(self):
+        """cancel_all cancels and removes all animations."""
+        mgr = AnimationManager()
+        a1 = Animation(0, 100, 1000)
+        a2 = Animation(0, 100, 1000)
+        mgr.add(a1)
+        mgr.add(a2)
+
+        mgr.cancel_all()
+        assert a1.is_completed()
+        assert a2.is_completed()
+        assert mgr.is_empty()
+
+    def test_remove_for_widget(self):
+        """remove_for_widget cancels only animations for that widget."""
+        mgr = AnimationManager()
+
+        class FakeWidget:
+            pass
+
+        w1 = FakeWidget()
+        w2 = FakeWidget()
+
+        a1 = Animation(0, 100, 1000)
+        a1._widget = w1
+        a2 = Animation(0, 100, 1000)
+        a2._widget = w2
+
+        mgr.add(a1)
+        mgr.add(a2)
+
+        mgr.remove_for_widget(w1)
+        assert a1.is_completed()
+        assert not a2.is_completed()
+        assert not mgr.is_empty()
+
+    def test_tick_empty_manager(self):
+        """Ticking an empty manager does nothing."""
+        mgr = AnimationManager()
+        mgr.tick(100)  # should not raise
+
+
+# ---------------------------------------------------------------------------
+# Widget fade_in integration test
+# ---------------------------------------------------------------------------
+
+class TestWidgetFadeInIntegration:
+    """Integration test: widget.fade_in() with a real Menu + AnimationManager."""
+
+    def test_fade_in_registers_and_ticks(self):
+        """fade_in creates an animation, registers it, and ticking advances opacity."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Test")
+
+        # fade_in sets opacity to 0 first, then animates to 255
+        anim = btn.fade_in(duration=100)
+
+        assert btn.get_opacity() == 0
+        mgr = menu.get_animation_manager()
+        assert not mgr.is_empty()
+
+        # Tick 50ms — should be ~halfway
+        mgr.tick(50)
+        assert 0 < btn.get_opacity() < 255
+
+        # Tick the rest
+        mgr.tick(50)
+        assert btn.get_opacity() == 255
+        assert anim.is_completed()
+        assert mgr.is_empty()
+
+    def test_fade_out_hides_widget(self):
+        """fade_out animates opacity to 0 then hides the widget."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Test")
+        btn.set_opacity(255)
+
+        anim = btn.fade_out(duration=100)
+        mgr = menu.get_animation_manager()
+
+        mgr.tick(100)
+        assert anim.is_completed()
+        assert btn.get_opacity() == 0
+        assert not btn.is_visible()
+
+    def test_remove_widget_cleans_animation(self):
+        """Removing a widget cancels and removes its active animations."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Test")
+        btn.fade_in(duration=1000)
+
+        mgr = menu.get_animation_manager()
+        assert not mgr.is_empty()
+
+        menu.remove_widget(btn)
+        assert mgr.is_empty()
+
+    def test_opacity_clamped_during_ease_out_back(self):
+        """Opacity stays in [0, 255] even with overshooting easing."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Test")
+
+        btn.animate_opacity(255, duration=500, easing=ease_out_back)
+        mgr = menu.get_animation_manager()
+
+        for _ in range(50):
+            mgr.tick(10)
+            assert 0 <= btn.get_opacity() <= 255
+
+
+# ---------------------------------------------------------------------------
+# Transition helpers integration test
+# ---------------------------------------------------------------------------
+
+class TestTransitions:
+    """Test that transitions.py helpers register with the AnimationManager."""
+
+    def test_fade_in_registers(self):
+        """transitions.fade_in registers the animation with the menu."""
+        from pygame_menu.transitions import fade_in
+
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Test")
+
+        anim = fade_in(btn, duration=100)
+        mgr = menu.get_animation_manager()
+
+        assert not mgr.is_empty()
+        assert anim._widget is btn
+
+        # Actually ticks
+        mgr.tick(100)
+        assert anim.is_completed()
+        assert btn.get_opacity() == 255
+
+    def test_fade_out_registers(self):
