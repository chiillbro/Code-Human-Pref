@@ -0,0 +1,252 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+BREADCRUMB
+Displays a navigation breadcrumb trail showing the path from the root menu
+to the currently displayed menu (e.g. "Main > Settings > Audio").
+
+The widget is non-selectable and is drawn automatically by the Menu when
+breadcrumbs are enabled via the theme.
+"""
+
+__all__ = ['Breadcrumb']
+
+import pygame
+import pygame_menu
+
+from pygame_menu.font import get_font as _get_font
+from pygame_menu.utils import make_surface
+from pygame_menu.widgets.core.widget import Widget
+
+from pygame_menu._types import Optional, List, Tuple, Any, CallbackType, ColorType
+
+
+class Breadcrumb(Widget):
+    """
+    Breadcrumb navigation widget.  Builds a text trail from the menu-navigation
+    history (using the ``_prev`` linked-list on the root menu) and renders it as
+    a single surface.
+
+    Rendering is lazy: the surface is only rebuilt when the navigation depth
+    changes.
+
+    :param separator: String placed between path segments
+    :param font_name: Font used for the breadcrumb text
+    :param font_size: Font size in px
+    :param font_color: Text colour for ancestor segments
+    :param active_color: Text colour for the current (last) segment
+    :param background_color: Optional background colour behind the breadcrumb
+    :param padding_x: Horizontal padding in px
+    :param padding_y: Vertical padding in px
+    :param breadcrumb_id: Widget ID
+    """
+    _separator: str
+    _bc_font_name: Any
+    _bc_font_size: int
+    _bc_font_color: ColorType
+    _bc_active_color: ColorType
+    _bc_background_color: Optional[ColorType]
+    _bc_padding_x: int
+    _bc_padding_y: int
+    _bc_font: Optional['pygame.font.Font']
+    _last_depth: int
+    _path_titles: List[str]
+
+    def __init__(
+            self,
+            separator: str = ' > ',
+            font_name: Any = None,
+            font_size: int = 16,
+            font_color: ColorType = (120, 120, 120),
+            active_color: ColorType = (50, 50, 50),
+            background_color: Optional[ColorType] = None,
+            padding_x: int = 10,
+            padding_y: int = 4,
+            breadcrumb_id: str = '',
+    ) -> None:
+        super(Breadcrumb, self).__init__(
+            title='',
+            widget_id=breadcrumb_id,
+        )
+        self._separator = separator
+        self._bc_font_name = font_name
+        self._bc_font_size = font_size
+        self._bc_font_color = font_color
+        self._bc_active_color = active_color
+        self._bc_background_color = background_color
+        self._bc_padding_x = padding_x
+        self._bc_padding_y = padding_y
+        self._bc_font = None
+        self._last_depth = -1
+        self._path_titles = []
+
+        # Breadcrumb is never selectable and is always floating
+        self.is_selectable = False
+
+    # ------------------------------------------------------------------
+    # Path building
+    # ------------------------------------------------------------------
+
+    def _build_path(self) -> List[str]:
+        """
+        Traverse the ``_prev`` linked-list on the root menu to collect the
+        ordered list of menu titles from root to current.
+
+        :return: List of menu title strings, root first
+        """
+        menu = self._menu
+        if menu is None:
+            return []
+
+        top = menu._top
+
+        # Collect menus from the _prev chain.
+        # _prev structure: [parent_state, current_menu]
+        # Walking prev[0] goes towards root; prev[1] is the menu at that depth.
+        menus: List['pygame_menu.Menu'] = []
+        prev = top._prev
+        if prev is not None:
+            while prev is not None:
+                menus.append(prev[1])
+                prev = prev[0]
+
+        # menus is in reverse order (deepest parent first), so reverse it
+        menus.reverse()
+
+        # Append current menu at the end
+        titles = [m.get_title() for m in menus]
+        titles.append(top._current.get_title())
+
+        return titles
+
+    # ------------------------------------------------------------------
+    # Rendering
+    # ------------------------------------------------------------------
+
+    def _ensure_font(self) -> None:
+        """Lazy-load the pygame font object."""
+        if self._bc_font is None:
+            if self._bc_font_name is None and self._menu is not None:
+                self._bc_font_name = self._menu.get_theme().widget_font
+            if self._bc_font_name is None:
+                from pygame_menu.font import FONT_OPEN_SANS
+                self._bc_font_name = FONT_OPEN_SANS
+            self._bc_font = _get_font(self._bc_font_name, self._bc_font_size)
+
+    def _render(self) -> Optional[bool]:
+        """Build the breadcrumb surface.  Re-renders only when depth changes."""
+        menu = self._menu
+        if menu is None:
+            return None
+
+        depth = menu._get_depth()
+        titles = self._build_path()
+
+        if not self._render_hash_changed(depth, tuple(titles), self._visible):
+            return True
+
+        self._path_titles = titles
+        self._last_depth = depth
+
+        # If at root (depth 0 → only one title), make a 0×0 surface so it's
+        # effectively invisible.
+        if depth == 0:
+            self._surface = make_surface(1, 1, alpha=True)
+            self._rect.width, self._rect.height = 0, 0
+            return None
+
+        self._ensure_font()
+        font = self._bc_font
+
+        # Render each segment and separator individually so we can apply
+        # different colours to ancestor vs. current segment.
+        segment_surfaces: List['pygame.Surface'] = []
+        sep_surface = font.render(self._separator, True, self._bc_font_color)
+
+        for idx, title in enumerate(titles):
+            is_last = idx == len(titles) - 1
+            color = self._bc_active_color if is_last else self._bc_font_color
+            segment_surfaces.append(font.render(title, True, color))
+
+        # Compute total width and height
+        total_w = sum(s.get_width() for s in segment_surfaces) + \
+                  sep_surface.get_width() * (len(segment_surfaces) - 1) + \
+                  self._bc_padding_x * 2
+        total_h = max(s.get_height() for s in segment_surfaces) + \
+                  self._bc_padding_y * 2
+
+        self._surface = make_surface(total_w, total_h, alpha=True)
+
+        # Draw background
+        if self._bc_background_color is not None:
+            self._surface.fill(self._bc_background_color)
+
+        # Blit segments
+        x = self._bc_padding_x
+        y = self._bc_padding_y
+        for idx, seg_surf in enumerate(segment_surfaces):
+            self._surface.blit(seg_surf, (x, y))
+            x += seg_surf.get_width()
+            if idx < len(segment_surfaces) - 1:
+                self._surface.blit(sep_surface, (x, y))
+                x += sep_surface.get_width()
+
+        self._rect.width, self._rect.height = total_w, total_h
+
+    def _draw(self, surface: 'pygame.Surface') -> None:
+        """Blit the pre-rendered breadcrumb surface."""
+        if self._surface is None or self._last_depth == 0:
+            return
+        surface.blit(self._surface, (self._rect.x, self._rect.y))
+
+    def get_path_titles(self) -> List[str]:
+        """
+        Return the current breadcrumb path as a list of menu title strings.
+
+        :return: Ordered list from root menu to current menu
+        """
+        return list(self._path_titles)
+
+    def _apply_font(self) -> None:
+        """No-op: breadcrumb manages its own font."""
+        pass
+
+    def update(self, events: 'pygame_menu._types.EventVectorType') -> bool:
+        """
+        Process click events — clicking an ancestor segment navigates back to
+        that depth.
+
+        :param events: Pygame events
+        :return: True if event was consumed
+        """
+        menu = self._menu
+        if menu is None or self._last_depth == 0:
+            return False
+
+        for event in events:
+            if event.type == pygame.MOUSEBUTTONUP and event.button == 1:
+                mx, my = event.pos
+                rect = self.get_rect(to_real_position=True)
+                if not rect.collidepoint(mx, my):
+                    continue
+
+                # Determine which segment was clicked based on x position
+                self._ensure_font()
+                font = self._bc_font
+                sep_w = font.size(self._separator)[0]
+
+                local_x = mx - rect.x - self._bc_padding_x
+                running_x = 0
+                for idx, title in enumerate(self._path_titles):
+                    seg_w = font.size(title)[0]
+                    if local_x < running_x + seg_w:
+                        # Clicked on segment idx
+                        levels_back = len(self._path_titles) - 1 - idx
+                        if levels_back > 0:
+                            menu.reset(levels_back)
+                            return True
+                        return False  # Already on this menu
+                    running_x += seg_w + sep_w
+
+        return False
