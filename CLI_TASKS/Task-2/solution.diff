+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TOOLTIP
+Tooltip class for displaying contextual help text on widget hover.
+"""
+
+__all__ = ['WidgetTooltip']
+
+import time
+
+import pygame
+
+from pygame_menu.font import FontType, get_font
+from pygame_menu.utils import assert_color
+
+from pygame_menu._types import Optional, ColorType, Tuple2IntType, NumberType
+
+
+class WidgetTooltip(object):
+    """
+    Tooltip object displayed when a user hovers over a widget.
+
+    The tooltip renders a text surface with background, border, and padding,
+    positioned near the mouse cursor. It appears after a configurable delay
+    and repositions itself to stay within window boundaries.
+
+    :param text: Tooltip text content
+    :param font: Font name or path
+    :param font_size: Font size in px
+    :param font_color: Font color
+    :param background_color: Tooltip background color
+    :param border_color: Tooltip border color
+    :param border_width: Tooltip border width in px
+    :param padding: Internal padding (horizontal, vertical) in px
+    :param delay_ms: Delay in milliseconds before showing the tooltip
+    :param max_width: Maximum tooltip width in px before wrapping. If ``0`` no wrapping is applied
+    """
+    _text: str
+    _font_name: FontType
+    _font_size: int
+    _font_color: ColorType
+    _background_color: ColorType
+    _border_color: ColorType
+    _border_width: int
+    _padding: Tuple2IntType
+    _delay_ms: NumberType
+    _max_width: int
+
+    _hover_start_time: float
+    _visible: bool
+    _surface: Optional['pygame.Surface']
+    _last_mouse_pos: Tuple2IntType
+
+    def __init__(
+            self,
+            text: str,
+            font: FontType = '',
+            font_size: int = 14,
+            font_color: ColorType = (0, 0, 0),
+            background_color: ColorType = (255, 255, 225),
+            border_color: ColorType = (0, 0, 0),
+            border_width: int = 1,
+            padding: Tuple2IntType = (6, 4),
+            delay_ms: NumberType = 500,
+            max_width: int = 0
+    ) -> None:
+        assert isinstance(text, str) and len(text) > 0, \
+            'tooltip text must be a non-empty string'
+        assert isinstance(font_size, int) and font_size > 0, \
+            'font size must be a positive integer'
+        assert isinstance(border_width, int) and border_width >= 0, \
+            'border width must be a non-negative integer'
+        assert isinstance(delay_ms, (int, float)) and delay_ms >= 0, \
+            'delay must be a non-negative number'
+        assert isinstance(max_width, int) and max_width >= 0, \
+            'max_width must be a non-negative integer'
+
+        self._text = text
+        self._font_name = font
+        self._font_size = font_size
+        self._font_color = assert_color(font_color)
+        self._background_color = assert_color(background_color)
+        self._border_color = assert_color(border_color)
+        self._border_width = border_width
+        self._padding = padding
+        self._delay_ms = delay_ms
+        self._max_width = max_width
+
+        self._hover_start_time = 0.0
+        self._visible = False
+        self._surface = None
+        self._last_mouse_pos = (0, 0)
+
+    def get_text(self) -> str:
+        """
+        Return the tooltip text.
+
+        :return: Tooltip text
+        """
+        return self._text
+
+    def set_text(self, text: str) -> 'WidgetTooltip':
+        """
+        Set the tooltip text. This invalidates the cached surface.
+
+        :param text: New tooltip text
+        :return: Self reference
+        """
+        assert isinstance(text, str) and len(text) > 0, \
+            'tooltip text must be a non-empty string'
+        self._text = text
+        self._surface = None
+        return self
+
+    def on_mouse_enter(self) -> None:
+        """
+        Called when the mouse enters the associated widget area.
+        Starts the hover delay timer.
+        """
+        if self._hover_start_time == 0.0:
+            self._hover_start_time = time.time()
+
+    def on_mouse_leave(self) -> None:
+        """
+        Called when the mouse leaves the associated widget area.
+        Hides the tooltip and resets the timer.
+        """
+        self._hover_start_time = 0.0
+        self._visible = False
+
+    def is_visible(self) -> bool:
+        """
+        Return ``True`` if the tooltip should be drawn.
+
+        :return: Visibility status
+        """
+        if self._hover_start_time == 0.0:
+            return False
+        elapsed_ms = (time.time() - self._hover_start_time) * 1000
+        if elapsed_ms >= self._delay_ms:
+            self._visible = True
+        return self._visible
+
+    def _build_surface(self, font_obj: 'pygame.font.Font') -> 'pygame.Surface':
+        """
+        Build the tooltip surface with text, background, border, and padding.
+
+        :param font_obj: Pygame font object
+        :return: Rendered tooltip surface
+        """
+        lines = self._wrap_text(font_obj, self._text)
+        line_surfaces = [font_obj.render(line, True, self._font_color) for line in lines]
+
+        # Calculate total dimensions
+        pad_x, pad_y = self._padding
+        bw = self._border_width
+        max_line_w = max(s.get_width() for s in line_surfaces) if line_surfaces else 0
+        line_height = font_obj.get_height()
+        total_text_h = line_height * len(line_surfaces)
+
+        surf_w = max_line_w + 2 * pad_x + 2 * bw
+        surf_h = total_text_h + 2 * pad_y + 2 * bw
+
+        surface = pygame.Surface((surf_w, surf_h), pygame.SRCALPHA)
+
+        # Draw background
+        bg_color = self._background_color if len(self._background_color) == 4 else (*self._background_color, 255)
+        surface.fill(bg_color)
+
+        # Draw border
+        if bw > 0:
+            border_color = self._border_color if len(self._border_color) == 4 else (*self._border_color, 255)
+            pygame.draw.rect(surface, border_color, (0, 0, surf_w, surf_h), bw)
+
+        # Blit text lines
+        for i, line_surf in enumerate(line_surfaces):
+            surface.blit(line_surf, (pad_x + bw, pad_y + bw + i * line_height))
+
+        return surface
+
+    def _wrap_text(self, font_obj: 'pygame.font.Font', text: str) -> list:
+        """
+        Wrap text into lines that fit within ``max_width``.
+
+        :param font_obj: Pygame font object
+        :param text: Text to wrap
+        :return: List of text lines
+        """
+        if self._max_width <= 0:
+            return text.split('\n') if '\n' in text else [text]
+
+        effective_width = self._max_width - 2 * self._padding[0] - 2 * self._border_width
+        if effective_width <= 0:
+            return [text]
+
+        result_lines = []
+        for paragraph in text.split('\n'):
+            words = paragraph.split(' ')
+            current_line = ''
+            for word in words:
+                test_line = f'{current_line} {word}'.strip() if current_line else word
+                if font_obj.size(test_line)[0] <= effective_width:
+                    current_line = test_line
+                else:
+                    if current_line:
+                        result_lines.append(current_line)
+                    current_line = word
+            if current_line:
+                result_lines.append(current_line)
+            elif not words or (len(words) == 1 and words[0] == ''):
+                result_lines.append('')
+
+        return result_lines if result_lines else ['']
+
+    def get_surface(self, font_obj: 'pygame.font.Font') -> 'pygame.Surface':
+        """
+        Get the tooltip surface, building it if necessary.
+
+        :param font_obj: Pygame font object
+        :return: Rendered tooltip surface
+        """
+        if self._surface is None:
+            self._surface = self._build_surface(font_obj)
+        return self._surface
+
+    def compute_position(
+            self,
+            mouse_pos: Tuple2IntType,
+            window_width: int,
+            window_height: int,
+            font_obj: 'pygame.font.Font'
+    ) -> Tuple2IntType:
+        """
+        Compute the tooltip position near the cursor, ensuring it stays within
+        the window boundaries.
+
+        :param mouse_pos: Current mouse position (x, y)
+        :param window_width: Window width in px
+        :param window_height: Window height in px
+        :param font_obj: Pygame font object
+        :return: Tooltip position (x, y)
+        """
+        surface = self.get_surface(font_obj)
+        tw, th = surface.get_size()
+
+        # Default: position below and to the right of the cursor
+        offset_x, offset_y = 12, 16
+        x = mouse_pos[0] + offset_x
+        y = mouse_pos[1] + offset_y
+
+        # Flip horizontally if tooltip would overflow the right edge
+        if x + tw > window_width:
+            x = mouse_pos[0] - tw - offset_x
+
+        # Flip vertically if tooltip would overflow the bottom edge
+        if y + th > window_height:
+            y = mouse_pos[1] - th - offset_y
+
+        # Clamp to window boundaries
+        x = max(0, min(x, window_width - tw))
+        y = max(0, min(y, window_height - th))
+
+        return x, y
+
+    def draw(
+            self,
+            surface: 'pygame.Surface',
+            mouse_pos: Tuple2IntType,
+            window_width: int,
+            window_height: int,
+            font_obj: 'pygame.font.Font'
+    ) -> None:
+        """
+        Draw the tooltip on the given surface if visible.
+
+        :param surface: Target pygame surface
+        :param mouse_pos: Current mouse position
+        :param window_width: Window width in px
+        :param window_height: Window height in px
+        :param font_obj: Pygame font used for rendering
+        """
+        if not self.is_visible():
+            return
+        tooltip_surface = self.get_surface(font_obj)
+        pos = self.compute_position(mouse_pos, window_width, window_height, font_obj)
+        surface.blit(tooltip_surface, pos)
