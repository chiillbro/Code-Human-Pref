+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST WIDGET - BREADCRUMB
+Tests for the Breadcrumb navigation widget.
+"""
+
+import pygame
+import pygame_menu
+
+from test._utils import BaseTest, MenuUtils, surface, reset_widgets_over
+
+
+class BreadcrumbWidgetTest(BaseTest):
+
+    def setUp(self) -> None:
+        """Set up breadcrumb-enabled theme."""
+        self.theme = pygame_menu.themes.THEME_DEFAULT.copy()
+        self.theme.breadcrumb_enabled = True
+        reset_widgets_over()
+
+    # ------------------------------------------------------------------
+    # Construction / defaults
+    # ------------------------------------------------------------------
+
+    def test_breadcrumb_created_when_enabled(self) -> None:
+        """Menu creates a Breadcrumb widget when theme.breadcrumb_enabled is True."""
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        self.assertIsNotNone(menu._breadcrumb)
+        self.assertIsInstance(menu._breadcrumb, pygame_menu.widgets.Breadcrumb)
+
+    def test_breadcrumb_none_when_disabled(self) -> None:
+        """Menu does NOT create a Breadcrumb when the flag is off."""
+        theme = pygame_menu.themes.THEME_DEFAULT.copy()
+        theme.breadcrumb_enabled = False
+        menu = MenuUtils.generic_menu(title='Root', theme=theme)
+        self.assertIsNone(menu._breadcrumb)
+
+    def test_breadcrumb_default_properties(self) -> None:
+        """Breadcrumb inherits separator / font settings from the theme."""
+        self.theme.breadcrumb_separator = ' / '
+        self.theme.breadcrumb_font_size = 20
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        bc = menu._breadcrumb
+        self.assertEqual(bc._separator, ' / ')
+        self.assertEqual(bc._bc_font_size, 20)
+
+    def test_breadcrumb_is_not_selectable(self) -> None:
+        """Breadcrumb widgets must never be selectable."""
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        self.assertFalse(menu._breadcrumb.is_selectable)
+
+    # ------------------------------------------------------------------
+    # Path building
+    # ------------------------------------------------------------------
+
+    def test_path_at_root(self) -> None:
+        """At root depth the path should contain only the root title."""
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        menu.enable()
+        menu._breadcrumb._render()
+        titles = menu._breadcrumb.get_path_titles()
+        self.assertEqual(titles, ['Root'])
+
+    def test_path_single_submenu(self) -> None:
+        """After opening one submenu the path is [Root, Sub]."""
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        sub = MenuUtils.generic_menu(title='Settings', theme=self.theme)
+        btn = menu.add.button('go', sub)
+        btn.apply()
+        menu.enable()
+
+        bc = menu.get_current()._breadcrumb
+        bc._render()
+        self.assertEqual(bc.get_path_titles(), ['Root', 'Settings'])
+
+    def test_path_deep_navigation(self) -> None:
+        """Navigate three levels deep and verify the full breadcrumb path."""
+        m1 = MenuUtils.generic_menu(title='Main', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='Audio', theme=self.theme)
+        m3 = MenuUtils.generic_menu(title='EQ', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m2.add.button('go', m3).apply()
+        m1.enable()
+
+        bc = m1.get_current()._breadcrumb
+        bc._render()
+        self.assertEqual(bc.get_path_titles(), ['Main', 'Audio', 'EQ'])
+
+    def test_path_after_back(self) -> None:
+        """Going back one level removes the last segment from the path."""
+        m1 = MenuUtils.generic_menu(title='Main', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='Video', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m1.enable()
+
+        # Depth is 1
+        bc = m1.get_current()._breadcrumb
+        bc._render()
+        self.assertEqual(bc.get_path_titles(), ['Main', 'Video'])
+
+        # Go back
+        m1.reset(1)
+        bc_root = m1.get_current()._breadcrumb
+        bc_root._render()
+        self.assertEqual(bc_root.get_path_titles(), ['Main'])
+
+    # ------------------------------------------------------------------
+    # Rendering
+    # ------------------------------------------------------------------
+
+    def test_render_invisible_at_root(self) -> None:
+        """At depth 0 the breadcrumb surface should be effectively invisible."""
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        menu.enable()
+        bc = menu._breadcrumb
+        bc._render()
+        # At root the rect dimensions should be 0×0
+        self.assertEqual(bc._rect.width, 0)
+        self.assertEqual(bc._rect.height, 0)
+
+    def test_render_visible_at_depth(self) -> None:
+        """At depth > 0 the breadcrumb should have a non-zero surface."""
+        m1 = MenuUtils.generic_menu(title='Main', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='Sub', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m1.enable()
+
+        bc = m1.get_current()._breadcrumb
+        bc._render()
+        self.assertGreater(bc._rect.width, 0)
+        self.assertGreater(bc._rect.height, 0)
+
+    def test_render_hash_caching(self) -> None:
+        """Calling _render twice without navigation should not rebuild."""
+        m1 = MenuUtils.generic_menu(title='A', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='B', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m1.enable()
+
+        bc = m1.get_current()._breadcrumb
+        bc._render()
+        surf1 = bc._surface
+        bc._render()
+        surf2 = bc._surface
+        # surface object identity should be preserved when hash hasn't changed
+        self.assertIs(surf1, surf2)
+
+    # ------------------------------------------------------------------
+    # Draw integration
+    # ------------------------------------------------------------------
+
+    def test_draw_at_root_no_error(self) -> None:
+        """Drawing at root depth must not raise."""
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        menu.enable()
+        menu.draw(surface)
+
+    def test_draw_at_depth_no_error(self) -> None:
+        """Drawing at depth > 0 must not raise."""
+        m1 = MenuUtils.generic_menu(title='A', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='B', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m1.enable()
+        m1.draw(surface)
+
+    def test_draw_multiple_depths(self) -> None:
+        """Navigate 5 levels and draw at each level."""
+        menus = [MenuUtils.generic_menu(title=f'M{i}', theme=self.theme) for i in range(6)]
+        for i in range(5):
+            menus[i].add.button('go', menus[i + 1]).apply()
+        menus[0].enable()
+
+        # Draw at the deepest level
+        menus[0].draw(surface)
+
+        # Now go back one level and draw again
+        menus[0].reset(1)
+        menus[0].draw(surface)
+
+    # ------------------------------------------------------------------
+    # Theme integration
+    # ------------------------------------------------------------------
+
+    def test_theme_custom_separator(self) -> None:
+        """Custom separator appears in the rendered path."""
+        self.theme.breadcrumb_separator = ' :: '
+        m1 = MenuUtils.generic_menu(title='A', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='B', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m1.enable()
+
+        bc = m1.get_current()._breadcrumb
+        self.assertEqual(bc._separator, ' :: ')
+
+    def test_theme_font_size(self) -> None:
+        """Font size from theme is used by breadcrumb."""
+        self.theme.breadcrumb_font_size = 24
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        self.assertEqual(menu._breadcrumb._bc_font_size, 24)
+
+    def test_theme_colors(self) -> None:
+        """Font and active colours from theme are forwarded."""
+        self.theme.breadcrumb_font_color = (200, 200, 200)
+        self.theme.breadcrumb_active_color = (10, 10, 10)
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        bc = menu._breadcrumb
+        # Colors may be extended by _format_color_opacity (adds alpha)
+        self.assertEqual(bc._bc_font_color[:3], (200, 200, 200))
+        self.assertEqual(bc._bc_active_color[:3], (10, 10, 10))
+
+    def test_theme_background_color(self) -> None:
+        """Background colour can be set via theme and is forwarded."""
+        self.theme.breadcrumb_background_color = (0, 0, 0)
+        menu = MenuUtils.generic_menu(title='Root', theme=self.theme)
+        bc = menu._breadcrumb
+        self.assertEqual(bc._bc_background_color[:3], (0, 0, 0))
+
+    def test_theme_validate_breadcrumb(self) -> None:
+        """Theme.validate() should succeed with breadcrumb defaults."""
+        theme = pygame_menu.themes.THEME_DEFAULT.copy()
+        theme.breadcrumb_enabled = True
+        theme.validate()  # Should not raise
+
+    def test_theme_validate_bad_font_size(self) -> None:
+        """Theme.validate() should reject non-positive font size."""
+        theme = pygame_menu.themes.THEME_DEFAULT.copy()
+        theme.breadcrumb_font_size = -1
+        self.assertRaises(AssertionError, theme.validate)
+
+    # ------------------------------------------------------------------
+    # Click navigation
+    # ------------------------------------------------------------------
+
+    def test_click_ancestor_navigates_back(self) -> None:
+        """Clicking an ancestor segment should call menu.reset() to go back."""
+        m1 = MenuUtils.generic_menu(title='Main', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='Sub1', theme=self.theme)
+        m3 = MenuUtils.generic_menu(title='Sub2', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m2.add.button('go', m3).apply()
+        m1.enable()
+
+        # We should be at depth 2 (Main > Sub1 > Sub2)
+        self.assertEqual(m1._get_depth(), 2)
+        self.assertEqual(m1.get_current().get_title(), 'Sub2')
+
+        # Render breadcrumb to set up the surface & rect
+        bc = m1.get_current()._breadcrumb
+        bc._render()
+
+        # Position breadcrumb at (0, 0) for easy clicking
+        bc._rect.x = 0
+        bc._rect.y = 0
+
+        # Create a click event inside the first segment ("Main")
+        # x=5 should land on the first segment
+        click_event = pygame.event.Event(
+            pygame.MOUSEBUTTONUP,
+            {'button': 1, 'pos': (5, 5)}
+        )
+        result = bc.update([click_event])
+        self.assertTrue(result)
+
+        # Should be back at root level
+        self.assertEqual(m1._get_depth(), 0)
+        self.assertEqual(m1.get_current().get_title(), 'Main')
+
+    def test_click_current_segment_no_navigation(self) -> None:
+        """Clicking on the current (last) segment should not navigate."""
+        m1 = MenuUtils.generic_menu(title='Main', theme=self.theme)
+        m2 = MenuUtils.generic_menu(title='Sub', theme=self.theme)
+        m1.add.button('go', m2).apply()
+        m1.enable()
+
+        bc = m1.get_current()._breadcrumb
+        bc._render()
+        bc._rect.x = 0
+        bc._rect.y = 0
+
+        # Click far right — should land on the last (current) segment
+        click_x = bc._rect.width - 5
+        click_event = pygame.event.Event(
+            pygame.MOUSEBUTTONUP,
+            {'button': 1, 'pos': (click_x, 5)}
+        )
+        result = bc.update([click_event])
+        self.assertFalse(result)
+        # Still at depth 1
+        self.assertEqual(m1._get_depth(), 1)
+
+    def test_click_outside_breadcrumb(self) -> None:
