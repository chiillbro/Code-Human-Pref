+class TooltipWidgetTest(BaseTest):
+
+    def test_tooltip_creation(self) -> None:
+        """
+        Test basic tooltip creation and properties.
+        """
+        tooltip = WidgetTooltip(text='Hello')
+        self.assertEqual(tooltip.get_text(), 'Hello')
+        self.assertFalse(tooltip.is_visible())
+
+    def test_tooltip_empty_text_raises(self) -> None:
+        """
+        Test that empty text raises an assertion.
+        """
+        self.assertRaises(AssertionError, lambda: WidgetTooltip(text=''))
+
+    def test_tooltip_invalid_font_size(self) -> None:
+        """
+        Test that invalid font_size raises an assertion.
+        """
+        self.assertRaises(AssertionError, lambda: WidgetTooltip(text='x', font_size=0))
+        self.assertRaises(AssertionError, lambda: WidgetTooltip(text='x', font_size=-1))
+
+    def test_tooltip_invalid_border_width(self) -> None:
+        """
+        Test that negative border_width raises an assertion.
+        """
+        self.assertRaises(AssertionError, lambda: WidgetTooltip(text='x', border_width=-1))
+
+    def test_tooltip_invalid_delay(self) -> None:
+        """
+        Test that negative delay raises an assertion.
+        """
+        self.assertRaises(AssertionError, lambda: WidgetTooltip(text='x', delay_ms=-1))
+
+    def test_tooltip_set_text(self) -> None:
+        """
+        Test set_text method.
+        """
+        tooltip = WidgetTooltip(text='Hello')
+        tooltip.set_text('World')
+        self.assertEqual(tooltip.get_text(), 'World')
+        # Setting empty text should raise
+        self.assertRaises(AssertionError, lambda: tooltip.set_text(''))
+
+    def test_tooltip_delay_visibility(self) -> None:
+        """
+        Test that tooltip becomes visible only after the delay.
+        """
+        tooltip = WidgetTooltip(text='Test', delay_ms=50)
+
+        # Not visible before mouse enter
+        self.assertFalse(tooltip.is_visible())
+
+        # Start hovering
+        tooltip.on_mouse_enter()
+        self.assertFalse(tooltip.is_visible())  # Not yet, delay not elapsed
+
+        # Wait for delay to pass
+        time.sleep(0.08)
+        self.assertTrue(tooltip.is_visible())
+
+    def test_tooltip_mouse_leave_hides(self) -> None:
+        """
+        Test that tooltip hides when mouse leaves.
+        """
+        tooltip = WidgetTooltip(text='Test', delay_ms=10)
+        tooltip.on_mouse_enter()
+        time.sleep(0.03)
+        self.assertTrue(tooltip.is_visible())
+
+        tooltip.on_mouse_leave()
+        self.assertFalse(tooltip.is_visible())
+
+    def test_tooltip_mouse_reenter(self) -> None:
+        """
+        Test that re-entering resets the delay.
+        """
+        tooltip = WidgetTooltip(text='Test', delay_ms=50)
+        tooltip.on_mouse_enter()
+        time.sleep(0.03)  # Not enough time
+        self.assertFalse(tooltip.is_visible())
+
+        tooltip.on_mouse_leave()
+        self.assertFalse(tooltip.is_visible())
+
+        # Re-enter should require waiting again
+        tooltip.on_mouse_enter()
+        self.assertFalse(tooltip.is_visible())
