+
+class TestVisualFeedback:
+    @staticmethod
+    def _make_menu_with_textinput(text=""):
+        menu = MenuUtils.generic_menu()
+        widget = menu.add.text_input("Name: ", default=text)
+        return menu, widget
+
+    def test_error_changes_border_color(self):
+        _, widget = self._make_menu_with_textinput("")
+        original_color = widget._border_color
+        widget.add_validator(Required())
+        widget.validate()
+        # Border should be error color (alpha added by theme)
+        assert widget._border_color[:3] == (220, 53, 69)
+
+    def test_error_creates_surface(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        widget.validate()
+        assert widget._validation_error_surface is not None
+        assert widget._validation_error_height > 0
+
+    def test_valid_shows_success_color(self):
+        _, widget = self._make_menu_with_textinput("hello")
+        widget.add_validator(Required())
+        # First validate with error to set up original border
+        widget._border_color = (0, 0, 0)
+        widget._border_width = 0
+        widget._original_border_color = (0, 0, 0)
+        widget._original_border_width = 0
+        widget.validate()
+        # Should show success color (alpha added by theme)
+        assert widget._border_color[:3] == (40, 167, 69)
+
+    def test_reset_restores_border(self):
+        _, widget = self._make_menu_with_textinput("")
+        original_color = widget._border_color
+        original_width = widget._border_width
+        widget.add_validator(Required())
+        widget.validate()
+        widget.reset_validation()
+        assert widget._border_color == original_color
+        assert widget._border_width == original_width
+
+    def test_error_expands_rect(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        widget.validate()
+        assert widget._rect_size_delta[1] > 0
+
+    def test_reset_clears_rect_delta(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        widget.validate()
+        widget.reset_validation()
+        assert widget._rect_size_delta[1] == 0
+
