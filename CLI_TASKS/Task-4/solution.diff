+class TestAutoValidateOnBlur:
+    def test_blur_triggers_validation(self):
+        menu = MenuUtils.generic_menu()
+        w1 = menu.add.text_input("Name: ", default="")
+        w2 = menu.add.text_input("Other: ", default="x")
