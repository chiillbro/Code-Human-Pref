+class TestCustom:
+    def test_pass(self):
+        v = Custom(lambda x: x > 0, "must be positive")
+        assert v.validate(1).is_valid
+
+    def test_fail(self):
+        v = Custom(lambda x: x > 0, "must be positive")
+        r = v.validate(-1)
+        assert not r.is_valid
+        assert r.error_message == "must be positive"
