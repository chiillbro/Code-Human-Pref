+# ---------------------------------------------------------------------------
+# CrossWidgetValidator
+# ---------------------------------------------------------------------------
+
+
+class TestCrossWidgetValidator:
+    def test_matching_values(self):
+        menu = MenuUtils.generic_menu()
+        w1 = menu.add.text_input("Pass: ", default="abc")
+        w2 = menu.add.text_input("Confirm: ", default="abc")
+
+        cv = CrossWidgetValidator(
+            widgets=[w1, w2],
+            fn=lambda vs: vs[0] == vs[1],
+            message="Passwords must match",
+            target_widget=w2,
+        )
+        result = cv.validate()
+        assert result is None  # Values match, no error
+
+    def test_mismatched_values(self):
+        menu = MenuUtils.generic_menu()
+        w1 = menu.add.text_input("Pass: ", default="abc")
+        w2 = menu.add.text_input("Confirm: ", default="xyz")
+
+        cv = CrossWidgetValidator(
+            widgets=[w1, w2],
+            fn=lambda vs: vs[0] == vs[1],
+            message="Passwords must match",
+            target_widget=w2,
+        )
+        result = cv.validate()
+        assert result is not None
+        assert not result.is_valid
+        assert result.error_message == "Passwords must match"
+
+    def test_widget_without_value(self):
+        """CrossWidgetValidator should handle widgets that raise ValueError."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Click")
+        w1 = menu.add.text_input("Name: ", default="x")
+
+        cv = CrossWidgetValidator(
+            widgets=[btn, w1],
+            fn=lambda vs: vs[0] is not None,
+            message="error",
+            target_widget=w1,
+        )
+        result = cv.validate()
+        # btn has no value -> None is passed -> fn returns False
+        assert result is not None
+
