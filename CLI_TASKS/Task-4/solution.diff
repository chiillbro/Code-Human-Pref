+    def test_no_max(self):
+        assert NumberRange(min_val=0).validate(999).is_valid
+
+    def test_string_number(self):
+        assert NumberRange(0, 10).validate("5").is_valid
+
+    def test_non_numeric(self):
+        assert not NumberRange(0, 10).validate("abc").is_valid
+
+    def test_none(self):
+        assert not NumberRange(0, 10).validate(None).is_valid
+
