+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+VALIDATORS
+Composable validation framework for widget values.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    "CrossWidgetValidator",
+    "Custom",
+    "Email",
+    "MaxLength",
+    "MinLength",
+    "NumberRange",
+    "OneOf",
+    "Pattern",
+    "Required",
+    "ValidationResult",
+    "Validator",
+]
+
+import re
+from abc import ABC, abstractmethod
+from dataclasses import dataclass, field
+from typing import TYPE_CHECKING, Any, Callable
+
+if TYPE_CHECKING:
+    from pygame_menu.widgets.core.widget import Widget
+
+
+@dataclass
+class ValidationResult:
+    """Result of a single validation check."""
+
+    is_valid: bool
+    error_message: str | None = None
+    validator_name: str = ""
+
+
+class Validator(ABC):
+    """Abstract base class for value validators."""
+
+    def __init__(self, message: str = "") -> None:
+        self.message = message
+
+    @abstractmethod
+    def validate(self, value: Any) -> ValidationResult:
+        """Validate the given value and return a result."""
+        raise NotImplementedError
+
+    @property
+    def name(self) -> str:
+        return self.__class__.__name__
+
+
+class Required(Validator):
+    """Fails if value is None, empty string, or empty list."""
+
+    def __init__(self, message: str = "This field is required") -> None:
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        if value is None or value == "" or value == []:
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+class MinLength(Validator):
+    """Fails if len(value) < min_len."""
+
+    def __init__(self, min_len: int, message: str = "") -> None:
+        self.min_len = min_len
+        if not message:
+            message = f"Must be at least {min_len} characters"
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        try:
+            if len(value) < self.min_len:
+                return ValidationResult(
+                    is_valid=False,
+                    error_message=self.message,
+                    validator_name=self.name,
+                )
+        except TypeError:
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+class MaxLength(Validator):
+    """Fails if len(value) > max_len."""
+
+    def __init__(self, max_len: int, message: str = "") -> None:
+        self.max_len = max_len
+        if not message:
+            message = f"Must be at most {max_len} characters"
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        try:
+            if len(value) > self.max_len:
+                return ValidationResult(
+                    is_valid=False,
+                    error_message=self.message,
+                    validator_name=self.name,
+                )
+        except TypeError:
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+class Pattern(Validator):
+    """Fails if value doesn't match the regex pattern."""
+
+    def __init__(self, regex: str, message: str = "Invalid format") -> None:
+        self._pattern = re.compile(regex)
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        if not isinstance(value, str) or not self._pattern.fullmatch(value):
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+# RFC 5322 simplified email regex — balances strictness with practicality.
+# Allows common formats: user.name+tag@sub.domain.tld
+_EMAIL_REGEX = re.compile(
+    r"^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+"
+    r"@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?"
+    r"(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$"
+)
+
+
+class Email(Validator):
+    """Validates basic email format using a reasonable RFC 5322 regex."""
+
+    def __init__(self, message: str = "Invalid email address") -> None:
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        if not isinstance(value, str) or not _EMAIL_REGEX.fullmatch(value):
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+class NumberRange(Validator):
+    """Fails if numeric value is outside range."""
+
+    def __init__(
+        self,
+        min_val: float | None = None,
+        max_val: float | None = None,
+        message: str = "",
+    ) -> None:
+        self.min_val = min_val
+        self.max_val = max_val
+        if not message:
+            if min_val is not None and max_val is not None:
+                message = f"Must be between {min_val} and {max_val}"
+            elif min_val is not None:
+                message = f"Must be at least {min_val}"
+            elif max_val is not None:
+                message = f"Must be at most {max_val}"
+            else:
+                message = "Invalid number"
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        try:
+            num = float(value)
+        except (TypeError, ValueError):
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        if self.min_val is not None and num < self.min_val:
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        if self.max_val is not None and num > self.max_val:
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+class Custom(Validator):
+    """Wraps an arbitrary predicate function."""
+
+    def __init__(
+        self, fn: Callable[[Any], bool], message: str = "Validation failed"
+    ) -> None:
+        self._fn = fn
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        if not self._fn(value):
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+class OneOf(Validator):
+    """Fails if value is not in the allowed choices list."""
+
+    def __init__(self, choices: list, message: str = "") -> None:
+        self.choices = choices
+        if not message:
+            message = f"Must be one of: {', '.join(str(c) for c in choices)}"
+        super().__init__(message)
+
+    def validate(self, value: Any) -> ValidationResult:
+        if value not in self.choices:
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name=self.name,
+            )
+        return ValidationResult(is_valid=True, validator_name=self.name)
+
+
+def run_validators(
+    validators: list[Validator],
+    value: Any,
+    collect_all: bool = False,
+) -> list[ValidationResult]:
+    """Run a list of validators against a value.
+
+    By default, stops at the first failure (short-circuit). If collect_all
+    is True, runs all validators and returns every failure.
+    """
+    errors: list[ValidationResult] = []
+    for v in validators:
+        result = v.validate(value)
+        if not result.is_valid:
+            errors.append(result)
+            if not collect_all:
+                break
+    return errors
+
+
+@dataclass
+class CrossWidgetValidator:
+    """Validates relationships between multiple widgets.
+
+    ``fn`` receives the list of values from ``widgets``. If it returns False,
+    the error is attached to ``target_widget``.
+    """
+
+    widgets: list[Widget] = field(default_factory=list)
+    fn: Callable[[list[Any]], bool] = field(default=lambda vs: True)
+    message: str = ""
+    target_widget: Widget | None = None
+
+    def validate(self) -> ValidationResult | None:
+        """Evaluate the cross-widget rule."""
+        values: list[Any] = []
+        for w in self.widgets:
+            try:
+                values.append(w.get_value())
+            except ValueError:
+                values.append(None)
+        if not self.fn(values):
+            return ValidationResult(
+                is_valid=False,
+                error_message=self.message,
+                validator_name="CrossWidgetValidator",
+            )
+        return None
