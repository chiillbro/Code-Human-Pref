+class TestWidgetValidation:
+    @staticmethod
+    def _make_menu_with_textinput(text=""):
+        menu = MenuUtils.generic_menu()
+        widget = menu.add.text_input("Name: ", default=text)
+        return menu, widget
+
+    def test_add_validator_chaining(self):
+        _, widget = self._make_menu_with_textinput()
+        result = widget.add_validator(Required()).add_validator(MinLength(2))
+        assert result is widget
+        assert len(widget._validators) == 2
+
+    def test_remove_validator(self):
+        _, widget = self._make_menu_with_textinput()
+        v = Required()
+        widget.add_validator(v)
+        widget.remove_validator(v)
+        assert len(widget._validators) == 0
+
+    def test_clear_validators(self):
+        _, widget = self._make_menu_with_textinput()
+        widget.add_validator(Required())
+        widget.add_validator(MinLength(2))
+        widget.clear_validators()
+        assert len(widget._validators) == 0
+
+    def test_clear_validators_resets_visual(self):
+        _, widget = self._make_menu_with_textinput()
+        widget.add_validator(Required())
+        widget.validate()
+        assert widget._show_validation
+        widget.clear_validators()
+        assert not widget._show_validation
+        assert widget._validation_error_surface is None
+
+    def test_set_required(self):
+        _, widget = self._make_menu_with_textinput()
+        widget.set_required("fill this")
+        assert len(widget._validators) == 1
+        assert isinstance(widget._validators[0], Required)
+
+    def test_validate_invalid(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        errors = widget.validate()
+        assert len(errors) == 1
+        assert not errors[0].is_valid
+
+    def test_validate_valid(self):
+        _, widget = self._make_menu_with_textinput("hello")
+        widget.add_validator(Required())
+        errors = widget.validate()
+        assert len(errors) == 0
+
+    def test_is_valid(self):
+        _, widget = self._make_menu_with_textinput("ok")
+        widget.add_validator(Required())
+        assert widget.is_valid()
+
+    def test_is_valid_false(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        assert not widget.is_valid()
+
+    def test_validate_no_get_value(self):
+        """Widgets without get_value() should be silently skipped."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button("Click me")
+        btn.add_validator(Required())
+        errors = btn.validate()
+        assert len(errors) == 0
+
+    def test_get_validation_errors(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        widget.validate()
+        errors = widget.get_validation_errors()
+        assert len(errors) == 1
+
+    def test_reset_validation(self):
+        _, widget = self._make_menu_with_textinput("")
+        widget.add_validator(Required())
+        widget.validate()
+        assert widget._show_validation
+        widget.reset_validation()
+        assert not widget._show_validation
+        assert len(widget._validation_errors) == 0
+
