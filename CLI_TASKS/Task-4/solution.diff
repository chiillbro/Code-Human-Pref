+class TestRunValidators:
+    def test_short_circuit(self):
+        validators = [Required(), MinLength(3), MaxLength(10)]
+        errors = run_validators(validators, "")
+        assert len(errors) == 1
+        assert errors[0].validator_name == "Required"
+
+    def test_collect_all(self):
+        validators = [Required(), MinLength(3)]
+        errors = run_validators(validators, "", collect_all=True)
+        assert len(errors) == 2
+
+    def test_all_pass(self):
+        validators = [Required(), MinLength(2)]
+        errors = run_validators(validators, "hello")
+        assert len(errors) == 0
