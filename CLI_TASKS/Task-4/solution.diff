+
+    def test_blur_no_validation_when_disabled(self):
+        menu = MenuUtils.generic_menu()
+        w1 = menu.add.text_input("Name: ", default="")
+        w1.add_validator(Required())
+        w1._auto_validate_on_blur = False
+
+        w1.select(True)
+        w1.select(False)
+
+        assert not w1._show_validation
+
