+"""
+Tests for the Widget Validation Framework.
+
+Covers:
+- All validator primitives (Required, MinLength, MaxLength, Pattern, Email,
+  NumberRange, Custom, OneOf)
+- Short-circuit vs collect-all mode
+- ValidationResult dataclass
+- Widget validation API (add_validator, remove_validator, validate, is_valid,
+  set_required, clear_validators, auto-validate-on-blur/change)
+- Visual error feedback (border color changes, error surface)
+- CrossWidgetValidator
+- Menu.validate(), Menu.is_valid(), Menu.reset_validation()
+- WidgetManager convenience kwargs (validators, required)
+"""
+
+from __future__ import annotations
+
+import pytest
+
+import pygame_menu
+from pygame_menu.validators import (
+    CrossWidgetValidator,
+    Custom,
+    Email,
+    MaxLength,
+    MinLength,
+    NumberRange,
+    OneOf,
+    Pattern,
+    Required,
+    ValidationResult,
+    Validator,
+    run_validators,
+)
+from test._utils import MenuUtils, surface
+
+# ---------------------------------------------------------------------------
+# Validator Primitives
+# ---------------------------------------------------------------------------
+
+
+class TestValidationResult:
+    def test_defaults(self):
+        r = ValidationResult(is_valid=True)
+        assert r.is_valid is True
+        assert r.error_message is None
+        assert r.validator_name == ""
+
+    def test_error(self):
+        r = ValidationResult(
+            is_valid=False, error_message="oops", validator_name="Required"
+        )
+        assert r.is_valid is False
+        assert r.error_message == "oops"
+
+
+class TestRequired:
+    def test_none(self):
+        v = Required()
+        assert not v.validate(None).is_valid
+
+    def test_empty_string(self):
+        assert not Required().validate("").is_valid
+
+    def test_empty_list(self):
+        assert not Required().validate([]).is_valid
+
+    def test_valid_string(self):
+        assert Required().validate("hello").is_valid
+
+    def test_valid_number(self):
+        assert Required().validate(42).is_valid
+
+    def test_custom_message(self):
+        v = Required("fill this in")
+        r = v.validate("")
+        assert r.error_message == "fill this in"
+
+
+class TestMinLength:
+    def test_too_short(self):
+        assert not MinLength(3).validate("ab").is_valid
+
+    def test_exact(self):
+        assert MinLength(3).validate("abc").is_valid
+
+    def test_longer(self):
+        assert MinLength(3).validate("abcd").is_valid
+
+    def test_non_sized(self):
+        assert not MinLength(1).validate(42).is_valid
+
+
+class TestMaxLength:
+    def test_too_long(self):
+        assert not MaxLength(3).validate("abcd").is_valid
+
+    def test_exact(self):
+        assert MaxLength(3).validate("abc").is_valid
+
+    def test_shorter(self):
+        assert MaxLength(3).validate("ab").is_valid
+
+
+class TestPattern:
+    def test_match(self):
+        assert Pattern(r"\d{3}").validate("123").is_valid
+
+    def test_no_match(self):
+        assert not Pattern(r"\d{3}").validate("12a").is_valid
