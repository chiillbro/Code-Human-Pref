+class TestNumberRange:
+    def test_in_range(self):
+        assert NumberRange(0, 10).validate(5).is_valid
+
+    def test_at_min(self):
+        assert NumberRange(0, 10).validate(0).is_valid
+
+    def test_at_max(self):
+        assert NumberRange(0, 10).validate(10).is_valid
+
+    def test_below_min(self):
