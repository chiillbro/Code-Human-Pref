     ti.draw(surface)  # should not crash and normal border path taken
 
 
+def test_error_label_surface_built_and_drawn():
+    """Invalid state must render an error label below the widget body."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("Email: ", validators=[Email()], required=True)
+    ti.set_value("bad")
+    ti.validate()
+
+    assert ti._validation_error_surface is not None
+    assert ti._validation_error_surface.get_height() > 0
+    # draw() must blit it without crashing
+    menu.draw(surface)
+
+
+def test_error_label_grows_widget_height():
+    """Error label must extend reported rect so next widget doesn't overlap."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("filled")
+    h_clean = ti.get_height()
+    base_delta = ti._rect_size_delta
+
+    ti.set_value("")
+    ti.validate()  # → invalid, builds error surface, grows delta
+    err_h = ti._validation_error_surface.get_height() + 2
+    assert ti._validation_rect_delta == err_h
+    assert ti._rect_size_delta[1] == base_delta[1] + err_h
+    assert ti.get_height() == h_clean + err_h
+
+    # Menu surface must have been invalidated so layout recomputes
+    assert menu._widgets_surface is None
+
+    # Fix the value → teardown gives the height back
+    ti.set_value("filled")
+    ti.validate()
+    assert ti._validation_error_surface is None
+    assert ti._validation_rect_delta == 0
+    assert ti._rect_size_delta == base_delta
+    assert ti.get_height() == h_clean
+
+
+def test_error_label_no_overlap_in_layout():
+    """End-to-end: widget below an invalid field must be pushed down."""
+    menu = MenuUtils.generic_menu()
+    top = menu.add.text_input("Top: ", required=True)
+    bottom = menu.add.text_input("Bottom: ")
+    menu.render()
+    y_before = bottom.get_rect().y
+
+    top.set_value("")
+    top.validate()
+    menu.render()
+    y_after = bottom.get_rect().y
+
+    assert y_after > y_before
+    assert top.get_rect().bottom <= bottom.get_rect().top  # no overlap
+
+
+def test_error_label_rebuilt_on_message_change():
+    """If error text changes (still invalid), the label surface is rebuilt."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", validators=[MinLength(10), Email()])
+
+    ti.set_value("abc")  # fails MinLength first
+    ti.validate()
+    surf1 = ti._validation_error_surface
+
+    ti.set_value("abcdefghijk")  # passes MinLength, fails Email
+    ti.validate()
+    surf2 = ti._validation_error_surface
+
+    assert surf1 is not surf2
+    assert surf2 is not None
+
+
+def test_success_border_one_shot():
+    """invalid→valid shows success border, next _force_render reverts."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+
+    ti.set_value("")
+    ti.validate()
+    assert ti._validation_show_success is False  # currently invalid
+
+    ti.set_value("filled")
+    ti.validate()  # invalid → valid
+    assert ti._validation_show_success is True
+    assert ti._validation_errors == []
+    ti.draw(surface)  # draws the success border
+
+    # Next interaction (any _force_render) reverts to normal border
+    ti._force_render()
+    assert ti._validation_show_success is False
+
+
+def test_success_border_skipped_on_clean_first_pass():
+    """No success flash if the widget was never invalid."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("filled")
+    ti.validate()
+    assert ti._validation_show_success is False
+
+
+def test_success_color_from_theme():
+    theme = pygame_menu.themes.THEME_DEFAULT.copy()
+    theme.widget_validation_success_color = (1, 2, 3)
+    menu = MenuUtils.generic_menu(theme=theme)
+    ti = menu.add.text_input("X: ")
+    assert ti._validation_success_color[:3] == (1, 2, 3)
+
+
+def test_clear_validators_tears_down_error_surface():
+    """clear_validators() must also restore border & drop the error label."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    base_delta = ti._rect_size_delta
+
+    ti.set_value("")
+    ti.validate()
+    assert ti._validation_error_surface is not None
+    assert ti._rect_size_delta[1] > base_delta[1]
+
+    ti.clear_validators()
+
