+
+
+def test_auto_validate_on_blur_skipped_without_validators():
+    """Widgets with no validators don't validate on blur (avoids pointless work)."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")  # no validators, auto-selected
