+
+
+def test_rangeslider_blur_calls_super():
+    """RangeSlider overrides _blur() — must still trigger auto-validate."""
+    menu = MenuUtils.generic_menu()
+    rs = menu.add.range_slider(
+        "Val: ", 50, (0, 100), 1,
