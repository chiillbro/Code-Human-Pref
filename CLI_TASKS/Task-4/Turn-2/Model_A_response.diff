+
+def test_textinput_blur_calls_super():
+    """TextInput overrides _blur() — must still trigger auto-validate."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", validators=[MinLength(5)])
+    ti.set_value("ab")
+    ti.select(False)  # blur → auto validate
+    assert ti._validation_result is not None
