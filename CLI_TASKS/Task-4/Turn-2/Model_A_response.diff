+
+
+# ---------------------------------------------------------------------------
+# Auto-validate on blur
+# ---------------------------------------------------------------------------
+
+def test_auto_validate_on_blur_default():
+    """Losing focus runs validate() automatically when validators are attached."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+
+    assert ti._auto_validate_on_blur is True
+    ti.set_value("")
+    # Widget was auto-selected on append (first selectable widget) → touched.
+    # It has not been validated yet because it never blurred.
+    assert ti._validation_result is None
+
+    ti.select(False)  # → _blur() → auto validate
+    assert ti._validation_result is not None
+    assert not ti._validation_result.valid
+    assert ti._validation_error_surface is not None
+
+
+def test_auto_validate_untouched_widget_skipped():
+    """A widget never focused by the user must NOT validate on creation blur."""
+    menu = MenuUtils.generic_menu()
+    menu.add.text_input("First: ")  # takes auto-selection
+    second = menu.add.text_input("Second: ", required=True)  # never focused
+    # _append_widget called select(False) on `second` but it was never touched
+    assert second._validation_result is None
+    assert second._validation_error_surface is None
+
+
+def test_auto_validate_on_blur_can_be_disabled():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_auto_validate_on_blur(False)
+
+    ti.set_value("")
