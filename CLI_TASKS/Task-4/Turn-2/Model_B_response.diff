         theme.validate()
 
 
+def test_theme_has_success_color():
+    theme = pygame_menu.themes.THEME_DEFAULT.copy()
+    assert hasattr(theme, "widget_validation_success_color")
+    assert theme.widget_validation_success_color[:3] == (40, 167, 69)
+    theme.validate()
+
+
+def test_theme_success_color_applied_to_widget():
+    theme = pygame_menu.themes.THEME_DEFAULT.copy()
+    theme.widget_validation_success_color = (0, 255, 0)
+    menu = MenuUtils.generic_menu(theme=theme)
+    ti = menu.add.text_input("X: ")
+    assert ti._validation_success_color[:3] == (0, 255, 0)
+
+
+def test_theme_success_color_constructor_kwarg():
+    theme = pygame_menu.Theme(widget_validation_success_color=(10, 200, 30))
+    theme.validate()
+    assert theme.widget_validation_success_color[:3] == (10, 200, 30)
+
+
+# ---------------------------------------------------------------------------
+# Error text rendering below widget
+# ---------------------------------------------------------------------------
+
+def test_error_surface_created_on_invalid():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    assert ti._validation_error_surface is None
+
+    ti.validate()
+    assert ti._validation_error_surface is not None
+    assert ti._rect_size_delta[1] > 0  # height grew
+
+
+def test_error_surface_removed_on_valid():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    assert ti._validation_error_surface is not None
+    old_delta = ti._rect_size_delta[1]
+    assert old_delta > 0
+
+    ti.set_value("hello")
+    ti.validate()
+    assert ti._validation_error_surface is None
+    assert ti._rect_size_delta[1] == 0
+
+
+def test_error_surface_draw_does_not_crash():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    ti.draw(surface)  # must not crash
+
+
+def test_clear_validation_removes_error_surface():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    assert ti._validation_error_surface is not None
+
+    ti.clear_validation()
+    assert ti._validation_error_surface is None
+    assert ti._rect_size_delta[1] == 0
+
+
+def test_clear_validators_removes_error_surface_and_border():
+    """clear_validators() must also clear the visual invalid state."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    assert ti._validation_error_surface is not None
+    assert ti._validation_errors
+
+    ti.clear_validators()
+    assert ti._validation_error_surface is None
+    assert ti._validation_errors == []
+    assert ti._rect_size_delta[1] == 0
+    assert ti.get_validators() == ()
+
+
+# ---------------------------------------------------------------------------
+# Success color (invalid → valid flash)
+# ---------------------------------------------------------------------------
+
+def test_success_flag_set_on_invalid_to_valid():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    assert not ti._validation_showing_success
+
+    ti.set_value("hello")
+    ti.validate()
+    assert ti._validation_showing_success
+
+
+def test_success_flag_cleared_on_blur():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    ti.set_value("hello")
+    ti.validate()
+    assert ti._validation_showing_success
+
+    ti._blur()
+    assert not ti._validation_showing_success
+
+
+def test_success_border_drawn():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    ti.set_value("ok")
+    ti.validate()
+    assert ti._validation_showing_success
+    ti.draw(surface)  # must not crash, should draw green border
+
+
+def test_set_validation_success_color():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.set_validation_success_color((100, 200, 50))
+    assert ti._validation_success_color[:3] == (100, 200, 50)
+
+
+# ---------------------------------------------------------------------------
+# Auto-validate on blur
+# ---------------------------------------------------------------------------
+
+def test_auto_validate_on_blur_textinput():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    assert ti._validation_result is None  # not yet validated
+
+    # Simulate user focus then blur (selection_time must be > 0)
+    ti._focus()
+    ti._blur()
+    assert ti._validation_result is not None
+    assert not ti._validation_result.valid
+
+
+def test_auto_validate_on_blur_rangeslider():
+    menu = MenuUtils.generic_menu()
+    rs = menu.add.range_slider("R: ", default=5, range_values=(0, 10), increment=1)
+    rs.add_validator(Custom(lambda v: v > 3))
+    # Simulate user focus then blur
+    rs._focus()
+    rs._blur()
+    assert rs._validation_result is not None
+    assert rs._validation_result.valid
+
+
+def test_auto_validate_disabled():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_auto_validate_on_blur(False)
+    ti.set_value("")
+    # Simulate user focus then blur
+    ti._focus()
+    ti._blur()
+    assert ti._validation_result is None  # should NOT have auto-validated
+
+
+def test_auto_validate_on_blur_skipped_when_no_validators():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.set_value("")
+    ti._blur()
+    # No validators → no auto-validation triggered → result stays None
+    assert ti._validation_result is None
+
+
+# ---------------------------------------------------------------------------
+# Menu surface invalidation
+# ---------------------------------------------------------------------------
+
+def test_menu_surface_invalidated_on_validation_state_change():
+    """Validation state flip must set _widgets_surface to None."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(Required())
+    ti.set_value("")
+
+    # Baseline: ensure menu surface exists
+    menu._render()
+    menu.render()
+    ws_before = menu._widgets_surface
+
+    # Validation flips None → invalid → _invalidate_menu_surface sets to None
+    # but _force_render re-renders immediately. Instead, verify indirectly by
+    # checking the widget's rect delta grew:
+    ti.validate()
+    assert ti._rect_size_delta[1] > 0  # error label added height
+
+    ti.set_value("hello")
+    ti.validate()
+    assert ti._rect_size_delta[1] == 0  # error label removed
+
+
