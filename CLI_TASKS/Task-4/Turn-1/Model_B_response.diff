+    ) -> tuple[bool, dict[str, list[str]]]:
+        """
+        Validate all widgets in the Menu that have validators attached.
+        Also runs any cross-validators registered on this Menu.
+
+        :param collect_all: If ``True``, collect all errors from all widgets instead of stopping at first invalid widget
+        :return: Tuple of (is_valid, errors_dict) where errors_dict maps widget IDs to lists of error messages
+        """
+        from pygame_menu.validation import (
+            ValidationResult,
+            VALIDATION_MODE_COLLECT_ALL,
+            VALIDATION_MODE_FAIL_FAST,
+        )
+        errors: dict[str, list[str]] = {}
+        all_valid = True
+
+        for widget in self._widgets:
+            if not widget._validators:
+                continue
+            old_mode = widget._validation_mode
+            if collect_all:
+                widget._validation_mode = VALIDATION_MODE_COLLECT_ALL
+            result = widget.validate()
+            widget._validation_mode = old_mode
+            if not result.valid:
+                all_valid = False
+                errors[widget.get_id()] = result.errors
+                if not collect_all:
+                    break
+
+        # Run cross-validators
+        if hasattr(self, "_cross_validators") and self._cross_validators:
+            widget_map = {w.get_id(): w for w in self._widgets}
+            for cv in self._cross_validators:
+                cv_errors = cv(widget_map)
+                for wid, msg in cv_errors:
+                    all_valid = False
+                    if wid not in errors:
+                        errors[wid] = []
+                    errors[wid].append(msg)
+                    # Also set the error on the widget for visual feedback
+                    w = widget_map.get(wid)
+                    if w is not None:
+                        w._validation_errors.append(msg)
+
+        return all_valid, errors
+
+    def add_cross_validator(self, *validators: 'CrossValidator') -> Menu:
+        """
+        Add one or more cross-validators that check relationships between
