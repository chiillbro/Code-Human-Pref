+
+    def set_validation_mode(self, mode: str) -> Widget:
+        """
+        Set the validation mode.
+
+        :param mode: ``"fail_fast"`` to stop at first error, ``"collect_all"`` to gather all errors
+        :return: Self reference
+        """
+        from pygame_menu.validation import VALIDATION_MODE_FAIL_FAST, VALIDATION_MODE_COLLECT_ALL
+        assert mode in (VALIDATION_MODE_FAIL_FAST, VALIDATION_MODE_COLLECT_ALL), (
