+        )
+        self._validation_mode = mode
+        return self
+
+    def validate(self) -> 'ValidationResult':
+        """
+        Run all validators on the current widget value. Returns a
+        :py:class:`pygame_menu.validation.ValidationResult`.
+
+        :return: Validation result
+        """
+        from pygame_menu.validation import ValidationResult, VALIDATION_MODE_FAIL_FAST
+        errors: list[str] = []
+        try:
+            value = self.get_value()
+        except ValueError:
+            value = None
