+
+        :param validators: CrossValidator instances
+        :return: Self reference
+        """
+        from pygame_menu.validation import CrossValidator
+        if not hasattr(self, "_cross_validators"):
+            self._cross_validators = []
+        for v in validators:
+            assert isinstance(v, CrossValidator), (
+                f"expected CrossValidator instance, got {type(v)}"
+            )
+            self._cross_validators.append(v)
+        return self
+
+    def clear_validation_errors(self) -> Menu:
+        """
+        Clear validation errors on all widgets in the Menu.
+
+        :return: Self reference
