+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST VALIDATION
+Tests for the widget validation system.
+"""
+
+from test._utils import MenuUtils, surface
+
+import pygame_menu
+from pygame_menu.validation import (
+    Required,
+    MinLength,
+    MaxLength,
+    Pattern,
+    Email,
+    Range,
+    OneOf,
+    NoneOf,
+    Custom,
+    CrossValidator,
+    MatchField,
+    ValidationResult,
+    VALIDATION_MODE_FAIL_FAST,
+    VALIDATION_MODE_COLLECT_ALL,
+)
+
+
+# =============================================================================
+# Validator primitives
+# =============================================================================
+
+
+class TestValidatorPrimitives:
+    """Tests for individual validator classes."""
+
+    def test_required_empty_string(self):
+        v = Required()
+        assert v("", None) is not None
+
+    def test_required_whitespace(self):
+        v = Required()
+        assert v("   ", None) is not None
+
+    def test_required_none(self):
+        v = Required()
