+        Return the current list of validation error messages from the last
+        :py:meth:`validate` call.
+
+        :return: List of error strings
+        """
+        return list(self._validation_errors)
+
+    def clear_validation_errors(self) -> Widget:
+        """
+        Clear any stored validation errors and reset the visual error state.
+
+        :return: Self reference
+        """
+        self._validation_errors.clear()
+        return self
