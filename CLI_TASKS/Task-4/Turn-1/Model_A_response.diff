diff --git a/pygame_menu/validation.py b/pygame_menu/validation.py
new file mode 100644
index 00000000..dde0ecc3
--- /dev/null
+++ b/pygame_menu/validation.py
@@ -0,0 +1,423 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+VALIDATION
+Composable validator primitives and validation results for widget input
+validation.
+"""
+
+from __future__ import annotations
+
+__all__ = [
+    # Core
+    "Validator",
+    "ValidationResult",
+    # Primitives
+    "Required",
+    "MinLength",
+    "MaxLength",
+    "Pattern",
+    "Range",
+    "Email",
+    "Custom",
+    # Cross-widget
+    "CrossWidgetValidator",
+    "FieldMatch",
+    # Constants
+    "VALIDATE_MODE_FAIL_FAST",
+    "VALIDATE_MODE_COLLECT_ALL",
+]
+
+import re
+from abc import ABC, abstractmethod
+from collections.abc import Callable, Sequence
+from typing import TYPE_CHECKING, Any, Optional
+
+if TYPE_CHECKING:
+    from pygame_menu.widgets.core.widget import Widget
+
+VALIDATE_MODE_FAIL_FAST = "fail-fast"
+"""Stop validation at the first failure (default)."""
+
+VALIDATE_MODE_COLLECT_ALL = "collect-all"
+"""Run every validator and collect all error messages."""
+
+
+class ValidationResult:
+    """
+    Outcome of running one or more validators against a value.
+
+    A result is *truthy* when valid and *falsy* when invalid, so it can be used
+    directly in boolean expressions::
+
+        if widget.validate():
+            submit()
+
+    :param valid: ``True`` if validation passed
+    :param errors: List of error messages (empty if valid)
+    :param value: The value that was validated
+    """
+
+    __slots__ = ("valid", "errors", "value")
+
+    def __init__(
+        self,
+        valid: bool,
+        errors: Optional[list[str]] = None,
+        value: Any = None,
+    ) -> None:
+        self.valid = valid
+        self.errors = errors or []
+        self.value = value
+
+    def __bool__(self) -> bool:
+        return self.valid
+
+    def __repr__(self) -> str:
+        if self.valid:
+            return "ValidationResult(valid=True)"
+        return f"ValidationResult(valid=False, errors={self.errors!r})"
+
+    @property
+    def first_error(self) -> Optional[str]:
+        """Return the first error message, or ``None`` if valid."""
+        return self.errors[0] if self.errors else None
+
+    def merge(self, other: ValidationResult) -> ValidationResult:
+        """
+        Merge another result into this one (in-place) and return self.
+
+        :param other: Result to merge
+        :return: Self reference
+        """
+        if not other.valid:
+            self.valid = False
+            self.errors.extend(other.errors)
+        return self
+
+    @classmethod
+    def ok(cls, value: Any = None) -> ValidationResult:
+        """Create a successful result."""
+        return cls(True, [], value)
+
+    @classmethod
+    def fail(cls, message: str, value: Any = None) -> ValidationResult:
+        """Create a failed result with a single error message."""
+        return cls(False, [message], value)
+
+
+class Validator(ABC):
+    """
+    Abstract base class for all validators.
+
+    Subclasses must implement :py:meth:`check` returning ``None`` on success or
+    an error message string on failure.
+
+    :param message: Optional custom error message overriding the default
+    """
+
+    __slots__ = ("_message",)
+
+    def __init__(self, message: Optional[str] = None) -> None:
+        self._message = message
+
+    @abstractmethod
+    def check(self, value: Any) -> Optional[str]:
+        """
+        Validate a value.
+
+        :param value: Value to validate (usually the widget's ``get_value()``)
+        :return: ``None`` if valid, otherwise an error message string
+        """
+        raise NotImplementedError
+
+    def __call__(self, value: Any) -> ValidationResult:
+        """
+        Run the validator and wrap the outcome in a :py:class:`ValidationResult`.
+
+        :param value: Value to validate
+        :return: Validation result
+        """
+        error = self.check(value)
+        if error is None:
+            return ValidationResult.ok(value)
+        return ValidationResult.fail(error, value)
+
+    def __repr__(self) -> str:
+        return f"{self.__class__.__name__}()"
+
+    def _msg(self, default: str) -> str:
+        """Return the custom message if set, otherwise the default."""
+        return self._message if self._message is not None else default
+
+
+def _is_empty(value: Any) -> bool:
+    """Return ``True`` if ``value`` should be considered empty/blank."""
+    if value is None:
+        return True
+    if isinstance(value, str):
+        return value.strip() == ""
+    if isinstance(value, (list, tuple, set, dict)):
+        return len(value) == 0
+    return False
+
+
+class Required(Validator):
+    """
+    Validator that fails when the value is empty.
+
+    Empty means ``None``, an empty/whitespace-only string, or an empty
+    collection.
+    """
+
+    def check(self, value: Any) -> Optional[str]:
+        if _is_empty(value):
+            return self._msg("This field is required")
+        return None
+
+
+class MinLength(Validator):
+    """
+    Validator that fails when ``len(value)`` is less than ``length``.
+
+    Empty values are skipped (combine with :py:class:`Required` to reject
+    blanks).
+
+    :param length: Minimum allowed length (inclusive)
+    :param message: Optional custom error message
+    """
+
+    __slots__ = ("_length",)
+
+    def __init__(self, length: int, message: Optional[str] = None) -> None:
+        assert isinstance(length, int) and length >= 0
+        super().__init__(message)
+        self._length = length
+
+    def check(self, value: Any) -> Optional[str]:
+        if _is_empty(value):
+            return None
+        try:
+            actual = len(value)
+        except TypeError:
+            actual = len(str(value))
+        if actual < self._length:
+            return self._msg(f"Must be at least {self._length} characters")
+        return None
+
+    def __repr__(self) -> str:
+        return f"MinLength({self._length})"
+
+
+class MaxLength(Validator):
+    """
+    Validator that fails when ``len(value)`` is greater than ``length``.
+
+    :param length: Maximum allowed length (inclusive)
+    :param message: Optional custom error message
+    """
+
+    __slots__ = ("_length",)
+
+    def __init__(self, length: int, message: Optional[str] = None) -> None:
+        assert isinstance(length, int) and length >= 0
+        super().__init__(message)
+        self._length = length
+
+    def check(self, value: Any) -> Optional[str]:
+        if value is None:
+            return None
+        try:
+            actual = len(value)
+        except TypeError:
+            actual = len(str(value))
+        if actual > self._length:
+            return self._msg(f"Must be at most {self._length} characters")
+        return None
+
+    def __repr__(self) -> str:
+        return f"MaxLength({self._length})"
+
+
+class Pattern(Validator):
+    """
+    Regex-based validator. Fails when the value does not match ``pattern``.
+
+    Uses :py:func:`re.fullmatch` so the entire string must match. Empty values
+    are skipped.
+
+    :param pattern: Regular-expression pattern (string or compiled ``re.Pattern``)
+    :param message: Optional custom error message
+    :param flags: Regex flags passed to :py:func:`re.compile`
+    """
+
+    __slots__ = ("_pattern",)
+
+    def __init__(
+        self,
+        pattern: str | re.Pattern[str],
+        message: Optional[str] = None,
+        flags: int = 0,
+    ) -> None:
+        super().__init__(message)
+        if isinstance(pattern, re.Pattern):
+            self._pattern = pattern
+        else:
+            self._pattern = re.compile(pattern, flags)
+
+    def check(self, value: Any) -> Optional[str]:
+        if _is_empty(value):
+            return None
+        if self._pattern.fullmatch(str(value)) is None:
+            return self._msg("Invalid format")
+        return None
+
+    def __repr__(self) -> str:
+        return f"Pattern({self._pattern.pattern!r})"
+
+
+# Permissive RFC-5322-ish pattern — deliberately not strict
+_EMAIL_RE = re.compile(
+    r"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}"
+)
+
+
+class Email(Pattern):
+    """
+    Convenience :py:class:`Pattern` validator for email addresses.
+
+    Uses a permissive regex; for stricter checking supply your own
+    :py:class:`Pattern`.
+    """
+
+    def __init__(self, message: Optional[str] = None) -> None:
+        super().__init__(_EMAIL_RE, message or "Enter a valid email address")
+
+
+class Range(Validator):
+    """
+    Validator for numeric values. Fails when the value is outside
+    ``[min_value, max_value]``.
+
+    Either bound may be ``None`` to disable that side of the check.
+
+    :param min_value: Lower bound (inclusive) or ``None``
+    :param max_value: Upper bound (inclusive) or ``None``
+    :param message: Optional custom error message
+    """
+
+    __slots__ = ("_min", "_max")
+
+    def __init__(
+        self,
+        min_value: Optional[float] = None,
+        max_value: Optional[float] = None,
+        message: Optional[str] = None,
+    ) -> None:
+        super().__init__(message)
+        self._min = min_value
+        self._max = max_value
+
+    def check(self, value: Any) -> Optional[str]:
+        if _is_empty(value):
+            return None
+        try:
+            num = float(value)
+        except (TypeError, ValueError):
+            return self._msg("Must be a number")
+        if self._min is not None and num < self._min:
+            return self._msg(f"Must be at least {self._min}")
+        if self._max is not None and num > self._max:
+            return self._msg(f"Must be at most {self._max}")
+        return None
+
+    def __repr__(self) -> str:
+        return f"Range(min={self._min}, max={self._max})"
+
+
+class Custom(Validator):
+    """
+    Wrap a plain callable as a validator.
+
+    The callable receives the value and returns either:
+
+    - ``None`` / ``True`` → valid
+    - ``False`` → invalid (uses ``message``)
+    - ``str`` → invalid (returned string is the error message)
+
+    :param func: Callable implementing the check
+    :param message: Fallback error message when ``func`` returns ``False``
+    """
+
+    __slots__ = ("_func",)
+
+    def __init__(
+        self,
+        func: Callable[[Any], Any],
+        message: str = "Invalid value",
+    ) -> None:
+        assert callable(func), "func must be callable"
+        super().__init__(message)
+        self._func = func
+
+    def check(self, value: Any) -> Optional[str]:
+        result = self._func(value)
+        if result is None or result is True:
+            return None
+        if result is False:
+            return self._message
+        return str(result)
+
+
+# ---------------------------------------------------------------------------
+# Cross-widget validation
+# ---------------------------------------------------------------------------
+
+class CrossWidgetValidator(ABC):
+    """
+    Abstract base class for validators that inspect the relationship between
+    multiple widgets (e.g. "password == confirm password").
+
+    Cross-widget validators are attached to a :py:class:`pygame_menu.Menu`
+    rather than to a single widget.
+    """
+
+    @abstractmethod
+    def check(self, widgets: Sequence[Widget]) -> Optional[str]:
+        """
+        Validate a relationship across widgets.
+
+        :param widgets: Ordered widgets participating in the relationship
+        :return: ``None`` if valid, otherwise an error message string
+        """
+        raise NotImplementedError
+
+    def __call__(self, widgets: Sequence[Widget]) -> ValidationResult:
+        error = self.check(widgets)
+        if error is None:
+            return ValidationResult.ok()
+        return ValidationResult.fail(error)
+
+
+class FieldMatch(CrossWidgetValidator):
+    """
+    Cross-widget validator that passes only when every widget in the group
+    returns the same value from ``get_value()``.
+
+    Typical use: password confirmation.
+
+    :param message: Optional custom error message
+    """
+
+    def __init__(self, message: Optional[str] = None) -> None:
+        self._message = message or "Fields do not match"
+
+    def check(self, widgets: Sequence[Widget]) -> Optional[str]:
+        if len(widgets) < 2:
+            return None
+        first = widgets[0].get_value()
+        for w in widgets[1:]:
+            if w.get_value() != first:
+                return self._message
+        return None
