@@ -0,0 +1,698 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST VALIDATION
+Tests for validator primitives, widget-level validation, cross-widget
+validation, menu-level form validation, and theme integration.
+"""
+
+import re
+
+import pytest
+
+import pygame_menu
+from pygame_menu.validation import (
+    VALIDATE_MODE_COLLECT_ALL,
+    VALIDATE_MODE_FAIL_FAST,
+    Custom,
+    Email,
+    FieldMatch,
+    MaxLength,
+    MinLength,
+    Pattern,
+    Range,
+    Required,
+    ValidationResult,
+    Validator,
+)
+from test._utils import MenuUtils, surface
+
+
+# ---------------------------------------------------------------------------
+# ValidationResult
+# ---------------------------------------------------------------------------
+
+def test_validation_result_truthiness():
+    ok = ValidationResult.ok("x")
+    assert ok
+    assert ok.valid is True
+    assert ok.errors == []
+    assert ok.first_error is None
+    assert ok.value == "x"
+
+    bad = ValidationResult.fail("nope", "y")
+    assert not bad
+    assert bad.valid is False
+    assert bad.errors == ["nope"]
+    assert bad.first_error == "nope"
+    assert bad.value == "y"
+
+    assert "valid=True" in repr(ok)
+    assert "nope" in repr(bad)
+
+
+def test_validation_result_merge():
+    r = ValidationResult.ok()
+    r.merge(ValidationResult.ok())
+    assert r.valid
+
+    r.merge(ValidationResult.fail("e1"))
+    r.merge(ValidationResult.fail("e2"))
+    assert not r.valid
+    assert r.errors == ["e1", "e2"]
+
+
+# ---------------------------------------------------------------------------
+# Validator primitives
+# ---------------------------------------------------------------------------
+
+def test_validator_is_abstract():
+    with pytest.raises(TypeError):
+        Validator()
+
+
+def test_required():
+    v = Required()
+    assert v("hello")
+    assert v(0)  # zero is not empty
+    assert v(False)  # False is not empty
+    assert not v("")
+    assert not v("   ")  # whitespace-only
+    assert not v(None)
+    assert not v([])
+    assert not v({})
+
+    custom = Required(message="Please fill this in")
+    assert custom("").first_error == "Please fill this in"
+
+
+def test_min_length():
+    v = MinLength(3)
+    assert v("abc")
+    assert v("abcd")
+    assert not v("ab")
+    assert v("")  # empty is skipped — combine with Required
+    assert v(None)
+    assert "MinLength(3)" == repr(v)
+
+    with pytest.raises(AssertionError):
+        MinLength(-1)
+
+
+def test_max_length():
+    v = MaxLength(5)
+    assert v("hello")
+    assert v("hi")
+    assert not v("hello!")
+    assert v(None)
+    assert "MaxLength(5)" == repr(v)
+
+
+def test_pattern_string_and_compiled():
+    v = Pattern(r"\d{3}-\d{4}")
+    assert v("123-4567")
+    assert not v("1234567")
+    assert not v("123-456")  # partial match rejected (fullmatch)
+    assert v("")  # empty skipped
+
+    compiled = Pattern(re.compile(r"[a-z]+", re.IGNORECASE))
+    assert compiled("HELLO")
+    assert not compiled("HELLO123")
+
+    assert "Pattern" in repr(v)
+
+
+def test_email():
+    v = Email()
+    assert v("user@example.com")
+    assert v("a.b+c@sub.domain.co")
+    assert not v("not-an-email")
+    assert not v("missing@tld")
+    assert not v("@no-local.com")
+    assert v("")  # empty skipped
+    assert v(None)
+
+
+def test_range():
+    v = Range(min_value=1, max_value=10)
+    assert v(1)
+    assert v(10)
+    assert v(5.5)
+    assert v("7")  # string coerced
+    assert not v(0)
+    assert not v(11)
+    assert not v("abc")  # not a number
+    assert v("")  # empty skipped
+
+    only_min = Range(min_value=0)
+    assert only_min(1000)
+    assert not only_min(-1)
+
+    only_max = Range(max_value=100)
+    assert only_max(-50)
+    assert not only_max(101)
+
+
+def test_custom_validator_return_modes():
+    # None → ok
+    assert Custom(lambda v: None)("x")
+
+    # True → ok
+    assert Custom(lambda v: True)("x")
+
+    # False → uses fallback message
+    r = Custom(lambda v: False, message="bad")("x")
+    assert not r
+    assert r.first_error == "bad"
+
+    # str → that string becomes the error
+    r = Custom(lambda v: "dynamic error")("x")
+    assert not r
+    assert r.first_error == "dynamic error"
+
+    with pytest.raises(AssertionError):
+        Custom("not-callable")
+
+
+def test_validator_call_wraps_check():
+    v = MinLength(5)
+    result = v("ab")
+    assert isinstance(result, ValidationResult)
+    assert not result
+    assert result.value == "ab"
+
+
+# ---------------------------------------------------------------------------
+# Widget-level validation API
+# ---------------------------------------------------------------------------
+
+def test_widget_add_remove_validators():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("Name: ")
+
+    assert ti.get_validators() == ()
+
+    req = Required()
+    minlen = MinLength(3)
+    ti.add_validator(req).add_validator(minlen)
+    assert ti.get_validators() == (req, minlen)
+
+    ti.remove_validator(minlen)
+    assert ti.get_validators() == (req,)
+
+    with pytest.raises(ValueError):
+        ti.remove_validator(minlen)  # not there anymore
+
+    ti.clear_validators()
+    assert ti.get_validators() == ()
+
+
+def test_widget_add_validator_rejects_non_validator():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    with pytest.raises(AssertionError):
+        ti.add_validator(lambda x: None)
+
+
+def test_widget_set_validators_replaces_all():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(Required())
+
+    new_set = [MinLength(2), MaxLength(10)]
+    ti.set_validators(new_set)
+    assert len(ti.get_validators()) == 2
+    assert all(not isinstance(v, Required) for v in ti.get_validators())
+
+    ti.set_validators(None)
+    assert ti.get_validators() == ()
+
+
+def test_widget_set_required_idempotent():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+
+    ti.set_required(True)
+    ti.set_required(True)  # second call should not duplicate
+    required_count = sum(1 for v in ti.get_validators() if isinstance(v, Required))
+    assert required_count == 1
+
+    ti.set_required(False)
+    assert all(not isinstance(v, Required) for v in ti.get_validators())
+
+
+def test_widget_validate_fail_fast():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(Required())
+    ti.add_validator(MinLength(5))
+
+    ti.set_value("")
+    result = ti.validate()  # default = fail-fast
+    assert not result
+    assert len(result.errors) == 1  # stopped at Required
+    assert "required" in result.first_error.lower()
+
+
+def test_widget_validate_collect_all():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(MinLength(5))
+    ti.add_validator(MaxLength(3))  # contradictory on purpose
+
+    ti.set_value("abcd")  # fails both
+    result = ti.validate(mode=VALIDATE_MODE_COLLECT_ALL)
+    assert not result
+    assert len(result.errors) == 2
+
+
+def test_widget_validate_rejects_bad_mode():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    with pytest.raises(AssertionError):
+        ti.validate(mode="bogus")
+
+
+def test_widget_validate_success():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("Email: ")
+    ti.add_validator(Required())
+    ti.add_validator(Email())
+
+    ti.set_value("user@example.com")
+    result = ti.validate()
+    assert result
+    assert result.value == "user@example.com"
+    assert ti.get_validation_errors() == ()
+
+
+def test_widget_is_valid_and_errors():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(Required())
+
+    ti.set_value("")
+    assert not ti.is_valid()
+    assert len(ti.get_validation_errors()) == 1
+
+    ti.set_value("hello")
+    ti.validate()
+    assert ti.is_valid()
+    assert ti.get_validation_errors() == ()
+
+
+def test_widget_clear_validation():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(Required())
+
+    ti.set_value("")
+    ti.validate()
+    assert ti.get_validation_errors()
+
+    ti.clear_validation()
+    assert ti.get_validation_errors() == ()
+    # Validators are kept
+    assert len(ti.get_validators()) == 1
+
+
+def test_widget_without_value_always_valid():
+    """Widgets that raise ValueError from get_value() should be valid."""
+    menu = MenuUtils.generic_menu()
+    label = menu.add.label("No value here")
+    label.add_validator(Required())
+    result = label.validate()
+    assert result
+
+
+def test_widget_no_validators_is_valid():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.set_value("")
+    assert ti.validate()
+    assert ti.is_valid()
+
+
+# ---------------------------------------------------------------------------
+# Visual error feedback
+# ---------------------------------------------------------------------------
+
+def test_invalid_border_drawn():
+    """An invalid widget must draw its invalid border even if normal border=0."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    # Default invalid style: 2px width — border must render without crashing
+    assert ti._validation_invalid_border_width == 2
+    ti.draw(surface)
+    # The normal border is 0 (theme default) but invalid border still kicks in
+    assert ti.get_border()[1] == 0
+
+
+def test_set_invalid_style():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.set_invalid_style(border_color=(0, 255, 0), border_width=5)
+    assert ti._validation_invalid_border_color[:3] == (0, 255, 0)
+    assert ti._validation_invalid_border_width == 5
+
+    with pytest.raises(AssertionError):
+        ti.set_invalid_style(border_width=-1)
+
+
+def test_validation_state_flip_triggers_render():
+    """Flipping valid→invalid must call _force_render(); staying put must not."""
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ")
+    ti.add_validator(Required())
+
+    calls = []
+    original = ti._force_render
+    ti._force_render = lambda: calls.append(1) or original()
+
+    ti.set_value("")
+    ti.validate()  # None → invalid: flip
+    assert len(calls) == 1
+
+    ti.validate()  # invalid → invalid: no flip
+    assert len(calls) == 1
+
+    ti.set_value("hello")
+    ti.validate()  # invalid → valid: flip
+    assert len(calls) == 2
+
+
+def test_clear_validation_removes_visual_state():
+    menu = MenuUtils.generic_menu()
+    ti = menu.add.text_input("X: ", required=True)
+    ti.set_value("")
+    ti.validate()
+    ti.draw(surface)
+
+    ti.clear_validation()
+    assert ti._validation_errors == []
+    ti.draw(surface)  # should not crash and normal border path taken
+
