+    confirm = menu.add.text_input("Confirm: ")
+    confirm.set_value("different")
+
+    fm = FieldMatch(message="Passwords must match")
+    r = fm([pw, confirm])
+    assert not r
+    assert r.first_error == "Passwords must match"
