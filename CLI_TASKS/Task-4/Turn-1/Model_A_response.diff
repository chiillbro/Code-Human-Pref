+def test_add_cross_validator_type_checks():
+    menu = MenuUtils.generic_menu()
+    a = menu.add.text_input("A: ")
+    b = menu.add.text_input("B: ")
+
+    with pytest.raises(AssertionError):
+        menu.add_cross_validator(Required(), a, b)  # not a CrossWidgetValidator
+
+    with pytest.raises(AssertionError):
+        menu.add_cross_validator(FieldMatch(), a)  # only one widget
+
+    with pytest.raises(AssertionError):
+        menu.add_cross_validator(FieldMatch(), a, 123)  # bad type
