+def test_full_registration_flow():
+    """End-to-end: build a form, fill it wrong, validate, fix, re-validate."""
+    menu = MenuUtils.generic_menu()
+
+    name = menu.add.text_input(
+        "Name: ", textinput_id="name", required=True, validators=[MinLength(2)]
+    )
+    email = menu.add.text_input(
+        "Email: ", textinput_id="email", required=True, validators=[Email()]
+    )
+    pw = menu.add.text_input("Password: ", textinput_id="pw", required=True)
+    confirm = menu.add.text_input("Confirm: ", textinput_id="confirm", required=True)
+    menu.add_cross_validator(FieldMatch("Passwords must match"), pw, confirm)
+
+    # Round 1: everything wrong
+    name.set_value("")
+    email.set_value("bad")
+    pw.set_value("secret123")
+    confirm.set_value("secret124")
+
+    assert not menu.is_valid()
+    assert name.get_validation_errors()
+    assert email.get_validation_errors()
+    assert pw.get_validation_errors()  # flagged by cross-validator
+    assert confirm.get_validation_errors()
+
+    # Round 2: fix everything
+    name.set_value("Alice")
+    email.set_value("alice@example.com")
+    confirm.set_value("secret123")
+
+    menu.clear_validation()
+    assert menu.is_valid()
+    for w in (name, email, pw, confirm):
+        assert w.get_validation_errors() == ()
