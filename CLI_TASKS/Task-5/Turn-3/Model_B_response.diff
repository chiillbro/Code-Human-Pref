     assert score.offensive == 1.0
     assert score.defensive == 1.0
     assert score.total == 0.0
+
+
+@patch("tuxemon.ai.manager.AIConfigLoader.get_ai_difficulty")
+def test_ai_manager_caches_position_evaluator(mock_get_difficulty):
+    """
+    AIManager.get_position_evaluator() must return the same instance for
+    repeated calls with the same character, and clear_ai() must invalidate
+    the cache.
+    """
+    from tuxemon.ai.ai import AIDifficulty
+    from tuxemon.ai.manager import AIManager
+
+    mock_get_difficulty.return_value = AIDifficulty(
+        difficulties={"default": DifficultyEntry()}
+    )
+
+    manager = AIManager(session=MagicMock())
+    character = MagicMock()
+    character.combat.ai_difficulty = None
+
+    first = manager.get_position_evaluator(character)
+    second = manager.get_position_evaluator(character)
+    assert first is second
+    assert isinstance(first, PositionEvaluator)
+
+    other = MagicMock()
+    other.combat.ai_difficulty = None
+    assert manager.get_position_evaluator(other) is not first
+
+    manager.clear_ai()
+    third = manager.get_position_evaluator(character)
+    assert third is not first
