+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_should_switch_false_when_all_candidates_worse(mock_matchup, config):
+    """Bench is non-empty but every candidate has a worse matchup than
+    the active monster: stay in even though position is below threshold."""
+    evaluator = PositionEvaluator(config)
+    position = PositionScore(
+        total=-2.0, breakdown={"type_matchup": 0.5}, raw_type_matchup=0.5
+    )
+    # best bench candidate still worse than active (0.5)
+    mock_matchup.return_value = 0.0  # gain = -0.5 < min 1.0
+    assert not evaluator.should_switch(
+        position, make_monster("b"), [make_monster("fire")]
+    )
+
+
+@patch("tuxemon.ai.position_evaluator.simple_damage_multiplier")
+def test_same_type_matchup_is_neutral(mock_mult):
+    """Fire vs fire: offensive == defensive, so matchup total is 0."""
+    mock_mult.return_value = 1.0
+    fire_a = make_monster("fire")
+    fire_b = make_monster("fire")
+    score = evaluate_type_matchup(fire_a, fire_b)
+    assert score.offensive == score.defensive
+    assert score.total == 0.0
+
