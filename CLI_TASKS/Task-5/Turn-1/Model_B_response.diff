+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+from tuxemon.ai.ai import DifficultyEntry
+from tuxemon.ai.position_evaluator import (
+    MatchupScore,
+    PositionEvaluator,
+    PositionScore,
+    best_matchup_against,
+    evaluate_type_matchup,
+)
+
+
+def make_monster(slug: str, hp_ratio: float = 1.0, statuses=None):
+    mon = MagicMock(slug=slug, hp_ratio=hp_ratio)
+    mon.types.current = [slug]
+    mon.status.get_statuses.return_value = statuses or []
+    return mon
+
+
+@pytest.fixture
+def config():
+    return DifficultyEntry(
+        switch_threshold=-0.5,
+        min_switch_gain=1.0,
+        hp_weight=1.0,
+        type_matchup_weight=1.0,
+        bench_depth_weight=0.25,
+        status_penalty=0.5,
+    )
+
+
+def test_matchup_score_total():
+    score = MatchupScore(offensive=2.0, defensive=0.5)
+    assert score.total == 1.5
+
+
+@patch("tuxemon.ai.position_evaluator.simple_damage_multiplier")
+def test_evaluate_type_matchup(mock_mult):
+    mock_mult.side_effect = [2.0, 0.5]
+    water = make_monster("water")
+    fire = make_monster("fire")
+    score = evaluate_type_matchup(water, fire)
+    assert score.offensive == 2.0
+    assert score.defensive == 0.5
+    assert score.total == 1.5
+
+
+@patch("tuxemon.ai.position_evaluator.simple_damage_multiplier")
+def test_best_matchup_against_picks_highest(mock_mult):
+    # water vs fire: 2.0/0.5 -> 1.5 ; water vs earth: 0.5/2.0 -> -1.5
+    mock_mult.side_effect = [2.0, 0.5, 0.5, 2.0]
+    water = make_monster("water")
+    fire = make_monster("fire")
+    earth = make_monster("earth")
+    assert best_matchup_against(water, [fire, earth]) == 1.5
+
+
+def test_best_matchup_against_empty():
+    assert best_matchup_against(make_monster("water"), []) == 0.0
+
+
+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_evaluate_position_breakdown(mock_matchup, config):
+    mock_matchup.return_value = 1.5
+    evaluator = PositionEvaluator(config)
+    mon = make_monster(
+        "water", hp_ratio=0.4, statuses=[MagicMock(slug="poison")]
+    )
+    opp = make_monster("fire", hp_ratio=0.8)
+    own_bench = [make_monster("a"), make_monster("b")]
+    opp_bench = [make_monster("c")]
+
+    result = evaluator.evaluate(mon, [opp], own_bench, opp_bench)
+
+    assert result.breakdown["hp_ratio"] == pytest.approx(-0.4)
+    assert result.breakdown["type_matchup"] == pytest.approx(1.5)
+    assert result.breakdown["bench_depth"] == pytest.approx(0.25)
+    assert result.breakdown["status"] == pytest.approx(-0.5)
+    assert result.total == pytest.approx(0.85)
+
+
+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_select_best_replacement_prefers_type_then_hp(mock_matchup, config):
+    evaluator = PositionEvaluator(config)
+    a = make_monster("a", hp_ratio=0.9)
+    b = make_monster("b", hp_ratio=0.5)
+    c = make_monster("c", hp_ratio=0.3)
+    opp = make_monster("fire")
+
+    def scores(mon, _):
+        return {"a": 0.0, "b": 1.5, "c": 1.5}[mon.slug]
+
+    mock_matchup.side_effect = scores
+    chosen = evaluator.select_best_replacement([a, b, c], [opp])
+    assert chosen is b
+
+
+def test_select_best_replacement_empty(config):
+    evaluator = PositionEvaluator(config)
+    assert evaluator.select_best_replacement([], [make_monster("x")]) is None
+
+
+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_should_switch_respects_threshold(mock_matchup, config):
+    evaluator = PositionEvaluator(config)
+    position = PositionScore(total=0.0, breakdown={"type_matchup": 0.0})
+    mock_matchup.return_value = 2.0
+    # position.total >= threshold (-0.5) -> no switch
+    assert not evaluator.should_switch(
+        position, make_monster("b"), [make_monster("fire")]
+    )
+
+
+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_should_switch_requires_min_gain(mock_matchup, config):
+    evaluator = PositionEvaluator(config)
+    position = PositionScore(
+        total=-1.0, breakdown={"type_matchup": -1.0}
+    )
+    mock_matchup.return_value = -0.5  # gain = 0.5 < min 1.0
+    assert not evaluator.should_switch(
+        position, make_monster("b"), [make_monster("fire")]
+    )
+
+
+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_should_switch_triggers_when_bad_position_and_big_gain(
+    mock_matchup, config
+):
+    evaluator = PositionEvaluator(config)
+    position = PositionScore(
+        total=-1.5, breakdown={"type_matchup": -1.0}
+    )
+    mock_matchup.return_value = 1.5  # gain = 2.5 >= 1.0
+    assert evaluator.should_switch(
+        position, make_monster("b"), [make_monster("fire")]
+    )
+
+
+@patch("tuxemon.ai.position_evaluator.best_matchup_against")
+def test_difficulty_controls_aggressiveness(mock_matchup):
+    """Hard should switch where easy stays in, given identical state."""
+    easy = PositionEvaluator(
+        DifficultyEntry(
+            switch_threshold=-1.5,
+            min_switch_gain=1.5,
+            type_matchup_weight=1.0,
+        )
+    )
+    hard = PositionEvaluator(
+        DifficultyEntry(
+            switch_threshold=0.25,
+            min_switch_gain=0.5,
+            type_matchup_weight=1.0,
+        )
+    )
+    position = PositionScore(total=-0.6, breakdown={"type_matchup": -0.5})
+    mock_matchup.return_value = 0.5  # gain = 1.0
+    replacement = make_monster("b")
+    opponents = [make_monster("fire")]
+
+    assert not easy.should_switch(position, replacement, opponents)
+    assert hard.should_switch(position, replacement, opponents)
