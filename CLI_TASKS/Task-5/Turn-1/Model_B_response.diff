new file mode 100644
index 000000000..97ba3631d
--- /dev/null
+++ b/mods/ai_difficulty.yaml
@@ -0,0 +1,51 @@
+# AI difficulty profiles controlling proactive switching behaviour.
+#
+# switch_threshold: position score below which the AI considers switching.
+#   Higher values make the AI more eager to switch out (more aggressive).
+# min_switch_gain: minimum improvement in type-matchup score required before
+#   the AI commits to a switch. Lower values make switching more aggressive.
+# hp_weight: weight applied to the HP-ratio difference (own - opponent).
+# type_matchup_weight: weight applied to the net type advantage
+#   (offensive multiplier - defensive multiplier).
+# bench_depth_weight: weight applied to the bench-size difference
+#   (own bench - opponent bench).
+# status_penalty: flat penalty subtracted from the position score for each
+#   active status effect on the AI's monster.
+difficulties:
+  default:
+    switch_threshold: -0.5
+    min_switch_gain: 1.0
+    hp_weight: 1.0
+    type_matchup_weight: 1.0
+    bench_depth_weight: 0.25
+    status_penalty: 0.5
+
+  easy:
+    # Rarely switches; only bails out of truly terrible positions and
+    # demands a big type advantage before doing so.
+    switch_threshold: -1.5
+    min_switch_gain: 1.5
+    hp_weight: 1.0
+    type_matchup_weight: 0.5
+    bench_depth_weight: 0.1
+    status_penalty: 0.25
+
+  medium:
+    # Balanced: switches out of clearly unfavourable matchups when a
+    # meaningfully better option is on the bench.
+    switch_threshold: -0.5
+    min_switch_gain: 1.0
+    hp_weight: 1.0
+    type_matchup_weight: 1.0
+    bench_depth_weight: 0.25
+    status_penalty: 0.5
+
+  hard:
+    # Aggressive: proactively pivots to the best type matchup even from
+    # roughly neutral positions.
+    switch_threshold: 0.25
+    min_switch_gain: 0.5
+    hp_weight: 1.0
+    type_matchup_weight: 1.5
+    bench_depth_weight: 0.3
+    status_penalty: 0.75
