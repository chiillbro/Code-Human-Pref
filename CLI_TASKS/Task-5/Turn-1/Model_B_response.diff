diff --git a/tuxemon/ai/position_evaluator.py b/tuxemon/ai/position_evaluator.py
new file mode 100644
index 000000000..c5943386e
--- /dev/null
+++ b/tuxemon/ai/position_evaluator.py
@@ -0,0 +1,166 @@
+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import logging
+from collections.abc import Sequence
+from dataclasses import dataclass
+from typing import TYPE_CHECKING
+
+from tuxemon.formula import simple_damage_multiplier
+
+if TYPE_CHECKING:
+    from tuxemon.ai.ai import DifficultyEntry
+    from tuxemon.monster.monster import Monster
+
+logger = logging.getLogger(__name__)
+
+
+@dataclass
+class MatchupScore:
+    """Type-matchup score for a single monster against a single opponent."""
+
+    offensive: float
+    defensive: float
+
+    @property
+    def total(self) -> float:
+        return self.offensive - self.defensive
+
+
+@dataclass
+class PositionScore:
+    """Composite favorability score for the current battle position."""
+
+    total: float
+    breakdown: dict[str, float]
+
+
+def evaluate_type_matchup(monster: Monster, opponent: Monster) -> MatchupScore:
+    """
+    Compare the elemental affinity between a monster and an opponent.
+
+    The offensive component is how hard ``monster`` hits ``opponent`` with
+    its native types; the defensive component is the reverse. A positive
+    total means the matchup favours ``monster``.
+    """
+    offensive = simple_damage_multiplier(
+        monster.types.current, opponent.types.current
+    )
+    defensive = simple_damage_multiplier(
+        opponent.types.current, monster.types.current
+    )
+    return MatchupScore(offensive=offensive, defensive=defensive)
+
+
+def best_matchup_against(
+    monster: Monster, opponents: Sequence[Monster]
+) -> float:
+    """Return the best (highest) matchup total against any active opponent."""
+    if not opponents:
+        return 0.0
+    return max(
+        evaluate_type_matchup(monster, opp).total for opp in opponents
+    )
+
+
+class PositionEvaluator:
+    """
+    Scores how favourable the current battle position is for an AI monster.
+
+    The score combines relative HP, type matchup, bench depth and active
+    status effects using the weights defined in the selected difficulty
+    profile. Higher scores mean the AI is in a better spot and should stay
+    in; lower scores mean a switch is worth considering.
+    """
+
+    def __init__(self, config: DifficultyEntry) -> None:
+        self.config = config
+
+    def evaluate(
+        self,
+        monster: Monster,
+        opponents: Sequence[Monster],
+        own_bench: Sequence[Monster],
+        opponent_bench: Sequence[Monster],
+    ) -> PositionScore:
+        breakdown: dict[str, float] = {}
+
+        opponent_hp = (
+            sum(o.hp_ratio for o in opponents) / len(opponents)
+            if opponents
+            else 1.0
+        )
+        breakdown["hp_ratio"] = (
+            monster.hp_ratio - opponent_hp
+        ) * self.config.hp_weight
+
+        breakdown["type_matchup"] = (
+            best_matchup_against(monster, opponents)
+            * self.config.type_matchup_weight
+        )
+
+        breakdown["bench_depth"] = (
+            len(own_bench) - len(opponent_bench)
+        ) * self.config.bench_depth_weight
+
+        status_penalty = 0.0
+        for status in monster.status.get_statuses():
+            status_penalty -= self.config.status_penalty
+        breakdown["status"] = status_penalty
+
+        total = sum(breakdown.values())
+        logger.debug(
+            f"Position for {monster.slug}: {breakdown} -> {total:.2f}"
+        )
+        return PositionScore(total=total, breakdown=breakdown)
+
+    def select_best_replacement(
+        self,
+        candidates: Sequence[Monster],
+        opponents: Sequence[Monster],
+    ) -> Monster | None:
+        """
+        Pick the bench monster with the best type matchup against the
+        currently active opponents, breaking ties by remaining HP.
+        """
+        if not candidates:
+            return None
+        return max(
+            candidates,
+            key=lambda m: (
+                best_matchup_against(m, opponents),
+                m.hp_ratio,
+            ),
+        )
+
+    def should_switch(
+        self,
+        current: PositionScore,
+        replacement: Monster,
+        opponents: Sequence[Monster],
+    ) -> bool:
+        """
+        Decide whether switching to ``replacement`` is worthwhile.
+
+        A switch is triggered only when the current position is below the
+        configured ``switch_threshold`` and the replacement's type matchup
+        improves on the active monster's by at least ``min_switch_gain``.
+        """
+        if current.total >= self.config.switch_threshold:
+            return False
+
+        current_matchup = (
+            current.breakdown["type_matchup"] / self.config.type_matchup_weight
+            if self.config.type_matchup_weight
+            else 0.0
+        )
+        replacement_matchup = best_matchup_against(replacement, opponents)
+        gain = replacement_matchup - current_matchup
+
+        logger.debug(
+            f"Switch check: current={current.total:.2f} "
+            f"threshold={self.config.switch_threshold:.2f} "
+            f"gain={gain:.2f} min_gain={self.config.min_switch_gain:.2f}"
+        )
+        return gain >= self.config.min_switch_gain
