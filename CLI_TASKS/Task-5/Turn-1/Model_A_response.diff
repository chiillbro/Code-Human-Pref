diff --git a/tuxemon/ai/battle_analyzer.py b/tuxemon/ai/battle_analyzer.py
new file mode 100644
index 000000000..c1f266ee3
--- /dev/null
+++ b/tuxemon/ai/battle_analyzer.py
@@ -0,0 +1,109 @@
+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import logging
+from collections.abc import Sequence
+from dataclasses import dataclass
+from typing import TYPE_CHECKING
+
+from tuxemon.element import ElementTypesHandler
+
+if TYPE_CHECKING:
+    from tuxemon.ai.ai import DifficultyEntry
+    from tuxemon.monster.monster import Monster
+
+logger = logging.getLogger(__name__)
+
+
+@dataclass
+class PositionScore:
+    total: float
+    breakdown: dict[str, float]
+
+
+def type_matchup_score(
+    candidate: Monster, opponents: Sequence[Monster]
+) -> float:
+    """
+    Returns a score describing how favorable the type matchup is for
+    ``candidate`` against the given opponents.
+
+    The score is the average of (offensive multiplier / defensive multiplier)
+    across all opponents. A value > 1.0 means the candidate has a net type
+    advantage (e.g. water vs fire), < 1.0 means a net disadvantage.
+    """
+    if not opponents:
+        return 1.0
+
+    total = 0.0
+    for opponent in opponents:
+        offense = ElementTypesHandler.calculate_affinity_score(
+            candidate.types.current, opponent.types.current
+        )
+        defense = ElementTypesHandler.calculate_affinity_score(
+            opponent.types.current, candidate.types.current
+        )
+        defense = defense or 1.0
+        total += offense / defense
+
+    return total / len(opponents)
+
+
+def select_best_type_matchup(
+    candidates: Sequence[Monster], opponents: Sequence[Monster]
+) -> Monster:
+    """
+    From a list of candidate monsters, return the one with the most
+    favorable type matchup against the active opponents. Ties are broken
+    by remaining HP ratio.
+    """
+    return max(
+        candidates,
+        key=lambda m: (type_matchup_score(m, opponents), m.hp_ratio),
+    )
+
+
+def evaluate_battle_position(
+    user: Monster,
+    opponents: Sequence[Monster],
+    own_bench: Sequence[Monster],
+    opponent_bench: Sequence[Monster],
+    config: DifficultyEntry,
+) -> PositionScore:
+    """
+    Produces a signed score describing how favorable the current battle
+    position is for ``user``. Positive values are favorable, negative
+    values are unfavorable. The magnitude is roughly normalised so that
+    the ``switch_threshold`` values in the difficulty config are sensible
+    in the [-2.0, 2.0] range.
+
+    Factors considered:
+      * HP ratio difference between the user and the average opponent.
+      * Type matchup (offense vs defense multipliers).
+      * Bench depth difference (remaining healthy reserves on each side).
+      * Negative status effects currently afflicting the user.
+    """
+    breakdown: dict[str, float] = {}
+
+    avg_opp_hp = (
+        sum(o.hp_ratio for o in opponents) / len(opponents)
+        if opponents
+        else 1.0
+    )
+    breakdown["hp"] = (user.hp_ratio - avg_opp_hp) * config.hp_weight
+
+    matchup = type_matchup_score(user, opponents)
+    breakdown["type"] = (matchup - 1.0) * config.type_weight
+
+    bench_diff = len(own_bench) - len(opponent_bench)
+    breakdown["bench"] = bench_diff * config.bench_weight
+
+    status_penalty = sum(1 for _ in user.status.get_statuses())
+    breakdown["status"] = -status_penalty * config.status_weight
+
+    total = sum(breakdown.values())
+    logger.debug(
+        f"Battle position for {user.slug}: {total:.2f} {breakdown}"
+    )
+    return PositionScore(total=total, breakdown=breakdown)
