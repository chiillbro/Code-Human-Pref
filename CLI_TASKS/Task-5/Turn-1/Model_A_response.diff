@@ -185,6 +195,59 @@ class TrainerAIDecisionStrategy(AIDecisionStrategy):
 
         return self.choose_action(ai, valid_actions)
 
+    def evaluate_switch(self, ai: AI) -> Monster | None:
+        """
+        Decide whether the AI should voluntarily switch its active monster
+        out this turn. Returns the replacement monster if switching is
+        advisable, otherwise ``None``.
+
+        The decision is based on the current battle-position score
+        (HP ratios, type matchup, bench depth, status effects) compared
+        against the trainer's difficulty ``switch_threshold``. A switch is
+        only performed when a bench monster offers at least
+        ``min_switch_advantage`` more type-matchup score than the current
+        monster.
+        """
+        combat = ai.combat_session
+        difficulty = ai.difficulty
+
+        own_bench = list(combat.get_bench(ai.character))
+        if not own_bench:
+            return None
+        if not combat.swap_tracker.can_swap(ai.monster):
+            return None
+
+        opponent = (
+            combat.right_player
+            if ai.character == combat.left_player
+            else combat.left_player
+        )
+        opponent_bench = list(combat.get_bench(opponent))
+
+        position = evaluate_battle_position(
+            ai.monster,
+            ai.opponents,
+            own_bench,
+            opponent_bench,
+            difficulty,
+        )
+        if position.total >= difficulty.switch_threshold:
+            return None
+
+        current_matchup = type_matchup_score(ai.monster, ai.opponents)
+        candidate = select_best_type_matchup(own_bench, ai.opponents)
+        candidate_matchup = type_matchup_score(candidate, ai.opponents)
+
+        if candidate_matchup - current_matchup < difficulty.min_switch_advantage:
+            return None
+
+        logger.debug(
+            f"AI switching {ai.monster.slug} -> {candidate.slug} "
+            f"(position={position.total:.2f}, "
+            f"matchup {current_matchup:.2f} -> {candidate_matchup:.2f})"
+        )
+        return candidate
+
     def default_decision(
         self, ai: AI, valid_actions: list[tuple[Technique, Monster]]
     ) -> None:
