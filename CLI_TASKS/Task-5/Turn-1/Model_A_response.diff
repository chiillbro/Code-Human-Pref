index 000000000..fe4e732c8
--- /dev/null
+++ b/mods/ai_difficulty.yaml
@@ -0,0 +1,39 @@
+# AI difficulty profiles controlling strategic switching behaviour.
+#
+# switch_threshold:
+#   Battle-position score below which the AI considers the current
+#   matchup unfavorable enough to voluntarily switch out. Lower values
+#   mean the AI tolerates worse positions before switching (less
+#   aggressive switching).
+#
+# min_switch_advantage:
+#   Minimum improvement in type-matchup score that a bench monster must
+#   offer over the active monster before the AI will swap to it. Higher
+#   values mean the AI only switches when the replacement is clearly
+#   better.
+#
+# type_weight / hp_weight / bench_weight / status_weight:
+#   Weights applied when computing the battle-position score. See
+#   tuxemon/ai/battle_analyzer.py:evaluate_battle_position.
+difficulties:
+  easy:
+    switch_threshold: -1.5
+    min_switch_advantage: 1.5
+    type_weight: 0.5
+    hp_weight: 1.0
+    bench_weight: 0.1
+    status_weight: 0.3
+  medium:
+    switch_threshold: -0.6
+    min_switch_advantage: 0.8
+    type_weight: 1.0
+    hp_weight: 1.0
+    bench_weight: 0.2
+    status_weight: 0.5
+  hard:
+    switch_threshold: -0.2
+    min_switch_advantage: 0.4
+    type_weight: 1.5
+    hp_weight: 1.0
+    bench_weight: 0.3
+    status_weight: 0.7
