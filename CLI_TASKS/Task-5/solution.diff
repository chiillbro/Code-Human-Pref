@@ -0,0 +1,512 @@
+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import logging
+import math
+import random
+from dataclasses import dataclass
+from enum import Enum
+
+from tuxemon.ai.battle_evaluator import (
+    BattleSnapshot,
+    BattleStateEvaluator,
+    MonsterSnapshot,
+)
+
+logger = logging.getLogger(__name__)
+
+# Sentinel scores for terminal states
+WIN_SCORE = 1_000_000.0
+LOSS_SCORE = -1_000_000.0
+
+# Maximum turn horizon to prevent infinite loops
+MAX_TURN_HORIZON = 20
+
+
+class ActionType(Enum):
+    TECHNIQUE = "technique"
+    SWITCH = "switch"
+
+
+@dataclass
+class AIAction:
+    """
+    Represents an action the AI or opponent can take.
+    Either using a technique on a target, or switching to a bench monster.
+    """
+
+    action_type: ActionType
+    technique_slug: str | None = None
+    target_slug: str | None = None
+    switch_to_slug: str | None = None
+
+    @property
+    def is_switch(self) -> bool:
+        return self.action_type is ActionType.SWITCH
+
+    @property
+    def is_technique(self) -> bool:
+        return self.action_type is ActionType.TECHNIQUE
+
+
+@dataclass
+class MinimaxResult:
+    """Result of a minimax search."""
+
+    best_action: AIAction | None
+    score: float
+    nodes_evaluated: int
+
+
+def _simulate_technique_damage(
+    attacker: MonsterSnapshot,
+    defender: MonsterSnapshot,
+    tech_slug: str,
+) -> int:
+    """
+    Estimate damage for minimax simulation. This is a lightweight heuristic
+    based on stat differentials and type advantage, not the full formula.py
+    pipeline (which requires live objects). Provides a reasonable approximation
+    for tree search.
+    """
+    from tuxemon.element import Element, ElementTypesHandler
+
+    # Estimate base damage from attacker stats
+    attack_power = max(attacker.melee, attacker.ranged)
+    defense = max(defender.armour, 1)
+
+    # Type multiplier
+    attack_types = [Element.get(s) for s in attacker.type_slugs if s]
+    defend_types = [Element.get(s) for s in defender.type_slugs if s]
+
+    type_mult = 1.0
+    if attack_types and defend_types:
+        type_mult = ElementTypesHandler.calculate_affinity_score(
+            attack_types, defend_types
+        )
+
+    # Heuristic: approximate damage = (attack * level_factor * type_mult) / defense
+    level_factor = 5 + attacker.level
+    raw_damage = int(
+        (attack_power * level_factor * type_mult) / (defense * 2)
+    )
+    return max(raw_damage, 1)
+
+
+def _simulate_switch(
+    snapshot: BattleSnapshot,
+    side: str,
+    switch_to_slug: str,
+) -> BattleSnapshot:
+    """
+    Create a new BattleSnapshot with a switch applied.
+    The switched-in monster becomes active; the old active goes to bench.
+    The opponent gets a free attack (estimated damage applied).
+    """
+    if side == "ai":
+        new_bench = []
+        switched_in = None
+        for m in snapshot.ai_bench:
+            if m.slug == switch_to_slug and switched_in is None:
+                switched_in = m
+            else:
+                new_bench.append(m)
+
+        if switched_in is None:
+            return snapshot
+
+        # Old active goes to bench (if not fainted)
+        old_active = snapshot.ai_active
+        if not old_active.is_fainted:
+            new_bench.append(old_active)
+
+        # Opponent gets a free attack on the switching monster
+        free_attack_dmg = _simulate_technique_damage(
+            snapshot.opponent_active, switched_in, ""
+        )
+        new_hp = max(switched_in.current_hp - free_attack_dmg, 0)
+        switched_in = MonsterSnapshot(
+            slug=switched_in.slug,
+            current_hp=new_hp,
+            max_hp=switched_in.max_hp,
+            level=switched_in.level,
+            speed=switched_in.speed,
+            melee=switched_in.melee,
+            ranged=switched_in.ranged,
+            armour=switched_in.armour,
+            dodge=switched_in.dodge,
+            type_slugs=switched_in.type_slugs,
+            status_slugs=switched_in.status_slugs,
+            is_fainted=new_hp <= 0,
+            move_slugs=switched_in.move_slugs,
+            has_healing_moves=switched_in.has_healing_moves,
+            has_status_moves=switched_in.has_status_moves,
+            has_stat_boost_moves=switched_in.has_stat_boost_moves,
+        )
+
+        return BattleSnapshot(
+            ai_active=switched_in,
+            opponent_active=snapshot.opponent_active,
+            ai_bench=tuple(new_bench),
+            opponent_bench=snapshot.opponent_bench,
+            turn=snapshot.turn,
+        )
+    else:
+        new_bench = []
+        switched_in = None
+        for m in snapshot.opponent_bench:
+            if m.slug == switch_to_slug and switched_in is None:
+                switched_in = m
+            else:
+                new_bench.append(m)
+
+        if switched_in is None:
+            return snapshot
+
+        old_active = snapshot.opponent_active
+        if not old_active.is_fainted:
+            new_bench.append(old_active)
+
+        return BattleSnapshot(
+            ai_active=snapshot.ai_active,
+            opponent_active=switched_in,
+            ai_bench=snapshot.ai_bench,
+            opponent_bench=tuple(new_bench),
+            turn=snapshot.turn,
+        )
+
+
+def _simulate_attack(
+    snapshot: BattleSnapshot,
+    attacker_side: str,
+    tech_slug: str,
+) -> BattleSnapshot:
+    """
+    Simulate an attack and return a new BattleSnapshot with updated HP.
+    """
+    if attacker_side == "ai":
+        attacker = snapshot.ai_active
+        defender = snapshot.opponent_active
+    else:
+        attacker = snapshot.opponent_active
+        defender = snapshot.ai_active
+
+    damage = _simulate_technique_damage(attacker, defender, tech_slug)
+    new_hp = max(defender.current_hp - damage, 0)
+    new_defender = MonsterSnapshot(
+        slug=defender.slug,
+        current_hp=new_hp,
+        max_hp=defender.max_hp,
+        level=defender.level,
+        speed=defender.speed,
+        melee=defender.melee,
+        ranged=defender.ranged,
+        armour=defender.armour,
+        dodge=defender.dodge,
+        type_slugs=defender.type_slugs,
+        status_slugs=defender.status_slugs,
+        is_fainted=new_hp <= 0,
+        move_slugs=defender.move_slugs,
+        has_healing_moves=defender.has_healing_moves,
+        has_status_moves=defender.has_status_moves,
+        has_stat_boost_moves=defender.has_stat_boost_moves,
+    )
+
+    if attacker_side == "ai":
+        return BattleSnapshot(
+            ai_active=snapshot.ai_active,
+            opponent_active=new_defender,
+            ai_bench=snapshot.ai_bench,
+            opponent_bench=snapshot.opponent_bench,
+            turn=snapshot.turn + 1,
+        )
+    else:
+        return BattleSnapshot(
+            ai_active=new_defender,
+            opponent_active=snapshot.opponent_active,
+            ai_bench=snapshot.ai_bench,
+            opponent_bench=snapshot.opponent_bench,
+            turn=snapshot.turn + 1,
+        )
+
+
+def _generate_actions(
+    snapshot: BattleSnapshot,
+    side: str,
+) -> list[AIAction]:
+    """
+    Generate all legal actions for the given side.
+    """
+    actions: list[AIAction] = []
+
+    if side == "ai":
+        active = snapshot.ai_active
+        bench = snapshot.ai_bench
+    else:
+        active = snapshot.opponent_active
+        bench = snapshot.opponent_bench
+
+    if active.is_fainted:
+        # Must switch if active is fainted
+        for m in bench:
+            if not m.is_fainted:
+                actions.append(
+                    AIAction(
+                        action_type=ActionType.SWITCH,
+                        switch_to_slug=m.slug,
+                    )
+                )
+        return actions
+
+    # Technique actions
+    for move_slug in active.move_slugs:
+        target_slug = (
+            snapshot.opponent_active.slug
+            if side == "ai"
+            else snapshot.ai_active.slug
+        )
+        actions.append(
+            AIAction(
+                action_type=ActionType.TECHNIQUE,
+                technique_slug=move_slug,
+                target_slug=target_slug,
+            )
+        )
+
+    # Switch actions
+    for m in bench:
+        if not m.is_fainted:
+            actions.append(
+                AIAction(
+                    action_type=ActionType.SWITCH,
+                    switch_to_slug=m.slug,
+                )
+            )
+
+    return actions
+
+
+def _apply_action(
+    snapshot: BattleSnapshot,
+    action: AIAction,
+    side: str,
+) -> BattleSnapshot:
+    """Apply an action to the snapshot, returning a new snapshot."""
+    if action.is_switch:
+        return _simulate_switch(snapshot, side, action.switch_to_slug or "")
+    else:
+        return _simulate_attack(
+            snapshot, side, action.technique_slug or ""
+        )
+
+
+class MinimaxEngine:
+    """
+    Minimax decision engine with alpha-beta pruning for AI combat
+    decisions. Operates on lightweight BattleSnapshot instances
+    to avoid coupling to live game objects.
+    """
+
+    def __init__(
+        self,
+        evaluator: BattleStateEvaluator,
+        search_depth: int = 2,
+        is_wild_battle: bool = False,
+    ) -> None:
+        self.evaluator = evaluator
+        self.search_depth = search_depth
+        self.is_wild_battle = is_wild_battle
+        self._nodes_evaluated = 0
+
+    def find_best_action(
+        self,
+        snapshot: BattleSnapshot,
+    ) -> MinimaxResult:
+        """
+        Run minimax search and return the best action for the AI.
+        """
+        self._nodes_evaluated = 0
+
+        actions = _generate_actions(snapshot, "ai")
+        if not actions:
+            return MinimaxResult(
+                best_action=None, score=0.0, nodes_evaluated=0
+            )
+
+        if len(actions) == 1:
+            self._nodes_evaluated = 1
+            result_snapshot = _apply_action(snapshot, actions[0], "ai")
+            score = self.evaluator.evaluate(result_snapshot).total
+            return MinimaxResult(
+                best_action=actions[0],
+                score=score,
+                nodes_evaluated=1,
+            )
+
+        best_score = -math.inf
+        best_action = actions[0]
+        alpha = -math.inf
+        beta = math.inf
+
+        for action in actions:
+            new_snapshot = _apply_action(snapshot, action, "ai")
+            score = self._minimax(
+                new_snapshot,
+                depth=self.search_depth - 1,
+                is_maximizing=False,
+                alpha=alpha,
+                beta=beta,
+            )
+
+            if score > best_score:
+                best_score = score
+                best_action = action
+
+            alpha = max(alpha, best_score)
+
+        logger.debug(
+            f"Minimax result: action={best_action}, "
+            f"score={best_score:.2f}, "
+            f"nodes={self._nodes_evaluated}"
+        )
+
+        return MinimaxResult(
+            best_action=best_action,
+            score=best_score,
+            nodes_evaluated=self._nodes_evaluated,
+        )
+
+    def _minimax(
+        self,
+        snapshot: BattleSnapshot,
+        depth: int,
+        is_maximizing: bool,
+        alpha: float,
+        beta: float,
+    ) -> float:
+        self._nodes_evaluated += 1
+
+        # Terminal state checks
+        if snapshot.is_terminal:
+            if snapshot.is_opponent_defeated:
+                return WIN_SCORE
+            return LOSS_SCORE
+
+        # Depth limit or turn horizon
+        if depth <= 0 or snapshot.turn >= MAX_TURN_HORIZON:
+            return self.evaluator.evaluate(snapshot).total
+
+        side = "ai" if is_maximizing else "opponent"
+        actions = _generate_actions(snapshot, side)
+
+        if not actions:
+            return self.evaluator.evaluate(snapshot).total
+
+        # For wild battles, opponent picks randomly instead of optimally
+        if not is_maximizing and self.is_wild_battle:
+            return self._simulate_random_opponent(
+                snapshot, actions, depth, alpha, beta
+            )
+
+        if is_maximizing:
+            max_eval = -math.inf
+            for action in actions:
+                new_snapshot = _apply_action(snapshot, action, side)
+                eval_score = self._minimax(
+                    new_snapshot, depth - 1, False, alpha, beta
+                )
+                max_eval = max(max_eval, eval_score)
+                alpha = max(alpha, eval_score)
+                if beta <= alpha:
+                    break  # Beta cutoff
+            return max_eval
+        else:
+            min_eval = math.inf
+            for action in actions:
+                new_snapshot = _apply_action(snapshot, action, side)
+                eval_score = self._minimax(
+                    new_snapshot, depth - 1, True, alpha, beta
+                )
+                min_eval = min(min_eval, eval_score)
+                beta = min(beta, eval_score)
+                if beta <= alpha:
+                    break  # Alpha cutoff
+            return min_eval
+
+    def _simulate_random_opponent(
+        self,
+        snapshot: BattleSnapshot,
+        actions: list[AIAction],
+        depth: int,
+        alpha: float,
+        beta: float,
+    ) -> float:
+        """
+        For wild battles: average over all opponent actions (random play).
+        """
+        total_score = 0.0
+        for action in actions:
+            new_snapshot = _apply_action(snapshot, action, "opponent")
+            score = self._minimax(
+                new_snapshot, depth - 1, True, alpha, beta
+            )
+            total_score += score
+        return total_score / len(actions)
+
+
+def apply_mistake_rate(
+    actions: list[AIAction],
+    scores: list[float],
+    mistake_rate: float,
+) -> AIAction:
+    """
+    Select an action with a softmax-over-top-K approach for mistakes.
+    With probability (1 - mistake_rate), pick the best action.
+    With probability mistake_rate, sample from the top actions
+    weighted by their relative scores (softmax).
+
+    This produces more realistic "mistakes" than uniform random: the AI
+    tends to pick the 2nd or 3rd best move rather than a completely
+    terrible one.
+    """
+    if not actions:
+        raise ValueError("No actions to select from.")
+
+    if len(actions) == 1:
+        return actions[0]
+
+    # Sort by score descending
+    paired = sorted(zip(scores, actions), key=lambda x: x[0], reverse=True)
+    sorted_scores = [s for s, _ in paired]
+    sorted_actions = [a for _, a in paired]
+
+    # With probability (1 - mistake_rate), play optimally
+    if random.random() >= mistake_rate:
+        return sorted_actions[0]
+
+    # Softmax over all actions for mistake selection
+    # Shift scores for numerical stability
+    max_score = sorted_scores[0]
+    shifted = [s - max_score for s in sorted_scores]
+
+    # Temperature scales how "random" mistakes are
+    # Lower temperature = mistakes are closer to optimal
+    temperature = 2.0
+    exp_scores = [math.exp(s / temperature) for s in shifted]
+    total = sum(exp_scores)
+
+    if total <= 0:
+        return random.choice(sorted_actions)
+
+    probabilities = [e / total for e in exp_scores]
+
+    # Weighted random selection
+    r = random.random()
+    cumulative = 0.0
+    for i, prob in enumerate(probabilities):
+        cumulative += prob
+        if r <= cumulative:
+            return sorted_actions[i]
+
+    return sorted_actions[-1]
