+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+from tuxemon.ai.battle_evaluator import (
+    BattleSnapshot,
+    BattleStateEvaluator,
+    EvalResult,
+    EvalWeights,
+    MonsterSnapshot,
+)
+
+
+def _make_snapshot(
+    slug: str = "rockitten",
+    current_hp: int = 50,
+    max_hp: int = 100,
+    level: int = 10,
+    speed: int = 20,
+    melee: int = 30,
+    ranged: int = 25,
+    armour: int = 20,
+    dodge: int = 15,
+    type_slugs: tuple[str, ...] = ("fire",),
+    status_slugs: tuple[str, ...] = (),
+    is_fainted: bool = False,
+    move_slugs: tuple[str, ...] = ("tackle",),
+    has_healing_moves: bool = False,
+    has_status_moves: bool = False,
+    has_stat_boost_moves: bool = False,
+) -> MonsterSnapshot:
+    return MonsterSnapshot(
+        slug=slug,
+        current_hp=current_hp,
+        max_hp=max_hp,
+        level=level,
+        speed=speed,
+        melee=melee,
+        ranged=ranged,
+        armour=armour,
+        dodge=dodge,
+        type_slugs=type_slugs,
+        status_slugs=status_slugs,
+        is_fainted=is_fainted,
+        move_slugs=move_slugs,
+        has_healing_moves=has_healing_moves,
+        has_status_moves=has_status_moves,
+        has_stat_boost_moves=has_stat_boost_moves,
+    )
+
+
+def _make_battle_snapshot(
+    ai_hp: int = 80,
+    opp_hp: int = 60,
+    ai_bench_count: int = 1,
+    opp_bench_count: int = 1,
+    turn: int = 1,
+) -> BattleSnapshot:
+    ai_active = _make_snapshot(slug="ai_mon", current_hp=ai_hp)
+    opp_active = _make_snapshot(slug="opp_mon", current_hp=opp_hp)
+    ai_bench = tuple(
+        _make_snapshot(slug=f"ai_bench_{i}")
+        for i in range(ai_bench_count)
+    )
+    opp_bench = tuple(
+        _make_snapshot(slug=f"opp_bench_{i}")
+        for i in range(opp_bench_count)
+    )
+    return BattleSnapshot(
+        ai_active=ai_active,
+        opponent_active=opp_active,
+        ai_bench=ai_bench,
+        opponent_bench=opp_bench,
+        turn=turn,
+    )
+
+
+class TestMonsterSnapshot:
+    def test_hp_ratio_normal(self):
+        snap = _make_snapshot(current_hp=50, max_hp=100)
+        assert snap.hp_ratio == pytest.approx(0.5)
+
+    def test_hp_ratio_full(self):
+        snap = _make_snapshot(current_hp=100, max_hp=100)
+        assert snap.hp_ratio == pytest.approx(1.0)
+
+    def test_hp_ratio_zero_max_hp(self):
+        snap = _make_snapshot(current_hp=0, max_hp=0)
+        assert snap.hp_ratio == pytest.approx(0.0)
+
+    def test_hp_ratio_clamped_above_one(self):
+        snap = _make_snapshot(current_hp=120, max_hp=100)
+        assert snap.hp_ratio == pytest.approx(1.0)
+
+    def test_fainted_state(self):
+        snap = _make_snapshot(is_fainted=True, current_hp=0)
+        assert snap.is_fainted is True
+
+    def test_frozen_nature(self):
+        snap = _make_snapshot()
+        with pytest.raises(AttributeError):
+            snap.slug = "modified"  # type: ignore[misc]
+
+
+class TestBattleSnapshot:
+    def test_ai_healthy_bench_count(self):
+        snap = _make_battle_snapshot(ai_bench_count=3)
+        assert snap.ai_healthy_bench_count == 3
+
+    def test_ai_healthy_bench_count_with_fainted(self):
+        ai_active = _make_snapshot(slug="ai_mon")
+        opp_active = _make_snapshot(slug="opp_mon")
+        fainted = _make_snapshot(slug="fainted", is_fainted=True, current_hp=0)
+        healthy = _make_snapshot(slug="healthy")
+        snap = BattleSnapshot(
+            ai_active=ai_active,
+            opponent_active=opp_active,
+            ai_bench=(fainted, healthy),
+            opponent_bench=(),
+            turn=1,
+        )
+        assert snap.ai_healthy_bench_count == 1
+
+    def test_is_ai_defeated(self):
+        snap = BattleSnapshot(
+            ai_active=_make_snapshot(is_fainted=True, current_hp=0),
+            opponent_active=_make_snapshot(),
+            ai_bench=(),
+            opponent_bench=(),
+            turn=1,
+        )
+        assert snap.is_ai_defeated is True
+        assert snap.is_terminal is True
+
+    def test_is_opponent_defeated(self):
+        snap = BattleSnapshot(
+            ai_active=_make_snapshot(),
+            opponent_active=_make_snapshot(is_fainted=True, current_hp=0),
+            ai_bench=(),
+            opponent_bench=(),
+            turn=1,
+        )
+        assert snap.is_opponent_defeated is True
+        assert snap.is_terminal is True
+
+    def test_not_terminal(self):
+        snap = _make_battle_snapshot()
+        assert snap.is_terminal is False
+
+    def test_frozen_nature(self):
+        snap = _make_battle_snapshot()
+        with pytest.raises(AttributeError):
+            snap.turn = 99  # type: ignore[misc]
+
+
+class TestEvalWeights:
+    def test_default_weights(self):
+        w = EvalWeights()
+        assert w.hp_ratio == 30.0
+        assert w.type_advantage == 20.0
+
+    def test_copy_produces_independent_instance(self):
+        w = EvalWeights(hp_ratio=50.0)
+        w2 = w.copy()
+        w2.hp_ratio = 10.0
+        assert w.hp_ratio == 50.0
+        assert w2.hp_ratio == 10.0
+
+
+class TestBattleStateEvaluator:
+    def test_evaluate_symmetric_state_is_near_zero(self):
+        snap = BattleSnapshot(
+            ai_active=_make_snapshot(slug="a", current_hp=50, max_hp=100),
+            opponent_active=_make_snapshot(slug="b", current_hp=50, max_hp=100),
+            ai_bench=(),
+            opponent_bench=(),
+            turn=1,
+        )
+        evaluator = BattleStateEvaluator()
+        result = evaluator.evaluate(snap)
+        # Same HP, same types, same everything -> hp/bench/fainted near 0
+        # Type advantage with same types may not be exactly 0
+        assert isinstance(result, EvalResult)
+        assert isinstance(result.total, float)
+
+    def test_ai_advantage_is_positive(self):
+        snap = BattleSnapshot(
+            ai_active=_make_snapshot(slug="a", current_hp=100, max_hp=100, level=20),
+            opponent_active=_make_snapshot(slug="b", current_hp=20, max_hp=100, level=5),
+            ai_bench=(_make_snapshot(slug="bench"),),
+            opponent_bench=(),
+            turn=1,
+        )
+        evaluator = BattleStateEvaluator()
+        result = evaluator.evaluate(snap)
+        assert result.total > 0
+
+    def test_ai_disadvantage_is_negative(self):
+        snap = BattleSnapshot(
+            ai_active=_make_snapshot(slug="a", current_hp=10, max_hp=100, level=5),
+            opponent_active=_make_snapshot(slug="b", current_hp=100, max_hp=100, level=20),
+            ai_bench=(),
+            opponent_bench=(_make_snapshot(slug="bench"),),
+            turn=1,
+        )
+        evaluator = BattleStateEvaluator()
+        result = evaluator.evaluate(snap)
+        assert result.total < 0
+
+    def test_custom_weights_applied(self):
+        weights = EvalWeights(
+            hp_ratio=100.0,
+            type_advantage=0.0,
+            status_effects=0.0,
+            bench_depth=0.0,
+            level_diff=0.0,
+            fainted_penalty=0.0,
+        )
+        snap = BattleSnapshot(
+            ai_active=_make_snapshot(slug="a", current_hp=100, max_hp=100),
+            opponent_active=_make_snapshot(slug="b", current_hp=50, max_hp=100),
+            ai_bench=(),
+            opponent_bench=(),
+            turn=1,
+        )
+        evaluator = BattleStateEvaluator(weights)
+        result = evaluator.evaluate(snap)
+        # (1.0 - 0.5) * 100 = 50
+        assert result.breakdown["hp_ratio"] == pytest.approx(50.0)
+
+    def test_breakdown_keys(self):
+        snap = _make_battle_snapshot()
+        evaluator = BattleStateEvaluator()
+        result = evaluator.evaluate(snap)
+        expected_keys = {
+            "hp_ratio",
+            "type_advantage",
+            "status_effects",
+            "bench_depth",
+            "level_diff",
+            "fainted_penalty",
+        }
+        assert set(result.breakdown.keys()) == expected_keys
