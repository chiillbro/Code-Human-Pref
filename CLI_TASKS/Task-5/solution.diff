+class AdvancedTrainerAIDecisionStrategy(AIDecisionStrategy):
+    """
+    Minimax-powered trainer AI that uses a strategy controller to
+    detect battle phases and adjusts its evaluation weights accordingly.
+    Falls back to the legacy TrainerAIDecisionStrategy behavior when
+    search_depth is 0, preserving backward compatibility.
+    """
+
+    def __init__(
+        self,
+        evaluator: OpponentEvaluator,
+        tracker: TechniqueTracker,
+        ai_trainers: AITrainers,
+        ai_items: AIItems,
+        ai_techs: AITechniques,
+        minimax_engine: MinimaxEngine,
+        strategy_controller: StrategyController,
+        switch_evaluator: SwitchEvaluator,
+        mistake_rate: float = 0.0,
+    ):
+        super().__init__(
+            evaluator, tracker, ai_trainers, ai_items, ai_techs
+        )
+        self.minimax_engine = minimax_engine
+        self.strategy_controller = strategy_controller
+        self.switch_evaluator = switch_evaluator
+        self.mistake_rate = mistake_rate
+        self._legacy_fallback = TrainerAIDecisionStrategy(
+            evaluator, tracker, ai_trainers, ai_items, ai_techs
+        )
+
+    def make_decision(self, ai: AI) -> None:
+        """
+        Advanced trainer battle decision-making using Minimax.
+        Falls back to legacy logic when search_depth is 0.
+        """
+        # Depth 0 = use legacy logic for backward compatibility
+        if self.minimax_engine.search_depth <= 0:
+            self._legacy_fallback.make_decision(ai)
+            return
+
+        # Healing item check (same as legacy)
+        items = ai.character.items
+        if items:
+            for item in items:
+                if self._legacy_fallback.need_healing(ai, item):
+                    ai.action_item(item)
+                    return
+
+        snapshot = self._build_snapshot(ai)
+
+        # Update evaluator weights based on detected battle phase
+        weights = self.strategy_controller.get_weights_for_snapshot(
+            snapshot
+        )
+        self.minimax_engine.evaluator.weights = weights
+
+        result = self.minimax_engine.find_best_action(snapshot)
+
+        if result.best_action is None:
+            self._legacy_fallback.make_decision(ai)
+            return
+
+        # Apply mistake rate if configured
+        if self.mistake_rate > 0.0:
+            action = self._apply_mistake(ai, snapshot)
+            if action is not None:
+                self._execute_action(ai, action)
+                return
+
+        self._execute_action(ai, result.best_action)
+
+    def _apply_mistake(
+        self, ai: AI, snapshot: BattleSnapshot
+    ) -> AIAction | None:
+        """
+        Evaluate all top-level actions and pick one using
+        softmax-weighted mistake logic.
+        """
+        from tuxemon.ai.minimax import (
+            _apply_action,
+            _generate_actions,
+            apply_mistake_rate,
+        )
+
+        actions = _generate_actions(snapshot, "ai")
+        if not actions:
+            return None
+
+        scores = []
+        for action in actions:
+            new_snap = _apply_action(snapshot, action, "ai")
+            score = self.minimax_engine.evaluator.evaluate(
+                new_snap
+            ).total
+            scores.append(score)
+
+        return apply_mistake_rate(actions, scores, self.mistake_rate)
+
+    def _build_snapshot(self, ai: AI) -> BattleSnapshot:
+        """
+        Build a BattleSnapshot from the live combat session state.
+        """
+        from tuxemon.ai.battle_evaluator import (
+            BattleSnapshot,
+            MonsterSnapshot,
+        )
+
+        combat = ai.session.client.combat_session
+        character = ai.character
+
+        # Determine which side is AI
+        is_left = character == combat.left_player
+        opponent = (
+            combat.right_player if is_left else combat.left_player
+        )
+
+        # Active monsters
+        ai_active_monsters = combat.field_monsters.get_monsters(
+            character
+        )
+        opp_active_monsters = combat.field_monsters.get_monsters(
+            opponent
+        )
+
+        ai_active = MonsterSnapshot.from_monster(
+            ai_active_monsters[0]
+            if ai_active_monsters
+            else ai.monster
+        )
+        opp_active = MonsterSnapshot.from_monster(
+            opp_active_monsters[0]
+            if opp_active_monsters
+            else ai.opponents[0]
+        )
+
+        # Bench (non-active, non-fainted)
+        ai_bench = tuple(
+            MonsterSnapshot.from_monster(m)
+            for m in combat.get_bench(character)
+        )
+        opp_bench = tuple(
+            MonsterSnapshot.from_monster(m)
+            for m in combat.get_bench(opponent)
+        )
+
+        return BattleSnapshot(
+            ai_active=ai_active,
+            opponent_active=opp_active,
+            ai_bench=ai_bench,
+            opponent_bench=opp_bench,
+            turn=combat.turn,
+        )
+
+    def _execute_action(self, ai: AI, action: AIAction) -> None:
+        """
+        Translate a minimax AIAction into a game action.
+        """
+        from tuxemon.ai.minimax import ActionType
+
+        if action.action_type is ActionType.SWITCH:
+            switch_slug = action.switch_to_slug
+            if switch_slug:
+                self._do_switch(ai, switch_slug)
+                return
+            # Fallback if switch slug is invalid
+            self._legacy_fallback.make_decision(ai)
+            return
+
+        # Technique action: find the matching technique and target
+        valid_actions = ai.get_available_moves()
+        tech_slug = action.technique_slug
+
+        for technique, target in valid_actions:
+            if technique.slug == tech_slug:
+                ai.action_tech(technique, target)
+                return
+
+        # If the chosen tech isn't in valid moves, fall back
+        if valid_actions:
+            technique, target = valid_actions[0]
+            ai.action_tech(technique, target)
+        else:
+            self._legacy_fallback.make_decision(ai)
+
+    def _do_switch(self, ai: AI, switch_slug: str) -> None:
+        """
+        Request a monster switch via the combat session.
+        Uses the standard ``swap`` technique, matching the player-side pattern.
+        Falls back to a technique if the switch target is invalid.
+        """
+        combat = ai.session.client.combat_session
+        bench = combat.get_bench(ai.character)
+
+        for bench_mon in bench:
+            if bench_mon.slug == switch_slug and not bench_mon.is_fainted:
+                swap = Technique.create("swap")
+                combat.enqueue_action(ai.monster, swap, bench_mon)
+                return
+
+        # Switch target not found; fall back to legacy
+        self._legacy_fallback.make_decision(ai)
+
+    def select_move(
+        self,
+        ai: AI,
+        target: Monster,
+        valid_actions: list[tuple[Technique, Monster]],
+    ) -> tuple[Technique, Monster]:
+        if not valid_actions:
+            return self.get_fallback_action(ai, target)
+        return self.choose_action(ai, valid_actions)
+
