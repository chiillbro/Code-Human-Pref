+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import math
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+from tuxemon.ai.battle_evaluator import (
+    BattleSnapshot,
+    BattleStateEvaluator,
+    EvalWeights,
+    MonsterSnapshot,
+)
+from tuxemon.ai.minimax import (
+    AIAction,
+    ActionType,
+    MinimaxEngine,
+    MinimaxResult,
+    _apply_action,
+    _generate_actions,
+    _simulate_attack,
+    _simulate_switch,
+    _simulate_technique_damage,
+    apply_mistake_rate,
+)
+
+
+def _snap(
+    slug: str = "mon",
+    current_hp: int = 50,
+    max_hp: int = 100,
+    level: int = 10,
+    speed: int = 20,
+    melee: int = 30,
+    ranged: int = 25,
+    armour: int = 20,
+    dodge: int = 15,
+    type_slugs: tuple[str, ...] = ("fire",),
+    status_slugs: tuple[str, ...] = (),
+    is_fainted: bool = False,
+    move_slugs: tuple[str, ...] = ("tackle",),
+    has_healing_moves: bool = False,
+    has_status_moves: bool = False,
+    has_stat_boost_moves: bool = False,
+) -> MonsterSnapshot:
+    return MonsterSnapshot(
+        slug=slug,
+        current_hp=current_hp,
+        max_hp=max_hp,
+        level=level,
+        speed=speed,
+        melee=melee,
+        ranged=ranged,
+        armour=armour,
+        dodge=dodge,
+        type_slugs=type_slugs,
+        status_slugs=status_slugs,
+        is_fainted=is_fainted,
+        move_slugs=move_slugs,
+        has_healing_moves=has_healing_moves,
+        has_status_moves=has_status_moves,
+        has_stat_boost_moves=has_stat_boost_moves,
+    )
+
+
+def _battle_snap(
+    ai_hp: int = 80,
+    opp_hp: int = 60,
+    ai_bench: tuple[MonsterSnapshot, ...] = (),
+    opp_bench: tuple[MonsterSnapshot, ...] = (),
+    turn: int = 1,
+) -> BattleSnapshot:
+    return BattleSnapshot(
+        ai_active=_snap(slug="ai_mon", current_hp=ai_hp),
+        opponent_active=_snap(slug="opp_mon", current_hp=opp_hp),
+        ai_bench=ai_bench,
+        opponent_bench=opp_bench,
+        turn=turn,
+    )
+
+
+class TestActionType:
+    def test_technique_action(self):
+        action = AIAction(
+            action_type=ActionType.TECHNIQUE,
+            technique_slug="tackle",
+            target_slug="enemy",
+        )
+        assert action.is_technique is True
+        assert action.is_switch is False
+
+    def test_switch_action(self):
+        action = AIAction(
+            action_type=ActionType.SWITCH,
+            switch_to_slug="bench_mon",
+        )
+        assert action.is_switch is True
+        assert action.is_technique is False
+
+
+class TestSimulateTechniqueDamage:
+    @patch("tuxemon.ai.minimax.Element")
+    @patch("tuxemon.ai.minimax.ElementTypesHandler")
+    def test_returns_positive_damage(
+        self, mock_handler, mock_element
+    ):
+        mock_element.get.return_value = MagicMock()
+        mock_handler.calculate_affinity_score.return_value = 1.0
+
+        attacker = _snap(melee=30, ranged=25, level=10)
+        defender = _snap(armour=20)
+
+        dmg = _simulate_technique_damage(attacker, defender, "tackle")
+        assert dmg >= 1
+
+    @patch("tuxemon.ai.minimax.Element")
+    @patch("tuxemon.ai.minimax.ElementTypesHandler")
+    def test_minimum_damage_is_one(
+        self, mock_handler, mock_element
+    ):
+        mock_element.get.return_value = MagicMock()
+        mock_handler.calculate_affinity_score.return_value = 0.01
+
+        attacker = _snap(melee=1, ranged=1, level=1)
+        defender = _snap(armour=999)
+
+        dmg = _simulate_technique_damage(attacker, defender, "tackle")
+        assert dmg == 1
+
+
+class TestSimulateSwitch:
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=10)
+    def test_switch_moves_bench_to_active_ai(self, mock_dmg):
+        bench_mon = _snap(slug="bench_1", current_hp=80)
+        snap = _battle_snap(ai_bench=(bench_mon,))
+
+        new_snap = _simulate_switch(snap, "ai", "bench_1")
+        assert new_snap.ai_active.slug == "bench_1"
+        # Old active should be in bench now
+        assert any(m.slug == "ai_mon" for m in new_snap.ai_bench)
+
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=10)
+    def test_switch_applies_free_attack(self, mock_dmg):
+        bench_mon = _snap(slug="bench_1", current_hp=80)
+        snap = _battle_snap(ai_bench=(bench_mon,))
+
+        new_snap = _simulate_switch(snap, "ai", "bench_1")
+        # Free attack should reduce HP
+        assert new_snap.ai_active.current_hp == 70
+
+    def test_switch_with_invalid_slug_returns_same(self):
+        snap = _battle_snap()
+        new_snap = _simulate_switch(snap, "ai", "nonexistent")
+        assert new_snap is snap
+
+
+class TestSimulateAttack:
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=20)
+    def test_ai_attack_reduces_opponent_hp(self, mock_dmg):
+        snap = _battle_snap(opp_hp=60)
+        new_snap = _simulate_attack(snap, "ai", "tackle")
+        assert new_snap.opponent_active.current_hp == 40
+
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=20)
+    def test_opponent_attack_reduces_ai_hp(self, mock_dmg):
+        snap = _battle_snap(ai_hp=80)
+        new_snap = _simulate_attack(snap, "opponent", "tackle")
+        assert new_snap.ai_active.current_hp == 60
+
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=999)
+    def test_hp_does_not_go_below_zero(self, mock_dmg):
+        snap = _battle_snap(opp_hp=10)
+        new_snap = _simulate_attack(snap, "ai", "tackle")
+        assert new_snap.opponent_active.current_hp == 0
+        assert new_snap.opponent_active.is_fainted is True
+
+
+class TestGenerateActions:
+    def test_generates_technique_actions(self):
+        snap = _battle_snap()
+        actions = _generate_actions(snap, "ai")
+        tech_actions = [a for a in actions if a.is_technique]
+        assert len(tech_actions) >= 1
+
+    def test_generates_switch_actions_when_bench_exists(self):
+        bench = (_snap(slug="bench_1"),)
+        snap = _battle_snap(ai_bench=bench)
+        actions = _generate_actions(snap, "ai")
+        switch_actions = [a for a in actions if a.is_switch]
+        assert len(switch_actions) == 1
+
+    def test_fainted_active_only_generates_switches(self):
+        fainted = _snap(slug="ai_mon", is_fainted=True, current_hp=0)
+        bench = (_snap(slug="bench_1"),)
+        snap = BattleSnapshot(
+            ai_active=fainted,
+            opponent_active=_snap(slug="opp_mon"),
+            ai_bench=bench,
+            opponent_bench=(),
+            turn=1,
+        )
+        actions = _generate_actions(snap, "ai")
+        assert all(a.is_switch for a in actions)
+
+    def test_no_actions_when_fainted_and_no_bench(self):
+        fainted = _snap(slug="ai_mon", is_fainted=True, current_hp=0)
+        snap = BattleSnapshot(
+            ai_active=fainted,
+            opponent_active=_snap(slug="opp_mon"),
+            ai_bench=(),
+            opponent_bench=(),
+            turn=1,
+        )
+        actions = _generate_actions(snap, "ai")
+        assert actions == []
+
+
+class TestApplyAction:
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=10)
+    def test_apply_technique_action(self, mock_dmg):
+        snap = _battle_snap(opp_hp=50)
