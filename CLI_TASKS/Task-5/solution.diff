+class TestMinimaxEngine:
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=10)
+    def test_finds_action_for_simple_state(self, mock_dmg):
+        evaluator = BattleStateEvaluator()
+        engine = MinimaxEngine(evaluator, search_depth=1)
+
+        snap = _battle_snap()
+        result = engine.find_best_action(snap)
+
+        assert isinstance(result, MinimaxResult)
+        assert result.best_action is not None
+        assert result.nodes_evaluated >= 1
+
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=10)
+    def test_returns_none_when_no_actions(self, mock_dmg):
+        evaluator = BattleStateEvaluator()
+        engine = MinimaxEngine(evaluator, search_depth=1)
+
+        fainted = _snap(slug="ai_mon", is_fainted=True, current_hp=0)
+        snap = BattleSnapshot(
+            ai_active=fainted,
+            opponent_active=_snap(slug="opp_mon"),
+            ai_bench=(),
+            opponent_bench=(),
+            turn=1,
+        )
+        result = engine.find_best_action(snap)
+        assert result.best_action is None
+
+    @patch("tuxemon.ai.minimax._simulate_technique_damage", return_value=10)
