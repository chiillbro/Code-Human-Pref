+
+class TestApplyMistakeRate:
+    def test_no_mistake_picks_best(self):
+        actions = [
+            AIAction(action_type=ActionType.TECHNIQUE, technique_slug="a"),
+            AIAction(action_type=ActionType.TECHNIQUE, technique_slug="b"),
+        ]
+        scores = [10.0, 5.0]
+
+        result = apply_mistake_rate(actions, scores, 0.0)
+        assert result.technique_slug == "a"
+
+    def test_single_action_returns_it(self):
+        action = AIAction(
+            action_type=ActionType.TECHNIQUE, technique_slug="only"
+        )
+        result = apply_mistake_rate([action], [10.0], 0.5)
+        assert result.technique_slug == "only"
+
+    def test_raises_on_empty_actions(self):
+        with pytest.raises(ValueError, match="No actions"):
+            apply_mistake_rate([], [], 0.5)
+
+    def test_high_mistake_rate_still_returns_valid_action(self):
+        actions = [
+            AIAction(action_type=ActionType.TECHNIQUE, technique_slug="a"),
+            AIAction(action_type=ActionType.TECHNIQUE, technique_slug="b"),
+            AIAction(action_type=ActionType.TECHNIQUE, technique_slug="c"),
+        ]
+        scores = [10.0, 5.0, 1.0]
+
+        result = apply_mistake_rate(actions, scores, 1.0)
+        assert result.technique_slug in {"a", "b", "c"}
