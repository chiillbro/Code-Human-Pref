+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import logging
+from dataclasses import dataclass
+
+from tuxemon.ai.battle_evaluator import MonsterSnapshot
+
+logger = logging.getLogger(__name__)
+
+# Default thresholds
+_LOW_HP_THRESHOLD = 0.20
+_BENCH_MIN_HP_RATIO = 0.50
+_SPEED_BONUS = 2.0
+_RESIST_BONUS = 3.0
+_SWITCH_COST_WEIGHT = 0.6
+
+
+@dataclass
+class SwitchScore:
+    """Scoring result for a potential switch-in."""
+
+    monster_slug: str
+    total: float
+    breakdown: dict[str, float]
+
+
+class SwitchEvaluator:
+    """
+    Evaluates whether the AI should switch its active monster for a
+    bench monster, considering type matchups, HP, speed, and the
+    cost of losing a turn to the opponent's free attack.
+    """
+
+    def __init__(
+        self,
+        low_hp_threshold: float = _LOW_HP_THRESHOLD,
+        bench_min_hp_ratio: float = _BENCH_MIN_HP_RATIO,
+    ) -> None:
+        self.low_hp_threshold = low_hp_threshold
+        self.bench_min_hp_ratio = bench_min_hp_ratio
+
+    def evaluate_switches(
+        self,
+        ai_active: MonsterSnapshot,
+        opponent_active: MonsterSnapshot,
+        bench: tuple[MonsterSnapshot, ...],
+        opponent_last_move_types: tuple[str, ...] | None = None,
+    ) -> list[SwitchScore]:
+        """
+        Score all healthy bench monsters as potential switch-ins.
+        Higher score = better switch candidate.
+        """
+        results: list[SwitchScore] = []
+
+        for bench_mon in bench:
+            if bench_mon.is_fainted:
+                continue
+
+            score = self._score_switch_in(
+                bench_mon,
+                opponent_active,
+                ai_active,
+                opponent_last_move_types,
+            )
+            results.append(score)
+
+        results.sort(key=lambda s: s.total, reverse=True)
+        return results
+
+    def should_force_switch(
+        self,
+        ai_active: MonsterSnapshot,
+        opponent_active: MonsterSnapshot,
+        bench: tuple[MonsterSnapshot, ...],
+    ) -> bool:
+        """
+        Determine if the AI should strongly prefer switching based
+        on HP threshold and bench availability.
+        """
+        if ai_active.hp_ratio >= self.low_hp_threshold:
+            return False
+
+        for bench_mon in bench:
+            if bench_mon.is_fainted:
+                continue
+            if bench_mon.hp_ratio < self.bench_min_hp_ratio:
+                continue
+            # Check the bench monster has at least neutral matchup
+            mult = _type_multiplier(
+                bench_mon.type_slugs, opponent_active.type_slugs
+            )
+            if mult >= 1.0:
+                return True
+
+        return False
+
+    def get_best_switch(
+        self,
+        ai_active: MonsterSnapshot,
+        opponent_active: MonsterSnapshot,
+        bench: tuple[MonsterSnapshot, ...],
+        opponent_last_move_types: tuple[str, ...] | None = None,
+    ) -> str | None:
+        """
+        Return the slug of the best switch-in, or None if no
+        viable candidate exists.
+        """
+        scores = self.evaluate_switches(
+            ai_active, opponent_active, bench, opponent_last_move_types
+        )
+        if not scores:
+            return None
+        if scores[0].total <= 0:
+            return None
+        return scores[0].monster_slug
+
+    def _score_switch_in(
+        self,
+        candidate: MonsterSnapshot,
+        opponent: MonsterSnapshot,
+        current_active: MonsterSnapshot,
+        opponent_last_move_types: tuple[str, ...] | None,
+    ) -> SwitchScore:
+        """
+        Score a single bench monster as a switch-in candidate.
+        Accounts for the cost of losing a turn.
+        """
+        breakdown: dict[str, float] = {}
+
+        # Type advantage vs opponent
+        type_mult = _type_multiplier(
+            candidate.type_slugs, opponent.type_slugs
+        )
+        # Score relative to current active's matchup
+        current_mult = _type_multiplier(
+            current_active.type_slugs, opponent.type_slugs
+        )
+        type_improvement = type_mult - current_mult
+        breakdown["type_advantage"] = type_improvement * 10.0
+
+        # HP ratio of the candidate
+        breakdown["hp_ratio"] = candidate.hp_ratio * 5.0
+
+        # Speed comparison: can it outspeed the opponent?
+        if candidate.speed > opponent.speed:
+            breakdown["speed_advantage"] = _SPEED_BONUS
+        else:
+            breakdown["speed_advantage"] = 0.0
+
+        # Resistance to opponent's last move type
+        resist_score = 0.0
+        if opponent_last_move_types:
+            resist_mult = _defensive_multiplier(
+                candidate.type_slugs, opponent_last_move_types
+            )
+            if resist_mult < 1.0:
+                resist_score = _RESIST_BONUS * (1.0 - resist_mult)
+        breakdown["resistance"] = resist_score
+
+        # Switch cost: estimate damage opponent deals during the switch turn
+        switch_cost = self._estimate_switch_cost(candidate, opponent)
+        breakdown["switch_cost"] = -switch_cost * _SWITCH_COST_WEIGHT
+
+        total = sum(breakdown.values())
+
+        logger.debug(
+            f"Switch score for {candidate.slug}: "
+            f"breakdown={breakdown}, total={total:.2f}"
+        )
+
+        return SwitchScore(
+            monster_slug=candidate.slug,
+            total=total,
+            breakdown=breakdown,
+        )
+
+    @staticmethod
+    def _estimate_switch_cost(
+        candidate: MonsterSnapshot,
+        opponent: MonsterSnapshot,
+    ) -> float:
+        """
+        Estimate the damage the opponent will deal during the switch turn
+        as a fraction of the candidate's max HP. This discounts the
+        switch-in score so the AI doesn't switch frivolously.
+        """
+        attack_power = max(opponent.melee, opponent.ranged)
+        defense = max(candidate.armour, 1)
+
+        type_mult = _type_multiplier(
+            opponent.type_slugs, candidate.type_slugs
+        )
+
+        level_factor = 5 + opponent.level
+        estimated_damage = (
+            attack_power * level_factor * type_mult
+        ) / (defense * 2)
+
+        # Normalize as fraction of candidate's max HP
+        if candidate.max_hp <= 0:
+            return 0.0
+
+        return min(estimated_damage / candidate.max_hp, 1.0)
+
+
+def _type_multiplier(
+    attacker_types: tuple[str, ...],
+    defender_types: tuple[str, ...],
+) -> float:
+    """Compute offensive type multiplier."""
+    from tuxemon.element import Element, ElementTypesHandler
+
+    attack_elements = [Element.get(s) for s in attacker_types if s]
+    defend_elements = [Element.get(s) for s in defender_types if s]
+
+    if not attack_elements or not defend_elements:
+        return 1.0
+
+    return ElementTypesHandler.calculate_affinity_score(
+        attack_elements, defend_elements
+    )
+
+
+def _defensive_multiplier(
+    defender_types: tuple[str, ...],
+    attacking_type_slugs: tuple[str, ...],
+) -> float:
+    """
+    Compute how much damage the defender takes from the attacker's types.
+    Lower = more resistant.
+    """
+    from tuxemon.element import Element, ElementTypesHandler
+
+    attack_elements = [Element.get(s) for s in attacking_type_slugs if s]
+    defend_elements = [Element.get(s) for s in defender_types if s]
+
+    if not attack_elements or not defend_elements:
+        return 1.0
+
+    return ElementTypesHandler.calculate_affinity_score(
+        attack_elements, defend_elements
+    )
