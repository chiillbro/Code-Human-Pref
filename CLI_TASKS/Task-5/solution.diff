+
+    @patch(
+        "tuxemon.ai.strategy_controller._get_type_multiplier",
+        return_value=1.5,
+    )
+    def test_sweep_with_type_advantage(self, mock_mult):
+        snap = _make_snapshot(
+            ai_hp=80,
+            ai_bench_count=1,
+            turn=5,
+        )
+        phase = self.controller.detect_phase(snap)
+        assert phase == BattlePhase.SWEEP
+
+    def test_default_to_sweep(self):
+        """When no special condition is met, default is SWEEP."""
+        snap = _make_snapshot(ai_hp=80, ai_bench_count=1, turn=5)
+        phase = self.controller.detect_phase(snap)
