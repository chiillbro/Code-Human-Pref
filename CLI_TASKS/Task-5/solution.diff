+    def test_get_weights_for_snapshot_returns_eval_weights(self):
+        snap = _make_snapshot(ai_hp=90, ai_bench_count=1)
+        weights = self.controller.get_weights_for_snapshot(snap)
+        assert isinstance(weights, EvalWeights)
+
+    def test_get_weights_copies(self):
+        w1 = self.controller.get_weights(BattlePhase.SWEEP)
+        w2 = self.controller.get_weights(BattlePhase.SWEEP)
+        w1.hp_ratio = 999.0
+        assert w2.hp_ratio != 999.0
+
+    @patch(
+        "tuxemon.ai.strategy_controller._get_type_multiplier",
+        return_value=0.4,
+    )
+    def test_stall_with_healing_at_disadvantage(self, mock_mult):
+        snap = _make_snapshot(
+            ai_hp=80,
+            ai_bench_count=0,
+            has_healing=True,
+        )
