+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+from tuxemon.ai.battle_evaluator import (
+    BattleSnapshot,
+    EvalWeights,
+    MonsterSnapshot,
+)
+from tuxemon.ai.strategy_controller import (
+    BattlePhase,
+    StrategyController,
+    _get_type_multiplier,
+)
+
+
+def _snap(
+    slug: str = "mon",
+    current_hp: int = 50,
+    max_hp: int = 100,
+    level: int = 10,
+    speed: int = 20,
+    melee: int = 30,
+    ranged: int = 25,
+    armour: int = 20,
+    dodge: int = 15,
+    type_slugs: tuple[str, ...] = ("fire",),
+    status_slugs: tuple[str, ...] = (),
+    is_fainted: bool = False,
+    move_slugs: tuple[str, ...] = ("tackle",),
+    has_healing_moves: bool = False,
+    has_status_moves: bool = False,
+    has_stat_boost_moves: bool = False,
+) -> MonsterSnapshot:
+    return MonsterSnapshot(
+        slug=slug,
+        current_hp=current_hp,
+        max_hp=max_hp,
+        level=level,
+        speed=speed,
+        melee=melee,
+        ranged=ranged,
+        armour=armour,
+        dodge=dodge,
+        type_slugs=type_slugs,
+        status_slugs=status_slugs,
+        is_fainted=is_fainted,
+        move_slugs=move_slugs,
+        has_healing_moves=has_healing_moves,
+        has_status_moves=has_status_moves,
+        has_stat_boost_moves=has_stat_boost_moves,
+    )
+
+
+def _make_snapshot(
+    ai_hp: int = 50,
+    ai_max_hp: int = 100,
+    ai_bench_count: int = 0,
+    ai_types: tuple[str, ...] = ("fire",),
+    opp_types: tuple[str, ...] = ("fire",),
+    turn: int = 1,
+    has_healing: bool = False,
+    has_status: bool = False,
+    has_stat_boost: bool = False,
+    ai_melee: int = 30,
+    opp_armour: int = 20,
+) -> BattleSnapshot:
+    ai_active = _snap(
+        slug="ai_mon",
+        current_hp=ai_hp,
+        max_hp=ai_max_hp,
+        type_slugs=ai_types,
+        has_healing_moves=has_healing,
+        has_status_moves=has_status,
+        has_stat_boost_moves=has_stat_boost,
+        melee=ai_melee,
+    )
+    opp_active = _snap(
+        slug="opp_mon",
+        type_slugs=opp_types,
+        armour=opp_armour,
+    )
+    ai_bench = tuple(
+        _snap(slug=f"bench_{i}") for i in range(ai_bench_count)
+    )
+    return BattleSnapshot(
+        ai_active=ai_active,
+        opponent_active=opp_active,
+        ai_bench=ai_bench,
+        opponent_bench=(),
+        turn=turn,
+    )
+
+
+class TestBattlePhaseEnum:
+    def test_all_phases_exist(self):
+        assert BattlePhase.SETUP.value == "setup"
+        assert BattlePhase.SWEEP.value == "sweep"
+        assert BattlePhase.STALL.value == "stall"
+        assert BattlePhase.DESPERATION.value == "desperation"
+        assert BattlePhase.SWITCH.value == "switch"
+
+
+class TestStrategyController:
+    def setup_method(self):
+        self.controller = StrategyController()
+
+    def test_desperation_low_hp_no_bench(self):
+        snap = _make_snapshot(ai_hp=10, ai_max_hp=100, ai_bench_count=0)
+        phase = self.controller.detect_phase(snap)
+        assert phase == BattlePhase.DESPERATION
+
+    def test_not_desperate_with_bench(self):
+        snap = _make_snapshot(ai_hp=10, ai_max_hp=100, ai_bench_count=1)
+        phase = self.controller.detect_phase(snap)
+        assert phase != BattlePhase.DESPERATION
+
+    def test_not_desperate_high_hp(self):
+        snap = _make_snapshot(ai_hp=90, ai_max_hp=100, ai_bench_count=0)
+        phase = self.controller.detect_phase(snap)
+        assert phase != BattlePhase.DESPERATION
+
+    @patch(
+        "tuxemon.ai.strategy_controller._get_type_multiplier",
+        return_value=1.0,
+    )
+    def test_setup_early_turn_with_stat_boost(self, mock_mult):
+        snap = _make_snapshot(
+            turn=1,
+            has_stat_boost=True,
+            ai_hp=80,
+            ai_bench_count=1,
+        )
