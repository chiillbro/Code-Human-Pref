+    def _smart_replacement(
+        self,
+        character: NPC,
+        available_monsters: Sequence[Monster],
+    ) -> Monster:
+        """
+        Use the SwitchEvaluator to pick the best replacement based on
+        type matchup and HP. Falls back to healthiest if evaluation fails.
+        """
+        combat = self.session.client.combat_session
+        opponent_player = (
+            combat.right_player
+            if character == combat.left_player
+            else combat.left_player
+        )
+        opp_active = combat.field_monsters.get_monsters(opponent_player)
+
+        if not opp_active:
+            chosen = max(
+                available_monsters, key=lambda m: m.current_hp
+            )
+            logger.debug(
+                f"Smart strategy (no opponent): {chosen.name}"
+            )
+            return chosen
+
+        try:
+            from tuxemon.ai.battle_evaluator import MonsterSnapshot
+            from tuxemon.ai.switch_evaluator import SwitchEvaluator
+
+            opp_snap = MonsterSnapshot.from_monster(opp_active[0])
+
