+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import logging
+from enum import Enum
+
+from tuxemon.ai.battle_evaluator import (
+    BattleSnapshot,
+    EvalWeights,
+)
+
+logger = logging.getLogger(__name__)
+
+
+class BattlePhase(Enum):
+    """
+    Represents the strategic phase of a battle from the AI's perspective.
+    """
+
+    SETUP = "setup"
+    SWEEP = "sweep"
+    STALL = "stall"
+    DESPERATION = "desperation"
+    SWITCH = "switch"
+
+
+# Weight profiles per battle phase
+_PHASE_WEIGHTS: dict[BattlePhase, EvalWeights] = {
+    BattlePhase.SETUP: EvalWeights(
+        hp_ratio=25.0,
+        type_advantage=15.0,
+        status_effects=20.0,  # Boost status moves value
+        bench_depth=8.0,
+        level_diff=5.0,
+        fainted_penalty=20.0,
+    ),
+    BattlePhase.SWEEP: EvalWeights(
+        hp_ratio=35.0,
+        type_advantage=30.0,  # Maximize damage
+        status_effects=5.0,
+        bench_depth=5.0,
+        level_diff=8.0,
+        fainted_penalty=20.0,
+    ),
+    BattlePhase.STALL: EvalWeights(
+        hp_ratio=40.0,  # Survive longer
+        type_advantage=10.0,
+        status_effects=20.0,  # Healing/status preferred
+        bench_depth=10.0,
+        level_diff=3.0,
+        fainted_penalty=25.0,
+    ),
+    BattlePhase.DESPERATION: EvalWeights(
+        hp_ratio=20.0,
+        type_advantage=35.0,  # Max damage, go all-out
+        status_effects=2.0,
+        bench_depth=2.0,
+        level_diff=5.0,
+        fainted_penalty=40.0,
+    ),
+    BattlePhase.SWITCH: EvalWeights(
+        hp_ratio=30.0,
+        type_advantage=25.0,
+        status_effects=10.0,
+        bench_depth=12.0,  # Bench matters more when switching
+        level_diff=5.0,
+        fainted_penalty=25.0,
+    ),
+}
+
+# Thresholds
+_DESPERATION_HP_THRESHOLD = 0.25
+_TYPE_DISADVANTAGE_THRESHOLD = 0.7
+_TYPE_ADVANTAGE_THRESHOLD = 1.3
+_SETUP_MAX_TURN = 2
+
+
+class StrategyController:
+    """
+    Detects the current battle phase by analyzing the battle state
+    and the AI monster's move pool. Returns per-phase weight profiles
+    for the BattleStateEvaluator.
+    """
+
+    def detect_phase(self, snapshot: BattleSnapshot) -> BattlePhase:
+        """
+        Classify the current battle into a strategic phase.
+        Checks are ordered by priority (most urgent first).
+        """
+        ai = snapshot.ai_active
+        opponent = snapshot.opponent_active
+
+        # DESPERATION: last monster, low HP
+        if self._is_desperate(snapshot):
+            logger.debug("Phase detected: DESPERATION")
+            return BattlePhase.DESPERATION
+
+        # SWITCH: severe type disadvantage with a better option on bench
+        if self._should_switch(snapshot):
+            logger.debug("Phase detected: SWITCH")
+            return BattlePhase.SWITCH
+
+        # STALL: at a type disadvantage but has healing/status moves
+        if self._should_stall(snapshot):
+            logger.debug("Phase detected: STALL")
+            return BattlePhase.STALL
+
+        # SETUP: early turns with stat-boost moves available
+        if self._should_setup(snapshot):
+            logger.debug("Phase detected: SETUP")
+            return BattlePhase.SETUP
+
+        # SWEEP: type advantage or strong offensive position
+        if self._should_sweep(snapshot):
+            logger.debug("Phase detected: SWEEP")
+            return BattlePhase.SWEEP
+
+        # Default to SWEEP
+        logger.debug("Phase detected: SWEEP (default)")
+        return BattlePhase.SWEEP
+
+    def get_weights(self, phase: BattlePhase) -> EvalWeights:
+        """Get the evaluation weight profile for a given phase."""
+        return _PHASE_WEIGHTS[phase].copy()
+
+    def get_weights_for_snapshot(
+        self, snapshot: BattleSnapshot
+    ) -> EvalWeights:
+        """Detect phase and return corresponding weights."""
+        phase = self.detect_phase(snapshot)
+        return self.get_weights(phase)
+
+    @staticmethod
+    def _is_desperate(snapshot: BattleSnapshot) -> bool:
+        """
+        True if AI has only one monster left (active) with low HP.
+        """
+        ai = snapshot.ai_active
+        has_bench = snapshot.ai_healthy_bench_count > 0
+
+        if has_bench:
+            return False
+
+        return ai.hp_ratio < _DESPERATION_HP_THRESHOLD
+
+    @staticmethod
+    def _should_switch(snapshot: BattleSnapshot) -> bool:
+        """
+        True if the AI's active monster is at a severe type disadvantage
+        and there's a better matchup available on the bench.
+        """
+        ai = snapshot.ai_active
+        opponent = snapshot.opponent_active
+
+        if snapshot.ai_healthy_bench_count == 0:
+            return False
+
+        # Check if current active is at a type disadvantage
+        type_mult = _get_type_multiplier(
+            ai.type_slugs, opponent.type_slugs
+        )
+        if type_mult >= _TYPE_DISADVANTAGE_THRESHOLD:
+            return False  # Not at a significant disadvantage
+
+        # Check if any bench monster has a better matchup
+        for bench_mon in snapshot.ai_bench:
+            if bench_mon.is_fainted:
+                continue
+            bench_mult = _get_type_multiplier(
+                bench_mon.type_slugs, opponent.type_slugs
+            )
+            if bench_mult > type_mult + 0.3:
+                return True
+
+        return False
+
+    @staticmethod
+    def _should_stall(snapshot: BattleSnapshot) -> bool:
+        """
+        True if at a type disadvantage but has healing or status moves.
+        """
+        ai = snapshot.ai_active
+        opponent = snapshot.opponent_active
+
+        type_mult = _get_type_multiplier(
+            ai.type_slugs, opponent.type_slugs
+        )
+        if type_mult >= 1.0:
+            return False  # Not disadvantaged
+
+        return ai.has_healing_moves or ai.has_status_moves
+
+    @staticmethod
+    def _should_setup(snapshot: BattleSnapshot) -> bool:
+        """
+        True if early in the battle and the AI monster has stat-boost moves.
+        Inspects the actual move pool, not just HP thresholds.
+        """
+        ai = snapshot.ai_active
+
+        if snapshot.turn > _SETUP_MAX_TURN:
+            return False
+
+        return ai.has_stat_boost_moves
+
+    @staticmethod
+    def _should_sweep(snapshot: BattleSnapshot) -> bool:
+        """
+        True if the AI has a significant stat or type advantage.
+        """
+        ai = snapshot.ai_active
+        opponent = snapshot.opponent_active
+
+        type_mult = _get_type_multiplier(
+            ai.type_slugs, opponent.type_slugs
+        )
+        if type_mult >= _TYPE_ADVANTAGE_THRESHOLD:
+            return True
+
+        # Stat advantage: if AI's attack stats are significantly higher
+        ai_power = max(ai.melee, ai.ranged)
+        opp_defense = max(opponent.armour, 1)
+        if ai_power > opp_defense * 1.3:
+            return True
+
+        return False
+
+
+def _get_type_multiplier(
+    attacker_types: tuple[str, ...],
+    defender_types: tuple[str, ...],
+) -> float:
+    """
+    Compute the type multiplier for attacker vs defender.
+    Returns 1.0 for neutral, >1.0 for advantage, <1.0 for disadvantage.
+    """
+    from tuxemon.element import Element, ElementTypesHandler
+
+    attack_elements = [Element.get(s) for s in attacker_types if s]
+    defend_elements = [Element.get(s) for s in defender_types if s]
+
+    if not attack_elements or not defend_elements:
+        return 1.0
+
+    return ElementTypesHandler.calculate_affinity_score(
+        attack_elements, defend_elements
+    )
