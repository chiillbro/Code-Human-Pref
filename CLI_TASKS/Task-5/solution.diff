new file mode 100644
index 000000000..87c33ca82
--- /dev/null
+++ b/tuxemon/ai/battle_evaluator.py
@@ -0,0 +1,244 @@
+# SPDX-License-Identifier: GPL-3.0
+# Copyright (c) 2014-2026 William Edwards <shadowapex@gmail.com>, Benjamin Bean <superman2k5@gmail.com>
+from __future__ import annotations
+
+import logging
+from dataclasses import dataclass, field
+from typing import TYPE_CHECKING
+
+from tuxemon.element import ElementTypesHandler
+
+if TYPE_CHECKING:
+    from tuxemon.monster.monster import Monster
+
+logger = logging.getLogger(__name__)
+
+
+@dataclass(frozen=True)
+class MonsterSnapshot:
+    """
+    Lightweight, immutable snapshot of a monster's battle-relevant state.
+    Used by the Minimax engine to avoid cloning live game objects.
+    """
+
+    slug: str
+    current_hp: int
+    max_hp: int
+    level: int
+    speed: int
+    melee: int
+    ranged: int
+    armour: int
+    dodge: int
+    type_slugs: tuple[str, ...]
+    status_slugs: tuple[str, ...]
+    is_fainted: bool
+    move_slugs: tuple[str, ...]
+    has_healing_moves: bool
+    has_status_moves: bool
+    has_stat_boost_moves: bool
+
+    @property
+    def hp_ratio(self) -> float:
+        if self.max_hp <= 0:
+            return 0.0
+        return min(self.current_hp / self.max_hp, 1.0)
+
+    @classmethod
+    def from_monster(cls, monster: Monster) -> MonsterSnapshot:
+        moves = monster.moves.get_moves()
+        has_healing = any(t.healing_power > 0 for t in moves)
+        has_status = any(
+            t.power == 0 and t.healing_power == 0 for t in moves
+        )
+        has_stat_boost = any(
+            bool(t.stat_modifiers) for t in moves
+        )
+
+        return cls(
+            slug=monster.slug,
+            current_hp=monster.current_hp,
+            max_hp=monster.hp,
+            level=monster.level,
+            speed=monster.speed,
+            melee=monster.melee,
+            ranged=monster.ranged,
+            armour=monster.armour,
+            dodge=monster.dodge,
+            type_slugs=tuple(monster.types.get_type_slugs()),
+            status_slugs=tuple(
+                s.slug for s in monster.status.get_statuses()
+            ),
+            is_fainted=monster.is_fainted,
+            move_slugs=tuple(t.slug for t in moves),
+            has_healing_moves=has_healing,
+            has_status_moves=has_status,
+            has_stat_boost_moves=has_stat_boost,
+        )
+
+
+@dataclass(frozen=True)
+class BattleSnapshot:
+    """
+    Complete snapshot of a battle state for stateless evaluation.
+    """
+
+    ai_active: MonsterSnapshot
+    opponent_active: MonsterSnapshot
+    ai_bench: tuple[MonsterSnapshot, ...]
+    opponent_bench: tuple[MonsterSnapshot, ...]
+    turn: int
+
+    @property
+    def ai_healthy_bench_count(self) -> int:
+        return sum(1 for m in self.ai_bench if not m.is_fainted)
+
+    @property
+    def opponent_healthy_bench_count(self) -> int:
+        return sum(1 for m in self.opponent_bench if not m.is_fainted)
+
+    @property
+    def ai_total_fainted(self) -> int:
+        fainted = int(self.ai_active.is_fainted)
+        fainted += sum(1 for m in self.ai_bench if m.is_fainted)
+        return fainted
+
+    @property
+    def opponent_total_fainted(self) -> int:
+        fainted = int(self.opponent_active.is_fainted)
+        fainted += sum(1 for m in self.opponent_bench if m.is_fainted)
+        return fainted
+
+    @property
+    def is_ai_defeated(self) -> bool:
+        if self.ai_active.is_fainted and self.ai_healthy_bench_count == 0:
+            return True
+        return False
+
+    @property
+    def is_opponent_defeated(self) -> bool:
+        if (
+            self.opponent_active.is_fainted
+            and self.opponent_healthy_bench_count == 0
+        ):
+            return True
+        return False
+
+    @property
+    def is_terminal(self) -> bool:
+        return self.is_ai_defeated or self.is_opponent_defeated
+
+
+@dataclass
+class EvalWeights:
+    """
+    Scoring weights for the battle state evaluator.
+    Strategy controller adjusts these per battle phase.
+    """
+
+    hp_ratio: float = 30.0
+    type_advantage: float = 20.0
+    status_effects: float = 10.0
+    bench_depth: float = 8.0
+    level_diff: float = 5.0
+    fainted_penalty: float = 25.0
+
+    def copy(self) -> EvalWeights:
+        return EvalWeights(
+            hp_ratio=self.hp_ratio,
+            type_advantage=self.type_advantage,
+            status_effects=self.status_effects,
+            bench_depth=self.bench_depth,
+            level_diff=self.level_diff,
+            fainted_penalty=self.fainted_penalty,
+        )
+
+
+@dataclass
+class EvalResult:
+    """Evaluation result with score breakdown."""
+
+    total: float
+    breakdown: dict[str, float] = field(default_factory=dict)
+
+
+class BattleStateEvaluator:
+    """
+    Stateless evaluator that scores a BattleSnapshot from the AI's
+    perspective. Positive scores favor the AI; negative favor the
+    opponent.
+    """
+
+    def __init__(self, weights: EvalWeights | None = None) -> None:
+        self.weights = weights or EvalWeights()
+
+    def evaluate(self, snapshot: BattleSnapshot) -> EvalResult:
+        breakdown: dict[str, float] = {}
+
+        # HP ratio differential
+        ai_hp = snapshot.ai_active.hp_ratio
+        opp_hp = snapshot.opponent_active.hp_ratio
+        breakdown["hp_ratio"] = (ai_hp - opp_hp) * self.weights.hp_ratio
+
+        # Type advantage (AI attacking opponent)
+        type_mult = self._type_advantage_score(
+            snapshot.ai_active.type_slugs,
+            snapshot.opponent_active.type_slugs,
+        )
+        breakdown["type_advantage"] = type_mult * self.weights.type_advantage
+
+        # Status effects: negative statuses on opponent are good for AI
+        opp_status_count = len(snapshot.opponent_active.status_slugs)
+        ai_status_count = len(snapshot.ai_active.status_slugs)
+        breakdown["status_effects"] = (
+            (opp_status_count - ai_status_count) * self.weights.status_effects
+        )
+
+        # Bench depth
+        ai_bench = snapshot.ai_healthy_bench_count
+        opp_bench = snapshot.opponent_healthy_bench_count
+        breakdown["bench_depth"] = (
+            (ai_bench - opp_bench) * self.weights.bench_depth
+        )
+
+        # Level differential
+        level_diff = (
+            snapshot.ai_active.level - snapshot.opponent_active.level
+        )
+        breakdown["level_diff"] = level_diff * self.weights.level_diff
+
+        # Fainted penalty
+        ai_fainted = snapshot.ai_total_fainted
+        opp_fainted = snapshot.opponent_total_fainted
+        breakdown["fainted_penalty"] = (
+            (opp_fainted - ai_fainted) * self.weights.fainted_penalty
+        )
+
+        total = sum(breakdown.values())
+
+        logger.debug(f"Evaluation breakdown: {breakdown}, total: {total}")
+        return EvalResult(total=total, breakdown=breakdown)
+
+    @staticmethod
+    def _type_advantage_score(
+        attacker_types: tuple[str, ...],
+        defender_types: tuple[str, ...],
+    ) -> float:
+        """
+        Compute type advantage score using element multiplier.
+        Returns a value centered around 0 (advantage positive,
+        disadvantage negative).
+        """
+        from tuxemon.element import Element
+
+        attack_elements = [Element.get(s) for s in attacker_types if s]
+        defend_elements = [Element.get(s) for s in defender_types if s]
+
+        if not attack_elements or not defend_elements:
+            return 0.0
+
+        multiplier = ElementTypesHandler.calculate_affinity_score(
+            attack_elements, defend_elements
+        )
+        # Center around 0: multiplier of 1.0 = neutral = 0
+        return multiplier - 1.0
