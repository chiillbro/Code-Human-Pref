+
+    def validate(self, update_style: bool = True) -> 'pygame_menu.validation.ValidationResult':
+        """
+        Run every attached validator against this Widget's current value and
+        return a structured result. All validators are checked (errors are
+        accumulated, not short-circuited).
+
+        If the Widget does not hold a value (:py:meth:`get_value` raises
+        ``ValueError``) validators receive ``None`` as the value.
+
+        When ``update_style`` is ``True`` (the default) a failing result
+        applies the validation-error border configured via
+        :py:meth:`set_validation_error_style`, and a passing result restores
+        the Widget's original border.
+
+        :param update_style: If ``True`` apply/clear the visual error border
+        :return: :py:class:`pygame_menu.validation.ValidationResult`
+        """
+        from pygame_menu.validation import ValidationResult
+
+        try:
+            value = self.get_value()
+        except ValueError:
+            value = None
+
+        errors: List[str] = []
+        for validator in self._validators:
+            msg = validator(value)
+            if msg is not None:
+                errors.append(msg)
+
+        result = ValidationResult(self, errors)
+
+        if update_style:
+            if result.valid:
+                self._clear_validation_error_style()
+            else:
+                self._apply_validation_error_style(errors)
+
+        return result
+
+    def _apply_validation_error_style(self, errors: List[str]) -> None:
+        """
+        Save the Widget's current border (once), apply the configured
+        validation-error border, and store the error messages so the inline
+        error text is drawn on subsequent :py:meth:`draw` calls.
+
+        :param errors: Error messages from the failed validation
+        """
+        if self._validation_saved_border is None:
+            self._validation_saved_border = (
+                self._border_color,
+                self._border_width,
+                self._border_position,
+                self._border_inflate
+            )
+        style = self._validation_error_style
+        if style['border_width'] > 0:
+            self.set_border(style['border_width'], style['border_color'], style['border_inflate'])
+        if errors != self._validation_errors:
+            self._validation_error_surface = None  # text changed; invalidate cache
+        self._validation_errors = list(errors)
+        self.force_menu_surface_cache_update()
+
+    def _clear_validation_error_style(self) -> None:
+        """
+        Restore the border that was active before the validation-error style
+        was applied and clear the inline error text. No-op if no error style is
+        currently active.
+        """
+        if self._validation_saved_border is None and not self._validation_errors:
+            return
+        if self._validation_saved_border is not None:
+            color, width, position, inflate = self._validation_saved_border
+            self._border_color = color
+            self._border_width = width
+            self._border_position = position
+            self._border_inflate = inflate
+            self._validation_saved_border = None
+        self._validation_errors = []
+        self._validation_error_surface = None
+        self.force_menu_surface_cache_update()
+
+    def _draw_validation_error(self, surface: 'pygame.Surface') -> None:
+        """
+        Draw the first validation-error message below the Widget. Called from
+        :py:meth:`draw` after the border is drawn. Uses the Widget's own font
+        family at the size configured via :py:meth:`set_validation_error_style`.
+
+        :param surface: Surface to draw on
+        """
+        if not self._validation_errors:
+            return
+        style = self._validation_error_style
+        if style['font_size'] == 0:
+            return
+        if self._validation_error_surface is None:
+            if not self._font_name:  # font not yet configured
+                return
+            err_font = pygame_menu.font.get_font(self._font_name, style['font_size'])
+            self._validation_error_surface = err_font.render(
+                self._validation_errors[0], self._font_antialias, style['font_color']
+            )
+        rect = self.get_rect()
+        surface.blit(
+            self._validation_error_surface,
+            (rect.x, rect.bottom + style['margin'])
+        )
+
