+    def validate(
+            self,
+            recursive: bool = False,
+            update_style: bool = True
+    ) -> 'pygame_menu.validation.MenuValidationResult':
+        """
+        Validate every Widget in this Menu that has at least one validator
+        attached (see :py:meth:`pygame_menu.widgets.core.widget.Widget.add_validator`).
+        Widgets without validators are skipped entirely.
+
+        The returned result is truthy only when **all** validated Widgets
+        passed::
+
+            result = menu.validate()
+            if result:
+                data = menu.get_input_data()
+            else:
+                for widget_id, errors in result.errors.items():
+                    print(widget_id, errors)
+
+        .. note::
+
+            This is applied only to the base Menu (not the currently displayed),
+            for such behaviour apply to :py:meth:`pygame_menu.menu.Menu.get_current` object.
+
+        :param recursive: If ``True`` also validate Widgets in sub-menus
+        :param update_style: If ``True`` apply/clear the visual error border on each Widget
+        :return: :py:class:`pygame_menu.validation.MenuValidationResult` keyed by Widget ID
+        """
+        from pygame_menu.validation import MenuValidationResult
+        assert isinstance(recursive, bool)
+        assert isinstance(update_style, bool)
+        return MenuValidationResult(self._validate(recursive, update_style, depth=0))
+
+    def _validate(
+            self,
+            recursive: bool,
+            update_style: bool,
+            depth: int
+    ) -> Dict[str, 'pygame_menu.validation.ValidationResult']:
+        """
+        Validate Widgets in this Menu and optionally sub-menus.
+
+        :param recursive: If ``True`` descend into sub-menus
+        :param update_style: Forwarded to each Widget's ``validate``
+        :param depth: Current recursion depth (for collision reporting)
+        :return: Mapping of Widget ID to per-widget result
+        """
+        results: Dict[str, Any] = {}
+        for widget in self._widgets:
+            if len(widget.get_validators()) == 0:
+                continue
+            results[widget.get_id()] = widget.validate(update_style=update_style)
+        if recursive:
+            depth += 1
+            for menu in self._submenus.keys():
+                # noinspection PyProtectedMember
+                sub_results = menu._validate(recursive, update_style, depth)
+                for key in sub_results.keys():
+                    if key in results:
+                        raise ValueError(
+                            f'collision between widget ID="{key}" at depth={depth}')
+                results.update(sub_results)
+        return results
+
