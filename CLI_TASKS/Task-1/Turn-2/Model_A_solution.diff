new file mode 100644
index 00000000..1863e438
--- /dev/null
+++ b/pygame_menu/validation.py
@@ -0,0 +1,261 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+VALIDATION
+Per-widget validation rules and result containers. Developers attach
+``Validator`` instances to widgets via ``Widget.add_validator`` and then
+call ``Widget.validate()`` or ``Menu.validate()`` to check all rules and
+receive a structured result.
+"""
+
+__all__ = [
+
+    # Result containers
+    'ValidationResult',
+    'MenuValidationResult',
+
+    # Base class
+    'Validator',
+
+    # Built-in validators
+    'Required',
+    'MinLength',
+    'MaxLength',
+    'Regex',
+    'NumericRange',
+    'Custom'
+
+]
+
+import re
+
+from abc import ABC, abstractmethod
+
+from pygame_menu._types import Any, Callable, Dict, List, NumberType, Optional
+
+
+# noinspection PyMissingOrEmptyDocstring
+class Validator(ABC):
+    """
+    Base class for widget validators. A validator is a callable that takes the
+    widget's current value and returns ``None`` when the value is acceptable
+    or an error message string when it is not.
+
+    Subclass and implement :py:meth:`__call__`, or use :py:class:`Custom` to
+    wrap an arbitrary callable.
+    """
+
+    @abstractmethod
+    def __call__(self, value: Any) -> Optional[str]:
+        """
+        Validate the given value.
+
+        :param value: Widget value to check
+        :return: ``None`` if valid, otherwise an error message string
+        """
+        raise NotImplementedError
+
+
+class Required(Validator):
+    """
+    Fails when the value is ``None``, an empty or whitespace-only string, or an
+    empty collection.
+
+    :param message: Error message returned on failure
+    """
+
+    def __init__(self, message: str = 'This field is required') -> None:
+        assert isinstance(message, str)
+        self._message = message
+
+    def __call__(self, value: Any) -> Optional[str]:
+        if value is None:
+            return self._message
+        if isinstance(value, str) and value.strip() == '':
+            return self._message
+        if hasattr(value, '__len__') and len(value) == 0:
+            return self._message
+        return None
+
+
+class MinLength(Validator):
+    """
+    Fails when the string representation of the value is shorter than the given
+    length. ``None`` values always fail.
+
+    :param length: Minimum number of characters (inclusive)
+    :param message: Error message returned on failure; a default is generated if not given
+    """
+
+    def __init__(self, length: int, message: Optional[str] = None) -> None:
+        assert isinstance(length, int) and length >= 0
+        self._length = length
+        self._message = message if message is not None else f'Must be at least {length} characters'
+
+    def __call__(self, value: Any) -> Optional[str]:
+        if value is None or len(str(value)) < self._length:
+            return self._message
+        return None
+
+
+class MaxLength(Validator):
+    """
+    Fails when the string representation of the value is longer than the given
+    length. ``None`` values pass (combine with :py:class:`Required` if needed).
+
+    :param length: Maximum number of characters (inclusive)
+    :param message: Error message returned on failure; a default is generated if not given
+    """
+
+    def __init__(self, length: int, message: Optional[str] = None) -> None:
+        assert isinstance(length, int) and length >= 0
+        self._length = length
+        self._message = message if message is not None else f'Must be at most {length} characters'
+
+    def __call__(self, value: Any) -> Optional[str]:
+        if value is not None and len(str(value)) > self._length:
+            return self._message
+        return None
+
+
+class Regex(Validator):
+    """
+    Fails when the string representation of the value does not match the given
+    regular expression against the **entire** input (using
+    :py:func:`re.fullmatch`). ``None`` values always fail.
+
+    :param pattern: Regular expression pattern string
+    :param message: Error message returned on failure; a default is generated if not given
+    """
+
+    def __init__(self, pattern: str, message: Optional[str] = None) -> None:
+        assert isinstance(pattern, str)
+        self._pattern = re.compile(pattern)
+        self._message = message if message is not None else f'Must match pattern {pattern}'
+
+    def __call__(self, value: Any) -> Optional[str]:
+        if value is None or not self._pattern.fullmatch(str(value)):
+            return self._message
+        return None
+
+
+class NumericRange(Validator):
+    """
+    Fails when the value (coerced to ``float``) falls outside the given
+    inclusive bounds. At least one of ``min_value`` or ``max_value`` must be
+    provided. Values that cannot be coerced to a number also fail.
+
+    :param min_value: Lower bound (inclusive), or ``None`` for no lower bound
+    :param max_value: Upper bound (inclusive), or ``None`` for no upper bound
+    :param message: Error message returned on failure; a default is generated if not given
+    """
+
+    def __init__(
+            self,
+            min_value: Optional[NumberType] = None,
+            max_value: Optional[NumberType] = None,
+            message: Optional[str] = None
+    ) -> None:
+        assert min_value is not None or max_value is not None, \
+            'at least one of min_value or max_value must be provided'
+        self._min = min_value
+        self._max = max_value
+        if message is not None:
+            self._message = message
+        elif min_value is not None and max_value is not None:
+            self._message = f'Must be between {min_value} and {max_value}'
+        elif min_value is not None:
+            self._message = f'Must be at least {min_value}'
+        else:
+            self._message = f'Must be at most {max_value}'
+
+    def __call__(self, value: Any) -> Optional[str]:
+        try:
+            num = float(value)
+        except (TypeError, ValueError):
+            return self._message
+        if self._min is not None and num < self._min:
+            return self._message
+        if self._max is not None and num > self._max:
+            return self._message
+        return None
+
+
+class Custom(Validator):
+    """
+    Wraps an arbitrary callable as a validator. The callable receives the
+    widget value and must return ``None`` on success or an error message string
+    on failure.
+
+    Example::
+
+        widget.add_validator(Custom(lambda v: None if v != 'admin' else 'Reserved name'))
+
+    :param func: Callable taking a value and returning ``None`` or an error string
+    """
+
+    def __init__(self, func: Callable[[Any], Optional[str]]) -> None:
+        assert callable(func)
+        self._func = func
+
+    def __call__(self, value: Any) -> Optional[str]:
+        return self._func(value)
+
+
+class ValidationResult(object):
+    """
+    Result of validating a single widget. Truthy when valid.
+
+    :param widget: Widget that was validated
+    :param errors: List of error message strings (empty when valid)
+    """
+
+    def __init__(self, widget: Any, errors: List[str]) -> None:
+        self.widget = widget
+        self.errors: List[str] = errors
+        self.valid: bool = len(errors) == 0
+
+    def __bool__(self) -> bool:
+        return self.valid
+
+    def __repr__(self) -> str:
+        return f'ValidationResult(valid={self.valid}, errors={self.errors})'
+
+
+class MenuValidationResult(object):
+    """
+    Aggregate result of validating every widget in a menu. Truthy only when
+    **all** widgets passed. Individual results are accessible by widget ID.
+
+    Example::
+
+        result = menu.validate()
+        if not result:
+            for widget_id, errors in result.errors.items():
+                print(widget_id, errors)
+
+    :param results: Mapping of widget ID to per-widget :py:class:`ValidationResult`
+    """
+
+    def __init__(self, results: Dict[str, ValidationResult]) -> None:
+        self.results: Dict[str, ValidationResult] = results
+        self.valid: bool = all(r.valid for r in results.values())
+        self.errors: Dict[str, List[str]] = {
+            wid: r.errors for wid, r in results.items() if not r.valid
+        }
+
+    def __bool__(self) -> bool:
+        return self.valid
+
+    def __getitem__(self, widget_id: str) -> ValidationResult:
+        return self.results[widget_id]
+
+    def __iter__(self):
+        return iter(self.results.values())
+
+    def __len__(self) -> int:
+        return len(self.results)
+
+    def __repr__(self) -> str:
+        return f'MenuValidationResult(valid={self.valid}, failed={list(self.errors.keys())})'
