+
+    def get_validators(self) -> Tuple['pygame_menu.validation.Validator', ...]:
+        """
+        Return the validators attached to this Widget.
+
+        :return: Tuple of validators in the order they will be checked
+        """
+        return tuple(self._validators)
+
+    def set_validation_error_style(
+            self,
+            border_width: int = 2,
+            border_color: ColorInputType = (255, 0, 0),
+            border_inflate: Tuple2IntType = (0, 0),
+            font_color: ColorInputType = (255, 0, 0),
+            font_size: int = 14,
+            margin: int = 2
+    ) -> 'Widget':
+        """
+        Configure how this Widget indicates a failed validation. The original
+        border is saved and restored automatically once the Widget passes
+        validation again. The inline error message is drawn below the Widget
+        using the Widget's own font family at the given ``font_size``.
+
+        .. note::
+
+            These values are normally populated from the Theme
+            (``widget_validation_error_*`` attributes) when the Widget is added
+            to a Menu; call this method only to override per-widget.
+
+        :param border_width: Error border width in px. ``0`` disables the error border
+        :param border_color: Error border color
+        :param border_inflate: Error border inflate (x, y) in px
+        :param font_color: Color of the inline error message text
+        :param font_size: Font size of the inline error message. ``0`` disables the message
+        :param margin: Vertical spacing in px between the Widget bottom edge and the error message
+        :return: Self reference
+        """
+        assert isinstance(border_width, int) and border_width >= 0
+        assert isinstance(font_size, int) and font_size >= 0
+        assert isinstance(margin, int) and margin >= 0
+        assert_vector(border_inflate, 2, int)
+        self._validation_error_style = {
+            'border_width': border_width,
+            'border_color': assert_color(border_color),
+            'border_inflate': border_inflate,
+            'font_color': assert_color(font_color),
+            'font_size': font_size,
+            'margin': margin
+        }
