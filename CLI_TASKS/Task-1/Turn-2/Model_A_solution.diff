new file mode 100644
index 00000000..ee998ea6
--- /dev/null
+++ b/test/test_validation.py
@@ -0,0 +1,817 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST VALIDATION
+Test the per-widget validation system: validators, Widget.validate,
+Menu.validate, and visual error indication.
+"""
+
+__all__ = ['ValidationTest']
+
+from test._utils import MenuUtils, BaseTest, surface
+
+import pygame_menu
+
+from pygame_menu.validation import Required, MinLength, MaxLength, Regex, \
+    NumericRange, Custom, ValidationResult, MenuValidationResult, Validator
+
+
+class ValidationTest(BaseTest):
+
+    # --------------------------------------------------------------------- #
+    # Individual validator behaviour
+    # --------------------------------------------------------------------- #
+
+    def test_required(self) -> None:
+        """
+        Test Required validator.
+        """
+        v = Required()
+        self.assertIsNone(v('hello'))
+        self.assertIsNone(v('  x  '))
+        self.assertIsNone(v(0))
+        self.assertIsNone(v(False))  # False is not "empty"
+        self.assertIsNone(v([1, 2]))
+
+        self.assertEqual(v(None), 'This field is required')
+        self.assertEqual(v(''), 'This field is required')
+        self.assertEqual(v('   '), 'This field is required')
+        self.assertEqual(v([]), 'This field is required')
+        self.assertEqual(v(()), 'This field is required')
+
+        # Custom message
+        v2 = Required('Name cannot be empty')
+        self.assertEqual(v2(''), 'Name cannot be empty')
+
+    def test_min_length(self) -> None:
+        """
+        Test MinLength validator.
+        """
+        v = MinLength(3)
+        self.assertIsNone(v('abc'))
+        self.assertIsNone(v('abcd'))
+        self.assertIsNone(v(123))  # str(123) == '123', length 3
+
+        self.assertEqual(v('ab'), 'Must be at least 3 characters')
+        self.assertEqual(v(''), 'Must be at least 3 characters')
+        self.assertEqual(v(None), 'Must be at least 3 characters')
+
+        # Custom message
+        v2 = MinLength(5, 'Too short!')
+        self.assertEqual(v2('abc'), 'Too short!')
+
+        # Zero length always passes non-None
+        v3 = MinLength(0)
+        self.assertIsNone(v3(''))
+
+    def test_max_length(self) -> None:
+        """
+        Test MaxLength validator.
+        """
+        v = MaxLength(5)
+        self.assertIsNone(v('abcde'))
+        self.assertIsNone(v('abc'))
+        self.assertIsNone(v(''))
+        self.assertIsNone(v(None))  # None passes max-length
+
+        self.assertEqual(v('abcdef'), 'Must be at most 5 characters')
+        self.assertEqual(v(123456), 'Must be at most 5 characters')
+
+        # Custom message
+        v2 = MaxLength(2, 'Too long!')
+        self.assertEqual(v2('abc'), 'Too long!')
+
+    def test_regex(self) -> None:
+        """
+        Test Regex validator.
+        """
+        v = Regex(r'^\d+$')
+        self.assertIsNone(v('123'))
+        self.assertIsNone(v('0'))
+        self.assertIsNone(v(456))  # str(456) matches
+
+        self.assertIsNotNone(v('abc'))
+        self.assertIsNotNone(v('12a'))
+        self.assertIsNotNone(v(''))
+        self.assertIsNotNone(v(None))
+
+        # Email-ish pattern with custom message
+        v2 = Regex(r'^[^@]+@[^@]+\.[^@]+$', 'Invalid email')
+        self.assertIsNone(v2('user@example.com'))
+        self.assertEqual(v2('not-an-email'), 'Invalid email')
+
+        # fullmatch semantics: pattern must match entire input, not just prefix
+        v3 = Regex(r'\d+')
+        self.assertIsNone(v3('123'))
+        self.assertIsNotNone(v3('123abc'))  # would falsely pass with re.match
+        self.assertIsNotNone(v3('abc123'))
+
+        v4 = Regex(r'[A-Z]{3}')
+        self.assertIsNone(v4('ABC'))
+        self.assertIsNotNone(v4('ABCD'))  # prefix matches but full input doesn't
+
+    def test_numeric_range(self) -> None:
+        """
+        Test NumericRange validator.
+        """
+        # Both bounds
+        v = NumericRange(min_value=0, max_value=100)
+        self.assertIsNone(v(0))
+        self.assertIsNone(v(50))
+        self.assertIsNone(v(100))
+        self.assertIsNone(v('50'))  # String coercion
+        self.assertIsNone(v(99.5))
+
+        self.assertEqual(v(-1), 'Must be between 0 and 100')
+        self.assertEqual(v(101), 'Must be between 0 and 100')
+        self.assertEqual(v('abc'), 'Must be between 0 and 100')
+        self.assertEqual(v(None), 'Must be between 0 and 100')
+
+        # Min only
+        v_min = NumericRange(min_value=10)
+        self.assertIsNone(v_min(10))
+        self.assertIsNone(v_min(1000))
+        self.assertEqual(v_min(9), 'Must be at least 10')
+
+        # Max only
+        v_max = NumericRange(max_value=5)
+        self.assertIsNone(v_max(5))
+        self.assertIsNone(v_max(-100))
+        self.assertEqual(v_max(6), 'Must be at most 5')
+
+        # Custom message
+        v_custom = NumericRange(min_value=1, max_value=10, message='Out of range')
+        self.assertEqual(v_custom(0), 'Out of range')
+
+        # Must provide at least one bound
+        self.assertRaises(AssertionError, lambda: NumericRange())
+
+    def test_custom(self) -> None:
+        """
+        Test Custom validator wrapper.
+        """
+        v = Custom(lambda val: None if val != 'admin' else 'Reserved name')
+        self.assertIsNone(v('alice'))
+        self.assertIsNone(v('bob'))
+        self.assertEqual(v('admin'), 'Reserved name')
+
+        # Non-callable rejected
+        self.assertRaises(AssertionError, lambda: Custom('not callable'))
+
+    # --------------------------------------------------------------------- #
+    # Result containers
+    # --------------------------------------------------------------------- #
+
+    def test_validation_result(self) -> None:
+        """
+        Test ValidationResult container.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Name: ')
+
+        # Valid result
+        r_ok = ValidationResult(w, [])
+        self.assertTrue(r_ok.valid)
+        self.assertTrue(bool(r_ok))
+        self.assertTrue(r_ok)
