+    # noinspection PyTypeChecker
+    def test_inline_error_text(self) -> None:
+        """
+        Failing validation stores error messages; draw() renders them below
+        the widget; passing validation clears them.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Name: ')
+        w.add_validator(Required('Name is required'))
+
+        # Before validate: no errors stored
+        self.assertEqual(w._validation_errors, [])
+        self.assertIsNone(w._validation_error_surface)
+
+        # Fail -> errors stored
+        w.validate()
+        self.assertEqual(w._validation_errors, ['Name is required'])
+
+        # Drawing should render the error surface and cache it
+        w.draw(surface)
+        self.assertIsNotNone(w._validation_error_surface)
+        self.assertGreater(w._validation_error_surface.get_width(), 0)
+        cached = w._validation_error_surface
+
+        # Re-draw reuses cache
+        w.draw(surface)
+        self.assertIs(w._validation_error_surface, cached)
+
+        # Error message changes -> cache invalidated
+        w.clear_validators()
+        w.add_validator(MinLength(5, 'Too short'))
+        w.set_value('ab')
+        w.validate()
+        self.assertEqual(w._validation_errors, ['Too short'])
+        self.assertIsNone(w._validation_error_surface)  # invalidated
+        w.draw(surface)
+        self.assertIsNot(w._validation_error_surface, cached)
+
+        # Pass -> errors + surface cleared
+        w.set_value('alice')
+        w.validate()
+        self.assertEqual(w._validation_errors, [])
+        self.assertIsNone(w._validation_error_surface)
+        w.draw(surface)  # no crash
+
