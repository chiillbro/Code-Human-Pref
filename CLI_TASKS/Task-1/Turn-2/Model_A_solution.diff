+            assert callable(v), \
+                f'validator must be callable, got {type(v).__name__}'
+            self._validators.append(v)
+        return self
+
+    def clear_validators(self) -> 'Widget':
+        """
+        Remove every validator previously attached to this Widget and clear any
+        active validation-error border.
+
+        :return: Self reference
+        """
+        self._validators = []
+        self._clear_validation_error_style()
