+    # noinspection PyTypeChecker
+    def test_inline_error_text_shown(self) -> None:
+        """
+        Failing validation adds a decorator for inline error text.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Name: ')
+        w.add_validator(Required())
+
+        self.assertIsNone(w._validation_error_decorator_id)
+
+        # Fail -> decorator added
+        w.validate()
+        self.assertIsNotNone(w._validation_error_decorator_id)
+
+        # Draw shouldn't crash
+        w.draw(surface)
+
+        # Pass -> decorator removed
+        w.set_value('ok')
+        w.validate()
+        self.assertIsNone(w._validation_error_decorator_id)
+
+    # noinspection PyTypeChecker
+    def test_inline_error_text_updated(self) -> None:
+        """
+        Successive validations update the error text rather than stacking.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Name: ')
+        w.add_validator(Required(), MinLength(5))
+
+        w.validate()
+        first_id = w._validation_error_decorator_id
+        self.assertIsNotNone(first_id)
+
+        # Validate again -> old decorator replaced
+        w.set_value('ab')
+        w.validate()
+        second_id = w._validation_error_decorator_id
+        self.assertIsNotNone(second_id)
+        self.assertNotEqual(first_id, second_id)
+
