+    # noinspection PyTypeChecker
+    def test_menu_validate_mixed(self) -> None:
+        """
+        Only widgets with validators participate; result aggregates correctly.
+        """
+        menu = MenuUtils.generic_menu()
+        w_name = menu.add.text_input('Name: ', textinput_id='name')
+        w_name.add_validator(Required())
+
+        w_age = menu.add.text_input('Age: ', textinput_id='age',
+                                    input_type=pygame_menu.locals.INPUT_INT)
+        w_age.add_validator(NumericRange(min_value=1, max_value=120))
+
+        menu.add.text_input('Optional: ', textinput_id='opt')  # No validators
+
+        # Both fail initially
+        r = menu.validate()
+        self.assertFalse(r)
+        self.assertEqual(len(r), 2)  # Only widgets with validators
+        self.assertIn('name', r.errors)
+        self.assertIn('age', r.errors)
+        self.assertNotIn('opt', r.results)
+
+        # Visual error applied to both
+        self.assertEqual(w_name._border_width, 2)
+        self.assertEqual(w_age._border_width, 2)
+
+        # Fix name only
+        w_name.set_value('Alice')
+        r = menu.validate()
+        self.assertFalse(r)
+        self.assertEqual(len(r.errors), 1)
+        self.assertIn('age', r.errors)
+        self.assertNotIn('name', r.errors)
+
+        # Name border cleared, age still red
+        self.assertEqual(w_name._border_width, 0)
+        self.assertEqual(w_age._border_width, 2)
+
+        # Fix age too
+        w_age.set_value(30)
+        r = menu.validate()
+        self.assertTrue(r)
+        self.assertEqual(r.errors, {})
+        self.assertTrue(r['name'])
+        self.assertTrue(r['age'])
