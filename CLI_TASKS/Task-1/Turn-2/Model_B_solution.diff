+    def test_menu_validate_recursive(self) -> None:
+        """
+        recursive=True validates widgets in submenus.
+        """
+        menu = MenuUtils.generic_menu()
+        menu.add.text_input('Main: ', textinput_id='main').add_validator(Required())
+
+        sub = MenuUtils.generic_menu()
+        sub.add.text_input('Sub: ', textinput_id='sub').add_validator(Required())
+        menu.add.button('go to sub', sub)
+
+        # Non-recursive: only main
+        r = menu.validate(recursive=False)
+        self.assertEqual(len(r), 1)
+        self.assertIn('main', r.results)
+        self.assertNotIn('sub', r.results)
+
+        # Recursive: both
+        r = menu.validate(recursive=True)
+        self.assertEqual(len(r), 2)
+        self.assertIn('main', r.results)
+        self.assertIn('sub', r.results)
+        self.assertFalse(r)  # Both empty -> both fail
+
+    def test_menu_validate_recursive_collision(self) -> None:
+        """
+        Duplicate widget IDs across submenus raise ValueError.
+        """
+        menu = MenuUtils.generic_menu()
+        menu.add.text_input('A: ', textinput_id='dup').add_validator(Required())
+
+        sub = MenuUtils.generic_menu()
+        sub.add.text_input('B: ', textinput_id='dup').add_validator(Required())
+        menu.add.button('sub', sub)
+
+        self.assertRaises(ValueError, lambda: menu.validate(recursive=True))
