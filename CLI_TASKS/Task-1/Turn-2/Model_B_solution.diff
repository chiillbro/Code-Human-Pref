+    # --------------------------------------------------------------------- #
+
+    def test_required(self) -> None:
+        """
+        Test Required validator.
+        """
+        v = Required()
+        self.assertIsNone(v('hello'))
+        self.assertIsNone(v('  x  '))
+        self.assertIsNone(v(0))
+        self.assertIsNone(v(False))  # False is not "empty"
+        self.assertIsNone(v([1, 2]))
+
+        self.assertEqual(v(None), 'This field is required')
+        self.assertEqual(v(''), 'This field is required')
+        self.assertEqual(v('   '), 'This field is required')
+        self.assertEqual(v([]), 'This field is required')
+        self.assertEqual(v(()), 'This field is required')
+
+        # Custom message
+        v2 = Required('Name cannot be empty')
+        self.assertEqual(v2(''), 'Name cannot be empty')
+
+    def test_min_length(self) -> None:
+        """
+        Test MinLength validator.
+        """
+        v = MinLength(3)
+        self.assertIsNone(v('abc'))
+        self.assertIsNone(v('abcd'))
+        self.assertIsNone(v(123))  # str(123) == '123', length 3
+
+        self.assertEqual(v('ab'), 'Must be at least 3 characters')
+        self.assertEqual(v(''), 'Must be at least 3 characters')
+        self.assertEqual(v(None), 'Must be at least 3 characters')
+
+        # Custom message
+        v2 = MinLength(5, 'Too short!')
+        self.assertEqual(v2('abc'), 'Too short!')
+
+        # Zero length always passes non-None
+        v3 = MinLength(0)
+        self.assertIsNone(v3(''))
+
+    def test_max_length(self) -> None:
+        """
+        Test MaxLength validator.
+        """
+        v = MaxLength(5)
+        self.assertIsNone(v('abcde'))
+        self.assertIsNone(v('abc'))
+        self.assertIsNone(v(''))
+        self.assertIsNone(v(None))  # None passes max-length
+
+        self.assertEqual(v('abcdef'), 'Must be at most 5 characters')
+        self.assertEqual(v(123456), 'Must be at most 5 characters')
+
+        # Custom message
+        v2 = MaxLength(2, 'Too long!')
+        self.assertEqual(v2('abc'), 'Too long!')
+
+    def test_regex(self) -> None:
+        """
+        Test Regex validator (uses re.fullmatch, whole string must match).
+        """
+        v = Regex(r'^\d+$')
+        self.assertIsNone(v('123'))
+        self.assertIsNone(v('0'))
+        self.assertIsNone(v(456))  # str(456) matches
+
+        self.assertIsNotNone(v('abc'))
+        self.assertIsNotNone(v('12a'))
+        self.assertIsNotNone(v(''))
+        self.assertIsNotNone(v(None))
+
+        # fullmatch: pattern without anchors still matches the entire string
+        v_no_anchors = Regex(r'\d+')
+        self.assertIsNone(v_no_anchors('123'))
+        self.assertIsNotNone(v_no_anchors('123abc'))  # would pass with re.match
+        self.assertIsNotNone(v_no_anchors('abc123'))
+
+        # Email-ish pattern with custom message
+        v2 = Regex(r'^[^@]+@[^@]+\.[^@]+$', 'Invalid email')
+        self.assertIsNone(v2('user@example.com'))
