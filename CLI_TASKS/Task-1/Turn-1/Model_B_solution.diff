@@ -0,0 +1,578 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST VALIDATION
+Tests for the widget validation system.
+"""
+
+from test._utils import *
+import pygame_menu
+
+from pygame_menu.validation import (
+    ValidationRule,
+    RequiredRule,
+    MinLengthRule,
+    MaxLengthRule,
+    RegexRule,
+    NumericRangeRule,
+    ValidationResult,
+    ValidationError
+)
+
+
+class ValidationRuleTest(BaseTest):
+    """
+    Tests for individual validation rules.
+    """
+
+    def test_required_rule(self) -> None:
+        """
+        Test RequiredRule.
+        """
+        rule = RequiredRule()
+        self.assertEqual(rule.name, 'required')
+
+        # Empty string fails
+        valid, msg = rule.validate('')
+        self.assertFalse(valid)
+        self.assertNotEqual(msg, '')
+
+        # Whitespace-only fails
+        valid, msg = rule.validate('   ')
+        self.assertFalse(valid)
+
+        # None fails
+        valid, msg = rule.validate(None)
+        self.assertFalse(valid)
+
+        # Non-empty passes
+        valid, msg = rule.validate('hello')
+        self.assertTrue(valid)
+        self.assertEqual(msg, '')
+
+        # Number passes
+        valid, msg = rule.validate(42)
+        self.assertTrue(valid)
+
+        # Custom message
+        rule2 = RequiredRule(message='Field cannot be blank')
+        valid, msg = rule2.validate('')
+        self.assertFalse(valid)
+        self.assertEqual(msg, 'Field cannot be blank')
+
+    def test_min_length_rule(self) -> None:
+        """
+        Test MinLengthRule.
+        """
+        rule = MinLengthRule(3)
+        self.assertEqual(rule.name, 'min_length')
+
+        # Too short
+        valid, msg = rule.validate('ab')
+        self.assertFalse(valid)
+
+        # Exact length
+        valid, msg = rule.validate('abc')
+        self.assertTrue(valid)
+
+        # Longer than min
+        valid, msg = rule.validate('abcdef')
+        self.assertTrue(valid)
+
+        # Empty with min 0
+        rule0 = MinLengthRule(0)
+        valid, msg = rule0.validate('')
+        self.assertTrue(valid)
+
+        # None treated as empty string
+        valid, msg = rule.validate(None)
+        self.assertFalse(valid)
+
+        # Custom message
+        rule2 = MinLengthRule(5, message='Too short!')
+        valid, msg = rule2.validate('ab')
+        self.assertEqual(msg, 'Too short!')
+
+    def test_max_length_rule(self) -> None:
+        """
+        Test MaxLengthRule.
+        """
+        rule = MaxLengthRule(5)
+        self.assertEqual(rule.name, 'max_length')
+
+        # Within limit
+        valid, msg = rule.validate('abc')
+        self.assertTrue(valid)
+
+        # Exact limit
+        valid, msg = rule.validate('abcde')
+        self.assertTrue(valid)
+
+        # Over limit
+        valid, msg = rule.validate('abcdef')
+        self.assertFalse(valid)
+
+        # Custom message
+        rule2 = MaxLengthRule(3, message='Too long!')
+        valid, msg = rule2.validate('abcd')
+        self.assertEqual(msg, 'Too long!')
+
+    def test_regex_rule(self) -> None:
+        """
+        Test RegexRule.
+        """
+        # Email-like pattern
+        rule = RegexRule(r'[^@]+@[^@]+\.[^@]+')
+        self.assertEqual(rule.name, 'regex')
+
+        valid, msg = rule.validate('user@example.com')
+        self.assertTrue(valid)
+
+        valid, msg = rule.validate('not-an-email')
+        self.assertFalse(valid)
+
+        # Alphanumeric pattern
+        rule2 = RegexRule(r'[a-zA-Z0-9]+', message='Alphanumeric only')
+        valid, msg = rule2.validate('hello123')
+        self.assertTrue(valid)
+
+        valid, msg = rule2.validate('hello world')
+        self.assertFalse(valid)
+        self.assertEqual(msg, 'Alphanumeric only')
+
+        # None treated as empty string
+        valid, msg = rule2.validate(None)
+        self.assertFalse(valid)
+
+    def test_numeric_range_rule(self) -> None:
+        """
+        Test NumericRangeRule.
+        """
+        rule = NumericRangeRule(min_value=0, max_value=100)
+        self.assertEqual(rule.name, 'numeric_range')
+
+        # Within range
+        valid, msg = rule.validate(50)
+        self.assertTrue(valid)
+
+        # At boundaries
+        valid, msg = rule.validate(0)
+        self.assertTrue(valid)
+        valid, msg = rule.validate(100)
+        self.assertTrue(valid)
+
+        # Below range
+        valid, msg = rule.validate(-1)
+        self.assertFalse(valid)
+
+        # Above range
+        valid, msg = rule.validate(101)
+        self.assertFalse(valid)
+
+        # String number
+        valid, msg = rule.validate('50')
+        self.assertTrue(valid)
+
+        # Non-numeric
+        valid, msg = rule.validate('abc')
+        self.assertFalse(valid)
+
+        # Min only
+        rule_min = NumericRangeRule(min_value=10)
+        valid, msg = rule_min.validate(5)
+        self.assertFalse(valid)
+        valid, msg = rule_min.validate(15)
+        self.assertTrue(valid)
+
+        # Max only
+        rule_max = NumericRangeRule(max_value=10)
+        valid, msg = rule_max.validate(5)
+        self.assertTrue(valid)
+        valid, msg = rule_max.validate(15)
+        self.assertFalse(valid)
+
+        # Float values
+        valid, msg = rule.validate(50.5)
+        self.assertTrue(valid)
+
+        # Custom message
+        rule2 = NumericRangeRule(min_value=0, max_value=10, message='Out of range')
+        valid, msg = rule2.validate(20)
+        self.assertEqual(msg, 'Out of range')
+
+    def test_numeric_range_rule_bad_args(self) -> None:
+        """
+        Test NumericRangeRule rejects min > max.
+        """
+        with self.assertRaises(AssertionError):
+            NumericRangeRule(min_value=10, max_value=5)
+
+
+class ValidationResultTest(BaseTest):
+    """
+    Tests for ValidationResult and ValidationError.
+    """
+
+    def test_valid_result(self) -> None:
+        """
+        Test that empty errors means valid.
+        """
+        result = ValidationResult()
+        self.assertTrue(result.valid)
+        self.assertTrue(bool(result))
+        self.assertEqual(len(result.errors), 0)
+
+    def test_invalid_result(self) -> None:
+        """
+        Test result with errors.
+        """
+        errors = [
+            ValidationError(rule='required', message='This field is required', widget_id='name'),
+            ValidationError(rule='min_length', message='Too short', widget_id='name')
+        ]
+        result = ValidationResult(errors)
+        self.assertFalse(result.valid)
+        self.assertFalse(bool(result))
+        self.assertEqual(len(result.errors), 2)
+        self.assertEqual(result.errors[0].rule, 'required')
+        self.assertEqual(result.errors[0].widget_id, 'name')
+
+    def test_validation_error_repr(self) -> None:
+        """
+        Test ValidationError repr.
+        """
+        err = ValidationError(rule='required', message='Required', widget_id='w1')
+        self.assertIn('required', repr(err))
+        self.assertIn('w1', repr(err))
+
+
+class WidgetValidationTest(BaseRSTest):
+    """
+    Tests for validation methods on widgets.
+    """
+
+    def test_add_and_clear_validation(self) -> None:
+        """
+        Test adding and clearing validation rules on a widget.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Name: ', textinput_id='name')
+
+        # No rules initially
+        result = w.validate()
+        self.assertTrue(result.valid)
+
+        # Add a rule
+        ret = w.add_validation(RequiredRule())
+        self.assertIs(ret, w)  # Returns self for chaining
+
+        # Validate empty input
+        result = w.validate()
+        self.assertFalse(result.valid)
+        self.assertEqual(len(result.errors), 1)
+        self.assertEqual(result.errors[0].rule, 'required')
+
+        # Set a value and validate again
+        w.set_value('John')
+        result = w.validate()
+        self.assertTrue(result.valid)
+
+        # Clear rules
+        w.clear_validation()
+        result = w.validate()
+        self.assertTrue(result.valid)
+
+    def test_multiple_rules(self) -> None:
+        """
+        Test multiple rules on one widget.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Username: ', textinput_id='username')
+
+        w.add_validation(RequiredRule())
+        w.add_validation(MinLengthRule(3))
+        w.add_validation(MaxLengthRule(20))
+        w.add_validation(RegexRule(r'[a-zA-Z0-9_]+', message='Alphanumeric and underscores only'))
+
+        # Empty fails required and min_length
+        result = w.validate()
+        self.assertFalse(result.valid)
+        rule_names = [e.rule for e in result.errors]
+        self.assertIn('required', rule_names)
+        self.assertIn('min_length', rule_names)
+
+        # Short input
+        w.set_value('ab')
+        result = w.validate()
+        self.assertFalse(result.valid)
+        rule_names = [e.rule for e in result.errors]
+        self.assertIn('min_length', rule_names)
+
+        # Invalid characters
+        w.set_value('hello world')
+        result = w.validate()
+        self.assertFalse(result.valid)
+        rule_names = [e.rule for e in result.errors]
+        self.assertIn('regex', rule_names)
+
+        # Valid input
+        w.set_value('valid_user')
+        result = w.validate()
+        self.assertTrue(result.valid)
+
+    def test_remove_validation_by_type(self) -> None:
