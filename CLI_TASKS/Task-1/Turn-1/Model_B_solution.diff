+    def test_validation_errors_state(self) -> None:
+        """
+        Test that validation errors are stored and can be cleared.
+        """
+        menu = MenuUtils.generic_menu()
+        w = menu.add.text_input('Name: ', textinput_id='name')
+        w.add_validation(RequiredRule())
+
+        # No errors initially
+        self.assertEqual(len(w.get_validation_errors()), 0)
+
+        # Validate populates errors
+        w.validate()
+        errors = w.get_validation_errors()
+        self.assertEqual(len(errors), 1)
+
+        # Clear errors without removing rules
+        w.clear_validation_errors()
+        self.assertEqual(len(w.get_validation_errors()), 0)
+
+        # Rules still in place
+        w.validate()
+        self.assertEqual(len(w.get_validation_errors()), 1)
