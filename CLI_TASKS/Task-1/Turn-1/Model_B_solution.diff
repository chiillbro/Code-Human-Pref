         """
         raise ValueError(f'{self.get_class_id()} does not accept value')
 
+    def add_validation(self, rule: 'pygame_menu.validation.ValidationRule') -> 'Widget':
+        """
+        Attach a validation rule to this widget. Rules are checked when
+        :py:meth:`validate` is called.
+
+        :param rule: Validation rule instance
+        :return: Self reference
+        """
+        from pygame_menu.validation import ValidationRule
+        assert isinstance(rule, ValidationRule), 'rule must be a ValidationRule instance'
+        self._validation_rules.append(rule)
+        return self
+
+    def remove_validation(self, rule_type: type) -> 'Widget':
+        """
+        Remove all validation rules of the given type.
+
+        :param rule_type: The class of rules to remove (e.g. ``RequiredRule``)
+        :return: Self reference
+        """
+        self._validation_rules = [r for r in self._validation_rules if not isinstance(r, rule_type)]
+        return self
+
+    def clear_validation(self) -> 'Widget':
+        """
+        Remove all validation rules from this widget.
+
+        :return: Self reference
+        """
+        self._validation_rules.clear()
+        self._validation_errors.clear()
+        return self
+
+    def validate(self) -> 'pygame_menu.validation.ValidationResult':
+        """
+        Run all attached validation rules against the current widget value.
+        Stores error messages internally for visual display and returns a
+        structured :py:class:`pygame_menu.validation.ValidationResult`.
+
+        :return: Validation result with ``valid`` flag and ``errors`` list
+        """
+        from pygame_menu.validation import ValidationResult, ValidationError
+        self._validation_errors.clear()
+        errors = []
+
+        if not self._validation_rules:
+            return ValidationResult()
+
+        try:
+            value = self.get_value()
+        except ValueError:
+            value = None
+
+        widget_id = self.get_id()
+        for rule in self._validation_rules:
+            is_valid, msg = rule.validate(value)
+            if not is_valid:
+                errors.append(ValidationError(
+                    rule=rule.name,
+                    message=msg,
+                    widget_id=widget_id
+                ))
+                self._validation_errors.append(msg)
+
+        return ValidationResult(errors)
+
+    def clear_validation_errors(self) -> 'Widget':
+        """
+        Clear the current validation error state without removing rules.
+
+        :return: Self reference
+        """
+        self._validation_errors.clear()
+        return self
+
+    def get_validation_errors(self) -> List[str]:
+        """
+        Return the list of current validation error messages.
+
+        :return: List of error message strings
+        """
+        return list(self._validation_errors)
+
+    def set_validation_error_color(self, color: ColorInputType) -> 'Widget':
+        """
+        Set the color used for the validation error border and text.
+
+        :param color: Error color
+        :return: Self reference
+        """
+        self._validation_error_color = assert_color(color)
+        return self
+
+    def _draw_validation_error(self, surface: 'pygame.Surface') -> None:
+        """
+        Draw validation error indicator: a red border and error text below the widget.
+
+        :param surface: Surface to draw on
+        """
+        if not self._validation_errors:
+            return
+
+        rect = self.get_rect(inflate=self._get_background_inflate())
+        color = self._validation_error_color
+
+        # Draw error border around widget
+        pygame.draw.rect(surface, color, rect, 2)
+
+        # Render the first error message below the widget
+        if self._font is not None:
+            error_font_size = max(self._font_size - 4, 10)
+            try:
+                error_font = pygame.font.Font(self._font_name, error_font_size)
+            except Exception:
+                error_font = pygame.font.SysFont('', error_font_size)
+            error_surface = error_font.render(self._validation_errors[0], True, color)
+            error_x = rect.x
+            error_y = rect.bottom + 2
+            surface.blit(error_surface, (error_x, error_y))
+
