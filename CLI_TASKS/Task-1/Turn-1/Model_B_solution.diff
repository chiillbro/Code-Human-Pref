index 00000000..8da9a382
--- /dev/null
+++ b/pygame_menu/validation.py
@@ -0,0 +1,212 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+VALIDATION
+Per-widget validation system with built-in rules for required fields,
+min/max length, regex pattern matching, and numeric range checks.
+"""
+
+__all__ = [
+    'ValidationRule',
+    'RequiredRule',
+    'MinLengthRule',
+    'MaxLengthRule',
+    'RegexRule',
+    'NumericRangeRule',
+    'ValidationResult',
+    'ValidationError'
+]
+
+import re
+
+from pygame_menu._types import Optional, List, Any, Union
+
+
+class ValidationError:
+    """
+    Represents a single validation failure.
+    """
+
+    def __init__(self, rule: str, message: str, widget_id: str = '') -> None:
+        """
+        :param rule: Rule name that failed (e.g. ``'required'``, ``'min_length'``)
+        :param message: Human-readable error message
+        :param widget_id: ID of the widget that failed validation
+        """
+        self.rule = rule
+        self.message = message
+        self.widget_id = widget_id
+
+    def __repr__(self) -> str:
+        return f'ValidationError(rule={self.rule!r}, message={self.message!r}, widget_id={self.widget_id!r})'
+
+
+class ValidationResult:
+    """
+    Structured result from validating one or more widgets.
+    """
+
+    def __init__(self, errors: Optional[List[ValidationError]] = None) -> None:
+        """
+        :param errors: List of validation errors. Empty list means valid.
+        """
+        self.errors: List[ValidationError] = errors if errors is not None else []
+
+    @property
+    def valid(self) -> bool:
+        """Return ``True`` if there are no validation errors."""
+        return len(self.errors) == 0
+
+    def __repr__(self) -> str:
+        return f'ValidationResult(valid={self.valid}, errors={self.errors})'
+
+    def __bool__(self) -> bool:
+        return self.valid
+
+
+class ValidationRule:
+    """
+    Base class for validation rules. Subclass this to create custom rules.
+    """
+    name: str = 'base'
+
+    def validate(self, value: Any) -> 'tuple[bool, str]':
+        """
+        Validate a value.
+
+        :param value: The value to validate
+        :return: Tuple of (is_valid, error_message). error_message is empty string if valid.
+        """
+        raise NotImplementedError('subclasses must implement validate()')
+
+    def __repr__(self) -> str:
+        return f'{self.__class__.__name__}()'
+
+
+class RequiredRule(ValidationRule):
+    """
+    Validates that the widget value is not empty or None.
+    """
+    name = 'required'
+
+    def __init__(self, message: str = 'This field is required') -> None:
+        """
+        :param message: Custom error message
+        """
+        self._message = message
+
+    def validate(self, value: Any) -> 'tuple[bool, str]':
+        if value is None:
+            return False, self._message
+        if isinstance(value, str) and value.strip() == '':
+            return False, self._message
+        return True, ''
+
+
+class MinLengthRule(ValidationRule):
+    """
+    Validates that the string value length is at least ``min_length``.
+    """
+    name = 'min_length'
+
+    def __init__(self, min_length: int, message: str = '') -> None:
+        """
+        :param min_length: Minimum required length
+        :param message: Custom error message. If empty, a default is generated.
+        """
+        assert isinstance(min_length, int) and min_length >= 0
+        self._min_length = min_length
+        self._message = message
+
+    def validate(self, value: Any) -> 'tuple[bool, str]':
+        text = str(value) if value is not None else ''
+        if len(text) < self._min_length:
+            msg = self._message or f'Must be at least {self._min_length} characters'
+            return False, msg
+        return True, ''
+
+
+class MaxLengthRule(ValidationRule):
+    """
+    Validates that the string value length is at most ``max_length``.
+    """
+    name = 'max_length'
+
+    def __init__(self, max_length: int, message: str = '') -> None:
+        """
+        :param max_length: Maximum allowed length
+        :param message: Custom error message. If empty, a default is generated.
+        """
+        assert isinstance(max_length, int) and max_length >= 0
+        self._max_length = max_length
+        self._message = message
+
+    def validate(self, value: Any) -> 'tuple[bool, str]':
+        text = str(value) if value is not None else ''
+        if len(text) > self._max_length:
+            msg = self._message or f'Must be at most {self._max_length} characters'
+            return False, msg
+        return True, ''
+
+
+class RegexRule(ValidationRule):
+    """
+    Validates that the string value matches a regular expression pattern.
+    """
+    name = 'regex'
+
+    def __init__(self, pattern: str, message: str = '') -> None:
+        """
+        :param pattern: Regular expression pattern (must fully match)
+        :param message: Custom error message. If empty, a default is generated.
+        """
+        self._pattern = re.compile(pattern)
+        self._message = message
+
+    def validate(self, value: Any) -> 'tuple[bool, str]':
+        text = str(value) if value is not None else ''
+        if not self._pattern.fullmatch(text):
+            msg = self._message or f'Does not match required pattern'
+            return False, msg
+        return True, ''
+
+
+class NumericRangeRule(ValidationRule):
+    """
+    Validates that the numeric value falls within [min_value, max_value].
+    Either bound can be ``None`` to skip that check.
+    """
+    name = 'numeric_range'
+
+    def __init__(
+            self,
+            min_value: Optional[Union[int, float]] = None,
+            max_value: Optional[Union[int, float]] = None,
+            message: str = ''
+    ) -> None:
+        """
+        :param min_value: Minimum allowed value (inclusive), or ``None`` for no minimum
+        :param max_value: Maximum allowed value (inclusive), or ``None`` for no maximum
+        :param message: Custom error message. If empty, a default is generated.
+        """
+        if min_value is not None and max_value is not None:
+            assert min_value <= max_value, 'min_value must be <= max_value'
+        self._min_value = min_value
+        self._max_value = max_value
+        self._message = message
+
+    def validate(self, value: Any) -> 'tuple[bool, str]':
+        try:
+            num = float(value)
+        except (TypeError, ValueError):
+            msg = self._message or 'Must be a valid number'
+            return False, msg
+
+        if self._min_value is not None and num < self._min_value:
+            msg = self._message or f'Must be at least {self._min_value}'
+            return False, msg
+        if self._max_value is not None and num > self._max_value:
+            msg = self._message or f'Must be at most {self._max_value}'
+            return False, msg
+        return True, ''
