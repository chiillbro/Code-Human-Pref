+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+TEST WIDGET - VALIDATION
+Test WidgetValidator, built-in rule factories, widget integration, and
+Menu-level form validation.
+"""
+
+__all__ = ['ValidationWidgetTest']
+
+from test._utils import MenuUtils, surface, BaseTest
+
+import pygame_menu
+
+from pygame_menu.widgets.core.validation import (
+    WidgetValidator,
+    required,
+    min_length,
+    max_length,
+    matches_pattern,
+    in_range,
+)
+
+
+class ValidationWidgetTest(BaseTest):
+
+    # ------------------------------------------------------------------
+    # WidgetValidator core
+    # ------------------------------------------------------------------
+
+    def test_validator_empty(self) -> None:
+        """A validator with no rules always passes."""
+        v = WidgetValidator()
+        self.assertFalse(v.has_rules())
+        self.assertEqual(v.validate('anything'), [])
+        self.assertTrue(v.is_valid('anything'))
+
+    def test_validator_add_rule(self) -> None:
+        """Rules can be added and are executed."""
+        v = WidgetValidator()
+        v.add_rule(lambda val: val == 'ok', 'not ok')
+        self.assertTrue(v.has_rules())
+        self.assertEqual(v.validate('ok'), [])
+        self.assertEqual(v.validate('bad'), ['not ok'])
+
+    def test_validator_chaining(self) -> None:
+        """add_rule returns self for chaining."""
+        v = WidgetValidator()
+        ret = v.add_rule(lambda val: True, 'a').add_rule(lambda val: True, 'b')
+        self.assertIs(ret, v)
+        self.assertEqual(len(v._rules), 2)
+
+    def test_validator_multiple_errors(self) -> None:
+        """All failing rules produce errors, not just the first."""
+        v = WidgetValidator()
+        v.add_rule(lambda val: False, 'err1')
+        v.add_rule(lambda val: False, 'err2')
+        errors = v.validate('x')
+        self.assertEqual(errors, ['err1', 'err2'])
+
+    def test_validator_clear_rules(self) -> None:
+        """clear_rules removes everything."""
+        v = WidgetValidator()
+        v.add_rule(lambda val: False, 'e')
+        v.clear_rules()
+        self.assertFalse(v.has_rules())
+        self.assertEqual(v.validate('x'), [])
+
+    def test_validator_predicate_exception(self) -> None:
+        """If a predicate raises, the value is treated as invalid."""
+        def bad_pred(val):
+            raise TypeError('boom')
+
+        v = WidgetValidator()
+        v.add_rule(bad_pred, 'type error')
+        self.assertEqual(v.validate('x'), ['type error'])
+
+    def test_validator_invalid_args(self) -> None:
+        """Non-callable predicate or empty message raise AssertionError."""
+        v = WidgetValidator()
+        self.assertRaises(AssertionError, lambda: v.add_rule('not callable', 'msg'))
+        self.assertRaises(AssertionError, lambda: v.add_rule(lambda x: True, ''))
+        self.assertRaises(AssertionError, lambda: v.add_rule(lambda x: True, 123))
+
+    # ------------------------------------------------------------------
+    # Built-in rule factories
+    # ------------------------------------------------------------------
+
+    def test_required_pass(self) -> None:
+        pred, msg = required()
+        self.assertTrue(pred('hello'))
+        self.assertTrue(pred(0))
+        self.assertTrue(pred(False))
+
+    def test_required_fail(self) -> None:
+        pred, msg = required()
+        self.assertFalse(pred(''))
+        self.assertFalse(pred('   '))
+        self.assertFalse(pred(None))
+        self.assertEqual(msg, 'This field is required')
+
+    def test_required_custom_message(self) -> None:
+        pred, msg = required('Please fill in')
+        self.assertEqual(msg, 'Please fill in')
+
+    def test_min_length_pass(self) -> None:
+        pred, msg = min_length(3)
+        self.assertTrue(pred('abc'))
+        self.assertTrue(pred('abcd'))
+
+    def test_min_length_fail(self) -> None:
+        pred, msg = min_length(3)
+        self.assertFalse(pred('ab'))
+        self.assertFalse(pred(''))
+        self.assertFalse(pred(123))  # not a string
+
+    def test_min_length_zero(self) -> None:
+        pred, _ = min_length(0)
+        self.assertTrue(pred(''))
+
+    def test_max_length_pass(self) -> None:
+        pred, _ = max_length(5)
+        self.assertTrue(pred('abc'))
+        self.assertTrue(pred(''))
+        self.assertTrue(pred('12345'))
+
+    def test_max_length_fail(self) -> None:
+        pred, _ = max_length(5)
+        self.assertFalse(pred('123456'))
+        self.assertFalse(pred(123))  # not a string
+
+    def test_matches_pattern_pass(self) -> None:
+        pred, _ = matches_pattern(r'[A-Z]{3}\d{2}')
+        self.assertTrue(pred('ABC12'))
+
+    def test_matches_pattern_fail(self) -> None:
+        pred, _ = matches_pattern(r'[A-Z]{3}\d{2}')
+        self.assertFalse(pred('abc12'))
+        self.assertFalse(pred('AB12'))
+        self.assertFalse(pred(123))
+
+    def test_matches_pattern_custom_message(self) -> None:
+        _, msg = matches_pattern(r'\d+', 'numbers only')
+        self.assertEqual(msg, 'numbers only')
+
+    def test_in_range_pass(self) -> None:
+        pred, _ = in_range(0, 100)
+        self.assertTrue(pred(50))
+        self.assertTrue(pred(0))
+        self.assertTrue(pred(100))
+        self.assertTrue(pred('42'))  # string coerced to float
+
+    def test_in_range_fail(self) -> None:
+        pred, _ = in_range(0, 100)
+        self.assertFalse(pred(-1))
+        self.assertFalse(pred(101))
+        self.assertFalse(pred('abc'))  # not numeric
+        self.assertFalse(pred(None))
+
+    def test_in_range_bad_bounds(self) -> None:
+        self.assertRaises(AssertionError, lambda: in_range(10, 5))
+
+    # ------------------------------------------------------------------
+    # Widget integration
+    # ------------------------------------------------------------------
+
+    def test_widget_no_validator_by_default(self) -> None:
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button('Test')
+        self.assertIsNone(btn.get_validator())
+
+    def test_widget_set_validator(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Name: ')
+        v = WidgetValidator().add_rule(*required())
+        ti.set_validator(v)
+        self.assertIs(ti.get_validator(), v)
+
+    def test_widget_clear_validator(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Name: ')
+        ti.set_validator(WidgetValidator().add_rule(*required()))
+        ti.set_validator(None)
+        self.assertIsNone(ti.get_validator())
+
+    def test_widget_set_validator_invalid(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Name: ')
+        self.assertRaises(AssertionError, lambda: ti.set_validator('bad'))
+
+    def test_widget_validate_required(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Name: ')
+        v = WidgetValidator().add_rule(*required())
+        ti.set_validator(v)
+        # Empty input should fail
+        errors = ti.validate()
+        self.assertEqual(len(errors), 1)
+        self.assertFalse(ti.is_valid())
+
+    def test_widget_validate_with_value(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Name: ', default='Alice')
+        v = WidgetValidator().add_rule(*required())
+        ti.set_validator(v)
+        self.assertTrue(ti.is_valid())
+
+    def test_widget_validate_min_length(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Code: ', default='AB')
+        v = WidgetValidator().add_rule(*min_length(3))
+        ti.set_validator(v)
+        self.assertFalse(ti.is_valid())
+
+    def test_widget_validate_no_rules(self) -> None:
+        """A validator with no rules always passes."""
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('X: ')
+        ti.set_validator(WidgetValidator())
+        self.assertTrue(ti.is_valid())
+        self.assertEqual(ti.get_validation_errors(), [])
+
+    def test_widget_validate_no_validator(self) -> None:
+        """Without a validator, validate() returns empty list."""
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('X: ')
+        self.assertEqual(ti.validate(), [])
+        self.assertTrue(ti.is_valid())
+
+    def test_widget_validate_non_input(self) -> None:
+        """Button has no get_value — validate gracefully returns empty."""
+        menu = MenuUtils.generic_menu()
+        btn = menu.add.button('OK')
+        v = WidgetValidator().add_rule(*required())
+        btn.set_validator(v)
+        # Button raises ValueError on get_value, so validate() should return []
+        self.assertEqual(btn.validate(), [])
+
+    def test_widget_get_validation_errors(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('E: ')
+        v = WidgetValidator().add_rule(*required()).add_rule(*min_length(5))
+        ti.set_validator(v)
+        ti.validate()
+        errors = ti.get_validation_errors()
+        self.assertEqual(len(errors), 2)
+
+    # ------------------------------------------------------------------
+    # Validator via kwargs
+    # ------------------------------------------------------------------
+
+    def test_validator_via_kwargs(self) -> None:
+        menu = MenuUtils.generic_menu()
+        v = WidgetValidator().add_rule(*required())
+        ti = menu.add.text_input('Name: ', validator=v)
+        self.assertIs(ti.get_validator(), v)
+
+    def test_validator_via_kwargs_none(self) -> None:
+        menu = MenuUtils.generic_menu()
+        ti = menu.add.text_input('Name: ')
+        self.assertIsNone(ti.get_validator())
+
+    def test_validator_via_kwargs_button(self) -> None:
+        menu = MenuUtils.generic_menu()
+        v = WidgetValidator().add_rule(*required())
+        btn = menu.add.button('OK', validator=v)
+        self.assertIs(btn.get_validator(), v)
+
+    def test_validator_kwarg_invalid(self) -> None:
+        menu = MenuUtils.generic_menu()
+        self.assertRaises(
+            AssertionError,
+            lambda: menu.add.text_input('Name: ', validator='bad')
+        )
+
+    # ------------------------------------------------------------------
+    # Menu-level validation
+    # ------------------------------------------------------------------
+
+    def test_menu_validate_widgets_empty(self) -> None:
+        menu = MenuUtils.generic_menu()
+        menu.add.button('OK')
+        self.assertEqual(menu.validate_widgets(), {})
+        self.assertTrue(menu.is_valid())
+
+    def test_menu_validate_widgets_pass(self) -> None:
+        menu = MenuUtils.generic_menu()
+        v = WidgetValidator().add_rule(*required())
+        ti = menu.add.text_input('Name: ', default='Alice', validator=v)
+        self.assertEqual(menu.validate_widgets(), {})
+        self.assertTrue(menu.is_valid())
+
+    def test_menu_validate_widgets_fail(self) -> None:
+        menu = MenuUtils.generic_menu()
+        v = WidgetValidator().add_rule(*required())
+        ti = menu.add.text_input('Name: ', validator=v)
+        result = menu.validate_widgets()
+        self.assertIn(ti.get_id(), result)
+        self.assertGreater(len(result[ti.get_id()]), 0)
+        self.assertFalse(menu.is_valid())
+
+    def test_menu_validate_multiple_widgets(self) -> None:
+        menu = MenuUtils.generic_menu()
+        v1 = WidgetValidator().add_rule(*required())
+        v2 = WidgetValidator().add_rule(*min_length(3))
+        ti1 = menu.add.text_input('A: ', validator=v1)
+        ti2 = menu.add.text_input('B: ', default='XY', validator=v2)
+        result = menu.validate_widgets()
+        self.assertIn(ti1.get_id(), result)
+        self.assertIn(ti2.get_id(), result)
+
+    def test_menu_validate_mixed(self) -> None:
+        """One widget valid, one invalid."""
+        menu = MenuUtils.generic_menu()
+        v1 = WidgetValidator().add_rule(*required())
+        v2 = WidgetValidator().add_rule(*required())
+        ti1 = menu.add.text_input('A: ', default='OK', validator=v1)
+        ti2 = menu.add.text_input('B: ', validator=v2)
+        result = menu.validate_widgets()
+        self.assertNotIn(ti1.get_id(), result)
+        self.assertIn(ti2.get_id(), result)
+
+    def test_menu_validate_widgets_without_validator(self) -> None:
+        """Widgets without validators are skipped."""
+        menu = MenuUtils.generic_menu()
+        menu.add.text_input('No val: ')
+        menu.add.button('OK')
+        self.assertEqual(menu.validate_widgets(), {})
+
