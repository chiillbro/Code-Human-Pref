new file mode 100644
index 00000000..b5639b01
--- /dev/null
+++ b/pygame_menu/widgets/core/validation.py
@@ -0,0 +1,214 @@
+"""
+pygame-menu
+https://github.com/ppizarror/pygame-menu
+
+WIDGET VALIDATION
+Provides per-widget validation rules with visual error feedback.
+A WidgetValidator holds an ordered list of rules (callable + error message pairs).
+When validated, it runs each rule against the widget's current value and collects
+any error messages for rules that fail.
+
+Built-in rule factories:
+    - ``required()``          – value must not be empty
+    - ``min_length(n)``       – string length >= n
+    - ``max_length(n)``       – string length <= n
+    - ``matches_pattern(p)``  – value matches regex pattern
+    - ``in_range(lo, hi)``    – numeric value within [lo, hi]
+"""
+
+__all__ = [
+    'WidgetValidator',
+    'required',
+    'min_length',
+    'max_length',
+    'matches_pattern',
+    'in_range',
+]
+
+import re
+from typing import Any, Callable, List, Optional, Tuple
+
+
+# ---------------------------------------------------------------------------
+# Type alias for a single rule: (predicate, error_message)
+# ---------------------------------------------------------------------------
+ValidationRule = Tuple[Callable[[Any], bool], str]
+
+
+# ---------------------------------------------------------------------------
+# WidgetValidator
+# ---------------------------------------------------------------------------
+
+class WidgetValidator:
+    """
+    Holds an ordered sequence of validation rules and can run them against a
+    value.  Each rule is a ``(predicate, message)`` pair where *predicate* is a
+    callable that receives the widget value and returns ``True`` when the value
+    is **valid**.  When a predicate returns ``False``, the corresponding
+    *message* is collected as an error.
+    """
+
+    def __init__(self) -> None:
+        self._rules: List[ValidationRule] = []
+
+    # -- mutators -----------------------------------------------------------
+
+    def add_rule(self, predicate: Callable[[Any], bool], message: str) -> 'WidgetValidator':
+        """
+        Append a validation rule.
+
+        :param predicate: Callable(value) -> bool.  Must return True if valid.
+        :param message: Human-readable error message shown when the rule fails.
+        :return: Self reference (for chaining)
+        """
+        assert callable(predicate), 'predicate must be callable'
+        assert isinstance(message, str) and len(message) > 0, \
+            'message must be a non-empty string'
+        self._rules.append((predicate, message))
+        return self
+
+    def clear_rules(self) -> 'WidgetValidator':
+        """
+        Remove all rules.
+
+        :return: Self reference
+        """
+        self._rules.clear()
+        return self
+
+    # -- queries ------------------------------------------------------------
+
+    def validate(self, value: Any) -> List[str]:
+        """
+        Run every rule against *value* and return a list of error messages for
+        rules that failed.  An empty list means the value is valid.
+
+        :param value: The widget value to validate
+        :return: List of error message strings (empty if valid)
+        """
+        errors: List[str] = []
+        for predicate, message in self._rules:
+            try:
+                if not predicate(value):
+                    errors.append(message)
+            except Exception:
+                # If the predicate itself raises (e.g. type mismatch),
+                # treat it as a validation failure.
+                errors.append(message)
+        return errors
+
+    def is_valid(self, value: Any) -> bool:
+        """
+        Convenience boolean check.
+
+        :param value: The widget value to validate
+        :return: True if all rules pass
+        """
+        return len(self.validate(value)) == 0
+
+    def has_rules(self) -> bool:
+        """
+        Return True if at least one rule has been added.
+
+        :return: True if rules exist
+        """
+        return len(self._rules) > 0
+
+
+# ---------------------------------------------------------------------------
+# Built-in rule factories
+# ---------------------------------------------------------------------------
+
+def required(message: Optional[str] = None) -> ValidationRule:
+    """
+    Value must not be empty (empty string / None).
+
+    :param message: Custom error message
+    :return: (predicate, message) tuple
+    """
+    msg = message or 'This field is required'
+
+    def _check(value: Any) -> bool:
+        if value is None:
+            return False
+        if isinstance(value, str) and value.strip() == '':
+            return False
+        return True
+
+    return _check, msg
+
+
+def min_length(n: int, message: Optional[str] = None) -> ValidationRule:
+    """
+    String value must have length >= *n*.
+
+    :param n: Minimum length
+    :param message: Custom error message
+    :return: (predicate, message) tuple
+    """
+    assert isinstance(n, int) and n >= 0
+    msg = message or f'Must be at least {n} characters'
+
+    def _check(value: Any) -> bool:
+        return isinstance(value, str) and len(value) >= n
+
+    return _check, msg
+
+
+def max_length(n: int, message: Optional[str] = None) -> ValidationRule:
+    """
+    String value must have length <= *n*.
+
+    :param n: Maximum length
+    :param message: Custom error message
+    :return: (predicate, message) tuple
+    """
+    assert isinstance(n, int) and n >= 0
+    msg = message or f'Must be at most {n} characters'
+
+    def _check(value: Any) -> bool:
+        return isinstance(value, str) and len(value) <= n
+
+    return _check, msg
+
+
+def matches_pattern(pattern: str, message: Optional[str] = None) -> ValidationRule:
+    """
+    String value must fully match the given regex *pattern*.
+
+    :param pattern: Regular expression pattern
+    :param message: Custom error message
+    :return: (predicate, message) tuple
+    """
+    assert isinstance(pattern, str) and len(pattern) > 0
+    compiled = re.compile(pattern)
+    msg = message or f'Must match pattern: {pattern}'
+
+    def _check(value: Any) -> bool:
+        if not isinstance(value, str):
+            return False
+        return compiled.fullmatch(value) is not None
+
+    return _check, msg
+
+
+def in_range(lo: float, hi: float, message: Optional[str] = None) -> ValidationRule:
+    """
+    Numeric value must be within [*lo*, *hi*] inclusive.
+
+    :param lo: Minimum value (inclusive)
+    :param hi: Maximum value (inclusive)
+    :param message: Custom error message
+    :return: (predicate, message) tuple
+    """
+    assert lo <= hi, 'lo must be <= hi'
+    msg = message or f'Must be between {lo} and {hi}'
+
+    def _check(value: Any) -> bool:
+        try:
+            v = float(value)
+        except (TypeError, ValueError):
+            return False
+        return lo <= v <= hi
+
+    return _check, msg
